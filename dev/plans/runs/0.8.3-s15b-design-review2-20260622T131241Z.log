    58	def enrich_doc(body: str, graph: dict) -> str:
    59	    """Append the doc's extracted entities + fact-triples to its body (one row per
    60	    doc). Deterministic; entity names deduped order-preserving; no-op on empty graph."""
    61	    ents, facts = _entities(graph), _facts(graph)
    62	    if not ents and not facts:
    63	        return body
    64	    blocks = []
    65	    if ents:
    66	        blocks.append("[entities] " + "; ".join(ents))
    67	    if facts:
    68	        blocks.append("[facts] " + "; ".join(facts))
    69	    return body + "\n\n" + "\n".join(blocks)
