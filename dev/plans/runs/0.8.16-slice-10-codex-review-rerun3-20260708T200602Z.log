   370	    fn embed(&self, input: &str) -> Result<Vector, EmbedderError> {
   371	        let encoding = self.tokenizer.encode(input, true).map_err(|e| err("tokenize", e))?;
   372	        let ids: Vec<i64> = encoding.get_ids().iter().map(|&x| i64::from(x)).collect();
   373	        let mask: Vec<i64> = encoding.get_attention_mask().iter().map(|&x| i64::from(x)).collect();
   374	        let len = ids.len();
   375	        let token_type: Vec<i64> = vec![0; len];
   376	        let shape = vec![1_i64, len as i64];
   377	
   378	        let ids_t = Tensor::from_array((shape.clone(), ids)).map_err(|e| err("input_ids", e))?;
   379	        let mask_t =
   380	            Tensor::from_array((shape.clone(), mask)).map_err(|e| err("attention_mask", e))?;
   381	        let tt_t = Tensor::from_array((shape, token_type)).map_err(|e| err("token_type_ids", e))?;
   382	
   383	        let mut session = self.session.lock().map_err(|_| err("session lock", "poisoned"))?;
   384	        let outputs = session
   385	            .run(ort::inputs![
   386	                "input_ids" => ids_t,
   387	                "attention_mask" => mask_t,
   388	                "token_type_ids" => tt_t,
   389	            ])
   390	            .map_err(|e| err("forward", e))?;
   391	
   392	        // last_hidden_state — first output, shape (1, L, H).
   393	        let (out_shape, data) =
   394	            outputs[0].try_extract_tensor::<f32>().map_err(|e| err("extract", e))?;
   395	        let dims: Vec<usize> = out_shape.iter().map(|&d| d as usize).collect();
   396	        if dims.len() != 3 {
   397	            return Err(err("output shape", format!("expected rank-3 (1,L,H), got {dims:?}")));
   398	        }
   399	        let (seq_len, hidden) = (dims[1], dims[2]);
   400	        if hidden != ORT_BGE_EMBEDDER_DIM as usize {
   401	            return Err(err(
   402	                "output dim",
   403	                format!("expected hidden {ORT_BGE_EMBEDDER_DIM}, got {hidden}"),
   404	            ));
   405	        }
   406	
   407	        // Pool. `embed()` is single-input (no padding), so the attention mask is
   408	        // all-ones and mean-pool reduces to a plain mean over `seq_len`.
   409	        let mut pooled = vec![0.0_f32; hidden];
   410	        match self.pooling {
   411	            OrtPooling::Cls => {
   412	                pooled.copy_from_slice(&data[0..hidden]);
   413	            }
   414	            OrtPooling::Mean => {
   415	                for pos in 0..seq_len {
   416	                    let base = pos * hidden;
   417	                    for (j, slot) in pooled.iter_mut().enumerate() {
   418	                        *slot += data[base + j];
   419	                    }
   420	                }
   421	                let denom = seq_len.max(1) as f32;
   422	                for slot in &mut pooled {
   423	                    *slot /= denom;
   424	                }
   425	            }
   426	        }
   427	
   428	        // L2-normalize (matches candle's `l2_normalize`).
   429	        let norm = pooled.iter().map(|v| v * v).sum::<f32>().sqrt().max(1e-12);
   430	        for slot in &mut pooled {
   431	            *slot /= norm;
   432	        }
   433	        Ok(pooled)
   434	    }
   435	}
