{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UMbhbYadBBUt2AykUHGnwP","type":"tool_result","content":"admin.py\nconfig.py\nengine.py\nerrors.py\n_fathomdb.pyi\n__init__.py\ntypes.py\n---\n\"\"\"FathomDB Python SDK public surface.\n\nTop-level five-verb surface and exception hierarchy owned by\n`dev/interfaces/python.md` + `dev/design/errors.md`. The package delegates\nto the native PyO3 extension `fathomdb._fathomdb` which binds to\n`fathomdb-engine`.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom fathomdb import _fathomdb as _native  # noqa: F401 — load native extension\nfrom fathomdb import admin, errors\nfrom fathomdb.config import EngineConfig\nfrom fathomdb.engine import Engine\nfrom fathomdb.types import (\n    CounterSnapshot,\n    SearchResult,\n    SoftFallback,\n    SoftFallbackBranch,\n    WriteReceipt,\n)\n\n__all__ = [\n    \"CounterSnapshot\",\n    \"Engine\",\n    \"EngineConfig\",\n    \"SearchResult\",\n    \"SoftFallback\",\n    \"SoftFallbackBranch\",\n    \"WriteReceipt\",\n    \"__version__\",\n    \"admin\",\n    \"errors\",\n]\n__version__ = \"0.6.0\"","is_error":false}]},"parent_tool_use_id":null,"session_id":"c409cac9-fa4a-4d9f-9db5-55aae00050c6","uuid":"6d7d6beb-9b38-4cf8-a83a-bbcf514fe7d7","timestamp":"2026-05-17T21:02:33.300Z","tool_use_result":{"stdout":"admin.py\nconfig.py\nengine.py\nerrors.py\n_fathomdb.pyi\n__init__.py\ntypes.py\n---\n\"\"\"FathomDB Python SDK public surface.\n\nTop-level five-verb surface and exception hierarchy owned by\n`dev/interfaces/python.md` + `dev/design/errors.md`. The package delegates\nto the native PyO3 extension `fathomdb._fathomdb` which binds to\n`fathomdb-engine`.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom fathomdb import _fathomdb as _native  # noqa: F401 — load native extension\nfrom fathomdb import admin, errors\nfrom fathomdb.config import EngineConfig\nfrom fathomdb.engine import Engine\nfrom fathomdb.types import (\n    CounterSnapshot,\n    SearchResult,\n    SoftFallback,\n    SoftFallbackBranch,\n    WriteReceipt,\n)\n\n__all__ = [\n    \"CounterSnapshot\",\n    \"Engine\",\n    \"EngineConfig\",\n    \"SearchResult\",\n    \"SoftFallback\",\n    \"SoftFallbackBranch\",\n    \"WriteReceipt\",\n    \"__version__\",\n    \"admin\",\n    \"errors\",\n]\n__version__ = \"0.6.0\"","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
