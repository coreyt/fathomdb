{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UTCN2y64jDHdA344dkJdCX","type":"tool_result","content":"1\t\"\"\"Caller-visible result shapes for the FathomDB Python SDK.\n2\t\n3\tField names owned by `dev/interfaces/python.md` § Caller-visible data shapes.\n4\t\"\"\"\n5\t\n6\tfrom __future__ import annotations\n7\t\n8\tfrom dataclasses import dataclass, field\n9\tfrom typing import Literal\n10\t\n11\t#: Typed soft-fallback branch values per `dev/design/retrieval.md`.\n12\tSoftFallbackBranch = Literal[\"vector\", \"text\"]\n13\t\n14\t\n15\t@dataclass(frozen=True)\n16\tclass WriteReceipt:\n17\t    \"\"\"Receipt returned by `engine.write` and `admin.configure`.\"\"\"\n18\t\n19\t    cursor: int\n20\t\n21\t\n22\t@dataclass(frozen=True)\n23\tclass SoftFallback:\n24\t    \"\"\"Hybrid-search soft-fallback signal.\n25\t\n26\t    `branch` indicates which non-essential branch could not contribute. Total\n27\t    request failure is not expressed via this carrier (see\n28\t    `dev/design/retrieval.md`).\n29\t    \"\"\"\n30\t\n31\t    branch: SoftFallbackBranch\n32\t\n33\t\n34\t@dataclass(frozen=True)\n35\tclass SearchResult:\n36\t    \"\"\"Result returned by `engine.search`.\"\"\"\n37\t\n38\t    projection_cursor: int\n39\t    soft_fallback: SoftFallback | None = None\n40\t    results: list[str] = field(default_factory=list)\n41\t\n42\t\n43\t@dataclass(frozen=True)\n44\tclass CounterSnapshot:\n45\t    \"\"\"Snapshot of engine-internal counters returned by `engine.counters`.\n46\t\n47\t    Field set mirrors the napi-rs `CounterSnapshot` in idiomatic snake_case\n48\t    per `dev/interfaces/python.md` § Engine-attached instrumentation and the\n49\t    cross-binding data-shape parity claim in `dev/design/bindings.md` § 1.\n50\t    \"\"\"\n51\t\n52\t    queries: int = 0\n53\t    writes: int = 0\n54\t    write_rows: int = 0\n55\t    admin_ops: int = 0\n56\t    cache_hit: int = 0\n57\t    cache_miss: int = 0\n58\t\n59\t\n60\t__all__ = [\n61\t    \"CounterSnapshot\",\n62\t    \"SearchResult\",\n63\t    \"SoftFallback\",\n64\t    \"SoftFallbackBranch\",\n65\t    \"WriteReceipt\",\n66\t]\n67\t"}]},"parent_tool_use_id":null,"session_id":"c409cac9-fa4a-4d9f-9db5-55aae00050c6","uuid":"12ab58fb-54e7-4fbd-8409-fa6249ed7798","timestamp":"2026-05-17T21:02:48.201Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-DX-external-user-docs-20260517T210205Z/src/python/fathomdb/types.py","content":"\"\"\"Caller-visible result shapes for the FathomDB Python SDK.\n\nField names owned by `dev/interfaces/python.md` § Caller-visible data shapes.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom dataclasses import dataclass, field\nfrom typing import Literal\n\n#: Typed soft-fallback branch values per `dev/design/retrieval.md`.\nSoftFallbackBranch = Literal[\"vector\", \"text\"]\n\n\n@dataclass(frozen=True)\nclass WriteReceipt:\n    \"\"\"Receipt returned by `engine.write` and `admin.configure`.\"\"\"\n\n    cursor: int\n\n\n@dataclass(frozen=True)\nclass SoftFallback:\n    \"\"\"Hybrid-search soft-fallback signal.\n\n    `branch` indicates which non-essential branch could not contribute. Total\n    request failure is not expressed via this carrier (see\n    `dev/design/retrieval.md`).\n    \"\"\"\n\n    branch: SoftFallbackBranch\n\n\n@dataclass(frozen=True)\nclass SearchResult:\n    \"\"\"Result returned by `engine.search`.\"\"\"\n\n    projection_cursor: int\n    soft_fallback: SoftFallback | None = None\n    results: list[str] = field(default_factory=list)\n\n\n@dataclass(frozen=True)\nclass CounterSnapshot:\n    \"\"\"Snapshot of engine-internal counters returned by `engine.counters`.\n\n    Field set mirrors the napi-rs `CounterSnapshot` in idiomatic snake_case\n    per `dev/interfaces/python.md` § Engine-attached instrumentation and the\n    cross-binding data-shape parity claim in `dev/design/bindings.md` § 1.\n    \"\"\"\n\n    queries: int = 0\n    writes: int = 0\n    write_rows: int = 0\n    admin_ops: int = 0\n    cache_hit: int = 0\n    cache_miss: int = 0\n\n\n__all__ = [\n    \"CounterSnapshot\",\n    \"SearchResult\",\n    \"SoftFallback\",\n    \"SoftFallbackBranch\",\n    \"WriteReceipt\",\n]\n","numLines":67,"startLine":1,"totalLines":67}}}
