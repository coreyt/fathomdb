{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Bau8TBW8Vh7CGLHZgf6c89","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t# scripts/release/smoke/smoke-pypi-wheel.sh — AC-056 PyPI smoke.\n3\t#\n4\t#   $1 = version (e.g. 0.6.0)\n5\t#\n6\t# Installs fathomdb==$1 from PyPI into a fresh venv, exercises the SDK\n7\t# end-to-end (open + write empty batch + search + close), and asserts\n8\t# the python process exits cleanly. Per `feedback_release_verification`:\n9\t# the wheel-on-disk lock cleanup + process exit are the bug signal that\n10\t# only fires under real install-from-registry conditions.\n11\tset -euo pipefail\n12\t\n13\tif [ \"$#\" -ne 1 ]; then\n14\t  printf 'usage: %s <version>\\n' \"$0\" >&2\n15\t  exit 2\n16\tfi\n17\tVERSION=\"$1\"\n18\tif ! printf '%s' \"$VERSION\" | grep -qE '^[0-9]+\\.[0-9]+\\.[0-9]+$'; then\n19\t  printf 'smoke-pypi-wheel: invalid version \"%s\" — expected semver MAJOR.MINOR.PATCH\\n' \\\n20\t    \"$VERSION\" >&2\n21\t  exit 2\n22\tfi\n23\t\n24\tWORK=\"$(mktemp -d)\"\n25\ttrap 'rm -rf \"$WORK\"' EXIT\n26\t\n27\tpython3 -m venv \"$WORK/venv\"\n28\t# shellcheck source=/dev/null\n29\t. \"$WORK/venv/bin/activate\"\n30\tpip install --quiet --upgrade pip\n31\tpip install --quiet \"fathomdb==${VERSION}\"\n32\t\n33\tDB=\"$WORK/smoke.fdb\"\n34\tpython3 - \"$DB\" <<'PY'\n35\timport sys\n36\tfrom fathomdb import Engine\n37\tdb_path = sys.argv[1]\n38\te = Engine.open(db_path)\n39\te.write([])\n40\te.search(\"smoke\")\n41\te.close()\n42\tprint(\"ok\")\n43\tPY\n44\t\n45\tprintf 'smoke-pypi-wheel: ok — fathomdb %s installed + open/write/search/close + process exit clean\\n' \\\n46\t  \"$VERSION\"\n47\t"}]},"parent_tool_use_id":null,"session_id":"c409cac9-fa4a-4d9f-9db5-55aae00050c6","uuid":"157c1d34-b6dc-4e32-97fb-00bff103d88e","timestamp":"2026-05-17T21:02:19.320Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-DX-external-user-docs-20260517T210205Z/scripts/release/smoke/smoke-pypi-wheel.sh","content":"#!/usr/bin/env bash\n# scripts/release/smoke/smoke-pypi-wheel.sh — AC-056 PyPI smoke.\n#\n#   $1 = version (e.g. 0.6.0)\n#\n# Installs fathomdb==$1 from PyPI into a fresh venv, exercises the SDK\n# end-to-end (open + write empty batch + search + close), and asserts\n# the python process exits cleanly. Per `feedback_release_verification`:\n# the wheel-on-disk lock cleanup + process exit are the bug signal that\n# only fires under real install-from-registry conditions.\nset -euo pipefail\n\nif [ \"$#\" -ne 1 ]; then\n  printf 'usage: %s <version>\\n' \"$0\" >&2\n  exit 2\nfi\nVERSION=\"$1\"\nif ! printf '%s' \"$VERSION\" | grep -qE '^[0-9]+\\.[0-9]+\\.[0-9]+$'; then\n  printf 'smoke-pypi-wheel: invalid version \"%s\" — expected semver MAJOR.MINOR.PATCH\\n' \\\n    \"$VERSION\" >&2\n  exit 2\nfi\n\nWORK=\"$(mktemp -d)\"\ntrap 'rm -rf \"$WORK\"' EXIT\n\npython3 -m venv \"$WORK/venv\"\n# shellcheck source=/dev/null\n. \"$WORK/venv/bin/activate\"\npip install --quiet --upgrade pip\npip install --quiet \"fathomdb==${VERSION}\"\n\nDB=\"$WORK/smoke.fdb\"\npython3 - \"$DB\" <<'PY'\nimport sys\nfrom fathomdb import Engine\ndb_path = sys.argv[1]\ne = Engine.open(db_path)\ne.write([])\ne.search(\"smoke\")\ne.close()\nprint(\"ok\")\nPY\n\nprintf 'smoke-pypi-wheel: ok — fathomdb %s installed + open/write/search/close + process exit clean\\n' \\\n  \"$VERSION\"\n","numLines":47,"startLine":1,"totalLines":47}}}
