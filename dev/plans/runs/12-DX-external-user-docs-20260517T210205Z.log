{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Kv7sNupNsiWcFz45nY2NvS","type":"tool_result","content":"1\t\"\"\"Single-rooted exception hierarchy for the FathomDB Python SDK.\n2\t\n3\tLayout owned by `dev/design/errors.md` § Binding-facing class matrix and\n4\t`dev/design/bindings.md` § 3. Concrete leaf classes are created by the\n5\tPyO3 binding (`fathomdb._fathomdb`); they inherit from `EngineError`\n6\twhich inherits from Python `Exception`. Typed payload attributes\n7\t(`holder_pid`, `kind`, `stage`, `recovery_hint_code`, `doc_anchor`,\n8\t`stored`, `supplied`, `stored_name`, `stored_revision`, `supplied_name`,\n9\t`supplied_revision`) are set by the binding's\n10\t`engine_error_to_py` / `engine_open_error_to_py` translators on raise.\n11\t\n12\tFor Python-only construction with typed kwargs (used by binding tests),\n13\t`_install_typed_init` layers a keyword-only `__init__` onto each\n14\tPyO3-created class that stores the documented payload fields as\n15\tinstance attributes.\n16\t\"\"\"\n17\t\n18\tfrom __future__ import annotations\n19\t\n20\tfrom fathomdb._fathomdb import (\n21\t    ClosingError as _ClosingError,\n22\t)\n23\tfrom fathomdb._fathomdb import (\n24\t    CorruptionError as _CorruptionError,\n25\t)\n26\tfrom fathomdb._fathomdb import (\n27\t    DatabaseLockedError as _DatabaseLockedError,\n28\t)\n29\tfrom fathomdb._fathomdb import (\n30\t    EmbedderDimensionMismatchError as _EmbedderDimensionMismatchError,\n31\t)\n32\tfrom fathomdb._fathomdb import (\n33\t    EmbedderError as _EmbedderError,\n34\t)\n35\tfrom fathomdb._fathomdb import (\n36\t    EmbedderNotConfiguredError as _EmbedderNotConfiguredError,\n37\t)\n38\tfrom fathomdb._fathomdb import (\n39\t    EmbedderIdentityMismatchError as _EmbedderIdentityMismatchError,\n40\t)\n41\tfrom fathomdb._fathomdb import (\n42\t    EngineError as _EngineError,\n43\t)\n44\tfrom fathomdb._fathomdb import (\n45\t    IncompatibleSchemaVersionError as _IncompatibleSchemaVersionError,\n46\t)\n47\tfrom fathomdb._fathomdb import (\n48\t    MigrationError as _MigrationError,\n49\t)\n50\tfrom fathomdb._fathomdb import (\n51\t    OpStoreError as _OpStoreError,\n52\t)\n53\tfrom fathomdb._fathomdb import (\n54\t    OverloadedError as _OverloadedError,\n55\t)\n56\tfrom fathomdb._fathomdb import (\n57\t    ProjectionError as _ProjectionError,\n58\t)\n59\tfrom fathomdb._fathomdb import (\n60\t    SchedulerError as _SchedulerError,\n61\t)\n62\tfrom fathomdb._fathomdb import (\n63\t    SchemaValidationError as _SchemaValidationError,\n64\t)\n65\tfrom fathomdb._fathomdb import (\n66\t    StorageError as _StorageError,\n67\t)\n68\tfrom fathomdb._fathomdb import (\n69\t    KindNotVectorIndexedError as _KindNotVectorIndexedError,\n70\t)\n71\tfrom fathomdb._fathomdb import (\n72\t    VectorError as _VectorError,\n73\t)\n74\tfrom fathomdb._fathomdb import (\n75\t    WriteValidationError as _WriteValidationError,\n76\t)\n77\t\n78\tEngineError = _EngineError\n79\tStorageError = _StorageError\n80\tProjectionError = _ProjectionError\n81\tVectorError = _VectorError\n82\tEmbedderError = _EmbedderError\n83\tEmbedderNotConfiguredError = _EmbedderNotConfiguredError\n84\tKindNotVectorIndexedError = _KindNotVectorIndexedError\n85\tSchedulerError = _SchedulerError\n86\tOpStoreError = _OpStoreError\n87\tWriteValidationError = _WriteValidationError\n88\tSchemaValidationError = _SchemaValidationError\n89\tOverloadedError = _OverloadedError\n90\tClosingError = _ClosingError\n91\tDatabaseLockedError = _DatabaseLockedError\n92\tCorruptionError = _CorruptionError\n93\tIncompatibleSchemaVersionError = _IncompatibleSchemaVersionError\n94\tMigrationError = _MigrationError\n95\tEmbedderIdentityMismatchError = _EmbedderIdentityMismatchError\n96\tEmbedderDimensionMismatchError = _EmbedderDimensionMismatchError\n97\t\n98\t\n99\tdef _install_typed_init(cls: type, fields: tuple[str, ...]) -> None:\n100\t    def __init__(self, *args, **kwargs):  # type: ignore[no-untyped-def]\n101\t        payload = {name: kwargs.pop(name, None) for name in fields}\n102\t        if kwargs:\n103\t            unexpected = \", \".join(sorted(kwargs))\n104\t            raise TypeError(f\"unexpected keyword arguments: {unexpected}\")\n105\t        Exception.__init__(self, *args)\n106\t        for name, value in payload.items():\n107\t            object.__setattr__(self, name, value)\n108\t\n109\t    cls.__init__ = __init__  # type: ignore[method-assign]\n110\t\n111\t\n112\t_install_typed_init(DatabaseLockedError, (\"holder_pid\",))\n113\t_install_typed_init(\n114\t    CorruptionError,\n115\t    (\"kind\", \"stage\", \"recovery_hint_code\", \"doc_anchor\"),\n116\t)\n117\t_install_typed_init(\n118\t    EmbedderIdentityMismatchError,\n119\t    (\"stored_name\", \"stored_revision\", \"supplied_name\", \"supplied_revision\"),\n120\t)\n121\t_install_typed_init(EmbedderDimensionMismatchError, (\"stored\", \"supplied\"))\n122\t\n123\t\n124\t__all__ = [\n125\t    \"ClosingError\",\n126\t    \"CorruptionError\",\n127\t    \"DatabaseLockedError\",\n128\t    \"EmbedderDimensionMismatchError\",\n129\t    \"EmbedderError\",\n130\t    \"EmbedderIdentityMismatchError\",\n131\t    \"EmbedderNotConfiguredError\",\n132\t    \"EngineError\",\n133\t    \"IncompatibleSchemaVersionError\",\n134\t    \"KindNotVectorIndexedError\",\n135\t    \"MigrationError\",\n136\t    \"OpStoreError\",\n137\t    \"OverloadedError\",\n138\t    \"ProjectionError\",\n139\t    \"SchedulerError\",\n140\t    \"SchemaValidationError\",\n141\t    \"StorageError\",\n142\t    \"VectorError\",\n143\t    \"WriteValidationError\",\n144\t]\n145\t"}]},"parent_tool_use_id":null,"session_id":"c409cac9-fa4a-4d9f-9db5-55aae00050c6","uuid":"47858e65-a1a5-4241-9381-d3837aa06042","timestamp":"2026-05-17T21:02:47.864Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-DX-external-user-docs-20260517T210205Z/src/python/fathomdb/errors.py","content":"\"\"\"Single-rooted exception hierarchy for the FathomDB Python SDK.\n\nLayout owned by `dev/design/errors.md` § Binding-facing class matrix and\n`dev/design/bindings.md` § 3. Concrete leaf classes are created by the\nPyO3 binding (`fathomdb._fathomdb`); they inherit from `EngineError`\nwhich inherits from Python `Exception`. Typed payload attributes\n(`holder_pid`, `kind`, `stage`, `recovery_hint_code`, `doc_anchor`,\n`stored`, `supplied`, `stored_name`, `stored_revision`, `supplied_name`,\n`supplied_revision`) are set by the binding's\n`engine_error_to_py` / `engine_open_error_to_py` translators on raise.\n\nFor Python-only construction with typed kwargs (used by binding tests),\n`_install_typed_init` layers a keyword-only `__init__` onto each\nPyO3-created class that stores the documented payload fields as\ninstance attributes.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom fathomdb._fathomdb import (\n    ClosingError as _ClosingError,\n)\nfrom fathomdb._fathomdb import (\n    CorruptionError as _CorruptionError,\n)\nfrom fathomdb._fathomdb import (\n    DatabaseLockedError as _DatabaseLockedError,\n)\nfrom fathomdb._fathomdb import (\n    EmbedderDimensionMismatchError as _EmbedderDimensionMismatchError,\n)\nfrom fathomdb._fathomdb import (\n    EmbedderError as _EmbedderError,\n)\nfrom fathomdb._fathomdb import (\n    EmbedderNotConfiguredError as _EmbedderNotConfiguredError,\n)\nfrom fathomdb._fathomdb import (\n    EmbedderIdentityMismatchError as _EmbedderIdentityMismatchError,\n)\nfrom fathomdb._fathomdb import (\n    EngineError as _EngineError,\n)\nfrom fathomdb._fathomdb import (\n    IncompatibleSchemaVersionError as _IncompatibleSchemaVersionError,\n)\nfrom fathomdb._fathomdb import (\n    MigrationError as _MigrationError,\n)\nfrom fathomdb._fathomdb import (\n    OpStoreError as _OpStoreError,\n)\nfrom fathomdb._fathomdb import (\n    OverloadedError as _OverloadedError,\n)\nfrom fathomdb._fathomdb import (\n    ProjectionError as _ProjectionError,\n)\nfrom fathomdb._fathomdb import (\n    SchedulerError as _SchedulerError,\n)\nfrom fathomdb._fathomdb import (\n    SchemaValidationError as _SchemaValidationError,\n)\nfrom fathomdb._fathomdb import (\n    StorageError as _StorageError,\n)\nfrom fathomdb._fathomdb import (\n    KindNotVectorIndexedError as _KindNotVectorIndexedError,\n)\nfrom fathomdb._fathomdb import (\n    VectorError as _VectorError,\n)\nfrom fathomdb._fathomdb import (\n    WriteValidationError as _WriteValidationError,\n)\n\nEngineError = _EngineError\nStorageError = _StorageError\nProjectionError = _ProjectionError\nVectorError = _VectorError\nEmbedderError = _EmbedderError\nEmbedderNotConfiguredError = _EmbedderNotConfiguredError\nKindNotVectorIndexedError = _KindNotVectorIndexedError\nSchedulerError = _SchedulerError\nOpStoreError = _OpStoreError\nWriteValidationError = _WriteValidationError\nSchemaValidationError = _SchemaValidationError\nOverloadedError = _OverloadedError\nClosingError = _ClosingError\nDatabaseLockedError = _DatabaseLockedError\nCorruptionError = _CorruptionError\nIncompatibleSchemaVersionError = _IncompatibleSchemaVersionError\nMigrationError = _MigrationError\nEmbedderIdentityMismatchError = _EmbedderIdentityMismatchError\nEmbedderDimensionMismatchError = _EmbedderDimensionMismatchError\n\n\ndef _install_typed_init(cls: type, fields: tuple[str, ...]) -> None:\n    def __init__(self, *args, **kwargs):  # type: ignore[no-untyped-def]\n        payload = {name: kwargs.pop(name, None) for name in fields}\n        if kwargs:\n            unexpected = \", \".join(sorted(kwargs))\n            raise TypeError(f\"unexpected keyword arguments: {unexpected}\")\n        Exception.__init__(self, *args)\n        for name, value in payload.items():\n            object.__setattr__(self, name, value)\n\n    cls.__init__ = __init__  # type: ignore[method-assign]\n\n\n_install_typed_init(DatabaseLockedError, (\"holder_pid\",))\n_install_typed_init(\n    CorruptionError,\n    (\"kind\", \"stage\", \"recovery_hint_code\", \"doc_anchor\"),\n)\n_install_typed_init(\n    EmbedderIdentityMismatchError,\n    (\"stored_name\", \"stored_revision\", \"supplied_name\", \"supplied_revision\"),\n)\n_install_typed_init(EmbedderDimensionMismatchError, (\"stored\", \"supplied\"))\n\n\n__all__ = [\n    \"ClosingError\",\n    \"CorruptionError\",\n    \"DatabaseLockedError\",\n    \"EmbedderDimensionMismatchError\",\n    \"EmbedderError\",\n    \"EmbedderIdentityMismatchError\",\n    \"EmbedderNotConfiguredError\",\n    \"EngineError\",\n    \"IncompatibleSchemaVersionError\",\n    \"KindNotVectorIndexedError\",\n    \"MigrationError\",\n    \"OpStoreError\",\n    \"OverloadedError\",\n    \"ProjectionError\",\n    \"SchedulerError\",\n    \"SchemaValidationError\",\n    \"StorageError\",\n    \"VectorError\",\n    \"WriteValidationError\",\n]\n","numLines":145,"startLine":1,"totalLines":145}}}
