{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NdiLc8YiUaHdn3CkcqKBwC","type":"tool_result","content":"80\t  } catch (err) {\n81\t    rethrowTyped(err);\n82\t  }\n83\t}\n84\t\n85\texport class Engine {\n86\t  readonly #native: NativeEngine;\n87\t  readonly config: EngineConfig;\n88\t\n89\t  private constructor(inner: NativeEngine, config: EngineConfig) {\n90\t    this.#native = inner;\n91\t    this.config = config;\n92\t  }\n93\t\n94\t  static async open(path: string, options: EngineOpenOptions = {}): Promise<Engine> {\n95\t    validateFfiString(path);\n96\t    const inner = await intercept(() => native.Engine.open(path, options));\n97\t    return new Engine(inner, options.engineConfig ?? {});\n98\t  }\n99\t\n100\t  async write(batch: unknown[] = []): Promise<WriteReceipt> {\n101\t    validateFfiTree(batch);\n102\t    return intercept(() => this.#native.write(batch));\n103\t  }\n104\t\n105\t  async search(query: string): Promise<SearchResult> {\n106\t    validateFfiString(query);\n107\t    const r = await intercept(() => this.#native.search(query));\n108\t    const branch = r.softFallback?.branch;\n109\t    return {\n110\t      projectionCursor: r.projectionCursor,\n111\t      softFallback:\n112\t        branch === \"vector\" || branch === \"text\" ? { branch } : null,\n113\t      results: r.results,\n114\t    };\n115\t  }\n116\t\n117\t  async close(): Promise<void> {\n118\t    await intercept(() => this.#native.close());\n119\t  }\n120\t\n121\t  async drain(timeoutMs: number): Promise<void> {\n122\t    await intercept(() => this.#native.drain(timeoutMs));\n123\t  }\n124\t\n125\t  counters(): CounterSnapshot {\n126\t    return interceptSync(() => this.#native.counters());\n127\t  }\n128\t\n129\t  setProfiling(enabled: boolean): void {\n130\t    interceptSync(() => this.#native.setProfiling(enabled));\n131\t  }\n132\t\n133\t  setSlowThresholdMs(value: number): void {\n134\t    interceptSync(() => this.#native.setSlowThresholdMs(value));\n135\t  }\n136\t\n137\t  attachSubscriber(callback: SubscriberCallback, options: AttachSubscriberOptions = {}): void {\n138\t    interceptSync(() => this.#native.attachSubscriber(callback, options));\n139\t  }"}]},"parent_tool_use_id":null,"session_id":"6c2ab885-f26f-4687-8076-7a046130c523","uuid":"7ebfc7f0-b61b-4dde-960a-be811e6abad2","timestamp":"2026-05-17T15:05:11.794Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-11d-release-workflow-20260517T145932Z/src/ts/src/index.ts","content":"  } catch (err) {\n    rethrowTyped(err);\n  }\n}\n\nexport class Engine {\n  readonly #native: NativeEngine;\n  readonly config: EngineConfig;\n\n  private constructor(inner: NativeEngine, config: EngineConfig) {\n    this.#native = inner;\n    this.config = config;\n  }\n\n  static async open(path: string, options: EngineOpenOptions = {}): Promise<Engine> {\n    validateFfiString(path);\n    const inner = await intercept(() => native.Engine.open(path, options));\n    return new Engine(inner, options.engineConfig ?? {});\n  }\n\n  async write(batch: unknown[] = []): Promise<WriteReceipt> {\n    validateFfiTree(batch);\n    return intercept(() => this.#native.write(batch));\n  }\n\n  async search(query: string): Promise<SearchResult> {\n    validateFfiString(query);\n    const r = await intercept(() => this.#native.search(query));\n    const branch = r.softFallback?.branch;\n    return {\n      projectionCursor: r.projectionCursor,\n      softFallback:\n        branch === \"vector\" || branch === \"text\" ? { branch } : null,\n      results: r.results,\n    };\n  }\n\n  async close(): Promise<void> {\n    await intercept(() => this.#native.close());\n  }\n\n  async drain(timeoutMs: number): Promise<void> {\n    await intercept(() => this.#native.drain(timeoutMs));\n  }\n\n  counters(): CounterSnapshot {\n    return interceptSync(() => this.#native.counters());\n  }\n\n  setProfiling(enabled: boolean): void {\n    interceptSync(() => this.#native.setProfiling(enabled));\n  }\n\n  setSlowThresholdMs(value: number): void {\n    interceptSync(() => this.#native.setSlowThresholdMs(value));\n  }\n\n  attachSubscriber(callback: SubscriberCallback, options: AttachSubscriberOptions = {}): void {\n    interceptSync(() => this.#native.attachSubscriber(callback, options));\n  }","numLines":60,"startLine":80,"totalLines":154}}}
