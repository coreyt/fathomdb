{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01StFRbkJqt715SHx5MhHMnR","type":"tool_result","content":"/home/coreyt/go/bin/actionlint\n/home/coreyt/.local/go/bin/go\nv1.7.12\ninstalled by building from source\nbuilt with go1.26.1 compiler for linux/arm64\n{\n  \"name\": \"fathomdb\",\n  \"version\": \"0.6.0\",\n  \"private\": true,\n  \"type\": \"module\",\n  \"description\": \"TypeScript SDK for FathomDB 0.6.0 — napi-rs binding to fathomdb-engine\",\n  \"scripts\": {\n    \"build:native\": \"napi build --platform --release --cargo-cwd ../rust/crates/fathomdb-napi --js false\",\n    \"build:native:debug\": \"napi build --platform --cargo-cwd ../rust/crates/fathomdb-napi --features test-hooks --js false\",\n    \"build\": \"npm run build:native && tsc -p tsconfig.json\",\n    \"build:debug\": \"npm run build:native:debug && tsc -p tsconfig.json\",\n    \"typecheck\": \"tsc --noEmit -p tsconfig.json\",\n    \"test\": \"npm run build:debug && node --test dist/tests/*.test.js\"\n  },\n  \"devDependencies\": {\n    \"@napi-rs/cli\": \"^2.18.4\",\n    \"@types/node\": \"^25.6.0\",\n    \"typescript\": \"^5.8.3\"\n  },\n  \"napi\": {\n    \"name\": \"fathomdb\",\n    \"triples\": {\n      \"defaults\": true,\n      \"additional\": []\n    }\n  }\n}\n---\n[build-system]\nrequires = [\"maturin>=1.7,<2\"]\nbuild-backend = \"maturin\"\n\n[project]\nname = \"fathomdb\"\nversion = \"0.6.0\"\ndescription = \"FathomDB Python SDK — PyO3 binding to the fathomdb-engine Rust core\"\nreadme = \"README.md\"\nrequires-python = \">=3.10\"\nlicense = { text = \"Apache-2.0\" }\ndependencies = []\n\n[project.optional-dependencies]\ntest = [\"pytest>=8\", \"hypothesis>=6\"]\nlint = [\"ruff>=0.6\"]\ntypecheck = [\"pyright>=1.1.380\"]\ndev = [\"pytest>=8\", \"hypothesis>=6\", \"ruff>=0.6\", \"pyright>=1.1.380\"]\n\n[tool.maturin]\nmanifest-path = \"../rust/crates/fathomdb-py/Cargo.toml\"\nmodule-name = \"fathomdb._fathomdb\"\npython-source = \".\"\nfeatures = [\"pyo3/extension-module\", \"test-hooks\"]\n\n[tool.ruff]\nline-length = 100\ntarget-version = \"py310\"\n\n[tool.pyright]\ninclude = [\"fathomdb\", \"tests\"]\ntypeCheckingMode = \"standard\"\npythonVersion = \"3.10\"\nvenvPath = \"../..\"\nvenv = \".venv\"","is_error":false}]},"parent_tool_use_id":null,"session_id":"6c2ab885-f26f-4687-8076-7a046130c523","uuid":"ba795bc2-3a20-4a23-9171-7920259c5d99","timestamp":"2026-05-17T14:59:59.644Z","tool_use_result":{"stdout":"/home/coreyt/go/bin/actionlint\n/home/coreyt/.local/go/bin/go\nv1.7.12\ninstalled by building from source\nbuilt with go1.26.1 compiler for linux/arm64\n{\n  \"name\": \"fathomdb\",\n  \"version\": \"0.6.0\",\n  \"private\": true,\n  \"type\": \"module\",\n  \"description\": \"TypeScript SDK for FathomDB 0.6.0 — napi-rs binding to fathomdb-engine\",\n  \"scripts\": {\n    \"build:native\": \"napi build --platform --release --cargo-cwd ../rust/crates/fathomdb-napi --js false\",\n    \"build:native:debug\": \"napi build --platform --cargo-cwd ../rust/crates/fathomdb-napi --features test-hooks --js false\",\n    \"build\": \"npm run build:native && tsc -p tsconfig.json\",\n    \"build:debug\": \"npm run build:native:debug && tsc -p tsconfig.json\",\n    \"typecheck\": \"tsc --noEmit -p tsconfig.json\",\n    \"test\": \"npm run build:debug && node --test dist/tests/*.test.js\"\n  },\n  \"devDependencies\": {\n    \"@napi-rs/cli\": \"^2.18.4\",\n    \"@types/node\": \"^25.6.0\",\n    \"typescript\": \"^5.8.3\"\n  },\n  \"napi\": {\n    \"name\": \"fathomdb\",\n    \"triples\": {\n      \"defaults\": true,\n      \"additional\": []\n    }\n  }\n}\n---\n[build-system]\nrequires = [\"maturin>=1.7,<2\"]\nbuild-backend = \"maturin\"\n\n[project]\nname = \"fathomdb\"\nversion = \"0.6.0\"\ndescription = \"FathomDB Python SDK — PyO3 binding to the fathomdb-engine Rust core\"\nreadme = \"README.md\"\nrequires-python = \">=3.10\"\nlicense = { text = \"Apache-2.0\" }\ndependencies = []\n\n[project.optional-dependencies]\ntest = [\"pytest>=8\", \"hypothesis>=6\"]\nlint = [\"ruff>=0.6\"]\ntypecheck = [\"pyright>=1.1.380\"]\ndev = [\"pytest>=8\", \"hypothesis>=6\", \"ruff>=0.6\", \"pyright>=1.1.380\"]\n\n[tool.maturin]\nmanifest-path = \"../rust/crates/fathomdb-py/Cargo.toml\"\nmodule-name = \"fathomdb._fathomdb\"\npython-source = \".\"\nfeatures = [\"pyo3/extension-module\", \"test-hooks\"]\n\n[tool.ruff]\nline-length = 100\ntarget-version = \"py310\"\n\n[tool.pyright]\ninclude = [\"fathomdb\", \"tests\"]\ntypeCheckingMode = \"standard\"\npythonVersion = \"3.10\"\nvenvPath = \"../..\"\nvenv = \".venv\"","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
