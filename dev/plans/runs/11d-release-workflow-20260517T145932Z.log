{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AjckZuMa3mv3djCoSKM1QM","type":"tool_result","content":"55\t}\n56\t\n57\t# Set [workspace.package].version in Cargo.toml.\n58\tset_workspace_version() {\n59\t  local new=\"$1\"\n60\t  awk_inplace \"$CARGO\" '\n61\t    BEGIN { in_block = 0 }\n62\t    /^\\[workspace\\.package\\]/ { in_block = 1; print; next }\n63\t    /^\\[/ { in_block = 0; print; next }\n64\t    {\n65\t      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n66\t        print \"version = \\\"'\"$new\"'\\\"\"\n67\t      } else {\n68\t        print\n69\t      }\n70\t    }\n71\t  '\n72\t}\n73\t\n74\t# Set [project].version in pyproject.toml.\n75\tset_pyproject_version() {\n76\t  local new=\"$1\"\n77\t  awk_inplace \"$PYPROJ\" '\n78\t    BEGIN { in_block = 0 }\n79\t    /^\\[project\\]/ { in_block = 1; print; next }\n80\t    /^\\[/ { in_block = 0; print; next }\n81\t    {\n82\t      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n83\t        print \"version = \\\"'\"$new\"'\\\"\"\n84\t      } else {\n85\t        print\n86\t      }\n87\t    }\n88\t  '\n89\t}\n90\t\n91\t# Set the top-level \"version\" field in package.json.\n92\t# Constraint: only rewrite the first occurrence so a nested \"version\" inside\n93\t# devDependencies cannot be touched.\n94\tset_npm_version() {\n95\t  local new=\"$1\"\n96\t  local tmp\n97\t  tmp=\"$(mktemp \"${NPMPKG}.XXXXXX\")\"\n98\t  awk -v new=\"$new\" '\n99\t    BEGIN { done = 0 }\n100\t    {\n101\t      if (!done && match($0, /\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/)) {\n102\t        sub(/\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/, \"\\\"version\\\": \\\"\" new \"\\\"\")\n103\t        done = 1\n104\t      }\n105\t      print\n106\t    }\n107\t  ' \"$NPMPKG\" >\"$tmp\"\n108\t  mv \"$tmp\" \"$NPMPKG\"\n109\t}\n110\t\n111\t# Set [package].version in fathomdb-embedder-api/Cargo.toml. Preserves any\n112\t# leading comment lines inside the [package] block (so the Axis-E why-comment\n113\t# survives re-runs).\n114\tset_embedder_api_version() {\n115\t  local new=\"$1\"\n116\t  awk_inplace \"$EMB_API\" '\n117\t    BEGIN { in_block = 0 }\n118\t    /^\\[package\\]/ { in_block = 1; print; next }\n119\t    /^\\[/ { in_block = 0; print; next }\n120\t    {\n121\t      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n122\t        print \"version = \\\"'\"$new\"'\\\"\"\n123\t      } else {\n124\t        print\n125\t      }\n126\t    }\n127\t  '\n128\t}\n129\t\n130\t# --- readers ---------------------------------------------------------------\n131\t\n132\tread_workspace_version() {\n133\t  awk '\n134\t    /^\\[workspace\\.package\\]/ { in_block = 1; next }"}]},"parent_tool_use_id":null,"session_id":"6c2ab885-f26f-4687-8076-7a046130c523","uuid":"97ca6d3b-efe5-4ceb-b8c4-9ce81abc1bea","timestamp":"2026-05-17T15:09:08.353Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-11d-release-workflow-20260517T145932Z/scripts/set-version.sh","content":"}\n\n# Set [workspace.package].version in Cargo.toml.\nset_workspace_version() {\n  local new=\"$1\"\n  awk_inplace \"$CARGO\" '\n    BEGIN { in_block = 0 }\n    /^\\[workspace\\.package\\]/ { in_block = 1; print; next }\n    /^\\[/ { in_block = 0; print; next }\n    {\n      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n        print \"version = \\\"'\"$new\"'\\\"\"\n      } else {\n        print\n      }\n    }\n  '\n}\n\n# Set [project].version in pyproject.toml.\nset_pyproject_version() {\n  local new=\"$1\"\n  awk_inplace \"$PYPROJ\" '\n    BEGIN { in_block = 0 }\n    /^\\[project\\]/ { in_block = 1; print; next }\n    /^\\[/ { in_block = 0; print; next }\n    {\n      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n        print \"version = \\\"'\"$new\"'\\\"\"\n      } else {\n        print\n      }\n    }\n  '\n}\n\n# Set the top-level \"version\" field in package.json.\n# Constraint: only rewrite the first occurrence so a nested \"version\" inside\n# devDependencies cannot be touched.\nset_npm_version() {\n  local new=\"$1\"\n  local tmp\n  tmp=\"$(mktemp \"${NPMPKG}.XXXXXX\")\"\n  awk -v new=\"$new\" '\n    BEGIN { done = 0 }\n    {\n      if (!done && match($0, /\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/)) {\n        sub(/\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/, \"\\\"version\\\": \\\"\" new \"\\\"\")\n        done = 1\n      }\n      print\n    }\n  ' \"$NPMPKG\" >\"$tmp\"\n  mv \"$tmp\" \"$NPMPKG\"\n}\n\n# Set [package].version in fathomdb-embedder-api/Cargo.toml. Preserves any\n# leading comment lines inside the [package] block (so the Axis-E why-comment\n# survives re-runs).\nset_embedder_api_version() {\n  local new=\"$1\"\n  awk_inplace \"$EMB_API\" '\n    BEGIN { in_block = 0 }\n    /^\\[package\\]/ { in_block = 1; print; next }\n    /^\\[/ { in_block = 0; print; next }\n    {\n      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n        print \"version = \\\"'\"$new\"'\\\"\"\n      } else {\n        print\n      }\n    }\n  '\n}\n\n# --- readers ---------------------------------------------------------------\n\nread_workspace_version() {\n  awk '\n    /^\\[workspace\\.package\\]/ { in_block = 1; next }","numLines":80,"startLine":55,"totalLines":330}}}
