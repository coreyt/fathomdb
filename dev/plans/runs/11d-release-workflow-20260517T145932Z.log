f '%s\\n' \"$OUT\" | jq -e . >/dev/null\n\nprintf 'smoke-crates-cli: ok — fathomdb-cli %s installed + check-integrity returned valid JSON\\n' \\\n  \"$VERSION\"\n","structuredPatch":[],"originalFile":null,"userModified":false}}
