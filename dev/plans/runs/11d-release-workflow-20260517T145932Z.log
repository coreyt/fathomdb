ft \"$EMB_API\" \"$(_toml_version_line \"$EMB_API\" '[package]')\" \\\n293\t        \"unparseable\" \"explicit [package] version\"\n294\t      rc=1\n295\t      ;;\n296\t  esac\n297\t\n298\t  # Every workspace crate except fathomdb-embedder-api must inherit Axis W\n299\t  # via `version.workspace = true`. Catch silent decoupling regressions.\n300\t  local crate manifest line line_no pkg_line\n301\t  for crate in \"$CRATES_DIR\"/*; do\n302\t    [ -d \"$crate\" ] || continue\n303\t    manifest=\"$crate/Cargo.toml\"\n304\t    [ -f \"$manifest\" ] || continue\n305\t    if [ \"$crate\" = \"$EMB_API_DIR\" ]; then\n306\t      continue\n307\t    fi\n308\t    line=\"$(awk '\n309\t      /^\\[package\\]/ { in_block = 1; next }\n310\t      /^\\[/          { in_block = 0 }\n311\t      in_block && /^version[[:space:]]*[=.]/ {\n312\t        print\n313\t        exit\n314\t      }\n315\t    ' \"$manifest\")\"\n316\t    case \"$line\" in\n317\t      version.workspace[[:space:]]*=[[:space:]]*true) ;;\n318\t      '')\n319\t        pkg_line=\"$(grep -n '^\\[package\\]' \"$manifest\" | head -1 | cut -d: -f1)\"\n320\t        _drift \"$manifest\" \"${pkg_line:-1}\" \"<missing>\" \"version.workspace = true\"\n321\t        rc=1\n322\t        ;;\n323\t      *)\n324\t        line_no=\"$(_toml_version_line \"$manifest\" '[package]')\"\n325\t        _drift \"$manifest\" \"${line_no:-1}\" \"$line\" \"version.workspace = true\"\n326\t        rc=1\n327\t        ;;\n328\t    esac\n329\t  done\n330\t\n331\t  if [ $rc -eq 0 ]; then\n332\t    printf 'ok: Axis W = %s; Axis E = %s\\n' \"$ws\" \"$emb\"\n333\t  fi\n334\t  return $rc\n335\t}\n336\t\n337\t# --- dispatch --------------------------------------------------------------\n338\t\n339\tif [ $# -eq 0 ]; then\n340\t  die_usage \"no mode given\"\n341\tfi\n342\t\n343\tmode=\"$1\"\n344\tshift || true\n345\t\n346\tcase \"$mode\" in\n347\t  --workspace)\n348\t    if [ $# -ne 1 ] || [ -z \"${1:-}\" ]; then\n349\t      die_usage \"--workspace requires <new-w-