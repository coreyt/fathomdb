{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012QY4Jt6QsGeu8SqyknymY1","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t# scripts/set-version.sh — two-axis version single source of truth.\n3\t#\n4\t# Axis W (workspace lockstep): Cargo.toml [workspace.package].version,\n5\t# src/python/pyproject.toml [project].version, src/ts/package.json\n6\t# top-level \"version\". Inherited by every workspace crate via\n7\t# `version.workspace = true`.\n8\t#\n9\t# Axis E (embedder-api independent semver):\n10\t# src/rust/crates/fathomdb-embedder-api/Cargo.toml [package].version.\n11\t#\n12\t# Owner: dev/design/release.md § Version axes.\n13\tset -euo pipefail\n14\t\n15\tusage() {\n16\t  cat <<'USAGE' >&2\n17\tUsage: scripts/set-version.sh <mode> [args]\n18\t\n19\tModes:\n20\t  --workspace <new-w-version>     Set Axis W (Cargo workspace + python + ts).\n21\t  --embedder-api <new-e-version>  Set Axis E (fathomdb-embedder-api only).\n22\t  --check-files                   Verify both axes are internally consistent.\n23\t\n24\tExamples:\n25\t  scripts/set-version.sh --workspace 0.6.1\n26\t  scripts/set-version.sh --embedder-api 0.7.0\n27\t  scripts/set-version.sh --check-files\n28\tUSAGE\n29\t}\n30\t\n31\tdie_usage() {\n32\t  if [ -n \"${1:-}\" ]; then\n33\t    printf 'error: %s\\n' \"$1\" >&2\n34\t  fi\n35\t  usage\n36\t  exit 2\n37\t}\n38\t\n39\tREPO_ROOT=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\"\n40\tCARGO=\"$REPO_ROOT/Cargo.toml\"\n41\tPYPROJ=\"$REPO_ROOT/src/python/pyproject.toml\"\n42\tNPMPKG=\"$REPO_ROOT/src/ts/package.json\"\n43\tEMB_API_DIR=\"$REPO_ROOT/src/rust/crates/fathomdb-embedder-api\"\n44\tEMB_API=\"$EMB_API_DIR/Cargo.toml\"\n45\tCRATES_DIR=\"$REPO_ROOT/src/rust/crates\"\n46\t\n47\t# Atomic write: edits \"$1\" with awk program \"$2\" via a tmpfile mv.\n48\tawk_inplace() {\n49\t  local target=\"$1\"\n50\t  local prog=\"$2\"\n51\t  local tmp\n52\t  tmp=\"$(mktemp \"${target}.XXXXXX\")\"\n53\t  awk \"$prog\" \"$target\" >\"$tmp\"\n54\t  mv \"$tmp\" \"$target\"\n55\t}\n56\t\n57\t# Set [workspace.package].version in Cargo.toml.\n58\tset_workspace_version() {\n59\t  local new=\"$1\"\n60\t  awk_inplace \"$CARGO\" '\n61\t    BEGIN { in_block = 0 }\n62\t    /^\\[workspace\\.package\\]/ { in_block = 1; print; next }\n63\t    /^\\[/ { in_block = 0; print; next }\n64\t    {\n65\t      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n66\t        print \"version = \\\"'\"$new\"'\\\"\"\n67\t      } else {\n68\t        print\n69\t      }\n70\t    }\n71\t  '\n72\t}\n73\t\n74\t# Set [project].version in pyproject.toml.\n75\tset_pyproject_version() {\n76\t  local new=\"$1\"\n77\t  awk_inplace \"$PYPROJ\" '\n78\t    BEGIN { in_block = 0 }\n79\t    /^\\[project\\]/ { in_block = 1; print; next }\n80\t    /^\\[/ { in_block = 0; print; next }\n81\t    {\n82\t      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n83\t        print \"version = \\\"'\"$new\"'\\\"\"\n84\t      } else {\n85\t        print\n86\t      }\n87\t    }\n88\t  '\n89\t}\n90\t\n91\t# Set the top-level \"version\" field in package.json.\n92\t# Constraint: only rewrite the first occurrence so a nested \"version\" inside\n93\t# devDependencies cannot be touched.\n94\tset_npm_version() {\n95\t  local new=\"$1\"\n96\t  local tmp\n97\t  tmp=\"$(mktemp \"${NPMPKG}.XXXXXX\")\"\n98\t  awk -v new=\"$new\" '\n99\t    BEGIN { done = 0 }\n100\t    {\n101\t      if (!done && match($0, /\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/)) {\n102\t        sub(/\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/, \"\\\"version\\\": \\\"\" new \"\\\"\")\n103\t        done = 1\n104\t      }\n105\t      print\n106\t    }\n107\t  ' \"$NPMPKG\" >\"$tmp\"\n108\t  mv \"$tmp\" \"$NPMPKG\"\n109\t}\n110\t\n111\t# Set [package].version in fathomdb-embedder-api/Cargo.toml. Preserves any\n112\t# leading comment lines inside the [package] block (so the Axis-E why-comment\n113\t# survives re-runs).\n114\tset_embedder_api_version() {\n115\t  local new=\"$1\"\n116\t  awk_inplace \"$EMB_API\" '\n117\t    BEGIN { in_block = 0 }\n118\t    /^\\[package\\]/ { in_block = 1; print; next }\n119\t    /^\\[/ { in_block = 0; print; next }\n120\t    {\n121\t      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n122\t        print \"version = \\\"'\"$new\"'\\\"\"\n123\t      } else {\n124\t        print\n125\t      }\n126\t    }\n127\t  '\n128\t}\n129\t\n130\t# --- readers ---------------------------------------------------------------\n131\t\n132\tread_workspace_version() {\n133\t  awk '\n134\t    /^\\[workspace\\.package\\]/ { in_block = 1; next }\n135\t    /^\\[/                     { in_block = 0 }\n136\t    in_block && /^version[[:space:]]*=/ {\n137\t      n = split($0, parts, \"\\\"\")\n138\t      if (n >= 3) { print parts[2] }\n139\t      exit\n140\t    }\n141\t  ' \"$CARGO\"\n142\t}\n143\t\n144\tread_pyproject_version() {\n145\t  awk '\n146\t    /^\\[project\\]/ { in_block = 1; next }\n147\t    /^\\[/          { in_block = 0 }\n148\t    in_block && /^version[[:space:]]*=/ {\n149\t      n = split($0, parts, \"\\\"\")\n150\t      if (n >= 3) { print parts[2] }\n151\t      exit\n152\t    }\n153\t  ' \"$PYPROJ\"\n154\t}\n155\t\n156\tread_npm_version() {\n157\t  sed -n 's/.*\"version\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p' \"$NPMPKG\" | head -1\n158\t}\n159\t\n160\t# Returns the literal text of the version line inside [package] of the\n161\t# embedder-api crate (e.g. `version = \"0.6.0\"` or `version.workspace = true`).\n162\tread_embedder_api_version_line() {\n163\t  awk '\n164\t    /^\\[package\\]/ { in_block = 1; next }\n165\t    /^\\[/          { in_block = 0 }\n166\t    in_block && /^version[[:space:]]*[=.]/ {\n167\t      print\n168\t      exit\n169\t    }\n170\t  ' \"$EMB_API\"\n171\t}\n172\t\n173\t# Parse out the value portion: returns \"0.6.0\" for `version = \"0.6.0\"`, or\n174\t# the literal \"workspace\" sentinel for `version.workspace = true`.\n175\tembedder_api_version_value() {\n176\t  local line\n177\t  line=\"$(read_embedder_api_version_line)\"\n178\t  case \"$line\" in\n179\t    version.workspace*) printf 'workspace' ;;\n180\t    version[[:space:]]*=*\\\"*) printf '%s' \"$line\" | sed -n 's/.*\"\\([^\"]*\\)\".*/\\1/p' ;;\n181\t    *) printf 'unknown' ;;\n182\t  esac\n183\t}\n184\t\n185\t# --- check-files -----------------------------------------------------------\n186\t\n187\t# Line number of the first `version =` / `version.workspace` declaration\n188\t# inside the given TOML [table] of the given file. Empty if not present.\n189\t_toml_version_line() {\n190\t  local file=\"$1\" table=\"$2\"\n191\t  awk -v table=\"$table\" '\n192\t    $0 == table { in_block = 1; next }\n193\t    /^\\[/ && in_block { exit }\n194\t    in_block && /^version[[:space:]]*[=.]/ { print NR; exit }\n195\t  ' \"$file\"\n196\t}\n197\t\n198\t# Line number of the first \"version\" key in a JSON file.\n199\t_json_version_line() {\n200\t  grep -n '\"version\"' \"$1\" | head -1 | cut -d: -f1\n201\t}\n202\t\n203\t# Emit a structured drift diagnostic: `<file>:<line>: version drift —\n204\t# observed \"X\", expected \"Y\"`. Centralized so every drift site has the\n205\t# same shape (parseable by tooling, asserted in test_set_version.sh).\n206\t_drift() {\n207\t  local file=\"$1\" line=\"$2\" observed=\"$3\" expected=\"$4\"\n208\t  printf '%s:%s: version drift — observed \"%s\", expected \"%s\"\\n' \\\n209\t    \"$file\" \"${line:-?}\" \"$observed\" \"$expected\" >&2\n210\t}\n211\t\n212\tcheck_files() {\n213\t  local ws py npm emb\n214\t  ws=\"$(read_workspace_version)\"\n215\t  py=\"$(read_pyproject_version)\"\n216\t  npm=\"$(read_npm_version)\"\n217\t  emb=\"$(embedder_api_version_value)\"\n218\t\n219\t  local rc=0\n220\t\n221\t  if [ -z \"$ws\" ]; then\n222\t    printf 'error: %s: no [workspace.package] version found\\n' \"$CARGO\" >&2\n223\t    rc=1\n224\t  fi\n225\t\n226\t  if [ \"$py\" != \"$ws\" ]; then\n227\t    _drift \"$PYPROJ\" \"$(_toml_version_line \"$PYPROJ\" '[project]')\" \"$py\" \"$ws\"\n228\t    rc=1\n229\t  fi\n230\t\n231\t  if [ \"$npm\" != \"$ws\" ]; then\n232\t    _drift \"$NPMPKG\" \"$(_json_version_line \"$NPMPKG\")\" \"$npm\" \"$ws\"\n233\t    rc=1\n234\t  fi\n235\t\n236\t  case \"$emb\" in\n237\t    workspace)\n238\t      _drift \"$EMB_API\" \"$(_toml_version_line \"$EMB_API\" '[package]')\" \\\n239\t        \"version.workspace = true\" \"explicit [package] version\"\n240\t      rc=1\n241\t      ;;\n242\t    unknown|'')\n243\t      _drift \"$EMB_API\" \"$(_toml_version_line \"$EMB_API\" '[package]')\" \\\n244\t        \"unparseable\" \"explicit [package] version\"\n245\t      rc=1\n246\t      ;;\n247\t  esac\n248\t\n249\t  # Every workspace crate except fathomdb-embedder-api must inherit Axis W\n250\t  # via `version.workspace = true`. Catch silent decoupling regressions.\n251\t  local crate manifest line line_no pkg_line\n252\t  for crate in \"$CRATES_DIR\"/*; do\n253\t    [ -d \"$crate\" ] || continue\n254\t    manifest=\"$crate/Cargo.toml\"\n255\t    [ -f \"$manifest\" ] || continue\n256\t    if [ \"$crate\" = \"$EMB_API_DIR\" ]; then\n257\t      continue\n258\t    fi\n259\t    line=\"$(awk '\n260\t      /^\\[package\\]/ { in_block = 1; next }\n261\t      /^\\[/          { in_block = 0 }\n262\t      in_block && /^version[[:space:]]*[=.]/ {\n263\t        print\n264\t        exit\n265\t      }\n266\t    ' \"$manifest\")\"\n267\t    case \"$line\" in\n268\t      version.workspace[[:space:]]*=[[:space:]]*true) ;;\n269\t      '')\n270\t        pkg_line=\"$(grep -n '^\\[package\\]' \"$manifest\" | head -1 | cut -d: -f1)\"\n271\t        _drift \"$manifest\" \"${pkg_line:-1}\" \"<missing>\" \"version.workspace = true\"\n272\t        rc=1\n273\t        ;;\n274\t      *)\n275\t        line_no=\"$(_toml_version_line \"$manifest\" '[package]')\"\n276\t        _drift \"$manifest\" \"${line_no:-1}\" \"$line\" \"version.workspace = true\"\n277\t        rc=1\n278\t        ;;\n279\t    esac\n280\t  done\n281\t\n282\t  if [ $rc -eq 0 ]; then\n283\t    printf 'ok: Axis W = %s; Axis E = %s\\n' \"$ws\" \"$emb\"\n284\t  fi\n285\t  return $rc\n286\t}\n287\t\n288\t# --- dispatch --------------------------------------------------------------\n289\t\n290\tif [ $# -eq 0 ]; then\n291\t  die_usage \"no mode given\"\n292\tfi\n293\t\n294\tmode=\"$1\"\n295\tshift || true\n296\t\n297\tcase \"$mode\" in\n298\t  --workspace)\n299\t    if [ $# -ne 1 ] || [ -z \"${1:-}\" ]; then\n300\t      die_usage \"--workspace requires <new-w-version>\"\n301\t    fi\n302\t    new=\"$1\"\n303\t    set_workspace_version \"$new\"\n304\t    set_pyproject_version \"$new\"\n305\t    set_npm_version \"$new\"\n306\t    check_files\n307\t    ;;\n308\t  --embedder-api)\n309\t    if [ $# -ne 1 ] || [ -z \"${1:-}\" ]; then\n310\t      die_usage \"--embedder-api requires <new-e-version>\"\n311\t    fi\n312\t    new=\"$1\"\n313\t    set_embedder_api_version \"$new\"\n314\t    check_files\n315\t    ;;\n316\t  --check-files)\n317\t    if [ $# -ne 0 ]; then\n318\t      die_usage \"--check-files takes no arguments\"\n319\t    fi\n320\t    check_files\n321\t    ;;\n322\t  -h|--help)\n323\t    usage\n324\t    exit 0\n325\t    ;;\n326\t  *)\n327\t    die_usage \"unknown mode: $mode\"\n328\t    ;;\n329\tesac\n330\t"}]},"parent_tool_use_id":null,"session_id":"6c2ab885-f26f-4687-8076-7a046130c523","uuid":"6b7bba59-3343-4c07-90f7-b788ff58b091","timestamp":"2026-05-17T14:59:48.878Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-11d-release-workflow-20260517T145932Z/scripts/set-version.sh","content":"#!/usr/bin/env bash\n# scripts/set-version.sh — two-axis version single source of truth.\n#\n# Axis W (workspace lockstep): Cargo.toml [workspace.package].version,\n# src/python/pyproject.toml [project].version, src/ts/package.json\n# top-level \"version\". Inherited by every workspace crate via\n# `version.workspace = true`.\n#\n# Axis E (embedder-api independent semver):\n# src/rust/crates/fathomdb-embedder-api/Cargo.toml [package].version.\n#\n# Owner: dev/design/release.md § Version axes.\nset -euo pipefail\n\nusage() {\n  cat <<'USAGE' >&2\nUsage: scripts/set-version.sh <mode> [args]\n\nModes:\n  --workspace <new-w-version>     Set Axis W (Cargo workspace + python + ts).\n  --embedder-api <new-e-version>  Set Axis E (fathomdb-embedder-api only).\n  --check-files                   Verify both axes are internally consistent.\n\nExamples:\n  scripts/set-version.sh --workspace 0.6.1\n  scripts/set-version.sh --embedder-api 0.7.0\n  scripts/set-version.sh --check-files\nUSAGE\n}\n\ndie_usage() {\n  if [ -n \"${1:-}\" ]; then\n    printf 'error: %s\\n' \"$1\" >&2\n  fi\n  usage\n  exit 2\n}\n\nREPO_ROOT=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\"\nCARGO=\"$REPO_ROOT/Cargo.toml\"\nPYPROJ=\"$REPO_ROOT/src/python/pyproject.toml\"\nNPMPKG=\"$REPO_ROOT/src/ts/package.json\"\nEMB_API_DIR=\"$REPO_ROOT/src/rust/crates/fathomdb-embedder-api\"\nEMB_API=\"$EMB_API_DIR/Cargo.toml\"\nCRATES_DIR=\"$REPO_ROOT/src/rust/crates\"\n\n# Atomic write: edits \"$1\" with awk program \"$2\" via a tmpfile mv.\nawk_inplace() {\n  local target=\"$1\"\n  local prog=\"$2\"\n  local tmp\n  tmp=\"$(mktemp \"${target}.XXXXXX\")\"\n  awk \"$prog\" \"$target\" >\"$tmp\"\n  mv \"$tmp\" \"$target\"\n}\n\n# Set [workspace.package].version in Cargo.toml.\nset_workspace_version() {\n  local new=\"$1\"\n  awk_inplace \"$CARGO\" '\n    BEGIN { in_block = 0 }\n    /^\\[workspace\\.package\\]/ { in_block = 1; print; next }\n    /^\\[/ { in_block = 0; print; next }\n    {\n      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n        print \"version = \\\"'\"$new\"'\\\"\"\n      } else {\n        print\n      }\n    }\n  '\n}\n\n# Set [project].version in pyproject.toml.\nset_pyproject_version() {\n  local new=\"$1\"\n  awk_inplace \"$PYPROJ\" '\n    BEGIN { in_block = 0 }\n    /^\\[project\\]/ { in_block = 1; print; next }\n    /^\\[/ { in_block = 0; print; next }\n    {\n      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n        print \"version = \\\"'\"$new\"'\\\"\"\n      } else {\n        print\n      }\n    }\n  '\n}\n\n# Set the top-level \"version\" field in package.json.\n# Constraint: only rewrite the first occurrence so a nested \"version\" inside\n# devDependencies cannot be touched.\nset_npm_version() {\n  local new=\"$1\"\n  local tmp\n  tmp=\"$(mktemp \"${NPMPKG}.XXXXXX\")\"\n  awk -v new=\"$new\" '\n    BEGIN { done = 0 }\n    {\n      if (!done && match($0, /\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/)) {\n        sub(/\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/, \"\\\"version\\\": \\\"\" new \"\\\"\")\n        done = 1\n      }\n      print\n    }\n  ' \"$NPMPKG\" >\"$tmp\"\n  mv \"$tmp\" \"$NPMPKG\"\n}\n\n# Set [package].version in fathomdb-embedder-api/Cargo.toml. Preserves any\n# leading comment lines inside the [package] block (so the Axis-E why-comment\n# survives re-runs).\nset_embedder_api_version() {\n  local new=\"$1\"\n  awk_inplace \"$EMB_API\" '\n    BEGIN { in_block = 0 }\n    /^\\[package\\]/ { in_block = 1; print; next }\n    /^\\[/ { in_block = 0; print; next }\n    {\n      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n        print \"version = \\\"'\"$new\"'\\\"\"\n      } else {\n        print\n      }\n    }\n  '\n}\n\n# --- readers ---------------------------------------------------------------\n\nread_workspace_version() {\n  awk '\n    /^\\[workspace\\.package\\]/ { in_block = 1; next }\n    /^\\[/                     { in_block = 0 }\n    in_block && /^version[[:space:]]*=/ {\n      n = split($0, parts, \"\\\"\")\n      if (n >= 3) { print parts[2] }\n      exit\n    }\n  ' \"$CARGO\"\n}\n\nread_pyproject_version() {\n  awk '\n    /^\\[project\\]/ { in_block = 1; next }\n    /^\\[/          { in_block = 0 }\n    in_block && /^version[[:space:]]*=/ {\n      n = split($0, parts, \"\\\"\")\n      if (n >= 3) { print parts[2] }\n      exit\n    }\n  ' \"$PYPROJ\"\n}\n\nread_npm_version() {\n  sed -n 's/.*\"version\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p' \"$NPMPKG\" | head -1\n}\n\n# Returns the literal text of the version line inside [package] of the\n# embedder-api crate (e.g. `version = \"0.6.0\"` or `version.workspace = true`).\nread_embedder_api_version_line() {\n  awk '\n    /^\\[package\\]/ { in_block = 1; next }\n    /^\\[/          { in_block = 0 }\n    in_block && /^version[[:space:]]*[=.]/ {\n      print\n      exit\n    }\n  ' \"$EMB_API\"\n}\n\n# Parse out the value portion: returns \"0.6.0\" for `version = \"0.6.0\"`, or\n# the literal \"workspace\" sentinel for `version.workspace = true`.\nembedder_api_version_value() {\n  local line\n  line=\"$(read_embedder_api_version_line)\"\n  case \"$line\" in\n    version.workspace*) printf 'workspace' ;;\n    version[[:space:]]*=*\\\"*) printf '%s' \"$line\" | sed -n 's/.*\"\\([^\"]*\\)\".*/\\1/p' ;;\n    *) printf 'unknown' ;;\n  esac\n}\n\n# --- check-files -----------------------------------------------------------\n\n# Line number of the first `version =` / `version.workspace` declaration\n# inside the given TOML [table] of the given file. Empty if not present.\n_toml_version_line() {\n  local file=\"$1\" table=\"$2\"\n  awk -v table=\"$table\" '\n    $0 == table { in_block = 1; next }\n    /^\\[/ && in_block { exit }\n    in_block && /^version[[:space:]]*[=.]/ { print NR; exit }\n  ' \"$file\"\n}\n\n# Line number of the first \"version\" key in a JSON file.\n_json_version_line() {\n  grep -n '\"version\"' \"$1\" | head -1 | cut -d: -f1\n}\n\n# Emit a structured drift diagnostic: `<file>:<line>: version drift —\n# observed \"X\", expected \"Y\"`. Centralized so every drift site has the\n# same shape (parseable by tooling, asserted in test_set_version.sh).\n_drift() {\n  local file=\"$1\" line=\"$2\" observed=\"$3\" expected=\"$4\"\n  printf '%s:%s: version drift — observed \"%s\", expected \"%s\"\\n' \\\n    \"$file\" \"${line:-?}\" \"$observed\" \"$expected\" >&2\n}\n\ncheck_files() {\n  local ws py npm emb\n  ws=\"$(read_workspace_version)\"\n  py=\"$(read_pyproject_version)\"\n  npm=\"$(read_npm_version)\"\n  emb=\"$(embedder_api_version_value)\"\n\n  local rc=0\n\n  if [ -z \"$ws\" ]; then\n    printf 'error: %s: no [workspace.package] version found\\n' \"$CARGO\" >&2\n    rc=1\n  fi\n\n  if [ \"$py\" != \"$ws\" ]; then\n    _drift \"$PYPROJ\" \"$(_toml_version_line \"$PYPROJ\" '[project]')\" \"$py\" \"$ws\"\n    rc=1\n  fi\n\n  if [ \"$npm\" != \"$ws\" ]; then\n    _drift \"$NPMPKG\" \"$(_json_version_line \"$NPMPKG\")\" \"$npm\" \"$ws\"\n    rc=1\n  fi\n\n  case \"$emb\" in\n    workspace)\n      _drift \"$EMB_API\" \"$(_toml_version_line \"$EMB_API\" '[package]')\" \\\n        \"version.workspace = true\" \"explicit [package] version\"\n      rc=1\n      ;;\n    unknown|'')\n      _drift \"$EMB_API\" \"$(_toml_version_line \"$EMB_API\" '[package]')\" \\\n        \"unparseable\" \"explicit [package] version\"\n      rc=1\n      ;;\n  esac\n\n  # Every workspace crate except fathomdb-embedder-api must inherit Axis W\n  # via `version.workspace = true`. Catch silent decoupling regressions.\n  local crate manifest line line_no pkg_line\n  for crate in \"$CRATES_DIR\"/*; do\n    [ -d \"$crate\" ] || continue\n    manifest=\"$crate/Cargo.toml\"\n    [ -f \"$manifest\" ] || continue\n    if [ \"$crate\" = \"$EMB_API_DIR\" ]; then\n      continue\n    fi\n    line=\"$(awk '\n      /^\\[package\\]/ { in_block = 1; next }\n      /^\\[/          { in_block = 0 }\n      in_block && /^version[[:space:]]*[=.]/ {\n        print\n        exit\n      }\n    ' \"$manifest\")\"\n    case \"$line\" in\n      version.workspace[[:space:]]*=[[:space:]]*true) ;;\n      '')\n        pkg_line=\"$(grep -n '^\\[package\\]' \"$manifest\" | head -1 | cut -d: -f1)\"\n        _drift \"$manifest\" \"${pkg_line:-1}\" \"<missing>\" \"version.workspace = true\"\n        rc=1\n        ;;\n      *)\n        line_no=\"$(_toml_version_line \"$manifest\" '[package]')\"\n        _drift \"$manifest\" \"${line_no:-1}\" \"$line\" \"version.workspace = true\"\n        rc=1\n        ;;\n    esac\n  done\n\n  if [ $rc -eq 0 ]; then\n    printf 'ok: Axis W = %s; Axis E = %s\\n' \"$ws\" \"$emb\"\n  fi\n  return $rc\n}\n\n# --- dispatch --------------------------------------------------------------\n\nif [ $# -eq 0 ]; then\n  die_usage \"no mode given\"\nfi\n\nmode=\"$1\"\nshift || true\n\ncase \"$mode\" in\n  --workspace)\n    if [ $# -ne 1 ] || [ -z \"${1:-}\" ]; then\n      die_usage \"--workspace requires <new-w-version>\"\n    fi\n    new=\"$1\"\n    set_workspace_version \"$new\"\n    set_pyproject_version \"$new\"\n    set_npm_version \"$new\"\n    check_files\n    ;;\n  --embedder-api)\n    if [ $# -ne 1 ] || [ -z \"${1:-}\" ]; then\n      die_usage \"--embedder-api requires <new-e-version>\"\n    fi\n    new=\"$1\"\n    set_embedder_api_version \"$new\"\n    check_files\n    ;;\n  --check-files)\n    if [ $# -ne 0 ]; then\n      die_usage \"--check-files takes no arguments\"\n    fi\n    check_files\n    ;;\n  -h|--help)\n    usage\n    exit 0\n    ;;\n  *)\n    die_usage \"unknown mode: $mode\"\n    ;;\nesac\n","numLines":330,"startLine":1,"totalLines":330}}}
