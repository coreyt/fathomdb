{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VqaeBGpviRhd2m9teuDGLq","type":"tool_result","content":"2380\t            code,\n2381\t        };\n2382\t        subscriber.on_event(&event);\n2383\t    }\n2384\t}\n2385\t\n2386\t/// Install a `sqlite3_profile` callback on `connection` that dispatches\n2387\t/// per-statement profile records and slow-statement signals to the\n2388\t/// engine's subscriber registry.\n2389\t///\n2390\t/// Why FFI rather than `rusqlite::Connection::profile`: the safe API\n2391\t/// (rusqlite 0.31) accepts only a `fn(&str, Duration)` with no\n2392\t/// environment, so it cannot carry a per-engine subscriber-registry\n2393\t/// pointer. We use `sqlite3_profile` directly with a leaked-into-`Box`\n2394\t/// context whose pointer is tied to the engine's lifetime via\n2395\t/// `Engine::profile_contexts`.\n2396\t///\n2397\t/// `sqlite3_profile` is documented as deprecated in favor of\n2398\t/// `sqlite3_trace_v2`, but it remains supported and is sufficient for\n2399\t/// the wall-clock + SQL-text payload required by AC-005a/b.\n2400\t#[allow(clippy::vec_box)]\n2401\tfn install_profile_callback(\n2402\t    connection: &Connection,\n2403\t    subscribers: &Arc<lifecycle::SubscriberRegistry>,\n2404\t    profiling_enabled: &Arc<AtomicBool>,\n2405\t    slow_threshold_ms: &Arc<AtomicU64>,\n2406\t    contexts: &mut Vec<Box<ProfileContext>>,\n2407\t) {\n2408\t    let mut ctx = Box::new(ProfileContext {\n2409\t        subscribers: Arc::clone(subscribers),\n2410\t        profiling_enabled: Arc::clone(profiling_enabled),\n2411\t        slow_threshold_ms: Arc::clone(slow_threshold_ms),\n2412\t    });\n2413\t    let ctx_ptr: *mut ProfileContext = &mut *ctx;\n2414\t\n2415\t    // SAFETY: the Box outlives the connection. Rust drops struct fields\n2416\t    // in declaration order. `connection` and `reader_pool` are declared\n2417\t    // before `profile_contexts`, so the connections — and SQLite's\n2418\t    // internal profile-callback state with them — are dropped before\n2419\t    // the `Box<ProfileContext>` allocations are freed. `Engine::close`\n2420\t    // additionally clears the callback via\n2421\t    // `sqlite3_profile(handle, None, NULL)` before connection close to\n2422\t    // drain any in-flight callback dispatch.\n2423\t    unsafe {\n2424\t        rusqlite::ffi::sqlite3_profile(\n2425\t            connection.handle(),\n2426\t            Some(profile_callback_trampoline),\n2427\t            ctx_ptr.cast::<std::ffi::c_void>(),\n2428\t        );\n2429\t    }\n2430\t    contexts.push(ctx);\n2431\t}\n2432\t\n2433\t/// Uninstall the profile callback so SQLite stops calling into our\n2434\t/// freed `Box<ProfileContext>` pointer once a connection is being torn\n2435\t/// down. Call before dropping `profile_contexts`.\n2436\tfn uninstall_profile_callback(connection: &Connection) {\n2437\t    // SAFETY: passing `None` as the callback unregisters the previous\n2438\t    // callback; SQLite documents this as legal and idempotent.\n2439\t    unsafe {\n2440\t        rusqlite::ffi::sqlite3_profile(connection.handle(), None, std::ptr::null_mut());\n2441\t    }\n2442\t}\n2443\t\n2444\t/// FFI trampoline for `sqlite3_profile`.\n2445\t///\n2446\t/// Invoked by SQLite at statement-finish with the SQL text and the\n2447\t/// statement's wall-clock cost in nanoseconds. We dispatch a\n2448\t/// `ProfileRecord` (when profiling is enabled) and a `SlowStatement`\n2449\t/// signal (when `wall_clock_ms` exceeds the configured slow threshold).\n2450\t///\n2451\t/// Per `dev/design/lifecycle.md` § Public record shape, the public\n2452\t/// payload exposes `wall_clock_ms`, `step_count`, and `cache_delta`.\n2453\t/// `sqlite3_profile` does not surface per-statement step counts or\n2454\t/// cache-hit deltas in its callback; we emit `0` for those fields and\n2455\t/// document the hazard. AC-005b requires the fields be typed numeric,\n2456\t/// not that they carry non-zero values for every backend.\n2457\tunsafe extern \"C\" fn profile_callback_trampoline(\n2458\t    user_data: *mut std::ffi::c_void,\n2459\t    sql: *const std::os::raw::c_char,\n2460\t    nanoseconds: u64,\n2461\t) {\n2462\t    if user_data.is_null() || sql.is_null() {\n2463\t        return;\n2464\t    }\n2465\t    let ctx = unsafe { &*(user_data.cast::<ProfileContext>()) };\n2466\t    let sql_text = match unsafe { std::ffi::CStr::from_ptr(sql) }.to_str() {\n2467\t        Ok(s) => s,\n2468\t        Err(_) => return,\n2469\t    };\n2470\t\n2471\t    let wall_clock_ms = nanoseconds / 1_000_000;\n2472\t\n2473\t    if ctx.profiling_enabled.load(Ordering::Relaxed) {\n2474\t        let record = lifecycle::ProfileRecord {\n2475\t            wall_clock_ms,\n2476\t            // step_count / cache_delta are not surfaced by\n2477\t            // sqlite3_profile; placeholder 0 satisfies AC-005b's\n2478\t            // \"typed numeric\" contract. A future profiling refactor\n2479\t            // around sqlite3_stmt_status + sqlite3_db_status would\n2480\t            // populate them with non-zero deltas.\n2481\t            step_count: 0,\n2482\t            cache_delta: 0,\n2483\t        };\n2484\t        ctx.subscribers.dispatch_profile(&record);\n2485\t    }\n2486\t\n2487\t    let threshold = ctx.slow_threshold_ms.load(Ordering::Relaxed);\n2488\t    if wall_clock_ms > threshold {\n2489\t        let signal = lifecycle::SlowStatement { statement: sql_text.to_string(), wall_clock_ms };\n2490\t        ctx.subscribers.dispatch_slow_statement(&signal);\n2491\t    }\n2492\t}\n2493\t\n2494\t#[cfg(test)]\n2495\tmod tests {\n2496\t    use super::{Engine, PreparedWrite};\n2497\t    use tempfile::TempDir;\n2498\t\n2499\t    #[test]\n2500\t    fn write_advances_cursor() {\n2501\t        let dir = TempDir::new().unwrap();\n2502\t        let opened = Engine::open(dir.path().join(\"rewrite.sqlite\")).expect(\"engine should open\");\n2503\t        let receipt = opened\n2504\t            .engine\n2505\t            .write(&[PreparedWrite::Node { kind: \"doc\".to_string(), body: \"hello\".to_string() }])\n2506\t            .expect(\"write should succeed\");\n2507\t\n2508\t        assert_eq!(receipt.cursor, 1);\n2509\t    }"}]},"parent_tool_use_id":null,"session_id":"62439105-342d-48a7-9848-2f7271298010","uuid":"ea79885a-b39b-42f0-beeb-fe9b86642ce7","timestamp":"2026-05-04T11:53:19.308Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-pack6-F0-thread-affine-readers-20260504T115216Z/src/rust/crates/fathomdb-engine/src/lib.rs","content":"            code,\n        };\n        subscriber.on_event(&event);\n    }\n}\n\n/// Install a `sqlite3_profile` callback on `connection` that dispatches\n/// per-statement profile records and slow-statement signals to the\n/// engine's subscriber registry.\n///\n/// Why FFI rather than `rusqlite::Connection::profile`: the safe API\n/// (rusqlite 0.31) accepts only a `fn(&str, Duration)` with no\n/// environment, so it cannot carry a per-engine subscriber-registry\n/// pointer. We use `sqlite3_profile` directly with a leaked-into-`Box`\n/// context whose pointer is tied to the engine's lifetime via\n/// `Engine::profile_contexts`.\n///\n/// `sqlite3_profile` is documented as deprecated in favor of\n/// `sqlite3_trace_v2`, but it remains supported and is sufficient for\n/// the wall-clock + SQL-text payload required by AC-005a/b.\n#[allow(clippy::vec_box)]\nfn install_profile_callback(\n    connection: &Connection,\n    subscribers: &Arc<lifecycle::SubscriberRegistry>,\n    profiling_enabled: &Arc<AtomicBool>,\n    slow_threshold_ms: &Arc<AtomicU64>,\n    contexts: &mut Vec<Box<ProfileContext>>,\n) {\n    let mut ctx = Box::new(ProfileContext {\n        subscribers: Arc::clone(subscribers),\n        profiling_enabled: Arc::clone(profiling_enabled),\n        slow_threshold_ms: Arc::clone(slow_threshold_ms),\n    });\n    let ctx_ptr: *mut ProfileContext = &mut *ctx;\n\n    // SAFETY: the Box outlives the connection. Rust drops struct fields\n    // in