{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GYek5Y9rFJpwcBfwm4XjjD","type":"tool_result","content":"680\t                    embedder_identity.clone(),\n681\t                );\n682\t\n683\t                install_profile_callback(\n684\t                    &connection,\n685\t                    &subscribers,\n686\t                    &profiling_enabled,\n687\t                    &slow_threshold_ms,\n688\t                    &mut profile_contexts,\n689\t                );\n690\t                for reader in &readers {\n691\t                    install_profile_callback(\n692\t                        reader,\n693\t                        &subscribers,\n694\t                        &profiling_enabled,\n695\t                        &slow_threshold_ms,\n696\t                        &mut profile_contexts,\n697\t                    );\n698\t                }\n699\t\n700\t                let opened = OpenedEngine {\n701\t                    engine: Self {\n702\t                        path: canonical_path.clone(),\n703\t                        next_cursor: AtomicU64::new(next_cursor),\n704\t                        closed: AtomicBool::new(false),\n705\t                        lock: Mutex::new(Some(lock)),\n706\t                        connection: Mutex::new(Some(connection)),\n707\t                        reader_pool: ReaderPool::new(readers),\n708\t                        counters: lifecycle::Counters::new(),\n709\t                        subscribers,\n710\t                        profiling_enabled,\n711\t                        slow_threshold_ms,\n712\t                        runtime_embedder,\n713\t                        runtime_embedder_identity: embedder_identity,\n714\t                        projection_runtime,\n715\t                        provenance_row_cap: AtomicU64::new(DEFAULT_PROVENANCE_ROW_CAP),\n716\t                        profile_contexts: Mutex::new(profile_contexts),\n717\t                        #[cfg(debug_assertions)]\n718\t                        force_next_commit_failure: AtomicBool::new(false),\n719\t                    },\n720\t                    report,\n721\t                };\n722\t                if let Some(subscriber) = initial_subscriber {\n723\t                    opened.engine.subscribers.attach_persistent(subscriber);\n724\t                }\n725\t                if database_has_pending_projection_work(&canonical_path).unwrap_or(false) {\n726\t                    opened.engine.projection_runtime.notify_new_work();\n727\t                }\n728\t                Ok(opened)\n729\t            }\n730\t            Err(err) => {\n731\t                if let Some(subscriber) = initial_subscriber {\n732\t                    emit_open_error_event(&subscriber, &err);\n733\t                }\n734\t                drop(lock);\n735\t                Err(err)\n736\t            }\n737\t        }\n738\t    }\n739\t\n740\t    fn open_locked(\n741\t        path: PathBuf,\n742\t        migrations: &'static [fathomdb_schema::Migration],\n743\t        embedder_identity: &EmbedderIdentity,\n744\t        emit_migration_event: &mut impl FnMut(&MigrationStepReport),\n745\t    ) -> Result<(Connection, Vec<Connection>, OpenReport), EngineOpenError> {\n746\t        register_sqlite_vec_extension();\n747\t        let connection = Connection::open(&path)\n748\t            .map_err(|err| map_open_sqlite_error(err, OpenStage::HeaderProbe))?;\n749\t        connection\n750\t            .pragma_update(None, \"journal_mode\", \"WAL\")\n751\t            .map_err(|err| map_open_sqlite_error(err, OpenStage::WalReplay))?;\n752\t        probe_open_integrity(&connection)?;\n753\t\n754\t        reject_legacy_shape(&connection)?;\n755\t        let migration = migrate_with_event_sink(&connection, migrations, emit_migration_event)\n756\t            .map_err(map_migration_error)?;\n757\t        check_embedder_profile(&connection, embedder_identity)?;\n758\t        ensure_vector_partition(&connection, embedder_identity.dimension).map_err(|_| {\n759\t            EngineOpenError::Io { message: \"could not initialize vector partition\".to_string() }\n760\t        })?;\n761\t\n762\t        let warmup_started = Instant::now();\n763\t        let report = OpenReport {\n764\t            schema_version_before: migration.schema_version_before,\n765\t            schema_version_after: migration.schema_version_after,\n766\t            migration_steps: migration.migration_steps,\n767\t            embedder_warmup_ms: u64::try_from(warmup_started.elapsed().as_millis())\n768\t                .unwrap_or(u64::MAX),\n769\t            query_backend: \"fathomdb-query + sqlite-vec\",\n770\t            default_embedder: embedder_identity.clone(),\n771\t        };\n772\t\n773\t        let mut readers = Vec::with_capacity(READER_POOL_SIZE);\n774\t        for _ in 0..READER_POOL_SIZE {\n775\t            let reader = Connection::open(&path)\n776\t                .map_err(|err| map_open_sqlite_error(err, OpenStage::HeaderProbe))?;\n777\t            reader\n778\t                .pragma_update(None, \"journal_mode\", \"WAL\")\n779\t                .map_err(|err| map_open_sqlite_error(err, OpenStage::WalReplay))?;\n780\t            reader\n781\t                .pragma_update(None, \"query_only\", \"ON\")\n782\t                .map_err(|err| map_open_sqlite_error(err, OpenStage::SchemaProbe))?;\n783\t            readers.push(reader);\n784\t        }\n785\t\n786\t        Ok((connection, readers, report))\n787\t    }\n788\t\n789\t    #[must_use]\n790\t    pub fn path(&self) -> &Path {\n791\t        &self.path\n792\t    }\n793\t\n794\t    pub fn write(&self, batch: &[PreparedWrite]) -> Result<WriteReceipt, EngineError> {\n795\t        let category = if batch_is_admin(batch) {\n796\t            lifecycle::EventCategory::Admin\n797\t        } else {\n798\t            lifecycle::EventCategory::Writer\n799\t        };\n800\t        self.emit_event(lifecycle::Phase::Started, category, None);\n801\t        let started = Instant::now();\n802\t        let outcome = self.write_inner(batch);\n803\t        self.detect_slow(started, category);\n804\t        match outcome {\n805\t            Ok(receipt) => {\n806\t                let rows = u64::try_from(batch.len()).unwrap_or(u64::MAX);\n807\t                if batch_is_admin(batch) {\n808\t                    self.counters.record_admin();\n809\t                } else {\n810\t                    self.counters.record_write(rows);\n811\t                }\n812\t                self.emit_event(lifecycle::Phase::Finished, category, None);\n813\t                Ok(receipt)\n814\t            }\n815\t            Err(err) => {\n816\t                let code = err.stable_code();\n817\t                self.counters.record_error(code);\n818\t                // AC-003d: capture-ordinal < raise-ordinal — Failed and Error\n819\t                // events both fire before the EngineError returns to the caller.\n820\t                self.emit_event(lifecycle::Phase::Failed, category, Some(code));\n821\t                self.emit_event(\n822\t                    lifecycle::Phase::Failed,\n823\t                    lifecycle::EventCategory::Error,\n824\t                    Some(code),\n825\t                );\n826\t                Err(err)\n827\t            }\n828\t        }\n829\t    }\n830\t\n831\t    fn write_inner(&self, batch: &[PreparedWrite]) -> Result<WriteReceipt, EngineError> {\n832\t        self.ensure_open()?;\n833\t\n834\t        if batch.is_empty() {\n835\t            return Err(EngineError::WriteValidation);\n836\t        }\n837\t\n838\t        let mut connection = self.connection.lock().map_err(|_| EngineError::Storage)?;\n839\t        let connection = connection.as_mut().ok_or(EngineError::Closing)?;\n840\t        let plans = validate_batch(connection, batch)?;\n841\t        let projection_jobs = collect_projection_jobs(connection, batch)?;\n842\t        #[cfg(debug_assertions)]\n843\t        if self.force_next_commit_failure.swap(false, Ordering::SeqCst) {\n844\t            return Err(EngineError::Storage);\n845\t        }\n846\t        let increment = u64::try_from(batch.len()).unwrap_or(u64::MAX);\n847\t        let cursor = self.next_cursor.load(Ordering::SeqCst).saturating_add(increment);\n848\t        let pending_projection = !projection_jobs.is_empty();\n849\t\n850\t        if let Err(err) = commit_batch(\n851\t            connection,\n852\t            batch,\n853\t            &plans,\n854\t            cursor,\n855\t            pending_projection,\n856\t            self.provenance_row_cap.load(Ordering::Relaxed),\n857\t        ) {\n858\t            self.emit_sqlite_internal_error(&err);\n859\t            return Err(EngineError::Storage);\n860\t        }\n861\t        self.next_cursor.store(cursor, Ordering::SeqCst);\n862\t        if pending_projection {\n863\t            self.projection_runtime.notify_new_work();\n864\t        }\n865\t\n866\t        Ok(WriteReceipt { cursor })\n867\t    }\n868\t\n869\t    pub fn search(&self, query: &str) -> Result<SearchResult, EngineError> {\n870\t        self.emit_event(lifecycle::Phase::Started, lifecycle::EventCategory::Search, None);\n871\t        let started = Instant::now();\n872\t        let outcome = self.search_inner(query);\n873\t        self.detect_slow(started, lifecycle::EventCategory::Search);\n874\t        match outcome {\n875\t            Ok(result) => {\n876\t                self.counters.record_query();\n877\t                self.emit_event(lifecycle::Phase::Finished, lifecycle::EventCategory::Search, None);\n878\t                Ok(result)\n879\t            }\n880\t            Err(err) => {\n881\t                let code = err.stable_code();\n882\t                self.counters.record_error(code);\n883\t                self.emit_event(\n884\t                    lifecycle::Phase::Failed,\n885\t                    lifecycle::EventCategory::Search,\n886\t                    Some(code),\n887\t                );\n888\t                self.emit_event(\n889\t                    lifecycle::Phase::Failed,\n890\t                    lifecycle::EventCategory::Error,\n891\t                    Some(code),\n892\t                );\n893\t                Err(err)\n894\t            }\n895\t        }\n896\t    }\n897\t\n898\t    fn detect_slow(&self, started: Instant, category: lifecycle::EventCategory) {\n899\t        let elapsed = started.elapsed();\n900\t        let threshold = self.slow_threshold_ms.load(Ordering::Relaxed);\n901\t        let threshold_duration = std::time::Duration::from_millis(threshold);\n902\t        if elapsed > threshold_duration {\n903\t            // `dev/design/lifecycle.md` § Slow and heartbeat policy: a slow\n904\t            // operation produces TWO correlated facts. The\n905\t            // statement-level slow-statement signal is dispatched by the\n906\t            // sqlite3_profile callback (`profile_callback_trampoline`).\n907\t            // This site emits the lifecycle `Phase::Slow` event for the\n908\t            // outer operation envelope (AC-008).\n909\t            self.emit_event(lifecycle::Phase::Slow, category, None);\n910\t        }\n911\t    }\n912\t\n913\t    fn emit_event(\n914\t        &self,\n915\t        phase: lifecycle::Phase,\n916\t        category: lifecycle::EventCategory,\n917\t        code: Option<&'static str>,\n918\t    ) {\n919\t        let event =\n920\t            lifecycle::Event { phase, source: lifecycle::EventSource::Engine, category, code };\n921\t        self.subscribers.dispatch(&event);\n922\t    }\n923\t\n924\t    /// Emit a `(SqliteInternal, Error, code: <SQLITE_*>)` lifecycle\n925\t    /// event for a rusqlite error. Per `dev/design/lifecycle.md`\n926\t    /// § Diagnostic source and category, SQLite-originated diagnostics\n927\t    /// route through the same host subscriber as engine-originated\n928\t    /// events with `source` preserved. AC-021 dispatches on\n929\t    /// `code == \"SQLITE_SCHEMA\"`.\n930\t    fn emit_sqlite_internal_error(&self, err: &rusqlite::Error) {\n931\t        if let Some(code) = sqlite_extended_code_name(err) {\n932\t            let event = lifecycle::Event {\n933\t                phase: lifecycle::Phase::Failed,\n934\t                source: lifecycle::EventSource::SqliteInternal,\n935\t                category: lifecycle::EventCategory::Error,\n936\t                code: Some(code),\n937\t            };\n938\t            self.subscribers.dispatch(&event);\n939\t        }\n940\t    }\n941\t\n942\t    fn search_inner(&self, query: &str) -> Result<SearchResult, EngineError> {\n943\t        self.ensure_open()?;\n944\t        if query.trim().is_empty() {\n945\t            return Err(EngineError::WriteValidation);\n946\t        }\n947\t\n948\t        let compiled = compile_text_query(query);\n949\t        // REQ-013 / AC-059b / REQ-055: the cursor returned with a search\n950\t        // MUST be derived from the same WAL snapshot the data was read\n951\t        // from. Loading `next_cursor` from the writer-side atomic before\n952\t        // the reader transaction acquires its snapshot races against\n953\t        // concurrent writers — see `dev/design/engine.md` § Cursor\n954\t        // contract. Run cursor probe + body query inside one read tx\n955\t        // (BEGIN DEFERRED on a `query_only=ON` connection in WAL mode is\n956\t        // a snapshot-stable read).\n957\t        let query_vector = self\n958\t            .runtime_embedder\n959\t            .as_ref()\n960\t            .and_then(|embedder| embedder.embed(query).ok())\n961\t            .and_then(|vector| serde_json::to_string(&vector).ok());\n962\t        let Some(mut reader) = self.reader_pool.borrow() else {\n963\t            return Err(EngineError::Storage);\n964\t        };\n965\t        let search_result = read_search_in_tx(&mut reader, &compiled, query_vector.as_deref());\n966\t        self.reader_pool.release(reader);\n967\t        let (cursor, soft_fallback, results) = match search_result {\n968\t            Ok(result) => result,\n969\t            Err(err) => {\n970\t                self.emit_sqlite_internal_error(&err);\n971\t                return Err(EngineError::Storage);\n972\t            }\n973\t        };\n974\t\n975\t        Ok(SearchResult { projection_cursor: cursor, soft_fallback, results })\n976\t    }\n977\t\n978\t    pub fn close(&self) -> Result<(), EngineError> {\n979\t        self.closed.store(true, Ordering::SeqCst);\n980\t        self.projection_runtime.stop();\n981\t        // Uninstall profile callbacks before dropping the connections so\n982\t        // SQLite cannot fire one last callback against a profile context\n983\t        // whose Box is about to free. Per `dev/design/engine.md` § Close\n984\t        // path step 6, readers drain before the writer connection so\n985\t        // SQLite's last-handle checkpointer runs on the writer.\n986\t        let readers = self.reader_pool.drain();\n987\t        for reader in &readers {\n988\t            uninstall_profile_callback(reader);\n989\t        }\n990\t        drop(readers);\n991\t        if let Ok(mut connection) = self.connection.lock() {\n992\t            if let Some(conn) = connection.as_ref() {\n993\t                uninstall_profile_callback(conn);\n994\t            }\n995\t            connection.take();\n996\t        }\n997\t        if let Ok(mut contexts) = self.profile_contexts.lock() {\n998\t            contexts.clear();\n999\t        }\n1000\t        if let Ok(mut lock) = self.lock.lock() {\n1001\t            lock.take();\n1002\t        }\n1003\t        Ok(())\n1004\t    }\n1005\t\n1006\t    /// Block until in-flight writes drain or `timeout_ms` elapses.\n1007\t    ///\n1008\t    /// Surface owned by `dev/interfaces/rust.md` § Engine-attached\n1009\t    /// instrumentation; semantics are owned by `dev/design/lifecycle.md`.\n1010\t    pub fn drain(&self, timeout_ms: u64) -> Result<(), EngineError> {\n1011\t        self.ensure_open()?;\n1012\t        if self.projection_runtime.wait_for_idle(timeout_ms) {\n1013\t            Ok(())\n1014\t        } else {\n1015\t            Err(EngineError::Scheduler)\n1016\t        }\n1017\t    }\n1018\t\n1019\t    /// Snapshot of engine-internal counters."}]},"parent_tool_use_id":null,"session_id":"62439105-342d-48a7-9848-2f7271298010","uuid":"cfa46f3b-d2d9-4522-a063-999b62a82894","timestamp":"2026-05-04T11:53:10.688Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-pack6-F0-thread-affine-readers-20260504T115216Z/src/rust/crates/fathomdb-engine/src/lib.rs","content":"                    embedder_identity.clone(),\n                );\n\n                install_profile_callback(\n                    &connection,\n                    &subscribers,\n                    &profiling_enabled,\n                    &slow_threshold_ms,\n                    &mut profile_contexts,\n                );\n                for reader in &readers {\n                    install_profile_callback(\n                        reader,\n                        &subscribers,\n                        &profiling_enabled,\n                        &slow_threshold_ms,\n                        &mut profile_contexts,\n                    );\n                }\n\n                let opened = OpenedEngine {\n                    engine: Self {\n                        path: canonical_path.clone(),\n                        next_cursor: AtomicU64::new(next_cursor),\n                        closed: AtomicBool::new(false),\n                        lock: Mutex::new(Some(lock)),\n                        connection: Mutex::new(Some(connection)),\n                        reader_pool: ReaderPool::new(readers),\n                        counters: lifecycle::Counters::new(),\n                        subscribers,\n                        profiling_enabled,\n                        slow_threshold_ms,\n                        runtime_embedder,\n                        runtime_embedder_identity: embedder_identity,\n                        projection_runtime,\n                        provenance_row_cap: AtomicU64::new(DEFAULT_PROVENANCE_ROW_CAP),\n                        profile_contexts: Mutex::new(profile_contexts),\n                        #[cfg(debug_assertions)]\n                        force_next_commit_failure: AtomicBool::new(false),\n                    },\n                    report,\n                };\n                if let Some(subscriber) = initial_subscriber {\n                    opened.engine.subscribers.attach_persistent(subscriber);\n                }\n                if database_has_pending_projection_work(&canonical_path).unwrap_or(false) {\n                    opened.engine.projection_runtime.notify_new_work();\n                }\n                Ok(opened)\n            }\n            Err(err) => {\n                if let Some(subscriber) = initial_subscriber {\n                    emit_open_error_event(&subscriber, &err);\n                }\n                drop(lock);\n                Err(err)\n            }\n        }\n    }\n\n    fn open_locked(\n        path: PathBuf,\n        migrations: &'static [fathomdb_schema::Migration],\n        embedder_identity: &EmbedderIdentity,\n        emit_migration_event: &mut impl FnMut(&MigrationStepReport),\n    ) -> Result<(Connection, Vec<Connection>, OpenReport), EngineOpenError> {\n        register_sqlite_vec_extension();\n        let connection = Connection::open(&path)\n            .map_err(|err| map_open_sqlite_error(err, OpenStage::HeaderProbe))?;\n        connection\n            .pragma_update(None, \"journal_mode\", \"WAL\")\n            .map_err(|err| map_open_sqlite_error(err, OpenStage::WalReplay))?;\n        probe_open_integrity(&connection)?;\n\n        reject_legacy_shape(&connection)?;\n        let migration = migrate_with_event_sink(&connection, migrations, emit_migration_event)\n            .map_err(map_migration_error)?;\n        check_embedder_profile(&connection, embedder_identity)?;\n        ensure_vector_partition(&connection, embedder_identity.dimension).map_err(|_| {\n            EngineOpenError::Io { message: \"could not initialize vector partition\".to_string() }\n        })?;\n\n        let warmup_started = Instant::now();\n        let report = OpenReport {\n            schema_version_before: migration.schema_version_before,\n            schema_version_after: migration.schema_version_after,\n            migration_steps: migration.migration_steps,\n            embedder_warmup_ms: u64::try_from(warmup_started.elapsed().as_millis())\n                .unwrap_or(u64::MAX),\n            query_backend: \"fathomdb-query + sqlite-vec\",\n            default_embedder: embedder_identity.clone(),\n        };\n\n        let mut readers = Vec::with_capacity(READER_POOL_SIZE);\n        for _ in 0..READER_POOL_SIZE {\n            let reader = Connection::open(&path)\n                .map_err(|err| map_open_sqlite_error(err, OpenStage::HeaderProbe))?;\n            reader\n                .pragma_update(None, \"journal_mode\", \"WAL\")\n                .map_err(|err| map_open_sqlite_error(err, OpenStage::WalReplay))?;\n            reader\n                .pragma_update(None, \"query_only\", \"ON\")\n                .map_err(|err| map_open_sqlite_error(err, OpenStage::SchemaProbe))?;\n            readers.push(reader);\n        }\n\n        Ok((connection, readers, report))\n    }\n\n    #[must_use]\n    pub fn path(&self) -> &Path {\n        &self.path\n    }\n\n    pub fn write(&self, batch: &[PreparedWrite]) -> Result<WriteReceipt, EngineError> {\n        let category = if batch_is_admin(batch) {\n            lifecycle::EventCategory::Admin\n        } else {\n            lifecycle::EventCategory::Writer\n        };\n        self.emit_event(lifecycle::Phase::Started, category, None);\n        let started = Instant::now();\n        let outcome = self.write_inner(batch);\n        self.detect_slow(started, category);\n        match outcome {\n            Ok(receipt) => {\n                let rows = u64::try_from(batch.len()).unwrap_or(u64::MAX);\n                if batch_is_admin(batch) {\n                    self.counters.record_admin();\n                } else {\n                    self.counters.record_write(rows);\n                }\n                self.emit_event(lifecycle::Phase::Finished, category, None);\n                Ok(receipt)\n            }\n            Err(err) => {\n                let code = err.stable_code();\n                self.counters.record_error(code);\n                // AC-003d: capture-ordinal < raise-ordinal — Failed and Error\n                // events both fire before the EngineError returns to the caller.\n                self.emit_event(lifecycle::Phase::Failed, category, Some(code));\n                self.emit_event(\n                    lifecycle::Phase::Failed,\n                    lifecycle::EventCategory::Error,\n                    Some(code),\n                );\n                Err(err)\n            }\n        }\n    }\n\n    fn write_inner(&self, batch: &[PreparedWrite]) -> Result<WriteReceipt, EngineError> {\n        self.ensure_open()?;\n\n        if batch.is_empty() {\n            return Err(EngineError::WriteValidation);\n        }\n\n        let mut connection = self.connection.lock().map_err(|_| EngineError::Storage)?;\n        let connection = connection.as_mut().ok_or(EngineError::Closing)?;\n        let plans = validate_batch(connection, batch)?;\n        let projection_jobs = collect_projection_jobs(connection, batch)?;\n        #[cfg(debug_assertions)]\n        if self.force_next_commit_failure.swap(false, Ordering::SeqCst) {\n            return Err(EngineError::Storage);\n        }\n        let increment = u64::try_from(batch.len()).unwrap_or(u64::MAX);\n        let cursor = self.next_cursor.load(Ordering::SeqCst).saturating_add(increment);\n        let pending_projection = !projection_jobs.is_empty();\n\n        if let Err(err) = commit_batch(\n            connection,\n            batch,\n            &plans,\n            cursor,\n            pending_projection,\n            self.provenance_row_cap.load(Ordering::Relaxed),\n        ) {\n            self.emit_sqlite_internal_error(&err);\n            return Err(EngineError::Storage);\n        }\n        self.next_cursor.store(cursor, Ordering::SeqCst);\n        if pending_projection {\n            self.projection_runtime.notify_new_work();\n        }\n\n        Ok(WriteReceipt { cursor })\n    }\n\n    pub fn search(&self, query: &str) -> Result<SearchResult, EngineError> {\n        self.emit_event(lifecycle::Phase::Started, lifecycle::EventCategory::Search, None);\n        let started = Instant::now();\n        let outcome = self.search_inner(query);\n        self.detect_slow(started, lifecycle::EventCategory::Search);\n        match outcome {\n            Ok(result) => {\n                self.counters.record_query();\n                self.emit_event(lifecycle::Phase::Finished, lifecycle::EventCategory::Search, None);\n                Ok(result)\n            }\n            Err(err) => {\n                let code = err.stable_code();\n                self.counters.record_error(code);\n                self.emit_event(\n                    lifecycle::Phase::Failed,\n                    lifecycle::EventCategory::Search,\n                    Some(code),\n                );\n                self.emit_event(\n                    lifecycle::Phase::Failed,\n                    lifecycle::EventCategory::Error,\n                    Some(code),\n                );\n                Err(err)\n            }\n        }\n    }\n\n    fn detect_slow(&self, started: Instant, category: lifecycle::EventCategory) {\n        let elapsed = started.elapsed();\n        let threshold = self.slow_threshold_ms.load(Ordering::Relaxed);\n        let threshold_duration = std::time::Duration::from_millis(threshold);\n        if elapsed > threshold_duration {\n            // `dev/design/lifecycle.md` § Slow and heartbeat policy: a slow\n            // operation produces TWO correlated facts. The\n            // statement-level slow-statement signal is dispatched by the\n            // sqlite3_profile callback (`profile_callback_trampoline`).\n            // This site emits the lifecycle `Phase::Slow` event for the\n            // outer operation envelope (AC-008).\n            self.emit_event(lifecycle::Phase::Slow, category, None);\n        }\n    }\n\n    fn emit_event(\n        &self,\n        phase: lifecycle::Phase,\n        category: lifecycle::EventCategory,\n        code: Option<&'static str>,\n    ) {\n        let event =\n            lifecycle::Event { phase, source: lifecycle::EventSource::Engine, category, code };\n        self.subscribers.dispatch(&event);\n    }\n\n    /// Emit a `(SqliteInternal, Error, code: <SQLITE_*>)` lifecycle\n    /// event for a rusqlite error. Per `dev/design/lifecycle.md`\n    /// § Diagnostic source and category, SQLite-originated diagnostics\n    /// route through the same host subscriber as engine-originated\n    /// events with `source` preserved. AC-021 dispatches on\n    /// `code == \"SQLITE_SCHEMA\"`.\n    fn emit_sqlite_internal_error(&self, err: &rusqlite::Error) {\n        if let Some(code) = sqlite_extended_code_name(err) {\n            let event = lifecycle::Event {\n                phase: lifecycle::Phase::Failed,\n                source: lifecycle::EventSource::SqliteInternal,\n                category: lifecycle::EventCategory::Error,\n                code: Some(code),\n            };\n            self.subscribers.dispatch(&event);\n        }\n    }\n\n    fn search_inner(&self, query: &str) -> Result<SearchResult, EngineError> {\n        self.ensure_open()?;\n        if query.trim().is_empty() {\n            return Err(EngineError::WriteValidation);\n        }\n\n        let compiled = compile_text_query(query);\n        // REQ-013 / AC-059b / REQ-055: the cursor returned with a search\n        // MUST be derived from the same WAL snapshot the data was read\n        // from. Loading `next_cursor` from the writer-side atomic before\n        // the reader transaction acquires its snapshot races against\n        // concurrent writers — see `dev/design/engine.md` § Cursor\n        // contract. Run cursor probe + body query inside one read tx\n        // (BEGIN DEFERRED on a `query_only=ON` connection in WAL mode is\n        // a snapshot-stable read).\n        let query_vector = self\n            .runtime_embedder\n            .as_ref()\n            .and_then(|embedder| embedder.embed(query).ok())\n            .and_then(|vector| serde_json::to_string(&vector).ok());\n        let Some(mut reader) = self.reader_pool.borrow() else {\n            return Err(EngineError::Storage);\n        };\n        let search_result = read_search_in_tx(&mut reader, &compiled, query_vector.as_deref());\n        self.reader_pool.release(reader);\n        let (cursor, soft_fallback, results) = match search_result {\n            Ok(result) => result,\n            Err(err) => {\n                self.emit_sqlite_internal_error(&err);\n                return Err(EngineError::Storage);\n            }\n        };\n\n        Ok(SearchResult { projection_cursor: cursor, soft_fallback, results })\n    }\n\n    pub fn close(&self) -> Result<(), EngineError> {\n        self.closed.store(true, Ordering::SeqCst);\n        self.projection_runtime.stop();\n        // Uninstall profile callbacks before dropping the connections so\n        // SQLite cannot fire one last callback against a profile context\n        // whose Box is about to free. Per `dev/design/engine.md` § Close\n        // path step 6, readers drain before the writer connection so\n        // SQLite's last-handle checkpointer runs on the writer.\n        let readers = self.reader_pool.drain();\n        for reader in &readers {\n            uninstall_profile_callback(reader);\n        }\n        drop(readers);\n        if let Ok(mut connection) = self.connection.lock() {\n            if let Some(conn) = connection.as_ref() {\n                uninstall_profile_callback(conn);\n            }\n            connection.take();\n        }\n        if let Ok(mut contexts) = self.profile_contexts.lock() {\n            contexts.clear();\n        }\n        if let Ok(mut lock) = self.lock.lock() {\n            lock.take();\n        }\n        Ok(())\n    }\n\n    /// Block until in-flight writes drain or `timeout_ms` elapses.\n    ///\n    /// Surface owned by `dev/interfaces/rust.md` § Engine-attached\n    /// instrumentation; semantics are owned by `dev/design/lifecycle.md`.\n    pub fn drain(&self, timeout_ms: u64) -> Result<(), EngineError> {\n        self.ensure_open()?;\n        if self.projection_runtime.wait_for_idle(timeout_ms) {\n            Ok(())\n        } else {\n            Err(EngineError::Scheduler)\n        }\n    }\n\n    /// Snapshot of engine-internal counters.","numLines":340,"startLine":680,"totalLines":2511}}}
