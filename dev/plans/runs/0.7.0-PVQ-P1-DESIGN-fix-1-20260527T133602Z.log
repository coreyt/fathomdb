{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R8ULmPbzoHyRCmmdBdHfzz","type":"tool_result","content":"895\t    pub table: &'static str,\n896\t}\n897\t\n898\t/// Which shadow-state surface a [`RebuildReport`] describes.\n899\t/// `Projections` covers the full FTS5 + vec0 + projection-terminal\n900\t/// rebuild emitted by [`Engine::rebuild_projections`]. `Vec0` covers\n901\t/// the vec0-only path emitted by [`Engine::rebuild_vec0`].\n902\t#[derive(Clone, Copy, Debug, Eq, PartialEq)]\n903\tpub enum RebuildKind {\n904\t    Projections,\n905\t    Vec0,\n906\t}\n907\t\n908\t/// Structured result of a rebuild operation. `rows_invalidated` is the\n909\t/// total shadow-state rows truncated before re-derivation; `rows_rebuilt`\n910\t/// is the count of rows the synchronous rebuild loop re-materialised\n911\t/// (asynchronous re-enqueue work performed by the projection scheduler is\n912\t/// not counted here). `projection_cursor_after` is the post-rebuild value\n913\t/// of the projection cursor.\n914\t#[derive(Clone, Debug, Eq, PartialEq)]\n915\tpub struct RebuildReport {\n916\t    pub kind: RebuildKind,\n917\t    pub rows_invalidated: u64,\n918\t    pub rows_rebuilt: u64,\n919\t    pub projection_cursor_after: u64,\n920\t}\n921\t\n922\t/// Phase 9 Pack B excise report (AC-028a/b/c). Counts are post-excise\n923\t/// totals; `projections_invalidated` reports the shadow-row invalidation\n924\t/// total (FTS5 + vec0 + projection terminal) for the excised source.\n925\t#[derive(Clone, Debug, Eq, PartialEq)]\n926\tpub struct ExciseReport {\n927\t    pub source_ref: String,\n928\t    pub nodes_excised: u64,\n929\t    pub edges_excised: u64,"}]},"parent_tool_use_id":null,"session_id":"15e9754f-2583-43b5-b988-10adeffaf9c5","uuid":"d7171d7e-f57b-4b8d-88e6-8c50f89f26c2","timestamp":"2026-05-27T13:36:23.861Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-0.7.0-PVQ-P1-DESIGN-20260527T132416Z/src/rust/crates/fathomdb-engine/src/lib.rs","content":"    pub table: &'static str,\n}\n\n/// Which shadow-state surface a [`RebuildReport`] describes.\n/// `Projections` covers the full FTS5 + vec0 + projection-terminal\n/// rebuild emitted by [`Engine::rebuild_projections`]. `Vec0` covers\n/// the vec0-only path emitted by [`Engine::rebuild_vec0`].\n#[derive(Clone, Copy, Debug, Eq, PartialEq)]\npub enum RebuildKind {\n    Projections,\n    Vec0,\n}\n\n/// Structured result of a rebuild operation. `rows_invalidated` is the\n/// total shadow-state rows truncated before re-derivation; `rows_rebuilt`\n/// is the count of rows the synchronous rebuild loop re-materialised\n/// (asynchronous re-enqueue work performed by the projection scheduler is\n/// not counted here). `projection_cursor_after` is the post-rebuild value\n/// of the projection cursor.\n#[derive(Clone, Debug, Eq, PartialEq)]\npub struct RebuildReport {\n    pub kind: RebuildKind,\n    pub rows_invalidated: u64,\n    pub rows_rebuilt: u64,\n    pub projection_cursor_after: u64,\n}\n\n/// Phase 9 Pack B excise report (AC-028a/b/c). Counts are post-excise\n/// totals; `projections_invalidated` reports the shadow-row invalidation\n/// total (FTS5 + vec0 + projection terminal) for the excised source.\n#[derive(Clone, Debug, Eq, PartialEq)]\npub struct ExciseReport {\n    pub source_ref: String,\n    pub nodes_excised: u64,\n    pub edges_excised: u64,","numLines":35,"startLine":895,"totalLines":4114}}}
