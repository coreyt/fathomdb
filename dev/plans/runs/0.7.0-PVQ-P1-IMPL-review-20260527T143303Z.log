+            [DEFAULT_VECTOR_PARTITION],
+            |row| row.get::<_, String>(0),
+        )
+        .optional()?;
+
+    match existing_sql {
+        None => create_vector_partition(connection, dimension),
+        Some(sql) if sql.contains("embedding_bin") => Ok(()),
+        Some(_) => migrate_vector_partition_to_pack1(connection, dimension),
+    }
+}
