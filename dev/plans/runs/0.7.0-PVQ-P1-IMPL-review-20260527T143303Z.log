  3325	        "CREATE VIRTUAL TABLE IF NOT EXISTS {DEFAULT_VECTOR_PARTITION} USING vec0(\
  3326	            embedding float[{dimension}],\
  3327	            embedding_bin bit[{dimension}],\
  3328	            source_type TEXT partition key,\
  3329	            kind TEXT,\
  3330	            created_at INTEGER\
  3331	         )"
  3332	    );
  3333	    connection.execute_batch(&sql)
  3334	}
