  3294	fn ensure_vector_partition(connection: &mut Connection, dimension: u32) -> rusqlite::Result<()> {
  3295	    // 0.7.0 Pack 1 schema per dev/design/0.7.0-vector-quant-pack1.md D1/D2:
  3296	    // f32 `embedding` + binary-quant sibling `embedding_bin` + `source_type`
  3297	    // partition key + `kind` + `created_at`. The vec0 column type is
  3298	    // dim-parameterized, so the reshape lives here rather than in the
  3299	    // SQL-only migration framework — see fathomdb-schema migration step 9
  3300	    // and dev/plans/runs/0.7.0-PVQ-P1-IMPL-output.json for the deviation
  3301	    // from the design memo's "Choose (a)" guidance.
  3302	    //
  3303	    // Three paths:
  3304	    //   (1) no vector_default       -> CREATE at new shape.
  3305	    //   (2) old single-column shape -> stage + drop + recreate at new shape
  3306	    //                                  + repopulate with vec_quantize_binary.
  3307	    //   (3) already new shape       -> no-op.
  3308	    let existing_sql: Option<String> = connection
  3309	        .query_row(
  3310	            "SELECT sql FROM sqlite_master WHERE type='table' AND name=?1",
  3311	            [DEFAULT_VECTOR_PARTITION],
  3312	            |row| row.get::<_, String>(0),
  3313	        )
  3314	        .optional()?;
  3315	
  3316	    match existing_sql {
  3317	        None => create_vector_partition(connection, dimension),
  3318	        Some(sql) if sql.contains("embedding_bin") => Ok(()),
  3319	        Some(_) => migrate_vector_partition_to_pack1(connection, dimension),
  3320	    }
  3321	}
