    70	/// An ORT execution provider selection, resolved from the `FATHOMDB_EMBED_DEVICE`
    71	/// grammar. Kept as a plain enum (no `ort` types) so the request→provider
    72	/// mapping is pure + unit-testable without a model or a native runtime.
    73	#[derive(Clone, Copy, Debug, PartialEq, Eq)]
    74	pub(crate) enum OrtProvider {
    75	    Cpu,
    76	    Cuda(i32),
    77	    Rocm(i32),
    78	    DirectMl(i32),
    79	    OpenVino,
    80	}
    81	
    82	/// PURE map from the backend-agnostic [`DeviceRequest`] (parsed by the shared
    83	/// `parse_device_request`, grammar parity with candle) to an [`OrtProvider`].
    84	///
    85	/// Returns the provider plus an optional LOUD-fallback message when the request
    86	/// could not be honored and CPU was substituted (mirrors candle's loud CPU
    87	/// fallback). The cross-vendor providers candle cannot reach — ROCm / DirectML
    88	/// / OpenVINO — are requested through the base grammar's `Unknown` arm
    89	/// (`FATHOMDB_EMBED_DEVICE=rocm|rocm:N|directml|openvino`), so the shared
    90	/// parser stays unchanged and ONNX only extends the interpretation.
    91	pub(crate) fn map_device_request(req: &DeviceRequest) -> (OrtProvider, Option<String>) {
    92	    match req {
    93	        DeviceRequest::Cpu => (OrtProvider::Cpu, None),
    94	        DeviceRequest::Cuda(idx) => (OrtProvider::Cuda(*idx as i32), None),
    95	        DeviceRequest::Metal => (
    96	            OrtProvider::Cpu,
    97	            Some(
    98	                "FATHOMDB_EMBED_DEVICE=metal is a candle backend; the ONNX path has no Metal \
    99	                 execution provider (use rocm|directml|openvino for cross-vendor GPUs, or \
   100	                 candle's embed-metal build); using CPU"
   101	                    .to_string(),
   102	            ),
   103	        ),
   104	        DeviceRequest::Unknown(name) => map_extended_provider(name),
   105	    }
   106	}
   107	
   108	/// Interpret an `Unknown` device token as a cross-vendor ORT provider.
   109	/// Accepts `rocm`|`rocm:N`, `directml`|`dml`|`directml:N`, `openvino`|`ovep`.
   110	/// Anything else is a LOUD CPU fallback.
   111	fn map_extended_provider(raw: &str) -> (OrtProvider, Option<String>) {
   112	    let (head, idx) = match raw.split_once(':') {
   113	        Some((h, i)) => (h, i.parse::<i32>().unwrap_or(0)),
   114	        None => (raw, 0),
   115	    };
   116	    match head {
   117	        "rocm" => (OrtProvider::Rocm(idx), None),
   118	        "directml" | "dml" => (OrtProvider::DirectMl(idx), None),
   119	        "openvino" | "ovep" => (OrtProvider::OpenVino, None),
   120	        other => (
   121	            OrtProvider::Cpu,
   122	            Some(format!(
   123	                "FATHOMDB_EMBED_DEVICE={other} is not a recognized ONNX execution provider \
   124	                 (expected cpu|cuda|cuda:N|rocm|rocm:N|directml|openvino); using CPU"
   125	            )),
   126	        ),
   127	    }
   128	}
   129	
   130	/// Emit a LOUD construction-time fallback warning to stderr. Centralized so the
   131	/// `clippy::print_stderr` allow is scoped to construction (never `embed()`), and
   132	/// so the loud fallback is OUR OWN — `ort` is built `default-features = false`,
   133	/// which compiles out its warn/error macros, so we cannot rely on it to surface
   134	/// a silent CPU fallback (R-ONNX-2).
   135	#[allow(clippy::print_stderr)] // construction-time only (not in `embed()`)
   136	fn emit_onnx_warning(msg: &str) {
   137	    eprintln!("fathomdb-embedder(onnx): {msg}");
   138	}
   139	
   140	/// RUNTIME resolution of the ORT provider from `FATHOMDB_EMBED_DEVICE`
   141	/// (R-ONNX-2 — not a compile-time constant). Emits the LOUD stderr fallback
   142	/// message at construction time, never inside `embed()`.
   143	fn resolve_provider_from_env() -> OrtProvider {
   144	    let raw = std::env::var("FATHOMDB_EMBED_DEVICE").unwrap_or_default();
   145	    let (provider, warn) = map_device_request(&parse_device_request(&raw));
   146	    if let Some(msg) = warn {
   147	        emit_onnx_warning(&msg);
   148	    }
   149	    provider
   150	}
   151	
   152	/// PURE decision for the SESSION-BUILD stage of the loud fallback (R-ONNX-2):
   153	/// given a requested [`OrtProvider`] and an availability probe, return the
   154	/// EFFECTIVE provider plus an optional LOUD warning. A non-CPU provider the
   155	/// probe reports unavailable is downgraded to CPU and the warning names the
   156	/// requested provider; the caller emits it. This is distinct from the earlier
   157	/// grammar-mapping warning ([`map_device_request`]): a request like `rocm` maps
   158	/// cleanly to `Rocm`, but if this ONNX Runtime build lacks the ROCm EP, `ort`'s
   159	/// own dispatch would fall back to CPU SILENTLY (its log macros are compiled out
   160	/// under `default-features = false`), making a cross-vendor run look successful
   161	/// while secretly on CPU. Kept pure (probe injected) so it is unit-testable
   162	/// with no model and no ORT native lib.
   163	fn resolve_effective_provider_with(
   164	    requested: OrtProvider,
   165	    is_available: impl Fn(OrtProvider) -> bool,
   166	) -> (OrtProvider, Option<String>) {
   167	    if matches!(requested, OrtProvider::Cpu) {
   168	        return (OrtProvider::Cpu, None);
   169	    }
   170	    if is_available(requested) {
   171	        (requested, None)
   172	    } else {
   173	        (
   174	            OrtProvider::Cpu,
   175	            Some(format!(
   176	                "requested ONNX execution provider {requested:?} is unavailable in this ONNX \
   177	                 Runtime build/runtime (ort is built default-features=false, so its own fallback \
   178	                 log is compiled out); falling back to CPU"
   179	            )),
   180	        )
   181	    }
   182	}
   183	
   184	/// Thin LIVE wrapper over [`resolve_effective_provider_with`] using `ort`'s real
   185	/// `ExecutionProvider::is_available()` probe.
   186	fn resolve_effective_provider(requested: OrtProvider) -> (OrtProvider, Option<String>) {
   187	    resolve_effective_provider_with(requested, provider_is_available)
   188	}
   189	
   190	/// Probe whether this ONNX Runtime build was compiled with support for the
   191	/// requested non-CPU provider (`ort`'s `ExecutionProvider::is_available()`).
   192	/// Returns `false` when the probe errors — e.g. the ORT dylib is absent under
   193	/// `load-dynamic` — which is precisely an unavailable provider, the silent-CPU
   194	/// case we must surface.
   195	fn provider_is_available(provider: OrtProvider) -> bool {
   196	    match provider {
   197	        OrtProvider::Cpu => true,
   198	        OrtProvider::Cuda(_) => CUDAExecutionProvider::default().is_available().unwrap_or(false),
   199	        OrtProvider::Rocm(_) => ROCmExecutionProvider::default().is_available().unwrap_or(false),
   200	        OrtProvider::DirectMl(_) => {
   201	            DirectMLExecutionProvider::default().is_available().unwrap_or(false)
   202	        }
   203	        OrtProvider::OpenVino => {
   204	            OpenVINOExecutionProvider::default().is_available().unwrap_or(false)
   205	        }
   206	    }
   207	}
   208	
   209	/// Build the concrete `ort` execution-provider dispatch for a resolved
   210	/// [`OrtProvider`].
   211	///
   212	/// ORT's DEFAULT dispatch (`fail_silently`) is non-fatal: if a compiled-in
   213	/// non-CPU provider cannot REGISTER at runtime (missing CUDA/cuDNN/ROCm libs,
   214	/// bad device id) ORT logs internally and silently falls back to CPU, so
   215	/// `with_execution_providers` returns `Ok` and our loud-fallback machinery
   216	/// never fires (codex §9 fix-3 root cause). To make a non-CPU registration
   217	/// failure SURFACE as an `Err` — which then flows into
   218	/// [`build_session_with_fallback`]'s CPU retry + LOUD warning — we mark every
   219	/// non-CPU dispatch `.error_on_failure()`. The CPU dispatch keeps the default
   220	/// (silent) behavior: it is the always-available floor and the retry target,
   221	/// so it must be allowed to succeed rather than error.
   222	fn provider_dispatch(provider: OrtProvider) -> ExecutionProviderDispatch {
   223	    match provider {
   224	        OrtProvider::Cpu => CPUExecutionProvider::default().build(),
   225	        OrtProvider::Cuda(idx) => {
   226	            CUDAExecutionProvider::default().with_device_id(idx).build().error_on_failure()
   227	        }
   228	        OrtProvider::Rocm(idx) => {
   229	            ROCmExecutionProvider::default().with_device_id(idx).build().error_on_failure()
   230	        }
   231	        OrtProvider::DirectMl(idx) => {
   232	            DirectMLExecutionProvider::default().with_device_id(idx).build().error_on_failure()
   233	        }
   234	        OrtProvider::OpenVino => OpenVINOExecutionProvider::default().build().error_on_failure(),
   235	    }
   236	}
   237	
   238	/// SECOND, RUNTIME stage of the loud fallback (R-ONNX-2, codex §9 fix-2):
   239	/// even when the availability probe ([`resolve_effective_provider`]) reports a
   240	/// non-CPU EP as compiled-in, actually BUILDING/COMMITTING the session with it
   241	/// can still fail at runtime — missing CUDA/cuDNN/ROCm runtime libs, a bad
   242	/// device id, an incompatible driver. `ort`'s own dispatch would surface that
   243	/// as a hard `Err`, so a user with a CUDA-enabled ORT but absent runtime deps
   244	/// could not open the embedder AT ALL, violating the documented loud CPU
   245	/// fallback. This helper attempts the build with `effective`; on failure of a
   246	/// NON-CPU provider it produces a LOUD warning (naming the provider + the
   247	/// error) and RETRIES with CPU, returning the CPU session. A CPU failure is a
   248	/// real error (no retry). Generic over the session/error types with the build
   249	/// step injected as a closure, so the retry control flow is unit-testable with
   250	/// NO model and NO ORT native lib.
   251	fn build_session_with_fallback<S, E, F>(
   252	    effective: OrtProvider,
   253	    build: F,
   254	) -> Result<(S, Option<String>), E>
   255	where
   256	    F: Fn(OrtProvider) -> Result<S, E>,
   257	    E: std::fmt::Display,
   258	{
   259	    match build(effective) {
   260	        Ok(session) => Ok((session, None)),
   261	        // A CPU build failure is a genuine error — there is nothing to fall
   262	        // back to, so do not retry.
   263	        Err(e) if matches!(effective, OrtProvider::Cpu) => Err(e),
   264	        // The requested non-CPU EP was reported available but failed to build
   265	        // at runtime: warn LOUDLY and retry on CPU. Only a CPU failure here is
   266	        // fatal.
   267	        Err(e) => {
   268	            let warn = format!(
   269	                "requested ONNX execution provider {effective:?} was reported available but \
   270	                 FAILED during ONNX Runtime session creation ({e}); falling back to CPU"
   271	            );
   272	            let session = build(OrtProvider::Cpu)?;
   273	            Ok((session, Some(warn)))
   274	        }
   275	    }
   276	}
   277	
   278	/// Stream a file through SHA-256, returning the 32-byte digest. Read in fixed
   279	/// chunks rather than buffering the whole file so a ~130 MB `.onnx` export is
   280	/// not held in memory (this runs once, at construction).
   281	fn sha256_file(path: &Path) -> Result<[u8; 32], EmbedderError> {
   282	    use sha2::{Digest, Sha256};
   283	    let mut file = std::fs::File::open(path).map_err(|e| err("asset digest open", e))?;
   284	    let mut hasher = Sha256::new();
   285	    let mut buf = [0_u8; 64 * 1024];
   286	    loop {
   287	        let n =
   288	            std::io::Read::read(&mut file, &mut buf).map_err(|e| err("asset digest read", e))?;
   289	        if n == 0 {
   290	            break;
   291	        }
   292	        hasher.update(&buf[..n]);
   293	    }
   294	    Ok(hasher.finalize().into())
   295	}
   296	
   297	/// PURE composition of the SELF-DESCRIBING identity revision from the two asset
   298	/// content digests (codex §9 fix-5, remedy (b)). The revision is the pinned
   299	/// base [`HF_REVISION`] plus a short hex of `SHA-256(model_digest ||
   300	/// tokenizer_digest)`:
   301	///
   302	/// `"<HF_REVISION>+onnx-<12 hex>"`
   303	///
   304	/// Net effect: two different model/tokenizer assets → two DIFFERENT revisions
   305	/// (hence different [`EmbedderIdentity`], so the engine rejects mixing vectors
   306	/// written under a different asset), while the SAME asset yields a STABLE
   307	/// revision across opens. Composing the two per-file digests into one final
   308	/// hash is deterministic and unambiguous (both inputs are fixed 32-byte
   309	/// digests, so there is no boundary ambiguity). Digest inputs make this a pure
   310	/// function — no ORT session, unit-testable with arbitrary bytes.
   311	fn compose_asset_revision(model_digest: &[u8; 32], tokenizer_digest: &[u8; 32]) -> String {
   312	    use sha2::{Digest, Sha256};
   313	    let mut hasher = Sha256::new();
   314	    hasher.update(model_digest);
   315	    hasher.update(tokenizer_digest);
   316	    let combined = hasher.finalize();
   317	    let mut hex = String::with_capacity(12);
   318	    for byte in combined.iter().take(6) {
   319	        use std::fmt::Write as _;
   320	        let _ = write!(hex, "{byte:02x}");
   321	    }
   322	    format!("{HF_REVISION}+onnx-{hex}")
   323	}
   324	
   325	/// Derive the self-describing identity revision from the ACTUALLY-loaded asset
   326	/// files on disk: hash the model bytes and the tokenizer bytes, then compose
   327	/// via [`compose_asset_revision`]. Takes paths (not an ORT session) so the
   328	/// revision derivation is exercisable with arbitrary temp files in tests.
   329	fn derive_asset_revision(
   330	    model_path: &Path,
   331	    tokenizer_path: &Path,
   332	) -> Result<String, EmbedderError> {
   333	    let model_digest = sha256_file(model_path)?;
   334	    let tokenizer_digest = sha256_file(tokenizer_path)?;
   335	    Ok(compose_asset_revision(&model_digest, &tokenizer_digest))
   336	}
   337	
   338	/// Cross-vendor ONNX-Runtime BGE-small embedder.
   339	///
   340	/// `Session::run` needs `&mut self` but the `Embedder` trait is `&self` +
   341	/// `Send + Sync`, so the session lives behind a `Mutex`. Embedding is a short
   342	/// forward pass, so lock contention is not a concern for the offline/eval use
   343	/// this backend targets.
   344	pub struct OrtBgeEmbedder {
   345	    identity: EmbedderIdentity,
   346	    tokenizer: Tokenizer,
   347	    session: Mutex<Session>,
   348	    pooling: OrtPooling,
   349	}
   350	
   351	fn err(context: &str, e: impl std::fmt::Display) -> EmbedderError {
   352	    EmbedderError::Failed { message: format!("ort_bge {context}: {e}") }
   353	}
   354	
   355	impl OrtBgeEmbedder {
   356	    /// Construct from an on-disk `.onnx` model + `tokenizer.json`, selecting the
   357	    /// ORT execution provider at RUNTIME from `FATHOMDB_EMBED_DEVICE` (R-ONNX-2).
   358	    /// Paths are caller-supplied (no hardcoded absolute path) so the model is an
   359	    /// offline-build/eval asset the caller provisions.
   360	    pub fn from_files(model_path: &Path, tokenizer_path: &Path) -> Result<Self, EmbedderError> {
   361	        Self::from_files_with_provider(model_path, tokenizer_path, resolve_provider_from_env())
   362	    }
   363	
   364	    /// Construct from `FATHOMDB_ONNX_MODEL_PATH` + `FATHOMDB_ONNX_TOKENIZER_PATH`
   365	    /// (device from `FATHOMDB_EMBED_DEVICE`). The env-driven entry point an eval
   366	    /// harness / caller uses to engage the ONNX backend without recompiling.
   367	    pub fn from_env() -> Result<Self, EmbedderError> {
   368	        let model = std::env::var("FATHOMDB_ONNX_MODEL_PATH")
   369	            .map_err(|_| err("from_env", "FATHOMDB_ONNX_MODEL_PATH is unset"))?;
   370	        let tok = std::env::var("FATHOMDB_ONNX_TOKENIZER_PATH")
   371	            .map_err(|_| err("from_env", "FATHOMDB_ONNX_TOKENIZER_PATH is unset"))?;
   372	        Self::from_files(Path::new(&model), Path::new(&tok))
   373	    }
   374	
   375	    fn from_files_with_provider(
   376	        model_path: &Path,
   377	        tokenizer_path: &Path,
   378	        provider: OrtProvider,
   379	    ) -> Result<Self, EmbedderError> {
   380	        let mut tokenizer =
   381	            Tokenizer::from_file(tokenizer_path).map_err(|e| err("tokenizer load", e))?;
   382	        tokenizer
   383	            .with_truncation(Some(TruncationParams {
   384	                max_length: MAX_SEQUENCE_TOKENS,
   385	                ..Default::default()
   386	            }))
   387	            .map_err(|e| err("tokenizer truncation", e))?;
   388	
   389	        // SESSION-BUILD stage of the loud fallback (R-ONNX-2): if the requested
   390	        // non-CPU provider is unavailable in this ORT build, downgrade to CPU
   391	        // and warn LOUDLY ourselves rather than letting `ort`'s compiled-out
   392	        // dispatch fall back silently. CPU functionality is preserved.
   393	        let (effective, avail_warn) = resolve_effective_provider(provider);
   394	        if let Some(msg) = avail_warn {
   395	            emit_onnx_warning(&msg);
   396	        }
   397	
   398	        // SESSION-BUILD RUNTIME stage (codex §9 fix-2): the availability probe
   399	        // above can pass yet the concrete build still fail (missing runtime
   400	        // libs, bad device id). `build_session_with_fallback` warns LOUDLY and
   401	        // retries on CPU for a non-CPU EP so an unavailable-at-runtime GPU never
   402	        // blocks opening the embedder; a CPU failure stays a hard error.
   403	        let (session, build_warn) = build_session_with_fallback(effective, |p| {
   404	            Session::builder()?
   405	                .with_execution_providers([provider_dispatch(p)])?
   406	                .commit_from_file(model_path)
   407	        })
   408	        .map_err(|e| err("session build", e))?;
   409	        if let Some(msg) = build_warn {
   410	            emit_onnx_warning(&msg);
   411	        }
   412	
   413	        // Self-describing identity (codex §9 fix-5): derive the revision from a
   414	        // content digest of the ACTUALLY-loaded model + tokenizer assets rather
   415	        // than advertising the pinned base revision unconditionally. A stale or
   416	        // alternate FATHOMDB_ONNX_MODEL_PATH now yields a DIFFERENT identity, so
   417	        // the engine's EmbedderIdentity check rejects reading vectors written
   418	        // under a different embedding space (R-ONNX-3 same-asset discipline).
   419	        let revision = derive_asset_revision(model_path, tokenizer_path)?;
   420	        let identity = EmbedderIdentity::new(ORT_BGE_EMBEDDER_NAME, revision, ORT_BGE_EMBEDDER_DIM);
   421	
   422	        Ok(Self { identity, tokenizer, session: Mutex::new(session), pooling: OrtPooling::Cls })
   423	    }
   424	
   425	    /// Select the pooling strategy (default [`OrtPooling::Cls`]). Does NOT change
   426	    /// the identity — use only on a fresh workspace / in the equivalence harness.
   427	    #[must_use]
   428	    pub fn with_pooling(mut self, pooling: OrtPooling) -> Self {
   429	        self.pooling = pooling;
   430	        self
   431	    }
   432	}
   433	
   434	impl Embedder for OrtBgeEmbedder {
   435	    fn identity(&self) -> EmbedderIdentity {
   436	        self.identity.clone()
   437	    }
   438	
   439	    fn embed(&self, input: &str) -> Result<Vector, EmbedderError> {
   440	        let encoding = self.tokenizer.encode(input, true).map_err(|e| err("tokenize", e))?;
   441	        let ids: Vec<i64> = encoding.get_ids().iter().map(|&x| i64::from(x)).collect();
   442	        let mask: Vec<i64> = encoding.get_attention_mask().iter().map(|&x| i64::from(x)).collect();
   443	        let len = ids.len();
   444	        let token_type: Vec<i64> = vec![0; len];
   445	        let shape = vec![1_i64, len as i64];
   446	
   447	        let ids_t = Tensor::from_array((shape.clone(), ids)).map_err(|e| err("input_ids", e))?;
   448	        let mask_t =
   449	            Tensor::from_array((shape.clone(), mask)).map_err(|e| err("attention_mask", e))?;
   450	        let tt_t = Tensor::from_array((shape, token_type)).map_err(|e| err("token_type_ids", e))?;
   451	
   452	        let mut session = self.session.lock().map_err(|_| err("session lock", "poisoned"))?;
   453	        let outputs = session
   454	            .run(ort::inputs![
   455	                "input_ids" => ids_t,
   456	                "attention_mask" => mask_t,
   457	                "token_type_ids" => tt_t,
   458	            ])
   459	            .map_err(|e| err("forward", e))?;
   460	
   461	        // last_hidden_state — first output, shape (1, L, H).
   462	        let (out_shape, data) =
   463	            outputs[0].try_extract_tensor::<f32>().map_err(|e| err("extract", e))?;
   464	        let dims: Vec<usize> = out_shape.iter().map(|&d| d as usize).collect();
   465	        if dims.len() != 3 {
   466	            return Err(err("output shape", format!("expected rank-3 (1,L,H), got {dims:?}")));
   467	        }
   468	        let (seq_len, hidden) = (dims[1], dims[2]);
   469	        if hidden != ORT_BGE_EMBEDDER_DIM as usize {
   470	            return Err(err(
   471	                "output dim",
   472	                format!("expected hidden {ORT_BGE_EMBEDDER_DIM}, got {hidden}"),
   473	            ));
   474	        }
   475	
   476	        // Pool. `embed()` is single-input (no padding), so the attention mask is
   477	        // all-ones and mean-pool reduces to a plain mean over `seq_len`.
   478	        let mut pooled = vec![0.0_f32; hidden];
   479	        match self.pooling {
   480	            OrtPooling::Cls => {
   481	                pooled.copy_from_slice(&data[0..hidden]);
   482	            }
   483	            OrtPooling::Mean => {
   484	                for pos in 0..seq_len {
   485	                    let base = pos * hidden;
   486	                    for (j, slot) in pooled.iter_mut().enumerate() {
   487	                        *slot += data[base + j];
   488	                    }
   489	                }
   490	                let denom = seq_len.max(1) as f32;
   491	                for slot in &mut pooled {
   492	                    *slot /= denom;
   493	                }
   494	            }
   495	        }
   496	
   497	        // L2-normalize (matches candle's `l2_normalize`).
   498	        let norm = pooled.iter().map(|v| v * v).sum::<f32>().sqrt().max(1e-12);
   499	        for slot in &mut pooled {
   500	            *slot /= norm;
   501	        }
   502	        Ok(pooled)
   503	    }
   504	}
