    27	use ort::execution_providers::{
    28	    CPUExecutionProvider, CUDAExecutionProvider, DirectMLExecutionProvider, ExecutionProvider,
    29	    ExecutionProviderDispatch, OpenVINOExecutionProvider, ROCmExecutionProvider,
    30	};
    31	use ort::session::Session;
    32	use ort::value::Tensor;
    33	use tokenizers::{Tokenizer, TruncationParams};
    34	
    35	use crate::device::{parse_device_request, DeviceRequest};
    36	
    37	/// Engine-facing identity name. Deliberately DISTINCT from the candle default
    38	/// (`fathomdb-bge-small-en-v1.5`) so the engine's identity check enforces the
    39	/// R-ONNX-3 same-backend build-and-read discipline: candle-written vectors and
    40	/// ONNX-read queries never silently mix until 0.8.18 #5 enforces a candle↔ONNX
    41	/// tolerance (ADR §3).
    42	pub const ORT_BGE_EMBEDDER_NAME: &str = "fathomdb-bge-small-en-v1.5-onnx";
    43	
    44	/// Output dimension for `bge-small-en-v1.5` (matches the candle reference).
