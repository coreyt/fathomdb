    54	
    55	/// Tokenizer truncation ceiling — BGE-small's 512-slot learned position
    56	/// embeddings, identical to the candle path (`candle_bge::MAX_SEQUENCE_TOKENS`).
    57	const MAX_SEQUENCE_TOKENS: usize = 512;
    58	
    59	/// Sentence-vector pooling. Mirrors `candle_bge::Pooling`. Default is
    60	/// [`OrtPooling::Cls`] — the model-native, CLS-corrected mode the candle
    61	/// reference is compared against at Slice 15 (design §5).
    62	#[derive(Clone, Copy, Debug, PartialEq, Eq)]
    63	pub enum OrtPooling {
    64	    /// Mean over the attention mask (candle's historical default).
    65	    Mean,
    66	    /// `[CLS]` token (position 0) — the mode BGE-small was trained for.
    67	    Cls,
    68	}
