    51	fn hash64(input: &str) -> u64 {
    52	    let mut seed: u64 = 0xcbf29ce484222325;
    53	    for b in input.bytes() {
    54	        seed ^= u64::from(b);
    55	        seed = seed.wrapping_mul(0x100000001b3);
    56	    }
    57	    seed
    58	}
