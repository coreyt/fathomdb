  3924	/// 0.7.2 PR-2b — recompute core with an optional fault-injection point. The
  3925	/// `fail_after_mean_update` flag (debug builds only, set via a test seam)
  3926	/// errors AFTER the `mean_vec` UPDATE but BEFORE the re-quantize completes,
  3927	/// so the caller's tx rolls back the partial recentering.
  3928	fn recompute_mean_in_tx_inner(
  3929	    tx: &rusqlite::Transaction<'_>,
  3930	    identity: &EmbedderIdentity,
  3931	    fail_after_mean_update: bool,
  3932	) -> Result<MeanRecomputeReport, EngineError> {
  3933	    let started = Instant::now();
  3934	    let dim = identity.dimension as usize;
  3935	    // The previously-pinned mean (if any) is read first so we can report
  3936	    // the pre-recompute drift cosine.
  3937	    let old_mean = read_pinned_mean_vec(tx, identity.dimension)?;
  3938	    let rows: Vec<(i64, Vec<u8>)> = {
  3939	        let mut statement = tx
  3940	            .prepare("SELECT rowid, embedding FROM vector_default ORDER BY rowid")
  3941	            .map_err(|_| EngineError::Storage)?;
  3942	        let mapped = statement
  3943	            .query_map([], |row| Ok((row.get::<_, i64>(0)?, row.get::<_, Vec<u8>>(1)?)))
  3944	            .map_err(|_| EngineError::Storage)?;
  3945	        let mut out = Vec::new();
  3946	        for r in mapped {
  3947	            out.push(r.map_err(|_| EngineError::Storage)?);
  3948	        }
  3949	        out
  3950	    };
  3951	    let mut accumulator = MeanAccumulator::new(dim);
  3952	    for (_rowid, blob) in &rows {
  3953	        if blob.len() != dim * 4 {
  3954	            return Err(EngineError::Storage);
  3955	        }
  3956	        accumulator.add(&decode_vector_blob(blob));
  3957	    }
  3958	    let old_doc_count = accumulator.count();
  3959	    let mean = accumulator.materialize();
  3960	    let drift_cos_before = match &old_mean {
  3961	        Some(old) => cosine_similarity(&mean, old),
  3962	        None => 1.0,
  3963	    };
  3964	    tx.execute(
  3965	        "UPDATE _fathomdb_embedder_profiles SET mean_vec = ?1 WHERE profile = 'default'",
  3966	        params![encode_vector_blob(&mean)],
  3967	    )
  3968	    .map_err(|_| EngineError::Storage)?;
  3969	    if fail_after_mean_update {
  3970	        // Injected fault: bail before re-quantizing so the caller's tx
  3971	        // rolls back the `mean_vec` UPDATE too (crash-atomicity proof).
  3972	        return Err(EngineError::Storage);
  3973	    }
  3974	    let (doc_count, _) = run_pin_and_requantize_pass(tx, &rows, &mean)?;
  3975	    Ok(MeanRecomputeReport {
