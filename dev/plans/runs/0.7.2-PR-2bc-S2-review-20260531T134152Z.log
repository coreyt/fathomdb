 impl Embedder for NoopEmbedder {
     fn identity(&self) -> EmbedderIdentity {
         self.identity.clone()
     }
 
     fn embed(&self, _input: &str) -> Result<Vector, EmbedderError> {
         let mut vector = vec![0.0_f32; self.identity.dimension as usize];
