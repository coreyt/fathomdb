  2473	    /// Doctor bit-preserving export. Runs `VACUUM INTO` to produce a
  2474	    /// self-contained SQLite file at `out`, computes SHA-256 of the
  2475	    /// resulting bytes, and writes a JSON manifest at `manifest`. Per
  2476	    /// AC-039a/b.
  2477	    pub fn safe_export(
  2478	        &self,
  2479	        out: &Path,
  2480	        manifest: &Path,
  2481	    ) -> Result<SafeExportArtifact, EngineError> {
  2482	        self.ensure_open()?;
  2483	        {
  2484	            let connection = self.connection.lock().map_err(|_| EngineError::Storage)?;
  2485	            let connection = connection.as_ref().ok_or(EngineError::Closing)?;
  2486	            let target = out.to_string_lossy().to_string();
  2487	            connection
  2488	                .execute("VACUUM INTO ?1", params![target])
  2489	                .map_err(|_| EngineError::Storage)?;
  2490	        }
  2491	        let bytes = std::fs::read(out).map_err(|_| EngineError::Storage)?;
  2492	        let digest = sha2::Sha256::digest(&bytes);
  2493	        let sha256_hex = hex_encode(digest.as_slice());
  2494	        let export_abs = out.canonicalize().unwrap_or_else(|_| out.to_path_buf());
  2495	        let manifest_json = serde_json::json!({
  2496	            "export_path": export_abs.to_string_lossy(),
  2497	            "sha256": sha256_hex,
  2498	            "byte_count": bytes.len() as u64,
  2499	        });
  2500	        let manifest_bytes =
  2501	            serde_json::to_vec_pretty(&manifest_json).map_err(|_| EngineError::Storage)?;
  2502	        std::fs::write(manifest, &manifest_bytes).map_err(|_| EngineError::Storage)?;
  2503	        Ok(SafeExportArtifact {
  2504	            export_path: out.to_path_buf(),
  2505	            manifest_path: manifest.to_path_buf(),
  2506	            manifest_sha256: sha256_hex,
  2507	        })
  2508	    }
