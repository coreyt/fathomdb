   120	/// Write `count` `doc` nodes (bodies built by `body`) through the PRODUCTION
   121	/// path in batches of `batch`, draining after each batch.
   122	fn write_docs<F: Fn(usize) -> String>(engine: &Engine, count: usize, batch: usize, body: F) {
   123	    let mut written = 0usize;
   124	    while written < count {
   125	        let take = batch.min(count - written);
   126	        let nodes: Vec<PreparedWrite> = (0..take)
   127	            .map(|i| PreparedWrite::Node {
   128	                kind: "doc".to_string(),
   129	                body: body(written + i),
   130	                source_id: None,
   131	            })
   132	            .collect();
   133	        engine.write(&nodes).expect("production write");
   134	        written += take;
   135	        engine.drain(60_000).expect("drain");
   136	    }
   137	}
