   189	/// CARVED OUT (deferred to 0.8.x). On a synthetic topic pivot (pin a
   190	/// topic-A-skewed mean, then flood topic-B docs well past the old debounce
   191	/// window) the engine must NOT auto-recompute mid-ingest: no
   192	/// `MeanVecRecomputed { DriftAuto }`, no `MeanRecomputeDeferred`, and the
   193	/// pinned `mean_vec` must be byte-identical before and after the B-flood.
   194	/// The manual `doctor recompute-mean` path is unaffected (covered elsewhere).
   195	///
   196	/// RED on pre-carve-out code: the auto-detector fires on this exact pivot
   197	/// (it is the old `drift_recompute_improves_topic_b_recall` Part 1 scenario),
   198	/// staging a `MeanVecRecomputed { DriftAuto }` event and overwriting the
   199	/// pinned mean — so the no-auto-event assertion (and the unchanged-mean
   200	/// assertion) fail. GREEN after the detector is removed.
   201	#[test]
   202	fn topic_pivot_does_not_auto_recompute_mid_ingest() {
   203	    let (_dir, path) = fixture_path("pr2bc_no_auto_drift");
   204	    let opened = open_caller(&path, Arc::new(SimulatedBgeEmbedder::default()));
   205	    let engine = opened.engine;
   206	    engine.configure_vector_kind_for_test("doc").expect("vector kind");
   207	
   208	    // Pin a topic-A-skewed mean, then snapshot the pinned mean.
   209	    write_docs(&engine, MEAN_VEC_PIN_THRESHOLD as usize, 64, |i| format!("A:{i}"));
   210	    let _ = engine.drain_embedder_events();
   211	    let mean_after_pin = read_mean_vec(&path).expect("mean pinned after topic-A");
   212	
   213	    // Flood topic-B far past the old debounce floor (256). Pre-carve-out this
   214	    // is exactly what tripped the auto drift detector.
   215	    write_docs(&engine, 600, 64, |i| format!("B:{i}"));
   216	    let events = engine.drain_embedder_events().expect("drain events");
   217	
   218	    // No automatic recompute event of any kind may be emitted mid-ingest: the
   219	    // automatic drift detector that used to stage `MeanVecRecomputed{DriftAuto}`
   220	    // (and, above the 200k cap, `MeanRecomputeDeferred`) is carved out. The
   221	    // only event a topic-B flood may produce post-pin is none at all.
   222	    let any_recomputed =
   223	        events.iter().any(|e| matches!(e, EmbedderEvent::MeanVecRecomputed { .. }));
