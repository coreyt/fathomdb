    60	/// Topic-aware unit vector. A body prefixed `A:` clusters around a fixed
    61	/// topic-A direction, `B:` around an (almost) orthogonal topic-B direction,
    62	/// each with per-doc noise; anything else is generic. This makes a
    63	/// topic-A-skewed pinned mean systematically wrong for topic-B docs, which
    64	/// is exactly the failure PR-2b's recompute must repair.
    65	fn topic_vector(input: &str) -> Vector {
    66	    let (topic, rest) = match input.split_once(':') {
    67	        Some(("A", rest)) => (Some(false), rest),
    68	        Some(("B", rest)) => (Some(true), rest),
    69	        _ => (None, input),
    70	    };
    71	    let seed = hash64(rest);
    72	    let mut v = vec![0.0f32; DIM as usize];
    73	    // Per-doc signal (mean-zero), small enough that a topic-mismatched mean
    74	    // offset swamps it (collapsing sign bits -> the PR-2a recall failure),
    75	    // but recoverable once the CORRECT corpus mean removes the common-mode
    76	    // topic offset.
    77	    for (i, slot) in v.iter_mut().enumerate() {
    78	        let mixed = seed.wrapping_add(i as u64).wrapping_mul(2654435761);
    79	        *slot = (((mixed >> 8) as u32 as f32) / (u32::MAX as f32) - 0.5) * 0.7;
    80	    }
    81	    // Topic direction: a moderate per-block DC offset. The two topics' means
    82	    // differ sharply (low cosine -> drives the detector). 2*offset (0.8)
    83	    // exceeds the per-doc signal half-range (0.35), so centering a B doc by
    84	    // an A-skewed mean pushes the whole B-block to one sign (loss of
    85	    // per-doc discrimination); the correct B-dominated mean restores it.
    86	    if let Some(is_b) = topic {
    87	        let half = (DIM / 2) as usize;
    88	        for (i, slot) in v.iter_mut().enumerate() {
    89	            let in_b_block = i >= half;
    90	            if in_b_block == is_b {
    91	                *slot += 0.4;
    92	            } else {
    93	                *slot -= 0.4;
    94	            }
    95	        }
    96	    }
    97	    // Unit-normalize (bge vectors are unit-norm).
    98	    let norm = v.iter().map(|x| x * x).sum::<f32>().sqrt().max(1e-9);
    99	    for slot in &mut v {
   100	        *slot /= norm;
   101	    }
   102	    v
   103	}
