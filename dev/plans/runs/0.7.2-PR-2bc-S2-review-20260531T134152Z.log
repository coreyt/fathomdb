  2351	    /// 0.7.2 PR-2b — explicit `doctor recompute-mean` path. Re-derives the
  2352	    /// pinned corpus mean from the current `vector_default` rows and
  2353	    /// re-quantizes every row, SYNCHRONOUSLY in one transaction. ALWAYS
  2354	    /// allowed at any corpus size — this is the ONLY mean-refresh path as of
  2355	    /// 0.7.2 (the automatic in-ingest drift detector was carved out / deferred
  2356	    /// to 0.8.x; see `dev/design/embedder.md` §0.3).
  2357	    ///
  2358	    /// Serializes against the projection workers via `commit_gate` so the
  2359	    /// re-quantize sees a totally-ordered history, exactly like the at-pin
  2360	    /// commit. Publishes a `MeanVecRecomputed { trigger: Manual }` event
  2361	    /// only after the transaction is durable. No-op-safe on a non-MC
  2362	    /// identity (returns `EmbedderNotConfigured` rather than corrupting an
  2363	    /// un-centered workspace).
  2364	    pub fn recompute_mean(&self) -> Result<MeanRecomputeReport, EngineError> {
  2365	        self.ensure_open()?;
  2366	        let identity = self.runtime_embedder_identity.clone();
  2367	        if !identity_requires_mean_centering(&identity) {
  2368	            return Err(EngineError::EmbedderNotConfigured);
  2369	        }
  2370	        let report = {
  2371	            // Hold the commit gate for the whole recompute so no projection
  2372	            // worker commit interleaves with the re-quantize.
  2373	            let _gate = self
  2374	                .projection_runtime
  2375	                .shared
  2376	                .commit_gate
  2377	                .lock()
  2378	                .unwrap_or_else(|p| p.into_inner());
  2379	            let mut connection = self.connection.lock().map_err(|_| EngineError::Storage)?;
  2380	            let connection = connection.as_mut().ok_or(EngineError::Closing)?;
  2381	            let tx = connection.transaction().map_err(|_| EngineError::Storage)?;
  2382	            #[cfg(debug_assertions)]
  2383	            let fail = self
  2384	                .projection_runtime
  2385	                .shared
  2386	                .force_recompute_failure
  2387	                .swap(false, Ordering::SeqCst);
  2388	            #[cfg(not(debug_assertions))]
  2389	            let fail = false;
  2390	            let report = recompute_mean_in_tx_inner(&tx, &identity, fail)?;
  2391	            tx.commit().map_err(|_| EngineError::Storage)?;
  2392	            report
  2393	        };
  2394	        // Post-durable-commit publish.
  2395	        if let Ok(mut events) = self.projection_runtime.shared.pending_events.lock() {
  2396	            events.push(EmbedderEvent::MeanVecRecomputed {
  2397	                dim: report.dim,
  2398	                doc_count: report.doc_count_requantized,
  2399	                trigger: MeanRecomputeTrigger::Manual,
  2400	            });
  2401	        }
  2402	        Ok(report)
