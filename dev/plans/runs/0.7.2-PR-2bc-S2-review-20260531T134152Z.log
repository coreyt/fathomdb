     fn wait_for_idle(&self, timeout_ms: u64) -> bool {
         let deadline = Instant::now() + Duration::from_millis(timeout_ms);
         let mut state = match self.shared.state.lock() {
             Ok(state) => state,
             Err(_) => return false,
         };
         loop {
