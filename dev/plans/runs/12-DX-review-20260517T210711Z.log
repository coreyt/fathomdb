    40	e.search("smoke")
    41	e.close()
    42	print("ok")
    43	PY
    44	
    45	printf 'smoke-pypi-wheel: ok — fathomdb %s installed + open/write/search/close + process exit clean\n' \
    46	  "$VERSION"

