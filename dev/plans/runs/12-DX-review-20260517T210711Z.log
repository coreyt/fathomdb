     1	#!/usr/bin/env bash
     2	# scripts/release/smoke/smoke-pypi-wheel.sh — AC-056 PyPI smoke.
     3	#
     4	#   $1 = version (e.g. 0.6.0)
     5	#
     6	# Installs fathomdb==$1 from PyPI into a fresh venv, exercises the SDK
     7	# end-to-end (open + write empty batch + search + close), and asserts
     8	# the python process exits cleanly. Per `feedback_release_verification`:
     9	# the wheel-on-disk lock cleanup + process exit are the bug signal that
    10	# only fires under real install-from-registry conditions.
    11	set -euo pipefail
    12	
    13	if [ "$#" -ne 1 ]; then
    14	  printf 'usage: %s <version>\n' "$0" >&2
    15	  exit 2
    16	fi
    17	VERSION="$1"
    18	if ! printf '%s' "$VERSION" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
    19	  printf 'smoke-pypi-wheel: invalid version "%s" — expected semver MAJOR.MINOR.PATCH\n' \
    20	    "$VERSION" >&2
    21	  exit 2
    22	fi
    23	
    24	WORK="$(mktemp -d)"
    25	trap 'rm -rf "$WORK"' EXIT
    26	
    27	python3 -m venv "$WORK/venv"
    28	# shellcheck source=/dev/null
    29	. "$WORK/venv/bin/activate"
    30	pip install --quiet --upgrade pip
    31	pip install --quiet "fathomdb==${VERSION}"
