{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013EyWCRLi3F5b6XEMZWCW8n","type":"tool_result","content":"285\t    }\n286\t    // No vector kind configured -> projection runtime still drains FTS index.\n287\t    engine.drain(600_000).expect(\"ac-012 drain\");\n288\t    started.elapsed()\n289\t}\n290\t\n291\t/// Deterministic varying-vector embedder. Projects an input token's\n292\t/// stable hash onto a single coordinate per call so vec0 ANN search\n293\t/// returns distinct k=10 neighbors (a constant-vector embedder would\n294\t/// collapse all distances to 0). Reproducible byte-for-byte across runs.\n295\t#[derive(Clone, Debug)]\n296\tstruct VaryingEmbedder {\n297\t    identity: EmbedderIdentity,\n298\t    dim: u32,\n299\t}\n300\t\n301\timpl VaryingEmbedder {\n302\t    fn new(dim: u32) -> Self {\n303\t        Self { identity: EmbedderIdentity::new(\"varying\", \"perf-gates\", dim), dim }\n304\t    }\n305\t\n306\t    fn vector_for(&self, text: &str) -> Vector {\n307\t        let dim = self.dim as usize;\n308\t        let mut v = vec![0.0_f32; dim];\n309\t        // FNV-1a 64-bit on the input; spread across coordinates with\n310\t        // deterministic small magnitudes so distance is meaningful.\n311\t        let mut h: u64 = 0xcbf29ce484222325;\n312\t        for &b in text.as_bytes() {\n313\t            h ^= b as u64;\n314\t            h = h.wrapping_mul(0x100000001b3);\n315\t        }\n316\t        // Place mass on a small handful of coordinates derived from h.\n317\t        for k in 0..6 {\n318\t            let coord = ((h >> (k * 8)) as usize) % dim;\n319\t            let sign = if (h >> (k * 8 + 7)) & 1 == 0 { 1.0 } else { -1.0 };\n320\t            v[coord] += sign * 0.5_f32;\n321\t        }\n322\t        // Normalize-ish so all vectors have similar magnitude.\n323\t        let norm: f32 = v.iter().map(|x| x * x).sum::<f32>().sqrt().max(1e-6);\n324\t        for x in &mut v {\n325\t            *x /= norm;\n326\t        }\n327\t        v\n328\t    }\n329\t}\n330\t\n331\timpl Embedder for VaryingEmbedder {\n332\t    fn identity(&self) -> EmbedderIdentity {\n333\t        self.identity.clone()\n334\t    }\n335\t\n336\t    fn embed(&self, text: &str) -> Result<Vector, EmbedderError> {\n337\t        Ok(self.vector_for(text))\n338\t    }\n339\t}\n340\t\n341\t/// AC-013 deterministic seeder: N vector rows with varying embeddings.\n342\t/// Returns elapsed seed time. Bodies double as both FTS5 documents and\n343\t/// the input to the embedder, so the same fixture supports AC-019's\n344\t/// FTS+vector mixed workload.\n345\tfn seed_ac013_corpus(engine: &Engine, n: usize) -> Duration {\n346\t    const BATCH: usize = 1024;\n347\t    let vocab = perf_vocab();\n348\t    let cumulative = zipf_cumulative(vocab.len());\n349\t    let mut rng = SeededRng::new(0x0AC0_13D0_13D0);\n350\t    engine.configure_vector_kind_for_test(\"doc\").expect(\"vector kind\");\n351\t    let started = Instant::now();\n352\t    let mut written = 0usize;\n353\t    while written < n {\n354\t        let take = BATCH.min(n - written);\n355\t        let mut batch = Vec::with_capacity(take);\n356\t        for _ in 0..take {\n357\t            batch.push(PreparedWrite::Node {\n358\t                kind: \"doc\".to_string(),\n359\t                body: synth_chunk_body(&mut rng, &vocab, &cumulative),\n360\t                source_id: None,\n361\t            });\n362\t        }\n363\t        engine.write(&batch).expect(\"ac-013 seed write\");\n364\t        written += take;\n365\t    }\n366\t    engine.drain(1_800_000).expect(\"ac-013 drain\");\n367\t    started.elapsed()\n368\t}\n369\t\n370\t/// Build a held-out reproducible query set drawn from the same\n371\t/// distribution as the indexed corpus (ADR-0.6.0-retrieval-latency-gates\n372\t/// \"Query vectors drawn from a held-out slice of the same distribution\").\n373\tfn ac013_query_bodies(count: usize) -> Vec<String> {\n374\t    let vocab = perf_vocab();\n375\t    let cumulative = zipf_cumulative(vocab.len());\n376\t    // Use a different seed than the corpus so the query set is held out\n377\t    // (not byte-equal to seeded chunks but drawn from same distribution).\n378\t    let mut rng = SeededRng::new(0x0AC0_130D_EC0D_E000);\n379\t    (0..count).map(|_| synth_chunk_body(&mut rng, &vocab, &cumulative)).collect()"}]},"parent_tool_use_id":null,"session_id":"8d9c2010-470a-469e-a899-a4db3c31910c","uuid":"628fa1b5-aa29-4a3d-8792-4c3ec898dbb2","timestamp":"2026-05-27T13:24:45.775Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-0.7.0-PVQ-P1-DESIGN-20260527T132416Z/src/rust/crates/fathomdb-engine/tests/perf_gates.rs","content":"    }\n    // No vector kind configured -> projection runtime still drains FTS index.\n    engine.drain(600_000).expect(\"ac-012 drain\");\n    started.elapsed()\n}\n\n/// Deterministic varying-vector embedder. Projects an input token's\n/// stable hash onto a single coordinate per call so vec0 ANN search\n/// returns distinct k=10 neighbors (a constant-vector embedder would\n/// collapse all distances to 0). Reproducible byte-for-byte across runs.\n#[derive(Clone, Debug)]\nstruct VaryingEmbedder {\n    identity: EmbedderIdentity,\n    dim: u32,\n}\n\nimpl VaryingEmbedder {\n    fn new(dim: u32) -> Self {\n        Self { identity: EmbedderIdentity::new(\"varying\", \"perf-gates\", dim), dim }\n    }\n\n    fn vector_for(&self, text: &str) -> Vector {\n        let dim = self.dim as usize;\n        let mut v = vec![0.0_f32; dim];\n        // FNV-1a 64-bit on the input; spread across coordinates with\n        // deterministic small magnitudes so distance is meaningful.\n        let mut h: u64 = 0xcbf29ce484222325;\n        for &b in text.as_bytes() {\n            h ^= b as u64;\n            h = h.wrapping_mul(0x100000001b3);\n        }\n        // Place mass on a small handful of coordinates derived from h.\n        for k in 0..6 {\n            let coord = ((h >> (k * 8)) as usize) % dim;\n            let sign = if (h >> (k * 8 + 7)) & 1 == 0 { 1.0 } else { -1.0 };\n            v[coord] += sign * 0.5_f32;\n        }\n        // Normalize-ish so all vectors have similar magnitude.\n        let norm: f32 = v.iter().map(|x| x * x).sum::<f32>().sqrt().max(1e-6);\n        for x in &mut v {\n            *x /= norm;\n        }\n        v\n    }\n}\n\nimpl Embedder for VaryingEmbedder {\n    fn identity(&self) -> EmbedderIdentity {\n        self.identity.clone()\n    }\n\n    fn embed(&self, text: &str) -> Result<Vector, EmbedderError> {\n        Ok(self.vector_for(text))\n    }\n}\n\n/// AC-013 deterministic seeder: N vector rows with varying embeddings.\n/// Returns elapsed seed time. Bodies double as both FTS5 documents and\n/// the input to the embedder, so the same fixture supports AC-019's\n/// FTS+vector mixed workload.\nfn seed_ac013_corpus(engine: &Engine, n: usize) -> Duration {\n    const BATCH: usize = 1024;\n    let vocab = perf_vocab();\n    let cumulative = zipf_cumulative(vocab.len());\n    let mut rng = SeededRng::new(0x0AC0_13D0_13D0);\n    engine.configure_vector_kind_for_test(\"doc\").expect(\"vector kind\");\n    let started = Instant::now();\n    let mut written = 0usize;\n    while written < n {\n        let take = BATCH.min(n - written);\n        let mut batch = Vec::with_capacity(take);\n        for _ in 0..take {\n            batch.push(PreparedWrite::Node {\n                kind: \"doc\".to_string(),\n                body: synth_chunk_body(&mut rng, &vocab, &cumulative),\n                source_id: None,\n            });\n        }\n        engine.write(&batch).expect(\"ac-013 seed write\");\n        written += take;\n    }\n    engine.drain(1_800_000).expect(\"ac-013 drain\");\n    started.elapsed()\n}\n\n/// Build a held-out reproducible query set drawn from the same\n/// distribution as the indexed corpus (ADR-0.6.0-retrieval-latency-gates\n/// \"Query vectors drawn from a held-out slice of the same distribution\").\nfn ac013_query_bodies(count: usize) -> Vec<String> {\n    let vocab = perf_vocab();\n    let cumulative = zipf_cumulative(vocab.len());\n    // Use a different seed than the corpus so the query set is held out\n    // (not byte-equal to seeded chunks but drawn from same distribution).\n    let mut rng = SeededRng::new(0x0AC0_130D_EC0D_E000);\n    (0..count).map(|_| synth_chunk_body(&mut rng, &vocab, &cumulative)).collect()","numLines":95,"startLine":285,"totalLines":1177}}}
