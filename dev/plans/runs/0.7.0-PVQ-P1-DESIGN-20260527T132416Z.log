            );\n2191\t        }\n2192\t\n2193\t        let nodes_excised = tx\n2194\t            .execute(\"DELETE FROM canonical_nodes WHERE source_id = ?1\", [source_id])\n2195\t            .map_err(|_| EngineError::Storage)? as u64;\n2196\t        let edges_excised = tx\n2197\t            .execute(\"DELETE FROM canonical_edges WHERE source_id = ?1\", [source_id])\n2198\t            .map_err(|_| EngineError::Storage)? as u64;\n2199\t\n2200\t        // AC-028a audit row: a single append on the\n2201\t        // `excise_source_audit` collection naming the excised source.\n2202\t        // `next_cursor` after a prior write holds the LAST committed cursor;\n2203\t        // mirror the vec writer pattern (load + 1, then store post-commit)\n2204\t        // so the audit row's `write_cursor` is strictly greater than every\n2205\t        // canonical row that preceded it.\n2206\t        let excised_at = SystemTime::now().duration_since(UNIX_EPOCH).unwrap_or_default().as_secs();\n2207\t        let payload = serde_json::json!({\n2208\t            \"source_id\": source_id,\n2209\t            \"excised_at\": excised_at,\n2210\t            \"nodes_excised\": nodes_excised,\n2211\t            \"edges_excised\": edges_excised,\n2212\t            \"projections_invalidated\": shadow_invalidated,\n2213\t        })\n2214\t        .to_string();\n2215\t        let audit_cursor = self.next_cursor.load(Ordering::SeqCst).saturating_add(1);\n2216\t        tx.execute(\n2217\t            \"INSERT INTO operational_mutations(\n2218\t                collection_name, record_key, op_kind, payload_json, schema_id, write_cursor\n2219\t             ) VALUES('excise_source_audit', ?1, 'append', ?2, NULL, ?3)\",\n2220\t            params![source_id, payload, audit_cursor],\n2221\t        )\n2222\t        .map_err(|_| EngineError::Storage)?;\n2223\t\n2224\t        tx.commit().map_err(|_| EngineError::Storage)?;\n2225\t        self.next_cursor.store(audit_cursor, Ordering::SeqCst);\n2226\t        Ok(ExciseReport {\n2227\t            source_ref: source_id.to_string(),\n2228\t            nodes_excised,\n2229\t            edges_excised,\n2230\t            projections_invalidated: shadow_invalidated,\n2231\t        })\n2232\t    }\n2233\t\n2234\t    fn run_rebuild(\n2235\t        &self,\n2236\t        include_fts: bool,\n2237\t        kind: RebuildKind,\n2238\t    ) -> Result<RebuildReport, EngineError> {\n2239\t        self.projection_runtime.set_frozen(true);\n2240\t        // Drain MUST succeed: rebuild_shadow_state truncates shadow rows,\n2241\t        // and SQLite-WAL allows a worker that already dequeued a job to\n2242\t        // commit its `INSERT OR IGNORE INTO _fathomdb_vector_rows / vec0`\n2243\t        // after our truncate releases the writer lock, leaving stale\n2244\t        // rows. Surfacing the timeout (instead of swallowing it) lets the\n2245\t        // operator retry rather than silently corrupt the rebuild.\n2246\t        let drain_result = self.drain(REBUILD_DRAIN_TIMEOUT_MS);\n2247\t        let result = drain_result.and_then(|()| self.rebuild_shadow_state(include_fts, kind));\n2248\t        self.projection_runtime.set_frozen(false);\n2249\t        result\n2250\t    }\n2251\t\n2252\t    fn rebuild_shadow_state(\n2253\t        &self,\n2254\t        include_fts: bool,\n2255\t        kind: RebuildKind,\n2256\t    ) -> Result<RebuildReport, EngineError> {\n2257\t        let mut connection = self.connection.lock().map_err(|_| EngineError::Storage)?;\n2258\t        let connection = connection.as_mut().ok_or(EngineError::Closing)?;\n2259\t        let tx = connection.transaction().map_err(|_| EngineError::Storage)?;"}]},"parent_tool_use_id":null,"session_id":"8d9c2010-470a-469e-a899-a4db3c31910c","uuid":"d02520dd-b660-46f7-94dc-8da0cb837d47","timestamp":"2026-05-27T13:24:31.751Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-0.7.0-PVQ-P1-DESIGN-20260527T132416Z/src/rust/crates/fathomdb-engine/src/lib.rs","content":"                .prepare(\"SELECT write_cursor FROM canonical_edges WHERE source_id = ?1\")\n                .map_err(|_| EngineError::Storage)?;\n            let rows = stmt\n                .query_map([source_id], |row| row.get::<_, i64>(0))\n                .map_err(|_| EngineError::Storage)?;\n            rows.collect::<rusqlite::Result<Vec<_>>>().map_err(|_| EngineError::Storage)?\n        };\n\n        let mut shadow_invalidated: u64 = 0;\n        for cursor in node_cursors.iter().chain(edge_cursors.iter()) {\n            shadow_invalidated = shadow_invalidated.saturating_add(\n                tx.execute(\"DELETE FROM search_index WHERE write_cursor = ?1\", [cursor])\n                    .map_err(|_| EngineError::Storage)? as u64,\n            );\n            // vec0 rowid is the canonical row's write_cursor (see\n            // `_fathomdb_vector_rows.write_cursor UNIQUE`).\n            shadow_invalidated = shadow_invalidated.saturating_add(\n                tx.execute(\"DELETE FROM vector_default WHERE rowid = ?1\", [cursor])\n                    .map_err(|_| EngineError::Storage)? as u64,\n            );\n            shadow_invalidated = shadow_invalidated.saturating_add(\n                tx.execute(\"DELETE FROM _fathomdb_vector_rows WHERE write_cursor = ?1\", [cursor])\n                    .map_err(|_| EngineError::Storage)? as u64,\n            );\n            shadow_invalidated = shadow_invalidated.saturating_add(\n                tx.execute(\n                    \"DELETE FROM _fathomdb_projection_terminal WHERE write_cursor = ?1\",\n                    [cursor],\n                )\n                .map_err(|_| EngineError::Storage)? as u64,\n            );\n        }\n\n        let nodes_excised = tx\n            .execute(\"DELETE FROM canonical_nodes WHERE source_id = ?1\", [source_id])\n            .map_err(|_| EngineError::Storage)? as u64;\n        let edges_excised = tx\n            .execute(\"DELETE FROM canonical_edges WHERE source_id = ?1\", [source_id])\n            .map_err(|_| EngineError::Storage)? as u64;\n\n        // AC-028a audit row: a single append on the\n        // `excise_source_audit` collection naming the excised source.\n        // `next_cursor` after a prior write holds the LAST committed cursor;\n        // mirror the vec writer pattern (load + 1, then store post-commit)\n        // so the audit row's `write_cursor` is strictly greater than every\n        // canonical row that preceded it.\n        let excised_at = SystemTime::now().duration_since(UNIX_EPOCH).unwrap_or_default().as_secs();\n        let payload = serde_json::json!({\n            \"source_id\": source_id,\n            \"excised_at\": excised_at,\n            \"nodes_excised\": nodes_excised,\n            \"edges_excised\": edges_excised,\n            \"projections_invalidated\": shadow_invalidated,\n        })\n        .to_string();\n        let audit_cursor = self.next_cursor.load(Ordering::SeqCst).saturating_add(1);\n        tx.execute(\n            \"INSERT INTO operational_mutations(\n                collection_name, record_key, op_kind, payload_json, schema_id, write_cursor\n             ) VALUES('excise_source_audit', ?1, 'append', ?2, NULL, ?3)\",\n            params![source_id, payload, audit_cursor],\n        )\n        .map_err(|_| EngineError::Storage)?;\n\n        tx.commit().map_err(|_| EngineError::Storage)?;\n        self.next_cursor.store(audit_cursor, Ordering::SeqCst);\n        Ok(ExciseReport {\n            source_ref: source_id.to_string(),\n            nodes_excised,\n            edges_excised,\n            projections_invalidated: shadow_invalidated,\n        })\n    }\n\n    fn run_rebuild(\n        &self,\n        include_fts: bool,\n        kind: RebuildKind,\n    ) -> Result<RebuildReport, EngineError> {\n        self.projection_runtime.set_frozen(true);\n        // Drain MUST succeed: rebuild_shadow_state truncates shadow rows,\n        // and SQLite-WAL allows a worker that already dequeued a job to\n        // commit its `INSERT OR IGNORE INTO _fathomdb_vector_rows / vec0`\n        // after our truncate releases the writer lock, leaving stale\n        // rows. Surfacing the timeout (instead of swallowing it) lets the\n        // operator retry rather than silently corrupt the rebuild.\n        let drain_result = self.drain(REBUILD_DRAIN_TIMEOUT_MS);\n        let result = drain_result.and_then(|()| self.rebuild_shadow_state(include_fts, kind));\n        self.projection_runtime.set_frozen(false);\n        result\n    }\n\n    fn rebuild_shadow_state(\n        &self,\n        include_fts: bool,\n        kind: RebuildKind,\n    ) -> Result<RebuildReport, EngineError> {\n        let mut connection = self.connection.lock().map_err(|_| EngineError::Storage)?;\n        let connection = connection.as_mut().ok_or(EngineError::Closing)?;\n        let tx = connection.transaction().map_err(|_| EngineError::Storage)?;","numLines":100,"startLine":2160,"totalLines":4114}}}
