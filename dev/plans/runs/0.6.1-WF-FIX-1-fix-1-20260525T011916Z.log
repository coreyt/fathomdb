{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KY9LEhZaLEH5SEgVBu1Qsn","type":"tool_result","content":"122\t# to republish a yanked version number.\n123\tregistry_has_version() {\n124\t  local crate=\"$1\" version=\"$2\"\n125\t  local base=\"${CARGO_PUBLISH_IF_NEW_REGISTRY:-https://crates.io}\"\n126\t  local url=\"${base}/api/v1/crates/${crate}\"\n127\t  local body\n128\t  if ! body=\"$(curl --silent --show-error --fail --max-time 30 \\\n129\t        -H \"User-Agent: fathomdb-release-publish-guard (https://github.com/coreyt/fathomdb)\" \\\n130\t        \"$url\" 2>&1)\"; then\n131\t    printf 'cargo-publish-if-new: registry query failed for %s — %s\\n' \\\n132\t      \"$crate\" \"$body\" >&2\n133\t    return 2\n134\t  fi\n135\t  # Fail-closed: validate the body is parseable JSON before inspecting it.\n136\t  # A malformed/truncated 200 response would otherwise silently fall through\n137\t  # as \"version not found\" (return 1) and trigger an unnecessary publish attempt.\n138\t  if ! printf '%s' \"$body\" | jq . >/dev/null 2>&1; then\n139\t    printf 'cargo-publish-if-new: registry returned malformed JSON for %s\\n' \\\n140\t      \"$crate\" >&2\n141\t    return 2"}]},"parent_tool_use_id":null,"session_id":"94ef9a18-efe7-461e-91d9-252b6b93035c","uuid":"6fdab14a-34e7-419e-a44e-03ff0a4235cf","timestamp":"2026-05-25T01:21:24.162Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-0.6.1-WF-FIX-1-axis-e-idempotent-publish-20260525T010638Z/scripts/release/cargo-publish-if-new.sh","content":"# to republish a yanked version number.\nregistry_has_version() {\n  local crate=\"$1\" version=\"$2\"\n  local base=\"${CARGO_PUBLISH_IF_NEW_REGISTRY:-https://crates.io}\"\n  local url=\"${base}/api/v1/crates/${crate}\"\n  local body\n  if ! body=\"$(curl --silent --show-error --fail --max-time 30 \\\n        -H \"User-Agent: fathomdb-release-publish-guard (https://github.com/coreyt/fathomdb)\" \\\n        \"$url\" 2>&1)\"; then\n    printf 'cargo-publish-if-new: registry query failed for %s — %s\\n' \\\n      \"$crate\" \"$body\" >&2\n    return 2\n  fi\n  # Fail-closed: validate the body is parseable JSON before inspecting it.\n  # A malformed/truncated 200 response would otherwise silently fall through\n  # as \"version not found\" (return 1) and trigger an unnecessary publish attempt.\n  if ! printf '%s' \"$body\" | jq . >/dev/null 2>&1; then\n    printf 'cargo-publish-if-new: registry returned malformed JSON for %s\\n' \\\n      \"$crate\" >&2\n    return 2","numLines":20,"startLine":122,"totalLines":181}}}
