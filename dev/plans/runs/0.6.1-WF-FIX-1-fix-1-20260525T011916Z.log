{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0138hwgycBdBBihZqXGkZBSR","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t# scripts/release/cargo-publish-if-new.sh — idempotency guard for the\n3\t# release.yml T1..T7 cargo-publish tiers.\n4\t#\n5\t# Reads the local crate version from src/rust/crates/<crate>/Cargo.toml\n6\t# (resolving `version.workspace = true` to the root [workspace.package]),\n7\t# queries crates.io for already-published versions, and:\n8\t#\n9\t#   • if the target version is already on the registry → log\n10\t#     \"already published; skipping\" and exit 0 (idempotent no-op).\n11\t#   • otherwise → invoke `cargo publish -p <crate> --token \"$CARGO_REGISTRY_TOKEN\"`.\n12\t#\n13\t# With --dry-run, the registry check is bypassed and the helper always\n14\t# forwards to `cargo publish --dry-run -p <crate>` — dry runs exercise\n15\t# packaging regardless of registry state.\n16\t#\n17\t# Motivation: axis-W-only patch releases (e.g. 0.6.1, where axis-E\n18\t# fathomdb-embedder-api is held at 0.6.0) would otherwise fail at T1\n19\t# with \"version already exists\". Also covers partial-republish retries\n20\t# where an RC2 follows an RC1 that landed only some tiers.\n21\t#\n22\t# Test env overrides (NOT for production CI):\n23\t#   CARGO_PUBLISH_IF_NEW_REGISTRY      — base URL in place of https://crates.io\n24\t#   CARGO_PUBLISH_IF_NEW_LOCAL_VERSION — skip manifest read; use this version\n25\tset -euo pipefail\n26\t\n27\tusage() {\n28\t  cat <<'USAGE' >&2\n29\tUsage: cargo-publish-if-new.sh [--dry-run] <crate-name>\n30\t\n31\tPublishes <crate-name> to crates.io only if the local Cargo.toml\n32\tversion is not already on the registry. --dry-run forwards to\n33\t`cargo publish --dry-run` regardless of registry state.\n34\t\n35\tEnvironment:\n36\t  CARGO_REGISTRY_TOKEN  required when not in --dry-run mode\n37\tUSAGE\n38\t}\n39\t\n40\tDRY_RUN=0\n41\tCRATE=\"\"\n42\twhile [ \"$#\" -gt 0 ]; do\n43\t  case \"$1\" in\n44\t    --dry-run) DRY_RUN=1; shift ;;\n45\t    -h|--help) usage; exit 0 ;;\n46\t    --) shift; break ;;\n47\t    -*) printf 'cargo-publish-if-new: unknown flag %s\\n' \"$1\" >&2; usage; exit 2 ;;\n48\t    *)  if [ -n \"$CRATE\" ]; then\n49\t          printf 'cargo-publish-if-new: unexpected extra arg %s\\n' \"$1\" >&2\n50\t          usage; exit 2\n51\t        fi\n52\t        CRATE=\"$1\"; shift ;;\n53\t  esac\n54\tdone\n55\t\n56\tif [ -z \"$CRATE\" ]; then\n57\t  usage\n58\t  exit 2\n59\tfi\n60\t\n61\tREPO_ROOT=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/../..\" && pwd)\"\n62\tROOT_MANIFEST=\"$REPO_ROOT/Cargo.toml\"\n63\tCRATE_MANIFEST=\"$REPO_ROOT/src/rust/crates/$CRATE/Cargo.toml\"\n64\t\n65\t# Read [workspace.package].version from the root manifest. Mirrors\n66\t# scripts/set-version.sh's reader semantics: first version line inside\n67\t# the [workspace.package] block.\n68\tread_workspace_version() {\n69\t  awk '\n70\t    /^\\[workspace\\.package\\]/ { in_block = 1; next }\n71\t    /^\\[/                     { in_block = 0 }\n72\t    in_block && /^version[[:space:]]*=[[:space:]]*\"/ {\n73\t      n = split($0, parts, \"\\\"\")\n74\t      if (n >= 3) { print parts[2] }\n75\t      exit\n76\t    }\n77\t  ' \"$ROOT_MANIFEST\"\n78\t}\n79\t\n80\t# Read [package].version from a crate manifest. Returns \"WORKSPACE\"\n81\t# (sentinel) when the crate inherits via `version.workspace = true`.\n82\tread_crate_version() {\n83\t  awk '\n84\t    /^\\[package\\]/ { in_block = 1; next }\n85\t    /^\\[/          { in_block = 0 }\n86\t    in_block && /^version[[:space:]]*\\.workspace[[:space:]]*=[[:space:]]*true/ {\n87\t      print \"WORKSPACE\"; exit\n88\t    }\n89\t    in_block && /^version[[:space:]]*=[[:space:]]*\"/ {\n90\t      n = split($0, parts, \"\\\"\")\n91\t      if (n >= 3) { print parts[2] }\n92\t      exit\n93\t    }\n94\t  ' \"$1\"\n95\t}\n96\t\n97\tresolve_local_version() {\n98\t  if [ -n \"${CARGO_PUBLISH_IF_NEW_LOCAL_VERSION:-}\" ]; then\n99\t    printf '%s' \"$CARGO_PUBLISH_IF_NEW_LOCAL_VERSION\"\n100\t    return 0\n101\t  fi\n102\t  if [ ! -f \"$CRATE_MANIFEST\" ]; then\n103\t    printf 'cargo-publish-if-new: manifest not found at %s\\n' \"$CRATE_MANIFEST\" >&2\n104\t    return 1\n105\t  fi\n106\t  local v\n107\t  v=\"$(read_crate_version \"$CRATE_MANIFEST\")\"\n108\t  if [ \"$v\" = \"WORKSPACE\" ]; then\n109\t    v=\"$(read_workspace_version)\"\n110\t  fi\n111\t  if [ -z \"$v\" ]; then\n112\t    printf 'cargo-publish-if-new: cannot read version for %s\\n' \"$CRATE\" >&2\n113\t    return 1\n114\t  fi\n115\t  printf '%s' \"$v\"\n116\t}\n117\t\n118\t# Returns 0 if $version appears anywhere in versions[].num for $crate\n119\t# at the configured registry, 1 if absent, 2 if the registry query\n120\t# itself failed (network / 5xx / non-JSON body). Yanked versions are\n121\t# still treated as \"already published\" because cargo publish refuses\n122\t# to republish a yanked version number.\n123\tregistry_has_version() {\n124\t  local crate=\"$1\" version=\"$2\"\n125\t  local base=\"${CARGO_PUBLISH_IF_NEW_REGISTRY:-https://crates.io}\"\n126\t  local url=\"${base}/api/v1/crates/${crate}\"\n127\t  local body\n128\t  if ! body=\"$(curl --silent --show-error --fail --max-time 30 \\\n129\t        -H \"User-Agent: fathomdb-release-publish-guard (https://github.com/coreyt/fathomdb)\" \\\n130\t        \"$url\" 2>&1)\"; then\n131\t    printf 'cargo-publish-if-new: registry query failed for %s — %s\\n' \\\n132\t      \"$crate\" \"$body\" >&2\n133\t    return 2\n134\t  fi\n135\t  if printf '%s' \"$body\" | jq -e --arg v \"$version\" \\\n136\t       '.versions | map(.num) | index($v) != null' >/dev/null 2>&1; then\n137\t    return 0\n138\t  fi\n139\t  return 1\n140\t}\n141\t\n142\tLOCAL_VERSION=\"$(resolve_local_version)\"\n143\t\n144\tif [ \"$DRY_RUN\" -eq 1 ]; then\n145\t  printf 'cargo-publish-if-new: %s@%s — --dry-run; forwarding to cargo publish --dry-run\\n' \\\n146\t    \"$CRATE\" \"$LOCAL_VERSION\"\n147\t  exec cargo publish --dry-run -p \"$CRATE\"\n148\tfi\n149\t\n150\tset +e\n151\tregistry_has_version \"$CRATE\" \"$LOCAL_VERSION\"\n152\trc=$?\n153\tset -e\n154\tcase \"$rc\" in\n155\t  0)\n156\t    printf 'cargo-publish-if-new: %s@%s already published; skipping\\n' \\\n157\t      \"$CRATE\" \"$LOCAL_VERSION\"\n158\t    exit 0\n159\t    ;;\n160\t  1)\n161\t    printf 'cargo-publish-if-new: %s@%s not on registry; publishing\\n' \\\n162\t      \"$CRATE\" \"$LOCAL_VERSION\"\n163\t    if [ -z \"${CARGO_REGISTRY_TOKEN:-}\" ]; then\n164\t      printf 'cargo-publish-if-new: CARGO_REGISTRY_TOKEN not set\\n' >&2\n165\t      exit 1\n166\t    fi\n167\t    exec cargo publish -p \"$CRATE\" --token \"$CARGO_REGISTRY_TOKEN\"\n168\t    ;;\n169\t  *)\n170\t    exit \"$rc\"\n171\t    ;;\n172\tesac\n173\t"}]},"parent_tool_use_id":null,"session_id":"94ef9a18-efe7-461e-91d9-252b6b93035c","uuid":"c66207a8-d00b-43fb-8857-c0fab91b405a","timestamp":"2026-05-25T01:19:24.037Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-0.6.1-WF-FIX-1-axis-e-idempotent-publish-20260525T010638Z/scripts/release/cargo-publish-if-new.sh","content":"#!/usr/bin/env bash\n# scripts/release/cargo-publish-if-new.sh — idempotency guard for the\n# release.yml T1..T7 cargo-publish tiers.\n#\n# Reads the local crate version from src/rust/crates/<crate>/Cargo.toml\n# (resolving `version.workspace = true` to the root [workspace.package]),\n# queries crates.io for already-published versions, and:\n#\n#   • if the target version is already on the registry → log\n#     \"already published; skipping\" and exit 0 (idempotent no-op).\n#   • otherwise → invoke `cargo publish -p <crate> --token \"$CARGO_REGISTRY_TOKEN\"`.\n#\n# With --dry-run, the registry check is bypassed and the helper always\n# forwards to `cargo publish --dry-run -p <crate>` — dry runs exercise\n# packaging regardless of registry state.\n#\n# Motivation: axis-W-only patch releases (e.g. 0.6.1, where axis-E\n# fathomdb-embedder-api is held at 0.6.0) would otherwise fail at T1\n# with \"version already exists\". Also covers partial-republish retries\n# where an RC2 follows an RC1 that landed only some tiers.\n#\n# Test env overrides (NOT for production CI):\n#   CARGO_PUBLISH_IF_NEW_REGISTRY      — base URL in place of https://crates.io\n#   CARGO_PUBLISH_IF_NEW_LOCAL_VERSION — skip manifest read; use this version\nset -euo pipefail\n\nusage() {\n  cat <<'USAGE' >&2\nUsage: cargo-publish-if-new.sh [--dry-run] <crate-name>\n\nPublishes <crate-name> to crates.io only if the local Cargo.toml\nversion is not already on the registry. --dry-run forwards to\n`cargo publish --dry-run` regardless of registry state.\n\nEnvironment:\n  CARGO_REGISTRY_TOKEN  required when not in --dry-run mode\nUSAGE\n}\n\nDRY_RUN=0\nCRATE=\"\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --dry-run) DRY_RUN=1; shift ;;\n    -h|--help) usage; exit 0 ;;\n    --) shift; break ;;\n    -*) printf 'cargo-publish-if-new: unknown flag %s\\n' \"$1\" >&2; usage; exit 2 ;;\n    *)  if [ -n \"$CRATE\" ]; then\n          printf 'cargo-publish-if-new: unexpected extra arg %s\\n' \"$1\" >&2\n          usage; exit 2\n        fi\n        CRATE=\"$1\"; shift ;;\n  esac\ndone\n\nif [ -z \"$CRATE\" ]; then\n  usage\n  exit 2\nfi\n\nREPO_ROOT=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/../..\" && pwd)\"\nROOT_MANIFEST=\"$REPO_ROOT/Cargo.toml\"\nCRATE_MANIFEST=\"$REPO_ROOT/src/rust/crates/$CRATE/Cargo.toml\"\n\n# Read [workspace.package].version from the root manifest. Mirrors\n# scripts/set-version.sh's reader semantics: first version line inside\n# the [workspace.package] block.\nread_workspace_version() {\n  awk '\n    /^\\[workspace\\.package\\]/ { in_block = 1; next }\n    /^\\[/                     { in_block = 0 }\n    in_block && /^version[[:space:]]*=[[:space:]]*\"/ {\n      n = split($0, parts, \"\\\"\")\n      if (n >= 3) { print parts[2] }\n      exit\n    }\n  ' \"$ROOT_MANIFEST\"\n}\n\n# Read [package].version from a crate manifest. Returns \"WORKSPACE\"\n# (sentinel) when the crate inherits via `version.workspace = true`.\nread_crate_version() {\n  awk '\n    /^\\[package\\]/ { in_block = 1; next }\n    /^\\[/          { in_block = 0 }\n    in_block && /^version[[:space:]]*\\.workspace[[:space:]]*=[[:space:]]*true/ {\n      print \"WORKSPACE\"; exit\n    }\n    in_block && /^version[[:space:]]*=[[:space:]]*\"/ {\n      n = split($0, parts, \"\\\"\")\n      if (n >= 3) { print parts[2] }\n      exit\n    }\n  ' \"$1\"\n}\n\nresolve_local_version() {\n  if [ -n \"${CARGO_PUBLISH_IF_NEW_LOCAL_VERSION:-}\" ]; then\n    printf '%s' \"$CARGO_PUBLISH_IF_NEW_LOCAL_VERSION\"\n    return 0\n  fi\n  if [ ! -f \"$CRATE_MANIFEST\" ]; then\n    printf 'cargo-publish-if-new: manifest not found at %s\\n' \"$CRATE_MANIFEST\" >&2\n    return 1\n  fi\n  local v\n  v=\"$(read_crate_version \"$CRATE_MANIFEST\")\"\n  if [ \"$v\" = \"WORKSPACE\" ]; then\n    v=\"$(read_workspace_version)\"\n  fi\n  if [ -z \"$v\" ]; then\n    printf 'cargo-publish-if-new: cannot read version for %s\\n' \"$CRATE\" >&2\n    return 1\n  fi\n  printf '%s' \"$v\"\n}\n\n# Returns 0 if $version appears anywhere in versions[].num for $crate\n# at the configured registry, 1 if absent, 2 if the registry query\n# itself failed (network / 5xx / non-JSON body). Yanked versions are\n# still treated as \"already published\" because cargo publish refuses\n# to republish a yanked version number.\nregistry_has_version() {\n  local crate=\"$1\" version=\"$2\"\n  local base=\"${CARGO_PUBLISH_IF_NEW_REGISTRY:-https://crates.io}\"\n  local url=\"${base}/api/v1/crates/${crate}\"\n  local body\n  if ! body=\"$(curl --silent --show-error --fail --max-time 30 \\\n        -H \"User-Agent: fathomdb-release-publish-guard (https://github.com/coreyt/fathomdb)\" \\\n        \"$url\" 2>&1)\"; then\n    printf 'cargo-publish-if-new: registry query failed for %s — %s\\n' \\\n      \"$crate\" \"$body\" >&2\n    return 2\n  fi\n  if printf '%s' \"$body\" | jq -e --arg v \"$version\" \\\n       '.versions | map(.num) | index($v) != null' >/dev/null 2>&1; then\n    return 0\n  fi\n  return 1\n}\n\nLOCAL_VERSION=\"$(resolve_local_version)\"\n\nif [ \"$DRY_RUN\" -eq 1 ]; then\n  printf 'cargo-publish-if-new: %s@%s — --dry-run; forwarding to cargo publish --dry-run\\n' \\\n    \"$CRATE\" \"$LOCAL_VERSION\"\n  exec cargo publish --dry-run -p \"$CRATE\"\nfi\n\nset +e\nregistry_has_version \"$CRATE\" \"$LOCAL_VERSION\"\nrc=$?\nset -e\ncase \"$rc\" in\n  0)\n    printf 'cargo-publish-if-new: %s@%s already published; skipping\\n' \\\n      \"$CRATE\" \"$LOCAL_VERSION\"\n    exit 0\n    ;;\n  1)\n    printf 'cargo-publish-if-new: %s@%s not on registry; publishing\\n' \\\n      \"$CRATE\" \"$LOCAL_VERSION\"\n    if [ -z \"${CARGO_REGISTRY_TOKEN:-}\" ]; then\n      printf 'cargo-publish-if-new: CARGO_REGISTRY_TOKEN not set\\n' >&2\n      exit 1\n    fi\n    exec cargo publish -p \"$CRATE\" --token \"$CARGO_REGISTRY_TOKEN\"\n    ;;\n  *)\n    exit \"$rc\"\n    ;;\nesac\n","numLines":173,"startLine":1,"totalLines":173}}}
