{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Pnqv21qV4UuNvQg4r7vMPj","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t# scripts/tests/test_cargo_publish_if_new.sh — offline coverage for the\n3\t# idempotent cargo publish helper (release.yml T1..T7). Mirrors the fixture\n4\t# pattern in test_assert_co_tagging.sh: python3 -m http.server serves a\n5\t# fake crates.io JSON index, and `cargo` is a shim in PATH so no real\n6\t# registry or toolchain work happens.\n7\tset -euo pipefail\n8\t\n9\tSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n10\tREPO_ROOT=\"$(cd \"$SCRIPT_DIR/../..\" && pwd)\"\n11\tHELPER=\"$REPO_ROOT/scripts/release/cargo-publish-if-new.sh\"\n12\tFIX_DIR=\"$REPO_ROOT/dev/release/fixtures/cargo-publish-if-new\"\n13\t\n14\tFAILED=0\n15\tSERVE_DIR=\"$(mktemp -d)\"\n16\tSHIM_DIR=\"$(mktemp -d)\"\n17\texport CARGO_LOG=\"$SHIM_DIR/cargo.log\"\n18\tPORT=0\n19\tPID=0\n20\t\n21\tcleanup() {\n22\t  if [ \"$PID\" -ne 0 ]; then\n23\t    kill \"$PID\" 2>/dev/null || true\n24\t    wait \"$PID\" 2>/dev/null || true\n25\t  fi\n26\t  rm -rf \"$SERVE_DIR\" \"$SHIM_DIR\"\n27\t}\n28\ttrap cleanup EXIT\n29\t\n30\tpass() { printf 'PASS  %s\\n' \"$1\"; }\n31\tfail() { printf 'FAIL  %s\\n' \"$1\" >&2; FAILED=$((FAILED + 1)); }\n32\t\n33\tmkdir -p \"$SERVE_DIR/api/v1/crates\"\n34\t\n35\tstart_server() {\n36\t  ( cd \"$SERVE_DIR\" && python3 -u -m http.server 0 ) >\"$SERVE_DIR/server.log\" 2>&1 &\n37\t  PID=$!\n38\t  for _ in $(seq 1 50); do\n39\t    if grep -qE 'Serving HTTP on .* port [0-9]+' \"$SERVE_DIR/server.log\" 2>/dev/null; then\n40\t      PORT=\"$(sed -nE 's/.*port ([0-9]+).*/\\1/p' \"$SERVE_DIR/server.log\" | head -1)\"\n41\t      break\n42\t    fi\n43\t    sleep 0.05\n44\t  done\n45\t  if [ \"$PORT\" -eq 0 ]; then\n46\t    fail \"fixture http server failed to bind\"\n47\t    return 1\n48\t  fi\n49\t}\n50\t\n51\tstop_server() {\n52\t  if [ \"$PID\" -ne 0 ]; then\n53\t    kill \"$PID\" 2>/dev/null || true\n54\t    wait \"$PID\" 2>/dev/null || true\n55\t    PID=0\n56\t  fi\n57\t}\n58\t\n59\t# Install a fake `cargo` shim that records its argv and exits with the\n60\t# code from $CARGO_SHIM_EXIT (default 0). The shim does NOT touch the\n61\t# real cargo binary so tests are hermetic.\n62\tinstall_cargo_shim() {\n63\t  cat >\"$SHIM_DIR/cargo\" <<'SHIM'\n64\t#!/usr/bin/env bash\n65\tprintf '%s\\n' \"$*\" >>\"$CARGO_LOG\"\n66\texit \"${CARGO_SHIM_EXIT:-0}\"\n67\tSHIM\n68\t  chmod +x \"$SHIM_DIR/cargo\"\n69\t}\n70\t\n71\treset_shim_log() { : >\"$CARGO_LOG\"; }\n72\t\n73\tinstall_cargo_shim\n74\treset_shim_log\n75\t\n76\t# Fixture JSON for the fake registry — one crate at 0.6.0 (matches the\n77\t# Axis-E held-version scenario the slice exists to fix).\n78\tmkdir -p \"$FIX_DIR\"\n79\tcat >\"$FIX_DIR/fathomdb-embedder-api.json\" <<'JSON'\n80\t{\n81\t  \"crate\": {\"name\": \"fathomdb-embedder-api\"},\n82\t  \"versions\": [\n83\t    {\"num\": \"0.6.0\", \"yanked\": false},\n84\t    {\"num\": \"0.5.1\", \"yanked\": false}\n85\t  ]\n86\t}\n87\tJSON\n88\t# Pre-release fixture: a crate whose registry has 0.6.1-rc.1 already.\n89\tcat >\"$FIX_DIR/fathomdb-engine.json\" <<'JSON'\n90\t{\n91\t  \"crate\": {\"name\": \"fathomdb-engine\"},\n92\t  \"versions\": [\n93\t    {\"num\": \"0.6.1-rc.1\", \"yanked\": false},\n94\t    {\"num\": \"0.6.0\", \"yanked\": false}\n95\t  ]\n96\t}\n97\tJSON\n98\t# Crate with NO matching version — should publish.\n99\tcat >\"$FIX_DIR/fathomdb-schema.json\" <<'JSON'\n100\t{\n101\t  \"crate\": {\"name\": \"fathomdb-schema\"},\n102\t  \"versions\": [\n103\t    {\"num\": \"0.6.0\", \"yanked\": false}\n104\t  ]\n105\t}\n106\tJSON\n107\t\n108\tcp \"$FIX_DIR/fathomdb-embedder-api.json\" \"$SERVE_DIR/api/v1/crates/fathomdb-embedder-api\"\n109\tcp \"$FIX_DIR/fathomdb-engine.json\"       \"$SERVE_DIR/api/v1/crates/fathomdb-engine\"\n110\tcp \"$FIX_DIR/fathomdb-schema.json\"       \"$SERVE_DIR/api/v1/crates/fathomdb-schema\"\n111\t\n112\tstart_server\n113\t\n114\tREG=\"http://127.0.0.1:${PORT}\"\n115\trun_helper() {\n116\t  PATH=\"$SHIM_DIR:$PATH\" \\\n117\t  CARGO_PUBLISH_IF_NEW_REGISTRY=\"$REG\" \\\n118\t  CARGO_REGISTRY_TOKEN=\"test-token\" \\\n119\t  \"$HELPER\" \"$@\"\n120\t}\n121\t\n122\t# 1) Crate version already on the registry → skip; cargo NOT invoked.\n123\treset_shim_log\n124\tif out=\"$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.0 \\\n125\t            run_helper fathomdb-embedder-api 2>&1)\"; then\n126\t  if printf '%s' \"$out\" | grep -q 'already published; skipping' \\\n127\t     && ! [ -s \"$CARGO_LOG\" ]; then\n128\t    pass \"skip when registry already has the version\"\n129\t  else\n130\t    fail \"skip-case: log='$out' shim_log='$(cat \"$CARGO_LOG\")'\"\n131\t  fi\n132\telse\n133\t  fail \"skip-case: helper exited non-zero: $out\"\n134\tfi\n135\t\n136\t# 2) Crate version not on the registry → cargo publish invoked, exit 0.\n137\treset_shim_log\n138\tif out=\"$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.1 \\\n139\t            run_helper fathomdb-schema 2>&1)\"; then\n140\t  if grep -q -- '-p fathomdb-schema' \"$CARGO_LOG\" \\\n141\t     && grep -q 'publish' \"$CARGO_LOG\" \\\n142\t     && ! grep -q -- '--dry-run' \"$CARGO_LOG\"; then\n143\t    pass \"publish when registry lacks the version\"\n144\t  else\n145\t    fail \"publish-case: shim_log='$(cat \"$CARGO_LOG\")' helper='$out'\"\n146\t  fi\n147\telse\n148\t  fail \"publish-case: helper exited non-zero: $out\"\n149\tfi\n150\t\n151\t# 3) Pre-release version present in registry → still skip.\n152\treset_shim_log\n153\tif out=\"$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.1-rc.1 \\\n154\t            run_helper fathomdb-engine 2>&1)\"; then\n155\t  if printf '%s' \"$out\" | grep -q 'already published; skipping' \\\n156\t     && ! [ -s \"$CARGO_LOG\" ]; then\n157\t    pass \"skip pre-release version already on registry\"\n158\t  else\n159\t    fail \"rc-skip-case: log='$out' shim='$(cat \"$CARGO_LOG\")'\"\n160\t  fi\n161\telse\n162\t  fail \"rc-skip-case: helper exited non-zero: $out\"\n163\tfi\n164\t\n165\t# 4) --dry-run forwards to cargo publish --dry-run regardless of registry state.\n166\treset_shim_log\n167\tif out=\"$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.0 \\\n168\t            run_helper --dry-run fathomdb-embedder-api 2>&1)\"; then\n169\t  if grep -q -- '--dry-run' \"$CARGO_LOG\" \\\n170\t     && grep -q -- '-p fathomdb-embedder-api' \"$CARGO_LOG\"; then\n171\t    pass \"--dry-run forwards regardless of registry state\"\n172\t  else\n173\t    fail \"dry-run-case: shim='$(cat \"$CARGO_LOG\")' helper='$out'\"\n174\t  fi\n175\telse\n176\t  fail \"dry-run-case: helper exited non-zero: $out\"\n177\tfi\n178\t\n179\t# 5) cargo publish failure must propagate non-zero.\n180\treset_shim_log\n181\tif CARGO_SHIM_EXIT=101 CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.1 \\\n182\t     run_helper fathomdb-schema >/dev/null 2>&1; then\n183\t  fail \"publish-failure-case: should have exited non-zero\"\n184\telse\n185\t  pass \"publish failure propagates non-zero exit\"\n186\tfi\n187\t\n188\t# 6) Missing arg → usage exit.\n189\tif out=\"$(\"$HELPER\" 2>&1)\"; then\n190\t  fail \"missing-arg-case: should have failed\"\n191\telse\n192\t  if printf '%s' \"$out\" | grep -qi 'usage'; then\n193\t    pass \"missing arg → usage\"\n194\t  else\n195\t    fail \"missing-arg-case: wrong diagnostic: $out\"\n196\t  fi\n197\tfi\n198\t\n199\t# 7) Regression guard: helper must set a User-Agent header (crates.io\n200\t# returns HTTP 403 without one — same constraint as assert-co-tagging.sh).\n201\tif grep -q 'User-Agent:' \"$HELPER\"; then\n202\t  pass \"helper sets User-Agent for crates.io\"\n203\telse\n204\t  fail \"helper missing User-Agent header\"\n205\tfi\n206\t\n207\tstop_server\n208\t\n209\tif [ \"$FAILED\" -gt 0 ]; then\n210\t  printf '\\n%d test(s) failed\\n' \"$FAILED\" >&2\n211\t  exit 1\n212\tfi\n213\tprintf '\\nAll cargo-publish-if-new tests passed\\n'\n214\t"}]},"parent_tool_use_id":null,"session_id":"94ef9a18-efe7-461e-91d9-252b6b93035c","uuid":"14d5d291-5425-450e-b539-e4c901d2b7c5","timestamp":"2026-05-25T01:19:24.650Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-0.6.1-WF-FIX-1-axis-e-idempotent-publish-20260525T010638Z/scripts/tests/test_cargo_publish_if_new.sh","content":"#!/usr/bin/env bash\n# scripts/tests/test_cargo_publish_if_new.sh — offline coverage for the\n# idempotent cargo publish helper (release.yml T1..T7). Mirrors the fixture\n# pattern in test_assert_co_tagging.sh: python3 -m http.server serves a\n# fake crates.io JSON index, and `cargo` is a shim in PATH so no real\n# registry or toolchain work happens.\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nREPO_ROOT=\"$(cd \"$SCRIPT_DIR/../..\" && pwd)\"\nHELPER=\"$REPO_ROOT/scripts/release/cargo-publish-if-new.sh\"\nFIX_DIR=\"$REPO_ROOT/dev/release/fixtures/cargo-publish-if-new\"\n\nFAILED=0\nSERVE_DIR=\"$(mktemp -d)\"\nSHIM_DIR=\"$(mktemp -d)\"\nexport CARGO_LOG=\"$SHIM_DIR/cargo.log\"\nPORT=0\nPID=0\n\ncleanup() {\n  if [ \"$PID\" -ne 0 ]; then\n    kill \"$PID\" 2>/dev/null || true\n    wait \"$PID\" 2>/dev/null || true\n  fi\n  rm -rf \"$SERVE_DIR\" \"$SHIM_DIR\"\n}\ntrap cleanup EXIT\n\npass() { printf 'PASS  %s\\n' \"$1\"; }\nfail() { printf 'FAIL  %s\\n' \"$1\" >&2; FAILED=$((FAILED + 1)); }\n\nmkdir -p \"$SERVE_DIR/api/v1/crates\"\n\nstart_server() {\n  ( cd \"$SERVE_DIR\" && python3 -u -m http.server 0 ) >\"$SERVE_DIR/server.log\" 2>&1 &\n  PID=$!\n  for _ in $(seq 1 50); do\n    if grep -qE 'Serving HTTP on .* port [0-9]+' \"$SERVE_DIR/server.log\" 2>/dev/null; then\n      PORT=\"$(sed -nE 's/.*port ([0-9]+).*/\\1/p' \"$SERVE_DIR/server.log\" | head -1)\"\n      break\n    fi\n    sleep 0.05\n  done\n  if [ \"$PORT\" -eq 0 ]; then\n    fail \"fixture http server failed to bind\"\n    return 1\n  fi\n}\n\nstop_server() {\n  if [ \"$PID\" -ne 0 ]; then\n    kill \"$PID\" 2>/dev/null || true\n    wait \"$PID\" 2>/dev/null || true\n    PID=0\n  fi\n}\n\n# Install a fake `cargo` shim that records its argv and exits with the\n# code from $CARGO_SHIM_EXIT (default 0). The shim does NOT touch the\n# real cargo binary so tests are hermetic.\ninstall_cargo_shim() {\n  cat >\"$SHIM_DIR/cargo\" <<'SHIM'\n#!/usr/bin/env bash\nprintf '%s\\n' \"$*\" >>\"$CARGO_LOG\"\nexit \"${CARGO_SHIM_EXIT:-0}\"\nSHIM\n  chmod +x \"$SHIM_DIR/cargo\"\n}\n\nreset_shim_log() { : >\"$CARGO_LOG\"; }\n\ninstall_cargo_shim\nreset_shim_log\n\n# Fixture JSON for the fake registry — one crate at 0.6.0 (matches the\n# Axis-E held-version scenario the slice exists to fix).\nmkdir -p \"$FIX_DIR\"\ncat >\"$FIX_DIR/fathomdb-embedder-api.json\" <<'JSON'\n{\n  \"crate\": {\"name\": \"fathomdb-embedder-api\"},\n  \"versions\": [\n    {\"num\": \"0.6.0\", \"yanked\": false},\n    {\"num\": \"0.5.1\", \"yanked\": false}\n  ]\n}\nJSON\n# Pre-release fixture: a crate whose registry has 0.6.1-rc.1 already.\ncat >\"$FIX_DIR/fathomdb-engine.json\" <<'JSON'\n{\n  \"crate\": {\"name\": \"fathomdb-engine\"},\n  \"versions\": [\n    {\"num\": \"0.6.1-rc.1\", \"yanked\": false},\n    {\"num\": \"0.6.0\", \"yanked\": false}\n  ]\n}\nJSON\n# Crate with NO matching version — should publish.\ncat >\"$FIX_DIR/fathomdb-schema.json\" <<'JSON'\n{\n  \"crate\": {\"name\": \"fathomdb-schema\"},\n  \"versions\": [\n    {\"num\": \"0.6.0\", \"yanked\": false}\n  ]\n}\nJSON\n\ncp \"$FIX_DIR/fathomdb-embedder-api.json\" \"$SERVE_DIR/api/v1/crates/fathomdb-embedder-api\"\ncp \"$FIX_DIR/fathomdb-engine.json\"       \"$SERVE_DIR/api/v1/crates/fathomdb-engine\"\ncp \"$FIX_DIR/fathomdb-schema.json\"       \"$SERVE_DIR/api/v1/crates/fathomdb-schema\"\n\nstart_server\n\nREG=\"http://127.0.0.1:${PORT}\"\nrun_helper() {\n  PATH=\"$SHIM_DIR:$PATH\" \\\n  CARGO_PUBLISH_IF_NEW_REGISTRY=\"$REG\" \\\n  CARGO_REGISTRY_TOKEN=\"test-token\" \\\n  \"$HELPER\" \"$@\"\n}\n\n# 1) Crate version already on the registry → skip; cargo NOT invoked.\nreset_shim_log\nif out=\"$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.0 \\\n            run_helper fathomdb-embedder-api 2>&1)\"; then\n  if printf '%s' \"$out\" | grep -q 'already published; skipping' \\\n     && ! [ -s \"$CARGO_LOG\" ]; then\n    pass \"skip when registry already has the version\"\n  else\n    fail \"skip-case: log='$out' shim_log='$(cat \"$CARGO_LOG\")'\"\n  fi\nelse\n  fail \"skip-case: helper exited non-zero: $out\"\nfi\n\n# 2) Crate version not on the registry → cargo publish invoked, exit 0.\nreset_shim_log\nif out=\"$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.1 \\\n            run_helper fathomdb-schema 2>&1)\"; then\n  if grep -q -- '-p fathomdb-schema' \"$CARGO_LOG\" \\\n     && grep -q 'publish' \"$CARGO_LOG\" \\\n     && ! grep -q -- '--dry-run' \"$CARGO_LOG\"; then\n    pass \"publish when registry lacks the version\"\n  else\n    fail \"publish-case: shim_log='$(cat \"$CARGO_LOG\")' helper='$out'\"\n  fi\nelse\n  fail \"publish-case: helper exited non-zero: $out\"\nfi\n\n# 3) Pre-release version present in registry → still skip.\nreset_shim_log\nif out=\"$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.1-rc.1 \\\n            run_helper fathomdb-engine 2>&1)\"; then\n  if printf '%s' \"$out\" | grep -q 'already published; skipping' \\\n     && ! [ -s \"$CARGO_LOG\" ]; then\n    pass \"skip pre-release version already on registry\"\n  else\n    fail \"rc-skip-case: log='$out' shim='$(cat \"$CARGO_LOG\")'\"\n  fi\nelse\n  fail \"rc-skip-case: helper exited non-zero: $out\"\nfi\n\n# 4) --dry-run forwards to cargo publish --dry-run regardless of registry state.\nreset_shim_log\nif out=\"$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.0 \\\n            run_helper --dry-run fathomdb-embedder-api 2>&1)\"; then\n  if grep -q -- '--dry-run' \"$CARGO_LOG\" \\\n     && grep -q -- '-p fathomdb-embedder-api' \"$CARGO_LOG\"; then\n    pass \"--dry-run forwards regardless of registry state\"\n  else\n    fail \"dry-run-case: shim='$(cat \"$CARGO_LOG\")' helper='$out'\"\n  fi\nelse\n  fail \"dry-run-case: helper exited non-zero: $out\"\nfi\n\n# 5) cargo publish failure must propagate non-zero.\nreset_shim_log\nif CARGO_SHIM_EXIT=101 CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.1 \\\n     run_helper fathomdb-schema >/dev/null 2>&1; then\n  fail \"publish-failure-case: should have exited non-zero\"\nelse\n  pass \"publish failure propagates non-zero exit\"\nfi\n\n# 6) Missing arg → usage exit.\nif out=\"$(\"$HELPER\" 2>&1)\"; then\n  fail \"missing-arg-case: should have failed\"\nelse\n  if printf '%s' \"$out\" | grep -qi 'usage'; then\n    pass \"missing arg → usage\"\n  else\n    fail \"missing-arg-case: wrong diagnostic: $out\"\n  fi\nfi\n\n# 7) Regression guard: helper must set a User-Agent header (crates.io\n# returns HTTP 403 without one — same constraint as assert-co-tagging.sh).\nif grep -q 'User-Agent:' \"$HELPER\"; then\n  pass \"helper sets User-Agent for crates.io\"\nelse\n  fail \"helper missing User-Agent header\"\nfi\n\nstop_server\n\nif [ \"$FAILED\" -gt 0 ]; then\n  printf '\\n%d test(s) failed\\n' \"$FAILED\" >&2\n  exit 1\nfi\nprintf '\\nAll cargo-publish-if-new tests passed\\n'\n","numLines":214,"startLine":1,"totalLines":214}}}
