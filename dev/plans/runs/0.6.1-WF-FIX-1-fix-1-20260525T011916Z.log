{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018KHwUnSNtHXN3g41HzDp4X","type":"tool_result","content":"100\t{\n101\t  \"crate\": {\"name\": \"fathomdb-schema\"},\n102\t  \"versions\": [\n103\t    {\"num\": \"0.6.0\", \"yanked\": false}\n104\t  ]\n105\t}\n106\tJSON\n107\t\n108\tcp \"$FIX_DIR/fathomdb-embedder-api.json\" \"$SERVE_DIR/api/v1/crates/fathomdb-embedder-api\"\n109\tcp \"$FIX_DIR/fathomdb-engine.json\"       \"$SERVE_DIR/api/v1/crates/fathomdb-engine\"\n110\tcp \"$FIX_DIR/fathomdb-schema.json\"       \"$SERVE_DIR/api/v1/crates/fathomdb-schema\"\n111\t\n112\tstart_server\n113\t\n114\tREG=\"http://127.0.0.1:${PORT}\"\n115\trun_helper() {\n116\t  PATH=\"$SHIM_DIR:$PATH\" \\\n117\t  CARGO_PUBLISH_IF_NEW_REGISTRY=\"$REG\" \\\n118\t  CARGO_REGISTRY_TOKEN=\"test-token\" \\\n119\t  \"$HELPER\" \"$@\"\n120\t}\n121\t\n122\t# 1) Crate version already on the registry → skip; cargo NOT invoked.\n123\treset_shim_log\n124\tif out=\"$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.0 \\\n125\t            run_helper fathomdb-embedder-api 2>&1)\"; then\n126\t  if printf '%s' \"$out\" | grep -q 'already published; skipping' \\\n127\t     && ! [ -s \"$CARGO_LOG\" ]; then\n128\t    pass \"skip when registry already has the version\"\n129\t  else\n130\t    fail \"skip-case: log='$out' shim_log='$(cat \"$CARGO_LOG\")'\"\n131\t  fi\n132\telse\n133\t  fail \"skip-case: helper exited non-zero: $out\"\n134\tfi\n135\t\n136\t# 2) Crate version not on the registry → cargo publish invoked, exit 0.\n137\treset_shim_log\n138\tif out=\"$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.1 \\\n139\t            run_helper fathomdb-schema 2>&1)\"; then\n140\t  if grep -q -- '-p fathomdb-schema' \"$CARGO_LOG\" \\\n141\t     && grep -q 'publish' \"$CARGO_LOG\" \\\n142\t     && ! grep -q -- '--dry-run' \"$CARGO_LOG\"; then\n143\t    pass \"publish when registry lacks the version\"\n144\t  else\n145\t    fail \"publish-case: shim_log='$(cat \"$CARGO_LOG\")' helper='$out'\"\n146\t  fi\n147\telse\n148\t  fail \"publish-case: helper exited non-zero: $out\"\n149\tfi\n150\t\n151\t# 3) Pre-release version present in registry → still skip.\n152\treset_shim_log\n153\tif out=\"$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.1-rc.1 \\\n154\t            run_helper fathomdb-engine 2>&1)\"; then\n155\t  if printf '%s' \"$out\" | grep -q 'already published; skipping' \\\n156\t     && ! [ -s \"$CARGO_LOG\" ]; then\n157\t    pass \"skip pre-release version already on registry\"\n158\t  else\n159\t    fail \"rc-skip-case: log='$out' shim='$(cat \"$CARGO_LOG\")'\"\n160\t  fi\n161\telse\n162\t  fail \"rc-skip-case: helper exited non-zero: $out\"\n163\tfi\n164\t\n165\t# 4) --dry-run forwards to cargo publish --dry-run regardless of registry state.\n166\treset_shim_log\n167\tif out=\"$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.0 \\\n168\t            run_helper --dry-run fathomdb-embedder-api 2>&1)\"; then\n169\t  if grep -q -- '--dry-run' \"$CARGO_LOG\" \\\n170\t     && grep -q -- '-p fathomdb-embedder-api' \"$CARGO_LOG\"; then\n171\t    pass \"--dry-run forwards regardless of registry state\"\n172\t  else\n173\t    fail \"dry-run-case: shim='$(cat \"$CARGO_LOG\")' helper='$out'\"\n174\t  fi\n175\telse\n176\t  fail \"dry-run-case: helper exited non-zero: $out\"\n177\tfi\n178\t\n179\t# 5) cargo publish failure must propagate non-zero.\n180\treset_shim_log\n181\tif CARGO_SHIM_EXIT=101 CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.1 \\\n182\t     run_helper fathomdb-schema >/dev/null 2>&1; then\n183\t  fail \"publish-failure-case: should have exited non-zero\"\n184\telse\n185\t  pass \"publish failure propagates non-zero exit\"\n186\tfi\n187\t\n188\t# 6) Missing arg → usage exit.\n189\tif out=\"$(\"$HELPER\" 2>&1)\"; then\n190\t  fail \"missing-arg-case: should have failed\"\n191\telse\n192\t  if printf '%s' \"$out\" | grep -qi 'usage'; then\n193\t    pass \"missing arg → usage\"\n194\t  else\n195\t    fail \"missing-arg-case: wrong diagnostic: $out\"\n196\t  fi\n197\tfi\n198\t\n199\t# 7) Regression guard: helper must set a User-Agent header (crates.io\n200\t# returns HTTP 403 without one — same constraint as assert-co-tagging.sh).\n201\tif grep -q 'User-Agent:' \"$HELPER\"; then\n202\t  pass \"helper sets User-Agent for crates.io\"\n203\telse\n204\t  fail \"helper missing User-Agent header\"\n205\tfi\n206\t\n207\tstop_server\n208\t\n209\tif [ \"$FAILED\" -gt 0 ]; then\n210\t  printf '\\n%d test(s) failed\\n' \"$FAILED\" >&2\n211\t  exit 1\n212\tfi\n213\tprintf '\\nAll cargo-publish-if-new tests passed\\n'"}]},"parent_tool_use_id":null,"session_id":"94ef9a18-efe7-461e-91d9-252b6b93035c","uuid":"02dc8657-88a6-46f0-aa26-f6631fb5a224","timestamp":"2026-05-25T01:20:40.435Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-0.6.1-WF-FIX-1-axis-e-idempotent-publish-20260525T010638Z/scripts/tests/test_cargo_publish_if_new.sh","content":"{\n  \"crate\": {\"name\": \"fathomdb-schema\"},\n  \"versions\": [\n    {\"num\": \"0.6.0\", \"yanked\": false}\n  ]\n}\nJSON\n\ncp \"$FIX_DIR/fathomdb-embedder-api.json\" \"$SERVE_DIR/api/v1/crates/fathomdb-embedder-api\"\ncp \"$FIX_DIR/fathomdb-engine.json\"       \"$SERVE_DIR/api/v1/crates/fathomdb-engine\"\ncp \"$FIX_DIR/fathomdb-schema.json\"       \"$SERVE_DIR/api/v1/crates/fathomdb-schema\"\n\nstart_server\n\nREG=\"http://127.0.0.1:${PORT}\"\nrun_helper() {\n  PATH=\"$SHIM_DIR:$PATH\" \\\n  CARGO_PUBLISH_IF_NEW_REGISTRY=\"$REG\" \\\n  CARGO_REGISTRY_TOKEN=\"test-token\" \\\n  \"$HELPER\" \"$@\"\n}\n\n# 1) Crate version already on the registry → skip; cargo NOT invoked.\nreset_shim_log\nif out=\"$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.0 \\\n            run_helper fathomdb-embedder-api 2>&1)\"; then\n  if printf '%s' \"$out\" | grep -q 'already published; skipping' \\\n     && ! [ -s \"$CARGO_LOG\" ]; then\n    pass \"skip when registry already has the version\"\n  else\n    fail \"skip-case: log='$out' shim_log='$(cat \"$CARGO_LOG\")'\"\n  fi\nelse\n  fail \"skip-case: helper exited non-zero: $out\"\nfi\n\n# 2) Crate version not on the registry → cargo publish invoked, exit 0.\nreset_shim_log\nif out=\"$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.1 \\\n            run_helper fathomdb-schema 2>&1)\"; then\n  if grep -q -- '-p fathomdb-schema' \"$CARGO_LOG\" \\\n     && grep -q 'publish' \"$CARGO_LOG\" \\\n     && ! grep -q -- '--dry-run' \"$CARGO_LOG\"; then\n    pass \"publish when registry lacks the version\"\n  else\n    fail \"publish-case: shim_log='$(cat \"$CARGO_LOG\")' helper='$out'\"\n  fi\nelse\n  fail \"publish-case: helper exited non-zero: $out\"\nfi\n\n# 3) Pre-release version present in registry → still skip.\nreset_shim_log\nif out=\"$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.1-rc.1 \\\n            run_helper fathomdb-engine 2>&1)\"; then\n  if printf '%s' \"$out\" | grep -q 'already published; skipping' \\\n     && ! [ -s \"$CARGO_LOG\" ]; then\n    pass \"skip pre-release version already on registry\"\n  else\n    fail \"rc-skip-case: log='$out' shim='$(cat \"$CARGO_LOG\")'\"\n  fi\nelse\n  fail \"rc-skip-case: helper exited non-zero: $out\"\nfi\n\n# 4) --dry-run forwards to cargo publish --dry-run regardless of registry state.\nreset_shim_log\nif out=\"$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.0 \\\n            run_helper --dry-run fathomdb-embedder-api 2>&1)\"; then\n  if grep -q -- '--dry-run' \"$CARGO_LOG\" \\\n     && grep -q -- '-p fathomdb-embedder-api' \"$CARGO_LOG\"; then\n    pass \"--dry-run forwards regardless of registry state\"\n  else\n    fail \"dry-run-case: shim='$(cat \"$CARGO_LOG\")' helper='$out'\"\n  fi\nelse\n  fail \"dry-run-case: helper exited non-zero: $out\"\nfi\n\n# 5) cargo publish failure must propagate non-zero.\nreset_shim_log\nif CARGO_SHIM_EXIT=101 CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.1 \\\n     run_helper fathomdb-schema >/dev/null 2>&1; then\n  fail \"publish-failure-case: should have exited non-zero\"\nelse\n  pass \"publish failure propagates non-zero exit\"\nfi\n\n# 6) Missing arg → usage exit.\nif out=\"$(\"$HELPER\" 2>&1)\"; then\n  fail \"missing-arg-case: should have failed\"\nelse\n  if printf '%s' \"$out\" | grep -qi 'usage'; then\n    pass \"missing arg → usage\"\n  else\n    fail \"missing-arg-case: wrong diagnostic: $out\"\n  fi\nfi\n\n# 7) Regression guard: helper must set a User-Agent header (crates.io\n# returns HTTP 403 without one — same constraint as assert-co-tagging.sh).\nif grep -q 'User-Agent:' \"$HELPER\"; then\n  pass \"helper sets User-Agent for crates.io\"\nelse\n  fail \"helper missing User-Agent header\"\nfi\n\nstop_server\n\nif [ \"$FAILED\" -gt 0 ]; then\n  printf '\\n%d test(s) failed\\n' \"$FAILED\" >&2\n  exit 1\nfi\nprintf '\\nAll cargo-publish-if-new tests passed\\n'","numLines":114,"startLine":100,"totalLines":214}}}
