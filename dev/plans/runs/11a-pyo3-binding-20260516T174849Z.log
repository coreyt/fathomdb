{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Bs6GswqHHbk1GcSWM6uBUh","type":"tool_result","content":"1\t\"\"\"Public surface assertions for the Python SDK.\n2\t\n3\tPins the five-verb top-level surface, the engine-attached instrumentation\n4\tmethods, the keyword vs EngineConfig forms of `Engine.open`, and the\n5\tsoft-fallback record shape per `dev/interfaces/python.md` and\n6\t`dev/design/bindings.md` § 3.\n7\t\"\"\"\n8\t\n9\tfrom __future__ import annotations\n10\t\n11\timport inspect\n12\t\n13\timport fathomdb\n14\tfrom fathomdb import Engine, EngineConfig, SearchResult, SoftFallback, WriteReceipt, admin\n15\t\n16\t\n17\tdef test_top_level_exports_match_canonical_set() -> None:\n18\t    expected = {\n19\t        \"Engine\",\n20\t        \"EngineConfig\",\n21\t        \"SearchResult\",\n22\t        \"SoftFallback\",\n23\t        \"WriteReceipt\",\n24\t        \"admin\",\n25\t        \"errors\",\n26\t    }\n27\t    assert expected.issubset(set(fathomdb.__all__))\n28\t\n29\t\n30\tdef test_admin_is_module_level_namespace() -> None:\n31\t    assert inspect.ismodule(admin)\n32\t    assert hasattr(admin, \"configure\")\n33\t\n34\t\n35\tdef test_engine_exposes_five_verbs_plus_instrumentation() -> None:\n36\t    for verb in (\"open\", \"write\", \"search\", \"close\"):\n37\t        assert hasattr(Engine, verb), f\"Engine must expose {verb}\"\n38\t\n39\t    for instr in (\n40\t        \"drain\",\n41\t        \"counters\",\n42\t        \"set_profiling\",\n43\t        \"set_slow_threshold_ms\",\n44\t        \"attach_logging_subscriber\",\n45\t    ):\n46\t        assert hasattr(Engine, instr), f\"Engine must expose {instr}\"\n47\t\n48\t\n49\tdef test_engine_open_accepts_kwargs_and_engine_config() -> None:\n50\t    by_kwargs = Engine.open(\n51\t        \"rewrite.sqlite\",\n52\t        embedder_pool_size=2,\n53\t        scheduler_runtime_threads=4,\n54\t        provenance_row_cap=1024,\n55\t        embedder_call_timeout_ms=30_000,\n56\t        slow_threshold_ms=250,\n57\t    )\n58\t    cfg = EngineConfig(\n59\t        embedder_pool_size=2,\n60\t        scheduler_runtime_threads=4,\n61\t        provenance_row_cap=1024,\n62\t        embedder_call_timeout_ms=30_000,\n63\t        slow_threshold_ms=250,\n64\t    )\n65\t    by_config = Engine.open(\"rewrite.sqlite\", config=cfg)\n66\t\n67\t    assert by_kwargs.config == by_config.config\n68\t\n69\t\n70\tdef test_engine_open_rejects_kwargs_and_config_together() -> None:\n71\t    cfg = EngineConfig()\n72\t    try:\n73\t        Engine.open(\"rewrite.sqlite\", config=cfg, embedder_pool_size=2)\n74\t    except ValueError:\n75\t        return\n76\t    raise AssertionError(\"Engine.open must reject config + kwargs in the same call\")\n77\t\n78\t\n79\tdef test_write_receipt_carries_cursor() -> None:\n80\t    engine = Engine.open(\"rewrite.sqlite\")\n81\t    receipt = engine.write([{\"kind\": \"doc\"}])\n82\t    assert isinstance(receipt, WriteReceipt)\n83\t    assert isinstance(receipt.cursor, int)\n84\t\n85\t\n86\tdef test_search_result_carries_optional_soft_fallback() -> None:\n87\t    engine = Engine.open(\"rewrite.sqlite\")\n88\t    result = engine.search(\"hello\")\n89\t    assert isinstance(result, SearchResult)\n90\t    assert isinstance(result.projection_cursor, int)\n91\t    assert result.soft_fallback is None\n92\t\n93\t\n94\tdef test_soft_fallback_branch_is_typed() -> None:\n95\t    f = SoftFallback(branch=\"vector\")\n96\t    assert f.branch == \"vector\"\n97\t    f = SoftFallback(branch=\"text\")\n98\t    assert f.branch == \"text\"\n99\t\n100\t\n101\tdef test_admin_configure_returns_write_receipt_shape() -> None:\n102\t    engine = Engine.open(\"rewrite.sqlite\")\n103\t    receipt = admin.configure(engine, name=\"default\", body=\"{}\")\n104\t    assert isinstance(receipt, WriteReceipt)\n105\t    assert isinstance(receipt.cursor, int)\n106\t\n107\t\n108\tdef test_engine_attached_stub_methods_return_canonical_types() -> None:\n109\t    engine = Engine.open(\"rewrite.sqlite\")\n110\t\n111\t    engine.drain(timeout_s=0)\n112\t    snapshot = engine.counters()\n113\t    assert snapshot is not None\n114\t\n115\t    engine.set_profiling(enabled=True)\n116\t    engine.set_slow_threshold_ms(value=100)\n117\t\n118\t    import logging\n119\t\n120\t    engine.attach_logging_subscriber(logging.getLogger(\"fathomdb-test\"))\n121\t"}]},"parent_tool_use_id":null,"session_id":"832e6e92-5689-410c-95d4-734b1bf78ed2","uuid":"0b2ae12b-68ad-47e4-997a-e21259250147","timestamp":"2026-05-16T17:53:08.601Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-11a-pyo3-binding-20260516T174849Z/src/python/tests/test_surface.py","content":"\"\"\"Public surface assertions for the Python SDK.\n\nPins the five-verb top-level surface, the engine-attached instrumentation\nmethods, the keyword vs EngineConfig forms of `Engine.open`, and the\nsoft-fallback record shape per `dev/interfaces/python.md` and\n`dev/design/bindings.md` § 3.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport inspect\n\nimport fathomdb\nfrom fathomdb import Engine, EngineConfig, SearchResult, SoftFallback, WriteReceipt, admin\n\n\ndef test_top_level_exports_match_canonical_set() -> None:\n    expected = {\n        \"Engine\",\n        \"EngineConfig\",\n        \"SearchResult\",\n        \"SoftFallback\",\n        \"WriteReceipt\",\n        \"admin\",\n        \"errors\",\n    }\n    assert expected.issubset(set(fathomdb.__all__))\n\n\ndef test_admin_is_module_level_namespace() -> None:\n    assert inspect.ismodule(admin)\n    assert hasattr(admin, \"configure\")\n\n\ndef test_engine_exposes_five_verbs_plus_instrumentation() -> None:\n    for verb in (\"open\", \"write\", \"search\", \"close\"):\n        assert hasattr(Engine, verb), f\"Engine must expose {verb}\"\n\n    for instr in (\n        \"drain\",\n        \"counters\",\n        \"set_profiling\",\n        \"set_slow_threshold_ms\",\n        \"attach_logging_subscriber\",\n    ):\n        assert hasattr(Engine, instr), f\"Engine must expose {instr}\"\n\n\ndef test_engine_open_accepts_kwargs_and_engine_config() -> None:\n    by_kwargs = Engine.open(\n        \"rewrite.sqlite\",\n        embedder_pool_size=2,\n        scheduler_runtime_threads=4,\n        provenance_row_cap=1024,\n        embedder_call_timeout_ms=30_000,\n        slow_threshold_ms=250,\n    )\n    cfg = EngineConfig(\n        embedder_pool_size=2,\n        scheduler_runtime_threads=4,\n        provenance_row_cap=1024,\n        embedder_call_timeout_ms=30_000,\n        slow_threshold_ms=250,\n    )\n    by_config = Engine.open(\"rewrite.sqlite\", config=cfg)\n\n    assert by_kwargs.config == by_config.config\n\n\ndef test_engine_open_rejects_kwargs_and_config_together() -> None:\n    cfg = EngineConfig()\n    try:\n        Engine.open(\"rewrite.sqlite\", config=cfg, embedder_pool_size=2)\n    except ValueError:\n        return\n    raise AssertionError(\"Engine.open must reject config + kwargs in the same call\")\n\n\ndef test_write_receipt_carries_cursor() -> None:\n    engine = Engine.open(\"rewrite.sqlite\")\n    receipt = engine.write([{\"kind\": \"doc\"}])\n    assert isinstance(receipt, WriteReceipt)\n    assert isinstance(receipt.cursor, int)\n\n\ndef test_search_result_carries_optional_soft_fallback() -> None:\n    engine = Engine.open(\"rewrite.sqlite\")\n    result = engine.search(\"hello\")\n    assert isinstance(result, SearchResult)\n    assert isinstance(result.projection_cursor, int)\n    assert result.soft_fallback is None\n\n\ndef test_soft_fallback_branch_is_typed() -> None:\n    f = SoftFallback(branch=\"vector\")\n    assert f.branch == \"vector\"\n    f = SoftFallback(branch=\"text\")\n    assert f.branch == \"text\"\n\n\ndef test_admin_configure_returns_write_receipt_shape() -> None:\n    engine = Engine.open(\"rewrite.sqlite\")\n    receipt = admin.configure(engine, name=\"default\", body=\"{}\")\n    assert isinstance(receipt, WriteReceipt)\n    assert isinstance(receipt.cursor, int)\n\n\ndef test_engine_attached_stub_methods_return_canonical_types() -> None:\n    engine = Engine.open(\"rewrite.sqlite\")\n\n    engine.drain(timeout_s=0)\n    snapshot = engine.counters()\n    assert snapshot is not None\n\n    engine.set_profiling(enabled=True)\n    engine.set_slow_threshold_ms(value=100)\n\n    import logging\n\n    engine.attach_logging_subscriber(logging.getLogger(\"fathomdb-test\"))\n","numLines":121,"startLine":1,"totalLines":121}}}
