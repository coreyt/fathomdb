{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01RxrHeJftp7SgXyo7ABZgvA","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_012dovQpJ6mLsC8JM9SbqWFN","name":"Write","input":{"file_path":"/tmp/fdb-11a-pyo3-binding-20260516T174849Z/src/python/fathomdb/admin.py","content":"\"\"\"Admin namespace exposing the `configure` verb beside `Engine`.\n\nPer `dev/interfaces/python.md` § Runtime surface, `admin.configure` is the\nfifth canonical SDK verb. The native binding (`fathomdb._fathomdb`)\nperforms the writer-thread wiring; this module exposes the typed\nPython signature and converts the native receipt to the public\n`WriteReceipt` dataclass.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom typing import TYPE_CHECKING\n\nfrom fathomdb._fathomdb import admin_configure as _native_configure\nfrom fathomdb.types import WriteReceipt\n\nif TYPE_CHECKING:\n    from fathomdb.engine import Engine\n\n\ndef configure(engine: \"Engine\", *, name: str, body: str) -> WriteReceipt:\n    \"\"\"Submit an admin schema configuration.\"\"\"\n\n    if not name:\n        raise ValueError(\"admin.configure requires a non-empty name\")\n    if body is None:\n        raise ValueError(\"admin.configure requires a body\")\n    receipt = _native_configure(engine._native, name, body)\n    return WriteReceipt(cursor=receipt.cursor)\n\n\n__all__ = [\"configure\"]\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":368,"cache_read_input_tokens":125309,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":368},"output_tokens":59,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"832e6e92-5689-410c-95d4-734b1bf78ed2","uuid":"d32f5f43-ba05-44f5-b32c-7c0a46b77262"}
