+def _mk_q(query_class: str, doc_ids: list[str]) -> dict:
+    return {
+        "query": f"q over {doc_ids}",
+        "query_class": query_class,
+        "required_evidence": [{"doc_id": d} for d in doc_ids],
+        "answers": ["x"],
+    }
