{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JY2CeATMVoBVrptZY6SrF6","type":"tool_result","content":"1\t\"\"\"AC-060a — typed error payload coverage.\n2\t\n3\tThe engine returns enum variants with typed fields; the binding\n4\ttranslator (`engine_error_to_py` / `engine_open_error_to_py`) attaches\n5\tthose fields as Python attributes on the raised exception so callers\n6\tcan dispatch and inspect without parsing message text.\n7\t\"\"\"\n8\t\n9\tfrom __future__ import annotations\n10\t\n11\timport pytest\n12\t\n13\tfrom fathomdb import Engine\n14\tfrom fathomdb.errors import (\n15\t    CorruptionError,\n16\t    DatabaseLockedError,\n17\t    EmbedderDimensionMismatchError,\n18\t)\n19\t\n20\t\n21\tdef test_database_locked_error_attr_round_trip() -> None:\n22\t    err = DatabaseLockedError(holder_pid=12345)\n23\t    assert err.holder_pid == 12345\n24\t\n25\t\n26\tdef test_database_locked_engine_triggered(db_path: str) -> None:\n27\t    \"\"\"Opening the same database twice in one process must surface\n28\t    `DatabaseLockedError` with the `holder_pid` attribute populated\n29\t    (or `None` when the lockfile is unparseable).\"\"\"\n30\t\n31\t    a = Engine.open(db_path)\n32\t    try:\n33\t        with pytest.raises(DatabaseLockedError) as excinfo:\n34\t            Engine.open(db_path)\n35\t        assert hasattr(excinfo.value, \"holder_pid\")\n36\t        assert excinfo.value.holder_pid is None or isinstance(\n37\t            excinfo.value.holder_pid, int\n38\t        )\n39\t    finally:\n40\t        a.close()\n41\t\n42\t\n43\tdef test_corruption_error_attrs_round_trip() -> None:\n44\t    err = CorruptionError(\n45\t        kind=\"HeaderMalformed\",\n46\t        stage=\"HeaderProbe\",\n47\t        recovery_hint_code=\"E_CORRUPT_HEADER\",\n48\t        doc_anchor=\"design/recovery.md#header-malformed\",\n49\t    )\n50\t    assert err.kind == \"HeaderMalformed\"\n51\t    assert err.stage == \"HeaderProbe\"\n52\t    assert err.recovery_hint_code == \"E_CORRUPT_HEADER\"\n53\t    assert err.doc_anchor == \"design/recovery.md#header-malformed\"\n54\t\n55\t\n56\tdef test_embedder_dimension_mismatch_attrs_round_trip() -> None:\n57\t    err = EmbedderDimensionMismatchError(stored=384, supplied=768)\n58\t    assert err.stored == 384\n59\t    assert err.supplied == 768\n60\t    assert isinstance(err.stored, int)\n61\t    assert isinstance(err.supplied, int)\n62\t"}]},"parent_tool_use_id":null,"session_id":"9bf016af-3b87-4a97-9dc2-e8a2161a09cc","uuid":"7591bd08-a527-4fe1-a9c9-b7cabb40ee62","timestamp":"2026-05-16T18:52:08.224Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-11a-pyo3-binding-20260516T174849Z/src/python/tests/test_typed_errors.py","content":"\"\"\"AC-060a — typed error payload coverage.\n\nThe engine returns enum variants with typed fields; the binding\ntranslator (`engine_error_to_py` / `engine_open_error_to_py`) attaches\nthose fields as Python attributes on the raised exception so callers\ncan dispatch and inspect without parsing message text.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport pytest\n\nfrom fathomdb import Engine\nfrom fathomdb.errors import (\n    CorruptionError,\n    DatabaseLockedError,\n    EmbedderDimensionMismatchError,\n)\n\n\ndef test_database_locked_error_attr_round_trip() -> None:\n    err = DatabaseLockedError(holder_pid=12345)\n    assert err.holder_pid == 12345\n\n\ndef test_database_locked_engine_triggered(db_path: str) -> None:\n    \"\"\"Opening the same database twice in one process must surface\n    `DatabaseLockedError` with the `holder_pid` attribute populated\n    (or `None` when the lockfile is unparseable).\"\"\"\n\n    a = Engine.open(db_path)\n    try:\n        with pytest.raises(DatabaseLockedError) as excinfo:\n            Engine.open(db_path)\n        assert hasattr(excinfo.value, \"holder_pid\")\n        assert excinfo.value.holder_pid is None or isinstance(\n            excinfo.value.holder_pid, int\n        )\n    finally:\n        a.close()\n\n\ndef test_corruption_error_attrs_round_trip() -> None:\n    err = CorruptionError(\n        kind=\"HeaderMalformed\",\n        stage=\"HeaderProbe\",\n        recovery_hint_code=\"E_CORRUPT_HEADER\",\n        doc_anchor=\"design/recovery.md#header-malformed\",\n    )\n    assert err.kind == \"HeaderMalformed\"\n    assert err.stage == \"HeaderProbe\"\n    assert err.recovery_hint_code == \"E_CORRUPT_HEADER\"\n    assert err.doc_anchor == \"design/recovery.md#header-malformed\"\n\n\ndef test_embedder_dimension_mismatch_attrs_round_trip() -> None:\n    err = EmbedderDimensionMismatchError(stored=384, supplied=768)\n    assert err.stored == 384\n    assert err.supplied == 768\n    assert isinstance(err.stored, int)\n    assert isinstance(err.supplied, int)\n","numLines":62,"startLine":1,"totalLines":62}}}
