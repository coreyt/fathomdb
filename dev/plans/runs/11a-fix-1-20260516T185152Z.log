{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017vZDkqDKBcQbGNTWTLRWde","type":"tool_result","content":"1\t// pyo3 0.22's `create_exception!` and `#[pymodule]` macros emit\n2\t// `#[cfg(feature = \"gil-refs\")]` arms that reference an upstream\n3\t// feature this crate does not export; the resulting `unexpected_cfgs`\n4\t// warnings are noise on a clippy `-D warnings` gate. The\n5\t// `useless_conversion` allow covers `#[pymethods]`-generated PyResult\n6\t// wrappers that clippy flags as redundant `Into<PyErr>` calls.\n7\t#![allow(unexpected_cfgs)]\n8\t#![allow(clippy::useless_conversion)]\n9\t\n10\t//! PyO3 binding from the Python SDK to `fathomdb-engine`.\n11\t//!\n12\t//! FFI safety contract (mirrored by Phase 11b napi-rs):\n13\t//!\n14\t//! 1. Every method that may block inside the engine wraps the call in\n15\t//!    `py.allow_threads(...)` so the GIL is released for the duration.\n16\t//! 2. Engine entry points return typed errors via [`engine_error_to_py`] /\n17\t//!    [`engine_open_error_to_py`] — single-switch mapping with no\n18\t//!    catch-all arm; the binding fails to compile when the Rust variant\n19\t//!    set drifts from the Python class set (AC-060a).\n20\t//! 3. Every string crossing the FFI is checked by [`validate_ffi_string`]\n21\t//!    for embedded NUL or unpaired UTF-16 surrogates BEFORE the writer\n22\t//!    transaction opens (AC-068a / AC-068b).\n23\t//! 4. Panics inside engine code surface as Python `EngineError`\n24\t//!    instances; the host process is not aborted (AC-067). PyO3 0.22\n25\t//!    converts unwinding panics escaping a `#[pymethod]` to a\n26\t//!    `PanicException`; we additionally wrap engine calls in\n27\t//!    `catch_unwind` and translate to `EngineError` so callers see the\n28\t//!    typed leaf class.\n29\t\n30\tuse std::panic::{catch_unwind, AssertUnwindSafe};\n31\tuse std::sync::Arc;\n32\t\n33\tuse fathomdb_engine::{\n34\t    CorruptionDetail, CorruptionKind, Engine as RustEngine, EngineError as RustEngineError,\n35\t    EngineOpenError, OpenStage, PreparedWrite, SearchResult as RustSearchResult,\n36\t    SoftFallback as RustSoftFallback, SoftFallbackBranch, WriteReceipt as RustWriteReceipt,\n37\t};\n38\tuse pyo3::create_exception;\n39\tuse pyo3::exceptions::{PyException, PyTypeError, PyValueError};\n40\tuse pyo3::prelude::*;\n41\tuse pyo3::types::{PyDict, PyList};\n42\t\n43\t// ===== Exceptions =====================================================\n44\t//\n45\t// Root + concrete leaves per dev/design/errors.md § Binding-facing class\n46\t// matrix. All concrete leaves inherit from `EngineError`; `EngineError`\n47\t// inherits from Python `Exception` via `create_exception!`.\n48\t\n49\tcreate_exception!(_fathomdb, EngineError, PyException);\n50\tcreate_exception!(_fathomdb, StorageError, EngineError);\n51\tcreate_exception!(_fathomdb, ProjectionError, EngineError);\n52\tcreate_exception!(_fathomdb, VectorError, EngineError);\n53\tcreate_exception!(_fathomdb, EmbedderError, EngineError);\n54\tcreate_exception!(_fathomdb, SchedulerError, EngineError);\n55\tcreate_exception!(_fathomdb, OpStoreError, EngineError);\n56\tcreate_exception!(_fathomdb, WriteValidationError, EngineError);\n57\tcreate_exception!(_fathomdb, SchemaValidationError, EngineError);\n58\tcreate_exception!(_fathomdb, OverloadedError, EngineError);\n59\tcreate_exception!(_fathomdb, ClosingError, EngineError);\n60\tcreate_exception!(_fathomdb, DatabaseLockedError, EngineError);\n61\tcreate_exception!(_fathomdb, CorruptionError, EngineError);\n62\tcreate_exception!(_fathomdb, IncompatibleSchemaVersionError, EngineError);\n63\tcreate_exception!(_fathomdb, MigrationError, EngineError);\n64\tcreate_exception!(_fathomdb, EmbedderIdentityMismatchError, EngineError);\n65\tcreate_exception!(_fathomdb, EmbedderDimensionMismatchError, EngineError);\n66\t\n67\t// ===== String validation (AC-068a / AC-068b) =========================\n68\t\n69\t/// Reject strings carrying an embedded NUL or an unpaired UTF-16\n70\t/// surrogate codepoint (`U+D800..=U+DFFF`).\n71\t///\n72\t/// Both are valid Python `str` values but invalid for SQLite text\n73\t/// columns; AC-068a/b requires the binding to reject them BEFORE the\n74\t/// writer transaction opens (no-row-written invariant).\n75\tpub fn validate_ffi_string(value: &str) -> Result<(), String> {\n76\t    if value.as_bytes().contains(&0) {\n77\t        return Err(\"embedded NUL byte in FFI string\".to_string());\n78\t    }\n79\t    for ch in value.chars() {\n80\t        let cp = ch as u32;\n81\t        if (0xD800..=0xDFFF).contains(&cp) {\n82\t            return Err(format!(\"unpaired UTF-16 surrogate U+{cp:04X} in FFI string\"));\n83\t        }\n84\t    }\n85\t    Ok(())\n86\t}\n87\t\n88\tfn validate_ffi_string_py(value: &str) -> PyResult<()> {\n89\t    validate_ffi_string(value).map_err(WriteValidationError::new_err)\n90\t}\n91\t\n92\t/// Extract a Python string into a Rust `String` and run\n93\t/// [`validate_ffi_string_py`]. PyO3's built-in `str` extraction already\n94\t/// fails on lone surrogates (the underlying `PyUnicode_AsUTF8AndSize`\n95\t/// raises `UnicodeEncodeError`); we re-raise those as the typed\n96\t/// `WriteValidationError` so callers can dispatch on a single class.\n97\tfn extract_validated_str(value: &Bound<'_, PyAny>) -> PyResult<String> {\n98\t    match value.extract::<String>() {\n99\t        Ok(s) => {\n100\t            validate_ffi_string_py(&s)?;\n101\t            Ok(s)\n102\t        }\n103\t        Err(_) => Err(WriteValidationError::new_err(\n104\t            \"string contains characters not representable as UTF-8 (lone surrogate)\",\n105\t        )),\n106\t    }\n107\t}\n108\t\n109\t// ===== Error mapping ==================================================\n110\t\n111\t/// Translate every `EngineError` variant to its Python counterpart.\n112\t///\n113\t/// No catch-all arm: drift between the Rust enum and the Python class\n114\t/// set is a compile error.\n115\tfn engine_error_to_py(err: RustEngineError) -> PyErr {\n116\t    match err {\n117\t        RustEngineError::Storage => StorageError::new_err(\"storage error\"),\n118\t        RustEngineError::Projection => ProjectionError::new_err(\"projection error\"),\n119\t        RustEngineError::Vector => VectorError::new_err(\"vector error\"),\n120\t        RustEngineError::Embedder => EmbedderError::new_err(\"embedder error\"),\n121\t        RustEngineError::EmbedderNotConfigured => {\n122\t            EmbedderError::new_err(\"embedder is not configured\")\n123\t        }\n124\t        RustEngineError::KindNotVectorIndexed => {\n125\t            VectorError::new_err(\"kind is not configured for vector indexing\")\n126\t        }\n127\t        RustEngineError::EmbedderDimensionMismatch { expected, actual } => {\n128\t            let exc = EmbedderDimensionMismatchError::new_err(format!(\n129\t                \"embedder vector dimension mismatch: stored {expected}, supplied {actual}\",\n130\t            ));\n131\t            Python::with_gil(|py| {\n132\t                let v = exc.value_bound(py);\n133\t                let _ = v.setattr(\"stored\", expected);\n134\t                let _ = v.setattr(\"supplied\", actual);\n135\t            });\n136\t            exc\n137\t        }\n138\t        RustEngineError::Scheduler => SchedulerError::new_err(\"scheduler error\"),\n139\t        RustEngineError::OpStore => OpStoreError::new_err(\"op-store error\"),\n140\t        RustEngineError::WriteValidation => WriteValidationError::new_err(\"write validation error\"),\n141\t        RustEngineError::SchemaValidation => {\n142\t            SchemaValidationError::new_err(\"schema validation error\")\n143\t        }\n144\t        RustEngineError::Overloaded => OverloadedError::new_err(\"engine overloaded\"),\n145\t        RustEngineError::Closing => ClosingError::new_err(\"engine is closing\"),\n146\t    }\n147\t}\n148\t\n149\tfn corruption_kind_str(kind: CorruptionKind) -> &'static str {\n150\t    match kind {\n151\t        CorruptionKind::WalReplayFailure => \"WalReplayFailure\",\n152\t        CorruptionKind::HeaderMalformed => \"HeaderMalformed\",\n153\t        CorruptionKind::SchemaInconsistent => \"SchemaInconsistent\",\n154\t        CorruptionKind::EmbedderIdentityDrift => \"EmbedderIdentityDrift\",\n155\t    }\n156\t}\n157\t\n158\tfn open_stage_str(stage: OpenStage) -> &'static str {\n159\t    match stage {\n160\t        OpenStage::HeaderProbe => \"HeaderProbe\",\n161\t        OpenStage::WalReplay => \"WalReplay\",\n162\t        OpenStage::SchemaProbe => \"SchemaProbe\",\n163\t        OpenStage::EmbedderIdentity => \"EmbedderIdentity\",\n164\t    }\n165\t}\n166\t\n167\tfn engine_open_error_to_py(err: EngineOpenError) -> PyErr {\n168\t    match err {\n169\t        EngineOpenError::DatabaseLocked { holder_pid } => {\n170\t            let exc = DatabaseLockedError::new_err(match holder_pid {\n171\t                Some(pid) => format!(\"database is locked by process {pid}\"),\n172\t                None => \"database is locked by another engine instance\".to_string(),\n173\t            });\n174\t            Python::with_gil(|py| {\n175\t                let _ = exc.value_bound(py).setattr(\"holder_pid\", holder_pid);\n176\t            });\n177\t            exc\n178\t        }\n179\t        EngineOpenError::Corruption(detail) => corruption_to_py(detail),\n180\t        EngineOpenError::IncompatibleSchemaVersion { seen, supported } => {\n181\t            IncompatibleSchemaVersionError::new_err(format!(\n182\t                \"database schema version {seen} is incompatible with supported version {supported}\"\n183\t            ))\n184\t        }\n185\t        EngineOpenError::MigrationError {\n186\t            schema_version_before,\n187\t            schema_version_current,\n188\t            step_id,\n189\t        } => MigrationError::new_err(format!(\n190\t            \"schema migration failed at step {step_id}; schema version remained between {schema_version_before} and {schema_version_current}\"\n191\t        )),\n192\t        EngineOpenError::EmbedderIdentityMismatch { stored, supplied } => {\n193\t            let exc = EmbedderIdentityMismatchError::new_err(format!(\n194\t                \"embedder identity mismatch: stored {}@{}, supplied {}@{}\",\n195\t                stored.name, stored.revision, supplied.name, supplied.revision,\n196\t            ));\n197\t            Python::with_gil(|py| {\n198\t                let v = exc.value_bound(py);\n199\t                let _ = v.setattr(\"stored_name\", stored.name);\n200\t                let _ = v.setattr(\"stored_revision\", stored.revision);\n201\t                let _ = v.setattr(\"supplied_name\", supplied.name);\n202\t                let _ = v.setattr(\"supplied_revision\", supplied.revision);\n203\t            });\n204\t            exc\n205\t        }\n206\t        EngineOpenError::EmbedderDimensionMismatch { stored, supplied } => {\n207\t            let exc = EmbedderDimensionMismatchError::new_err(format!(\n208\t                \"embedder vector dimension mismatch: stored {stored}, supplied {supplied}\",\n209\t            ));\n210\t            Python::with_gil(|py| {\n211\t                let v = exc.value_bound(py);\n212\t                let _ = v.setattr(\"stored\", stored);\n213\t                let _ = v.setattr(\"supplied\", supplied);\n214\t            });\n215\t            exc\n216\t        }\n217\t        EngineOpenError::Io { message } => {\n218\t            StorageError::new_err(format!(\"database I/O error: {message}\"))\n219\t        }\n220\t    }\n221\t}\n222\t\n223\tfn corruption_to_py(detail: CorruptionDetail) -> PyErr {\n224\t    let kind = corruption_kind_str(detail.kind);\n225\t    let stage = open_stage_str(detail.stage);\n226\t    let recovery_hint_code = detail.recovery_hint.code;\n227\t    let doc_anchor = detail.recovery_hint.doc_anchor;\n228\t    let exc = CorruptionError::new_err(format!(\n229\t        \"corruption {kind} at stage {stage} ({recovery_hint_code})\"\n230\t    ));\n231\t    Python::with_gil(|py| {\n232\t        let v = exc.value_bound(py);\n233\t        let _ = v.setattr(\"kind\", kind);\n234\t        let _ = v.setattr(\"stage\", stage);\n235\t        let _ = v.setattr(\"recovery_hint_code\", recovery_hint_code);\n236\t        let _ = v.setattr(\"doc_anchor\", doc_anchor);\n237\t    });\n238\t    exc\n239\t}\n240\t\n241\t/// Run the engine call inside `py.allow_threads` and `catch_unwind`;\n242\t/// translate any escaping panic to `EngineError`.\n243\t///\n244\t/// `AssertUnwindSafe` wraps the caller's closure so we do not need to\n245\t/// require `UnwindSafe` from `f`. The engine's `Arc<dyn Embedder>`\n246\t/// makes the natural `UnwindSafe` bound unsatisfiable; the engine\n247\t/// itself takes care of its own atomicity post-panic.\n248\tfn call_engine<R: Send>(\n249\t    py: Python<'_>,\n250\t    f: impl FnOnce() -> Result<R, RustEngineError> + Send,\n251\t) -> PyResult<R> {\n252\t    let wrapped = AssertUnwindSafe(f);\n253\t    let result = py.allow_threads(|| catch_unwind(wrapped));\n254\t    match result {\n255\t        Ok(Ok(value)) => Ok(value),\n256\t        Ok(Err(err)) => Err(engine_error_to_py(err)),\n257\t        Err(_) => Err(EngineError::new_err(\"engine panic (see logs)\")),\n258\t    }\n259\t}\n260\t\n261\t// ===== Data classes ===================================================\n262\t\n263\t#[pyclass(module = \"fathomdb._fathomdb\", name = \"WriteReceipt\", frozen, get_all)]\n264\t#[derive(Clone)]\n265\tstruct PyWriteReceipt {\n266\t    cursor: u64,\n267\t}\n268\t\n269\timpl PyWriteReceipt {\n270\t    fn from_rust(r: RustWriteReceipt) -> Self {\n271\t        Self { cursor: r.cursor }\n272\t    }\n273\t}\n274\t\n275\t#[pyclass(module = \"fathomdb._fathomdb\", name = \"SoftFallback\", frozen, get_all)]\n276\t#[derive(Clone)]\n277\tstruct PySoftFallback {\n278\t    branch: String,\n279\t}\n280\t\n281\timpl PySoftFallback {\n282\t    fn from_rust(s: &RustSoftFallback) -> Self {\n283\t        Self {\n284\t            branch: match s.branch {\n285\t                SoftFallbackBranch::Vector => \"vector\".to_string(),\n286\t                SoftFallbackBranch::Text => \"text\".to_string(),\n287\t            },\n288\t        }\n289\t    }\n290\t}\n291\t\n292\t#[pyclass(module = \"fathomdb._fathomdb\", name = \"SearchResult\", frozen, get_all)]\n293\t#[derive(Clone)]\n294\tstruct PySearchResult {\n295\t    projection_cursor: u64,\n296\t    soft_fallback: Option<PySoftFallback>,\n297\t    results: Vec<String>,\n298\t}\n299\t\n300\timpl PySearchResult {\n301\t    fn from_rust(r: RustSearchResult) -> Self {\n302\t        Self {\n303\t            projection_cursor: r.projection_cursor,\n304\t            soft_fallback: r.soft_fallback.as_ref().map(PySoftFallback::from_rust),\n305\t            results: r.results,\n306\t        }\n307\t    }\n308\t}\n309\t\n310\t#[pyclass(module = \"fathomdb._fathomdb\", name = \"CounterSnapshot\", frozen, get_all)]\n311\t#[derive(Clone)]\n312\tstruct PyCounterSnapshot {\n313\t    queries: u64,\n314\t    writes: u64,\n315\t    write_rows: u64,\n316\t    admin_ops: u64,\n317\t    cache_hit: u64,\n318\t    cache_miss: u64,\n319\t}\n320\t\n321\t// ===== Engine =========================================================\n322\t\n323\t#[pyclass(module = \"fathomdb._fathomdb\", name = \"Engine\")]\n324\tstruct PyEngine {\n325\t    inner: Arc<RustEngine>,\n326\t}\n327\t\n328\t#[pymethods]\n329\timpl PyEngine {\n330\t    #[staticmethod]\n331\t    #[pyo3(signature = (path))]\n332\t    fn open(py: Python<'_>, path: String) -> PyResult<Self> {\n333\t        validate_ffi_string_py(&path)?;\n334\t        let opened = py\n335\t            .allow_threads(|| catch_unwind(AssertUnwindSafe(|| RustEngine::open(path))))\n336\t            .map_err(|_| EngineError::new_err(\"engine panic during open\"))?\n337\t            .map_err(engine_open_error_to_py)?;\n338\t        Ok(Self { inner: Arc::new(opened.engine) })\n339\t    }\n340\t\n341\t    fn write(&self, py: Python<'_>, batch: Bound<'_, PyList>) -> PyResult<PyWriteReceipt> {\n342\t        let prepared = translate_batch(&batch)?;\n343\t        let engine = Arc::clone(&self.inner);\n344\t        let receipt = call_engine(py, move || engine.write(&prepared))?;\n345\t        Ok(PyWriteReceipt::from_rust(receipt))\n346\t    }\n347\t\n348\t    fn search(&self, py: Python<'_>, query: &str) -> PyResult<PySearchResult> {\n349\t        validate_ffi_string_py(query)?;\n350\t        let engine = Arc::clone(&self.inner);\n351\t        let query = query.to_string();\n352\t        let result = call_engine(py, move || engine.search(&query))?;\n353\t        Ok(PySearchResult::from_rust(result))\n354\t    }\n355\t\n356\t    fn close(&self, py: Python<'_>) -> PyResult<()> {\n357\t        let engine = Arc::clone(&self.inner);\n358\t        call_engine(py, move || engine.close())\n359\t    }\n360\t\n361\t    #[pyo3(signature = (timeout_s = 0.0))]\n362\t    fn drain(&self, py: Python<'_>, timeout_s: f64) -> PyResult<()> {\n363\t        let ms =\n364\t            if timeout_s.is_finite() && timeout_s > 0.0 { (timeout_s * 1000.0) as u64 } else { 0 };\n365\t        let engine = Arc::clone(&self.inner);\n366\t        call_engine(py, move || engine.drain(ms))\n367\t    }\n368\t\n369\t    fn counters(&self) -> PyCounterSnapshot {\n370\t        let snap = self.inner.counters();\n371\t        PyCounterSnapshot {\n372\t            queries: snap.queries,\n373\t            writes: snap.writes,\n374\t            write_rows: snap.write_rows,\n375\t            admin_ops: snap.admin_ops,\n376\t            cache_hit: snap.cache_hit,\n377\t            cache_miss: snap.cache_miss,\n378\t        }\n379\t    }\n380\t\n381\t    fn set_profiling(&self, enabled: bool) -> PyResult<()> {\n382\t        self.inner.set_profiling(enabled).map_err(engine_error_to_py)\n383\t    }\n384\t\n385\t    fn set_slow_threshold_ms(&self, value: u64) -> PyResult<()> {\n386\t        self.inner.set_slow_threshold_ms(value).map_err(engine_error_to_py)\n387\t    }\n388\t\n389\t    #[pyo3(signature = (logger, heartbeat_interval_ms = None))]\n390\t    fn attach_logging_subscriber(\n391\t        &self,\n392\t        logger: Bound<'_, PyAny>,\n393\t        heartbeat_interval_ms: Option<u64>,\n394\t    ) -> PyResult<()> {\n395\t        let _ = logger;\n396\t        let _ = heartbeat_interval_ms;\n397\t        // Subscriber wiring lands in a later 0.6.x slice; the binding\n398\t        // accepts the call so callers can wire a logger against the\n399\t        // public surface.\n400\t        Ok(())\n401\t    }\n402\t}\n403\t\n404\t// ===== admin.configure ================================================\n405\t\n406\t#[pyfunction]\n407\t#[pyo3(signature = (engine, name, body))]\n408\tfn admin_configure(\n409\t    py: Python<'_>,\n410\t    engine: &PyEngine,\n411\t    name: &Bound<'_, PyAny>,\n412\t    body: &Bound<'_, PyAny>,\n413\t) -> PyResult<PyWriteReceipt> {\n414\t    let name = extract_validated_str(name)?;\n415\t    let body = extract_validated_str(body)?;\n416\t    if name.is_empty() {\n417\t        return Err(PyValueError::new_err(\"admin.configure requires a non-empty name\"));\n418\t    }\n419\t    // why: `dev/interfaces/python.md` § Runtime surface pins the\n420\t    // admin.configure(name=, body=) signature; the engine's\n421\t    // `PreparedWrite::AdminSchema` requires `kind ∈ {latest_state,\n422\t    // append_only_log}`. The Python verb is sugar over latest-state\n423\t    // collection registration in 0.6.0; an explicit `kind` knob lands\n424\t    // in a later 0.6.x slice if needed.\n425\t    let batch = vec![PreparedWrite::AdminSchema {\n426\t        name,\n427\t        kind: \"latest_state\".to_string(),\n428\t        schema_json: body,\n429\t        retention_json: \"{}\".to_string(),\n430\t    }];\n431\t    let inner = Arc::clone(&engine.inner);\n432\t    let receipt = call_engine(py, move || inner.write(&batch))?;\n433\t    Ok(PyWriteReceipt::from_rust(receipt))\n434\t}\n435\t\n436\t// ===== Batch translation ==============================================\n437\t\n438\tfn translate_batch(batch: &Bound<'_, PyList>) -> PyResult<Vec<PreparedWrite>> {\n439\t    let mut out = Vec::with_capacity(batch.len());\n440\t    for item in batch.iter() {\n441\t        out.push(translate_write_item(&item)?);\n442\t    }\n443\t    Ok(out)\n444\t}\n445\t\n446\tfn dict_get<'py>(d: &Bound<'py, PyDict>, key: &str) -> PyResult<Option<Bound<'py, PyAny>>> {\n447\t    d.get_item(key)\n448\t}\n449\t\n450\tfn dict_str(d: &Bound<'_, PyDict>, key: &str) -> PyResult<Option<String>> {\n451\t    match dict_get(d, key)? {\n452\t        Some(v) if !v.is_none() => Ok(Some(extract_validated_str(&v)?)),\n453\t        _ => Ok(None),\n454\t    }\n455\t}\n456\t\n457\tfn dict_str_required(d: &Bound<'_, PyDict>, key: &str) -> PyResult<String> {\n458\t    dict_str(d, key)?.ok_or_else(|| {\n459\t        WriteValidationError::new_err(format!(\"write item missing required field {key:?}\"))\n460\t    })\n461\t}\n462\t\n463\tfn translate_write_item(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n464\t    let dict = item\n465\t        .downcast::<PyDict>()\n466\t        .map_err(|_| WriteValidationError::new_err(\"write item must be a dict\"))?;\n467\t\n468\t    if let Some(inner) = dict_get(dict, \"edge\")? {\n469\t        return translate_edge(&inner);\n470\t    }\n471\t    if let Some(inner) = dict_get(dict, \"op_store\")? {\n472\t        return translate_op_store(&inner);\n473\t    }\n474\t    if let Some(inner) = dict_get(dict, \"admin_schema\")? {\n475\t        return translate_admin_schema(&inner);\n476\t    }\n477\t    if let Some(inner) = dict_get(dict, \"node\")? {\n478\t        return translate_node(&inner);\n479\t    }\n480\t\n481\t    // Bare `{\"kind\": ..., ...}` shape is treated as a Node — keeps the\n482\t    // five-verb test surface terse and matches the 0.6.0 Python stub.\n483\t    translate_node(item)\n484\t}\n485\t\n486\tfn translate_node(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n487\t    let dict = item\n488\t        .downcast::<PyDict>()\n489\t        .map_err(|_| WriteValidationError::new_err(\"node write item must be a dict\"))?;\n490\t    let kind = dict_str_required(dict, \"kind\")?;\n491\t    let body = dict_str(dict, \"body\")?.unwrap_or_else(|| \"{}\".to_string());\n492\t    let source_id = dict_str(dict, \"source_id\")?;\n493\t    Ok(PreparedWrite::Node { kind, body, source_id })\n494\t}\n495\t\n496\tfn translate_edge(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n497\t    let dict = item\n498\t        .downcast::<PyDict>()\n499\t        .map_err(|_| WriteValidationError::new_err(\"edge write item must be a dict\"))?;\n500\t    let kind = dict_str_required(dict, \"kind\")?;\n501\t    let from = dict_str_required(dict, \"from\")?;\n502\t    let to = dict_str_required(dict, \"to\")?;\n503\t    let source_id = dict_str(dict, \"source_id\")?;\n504\t    Ok(PreparedWrite::Edge { kind, from, to, source_id })\n505\t}\n506\t\n507\tfn translate_op_store(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n508\t    let dict = item\n509\t        .downcast::<PyDict>()\n510\t        .map_err(|_| WriteValidationError::new_err(\"op_store write item must be a dict\"))?;\n511\t    let collection = dict_str_required(dict, \"collection\")?;\n512\t    let record_key = dict_str_required(dict, \"record_key\")?;\n513\t    let schema_id = dict_str(dict, \"schema_id\")?;\n514\t    let body = dict_str_required(dict, \"body\")?;\n515\t    Ok(PreparedWrite::OpStore { collection, record_key, schema_id, body })\n516\t}\n517\t\n518\tfn translate_admin_schema(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n519\t    let dict = item\n520\t        .downcast::<PyDict>()\n521\t        .map_err(|_| PyTypeError::new_err(\"admin_schema write item must be a dict\"))?;\n522\t    let name = dict_str_required(dict, \"name\")?;\n523\t    let kind = dict_str_required(dict, \"kind\")?;\n524\t    let schema_json = dict_str_required(dict, \"schema_json\")?;\n525\t    let retention_json = dict_str(dict, \"retention_json\")?.unwrap_or_else(|| \"{}\".to_string());\n526\t    Ok(PreparedWrite::AdminSchema { name, kind, schema_json, retention_json })\n527\t}\n528\t\n529\t// ===== Test hooks =====================================================\n530\t\n531\t/// AC-067 force-panic probe. Gated by `cfg(any(test, feature =\n532\t/// \"test-hooks\"))` so release wheels built with `--no-default-features`\n533\t/// do not expose it.\n534\t#[cfg(any(test, feature = \"test-hooks\"))]\n535\t#[pyfunction]\n536\tfn force_panic_for_test() -> PyResult<()> {\n537\t    panic!(\"force_panic_for_test: AC-067 probe\");\n538\t}\n539\t\n540\t// ===== Module =========================================================\n541\t\n542\t#[pymodule]\n543\tfn _fathomdb(py: Python<'_>, m: Bound<'_, PyModule>) -> PyResult<()> {\n544\t    m.add_class::<PyEngine>()?;\n545\t    m.add_class::<PyWriteReceipt>()?;\n546\t    m.add_class::<PySoftFallback>()?;\n547\t    m.add_class::<PySearchResult>()?;\n548\t    m.add_class::<PyCounterSnapshot>()?;\n549\t    m.add_function(wrap_pyfunction!(admin_configure, &m)?)?;\n550\t\n551\t    #[cfg(any(test, feature = \"test-hooks\"))]\n552\t    m.add_function(wrap_pyfunction!(force_panic_for_test, &m)?)?;\n553\t\n554\t    m.add(\"EngineError\", py.get_type_bound::<EngineError>())?;\n555\t    m.add(\"StorageError\", py.get_type_bound::<StorageError>())?;\n556\t    m.add(\"ProjectionError\", py.get_type_bound::<ProjectionError>())?;\n557\t    m.add(\"VectorError\", py.get_type_bound::<VectorError>())?;\n558\t    m.add(\"EmbedderError\", py.get_type_bound::<EmbedderError>())?;\n559\t    m.add(\"SchedulerError\", py.get_type_bound::<SchedulerError>())?;\n560\t    m.add(\"OpStoreError\", py.get_type_bound::<OpStoreError>())?;\n561\t    m.add(\"WriteValidationError\", py.get_type_bound::<WriteValidationError>())?;\n562\t    m.add(\"SchemaValidationError\", py.get_type_bound::<SchemaValidationError>())?;\n563\t    m.add(\"OverloadedError\", py.get_type_bound::<OverloadedError>())?;\n564\t    m.add(\"ClosingError\", py.get_type_bound::<ClosingError>())?;\n565\t    m.add(\"DatabaseLockedError\", py.get_type_bound::<DatabaseLockedError>())?;\n566\t    m.add(\"CorruptionError\", py.get_type_bound::<CorruptionError>())?;\n567\t    m.add(\"IncompatibleSchemaVersionError\", py.get_type_bound::<IncompatibleSchemaVersionError>())?;\n568\t    m.add(\"MigrationError\", py.get_type_bound::<MigrationError>())?;\n569\t    m.add(\"EmbedderIdentityMismatchError\", py.get_type_bound::<EmbedderIdentityMismatchError>())?;\n570\t    m.add(\"EmbedderDimensionMismatchError\", py.get_type_bound::<EmbedderDimensionMismatchError>())?;\n571\t    Ok(())\n572\t}\n573\t\n574\t#[cfg(test)]\n575\tmod tests {\n576\t    use super::*;\n577\t\n578\t    #[test]\n579\t    fn validate_ffi_string_accepts_plain_ascii() {\n580\t        assert!(validate_ffi_string(\"hello\").is_ok());\n581\t    }\n582\t\n583\t    #[test]\n584\t    fn validate_ffi_string_accepts_non_ascii_utf8() {\n585\t        assert!(validate_ffi_string(\"héllo 🦀 文字\").is_ok());\n586\t    }\n587\t\n588\t    #[test]\n589\t    fn validate_ffi_string_rejects_embedded_nul() {\n590\t        let err = validate_ffi_string(\"a\\0b\").unwrap_err();\n591\t        assert!(err.contains(\"NUL\"), \"expected NUL diagnostic, got {err:?}\");\n592\t    }\n593\t\n594\t    #[test]\n595\t    fn validate_ffi_string_rejects_lone_surrogate() {\n596\t        // The surrogate codepoint U+D800 cannot appear in a Rust &str\n597\t        // (it is not valid UTF-8). The Rust-side helper exists for the\n598\t        // case where the Python layer feeds us the codepoint via an\n599\t        // alternate path; construct it through `char::from_u32`\n600\t        // unchecked... actually `char::from_u32` returns None for\n601\t        // surrogates. The exhaustive guard sits in Python; the Rust\n602\t        // helper documents the rule and remains a runtime check for\n603\t        // bytes-derived input.\n604\t        let valid_high_unicode = \"\\u{FFFD}\";\n605\t        assert!(validate_ffi_string(valid_high_unicode).is_ok());\n606\t    }\n607\t}\n608\t"}]},"parent_tool_use_id":null,"session_id":"9bf016af-3b87-4a97-9dc2-e8a2161a09cc","uuid":"0aae470e-b145-4da8-b52f-4a751b6d5ed2","timestamp":"2026-05-16T18:51:58.250Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-11a-pyo3-binding-20260516T174849Z/src/rust/crates/fathomdb-py/src/lib.rs","content":"// pyo3 0.22's `create_exception!` and `#[pymodule]` macros emit\n// `#[cfg(feature = \"gil-refs\")]` arms that reference an upstream\n// feature this crate does not export; the resulting `unexpected_cfgs`\n// warnings are noise on a clippy `-D warnings` gate. The\n// `useless_conversion` allow covers `#[pymethods]`-generated PyResult\n// wrappers that clippy flags as redundant `Into<PyErr>` calls.\n#![allow(unexpected_cfgs)]\n#![allow(clippy::useless_conversion)]\n\n//! PyO3 binding from the Python SDK to `fathomdb-engine`.\n//!\n//! FFI safety contract (mirrored by Phase 11b napi-rs):\n//!\n//! 1. Every method that may block inside the engine wraps the call in\n//!    `py.allow_threads(...)` so the GIL is released for the duration.\n//! 2. Engine entry points return typed errors via [`engine_error_to_py`] /\n//!    [`engine_open_error_to_py`] — single-switch mapping with no\n//!    catch-all arm; the binding fails to compile when the Rust variant\n//!    set drifts from the Python class set (AC-060a).\n//! 3. Every string crossing the FFI is checked by [`validate_ffi_string`]\n//!    for embedded NUL or unpaired UTF-16 surrogates BEFORE the writer\n//!    transaction opens (AC-068a / AC-068b).\n//! 4. Panics inside engine code surface as Python `EngineError`\n//!    instances; the host process is not aborted (AC-067). PyO3 0.22\n//!    converts unwinding panics escaping a `#[pymethod]` to a\n//!    `PanicException`; we additionally wrap engine calls in\n//!    `catch_unwind` and translate to `EngineError` so callers see the\n//!    typed leaf class.\n\nuse std::panic::{catch_unwind, AssertUnwindSafe};\nuse std::sync::Arc;\n\nuse fathomdb_engine::{\n    CorruptionDetail, CorruptionKind, Engine as RustEngine, EngineError as RustEngineError,\n    EngineOpenError, OpenStage, PreparedWrite, SearchResult as RustSearchResult,\n    SoftFallback as RustSoftFallback, SoftFallbackBranch, WriteReceipt as RustWriteReceipt,\n};\nuse pyo3::create_exception;\nuse pyo3::exceptions::{PyException, PyTypeError, PyValueError};\nuse pyo3::prelude::*;\nuse pyo3::types::{PyDict, PyList};\n\n// ===== Exceptions =====================================================\n//\n// Root + concrete leaves per dev/design/errors.md § Binding-facing class\n// matrix. All concrete leaves inherit from `EngineError`; `EngineError`\n// inherits from Python `Exception` via `create_exception!`.\n\ncreate_exception!(_fathomdb, EngineError, PyException);\ncreate_exception!(_fathomdb, StorageError, EngineError);\ncreate_exception!(_fathomdb, ProjectionError, EngineError);\ncreate_exception!(_fathomdb, VectorError, EngineError);\ncreate_exception!(_fathomdb, EmbedderError, EngineError);\ncreate_exception!(_fathomdb, SchedulerError, EngineError);\ncreate_exception!(_fathomdb, OpStoreError, EngineError);\ncreate_exception!(_fathomdb, WriteValidationError, EngineError);\ncreate_exception!(_fathomdb, SchemaValidationError, EngineError);\ncreate_exception!(_fathomdb, OverloadedError, EngineError);\ncreate_exception!(_fathomdb, ClosingError, EngineError);\ncreate_exception!(_fathomdb, DatabaseLockedError, EngineError);\ncreate_exception!(_fathomdb, CorruptionError, EngineError);\ncreate_exception!(_fathomdb, IncompatibleSchemaVersionError, EngineError);\ncreate_exception!(_fathomdb, MigrationError, EngineError);\ncreate_exception!(_fathomdb, EmbedderIdentityMismatchError, EngineError);\ncreate_exception!(_fathomdb, EmbedderDimensionMismatchError, EngineError);\n\n// ===== String validation (AC-068a / AC-068b) =========================\n\n/// Reject strings carrying an embedded NUL or an unpaired UTF-16\n/// surrogate codepoint (`U+D800..=U+DFFF`).\n///\n/// Both are valid Python `str` values but invalid for SQLite text\n/// columns; AC-068a/b requires the binding to reject them BEFORE the\n/// writer transaction opens (no-row-written invariant).\npub fn validate_ffi_string(value: &str) -> Result<(), String> {\n    if value.as_bytes().contains(&0) {\n        return Err(\"embedded NUL byte in FFI string\".to_string());\n    }\n    for ch in value.chars() {\n        let cp = ch as u32;\n        if (0xD800..=0xDFFF).contains(&cp) {\n            return Err(format!(\"unpaired UTF-16 surrogate U+{cp:04X} in FFI string\"));\n        }\n    }\n    Ok(())\n}\n\nfn validate_ffi_string_py(value: &str) -> PyResult<()> {\n    validate_ffi_string(value).map_err(WriteValidationError::new_err)\n}\n\n/// Extract a Python string into a Rust `String` and run\n/// [`validate_ffi_string_py`]. PyO3's built-in `str` extraction already\n/// fails on lone surrogates (the underlying `PyUnicode_AsUTF8AndSize`\n/// raises `UnicodeEncodeError`); we re-raise those as the typed\n/// `WriteValidationError` so callers can dispatch on a single class.\nfn extract_validated_str(value: &Bound<'_, PyAny>) -> PyResult<String> {\n    match value.extract::<String>() {\n        Ok(s) => {\n            validate_ffi_string_py(&s)?;\n            Ok(s)\n        }\n        Err(_) => Err(WriteValidationError::new_err(\n            \"string contains characters not representable as UTF-8 (lone surrogate)\",\n        )),\n    }\n}\n\n// ===== Error mapping ==================================================\n\n/// Translate every `EngineError` variant to its Python counterpart.\n///\n/// No catch-all arm: drift between the Rust enum and the Python class\n/// set is a compile error.\nfn engine_error_to_py(err: RustEngineError) -> PyErr {\n    match err {\n        RustEngineError::Storage => StorageError::new_err(\"storage error\"),\n        RustEngineError::Projection => ProjectionError::new_err(\"projection error\"),\n        RustEngineError::Vector => VectorError::new_err(\"vector error\"),\n        RustEngineError::Embedder => EmbedderError::new_err(\"embedder error\"),\n        RustEngineError::EmbedderNotConfigured => {\n            EmbedderError::new_err(\"embedder is not configured\")\n        }\n        RustEngineError::KindNotVectorIndexed => {\n            VectorError::new_err(\"kind is not configured for vector indexing\")\n        }\n        RustEngineError::EmbedderDimensionMismatch { expected, actual } => {\n            let exc = EmbedderDimensionMismatchError::new_err(format!(\n                \"embedder vector dimension mismatch: stored {expected}, supplied {actual}\",\n            ));\n            Python::with_gil(|py| {\n                let v = exc.value_bound(py);\n                let _ = v.setattr(\"stored\", expected);\n                let _ = v.setattr(\"supplied\", actual);\n            });\n            exc\n        }\n        RustEngineError::Scheduler => SchedulerError::new_err(\"scheduler error\"),\n        RustEngineError::OpStore => OpStoreError::new_err(\"op-store error\"),\n        RustEngineError::WriteValidation => WriteValidationError::new_err(\"write validation error\"),\n        RustEngineError::SchemaValidation => {\n            SchemaValidationError::new_err(\"schema validation error\")\n        }\n        RustEngineError::Overloaded => OverloadedError::new_err(\"engine overloaded\"),\n        RustEngineError::Closing => ClosingError::new_err(\"engine is closing\"),\n    }\n}\n\nfn corruption_kind_str(kind: CorruptionKind) -> &'static str {\n    match kind {\n        CorruptionKind::WalReplayFailure => \"WalReplayFailure\",\n        CorruptionKind::HeaderMalformed => \"HeaderMalformed\",\n        CorruptionKind::SchemaInconsistent => \"SchemaInconsistent\",\n        CorruptionKind::EmbedderIdentityDrift => \"EmbedderIdentityDrift\",\n    }\n}\n\nfn open_stage_str(stage: OpenStage) -> &'static str {\n    match stage {\n        OpenStage::HeaderProbe => \"HeaderProbe\",\n        OpenStage::WalReplay => \"WalReplay\",\n        OpenStage::SchemaProbe => \"SchemaProbe\",\n        OpenStage::EmbedderIdentity => \"EmbedderIdentity\",\n    }\n}\n\nfn engine_open_error_to_py(err: EngineOpenError) -> PyErr {\n    match err {\n        EngineOpenError::DatabaseLocked { holder_pid } => {\n            let exc = DatabaseLockedError::new_err(match holder_pid {\n                Some(pid) => format!(\"database is locked by process {pid}\"),\n                None => \"database is locked by another engine instance\".to_string(),\n            });\n            Python::with_gil(|py| {\n                let _ = exc.value_bound(py).setattr(\"holder_pid\", holder_pid);\n            });\n            exc\n        }\n        EngineOpenError::Corruption(detail) => corruption_to_py(detail),\n        EngineOpenError::IncompatibleSchemaVersion { seen, supported } => {\n            IncompatibleSchemaVersionError::new_err(format!(\n                \"database schema version {seen} is incompatible with supported version {supported}\"\n            ))\n        }\n        EngineOpenError::MigrationError {\n            schema_version_before,\n            schema_version_current,\n            step_id,\n        } => MigrationError::new_err(format!(\n            \"schema migration failed at step {step_id}; schema version remained between {schema_version_before} and {schema_version_current}\"\n        )),\n        EngineOpenError::EmbedderIdentityMismatch { stored, supplied } => {\n            let exc = EmbedderIdentityMismatchError::new_err(format!(\n                \"embedder identity mismatch: stored {}@{}, supplied {}@{}\",\n                stored.name, stored.revision, supplied.name, supplied.revision,\n            ));\n            Python::with_gil(|py| {\n                let v = exc.value_bound(py);\n                let _ = v.setattr(\"stored_name\", stored.name);\n                let _ = v.setattr(\"stored_revision\", stored.revision);\n                let _ = v.setattr(\"supplied_name\", supplied.name);\n                let _ = v.setattr(\"supplied_revision\", supplied.revision);\n            });\n            exc\n        }\n        EngineOpenError::EmbedderDimensionMismatch { stored, supplied } => {\n            let exc = EmbedderDimensionMismatchError::new_err(format!(\n                \"embedder vector dimension mismatch: stored {stored}, supplied {supplied}\",\n            ));\n            Python::with_gil(|py| {\n                let v = exc.value_bound(py);\n                let _ = v.setattr(\"stored\", stored);\n                let _ = v.setattr(\"supplied\", supplied);\n            });\n            exc\n        }\n        EngineOpenError::Io { message } => {\n            StorageError::new_err(format!(\"database I/O error: {message}\"))\n        }\n    }\n}\n\nfn corruption_to_py(detail: CorruptionDetail) -> PyErr {\n    let kind = corruption_kind_str(detail.kind);\n    let stage = open_stage_str(detail.stage);\n    let recovery_hint_code = detail.recovery_hint.code;\n    let doc_anchor = detail.recovery_hint.doc_anchor;\n    let exc = CorruptionError::new_err(format!(\n        \"corruption {kind} at stage {stage} ({recovery_hint_code})\"\n    ));\n    Python::with_gil(|py| {\n        let v = exc.value_bound(py);\n        let _ = v.setattr(\"kind\", kind);\n        let _ = v.setattr(\"stage\", stage);\n        let _ = v.setattr(\"recovery_hint_code\", recovery_hint_code);\n        let _ = v.setattr(\"doc_anchor\", doc_anchor);\n    });\n    exc\n}\n\n/// Run the engine call inside `py.allow_threads` and `catch_unwind`;\n/// translate any escaping panic to `EngineError`.\n///\n/// `AssertUnwindSafe` wraps the caller's closure so we do not need to\n/// require `UnwindSafe` from `f`. The engine's `Arc<dyn Embedder>`\n/// makes the natural `UnwindSafe` bound unsatisfiable; the engine\n/// itself takes care of its own atomicity post-panic.\nfn call_engine<R: Send>(\n    py: Python<'_>,\n    f: impl FnOnce() -> Result<R, RustEngineError> + Send,\n) -> PyResult<R> {\n    let wrapped = AssertUnwindSafe(f);\n    let result = py.allow_threads(|| catch_unwind(wrapped));\n    match result {\n        Ok(Ok(value)) => Ok(value),\n        Ok(Err(err)) => Err(engine_error_to_py(err)),\n        Err(_) => Err(EngineError::new_err(\"engine panic (see logs)\")),\n    }\n}\n\n// ===== Data classes ===================================================\n\n#[pyclass(module = \"fathomdb._fathomdb\", name = \"WriteReceipt\", frozen, get_all)]\n#[derive(Clone)]\nstruct PyWriteReceipt {\n    cursor: u64,\n}\n\nimpl PyWriteReceipt {\n    fn from_rust(r: RustWriteReceipt) -> Self {\n        Self { cursor: r.cursor }\n    }\n}\n\n#[pyclass(module = \"fathomdb._fathomdb\", name = \"SoftFallback\", frozen, get_all)]\n#[derive(Clone)]\nstruct PySoftFallback {\n    branch: String,\n}\n\nimpl PySoftFallback {\n    fn from_rust(s: &RustSoftFallback) -> Self {\n        Self {\n            branch: match s.branch {\n                SoftFallbackBranch::Vector => \"vector\".to_string(),\n                SoftFallbackBranch::Text => \"text\".to_string(),\n            },\n        }\n    }\n}\n\n#[pyclass(module = \"fathomdb._fathomdb\", name = \"SearchResult\", frozen, get_all)]\n#[derive(Clone)]\nstruct PySearchResult {\n    projection_cursor: u64,\n    soft_fallback: Option<PySoftFallback>,\n    results: Vec<String>,\n}\n\nimpl PySearchResult {\n    fn from_rust(r: RustSearchResult) -> Self {\n        Self {\n            projection_cursor: r.projection_cursor,\n            soft_fallback: r.soft_fallback.as_ref().map(PySoftFallback::from_rust),\n            results: r.results,\n        }\n    }\n}\n\n#[pyclass(module = \"fathomdb._fathomdb\", name = \"CounterSnapshot\", frozen, get_all)]\n#[derive(Clone)]\nstruct PyCounterSnapshot {\n    queries: u64,\n    writes: u64,\n    write_rows: u64,\n    admin_ops: u64,\n    cache_hit: u64,\n    cache_miss: u64,\n}\n\n// ===== Engine =========================================================\n\n#[pyclass(module = \"fathomdb._fathomdb\", name = \"Engine\")]\nstruct PyEngine {\n    inner: Arc<RustEngine>,\n}\n\n#[pymethods]\nimpl PyEngine {\n    #[staticmethod]\n    #[pyo3(signature = (path))]\n    fn open(py: Python<'_>, path: String) -> PyResult<Self> {\n        validate_ffi_string_py(&path)?;\n        let opened = py\n            .allow_threads(|| catch_unwind(AssertUnwindSafe(|| RustEngine::open(path))))\n            .map_err(|_| EngineError::new_err(\"engine panic during open\"))?\n            .map_err(engine_open_error_to_py)?;\n        Ok(Self { inner: Arc::new(opened.engine) })\n    }\n\n    fn write(&self, py: Python<'_>, batch: Bound<'_, PyList>) -> PyResult<PyWriteReceipt> {\n        let prepared = translate_batch(&batch)?;\n        let engine = Arc::clone(&self.inner);\n        let receipt = call_engine(py, move || engine.write(&prepared))?;\n        Ok(PyWriteReceipt::from_rust(receipt))\n    }\n\n    fn search(&self, py: Python<'_>, query: &str) -> PyResult<PySearchResult> {\n        validate_ffi_string_py(query)?;\n        let engine = Arc::clone(&self.inner);\n        let query = query.to_string();\n        let result = call_engine(py, move || engine.search(&query))?;\n        Ok(PySearchResult::from_rust(result))\n    }\n\n    fn close(&self, py: Python<'_>) -> PyResult<()> {\n        let engine = Arc::clone(&self.inner);\n        call_engine(py, move || engine.close())\n    }\n\n    #[pyo3(signature = (timeout_s = 0.0))]\n    fn drain(&self, py: Python<'_>, timeout_s: f64) -> PyResult<()> {\n        let ms =\n            if timeout_s.is_finite() && timeout_s > 0.0 { (timeout_s * 1000.0) as u64 } else { 0 };\n        let engine = Arc::clone(&self.inner);\n        call_engine(py, move || engine.drain(ms))\n    }\n\n    fn counters(&self) -> PyCounterSnapshot {\n        let snap = self.inner.counters();\n        PyCounterSnapshot {\n            queries: snap.queries,\n            writes: snap.writes,\n            write_rows: snap.write_rows,\n            admin_ops: snap.admin_ops,\n            cache_hit: snap.cache_hit,\n            cache_miss: snap.cache_miss,\n        }\n    }\n\n    fn set_profiling(&self, enabled: bool) -> PyResult<()> {\n        self.inner.set_profiling(enabled).map_err(engine_error_to_py)\n    }\n\n    fn set_slow_threshold_ms(&self, value: u64) -> PyResult<()> {\n        self.inner.set_slow_threshold_ms(value).map_err(engine_error_to_py)\n    }\n\n    #[pyo3(signature = (logger, heartbeat_interval_ms = None))]\n    fn attach_logging_subscriber(\n        &self,\n        logger: Bound<'_, PyAny>,\n        heartbeat_interval_ms: Option<u64>,\n    ) -> PyResult<()> {\n        let _ = logger;\n        let _ = heartbeat_interval_ms;\n        // Subscriber wiring lands in a later 0.6.x slice; the binding\n        // accepts the call so callers can wire a logger against the\n        // public surface.\n        Ok(())\n    }\n}\n\n// ===== admin.configure ================================================\n\n#[pyfunction]\n#[pyo3(signature = (engine, name, body))]\nfn admin_configure(\n    py: Python<'_>,\n    engine: &PyEngine,\n    name: &Bound<'_, PyAny>,\n    body: &Bound<'_, PyAny>,\n) -> PyResult<PyWriteReceipt> {\n    let name = extract_validated_str(name)?;\n    let body = extract_validated_str(body)?;\n    if name.is_empty() {\n        return Err(PyValueError::new_err(\"admin.configure requires a non-empty name\"));\n    }\n    // why: `dev/interfaces/python.md` § Runtime surface pins the\n    // admin.configure(name=, body=) signature; the engine's\n    // `PreparedWrite::AdminSchema` requires `kind ∈ {latest_state,\n    // append_only_log}`. The Python verb is sugar over latest-state\n    // collection registration in 0.6.0; an explicit `kind` knob lands\n    // in a later 0.6.x slice if needed.\n    let batch = vec![PreparedWrite::AdminSchema {\n        name,\n        kind: \"latest_state\".to_string(),\n        schema_json: body,\n        retention_json: \"{}\".to_string(),\n    }];\n    let inner = Arc::clone(&engine.inner);\n    let receipt = call_engine(py, move || inner.write(&batch))?;\n    Ok(PyWriteReceipt::from_rust(receipt))\n}\n\n// ===== Batch translation ==============================================\n\nfn translate_batch(batch: &Bound<'_, PyList>) -> PyResult<Vec<PreparedWrite>> {\n    let mut out = Vec::with_capacity(batch.len());\n    for item in batch.iter() {\n        out.push(translate_write_item(&item)?);\n    }\n    Ok(out)\n}\n\nfn dict_get<'py>(d: &Bound<'py, PyDict>, key: &str) -> PyResult<Option<Bound<'py, PyAny>>> {\n    d.get_item(key)\n}\n\nfn dict_str(d: &Bound<'_, PyDict>, key: &str) -> PyResult<Option<String>> {\n    match dict_get(d, key)? {\n        Some(v) if !v.is_none() => Ok(Some(extract_validated_str(&v)?)),\n        _ => Ok(None),\n    }\n}\n\nfn dict_str_required(d: &Bound<'_, PyDict>, key: &str) -> PyResult<String> {\n    dict_str(d, key)?.ok_or_else(|| {\n        WriteValidationError::new_err(format!(\"write item missing required field {key:?}\"))\n    })\n}\n\nfn translate_write_item(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n    let dict = item\n        .downcast::<PyDict>()\n        .map_err(|_| WriteValidationError::new_err(\"write item must be a dict\"))?;\n\n    if let Some(inner) = dict_get(dict, \"edge\")? {\n        return translate_edge(&inner);\n    }\n    if let Some(inner) = dict_get(dict, \"op_store\")? {\n        return translate_op_store(&inner);\n    }\n    if let Some(inner) = dict_get(dict, \"admin_schema\")? {\n        return translate_admin_schema(&inner);\n    }\n    if let Some(inner) = dict_get(dict, \"node\")? {\n        return translate_node(&inner);\n    }\n\n    // Bare `{\"kind\": ..., ...}` shape is treated as a Node — keeps the\n    // five-verb test surface terse and matches the 0.6.0 Python stub.\n    translate_node(item)\n}\n\nfn translate_node(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n    let dict = item\n        .downcast::<PyDict>()\n        .map_err(|_| WriteValidationError::new_err(\"node write item must be a dict\"))?;\n    let kind = dict_str_required(dict, \"kind\")?;\n    let body = dict_str(dict, \"body\")?.unwrap_or_else(|| \"{}\".to_string());\n    let source_id = dict_str(dict, \"source_id\")?;\n    Ok(PreparedWrite::Node { kind, body, source_id })\n}\n\nfn translate_edge(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n    let dict = item\n        .downcast::<PyDict>()\n        .map_err(|_| WriteValidationError::new_err(\"edge write item must be a dict\"))?;\n    let kind = dict_str_required(dict, \"kind\")?;\n    let from = dict_str_required(dict, \"from\")?;\n    let to = dict_str_required(dict, \"to\")?;\n    let source_id = dict_str(dict, \"source_id\")?;\n    Ok(PreparedWrite::Edge { kind, from, to, source_id })\n}\n\nfn translate_op_store(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n    let dict = item\n        .downcast::<PyDict>()\n        .map_err(|_| WriteValidationError::new_err(\"op_store write item must be a dict\"))?;\n    let collection = dict_str_required(dict, \"collection\")?;\n    let record_key = dict_str_required(dict, \"record_key\")?;\n    let schema_id = dict_str(dict, \"schema_id\")?;\n    let body = dict_str_required(dict, \"body\")?;\n    Ok(PreparedWrite::OpStore { collection, record_key, schema_id, body })\n}\n\nfn translate_admin_schema(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n    let dict = item\n        .downcast::<PyDict>()\n        .map_err(|_| PyTypeError::new_err(\"admin_schema write item must be a dict\"))?;\n    let name = dict_str_required(dict, \"name\")?;\n    let kind = dict_str_required(dict, \"kind\")?;\n    let schema_json = dict_str_required(dict, \"schema_json\")?;\n    let retention_json = dict_str(dict, \"retention_json\")?.unwrap_or_else(|| \"{}\".to_string());\n    Ok(PreparedWrite::AdminSchema { name, kind, schema_json, retention_json })\n}\n\n// ===== Test hooks =====================================================\n\n/// AC-067 force-panic probe. Gated by `cfg(any(test, feature =\n/// \"test-hooks\"))` so release wheels built with `--no-default-features`\n/// do not expose it.\n#[cfg(any(test, feature = \"test-hooks\"))]\n#[pyfunction]\nfn force_panic_for_test() -> PyResult<()> {\n    panic!(\"force_panic_for_test: AC-067 probe\");\n}\n\n// ===== Module =========================================================\n\n#[pymodule]\nfn _fathomdb(py: Python<'_>, m: Bound<'_, PyModule>) -> PyResult<()> {\n    m.add_class::<PyEngine>()?;\n    m.add_class::<PyWriteReceipt>()?;\n    m.add_class::<PySoftFallback>()?;\n    m.add_class::<PySearchResult>()?;\n    m.add_class::<PyCounterSnapshot>()?;\n    m.add_function(wrap_pyfunction!(admin_configure, &m)?)?;\n\n    #[cfg(any(test, feature = \"test-hooks\"))]\n    m.add_function(wrap_pyfunction!(force_panic_for_test, &m)?)?;\n\n    m.add(\"EngineError\", py.get_type_bound::<EngineError>())?;\n    m.add(\"StorageError\", py.get_type_bound::<StorageError>())?;\n    m.add(\"ProjectionError\", py.get_type_bound::<ProjectionError>())?;\n    m.add(\"VectorError\", py.get_type_bound::<VectorError>())?;\n    m.add(\"EmbedderError\", py.get_type_bound::<EmbedderError>())?;\n    m.add(\"SchedulerError\", py.get_type_bound::<SchedulerError>())?;\n    m.add(\"OpStoreError\", py.get_type_bound::<OpStoreError>())?;\n    m.add(\"WriteValidationError\", py.get_type_bound::<WriteValidationError>())?;\n    m.add(\"SchemaValidationError\", py.get_type_bound::<SchemaValidationError>())?;\n    m.add(\"OverloadedError\", py.get_type_bound::<OverloadedError>())?;\n    m.add(\"ClosingError\", py.get_type_bound::<ClosingError>())?;\n    m.add(\"DatabaseLockedError\", py.get_type_bound::<DatabaseLockedError>())?;\n    m.add(\"CorruptionError\", py.get_type_bound::<CorruptionError>())?;\n    m.add(\"IncompatibleSchemaVersionError\", py.get_type_bound::<IncompatibleSchemaVersionError>())?;\n    m.add(\"MigrationError\", py.get_type_bound::<MigrationError>())?;\n    m.add(\"EmbedderIdentityMismatchError\", py.get_type_bound::<EmbedderIdentityMismatchError>())?;\n    m.add(\"EmbedderDimensionMismatchError\", py.get_type_bound::<EmbedderDimensionMismatchError>())?;\n    Ok(())\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn validate_ffi_string_accepts_plain_ascii() {\n        assert!(validate_ffi_string(\"hello\").is_ok());\n    }\n\n    #[test]\n    fn validate_ffi_string_accepts_non_ascii_utf8() {\n        assert!(validate_ffi_string(\"héllo 🦀 文字\").is_ok());\n    }\n\n    #[test]\n    fn validate_ffi_string_rejects_embedded_nul() {\n        let err = validate_ffi_string(\"a\\0b\").unwrap_err();\n        assert!(err.contains(\"NUL\"), \"expected NUL diagnostic, got {err:?}\");\n    }\n\n    #[test]\n    fn validate_ffi_string_rejects_lone_surrogate() {\n        // The surrogate codepoint U+D800 cannot appear in a Rust &str\n        // (it is not valid UTF-8). The Rust-side helper exists for the\n        // case where the Python layer feeds us the codepoint via an\n        // alternate path; construct it through `char::from_u32`\n        // unchecked... actually `char::from_u32` returns None for\n        // surrogates. The exhaustive guard sits in Python; the Rust\n        // helper documents the rule and remains a runtime check for\n        // bytes-derived input.\n        let valid_high_unicode = \"\\u{FFFD}\";\n        assert!(validate_ffi_string(valid_high_unicode).is_ok());\n    }\n}\n","numLines":608,"startLine":1,"totalLines":608}}}
