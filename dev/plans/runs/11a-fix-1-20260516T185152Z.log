{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NYv8wCqzYyxK5n2LZBkexV","type":"tool_result","content":"1\t\"\"\"FFI safety-contract tests for the PyO3 binding.\n2\t\n3\tCovers AC-067 (panic catch), AC-068a (embedded NUL rejected), and\n4\tAC-068b (unpaired UTF-16 surrogate rejected). The contract is locked\n5\there for Python and mirrored by the napi-rs binding in Phase 11b.\n6\t\"\"\"\n7\t\n8\tfrom __future__ import annotations\n9\t\n10\timport os\n11\t\n12\timport pytest\n13\t\n14\tfrom fathomdb import Engine, admin\n15\tfrom fathomdb._fathomdb import force_panic_for_test\n16\tfrom fathomdb.errors import EngineError, WriteValidationError\n17\t\n18\t\n19\tdef test_panic_surfaces_as_python_exception(db_path: str) -> None:\n20\t    \"\"\"AC-067 — engine panics must not abort the host process.\"\"\"\n21\t\n22\t    pid_before = os.getpid()\n23\t    with pytest.raises(BaseException):\n24\t        force_panic_for_test()\n25\t    pid_after = os.getpid()\n26\t    assert pid_before == pid_after, \"host process must not be aborted by engine panic\"\n27\t\n28\t    # Subsequent engine work must still succeed.\n29\t    engine = Engine.open(db_path)\n30\t    try:\n31\t        snapshot = engine.counters()\n32\t        assert snapshot is not None\n33\t    finally:\n34\t        engine.close()\n35\t\n36\t\n37\tdef test_embedded_nul_in_body_rejected_before_write(db_path: str) -> None:\n38\t    \"\"\"AC-068a — embedded NUL in any FFI string raises\n39\t    WriteValidationError, and no row is written.\"\"\"\n40\t\n41\t    engine = Engine.open(db_path)\n42\t    try:\n43\t        # Register a latest-state collection so the body would otherwise\n44\t        # commit a row.\n45\t        admin.configure(engine, name=\"nul_col\", body=\"{}\")\n46\t        before = engine._native.counters().write_rows\n47\t\n48\t        with pytest.raises(WriteValidationError) as excinfo:\n49\t            engine.write(\n50\t                [\n51\t                    {\n52\t                        \"op_store\": {\n53\t                            \"collection\": \"nul_col\",\n54\t                            \"record_key\": \"k1\",\n55\t                            \"body\": '{\"x\":\"a\\x00b\"}',\n56\t                        }\n57\t                    }\n58\t                ]\n59\t            )\n60\t        assert isinstance(excinfo.value, EngineError)\n61\t\n62\t        after = engine._native.counters().write_rows\n63\t        assert after == before, \"no row may be written when a NUL is rejected\"\n64\t    finally:\n65\t        engine.close()\n66\t\n67\t\n68\tdef test_unpaired_surrogate_in_body_rejected_before_write(db_path: str) -> None:\n69\t    \"\"\"AC-068b — lone UTF-16 surrogate codepoints raise\n70\t    WriteValidationError, and no row is written.\"\"\"\n71\t\n72\t    engine = Engine.open(db_path)\n73\t    try:\n74\t        admin.configure(engine, name=\"sur_col\", body=\"{}\")\n75\t        before = engine._native.counters().write_rows\n76\t\n77\t        with pytest.raises(WriteValidationError) as excinfo:\n78\t            engine.write(\n79\t                [\n80\t                    {\n81\t                        \"op_store\": {\n82\t                            \"collection\": \"sur_col\",\n83\t                            \"record_key\": \"k1\",\n84\t                            \"body\": '{\"x\":\"a\\ud800b\"}',\n85\t                        }\n86\t                    }\n87\t                ]\n88\t            )\n89\t        assert isinstance(excinfo.value, EngineError)\n90\t\n91\t        after = engine._native.counters().write_rows\n92\t        assert after == before, \"no row may be written when a surrogate is rejected\"\n93\t    finally:\n94\t        engine.close()\n95\t\n96\t\n97\tdef test_embedded_nul_in_node_kind_rejected(db_path: str) -> None:\n98\t    \"\"\"AC-068a — applies to every FFI string field, not just bodies.\"\"\"\n99\t\n100\t    engine = Engine.open(db_path)\n101\t    try:\n102\t        with pytest.raises(WriteValidationError):\n103\t            engine.write([{\"kind\": \"do\\x00c\", \"body\": \"{}\"}])\n104\t    finally:\n105\t        engine.close()\n106\t"}]},"parent_tool_use_id":null,"session_id":"9bf016af-3b87-4a97-9dc2-e8a2161a09cc","uuid":"20631098-2c56-4bde-a0b5-a3e3ef950015","timestamp":"2026-05-16T18:52:01.303Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-11a-pyo3-binding-20260516T174849Z/src/python/tests/test_ffi_safety.py","content":"\"\"\"FFI safety-contract tests for the PyO3 binding.\n\nCovers AC-067 (panic catch), AC-068a (embedded NUL rejected), and\nAC-068b (unpaired UTF-16 surrogate rejected). The contract is locked\nhere for Python and mirrored by the napi-rs binding in Phase 11b.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport os\n\nimport pytest\n\nfrom fathomdb import Engine, admin\nfrom fathomdb._fathomdb import force_panic_for_test\nfrom fathomdb.errors import EngineError, WriteValidationError\n\n\ndef test_panic_surfaces_as_python_exception(db_path: str) -> None:\n    \"\"\"AC-067 — engine panics must not abort the host process.\"\"\"\n\n    pid_before = os.getpid()\n    with pytest.raises(BaseException):\n        force_panic_for_test()\n    pid_after = os.getpid()\n    assert pid_before == pid_after, \"host process must not be aborted by engine panic\"\n\n    # Subsequent engine work must still succeed.\n    engine = Engine.open(db_path)\n    try:\n        snapshot = engine.counters()\n        assert snapshot is not None\n    finally:\n        engine.close()\n\n\ndef test_embedded_nul_in_body_rejected_before_write(db_path: str) -> None:\n    \"\"\"AC-068a — embedded NUL in any FFI string raises\n    WriteValidationError, and no row is written.\"\"\"\n\n    engine = Engine.open(db_path)\n    try:\n        # Register a latest-state collection so the body would otherwise\n        # commit a row.\n        admin.configure(engine, name=\"nul_col\", body=\"{}\")\n        before = engine._native.counters().write_rows\n\n        with pytest.raises(WriteValidationError) as excinfo:\n            engine.write(\n                [\n                    {\n                        \"op_store\": {\n                            \"collection\": \"nul_col\",\n                            \"record_key\": \"k1\",\n                            \"body\": '{\"x\":\"a\\x00b\"}',\n                        }\n                    }\n                ]\n            )\n        assert isinstance(excinfo.value, EngineError)\n\n        after = engine._native.counters().write_rows\n        assert after == before, \"no row may be written when a NUL is rejected\"\n    finally:\n        engine.close()\n\n\ndef test_unpaired_surrogate_in_body_rejected_before_write(db_path: str) -> None:\n    \"\"\"AC-068b — lone UTF-16 surrogate codepoints raise\n    WriteValidationError, and no row is written.\"\"\"\n\n    engine = Engine.open(db_path)\n    try:\n        admin.configure(engine, name=\"sur_col\", body=\"{}\")\n        before = engine._native.counters().write_rows\n\n        with pytest.raises(WriteValidationError) as excinfo:\n            engine.write(\n                [\n                    {\n                        \"op_store\": {\n                            \"collection\": \"sur_col\",\n                            \"record_key\": \"k1\",\n                            \"body\": '{\"x\":\"a\\ud800b\"}',\n                        }\n                    }\n                ]\n            )\n        assert isinstance(excinfo.value, EngineError)\n\n        after = engine._native.counters().write_rows\n        assert after == before, \"no row may be written when a surrogate is rejected\"\n    finally:\n        engine.close()\n\n\ndef test_embedded_nul_in_node_kind_rejected(db_path: str) -> None:\n    \"\"\"AC-068a — applies to every FFI string field, not just bodies.\"\"\"\n\n    engine = Engine.open(db_path)\n    try:\n        with pytest.raises(WriteValidationError):\n            engine.write([{\"kind\": \"do\\x00c\", \"body\": \"{}\"}])\n    finally:\n        engine.close()\n","numLines":106,"startLine":1,"totalLines":106}}}
