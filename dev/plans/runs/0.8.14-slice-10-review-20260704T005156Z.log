    let present = [leaf.is_empty(), coverage.is_empty(), graph.is_empty()]
137
        .iter()
138
        .filter(|empty| !**empty)
139
        .count();
140
    assert!(present >= 2, "expected >=2 distinct row_kinds populated, got {present}");
