   300	/// Deterministic varying-vector embedder. Projects an input token's
   301	/// stable hash onto a single coordinate per call so vec0 ANN search
   302	/// returns distinct k=10 neighbors (a constant-vector embedder would
   303	/// collapse all distances to 0). Reproducible byte-for-byte across runs.
   304	#[derive(Clone, Debug)]
   305	struct VaryingEmbedder {
   306	    identity: EmbedderIdentity,
   307	    dim: u32,
   308	}
   309	
   310	impl VaryingEmbedder {
   311	    fn new(dim: u32) -> Self {
   312	        Self { identity: EmbedderIdentity::new("varying", "perf-gates", dim), dim }
   313	    }
   314	
   315	    fn vector_for(&self, text: &str) -> Vector {
   316	        let dim = self.dim as usize;
   317	        let mut v = vec![0.0_f32; dim];
   318	        // FNV-1a 64-bit on the input; spread across coordinates with
   319	        // deterministic small magnitudes so distance is meaningful.
   320	        let mut h: u64 = 0xcbf29ce484222325;
   321	        for &b in text.as_bytes() {
   322	            h ^= b as u64;
   323	            h = h.wrapping_mul(0x100000001b3);
   324	        }
   325	        // Place mass on a small handful of coordinates derived from h.
   326	        for k in 0..6 {
   327	            let coord = ((h >> (k * 8)) as usize) % dim;
   328	            let sign = if (h >> (k * 8 + 7)) & 1 == 0 { 1.0 } else { -1.0 };
   329	            v[coord] += sign * 0.5_f32;
   330	        }
   331	        // Normalize-ish so all vectors have similar magnitude.
   332	        let norm: f32 = v.iter().map(|x| x * x).sum::<f32>().sqrt().max(1e-6);
   333	        for x in &mut v {
   334	            *x /= norm;
   335	        }
   336	        v
   337	    }
   338	}
   339	
   340	impl Embedder for VaryingEmbedder {
   341	    fn identity(&self) -> EmbedderIdentity {
   342	        self.identity.clone()
   343	    }
   344	
   345	    fn embed(&self, text: &str) -> Result<Vector, EmbedderError> {
   346	        Ok(self.vector_for(text))
   347	    }
   348	}
