   350	/// AC-013 deterministic seeder: N vector rows with varying embeddings.
   351	/// Returns elapsed seed time. Bodies double as both FTS5 documents and
   352	/// the input to the embedder, so the same fixture supports AC-019's
   353	/// FTS+vector mixed workload.
   354	fn seed_ac013_corpus(engine: &Engine, n: usize) -> Duration {
   355	    const BATCH: usize = 1024;
   356	    let vocab = perf_vocab();
   357	    let cumulative = zipf_cumulative(vocab.len());
   358	    let mut rng = SeededRng::new(0x0AC0_13D0_13D0);
   359	    engine.configure_vector_kind_for_test("doc").expect("vector kind");
   360	    let started = Instant::now();
   361	    let mut written = 0usize;
   362	    while written < n {
   363	        let take = BATCH.min(n - written);
   364	        let mut batch = Vec::with_capacity(take);
   365	        for _ in 0..take {
   366	            batch.push(PreparedWrite::Node {
   367	                kind: "doc".to_string(),
   368	                body: synth_chunk_body(&mut rng, &vocab, &cumulative),
   369	                source_id: None,
   370	            });
   371	        }
   372	        engine.write(&batch).expect("ac-013 seed write");
   373	        written += take;
   374	    }
   375	    engine.drain(1_800_000).expect("ac-013 drain");
   376	    started.elapsed()
   377	}
   378	
   379	/// Build a held-out reproducible query set drawn from the same
   380	/// distribution as the indexed corpus (ADR-0.6.0-retrieval-latency-gates
   381	/// "Query vectors drawn from a held-out slice of the same distribution").
   382	fn ac013_query_bodies(count: usize) -> Vec<String> {
   383	    let vocab = perf_vocab();
   384	    let cumulative = zipf_cumulative(vocab.len());
   385	    // Use a different seed than the corpus so the query set is held out
   386	    // (not byte-equal to seeded chunks but drawn from same distribution).
   387	    let mut rng = SeededRng::new(0x0AC0_130D_EC0D_E000);
   388	    (0..count).map(|_| synth_chunk_body(&mut rng, &vocab, &cumulative)).collect()
   389	}
   390	
   391	/// Bounded-size histogram for AC-019 tail-latency capture. Single
   392	/// power-of-two bucketing in microseconds; avoids unbounded
   393	/// `Vec<Duration>` per the Pack D plan (`Histogram::record` style).
   394	struct LatencyHistogram {
   395	    /// Bucket i spans [2^i us, 2^(i+1) us). 32 buckets covers 1 us .. ~71 minutes.
   396	    buckets: [u64; 32],
   397	    count: u64,
   398	}
   399	
   400	impl LatencyHistogram {
   401	    fn new() -> Self {
   402	        Self { buckets: [0; 32], count: 0 }
   403	    }
   404	
   405	    fn record(&mut self, d: Duration) {
   406	        let us = d.as_micros().max(1) as u64;
   407	        let bucket = (63 - us.leading_zeros()) as usize;
   408	        let bucket = bucket.min(self.buckets.len() - 1);
   409	        self.buckets[bucket] += 1;
   410	        self.count += 1;
   411	    }
   412	
   413	    fn merge(&mut self, other: &LatencyHistogram) {
   414	        for i in 0..self.buckets.len() {
   415	            self.buckets[i] += other.buckets[i];
   416	        }
   417	        self.count += other.count;
   418	    }
   419	
   420	    /// Return the upper bound of the bucket containing the requested
   421	    /// percentile (numerator/denominator). Conservative ceiling.
   422	    fn percentile_ceil(&self, numerator: u64, denominator: u64) -> Duration {
   423	        if self.count == 0 {
   424	            return Duration::ZERO;
   425	        }
   426	        let target = (self.count * numerator).div_ceil(denominator);
   427	        let mut acc: u64 = 0;
   428	        for (i, count) in self.buckets.iter().enumerate() {
   429	            acc += count;
   430	            if acc >= target {
   431	                let upper_us = 1u64 << (i + 1);
   432	                return Duration::from_micros(upper_us);
   433	            }
   434	        }
   435	        let i = self.buckets.len() - 1;
   436	        Duration::from_micros(1u64 << (i + 1))
   437	    }
   438	}
