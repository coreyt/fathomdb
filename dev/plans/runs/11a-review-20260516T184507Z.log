     1	"""FFI safety-contract tests for the PyO3 binding.
     2	
     3	Covers AC-067 (panic catch), AC-068a (embedded NUL rejected), and
     4	AC-068b (unpaired UTF-16 surrogate rejected). The contract is locked
     5	here for Python and mirrored by the napi-rs binding in Phase 11b.
     6	"""
     7	
     8	from __future__ import annotations
     9	
    10	import os
    11	
    12	import pytest
    13	
    14	from fathomdb import Engine, admin
    15	from fathomdb._fathomdb import force_panic_for_test
    16	from fathomdb.errors import EngineError, WriteValidationError
    17	
    18	
    19	def test_panic_surfaces_as_python_exception(db_path: str) -> None:
    20	    """AC-067 — engine panics must not abort the host process."""
    21	
    22	    pid_before = os.getpid()
    23	    with pytest.raises(BaseException):
    24	        force_panic_for_test()
    25	    pid_after = os.getpid()
    26	    assert pid_before == pid_after, "host process must not be aborted by engine panic"
    27	
    28	    # Subsequent engine work must still succeed.
    29	    engine = Engine.open(db_path)
    30	    try:
    31	        snapshot = engine.counters()
    32	        assert snapshot is not None
    33	    finally:
    34	        engine.close()
    35	
    36	
    37	def test_embedded_nul_in_body_rejected_before_write(db_path: str) -> None:
    38	    """AC-068a — embedded NUL in any FFI string raises
    39	    WriteValidationError, and no row is written."""
    40	
    41	    engine = Engine.open(db_path)
    42	    try:
    43	        # Register a latest-state collection so the body would otherwise
    44	        # commit a row.
    45	        admin.configure(engine, name="nul_col", body="{}")
    46	        before = engine._native.counters().write_rows
    47	
    48	        with pytest.raises(WriteValidationError) as excinfo:
    49	            engine.write(
    50	                [
    51	                    {
    52	                        "op_store": {
    53	                            "collection": "nul_col",
    54	                            "record_key": "k1",
    55	                            "body": '{"x":"a\x00b"}',
    56	                        }
    57	                    }
    58	                ]
    59	            )
    60	        assert isinstance(excinfo.value, EngineError)
    61	
    62	        after = engine._native.counters().write_rows
    63	        assert after == before, "no row may be written when a NUL is rejected"
    64	    finally:
    65	        engine.close()
    66	
    67	
    68	def test_unpaired_surrogate_in_body_rejected_before_write(db_path: str) -> None:
    69	    """AC-068b — lone UTF-16 surrogate codepoints raise
    70	    WriteValidationError, and no row is written."""
    71	
    72	    engine = Engine.open(db_path)
    73	    try:
    74	        admin.configure(engine, name="sur_col", body="{}")
    75	        before = engine._native.counters().write_rows
    76	
    77	        with pytest.raises(WriteValidationError) as excinfo:
    78	            engine.write(
    79	                [
    80	                    {
    81	                        "op_store": {
    82	                            "collection": "sur_col",
    83	                            "record_key": "k1",
    84	                            "body": '{"x":"a\ud800b"}',
    85	                        }
    86	                    }
    87	                ]
    88	            )
    89	        assert isinstance(excinfo.value, EngineError)
    90	
    91	        after = engine._native.counters().write_rows
    92	        assert after == before, "no row may be written when a surrogate is rejected"
    93	    finally:
    94	        engine.close()
