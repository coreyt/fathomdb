{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Eij6ZNjRPzqPxf4GzDPB3D","type":"tool_result","content":"1\t//! Pack 6 F.0 — thread-affine reader worker pool integration tests.\n2\t//!\n3\t//! Covers the two new acceptance contracts introduced by the refactor:\n4\t//!   1. Shutdown integrity: every reader worker exits on `Engine::close`,\n5\t//!      and every owned read-only `Connection` is dropped.\n6\t//!   2. Routing/concurrency stress: with 8 worker threads and many\n7\t//!      concurrent search callers, every dispatched search is handled\n8\t//!      exactly once — no request is lost or duplicated.\n9\t//!\n10\t//! These tests are deliberately cheap and deterministic. They are not\n11\t//! perf gates; AC-020 in `tests/perf_gates.rs` remains the perf oracle.\n12\t\n13\tuse std::sync::atomic::{AtomicUsize, Ordering};\n14\tuse std::sync::Arc;\n15\tuse std::thread;\n16\tuse std::time::{Duration, Instant};\n17\t\n18\tuse fathomdb_engine::{Engine, PreparedWrite};\n19\tuse fathomdb_schema::SQLITE_SUFFIX;\n20\tuse tempfile::TempDir;\n21\t\n22\tconst READER_POOL_SIZE: usize = 8;\n23\t\n24\tfn fresh_engine(name: &str) -> (TempDir, fathomdb_engine::OpenedEngine) {\n25\t    let dir = TempDir::new().unwrap();\n26\t    let path = dir.path().join(format!(\"{name}{SQLITE_SUFFIX}\"));\n27\t    let opened = Engine::open(path).expect(\"engine open\");\n28\t    (dir, opened)\n29\t}\n30\t\n31\t#[test]\n32\tfn reader_pool_spawns_eight_worker_threads_at_open() {\n33\t    let (_dir, opened) = fresh_engine(\"reader_pool_open\");\n34\t    assert_eq!(opened.engine.reader_worker_count_for_test(), READER_POOL_SIZE);\n35\t    // Workers may take a brief moment to enter their loops on slow CI;\n36\t    // give them a bounded window to publish into the live counter.\n37\t    let deadline = Instant::now() + Duration::from_secs(2);\n38\t    while opened.engine.live_reader_worker_count_for_test() < READER_POOL_SIZE\n39\t        && Instant::now() < deadline\n40\t    {\n41\t        thread::sleep(Duration::from_millis(5));\n42\t    }\n43\t    assert_eq!(opened.engine.live_reader_worker_count_for_test(), READER_POOL_SIZE);\n44\t}\n45\t\n46\t#[test]\n47\tfn reader_workers_exit_on_close_and_drop_connections() {\n48\t    let (_dir, opened) = fresh_engine(\"reader_pool_close\");\n49\t    // Issue at least one search so each worker has serviced traffic.\n50\t    for _ in 0..32 {\n51\t        let _ = opened.engine.search(\"ping\").err();\n52\t    }\n53\t    opened.engine.close().expect(\"close\");\n54\t    // After close, every worker must have returned from its loop and\n55\t    // dropped its owned read-only Connection.\n56\t    let deadline = Instant::now() + Duration::from_secs(2);\n57\t    while opened.engine.live_reader_worker_count_for_test() != 0 && Instant::now() < deadline {\n58\t        thread::sleep(Duration::from_millis(5));\n59\t    }\n60\t    assert_eq!(\n61\t        opened.engine.live_reader_worker_count_for_test(),\n62\t        0,\n63\t        \"reader workers did not exit on close\"\n64\t    );\n65\t    // Subsequent searches must surface a closing error rather than\n66\t    // hanging on a dead worker channel.\n67\t    let err = opened.engine.search(\"ping\").expect_err(\"search after close\");\n68\t    // We don't pin the exact variant: depending on the order of the\n69\t    // `closed` flag and the channel-closed signal, callers may surface\n70\t    // either `Closing` or `Storage`. The contract under test is that\n71\t    // close does not deadlock and search no longer succeeds.\n72\t    let msg = err.to_string();\n73\t    assert!(\n74\t        msg.contains(\"closing\") || msg.contains(\"storage\"),\n75\t        \"unexpected post-close search error: {msg}\"\n76\t    );\n77\t}\n78\t\n79\t#[test]\n80\tfn reader_workers_exit_on_drop_without_explicit_close() {\n81\t    let live = {\n82\t        let (_dir, opened) = fresh_engine(\"reader_pool_drop\");\n83\t        let live = opened.engine.live_reader_worker_count_for_test();\n84\t        // Drop the engine without calling close().\n85\t        drop(opened);\n86\t        live\n87\t    };\n88\t    assert_eq!(live, READER_POOL_SIZE);\n89\t    // We can't read the counter after drop, but the join inside\n90\t    // `ReaderWorkerPool::Drop` is synchronous, so by the time the\n91\t    // closure above returns every worker has exited. The fact that\n92\t    // this test returns at all is the assertion. Use `live` to\n93\t    // suppress unused warnings.\n94\t    assert_eq!(live, READER_POOL_SIZE);\n95\t}\n96\t\n97\t#[test]\n98\tfn concurrent_searches_route_to_workers_without_loss_or_duplication() {\n99\t    let (_dir, opened) = fresh_engine(\"reader_pool_routing\");\n100\t    // Seed one row so non-empty searches succeed deterministically.\n101\t    opened\n102\t        .engine\n103\t        .write(&[PreparedWrite::Node { kind: \"doc\".to_string(), body: \"hello world\".to_string() }])\n104\t        .expect(\"seed write\");\n105\t\n106\t    const CALLERS: usize = 32;\n107\t    const PER_CALLER: usize = 25;\n108\t\n109\t    let engine = Arc::new(opened.engine);\n110\t    let success = Arc::new(AtomicUsize::new(0));\n111\t    let failure = Arc::new(AtomicUsize::new(0));\n112\t\n113\t    let mut handles = Vec::with_capacity(CALLERS);\n114\t    for _ in 0..CALLERS {\n115\t        let engine = Arc::clone(&engine);\n116\t        let success = Arc::clone(&success);\n117\t        let failure = Arc::clone(&failure);\n118\t        handles.push(thread::spawn(move || {\n119\t            for _ in 0..PER_CALLER {\n120\t                match engine.search(\"hello\") {\n121\t                    Ok(_) => {\n122\t                        success.fetch_add(1, Ordering::SeqCst);\n123\t                    }\n124\t                    Err(_) => {\n125\t                        failure.fetch_add(1, Ordering::SeqCst);\n126\t                    }\n127\t                }\n128\t            }\n129\t        }));\n130\t    }\n131\t    for handle in handles {\n132\t        handle.join().expect(\"caller thread\");\n133\t    }\n134\t\n135\t    assert_eq!(failure.load(Ordering::SeqCst), 0, \"no search may fail\");\n136\t    // The strict equality is the duplication check: each\n137\t    // `engine.search` returns at most one response, and the success\n138\t    // counter is incremented exactly once per Ok(_).\n139\t    assert_eq!(success.load(Ordering::SeqCst), CALLERS * PER_CALLER);\n140\t    // All workers must still be live after the storm.\n141\t    assert_eq!(engine.live_reader_worker_count_for_test(), READER_POOL_SIZE);\n142\t}\n143\t\n144\t// -- G.1 lookaside ---------------------------------------------------\n145\t\n146\t#[test]\n147\tfn reader_workers_have_lookaside_configured_with_ok_rc() {\n148\t    let (_dir, opened) = fresh_engine(\"reader_pool_lookaside_rc\");\n149\t    let rcs = opened.engine.reader_lookaside_config_rcs_for_test();\n150\t    assert_eq!(rcs.len(), READER_POOL_SIZE);\n151\t    for (idx, rc) in rcs.iter().enumerate() {\n152\t        assert_eq!(*rc, 0, \"worker {idx} sqlite3_db_config(LOOKASIDE) rc must be SQLITE_OK\");\n153\t    }\n154\t}\n155\t\n156\t#[test]\n157\tfn reader_workers_consume_lookaside_slots_after_warmup_read() {\n158\t    let (_dir, opened) = fresh_engine(\"reader_pool_lookaside_used\");\n159\t\n160\t    // Drive at least one search through every worker so each connection\n161\t    // has prepared/stepped at least one statement.\n162\t    for _ in 0..(READER_POOL_SIZE * 8) {\n163\t        let _ = opened.engine.search(\"warmup\").err();\n164\t    }\n165\t\n166\t    let used = opened.engine.reader_lookaside_used_per_worker_for_test();\n167\t    eprintln!(\"LOOKASIDE_USED_HIWTR_PER_WORKER={used:?}\");\n168\t    assert_eq!(used.len(), READER_POOL_SIZE);\n169\t    for (idx, slots) in used.iter().enumerate() {\n170\t        assert!(\n171\t            *slots > 0,\n172\t            \"worker {idx} SQLITE_DBSTATUS_LOOKASIDE_USED must be >0 after warmup; got {slots}\",\n173\t        );\n174\t    }\n175\t}\n176\t"}]},"parent_tool_use_id":null,"session_id":"485c34a8-dceb-42a9-9d76-fb4335ae2dfc","uuid":"905395c8-6753-4f19-868f-5651d07b3950","timestamp":"2026-05-04T14:46:23.346Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-pack6G-G3_5-20260504T144523Z/src/rust/crates/fathomdb-engine/tests/reader_pool.rs","content":"//! Pack 6 F.0 — thread-affine reader worker pool integration tests.\n//!\n//! Covers the two new acceptance contracts introduced by the refactor:\n//!   1. Shutdown integrity: every reader worker exits on `Engine::close`,\n//!      and every owned read-only `Connection` is dropped.\n//!   2. Routing/concurrency stress: with 8 worker threads and many\n//!      concurrent search callers, every dispatched search is handled\n//!      exactly once — no request is lost or duplicated.\n//!\n//! These tests are deliberately cheap and deterministic. They are not\n//! perf gates; AC-020 in `tests/perf_gates.rs` remains the perf oracle.\n\nuse std::sync::atomic::{AtomicUsize, Ordering};\nuse std::sync::Arc;\nuse std::thread;\nuse std::time::{Duration, Instant};\n\nuse fathomdb_engine::{Engine, PreparedWrite};\nuse fathomdb_schema::SQLITE_SUFFIX;\nuse tempfile::TempDir;\n\nconst READER_POOL_SIZE: usize = 8;\n\nfn fresh_engine(name: &str) -> (TempDir, fathomdb_engine::OpenedEngine) {\n    let dir = TempDir::new().unwrap();\n    let path = dir.path().join(format!(\"{name}{SQLITE_SUFFIX}\"));\n    let opened = Engine::open(path).expect(\"engine open\");\n    (dir, opened)\n}\n\n#[test]\nfn reader_pool_spawns_eight_worker_threads_at_open() {\n    let (_dir, opened) = fresh_engine(\"reader_pool_open\");\n    assert_eq!(opened.engine.reader_worker_count_for_test(), READER_POOL_SIZE);\n    // Workers may take a brief moment to enter their loops on slow CI;\n    // give them a bounded window to publish into the live counter.\n    let deadline = Instant::now() + Duration::from_secs(2);\n    while opened.engine.live_reader_worker_count_for_test() < READER_POOL_SIZE\n        && Instant::now() < deadline\n    {\n        thread::sleep(Duration::from_millis(5));\n    }\n    assert_eq!(opened.engine.live_reader_worker_count_for_test(), READER_POOL_SIZE);\n}\n\n#[test]\nfn reader_workers_exit_on_close_and_drop_connections() {\n    let (_dir, opened) = fresh_engine(\"reader_pool_close\");\n    // Issue at least one search so each worker has serviced traffic.\n    for _ in 0..32 {\n        let _ = opened.engine.search(\"ping\").err();\n    }\n    opened.engine.close().expect(\"close\");\n    // After close, every worker must have returned from its loop and\n    // dropped its owned read-only Connection.\n    let deadline = Instant::now() + Duration::from_secs(2);\n    while opened.engine.live_reader_worker_count_for_test() != 0 && Instant::now() < deadline {\n        thread::sleep(Duration::from_millis(5));\n    }\n    assert_eq!(\n        opened.engine.live_reader_worker_count_for_test(),\n        0,\n        \"reader workers did not exit on close\"\n    );\n    // Subsequent searches must surface a closing error rather than\n    // hanging on a dead worker channel.\n    let err = opened.engine.search(\"ping\").expect_err(\"search after close\");\n    // We don't pin the exact variant: depending on the order of the\n    // `closed` flag and the channel-closed signal, callers may surface\n    // either `Closing` or `Storage`. The contract under test is that\n    // close does not deadlock and search no longer succeeds.\n    let msg = err.to_string();\n    assert!(\n        msg.contains(\"closing\") || msg.contains(\"storage\"),\n        \"unexpected post-close search error: {msg}\"\n    );\n}\n\n#[test]\nfn reader_workers_exit_on_drop_without_explicit_close() {\n    let live = {\n        let (_dir, opened) = fresh_engine(\"reader_pool_drop\");\n        let live = opened.engine.live_reader_worker_count_for_test();\n        // Drop the engine without calling close().\n        drop(opened);\n        live\n    };\n    assert_eq!(live, READER_POOL_SIZE);\n    // We can't read the counter after drop, but the join inside\n    // `ReaderWorkerPool::Drop` is synchronous, so by the time the\n    // closure above returns every worker has exited. The fact that\n    // this test returns at all is the assertion. Use `live` to\n    // suppress unused warnings.\n    assert_eq!(live, READER_POOL_SIZE);\n}\n\n#[test]\nfn concurrent_searches_route_to_workers_without_loss_or_duplication() {\n    let (_dir, opened) = fresh_engine(\"reader_pool_routing\");\n    // Seed one row so non-empty searches succeed deterministically.\n    opened\n        .engine\n        .write(&[PreparedWrite::Node { kind: \"doc\".to_string(), body: \"hello world\".to_string() }])\n        .expect(\"seed write\");\n\n    const CALLERS: usize = 32;\n    const PER_CALLER: usize = 25;\n\n    let engine = Arc::new(opened.engine);\n    let success = Arc::new(AtomicUsize::new(0));\n    let failure = Arc::new(AtomicUsize::new(0));\n\n    let mut handles = Vec::with_capacity(CALLERS);\n    for _ in 0..CALLERS {\n        let engine = Arc::clone(&engine);\n        let success = Arc::clone(&success);\n        let failure = Arc::clone(&failure);\n        handles.push(thread::spawn(move || {\n            for _ in 0..PER_CALLER {\n                match engine.search(\"hello\") {\n                    Ok(_) => {\n                        success.fetch_add(1, Ordering::SeqCst);\n                    }\n                    Err(_) => {\n                        failure.fetch_add(1, Ordering::SeqCst);\n                    }\n                }\n            }\n        }));\n    }\n    for handle in handles {\n        handle.join().expect(\"caller thread\");\n    }\n\n    assert_eq!(failure.load(Ordering::SeqCst), 0, \"no search may fail\");\n    // The strict equality is the duplication check: each\n    // `engine.search` returns at most one response, and the success\n    // counter is incremented exactly once per Ok(_).\n    assert_eq!(success.load(Ordering::SeqCst), CALLERS * PER_CALLER);\n    // All workers must still be live after the storm.\n    assert_eq!(engine.live_reader_worker_count_for_test(), READER_POOL_SIZE);\n}\n\n// -- G.1 lookaside ---------------------------------------------------\n\n#[test]\nfn reader_workers_have_lookaside_configured_with_ok_rc() {\n    let (_dir, opened) = fresh_engine(\"reader_pool_lookaside_rc\");\n    let rcs = opened.engine.reader_lookaside_config_rcs_for_test();\n    assert_eq!(rcs.len(), READER_POOL_SIZE);\n    for (idx, rc) in rcs.iter().enumerate() {\n        assert_eq!(*rc, 0, \"worker {idx} sqlite3_db_config(LOOKASIDE) rc must be SQLITE_OK\");\n    }\n}\n\n#[test]\nfn reader_workers_consume_lookaside_slots_after_warmup_read() {\n    let (_dir, opened) = fresh_engine(\"reader_pool_lookaside_used\");\n\n    // Drive at least one search through every worker so each connection\n    // has prepared/stepped at least one statement.\n    for _ in 0..(READER_POOL_SIZE * 8) {\n        let _ = opened.engine.search(\"warmup\").err();\n    }\n\n    let used = opened.engine.reader_lookaside_used_per_worker_for_test();\n    eprintln!(\"LOOKASIDE_USED_HIWTR_PER_WORKER={used:?}\");\n    assert_eq!(used.len(), READER_POOL_SIZE);\n    for (idx, slots) in used.iter().enumerate() {\n        assert!(\n            *slots > 0,\n            \"worker {idx} SQLITE_DBSTATUS_LOOKASIDE_USED must be >0 after warmup; got {slots}\",\n        );\n    }\n}\n","numLines":176,"startLine":1,"totalLines":176}}}
