{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0132WqUAXeANe3pw9RKmQJpZ","type":"tool_result","content":"200\t\n201\t/// One request handled by exactly one reader worker. The response is\n202\t/// returned through a fresh oneshot channel so requests cannot be\n203\t/// routed to or duplicated across workers.\n204\tenum ReaderRequest {\n205\t    Search {\n206\t        compiled: fathomdb_query::CompiledQuery,\n207\t        query_vector: Option<String>,\n208\t        respond: SyncSender<ReaderResponse>,\n209\t    },\n210\t    Shutdown,\n211\t    /// Pack 6.G G.1 — debug-only request that asks a worker to read its\n212\t    /// own connection's `SQLITE_DBSTATUS_LOOKASIDE_USED` and return the\n213\t    /// high-water mark (`hiwtr` out-param). Used solely by the integration\n214\t    /// test that asserts post-warmup lookaside slots were consumed; not\n215\t    /// on any production path.\n216\t    #[cfg(debug_assertions)]\n217\t    LookasideStatus {\n218\t        respond: SyncSender<i32>,\n219\t    },\n220\t}\n221\t\n222\ttype ReaderResponse = rusqlite::Result<(u64, Option<SoftFallback>, Vec<String>)>;\n223\t\n224\t/// Per-worker outbound channel capacity. Round-robin dispatch keeps\n225\t/// queue depth at ~0 on hot paths; the small slack absorbs jitter\n226\t/// without a runtime mutex.\n227\tconst READER_WORKER_CHANNEL_CAPACITY: usize = 4;\n228\t\n229\timpl ReaderWorkerPool {\n230\t    fn new(connections: Vec<Connection>) -> Self {\n231\t        let live_workers = Arc::new(AtomicUsize::new(0));\n232\t        let mut senders = Vec::with_capacity(connections.len());\n233\t        let mut handles = Vec::with_capacity(connections.len());\n234\t        for (idx, connection) in connections.into_iter().enumerate() {\n235\t            let (tx, rx) = mpsc::sync_channel::<ReaderRequest>(READER_WORKER_CHANNEL_CAPACITY);\n236\t            let live = Arc::clone(&live_workers);\n237\t            let handle = thread::Builder::new()\n238\t                .name(format!(\"fathomdb-reader-{idx}\"))\n239\t                .spawn(move || reader_worker_loop(connection, rx, live))\n240\t                .expect(\"spawn reader worker\");\n241\t            senders.push(tx);\n242\t            handles.push(handle);\n243\t        }\n244\t        Self {\n245\t            senders,\n246\t            handles: Mutex::new(Some(handles)),\n247\t            next: AtomicUsize::new(0),\n248\t            shutdown: AtomicBool::new(false),\n249\t            live_workers,\n250\t        }\n251\t    }\n252\t\n253\t    fn worker_count(&self) -> usize {\n254\t        self.senders.len()\n255\t    }\n256\t\n257\t    fn live_count(&self) -> usize {\n258\t        self.live_workers.load(Ordering::SeqCst)\n259\t    }\n260\t\n261\t    /// Pack 6.G G.1 — broadcast a `LookasideStatus` request to every\n262\t    /// worker (not round-robin) and collect each worker's\n263\t    /// `SQLITE_DBSTATUS_LOOKASIDE_USED`. Used only by the debug\n264\t    /// integration test for post-warmup lookaside-slot consumption.\n265\t    #[cfg(debug_assertions)]\n266\t    fn lookaside_used_per_worker(&self) -> Vec<i32> {\n267\t        let mut results = Vec::with_capacity(self.senders.len());\n268\t        for sender in &self.senders {\n269\t            let (tx, rx) = mpsc::sync_channel::<i32>(1);\n270\t            if sender.send(ReaderRequest::LookasideStatus { respond: tx }).is_ok() {\n271\t                results.push(rx.recv().unwrap_or(-1));\n272\t            } else {\n273\t                results.push(-1);\n274\t            }\n275\t        }\n276\t        results\n277\t    }\n278\t\n279\t    /// Hot path. Lock-free dispatch: `AtomicUsize::fetch_add` selects\n280\t    /// the worker, then a single `SyncSender::send` enqueues the\n281\t    /// request. No global mutex is taken on the request path.\n282\t    fn dispatch(&self, request: ReaderRequest) -> Result<(), ReaderRequest> {\n283\t        if self.shutdown.load(Ordering::Relaxed) {\n284\t            return Err(request);\n285\t        }\n286\t        let n = self.senders.len();\n287\t        if n == 0 {\n288\t            return Err(request);\n289\t        }\n290\t        let idx = self.next.fetch_add(1, Ordering::Relaxed) % n;\n291\t        self.senders[idx].send(request).map_err(|err| err.0)\n292\t    }\n293\t\n294\t    /// Signal every worker to exit and join its thread. Idempotent —\n295\t    /// safe to call from `Engine::close` and again from\n296\t    /// `ReaderWorkerPool::Drop`.\n297\t    fn shutdown(&self) {\n298\t        if self.shutdown.swap(true, Ordering::SeqCst) {\n299\t            return;\n300\t        }\n301\t        for sender in &self.senders {\n302\t            let _ = sender.send(ReaderRequest::Shutdown);\n303\t        }\n304\t        if let Ok(mut slot) = self.handles.lock() {\n305\t            if let Some(handles) = slot.take() {\n306\t                for handle in handles {\n307\t                    let _ = handle.join();\n308\t                }\n309\t            }\n310\t        }\n311\t    }\n312\t}\n313\t\n314\timpl Drop for ReaderWorkerPool {\n315\t    fn drop(&mut self) {\n316\t        self.shutdown();\n317\t    }\n318\t}\n319\t\n320\tfn reader_worker_loop(\n321\t    mut connection: Connection,\n322\t    rx: Receiver<ReaderRequest>,\n323\t    live_workers: Arc<AtomicUsize>,\n324\t) {\n325\t    live_workers.fetch_add(1, Ordering::SeqCst);\n326\t    // Drop guard so the live counter decrements even on panic.\n327\t    struct LiveGuard(Arc<AtomicUsize>);\n328\t    impl Drop for LiveGuard {\n329\t        fn drop(&mut self) {\n330\t            self.0.fetch_sub(1, Ordering::SeqCst);\n331\t        }\n332\t    }\n333\t    let _guard = LiveGuard(live_workers);\n334\t\n335\t    while let Ok(request) = rx.recv() {\n336\t        match request {\n337\t            ReaderRequest::Shutdown => break,\n338\t            ReaderRequest::Search { compiled, query_vector, respond } => {\n339\t                let result = read_search_in_tx(&mut connection, &compiled, query_vector.as_deref());\n340\t                // Receiver may have been dropped if the caller went\n341\t                // away; nothing to do in that case.\n342\t                let _ = respond.send(result);\n343\t            }\n344\t            #[cfg(debug_assertions)]\n345\t            ReaderRequest::LookasideStatus { respond } => {\n346\t                let _ = respond.send(read_lookaside_used_hiwtr(&connection));\n347\t            }\n348\t        }\n349\t    }\n350\t\n351\t    // Per `dev/design/engine.md` § Close path, uninstall the profile\n352\t    // callback before dropping the connection so SQLite cannot fire\n353\t    // one last callback against a `ProfileContext` whose Box is about\n354\t    // to free.\n355\t    uninstall_profile_callback(&connection);\n356\t    drop(connection);\n357\t}\n358\t\n359\timpl ProjectionRuntime {\n360\t    fn new(\n361\t        path: PathBuf,\n362\t        embedder: Option<Arc<dyn Embedder>>,\n363\t        embedder_identity: EmbedderIdentity,\n364\t    ) -> Self {\n365\t        let shared = Arc::new(ProjectionRuntimeShared {\n366\t            path,\n367\t            embedder,\n368\t            embedder_identity,\n369\t            state: Mutex::new(ProjectionRuntimeState::default()),\n370\t            state_cvar: Condvar::new(),\n371\t            queue: Mutex::new(VecDeque::new()),\n372\t            queue_cvar: Condvar::new(),\n373\t            retry_delays_ms: Mutex::new(DEFAULT_PROJECTION_RETRY_DELAYS_MS.to_vec()),\n374\t        });\n375\t\n376\t        let dispatcher_shared = Arc::clone(&shared);\n377\t        let dispatcher = thread::spawn(move || projection_dispatcher_loop(dispatcher_shared));\n378\t\n379\t        let mut workers = Vec::with_capacity(PROJECTION_WORKERS);\n380\t        for _ in 0..PROJECTION_WORKERS {\n381\t            let worker_shared = Arc::clone(&shared);\n382\t            workers.push(thread::spawn(move || projection_worker_loop(worker_shared)));\n383\t        }\n384\t\n385\t        Self { shared, dispatcher: Mutex::new(Some(dispatcher)), workers: Mutex::new(workers) }\n386\t    }\n387\t\n388\t    fn notify_new_work(&self) {\n389\t        if let Ok(mut state) = self.shared.state.lock() {\n390\t            state.pending_scan = true;\n391\t            self.shared.state_cvar.notify_all();\n392\t        }\n393\t    }\n394\t\n395\t    fn set_frozen(&self, frozen: bool) {\n396\t        if let Ok(mut state) = self.shared.state.lock() {\n397\t            state.frozen = frozen;\n398\t            if !frozen {\n399\t                state.pending_scan = true;\n400\t            }\n401\t            self.shared.state_cvar.notify_all();\n402\t        }\n403\t    }\n404\t\n405\t    fn wait_for_idle(&self, timeout_ms: u64) -> bool {\n406\t        let deadline = Instant::now() + Duration::from_millis(timeout_ms);\n407\t        let mut state = match self.shared.state.lock() {\n408\t            Ok(state) => state,\n409\t            Err(_) => return false,\n410\t        };\n411\t        loop {\n412\t            if state.active_jobs == 0 && state.queued_jobs == 0 {\n413\t                drop(state);\n414\t                if !database_has_pending_projection_work(&self.shared.path).unwrap_or(true) {\n415\t                    return true;\n416\t                }\n417\t                state = match self.shared.state.lock() {\n418\t                    Ok(state) => state,\n419\t                    Err(_) => return false,\n420\t                };\n421\t            }\n422\t            let now = Instant::now();\n423\t            if now >= deadline {\n424\t                return false;\n425\t            }\n426\t            let wait = deadline.saturating_duration_since(now);\n427\t            let Ok((next_state, _)) = self.shared.state_cvar.wait_timeout(state, wait) else {\n428\t                return false;\n429\t            };\n430\t            state = next_state;\n431\t        }\n432\t    }\n433\t\n434\t    fn set_retry_delays_for_test(&self, delays_ms: &[u64]) {\n435\t        if let Ok(mut delays) = self.shared.retry_delays_ms.lock() {\n436\t            *delays = delays_ms.to_vec();\n437\t        }\n438\t    }\n439\t\n440\t    fn stop(&self) {\n441\t        if let Ok(mut state) = self.shared.state.lock() {\n442\t            if state.stopping {\n443\t                return;\n444\t            }\n445\t            state.stopping = true;\n446\t            state.pending_scan = false;\n447\t            self.shared.state_cvar.notify_all();\n448\t        }\n449\t        if let Ok(mut queue) = self.shared.queue.lock() {\n450\t            queue.clear();\n451\t            self.shared.queue_cvar.notify_all();\n452\t        }\n453\t\n454\t        if let Ok(mut dispatcher) = self.dispatcher.lock() {\n455\t            if let Some(handle) = dispatcher.take() {\n456\t                let _ = handle.join();\n457\t            }\n458\t        }\n459\t        if let Ok(mut workers) = self.workers.lock() {\n460\t            for handle in workers.drain(..) {\n461\t                let _ = handle.join();\n462\t            }\n463\t        }\n464\t    }\n465\t}\n466\t\n467\t#[derive(Clone, Debug, Eq, PartialEq)]\n468\tpub struct OpenReport {\n469\t    pub schema_version_before: u32,\n470\t    pub schema_version_after: u32,\n471\t    pub migration_steps: Vec<MigrationStepReport>,\n472\t    pub embedder_warmup_ms: u64,\n473\t    pub query_backend: &'static str,\n474\t    pub default_embedder: EmbedderIdentity,\n475\t}\n476\t\n477\t#[derive(Debug)]\n478\tpub struct OpenedEngine {\n479\t    pub engine: Engine,\n480\t    pub report: OpenReport,\n481\t}\n482\t\n483\t#[derive(Clone, Debug, Eq, PartialEq)]\n484\tpub struct WriteReceipt {\n485\t    pub cursor: u64,\n486\t}\n487\t\n488\t/// Soft-fallback signal carried on hybrid `search` results.\n489\t///\n490\t/// Per `dev/design/retrieval.md` § Soft-fallback signal, this record is\n491\t/// present only when one non-essential branch could not contribute. Total\n492\t/// request failure is not expressed via this carrier.\n493\t#[derive(Clone, Debug, Eq, PartialEq)]\n494\tpub struct SoftFallback {\n495\t    pub branch: SoftFallbackBranch,\n496\t}\n497\t\n498\t/// Which retrieval branch could not contribute to a hybrid search.\n499\t///\n500\t/// `Vector` means the vector branch could not contribute; `Text` means the\n501\t/// text branch could not contribute. Owned by `dev/design/retrieval.md`;\n502\t/// the 0.6.0 enum is exactly these two members.\n503\t#[derive(Clone, Copy, Debug, Eq, PartialEq)]\n504\tpub enum SoftFallbackBranch {\n505\t    Vector,\n506\t    Text,\n507\t}\n508\t\n509\t#[derive(Clone, Debug, Eq, PartialEq)]\n510\tpub struct SearchResult {\n511\t    pub projection_cursor: u64,\n512\t    pub soft_fallback: Option<SoftFallback>,\n513\t    pub results: Vec<String>,\n514\t}\n515\t\n516\t#[derive(Clone, Debug, Eq, PartialEq)]\n517\tpub enum PreparedWrite {\n518\t    Node { kind: String, body: String },\n519\t    Edge { kind: String, from: String, to: String },\n520\t    OpStore { collection: String, record_key: String, schema_id: Option<String>, body: String },\n521\t    AdminSchema { name: String, kind: String, schema_json: String, retention_json: String },\n522\t}\n523\t\n524\t/// Snapshot of engine-internal counters returned by [`Engine::counters`].\n525\t///\n526\t/// Public key set is owned by `dev/design/lifecycle.md` § Public key set\n527\t/// and locked by AC-004a. Reading a snapshot is non-perturbing per\n528\t/// AC-004c. The 0.6.0 surface exposes exactly these seven fields.\n529\t#[derive(Clone, Debug, Default, Eq, PartialEq)]\n530\tpub struct CounterSnapshot {\n531\t    pub queries: u64,\n532\t    pub writes: u64,\n533\t    pub write_rows: u64,\n534\t    pub errors_by_code: BTreeMap<String, u64>,\n535\t    pub admin_ops: u64,\n536\t    pub cache_hit: u64,\n537\t    pub cache_miss: u64,\n538\t}\n539\t\n540\tpub use lifecycle::Subscription;\n541\t\n542\t/// Stable corruption-on-open detail carried by\n543\t/// [`EngineOpenError::Corruption`].\n544\t///\n545\t/// Layout owned by `dev/design/errors.md` § Corruption detail owner.\n546\t#[derive(Clone, Debug, Eq, PartialEq)]\n547\tpub struct CorruptionDetail {\n548\t    pub kind: CorruptionKind,\n549\t    pub stage: OpenStage,\n550\t    pub locator: CorruptionLocator,\n551\t    pub recovery_hint: RecoveryHint,\n552\t}\n553\t\n554\t/// Open-path corruption category.\n555\t///\n556\t/// 0.6.0 emits exactly the four members below; per\n557\t/// `dev/design/errors.md` § Engine.open corruption table, doctor-only\n558\t/// finding codes are not represented here.\n559\t#[derive(Clone, Copy, Debug, Eq, PartialEq)]"}]},"parent_tool_use_id":null,"session_id":"485c34a8-dceb-42a9-9d76-fb4335ae2dfc","uuid":"ee69dea9-c873-4faf-a602-b487464a67b3","timestamp":"2026-05-04T14:46:07.738Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-pack6G-G3_5-20260504T144523Z/src/rust/crates/fathomdb-engine/src/lib.rs","content":"\n/// One request handled by exactly one reader worker. The response is\n/// returned through a fresh oneshot channel so requests cannot be\n/// routed to or duplicated across workers.\nenum ReaderRequest {\n    Search {\n        compiled: fathomdb_query::CompiledQuery,\n        query_vector: Option<String>,\n        respond: SyncSender<ReaderResponse>,\n    },\n    Shutdown,\n    /// Pack 6.G G.1 — debug-only request that asks a worker to read its\n    /// own connection's `SQLITE_DBSTATUS_LOOKASIDE_USED` and return the\n    /// high-water mark (`hiwtr` out-param). Used solely by the integration\n    /// test that asserts post-warmup lookaside slots were consumed; not\n    /// on any production path.\n    #[cfg(debug_assertions)]\n    LookasideStatus {\n        respond: SyncSender<i32>,\n    },\n}\n\ntype ReaderResponse = rusqlite::Result<(u64, Option<SoftFallback>, Vec<String>)>;\n\n/// Per-worker outbound channel capacity. Round-robin dispatch keeps\n/// queue depth at ~0 on hot paths; the small slack absorbs jitter\n/// without a runtime mutex.\nconst READER_WORKER_CHANNEL_CAPACITY: usize = 4;\n\nimpl ReaderWorkerPool {\n    fn new(connections: Vec<Connection>) -> Self {\n        let live_workers = Arc::new(AtomicUsize::new(0));\n        let mut senders = Vec::with_capacity(connections.len());\n        let mut handles = Vec::with_capacity(connections.len());\n        for (idx, connection) in connections.into_iter().enumerate() {\n            let (tx, rx) = mpsc::sync_channel::<ReaderRequest>(READER_WORKER_CHANNEL_CAPACITY);\n            let live = Arc::clone(&live_workers);\n            let handle = thread::Builder::new()\n                .name(format!(\"fathomdb-reader-{idx}\"))\n                .spawn(move || reader_worker_loop(connection, rx, live))\n                .expect(\"spawn reader worker\");\n            senders.push(tx);\n            handles.push(handle);\n        }\n        Self {\n            senders,\n            handles: Mutex::new(Some(handles)),\n            next: AtomicUsize::new(0),\n            shutdown: AtomicBool::new(false),\n            live_workers,\n        }\n    }\n\n    fn worker_count(&self) -> usize {\n        self.senders.len()\n    }\n\n    fn live_count(&self) -> usize {\n        self.live_workers.load(Ordering::SeqCst)\n    }\n\n    /// Pack 6.G G.1 — broadcast a `LookasideStatus` request to every\n    /// worker (not round-robin) and collect each worker's\n    /// `SQLITE_DBSTATUS_LOOKASIDE_USED`. Used only by the debug\n    /// integration test for post-warmup lookaside-slot consumption.\n    #[cfg(debug_assertions)]\n    fn lookaside_used_per_worker(&self) -> Vec<i32> {\n        let mut results = Vec::with_capacity(self.senders.len());\n        for sender in &self.senders {\n            let (tx, rx) = mpsc::sync_channel::<i32>(1);\n            if sender.send(ReaderRequest::LookasideStatus { respond: tx }).is_ok() {\n                results.push(rx.recv().unwrap_or(-1));\n            } else {\n                results.push(-1);\n            }\n        }\n        results\n    }\n\n    /// Hot path. Lock-free dispatch: `AtomicUsize::fetch_add` selects\n    /// the worker, then a single `SyncSender::send` enqueues the\n    /// request. No global mutex is taken on the request path.\n    fn dispatch(&self, request: ReaderRequest) -> Result<(), ReaderRequest> {\n        if self.shutdown.load(Ordering::Relaxed) {\n            return Err(request);\n        }\n        let n = self.senders.len();\n        if n == 0 {\n            return Err(request);\n        }\n        let idx = self.next.fetch_add(1, Ordering::Relaxed) % n;\n        self.senders[idx].send(request).map_err(|err| err.0)\n    }\n\n    /// Signal every worker to exit and join its thread. Idempotent —\n    /// safe to call from `Engine::close` and again from\n    /// `ReaderWorkerPool::Drop`.\n    fn shutdown(&self) {\n        if self.shutdown.swap(true, Ordering::SeqCst) {\n            return;\n        }\n        for sender in &self.senders {\n            let _ = sender.send(ReaderRequest::Shutdown);\n        }\n        if let Ok(mut slot) = self.handles.lock() {\n            if let Some(handles) = slot.take() {\n                for handle in handles {\n                    let _ = handle.join();\n                }\n            }\n        }\n    }\n}\n\nimpl Drop for ReaderWorkerPool {\n    fn drop(&mut self) {\n        self.shutdown();\n    }\n}\n\nfn reader_worker_loop(\n    mut connection: Connection,\n    rx: Receiver<ReaderRequest>,\n    live_workers: Arc<AtomicUsize>,\n) {\n    live_workers.fetch_add(1, Ordering::SeqCst);\n    // Drop guard so the live counter decrements even on panic.\n    struct LiveGuard(Arc<AtomicUsize>);\n    impl Drop for LiveGuard {\n        fn drop(&mut self) {\n            self.0.fetch_sub(1, Ordering::SeqCst);\n        }\n    }\n    let _guard = LiveGuard(live_workers);\n\n    while let Ok(request) = rx.recv() {\n        match request {\n            ReaderRequest::Shutdown => break,\n            ReaderRequest::Search { compiled, query_vector, respond } => {\n                let result = read_search_in_tx(&mut connection, &compiled, query_vector.as_deref());\n                // Receiver may have been dropped if the caller went\n                // away; nothing to do in that case.\n                let _ = respond.send(result);\n            }\n            #[cfg(debug_assertions)]\n            ReaderRequest::LookasideStatus { respond } => {\n                let _ = respond.send(read_lookaside_used_hiwtr(&connection));\n            }\n        }\n    }\n\n    // Per `dev/design/engine.md` § Close path, uninstall the profile\n    // callback before dropping the connection so SQLite cannot fire\n    // one last callback against a `ProfileContext` whose Box is about\n    // to free.\n    uninstall_profile_callback(&connection);\n    drop(connection);\n}\n\nimpl ProjectionRuntime {\n    fn new(\n        path: PathBuf,\n        embedder: Option<Arc<dyn Embedder>>,\n        embedder_identity: EmbedderIdentity,\n    ) -> Self {\n        let shared = Arc::new(ProjectionRuntimeShared {\n            path,\n            embedder,\n            embedder_identity,\n            state: Mutex::new(ProjectionRuntimeState::default()),\n            state_cvar: Condvar::new(),\n            queue: Mutex::new(VecDeque::new()),\n            queue_cvar: Condvar::new(),\n            retry_delays_ms: Mutex::new(DEFAULT_PROJECTION_RETRY_DELAYS_MS.to_vec()),\n        });\n\n        let dispatcher_shared = Arc::clone(&shared);\n        let dispatcher = thread::spawn(move || projection_dispatcher_loop(dispatcher_shared));\n\n        let mut workers = Vec::with_capacity(PROJECTION_WORKERS);\n        for _ in 0..PROJECTION_WORKERS {\n            let worker_shared = Arc::clone(&shared);\n            workers.push(thread::spawn(move || projection_worker_loop(worker_shared)));\n        }\n\n        Self { shared, dispatcher: Mutex::new(Some(dispatcher)), workers: Mutex::new(workers) }\n    }\n\n    fn notify_new_work(&self) {\n        if let Ok(mut state) = self.shared.state.lock() {\n            state.pending_scan = true;\n            self.shared.state_cvar.notify_all();\n        }\n    }\n\n    fn set_frozen(&self, frozen: bool) {\n        if let Ok(mut state) = self.shared.state.lock() {\n            state.frozen = frozen;\n            if !frozen {\n                state.pending_scan = true;\n            }\n            self.shared.state_cvar.notify_all();\n        }\n    }\n\n    fn wait_for_idle(&self, timeout_ms: u64) -> bool {\n        let deadline = Instant::now() + Duration::from_millis(timeout_ms);\n        let mut state = match self.shared.state.lock() {\n            Ok(state) => state,\n            Err(_) => return false,\n        };\n        loop {\n            if state.active_jobs == 0 && state.queued_jobs == 0 {\n                drop(state);\n                if !database_has_pending_projection_work(&self.shared.path).unwrap_or(true) {\n                    return true;\n                }\n                state = match self.shared.state.lock() {\n                    Ok(state) => state,\n                    Err(_) => return false,\n                };\n            }\n            let now = Instant::now();\n            if now >= deadline {\n                return false;\n            }\n            let wait = deadline.saturating_duration_since(now);\n            let Ok((next_state, _)) = self.shared.state_cvar.wait_timeout(state, wait) else {\n                return false;\n            };\n            state = next_state;\n        }\n    }\n\n    fn set_retry_delays_for_test(&self, delays_ms: &[u64]) {\n        if let Ok(mut delays) = self.shared.retry_delays_ms.lock() {\n            *delays = delays_ms.to_vec();\n        }\n    }\n\n    fn stop(&self) {\n        if let Ok(mut state) = self.shared.state.lock() {\n            if state.stopping {\n                return;\n            }\n            state.stopping = true;\n            state.pending_scan = false;\n            self.shared.state_cvar.notify_all();\n        }\n        if let Ok(mut queue) = self.shared.queue.lock() {\n            queue.clear();\n            self.shared.queue_cvar.notify_all();\n        }\n\n        if let Ok(mut dispatcher) = self.dispatcher.lock() {\n            if let Some(handle) = dispatcher.take() {\n                let _ = handle.join();\n            }\n        }\n        if let Ok(mut workers) = self.workers.lock() {\n            for handle in workers.drain(..) {\n                let _ = handle.join();\n            }\n        }\n    }\n}\n\n#[derive(Clone, Debug, Eq, PartialEq)]\npub struct OpenReport {\n    pub schema_version_before: u32,\n    pub schema_version_after: u32,\n    pub migration_steps: Vec<MigrationStepReport>,\n    pub embedder_warmup_ms: u64,\n    pub query_backend: &'static str,\n    pub default_embedder: EmbedderIdentity,\n}\n\n#[derive(Debug)]\npub struct OpenedEngine {\n    pub engine: Engine,\n    pub report: OpenReport,\n}\n\n#[derive(Clone, Debug, Eq, PartialEq)]\npub struct WriteReceipt {\n    pub cursor: u64,\n}\n\n/// Soft-fallback signal carried on hybrid `search` results.\n///\n/// Per `dev/design/retrieval.md` § Soft-fallback signal, this record is\n/// present only when one non-essential branch could not contribute. Total\n/// request failure is not expressed via this carrier.\n#[derive(Clone, Debug, Eq, PartialEq)]\npub struct SoftFallback {\n    pub branch: SoftFallbackBranch,\n}\n\n/// Which retrieval branch could not contribute to a hybrid search.\n///\n/// `Vector` means the vector branch could not contribute; `Text` means the\n/// text branch could not contribute. Owned by `dev/design/retrieval.md`;\n/// the 0.6.0 enum is exactly these two members.\n#[derive(Clone, Copy, Debug, Eq, PartialEq)]\npub enum SoftFallbackBranch {\n    Vector,\n    Text,\n}\n\n#[derive(Clone, Debug, Eq, PartialEq)]\npub struct SearchResult {\n    pub projection_cursor: u64,\n    pub soft_fallback: Option<SoftFallback>,\n    pub results: Vec<String>,\n}\n\n#[derive(Clone, Debug, Eq, PartialEq)]\npub enum PreparedWrite {\n    Node { kind: String, body: String },\n    Edge { kind: String, from: String, to: String },\n    OpStore { collection: String, record_key: String, schema_id: Option<String>, body: String },\n    AdminSchema { name: String, kind: String, schema_json: String, retention_json: String },\n}\n\n/// Snapshot of engine-internal counters returned by [`Engine::counters`].\n///\n/// Public key set is owned by `dev/design/lifecycle.md` § Public key set\n/// and locked by AC-004a. Reading a snapshot is non-perturbing per\n/// AC-004c. The 0.6.0 surface exposes exactly these seven fields.\n#[derive(Clone, Debug, Default, Eq, PartialEq)]\npub struct CounterSnapshot {\n    pub queries: u64,\n    pub writes: u64,\n    pub write_rows: u64,\n    pub errors_by_code: BTreeMap<String, u64>,\n    pub admin_ops: u64,\n    pub cache_hit: u64,\n    pub cache_miss: u64,\n}\n\npub use lifecycle::Subscription;\n\n/// Stable corruption-on-open detail carried by\n/// [`EngineOpenError::Corruption`].\n///\n/// Layout owned by `dev/design/errors.md` § Corruption detail owner.\n#[derive(Clone, Debug, Eq, PartialEq)]\npub struct CorruptionDetail {\n    pub kind: CorruptionKind,\n    pub stage: OpenStage,\n    pub locator: CorruptionLocator,\n    pub recovery_hint: RecoveryHint,\n}\n\n/// Open-path corruption category.\n///\n/// 0.6.0 emits exactly the four members below; per\n/// `dev/design/errors.md` § Engine.open corruption table, doctor-only\n/// finding codes are not represented here.\n#[derive(Clone, Copy, Debug, Eq, PartialEq)]","numLines":360,"startLine":200,"totalLines":2793}}}
