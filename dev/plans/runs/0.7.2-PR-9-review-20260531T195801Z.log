    32	const DIM: u32 = 8;
    33	
    34	fn unit_vector(dim: u32) -> Vector {
    35	    let mut v = vec![0.0_f32; dim as usize];
    36	    v[0] = 1.0;
    37	    v
    38	}
    39	
    40	/// Embedder whose `embed()` blocks while `park` is true (simulating a hung
    41	/// forward pass), then returns a valid unit vector once the test releases
    42	/// it. `calls` counts entries so a test can assert the embed was actually
    43	/// attempted. The park loop sleeps in small increments so releasing it is
    44	/// observed promptly.
    45	#[derive(Debug)]
    46	struct ParkingEmbedder {
    47	    identity: EmbedderIdentity,
    48	    park: Arc<AtomicBool>,
    49	    calls: AtomicU64,
    50	}
    51	
    52	impl ParkingEmbedder {
    53	    fn new(park: Arc<AtomicBool>) -> Self {
    54	        Self {
    55	            identity: EmbedderIdentity::new("parking", "rev-a", DIM),
    56	            park,
    57	            calls: AtomicU64::new(0),
    58	        }
    59	    }
    60	}
    61	
    62	impl Embedder for ParkingEmbedder {
    63	    fn identity(&self) -> EmbedderIdentity {
    64	        self.identity.clone()
    65	    }
    66	
    67	    fn embed(&self, _text: &str) -> Result<Vector, EmbedderError> {
    68	        self.calls.fetch_add(1, Ordering::Relaxed);
    69	        // Block while parked, simulating a hung forward pass. The watchdog
    70	        // must abandon this call (finish + discard per Invariant 5); we never
    71	        // abort the thread. The block is bounded (~20s, well above both the
    72	        // lowered watchdog deadline and the test's drain timeout) purely as a
    73	        // safety valve so a regression that removes the watchdog cannot hang
    74	        // the test binary forever on a parked worker — it surfaces as a
    75	        // wedged `drain` (the RED signal) instead.
    76	        let mut waited = Duration::ZERO;
    77	        let cap = Duration::from_secs(20);
    78	        while self.park.load(Ordering::Relaxed) && waited < cap {
    79	            thread::sleep(Duration::from_millis(10));
    80	            waited += Duration::from_millis(10);
    81	        }
    82	        Ok(unit_vector(DIM))
    83	    }
    84	}
    85	
    86	/// Embedder that sleeps a fixed sub-budget delay then returns Ok — models a
