     3	//! The projection pool runs `PROJECTION_WORKERS` (2) workers. The PR-9
     4	//! pre-flight showed that calling the real `CandleBgeEmbedder::embed` (a
     5	//! `BertModel::forward` that is *itself* multi-threaded across all cores)
     6	//! concurrently on the two workers OVERSUBSCRIBES the CPU: two all-core
     7	//! forwards thrash the scheduler/cache and collapse throughput to ~13x
     8	//! slower than running one at a time (≈0.27 vs ≈3.6 docs/s on the dev box).
     9	//! It is not a data race — no wedge/corruption — purely a throughput
    10	//! pathology. The fix is to serialize the embed *call* engine-side while
    11	//! keeping commit/IO parallel across the workers.
    12	//!
    13	//! This test proves serialization mechanically with a fast mock embedder
    14	//! that records the maximum number of `embed()` calls in flight at once.
    15	//!
    16	//! RED (no guard): two workers embed concurrently → max in flight == 2.
    17	//! GREEN (guard):  embeds run one at a time   → max in flight == 1.
    18	
    19	use std::sync::atomic::{AtomicUsize, Ordering};
    20	use std::sync::Arc;
    21	use std::thread;
    22	use std::time::Duration;
    23	
    24	use fathomdb_embedder_api::{Embedder, EmbedderError, EmbedderIdentity, Vector};
    25	use fathomdb_engine::lifecycle::ProjectionStatus;
    26	use fathomdb_engine::{Engine, PreparedWrite};
    27	use fathomdb_schema::SQLITE_SUFFIX;
    28	use tempfile::TempDir;
    29	
    30	const DIM: u32 = 8;
    31	
    32	fn unit_vector() -> Vector {
    33	    let mut v = vec![0.0_f32; DIM as usize];
    34	    v[0] = 1.0;
    35	    v
    36	}
    37	
    38	/// Records peak concurrency of `embed()`. Each call bumps an in-flight
    39	/// counter, holds it for `delay` (so overlapping calls are observable),
    40	/// and updates the shared `max_in_flight` high-water mark.
    41	#[derive(Debug)]
    42	struct ConcurrencyProbeEmbedder {
    43	    identity: EmbedderIdentity,
    44	    in_flight: AtomicUsize,
    45	    max_in_flight: Arc<AtomicUsize>,
    46	    delay: Duration,
    47	}
    48	
    49	impl ConcurrencyProbeEmbedder {
    50	    fn new(max_in_flight: Arc<AtomicUsize>, delay: Duration) -> Self {
    51	        Self {
    52	            identity: EmbedderIdentity::new("probe", "rev-a", DIM),
    53	            in_flight: AtomicUsize::new(0),
    54	            max_in_flight,
    55	            delay,
    56	        }
    57	    }
    58	}
    59	
    60	impl Embedder for ConcurrencyProbeEmbedder {
    61	    fn identity(&self) -> EmbedderIdentity {
    62	        self.identity.clone()
    63	    }
    64	
    65	    fn embed(&self, _text: &str) -> Result<Vector, EmbedderError> {
    66	        let cur = self.in_flight.fetch_add(1, Ordering::SeqCst) + 1;
    67	        self.max_in_flight.fetch_max(cur, Ordering::SeqCst);
    68	        thread::sleep(self.delay);
    69	        self.in_flight.fetch_sub(1, Ordering::SeqCst);
    70	        Ok(unit_vector())
    71	    }
    72	}
    73	
    74	fn fixture_path(name: &str) -> (TempDir, std::path::PathBuf) {
    75	    let dir = TempDir::new().expect("tempdir");
    76	    let path = dir.path().join(format!("{name}{SQLITE_SUFFIX}"));
    77	    (dir, path)
    78	}
    79	
    80	/// Item 1: the production projection path must embed one-at-a-time. With two
    81	/// projection workers and a deliberately-slow embed, an unserialized engine
    82	/// would show two concurrent `embed()` calls; the engine-side guard pins the
    83	/// peak at exactly one.
    84	#[test]
    85	fn embeds_are_serialized_engine_side() {
    86	    let (_dir, path) = fixture_path("pr9_serialize");
    87	    let max_in_flight = Arc::new(AtomicUsize::new(0));
    88	    let embedder =
    89	        Arc::new(ConcurrencyProbeEmbedder::new(max_in_flight.clone(), Duration::from_millis(50)));
    90	    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect("open");
    91	    let engine = opened.engine;
    92	    engine.configure_vector_kind_for_test("doc").expect("vector kind");
    93	
    94	    // A worker grabs a whole PROJECTION_COMMIT_BATCH (16) at once, and the
    95	    // dispatcher enqueues up to PROJECTION_INFLIGHT_LIMIT (32) per scan — so
    96	    // we write > one batch (40 docs) to ensure both workers pick up work and
    97	    // would embed concurrently if the engine permitted it.
    98	    let nodes: Vec<PreparedWrite> = (0..40)
    99	        .map(|i| PreparedWrite::Node {
   100	            kind: "doc".to_string(),
   101	            body: format!("serialize-doc-{i}"),
   102	            source_id: None,
   103	        })
   104	        .collect();
   105	    engine.write(&nodes).expect("write");
   106	    engine.drain(30_000).expect("drain");
   107	    assert_eq!(
   108	        engine.projection_status_for_test("doc").expect("status"),
   109	        ProjectionStatus::UpToDate,
   110	        "all docs must project successfully"
   111	    );
   112	
   113	    let peak = max_in_flight.load(Ordering::SeqCst);
   114	    assert_eq!(
   115	        peak, 1,
   116	        "embeds must run one at a time engine-side (PR-9 oversubscription fix); \
   117	         observed {peak} concurrent embed() calls"
   118	    );
   119	}

