{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019wYEeC1pZtUsuvkjrqeoEC","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t# scripts/tests/test_set_version.sh — coverage for set-version.sh\n3\t# two-axis enforcement per dev/design/release.md § Version axes.\n4\tset -euo pipefail\n5\t\n6\tSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n7\tREPO_ROOT=\"$(cd \"$SCRIPT_DIR/../..\" && pwd)\"\n8\tSV=\"$REPO_ROOT/scripts/set-version.sh\"\n9\t\n10\tCARGO=\"$REPO_ROOT/Cargo.toml\"\n11\tPYPROJ=\"$REPO_ROOT/src/python/pyproject.toml\"\n12\tNPMPKG=\"$REPO_ROOT/src/ts/package.json\"\n13\tEMBAPI=\"$REPO_ROOT/src/rust/crates/fathomdb-embedder-api/Cargo.toml\"\n14\t\n15\tFAILED=0\n16\tTMPDIR_ROOT=\"$(mktemp -d)\"\n17\ttrap 'restore; rm -rf \"$TMPDIR_ROOT\"' EXIT\n18\t\n19\t# Snapshot the four manifests so the test never leaves the tree dirty.\n20\tSNAP=\"$TMPDIR_ROOT/snap\"\n21\tmkdir -p \"$SNAP\"\n22\tcp \"$CARGO\" \"$SNAP/Cargo.toml\"\n23\tcp \"$PYPROJ\" \"$SNAP/pyproject.toml\"\n24\tcp \"$NPMPKG\" \"$SNAP/package.json\"\n25\tcp \"$EMBAPI\" \"$SNAP/embedder-api.toml\"\n26\t\n27\trestore() {\n28\t  cp \"$SNAP/Cargo.toml\" \"$CARGO\" 2>/dev/null || true\n29\t  cp \"$SNAP/pyproject.toml\" \"$PYPROJ\" 2>/dev/null || true\n30\t  cp \"$SNAP/package.json\" \"$NPMPKG\" 2>/dev/null || true\n31\t  cp \"$SNAP/embedder-api.toml\" \"$EMBAPI\" 2>/dev/null || true\n32\t}\n33\t\n34\tpass() { printf 'PASS  %s\\n' \"$1\"; }\n35\tfail() { printf 'FAIL  %s\\n' \"$1\" >&2; FAILED=$((FAILED + 1)); }\n36\t\n37\t# Extract Axis W workspace version from Cargo.toml [workspace.package].\n38\tws_version() {\n39\t  awk '\n40\t    /^\\[workspace\\.package\\]/ { in_block = 1; next }\n41\t    /^\\[/                     { in_block = 0 }\n42\t    in_block && /^version[[:space:]]*=/ {\n43\t      n = split($0, parts, \"\\\"\")\n44\t      if (n >= 3) { print parts[2] }\n45\t      exit\n46\t    }\n47\t  ' \"$CARGO\"\n48\t}\n49\t\n50\t# Extract Axis E embedder-api version from its [package] block.\n51\temb_version() {\n52\t  awk '\n53\t    /^\\[package\\]/ { in_block = 1; next }\n54\t    /^\\[/          { in_block = 0 }\n55\t    in_block && /^version[[:space:]]*=/ {\n56\t      n = split($0, parts, \"\\\"\")\n57\t      if (n >= 3) { print parts[2] }\n58\t      exit\n59\t    }\n60\t  ' \"$EMBAPI\"\n61\t}\n62\t\n63\tpy_version() {\n64\t  awk '\n65\t    /^\\[project\\]/ { in_block = 1; next }\n66\t    /^\\[/          { in_block = 0 }\n67\t    in_block && /^version[[:space:]]*=/ {\n68\t      n = split($0, parts, \"\\\"\")\n69\t      if (n >= 3) { print parts[2] }\n70\t      exit\n71\t    }\n72\t  ' \"$PYPROJ\"\n73\t}\n74\t\n75\tnpm_version() {\n76\t  sed -n 's/.*\"version\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p' \"$NPMPKG\" | head -1\n77\t}\n78\t\n79\t# 1. --check-files clean tree → 0.\n80\trestore\n81\tif \"$SV\" --check-files >/dev/null 2>&1; then\n82\t  pass \"check-files clean tree exits 0\"\n83\telse\n84\t  fail \"check-files clean tree should exit 0\"\n85\tfi\n86\t\n87\t# 2. --workspace 9.9.9 updates all Axis W manifests; Axis E untouched.\n88\trestore\n89\tORIG_EMB=\"$(emb_version)\"\n90\t\"$SV\" --workspace 9.9.9 >/dev/null\n91\tif [ \"$(ws_version)\" = \"9.9.9\" ] && [ \"$(py_version)\" = \"9.9.9\" ] && [ \"$(npm_version)\" = \"9.9.9\" ]; then\n92\t  pass \"workspace 9.9.9 updates Cargo+pyproject+package.json\"\n93\telse\n94\t  fail \"workspace 9.9.9 did not propagate: ws=$(ws_version) py=$(py_version) npm=$(npm_version)\"\n95\tfi\n96\tif [ \"$(emb_version)\" = \"$ORIG_EMB\" ]; then\n97\t  pass \"workspace 9.9.9 leaves Axis E ($ORIG_EMB) untouched\"\n98\telse\n99\t  fail \"workspace 9.9.9 mutated Axis E: $ORIG_EMB → $(emb_version)\"\n100\tfi\n101\tif \"$SV\" --check-files >/dev/null 2>&1; then\n102\t  pass \"check-files clean after --workspace 9.9.9\"\n103\telse\n104\t  fail \"check-files should be clean after --workspace 9.9.9\"\n105\tfi\n106\t\n107\t# 3. --embedder-api 8.8.8 updates only Axis E; Axis W untouched.\n108\trestore\n109\tORIG_WS=\"$(ws_version)\"\n110\tORIG_PY=\"$(py_version)\"\n111\tORIG_NPM=\"$(npm_version)\"\n112\t\"$SV\" --embedder-api 8.8.8 >/dev/null\n113\tif [ \"$(emb_version)\" = \"8.8.8\" ]; then\n114\t  pass \"embedder-api 8.8.8 updates Axis E\"\n115\telse\n116\t  fail \"embedder-api 8.8.8 did not update Axis E: $(emb_version)\"\n117\tfi\n118\tif [ \"$(ws_version)\" = \"$ORIG_WS\" ] && [ \"$(py_version)\" = \"$ORIG_PY\" ] && [ \"$(npm_version)\" = \"$ORIG_NPM\" ]; then\n119\t  pass \"embedder-api 8.8.8 leaves Axis W untouched\"\n120\telse\n121\t  fail \"embedder-api 8.8.8 leaked into Axis W\"\n122\tfi\n123\tif \"$SV\" --check-files >/dev/null 2>&1; then\n124\t  pass \"check-files clean after --embedder-api 8.8.8\"\n125\telse\n126\t  fail \"check-files should be clean after --embedder-api 8.8.8\"\n127\tfi\n128\t\n129\t# Helper: assert that $out (a check-files stderr capture) contains a\n130\t# structured drift line for the given file naming observed/expected.\n131\tassert_drift_line() {\n132\t  local label=\"$1\" out=\"$2\" file_substr=\"$3\" observed=\"$4\" expected=\"$5\"\n133\t  local missing=0\n134\t  printf '%s' \"$out\" | grep -qE \"${file_substr}:[0-9]+:\" || missing=1\n135\t  printf '%s' \"$out\" | grep -qF \"observed \\\"${observed}\\\"\"        || missing=$((missing + 2))\n136\t  printf '%s' \"$out\" | grep -qF \"expected \\\"${expected}\\\"\"        || missing=$((missing + 4))\n137\t  if [ \"$missing\" -eq 0 ]; then\n138\t    pass \"$label\"\n139\t  else\n140\t    fail \"$label (missing bits=$missing); got: $out\"\n141\t  fi\n142\t}\n143\t\n144\t# 4a. Axis W drift on pyproject → structured diagnostic.\n145\trestore\n146\tWS_BEFORE=\"$(ws_version)\"\n147\tsed -i 's/^version = \"[^\"]*\"/version = \"7.7.7\"/' \"$PYPROJ\"\n148\tif out=\"$(\"$SV\" --check-files 2>&1)\"; then\n149\t  fail \"check-files should fail on drifted pyproject\"\n150\telse\n151\t  assert_drift_line \"check-files: pyproject drift structured diagnostic\" \\\n152\t    \"$out\" \"pyproject.toml\" \"7.7.7\" \"$WS_BEFORE\"\n153\tfi\n154\t\n155\t# 4b. Axis W drift on package.json → structured diagnostic.\n156\trestore\n157\tWS_BEFORE=\"$(ws_version)\"\n158\tsed -i 's/\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/\"version\": \"7.7.7\"/' \"$NPMPKG\"\n159\tif out=\"$(\"$SV\" --check-files 2>&1)\"; then\n160\t  fail \"check-files should fail on drifted package.json\"\n161\telse\n162\t  assert_drift_line \"check-files: package.json drift structured diagnostic\" \\\n163\t    \"$out\" \"package.json\" \"7.7.7\" \"$WS_BEFORE\"\n164\tfi\n165\t\n166\t# 5. Idempotent: --workspace <current> twice in a row → no second-pass change.\n167\trestore\n168\tCUR=\"$(ws_version)\"\n169\t\"$SV\" --workspace \"$CUR\" >/dev/null\n170\tHASH1=\"$(sha256sum \"$CARGO\" \"$PYPROJ\" \"$NPMPKG\" | sha256sum)\"\n171\t\"$SV\" --workspace \"$CUR\" >/dev/null\n172\tHASH2=\"$(sha256sum \"$CARGO\" \"$PYPROJ\" \"$NPMPKG\" | sha256sum)\"\n173\tif [ \"$HASH1\" = \"$HASH2\" ]; then\n174\t  pass \"workspace re-run is idempotent (hash stable)\"\n175\telse\n176\t  fail \"workspace re-run mutated content\"\n177\tfi\n178\t\n179\t# 6. Unknown flag → exit 2 with usage on stderr.\n180\trestore\n181\tif out=\"$(\"$SV\" --bogus-flag 2>&1)\"; then\n182\t  fail \"unknown flag should exit non-zero\"\n183\telse\n184\t  rc=$?\n185\t  if [ \"$rc\" -eq 2 ] && printf '%s' \"$out\" | grep -q -i 'usage'; then\n186\t    pass \"unknown flag → exit 2 + usage\"\n187\t  else\n188\t    fail \"unknown flag wrong exit ($rc) or no usage; got: $out\"\n189\t  fi\n190\tfi\n191\t\n192\t# 7. Missing argument to --workspace → exit 2 with usage.\n193\trestore\n194\tif out=\"$(\"$SV\" --workspace 2>&1)\"; then\n195\t  fail \"missing arg should exit non-zero\"\n196\telse\n197\t  rc=$?\n198\t  if [ \"$rc\" -eq 2 ] && printf '%s' \"$out\" | grep -q -i 'usage'; then\n199\t    pass \"missing arg → exit 2 + usage\"\n200\t  else\n201\t    fail \"missing arg wrong exit ($rc) or no usage; got: $out\"\n202\t  fi\n203\tfi\n204\t\n205\t# 8. Drift on Axis E (explicit version replaced with workspace inheritance) → fail.\n206\t# Pattern is version-agnostic so this test survives future Axis-E bumps without\n207\t# editing the sed literal each cut.\n208\trestore\n209\tsed -i -E 's/^version[[:space:]]*=[[:space:]]*\"[^\"]+\"$/version.workspace = true/' \"$EMBAPI\"\n210\tif out=\"$(\"$SV\" --check-files 2>&1)\"; then\n211\t  fail \"check-files should fail when Axis E inherits workspace\"\n212\telse\n213\t  assert_drift_line \"check-files: Axis E inheritance-regression structured diagnostic\" \\\n214\t    \"$out\" \"fathomdb-embedder-api/Cargo.toml\" \\\n215\t    \"version.workspace = true\" \"explicit [package] version\"\n216\tfi\n217\t\n218\t# 9. Drift on a non-embedder-api crate: replace `version.workspace = true`\n219\t#    with an explicit literal version → must be flagged with structured\n220\t#    diagnostic naming the crate manifest, observed=literal line,\n221\t#    expected=version.workspace = true.\n222\trestore\n223\tVICTIM=\"\"\n224\tfor c in \"$REPO_ROOT\"/src/rust/crates/*/Cargo.toml; do\n225\t  case \"$c\" in\n226\t    *fathomdb-embedder-api*) continue ;;\n227\t  esac\n228\t  if grep -q '^version\\.workspace[[:space:]]*=[[:space:]]*true' \"$c\"; then\n229\t    VICTIM=\"$c\"\n230\t    break\n231\t  fi\n232\tdone\n233\tif [ -z \"$VICTIM\" ]; then\n234\t  fail \"test 9 setup: no non-embedder-api crate uses version.workspace=true\"\n235\telse\n236\t  cp \"$VICTIM\" \"$TMPDIR_ROOT/victim.snap\"\n237\t  sed -i 's/^version\\.workspace[[:space:]]*=[[:space:]]*true/version = \"9.9.9\"/' \"$VICTIM\"\n238\t  if out=\"$(\"$SV\" --check-files 2>&1)\"; then\n239\t    cp \"$TMPDIR_ROOT/victim.snap\" \"$VICTIM\"\n240\t    fail \"check-files should fail when a non-embedder-api crate hardcodes version\"\n241\t  else\n242\t    cp \"$TMPDIR_ROOT/victim.snap\" \"$VICTIM\"\n243\t    assert_drift_line \"check-files: non-emb-api crate hardcoded-version structured diagnostic\" \\\n244\t      \"$out\" \"Cargo.toml\" 'version = \"9.9.9\"' \"version.workspace = true\"\n245\t  fi\n246\tfi\n247\t\n248\t# 10. Workspace.dependencies pin drift on an Axis W entry → structured\n249\t#     diagnostic. cargo publish requires every in-workspace dep to carry\n250\t#     a version requirement, and the pin must match the axis.\n251\trestore\n252\tsed -i 's/^fathomdb-engine[[:space:]]*=.*$/fathomdb-engine       = { path = \"src\\/rust\\/crates\\/fathomdb-engine\",       version = \"5.5.5\" }/' \"$CARGO\"\n253\tif out=\"$(\"$SV\" --check-files 2>&1)\"; then\n254\t  fail \"check-files should fail on drifted workspace.dependencies pin\"\n255\telse\n256\t  assert_drift_line \"check-files: workspace.dependencies pin drift structured diagnostic\" \\\n257\t    \"$out\" \"Cargo.toml\" \"5.5.5\" \"$(ws_version)\"\n258\tfi\n259\t\n260\t# 11. --embedder-api updates the workspace.dependencies pin for\n261\t#     fathomdb-embedder-api, not just the [package] block.\n262\trestore\n263\t\"$SV\" --embedder-api 3.3.3 >/dev/null\n264\tif grep -E '^fathomdb-embedder-api[[:space:]]*=.*version[[:space:]]*=[[:space:]]*\"3\\.3\\.3\"' \"$CARGO\" >/dev/null; then\n265\t  pass \"embedder-api 3.3.3 propagates to workspace.dependencies pin\"\n266\telse\n267\t  fail \"embedder-api 3.3.3 did not update workspace.dependencies pin\"\n268\tfi\n269\t\n270\t# 12. --workspace updates every Axis-W pin in workspace.dependencies,\n271\t#     and leaves the Axis-E pin (fathomdb-embedder-api) alone.\n272\trestore\n273\t\"$SV\" --embedder-api 2.2.2 >/dev/null\n274\t\"$SV\" --workspace 4.4.4 >/dev/null\n275\t# Axis W pins must all be 4.4.4.\n276\tbad=0\n277\tfor name in fathomdb fathomdb-embedder fathomdb-engine fathomdb-query fathomdb-schema; do\n278\t  if ! grep -E \"^${name}[[:space:]]*=.*version[[:space:]]*=[[:space:]]*\\\"4\\.4\\.4\\\"\" \"$CARGO\" >/dev/null; then\n279\t    bad=1\n280\t    fail \"workspace 4.4.4 did not propagate to workspace.dependencies pin for $name\"\n281\t  fi\n282\tdone\n283\t[ \"$bad\" -eq 0 ] && pass \"workspace 4.4.4 propagated to every Axis-W workspace.dependencies pin\"\n284\t# Axis E pin must still be 2.2.2.\n285\tif grep -E '^fathomdb-embedder-api[[:space:]]*=.*version[[:space:]]*=[[:space:]]*\"2\\.2\\.2\"' \"$CARGO\" >/dev/null; then\n286\t  pass \"workspace 4.4.4 left Axis-E workspace.dependencies pin (2.2.2) alone\"\n287\telse\n288\t  fail \"workspace 4.4.4 mutated Axis-E workspace.dependencies pin\"\n289\tfi\n290\t\n291\trestore\n292\t\n293\tif [ \"$FAILED\" -gt 0 ]; then\n294\t  printf '\\n%d test(s) failed\\n' \"$FAILED\" >&2\n295\t  exit 1\n296\tfi\n297\tprintf '\\nAll set-version.sh tests passed\\n'\n298\t"}]},"parent_tool_use_id":null,"session_id":"4851922d-2a7d-4929-9e12-caa05c2d927b","uuid":"8ee5d3cc-b3fd-4ec9-83ad-b75c346ba761","timestamp":"2026-05-24T20:50:01.667Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-0.6.1-AXIS-E-PIN-20260524T204950Z/scripts/tests/test_set_version.sh","content":"#!/usr/bin/env bash\n# scripts/tests/test_set_version.sh — coverage for set-version.sh\n# two-axis enforcement per dev/design/release.md § Version axes.\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nREPO_ROOT=\"$(cd \"$SCRIPT_DIR/../..\" && pwd)\"\nSV=\"$REPO_ROOT/scripts/set-version.sh\"\n\nCARGO=\"$REPO_ROOT/Cargo.toml\"\nPYPROJ=\"$REPO_ROOT/src/python/pyproject.toml\"\nNPMPKG=\"$REPO_ROOT/src/ts/package.json\"\nEMBAPI=\"$REPO_ROOT/src/rust/crates/fathomdb-embedder-api/Cargo.toml\"\n\nFAILED=0\nTMPDIR_ROOT=\"$(mktemp -d)\"\ntrap 'restore; rm -rf \"$TMPDIR_ROOT\"' EXIT\n\n# Snapshot the four manifests so the test never leaves the tree dirty.\nSNAP=\"$TMPDIR_ROOT/snap\"\nmkdir -p \"$SNAP\"\ncp \"$CARGO\" \"$SNAP/Cargo.toml\"\ncp \"$PYPROJ\" \"$SNAP/pyproject.toml\"\ncp \"$NPMPKG\" \"$SNAP/package.json\"\ncp \"$EMBAPI\" \"$SNAP/embedder-api.toml\"\n\nrestore() {\n  cp \"$SNAP/Cargo.toml\" \"$CARGO\" 2>/dev/null || true\n  cp \"$SNAP/pyproject.toml\" \"$PYPROJ\" 2>/dev/null || true\n  cp \"$SNAP/package.json\" \"$NPMPKG\" 2>/dev/null || true\n  cp \"$SNAP/embedder-api.toml\" \"$EMBAPI\" 2>/dev/null || true\n}\n\npass() { printf 'PASS  %s\\n' \"$1\"; }\nfail() { printf 'FAIL  %s\\n' \"$1\" >&2; FAILED=$((FAILED + 1)); }\n\n# Extract Axis W workspace version from Cargo.toml [workspace.package].\nws_version() {\n  awk '\n    /^\\[workspace\\.package\\]/ { in_block = 1; next }\n    /^\\[/                     { in_block = 0 }\n    in_block && /^version[[:space:]]*=/ {\n      n = split($0, parts, \"\\\"\")\n      if (n >= 3) { print parts[2] }\n      exit\n    }\n  ' \"$CARGO\"\n}\n\n# Extract Axis E embedder-api version from its [package] block.\nemb_version() {\n  awk '\n    /^\\[package\\]/ { in_block = 1; next }\n    /^\\[/          { in_block = 0 }\n    in_block && /^version[[:space:]]*=/ {\n      n = split($0, parts, \"\\\"\")\n      if (n >= 3) { print parts[2] }\n      exit\n    }\n  ' \"$EMBAPI\"\n}\n\npy_version() {\n  awk '\n    /^\\[project\\]/ { in_block = 1; next }\n    /^\\[/          { in_block = 0 }\n    in_block && /^version[[:space:]]*=/ {\n      n = split($0, parts, \"\\\"\")\n      if (n >= 3) { print parts[2] }\n      exit\n    }\n  ' \"$PYPROJ\"\n}\n\nnpm_version() {\n  sed -n 's/.*\"version\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p' \"$NPMPKG\" | head -1\n}\n\n# 1. --check-files clean tree → 0.\nrestore\nif \"$SV\" --check-files >/dev/null 2>&1; then\n  pass \"check-files clean tree exits 0\"\nelse\n  fail \"check-files clean tree should exit 0\"\nfi\n\n# 2. --workspace 9.9.9 updates all Axis W manifests; Axis E untouched.\nrestore\nORIG_EMB=\"$(emb_version)\"\n\"$SV\" --workspace 9.9.9 >/dev/null\nif [ \"$(ws_version)\" = \"9.9.9\" ] && [ \"$(py_version)\" = \"9.9.9\" ] && [ \"$(npm_version)\" = \"9.9.9\" ]; then\n  pass \"workspace 9.9.9 updates Cargo+pyproject+package.json\"\nelse\n  fail \"workspace 9.9.9 did not propagate: ws=$(ws_version) py=$(py_version) npm=$(npm_version)\"\nfi\nif [ \"$(emb_version)\" = \"$ORIG_EMB\" ]; then\n  pass \"workspace 9.9.9 leaves Axis E ($ORIG_EMB) untouched\"\nelse\n  fail \"workspace 9.9.9 mutated Axis E: $ORIG_EMB → $(emb_version)\"\nfi\nif \"$SV\" --check-files >/dev/null 2>&1; then\n  pass \"check-files clean after --workspace 9.9.9\"\nelse\n  fail \"check-files should be clean after --workspace 9.9.9\"\nfi\n\n# 3. --embedder-api 8.8.8 updates only Axis E; Axis W untouched.\nrestore\nORIG_WS=\"$(ws_version)\"\nORIG_PY=\"$(py_version)\"\nORIG_NPM=\"$(npm_version)\"\n\"$SV\" --embedder-api 8.8.8 >/dev/null\nif [ \"$(emb_version)\" = \"8.8.8\" ]; then\n  pass \"embedder-api 8.8.8 updates Axis E\"\nelse\n  fail \"embedder-api 8.8.8 did not update Axis E: $(emb_version)\"\nfi\nif [ \"$(ws_version)\" = \"$ORIG_WS\" ] && [ \"$(py_version)\" = \"$ORIG_PY\" ] && [ \"$(npm_version)\" = \"$ORIG_NPM\" ]; then\n  pass \"embedder-api 8.8.8 leaves Axis W untouched\"\nelse\n  fail \"embedder-api 8.8.8 leaked into Axis W\"\nfi\nif \"$SV\" --check-files >/dev/null 2>&1; then\n  pass \"check-files clean after --embedder-api 8.8.8\"\nelse\n  fail \"check-files should be clean after --embedder-api 8.8.8\"\nfi\n\n# Helper: assert that $out (a check-files stderr capture) contains a\n# structured drift line for the given file naming observed/expected.\nassert_drift_line() {\n  local label=\"$1\" out=\"$2\" file_substr=\"$3\" observed=\"$4\" expected=\"$5\"\n  local missing=0\n  printf '%s' \"$out\" | grep -qE \"${file_substr}:[0-9]+:\" || missing=1\n  printf '%s' \"$out\" | grep -qF \"observed \\\"${observed}\\\"\"        || missing=$((missing + 2))\n  printf '%s' \"$out\" | grep -qF \"expected \\\"${expected}\\\"\"        || missing=$((missing + 4))\n  if [ \"$missing\" -eq 0 ]; then\n    pass \"$label\"\n  else\n    fail \"$label (missing bits=$missing); got: $out\"\n  fi\n}\n\n# 4a. Axis W drift on pyproject → structured diagnostic.\nrestore\nWS_BEFORE=\"$(ws_version)\"\nsed -i 's/^version = \"[^\"]*\"/version = \"7.7.7\"/' \"$PYPROJ\"\nif out=\"$(\"$SV\" --check-files 2>&1)\"; then\n  fail \"check-files should fail on drifted pyproject\"\nelse\n  assert_drift_line \"check-files: pyproject drift structured diagnostic\" \\\n    \"$out\" \"pyproject.toml\" \"7.7.7\" \"$WS_BEFORE\"\nfi\n\n# 4b. Axis W drift on package.json → structured diagnostic.\nrestore\nWS_BEFORE=\"$(ws_version)\"\nsed -i 's/\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/\"version\": \"7.7.7\"/' \"$NPMPKG\"\nif out=\"$(\"$SV\" --check-files 2>&1)\"; then\n  fail \"check-files should fail on drifted package.json\"\nelse\n  assert_drift_line \"check-files: package.json drift structured diagnostic\" \\\n    \"$out\" \"package.json\" \"7.7.7\" \"$WS_BEFORE\"\nfi\n\n# 5. Idempotent: --workspace <current> twice in a row → no second-pass change.\nrestore\nCUR=\"$(ws_version)\"\n\"$SV\" --workspace \"$CUR\" >/dev/null\nHASH1=\"$(sha256sum \"$CARGO\" \"$PYPROJ\" \"$NPMPKG\" | sha256sum)\"\n\"$SV\" --workspace \"$CUR\" >/dev/null\nHASH2=\"$(sha256sum \"$CARGO\" \"$PYPROJ\" \"$NPMPKG\" | sha256sum)\"\nif [ \"$HASH1\" = \"$HASH2\" ]; then\n  pass \"workspace re-run is idempotent (hash stable)\"\nelse\n  fail \"workspace re-run mutated content\"\nfi\n\n# 6. Unknown flag → exit 2 with usage on stderr.\nrestore\nif out=\"$(\"$SV\" --bogus-flag 2>&1)\"; then\n  fail \"unknown flag should exit non-zero\"\nelse\n  rc=$?\n  if [ \"$rc\" -eq 2 ] && printf '%s' \"$out\" | grep -q -i 'usage'; then\n    pass \"unknown flag → exit 2 + usage\"\n  else\n    fail \"unknown flag wrong exit ($rc) or no usage; got: $out\"\n  fi\nfi\n\n# 7. Missing argument to --workspace → exit 2 with usage.\nrestore\nif out=\"$(\"$SV\" --workspace 2>&1)\"; then\n  fail \"missing arg should exit non-zero\"\nelse\n  rc=$?\n  if [ \"$rc\" -eq 2 ] && printf '%s' \"$out\" | grep -q -i 'usage'; then\n    pass \"missing arg → exit 2 + usage\"\n  else\n    fail \"missing arg wrong exit ($rc) or no usage; got: $out\"\n  fi\nfi\n\n# 8. Drift on Axis E (explicit version replaced with workspace inheritance) → fail.\n# Pattern is version-agnostic so this test survives future Axis-E bumps without\n# editing the sed literal each cut.\nrestore\nsed -i -E 's/^version[[:space:]]*=[[:space:]]*\"[^\"]+\"$/version.workspace = true/' \"$EMBAPI\"\nif out=\"$(\"$SV\" --check-files 2>&1)\"; then\n  fail \"check-files should fail when Axis E inherits workspace\"\nelse\n  assert_drift_line \"check-files: Axis E inheritance-regression structured diagnostic\" \\\n    \"$out\" \"fathomdb-embedder-api/Cargo.toml\" \\\n    \"version.workspace = true\" \"explicit [package] version\"\nfi\n\n# 9. Drift on a non-embedder-api crate: replace `version.workspace = true`\n#    with an explicit literal version → must be flagged with structured\n#    diagnostic naming the crate manifest, observed=literal line,\n#    expected=version.workspace = true.\nrestore\nVICTIM=\"\"\nfor c in \"$REPO_ROOT\"/src/rust/crates/*/Cargo.toml; do\n  case \"$c\" in\n    *fathomdb-embedder-api*) continue ;;\n  esac\n  if grep -q '^version\\.workspace[[:space:]]*=[[:space:]]*true' \"$c\"; then\n    VICTIM=\"$c\"\n    break\n  fi\ndone\nif [ -z \"$VICTIM\" ]; then\n  fail \"test 9 setup: no non-embedder-api crate uses version.workspace=true\"\nelse\n  cp \"$VICTIM\" \"$TMPDIR_ROOT/victim.snap\"\n  sed -i 's/^version\\.workspace[[:space:]]*=[[:space:]]*true/version = \"9.9.9\"/' \"$VICTIM\"\n  if out=\"$(\"$SV\" --check-files 2>&1)\"; then\n    cp \"$TMPDIR_ROOT/victim.snap\" \"$VICTIM\"\n    fail \"check-files should fail when a non-embedder-api crate hardcodes version\"\n  else\n    cp \"$TMPDIR_ROOT/victim.snap\" \"$VICTIM\"\n    assert_drift_line \"check-files: non-emb-api crate hardcoded-version structured diagnostic\" \\\n      \"$out\" \"Cargo.toml\" 'version = \"9.9.9\"' \"version.workspace = true\"\n  fi\nfi\n\n# 10. Workspace.dependencies pin drift on an Axis W entry → structured\n#     diagnostic. cargo publish requires every in-workspace dep to carry\n#     a version requirement, and the pin must match the axis.\nrestore\nsed -i 's/^fathomdb-engine[[:space:]]*=.*$/fathomdb-engine       = { path = \"src\\/rust\\/crates\\/fathomdb-engine\",       version = \"5.5.5\" }/' \"$CARGO\"\nif out=\"$(\"$SV\" --check-files 2>&1)\"; then\n  fail \"check-files should fail on drifted workspace.dependencies pin\"\nelse\n  assert_drift_line \"check-files: workspace.dependencies pin drift structured diagnostic\" \\\n    \"$out\" \"Cargo.toml\" \"5.5.5\" \"$(ws_version)\"\nfi\n\n# 11. --embedder-api updates the workspace.dependencies pin for\n#     fathomdb-embedder-api, not just the [package] block.\nrestore\n\"$SV\" --embedder-api 3.3.3 >/dev/null\nif grep -E '^fathomdb-embedder-api[[:space:]]*=.*version[[:space:]]*=[[:space:]]*\"3\\.3\\.3\"' \"$CARGO\" >/dev/null; then\n  pass \"embedder-api 3.3.3 propagates to workspace.dependencies pin\"\nelse\n  fail \"embedder-api 3.3.3 did not update workspace.dependencies pin\"\nfi\n\n# 12. --workspace updates every Axis-W pin in workspace.dependencies,\n#     and leaves the Axis-E pin (fathomdb-embedder-api) alone.\nrestore\n\"$SV\" --embedder-api 2.2.2 >/dev/null\n\"$SV\" --workspace 4.4.4 >/dev/null\n# Axis W pins must all be 4.4.4.\nbad=0\nfor name in fathomdb fathomdb-embedder fathomdb-engine fathomdb-query fathomdb-schema; do\n  if ! grep -E \"^${name}[[:space:]]*=.*version[[:space:]]*=[[:space:]]*\\\"4\\.4\\.4\\\"\" \"$CARGO\" >/dev/null; then\n    bad=1\n    fail \"workspace 4.4.4 did not propagate to workspace.dependencies pin for $name\"\n  fi\ndone\n[ \"$bad\" -eq 0 ] && pass \"workspace 4.4.4 propagated to every Axis-W workspace.dependencies pin\"\n# Axis E pin must still be 2.2.2.\nif grep -E '^fathomdb-embedder-api[[:space:]]*=.*version[[:space:]]*=[[:space:]]*\"2\\.2\\.2\"' \"$CARGO\" >/dev/null; then\n  pass \"workspace 4.4.4 left Axis-E workspace.dependencies pin (2.2.2) alone\"\nelse\n  fail \"workspace 4.4.4 mutated Axis-E workspace.dependencies pin\"\nfi\n\nrestore\n\nif [ \"$FAILED\" -gt 0 ]; then\n  printf '\\n%d test(s) failed\\n' \"$FAILED\" >&2\n  exit 1\nfi\nprintf '\\nAll set-version.sh tests passed\\n'\n","numLines":298,"startLine":1,"totalLines":298}}}
