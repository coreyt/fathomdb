{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q4tyApcn9UnbjcE4m8cqhz","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t# scripts/set-version.sh — two-axis version single source of truth.\n3\t#\n4\t# Axis W (workspace lockstep): Cargo.toml [workspace.package].version,\n5\t# src/python/pyproject.toml [project].version, src/ts/package.json\n6\t# top-level \"version\". Inherited by every workspace crate via\n7\t# `version.workspace = true`.\n8\t#\n9\t# Axis E (embedder-api independent semver):\n10\t# src/rust/crates/fathomdb-embedder-api/Cargo.toml [package].version.\n11\t#\n12\t# Owner: dev/design/release.md § Version axes.\n13\tset -euo pipefail\n14\t\n15\tusage() {\n16\t  cat <<'USAGE' >&2\n17\tUsage: scripts/set-version.sh <mode> [args]\n18\t\n19\tModes:\n20\t  --workspace <new-w-version>     Set Axis W (Cargo workspace + python + ts).\n21\t  --embedder-api <new-e-version>  Set Axis E (fathomdb-embedder-api only).\n22\t  --check-files                   Verify both axes are internally consistent.\n23\t\n24\tExamples:\n25\t  scripts/set-version.sh --workspace 0.6.1\n26\t  scripts/set-version.sh --embedder-api 0.7.0\n27\t  scripts/set-version.sh --check-files\n28\tUSAGE\n29\t}\n30\t\n31\tdie_usage() {\n32\t  if [ -n \"${1:-}\" ]; then\n33\t    printf 'error: %s\\n' \"$1\" >&2\n34\t  fi\n35\t  usage\n36\t  exit 2\n37\t}\n38\t\n39\tREPO_ROOT=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\"\n40\tCARGO=\"$REPO_ROOT/Cargo.toml\"\n41\tPYPROJ=\"$REPO_ROOT/src/python/pyproject.toml\"\n42\tNPMPKG=\"$REPO_ROOT/src/ts/package.json\"\n43\tEMB_API_DIR=\"$REPO_ROOT/src/rust/crates/fathomdb-embedder-api\"\n44\tEMB_API=\"$EMB_API_DIR/Cargo.toml\"\n45\tCRATES_DIR=\"$REPO_ROOT/src/rust/crates\"\n46\t\n47\t# Atomic write: edits \"$1\" with awk program \"$2\" via a tmpfile mv.\n48\tawk_inplace() {\n49\t  local target=\"$1\"\n50\t  local prog=\"$2\"\n51\t  local tmp\n52\t  tmp=\"$(mktemp \"${target}.XXXXXX\")\"\n53\t  awk \"$prog\" \"$target\" >\"$tmp\"\n54\t  mv \"$tmp\" \"$target\"\n55\t}\n56\t\n57\t# Set [workspace.package].version in Cargo.toml.\n58\tset_workspace_version() {\n59\t  local new=\"$1\"\n60\t  awk_inplace \"$CARGO\" '\n61\t    BEGIN { in_block = 0 }\n62\t    /^\\[workspace\\.package\\]/ { in_block = 1; print; next }\n63\t    /^\\[/ { in_block = 0; print; next }\n64\t    {\n65\t      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n66\t        print \"version = \\\"'\"$new\"'\\\"\"\n67\t      } else {\n68\t        print\n69\t      }\n70\t    }\n71\t  '\n72\t}\n73\t\n74\t# Update every Axis-W entry in [workspace.dependencies]. fathomdb-embedder-api\n75\t# is Axis E and is skipped here — its version is set separately via\n76\t# set_workspace_dep_embedder_api_version().\n77\t#\n78\t# Each line we touch is of the shape:\n79\t#   fathomdb-<name> = { path = \"...\", version = \"X.Y.Z\" }\n80\t# We rewrite only the version=\"X.Y.Z\" segment; path is preserved.\n81\tset_workspace_dep_axis_w_versions() {\n82\t  local new=\"$1\"\n83\t  awk_inplace \"$CARGO\" '\n84\t    BEGIN { in_block = 0 }\n85\t    /^\\[workspace\\.dependencies\\]/ { in_block = 1; print; next }\n86\t    /^\\[/ { in_block = 0; print; next }\n87\t    {\n88\t      if (in_block && $0 ~ /^fathomdb(-[a-z]+)*[[:space:]]*=/) {\n89\t        # Skip Axis E (fathomdb-embedder-api).\n90\t        if ($0 ~ /^fathomdb-embedder-api[[:space:]]*=/) {\n91\t          print; next\n92\t        }\n93\t        # Rewrite version=\"...\" in-place, preserve everything else.\n94\t        if (sub(/version[[:space:]]*=[[:space:]]*\"[^\"]*\"/,\n95\t                \"version = \\\"'\"$new\"'\\\"\")) {\n96\t          print; next\n97\t        }\n98\t      }\n99\t      print\n100\t    }\n101\t  '\n102\t}\n103\t\n104\t# Update the Axis-E entry in [workspace.dependencies] (fathomdb-embedder-api).\n105\tset_workspace_dep_embedder_api_version() {\n106\t  local new=\"$1\"\n107\t  awk_inplace \"$CARGO\" '\n108\t    BEGIN { in_block = 0 }\n109\t    /^\\[workspace\\.dependencies\\]/ { in_block = 1; print; next }\n110\t    /^\\[/ { in_block = 0; print; next }\n111\t    {\n112\t      if (in_block && $0 ~ /^fathomdb-embedder-api[[:space:]]*=/) {\n113\t        if (sub(/version[[:space:]]*=[[:space:]]*\"[^\"]*\"/,\n114\t                \"version = \\\"'\"$new\"'\\\"\")) {\n115\t          print; next\n116\t        }\n117\t      }\n118\t      print\n119\t    }\n120\t  '\n121\t}\n122\t\n123\t# Set [project].version in pyproject.toml.\n124\tset_pyproject_version() {\n125\t  local new=\"$1\"\n126\t  awk_inplace \"$PYPROJ\" '\n127\t    BEGIN { in_block = 0 }\n128\t    /^\\[project\\]/ { in_block = 1; print; next }\n129\t    /^\\[/ { in_block = 0; print; next }\n130\t    {\n131\t      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n132\t        print \"version = \\\"'\"$new\"'\\\"\"\n133\t      } else {\n134\t        print\n135\t      }\n136\t    }\n137\t  '\n138\t}\n139\t\n140\t# Set the top-level \"version\" field in package.json.\n141\t# Constraint: only rewrite the first occurrence so a nested \"version\" inside\n142\t# devDependencies cannot be touched.\n143\tset_npm_version() {\n144\t  local new=\"$1\"\n145\t  local tmp\n146\t  tmp=\"$(mktemp \"${NPMPKG}.XXXXXX\")\"\n147\t  awk -v new=\"$new\" '\n148\t    BEGIN { done = 0 }\n149\t    {\n150\t      if (!done && match($0, /\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/)) {\n151\t        sub(/\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/, \"\\\"version\\\": \\\"\" new \"\\\"\")\n152\t        done = 1\n153\t      }\n154\t      print\n155\t    }\n156\t  ' \"$NPMPKG\" >\"$tmp\"\n157\t  mv \"$tmp\" \"$NPMPKG\"\n158\t}\n159\t\n160\t# Set [package].version in fathomdb-embedder-api/Cargo.toml. Preserves any\n161\t# leading comment lines inside the [package] block (so the Axis-E why-comment\n162\t# survives re-runs).\n163\tset_embedder_api_version() {\n164\t  local new=\"$1\"\n165\t  awk_inplace \"$EMB_API\" '\n166\t    BEGIN { in_block = 0 }\n167\t    /^\\[package\\]/ { in_block = 1; print; next }\n168\t    /^\\[/ { in_block = 0; print; next }\n169\t    {\n170\t      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n171\t        print \"version = \\\"'\"$new\"'\\\"\"\n172\t      } else {\n173\t        print\n174\t      }\n175\t    }\n176\t  '\n177\t}\n178\t\n179\t# --- readers ---------------------------------------------------------------\n180\t\n181\tread_workspace_version() {\n182\t  awk '\n183\t    /^\\[workspace\\.package\\]/ { in_block = 1; next }\n184\t    /^\\[/                     { in_block = 0 }\n185\t    in_block && /^version[[:space:]]*=/ {\n186\t      n = split($0, parts, \"\\\"\")\n187\t      if (n >= 3) { print parts[2] }\n188\t      exit\n189\t    }\n190\t  ' \"$CARGO\"\n191\t}\n192\t\n193\tread_pyproject_version() {\n194\t  awk '\n195\t    /^\\[project\\]/ { in_block = 1; next }\n196\t    /^\\[/          { in_block = 0 }\n197\t    in_block && /^version[[:space:]]*=/ {\n198\t      n = split($0, parts, \"\\\"\")\n199\t      if (n >= 3) { print parts[2] }\n200\t      exit\n201\t    }\n202\t  ' \"$PYPROJ\"\n203\t}\n204\t\n205\tread_npm_version() {\n206\t  sed -n 's/.*\"version\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p' \"$NPMPKG\" | head -1\n207\t}\n208\t\n209\t# Returns the literal text of the version line inside [package] of the\n210\t# embedder-api crate (e.g. `version = \"0.6.0\"` or `version.workspace = true`).\n211\tread_embedder_api_version_line() {\n212\t  awk '\n213\t    /^\\[package\\]/ { in_block = 1; next }\n214\t    /^\\[/          { in_block = 0 }\n215\t    in_block && /^version[[:space:]]*[=.]/ {\n216\t      print\n217\t      exit\n218\t    }\n219\t  ' \"$EMB_API\"\n220\t}\n221\t\n222\t# Parse out the value portion: returns \"0.6.0\" for `version = \"0.6.0\"`, or\n223\t# the literal \"workspace\" sentinel for `version.workspace = true`.\n224\tembedder_api_version_value() {\n225\t  local line\n226\t  line=\"$(read_embedder_api_version_line)\"\n227\t  case \"$line\" in\n228\t    version.workspace*) printf 'workspace' ;;\n229\t    version[[:space:]]*=*\\\"*) printf '%s' \"$line\" | sed -n 's/.*\"\\([^\"]*\\)\".*/\\1/p' ;;\n230\t    *) printf 'unknown' ;;\n231\t  esac\n232\t}\n233\t\n234\t# --- check-files -----------------------------------------------------------\n235\t\n236\t# Line number of the first `version =` / `version.workspace` declaration\n237\t# inside the given TOML [table] of the given file. Empty if not present.\n238\t_toml_version_line() {\n239\t  local file=\"$1\" table=\"$2\"\n240\t  awk -v table=\"$table\" '\n241\t    $0 == table { in_block = 1; next }\n242\t    /^\\[/ && in_block { exit }\n243\t    in_block && /^version[[:space:]]*[=.]/ { print NR; exit }\n244\t  ' \"$file\"\n245\t}\n246\t\n247\t# Line number of the first \"version\" key in a JSON file.\n248\t_json_version_line() {\n249\t  grep -n '\"version\"' \"$1\" | head -1 | cut -d: -f1\n250\t}\n251\t\n252\t# Emit a structured drift diagnostic: `<file>:<line>: version drift —\n253\t# observed \"X\", expected \"Y\"`. Centralized so every drift site has the\n254\t# same shape (parseable by tooling, asserted in test_set_version.sh).\n255\t_drift() {\n256\t  local file=\"$1\" line=\"$2\" observed=\"$3\" expected=\"$4\"\n257\t  printf '%s:%s: version drift — observed \"%s\", expected \"%s\"\\n' \\\n258\t    \"$file\" \"${line:-?}\" \"$observed\" \"$expected\" >&2\n259\t}\n260\t\n261\tcheck_files() {\n262\t  local ws py npm emb\n263\t  ws=\"$(read_workspace_version)\"\n264\t  py=\"$(read_pyproject_version)\"\n265\t  npm=\"$(read_npm_version)\"\n266\t  emb=\"$(embedder_api_version_value)\"\n267\t\n268\t  local rc=0\n269\t\n270\t  if [ -z \"$ws\" ]; then\n271\t    printf 'error: %s: no [workspace.package] version found\\n' \"$CARGO\" >&2\n272\t    rc=1\n273\t  fi\n274\t\n275\t  if [ \"$py\" != \"$ws\" ]; then\n276\t    _drift \"$PYPROJ\" \"$(_toml_version_line \"$PYPROJ\" '[project]')\" \"$py\" \"$ws\"\n277\t    rc=1\n278\t  fi\n279\t\n280\t  if [ \"$npm\" != \"$ws\" ]; then\n281\t    _drift \"$NPMPKG\" \"$(_json_version_line \"$NPMPKG\")\" \"$npm\" \"$ws\"\n282\t    rc=1\n283\t  fi\n284\t\n285\t  case \"$emb\" in\n286\t    workspace)\n287\t      _drift \"$EMB_API\" \"$(_toml_version_line \"$EMB_API\" '[package]')\" \\\n288\t        \"version.workspace = true\" \"explicit [package] version\"\n289\t      rc=1\n290\t      ;;\n291\t    unknown|'')\n292\t      _drift \"$EMB_API\" \"$(_toml_version_line \"$EMB_API\" '[package]')\" \\\n293\t        \"unparseable\" \"explicit [package] version\"\n294\t      rc=1\n295\t      ;;\n296\t  esac\n297\t\n298\t  # Every workspace crate except fathomdb-embedder-api must inherit Axis W\n299\t  # via `version.workspace = true`. Catch silent decoupling regressions.\n300\t  local crate manifest line line_no pkg_line\n301\t  for crate in \"$CRATES_DIR\"/*; do\n302\t    [ -d \"$crate\" ] || continue\n303\t    manifest=\"$crate/Cargo.toml\"\n304\t    [ -f \"$manifest\" ] || continue\n305\t    if [ \"$crate\" = \"$EMB_API_DIR\" ]; then\n306\t      continue\n307\t    fi\n308\t    line=\"$(awk '\n309\t      /^\\[package\\]/ { in_block = 1; next }\n310\t      /^\\[/          { in_block = 0 }\n311\t      in_block && /^version[[:space:]]*[=.]/ {\n312\t        print\n313\t        exit\n314\t      }\n315\t    ' \"$manifest\")\"\n316\t    case \"$line\" in\n317\t      version.workspace[[:space:]]*=[[:space:]]*true) ;;\n318\t      '')\n319\t        pkg_line=\"$(grep -n '^\\[package\\]' \"$manifest\" | head -1 | cut -d: -f1)\"\n320\t        _drift \"$manifest\" \"${pkg_line:-1}\" \"<missing>\" \"version.workspace = true\"\n321\t        rc=1\n322\t        ;;\n323\t      *)\n324\t        line_no=\"$(_toml_version_line \"$manifest\" '[package]')\"\n325\t        _drift \"$manifest\" \"${line_no:-1}\" \"$line\" \"version.workspace = true\"\n326\t        rc=1\n327\t        ;;\n328\t    esac\n329\t  done\n330\t\n331\t  # [workspace.dependencies] version pins must match Axis W (or Axis E for\n332\t  # fathomdb-embedder-api). `cargo publish` requires each in-workspace dep\n333\t  # to carry a version requirement — if the pins drift from the axis\n334\t  # version, the published manifest will fail registry resolution at the\n335\t  # next tier.\n336\t  while IFS= read -r entry; do\n337\t    [ -n \"$entry\" ] || continue\n338\t    local dep_name dep_ver expected line_no\n339\t    dep_name=\"$(printf '%s' \"$entry\" | awk -F'[[:space:]]*=' '{print $1}')\"\n340\t    dep_ver=\"$(printf '%s' \"$entry\" | sed -nE 's/.*version[[:space:]]*=[[:space:]]*\"([^\"]+)\".*/\\1/p')\"\n341\t    case \"$dep_name\" in\n342\t      fathomdb-embedder-api) expected=\"$emb\" ;;\n343\t      *)                     expected=\"$ws\"  ;;\n344\t    esac\n345\t    if [ -z \"$dep_ver\" ]; then\n346\t      line_no=\"$(grep -nE \"^${dep_name}[[:space:]]*=\" \"$CARGO\" | head -1 | cut -d: -f1)\"\n347\t      _drift \"$CARGO\" \"${line_no:-1}\" \"<missing version>\" \"$expected\"\n348\t      rc=1\n349\t    elif [ \"$dep_ver\" != \"$expected\" ]; then\n350\t      line_no=\"$(grep -nE \"^${dep_name}[[:space:]]*=\" \"$CARGO\" | head -1 | cut -d: -f1)\"\n351\t      _drift \"$CARGO\" \"${line_no:-1}\" \"$dep_ver\" \"$expected\"\n352\t      rc=1\n353\t    fi\n354\t  done <<EOF\n355\t$(awk '\n356\t  /^\\[workspace\\.dependencies\\]/ { in_block = 1; next }\n357\t  /^\\[/ && in_block { exit }\n358\t  in_block && /^fathomdb/ { print }\n359\t' \"$CARGO\")\n360\tEOF\n361\t\n362\t  if [ $rc -eq 0 ]; then\n363\t    printf 'ok: Axis W = %s; Axis E = %s\\n' \"$ws\" \"$emb\"\n364\t  fi\n365\t  return $rc\n366\t}\n367\t\n368\t# --- dispatch --------------------------------------------------------------\n369\t\n370\tif [ $# -eq 0 ]; then\n371\t  die_usage \"no mode given\"\n372\tfi\n373\t\n374\tmode=\"$1\"\n375\tshift || true\n376\t\n377\tcase \"$mode\" in\n378\t  --workspace)\n379\t    if [ $# -ne 1 ] || [ -z \"${1:-}\" ]; then\n380\t      die_usage \"--workspace requires <new-w-version>\"\n381\t    fi\n382\t    new=\"$1\"\n383\t    set_workspace_version \"$new\"\n384\t    set_workspace_dep_axis_w_versions \"$new\"\n385\t    set_pyproject_version \"$new\"\n386\t    set_npm_version \"$new\"\n387\t    check_files\n388\t    ;;\n389\t  --embedder-api)\n390\t    if [ $# -ne 1 ] || [ -z \"${1:-}\" ]; then\n391\t      die_usage \"--embedder-api requires <new-e-version>\"\n392\t    fi\n393\t    new=\"$1\"\n394\t    set_embedder_api_version \"$new\"\n395\t    set_workspace_dep_embedder_api_version \"$new\"\n396\t    check_files\n397\t    ;;\n398\t  --check-files)\n399\t    if [ $# -ne 0 ]; then\n400\t      die_usage \"--check-files takes no arguments\"\n401\t    fi\n402\t    check_files\n403\t    ;;\n404\t  -h|--help)\n405\t    usage\n406\t    exit 0\n407\t    ;;\n408\t  *)\n409\t    die_usage \"unknown mode: $mode\"\n410\t    ;;\n411\tesac\n412\t"}]},"parent_tool_use_id":null,"session_id":"4851922d-2a7d-4929-9e12-caa05c2d927b","uuid":"ab516207-2265-4c0d-a003-eeb63d810d22","timestamp":"2026-05-24T20:49:55.556Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-0.6.1-AXIS-E-PIN-20260524T204950Z/scripts/set-version.sh","content":"#!/usr/bin/env bash\n# scripts/set-version.sh — two-axis version single source of truth.\n#\n# Axis W (workspace lockstep): Cargo.toml [workspace.package].version,\n# src/python/pyproject.toml [project].version, src/ts/package.json\n# top-level \"version\". Inherited by every workspace crate via\n# `version.workspace = true`.\n#\n# Axis E (embedder-api independent semver):\n# src/rust/crates/fathomdb-embedder-api/Cargo.toml [package].version.\n#\n# Owner: dev/design/release.md § Version axes.\nset -euo pipefail\n\nusage() {\n  cat <<'USAGE' >&2\nUsage: scripts/set-version.sh <mode> [args]\n\nModes:\n  --workspace <new-w-version>     Set Axis W (Cargo workspace + python + ts).\n  --embedder-api <new-e-version>  Set Axis E (fathomdb-embedder-api only).\n  --check-files                   Verify both axes are internally consistent.\n\nExamples:\n  scripts/set-version.sh --workspace 0.6.1\n  scripts/set-version.sh --embedder-api 0.7.0\n  scripts/set-version.sh --check-files\nUSAGE\n}\n\ndie_usage() {\n  if [ -n \"${1:-}\" ]; then\n    printf 'error: %s\\n' \"$1\" >&2\n  fi\n  usage\n  exit 2\n}\n\nREPO_ROOT=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\"\nCARGO=\"$REPO_ROOT/Cargo.toml\"\nPYPROJ=\"$REPO_ROOT/src/python/pyproject.toml\"\nNPMPKG=\"$REPO_ROOT/src/ts/package.json\"\nEMB_API_DIR=\"$REPO_ROOT/src/rust/crates/fathomdb-embedder-api\"\nEMB_API=\"$EMB_API_DIR/Cargo.toml\"\nCRATES_DIR=\"$REPO_ROOT/src/rust/crates\"\n\n# Atomic write: edits \"$1\" with awk program \"$2\" via a tmpfile mv.\nawk_inplace() {\n  local target=\"$1\"\n  local prog=\"$2\"\n  local tmp\n  tmp=\"$(mktemp \"${target}.XXXXXX\")\"\n  awk \"$prog\" \"$target\" >\"$tmp\"\n  mv \"$tmp\" \"$target\"\n}\n\n# Set [workspace.package].version in Cargo.toml.\nset_workspace_version() {\n  local new=\"$1\"\n  awk_inplace \"$CARGO\" '\n    BEGIN { in_block = 0 }\n    /^\\[workspace\\.package\\]/ { in_block = 1; print; next }\n    /^\\[/ { in_block = 0; print; next }\n    {\n      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n        print \"version = \\\"'\"$new\"'\\\"\"\n      } else {\n        print\n      }\n    }\n  '\n}\n\n# Update every Axis-W entry in [workspace.dependencies]. fathomdb-embedder-api\n# is Axis E and is skipped here — its version is set separately via\n# set_workspace_dep_embedder_api_version().\n#\n# Each line we touch is of the shape:\n#   fathomdb-<name> = { path = \"...\", version = \"X.Y.Z\" }\n# We rewrite only the version=\"X.Y.Z\" segment; path is preserved.\nset_workspace_dep_axis_w_versions() {\n  local new=\"$1\"\n  awk_inplace \"$CARGO\" '\n    BEGIN { in_block = 0 }\n    /^\\[workspace\\.dependencies\\]/ { in_block = 1; print; next }\n    /^\\[/ { in_block = 0; print; next }\n    {\n      if (in_block && $0 ~ /^fathomdb(-[a-z]+)*[[:space:]]*=/) {\n        # Skip Axis E (fathomdb-embedder-api).\n        if ($0 ~ /^fathomdb-embedder-api[[:space:]]*=/) {\n          print; next\n        }\n        # Rewrite version=\"...\" in-place, preserve everything else.\n        if (sub(/version[[:space:]]*=[[:space:]]*\"[^\"]*\"/,\n                \"version = \\\"'\"$new\"'\\\"\")) {\n          print; next\n        }\n      }\n      print\n    }\n  '\n}\n\n# Update the Axis-E entry in [workspace.dependencies] (fathomdb-embedder-api).\nset_workspace_dep_embedder_api_version() {\n  local new=\"$1\"\n  awk_inplace \"$CARGO\" '\n    BEGIN { in_block = 0 }\n    /^\\[workspace\\.dependencies\\]/ { in_block = 1; print; next }\n    /^\\[/ { in_block = 0; print; next }\n    {\n      if (in_block && $0 ~ /^fathomdb-embedder-api[[:space:]]*=/) {\n        if (sub(/version[[:space:]]*=[[:space:]]*\"[^\"]*\"/,\n                \"version = \\\"'\"$new\"'\\\"\")) {\n          print; next\n        }\n      }\n      print\n    }\n  '\n}\n\n# Set [project].version in pyproject.toml.\nset_pyproject_version() {\n  local new=\"$1\"\n  awk_inplace \"$PYPROJ\" '\n    BEGIN { in_block = 0 }\n    /^\\[project\\]/ { in_block = 1; print; next }\n    /^\\[/ { in_block = 0; print; next }\n    {\n      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n        print \"version = \\\"'\"$new\"'\\\"\"\n      } else {\n        print\n      }\n    }\n  '\n}\n\n# Set the top-level \"version\" field in package.json.\n# Constraint: only rewrite the first occurrence so a nested \"version\" inside\n# devDependencies cannot be touched.\nset_npm_version() {\n  local new=\"$1\"\n  local tmp\n  tmp=\"$(mktemp \"${NPMPKG}.XXXXXX\")\"\n  awk -v new=\"$new\" '\n    BEGIN { done = 0 }\n    {\n      if (!done && match($0, /\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/)) {\n        sub(/\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/, \"\\\"version\\\": \\\"\" new \"\\\"\")\n        done = 1\n      }\n      print\n    }\n  ' \"$NPMPKG\" >\"$tmp\"\n  mv \"$tmp\" \"$NPMPKG\"\n}\n\n# Set [package].version in fathomdb-embedder-api/Cargo.toml. Preserves any\n# leading comment lines inside the [package] block (so the Axis-E why-comment\n# survives re-runs).\nset_embedder_api_version() {\n  local new=\"$1\"\n  awk_inplace \"$EMB_API\" '\n    BEGIN { in_block = 0 }\n    /^\\[package\\]/ { in_block = 1; print; next }\n    /^\\[/ { in_block = 0; print; next }\n    {\n      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n        print \"version = \\\"'\"$new\"'\\\"\"\n      } else {\n        print\n      }\n    }\n  '\n}\n\n# --- readers ---------------------------------------------------------------\n\nread_workspace_version() {\n  awk '\n    /^\\[workspace\\.package\\]/ { in_block = 1; next }\n    /^\\[/                     { in_block = 0 }\n    in_block && /^version[[:space:]]*=/ {\n      n = split($0, parts, \"\\\"\")\n      if (n >= 3) { print parts[2] }\n      exit\n    }\n  ' \"$CARGO\"\n}\n\nread_pyproject_version() {\n  awk '\n    /^\\[project\\]/ { in_block = 1; next }\n    /^\\[/          { in_block = 0 }\n    in_block && /^version[[:space:]]*=/ {\n      n = split($0, parts, \"\\\"\")\n      if (n >= 3) { print parts[2] }\n      exit\n    }\n  ' \"$PYPROJ\"\n}\n\nread_npm_version() {\n  sed -n 's/.*\"version\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p' \"$NPMPKG\" | head -1\n}\n\n# Returns the literal text of the version line inside [package] of the\n# embedder-api crate (e.g. `version = \"0.6.0\"` or `version.workspace = true`).\nread_embedder_api_version_line() {\n  awk '\n    /^\\[package\\]/ { in_block = 1; next }\n    /^\\[/          { in_block = 0 }\n    in_block && /^version[[:space:]]*[=.]/ {\n      print\n      exit\n    }\n  ' \"$EMB_API\"\n}\n\n# Parse out the value portion: returns \"0.6.0\" for `version = \"0.6.0\"`, or\n# the literal \"workspace\" sentinel for `version.workspace = true`.\nembedder_api_version_value() {\n  local line\n  line=\"$(read_embedder_api_version_line)\"\n  case \"$line\" in\n    version.workspace*) printf 'workspace' ;;\n    version[[:space:]]*=*\\\"*) printf '%s' \"$line\" | sed -n 's/.*\"\\([^\"]*\\)\".*/\\1/p' ;;\n    *) printf 'unknown' ;;\n  esac\n}\n\n# --- check-files -----------------------------------------------------------\n\n# Line number of the first `version =` / `version.workspace` declaration\n# inside the given TOML [table] of the given file. Empty if not present.\n_toml_version_line() {\n  local file=\"$1\" table=\"$2\"\n  awk -v table=\"$table\" '\n    $0 == table { in_block = 1; next }\n    /^\\[/ && in_block { exit }\n    in_block && /^version[[:space:]]*[=.]/ { print NR; exit }\n  ' \"$file\"\n}\n\n# Line number of the first \"version\" key in a JSON file.\n_json_version_line() {\n  grep -n '\"version\"' \"$1\" | head -1 | cut -d: -f1\n}\n\n# Emit a structured drift diagnostic: `<file>:<line>: version drift —\n# observed \"X\", expected \"Y\"`. Centralized so every drift site has the\n# same shape (parseable by tooling, asserted in test_set_version.sh).\n_drift() {\n  local file=\"$1\" line=\"$2\" observed=\"$3\" expected=\"$4\"\n  printf '%s:%s: version drift — observed \"%s\", expected \"%s\"\\n' \\\n    \"$file\" \"${line:-?}\" \"$observed\" \"$expected\" >&2\n}\n\ncheck_files() {\n  local ws py npm emb\n  ws=\"$(read_workspace_version)\"\n  py=\"$(read_pyproject_version)\"\n  npm=\"$(read_npm_version)\"\n  emb=\"$(embedder_api_version_value)\"\n\n  local rc=0\n\n  if [ -z \"$ws\" ]; then\n    printf 'error: %s: no [workspace.package] version found\\n' \"$CARGO\" >&2\n    rc=1\n  fi\n\n  if [ \"$py\" != \"$ws\" ]; then\n    _drift \"$PYPROJ\" \"$(_toml_version_line \"$PYPROJ\" '[project]')\" \"$py\" \"$ws\"\n    rc=1\n  fi\n\n  if [ \"$npm\" != \"$ws\" ]; then\n    _drift \"$NPMPKG\" \"$(_json_version_line \"$NPMPKG\")\" \"$npm\" \"$ws\"\n    rc=1\n  fi\n\n  case \"$emb\" in\n    workspace)\n      _drift \"$EMB_API\" \"$(_toml_version_line \"$EMB_API\" '[package]')\" \\\n        \"version.workspace = true\" \"explicit [package] version\"\n      rc=1\n      ;;\n    unknown|'')\n      _drift \"$EMB_API\" \"$(_toml_version_line \"$EMB_API\" '[package]')\" \\\n        \"unparseable\" \"explicit [package] version\"\n      rc=1\n      ;;\n  esac\n\n  # Every workspace crate except fathomdb-embedder-api must inherit Axis W\n  # via `version.workspace = true`. Catch silent decoupling regressions.\n  local crate manifest line line_no pkg_line\n  for crate in \"$CRATES_DIR\"/*; do\n    [ -d \"$crate\" ] || continue\n    manifest=\"$crate/Cargo.toml\"\n    [ -f \"$manifest\" ] || continue\n    if [ \"$crate\" = \"$EMB_API_DIR\" ]; then\n      continue\n    fi\n    line=\"$(awk '\n      /^\\[package\\]/ { in_block = 1; next }\n      /^\\[/          { in_block = 0 }\n      in_block && /^version[[:space:]]*[=.]/ {\n        print\n        exit\n      }\n    ' \"$manifest\")\"\n    case \"$line\" in\n      version.workspace[[:space:]]*=[[:space:]]*true) ;;\n      '')\n        pkg_line=\"$(grep -n '^\\[package\\]' \"$manifest\" | head -1 | cut -d: -f1)\"\n        _drift \"$manifest\" \"${pkg_line:-1}\" \"<missing>\" \"version.workspace = true\"\n        rc=1\n        ;;\n      *)\n        line_no=\"$(_toml_version_line \"$manifest\" '[package]')\"\n        _drift \"$manifest\" \"${line_no:-1}\" \"$line\" \"version.workspace = true\"\n        rc=1\n        ;;\n    esac\n  done\n\n  # [workspace.dependencies] version pins must match Axis W (or Axis E for\n  # fathomdb-embedder-api). `cargo publish` requires each in-workspace dep\n  # to carry a version requirement — if the pins drift from the axis\n  # version, the published manifest will fail registry resolution at the\n  # next tier.\n  while IFS= read -r entry; do\n    [ -n \"$entry\" ] || continue\n    local dep_name dep_ver expected line_no\n    dep_name=\"$(printf '%s' \"$entry\" | awk -F'[[:space:]]*=' '{print $1}')\"\n    dep_ver=\"$(printf '%s' \"$entry\" | sed -nE 's/.*version[[:space:]]*=[[:space:]]*\"([^\"]+)\".*/\\1/p')\"\n    case \"$dep_name\" in\n      fathomdb-embedder-api) expected=\"$emb\" ;;\n      *)                     expected=\"$ws\"  ;;\n    esac\n    if [ -z \"$dep_ver\" ]; then\n      line_no=\"$(grep -nE \"^${dep_name}[[:space:]]*=\" \"$CARGO\" | head -1 | cut -d: -f1)\"\n      _drift \"$CARGO\" \"${line_no:-1}\" \"<missing version>\" \"$expected\"\n      rc=1\n    elif [ \"$dep_ver\" != \"$expected\" ]; then\n      line_no=\"$(grep -nE \"^${dep_name}[[:space:]]*=\" \"$CARGO\" | head -1 | cut -d: -f1)\"\n      _drift \"$CARGO\" \"${line_no:-1}\" \"$dep_ver\" \"$expected\"\n      rc=1\n    fi\n  done <<EOF\n$(awk '\n  /^\\[workspace\\.dependencies\\]/ { in_block = 1; next }\n  /^\\[/ && in_block { exit }\n  in_block && /^fathomdb/ { print }\n' \"$CARGO\")\nEOF\n\n  if [ $rc -eq 0 ]; then\n    printf 'ok: Axis W = %s; Axis E = %s\\n' \"$ws\" \"$emb\"\n  fi\n  return $rc\n}\n\n# --- dispatch --------------------------------------------------------------\n\nif [ $# -eq 0 ]; then\n  die_usage \"no mode given\"\nfi\n\nmode=\"$1\"\nshift || true\n\ncase \"$mode\" in\n  --workspace)\n    if [ $# -ne 1 ] || [ -z \"${1:-}\" ]; then\n      die_usage \"--workspace requires <new-w-version>\"\n    fi\n    new=\"$1\"\n    set_workspace_version \"$new\"\n    set_workspace_dep_axis_w_versions \"$new\"\n    set_pyproject_version \"$new\"\n    set_npm_version \"$new\"\n    check_files\n    ;;\n  --embedder-api)\n    if [ $# -ne 1 ] || [ -z \"${1:-}\" ]; then\n      die_usage \"--embedder-api requires <new-e-version>\"\n    fi\n    new=\"$1\"\n    set_embedder_api_version \"$new\"\n    set_workspace_dep_embedder_api_version \"$new\"\n    check_files\n    ;;\n  --check-files)\n    if [ $# -ne 0 ]; then\n      die_usage \"--check-files takes no arguments\"\n    fi\n    check_files\n    ;;\n  -h|--help)\n    usage\n    exit 0\n    ;;\n  *)\n    die_usage \"unknown mode: $mode\"\n    ;;\nesac\n","numLines":412,"startLine":1,"totalLines":412}}}
