   683	/// Read + validate the cache. `Ok(Some(map))` on a trusted hit;
   684	/// `Ok(None)` only when BOTH files are absent (the genuine cold cache);
   685	/// `Err(reason)` when present-but-stale/corrupt OR partially present
   686	/// (blob xor sidecar) — a partial cache is a loud miss, never silently
   687	/// treated as cold. The caller logs every miss and rebuilds; it never
   688	/// trusts the bytes.
   689	fn read_cache(
   690	    cache_path: &Path,
   691	    meta_path: &Path,
   692	    identity: &EmbedderIdentity,
   693	    doc_manifest_sha: &str,
   694	) -> Result<Option<VecCache>, String> {
   695	    let blob_exists = cache_path.exists();
   696	    let meta_exists = meta_path.exists();
   697	    if !blob_exists && !meta_exists {
   698	        return Ok(None);
   699	    }
   700	    if blob_exists != meta_exists {
   701	        return Err(format!(
   702	            "partial cache (blob={blob_exists}, sidecar={meta_exists}) — treating as miss"
   703	        ));
