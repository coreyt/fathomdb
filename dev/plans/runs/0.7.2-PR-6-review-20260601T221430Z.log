   624	    fn embed(&self, input: &str) -> Result<Vector, EmbedderError> {
   625	        let key = text_sha256(input);
   626	        if let Some(v) = self.cache.read().expect("cache read lock").get(&key) {
   627	            return Ok(v.clone());
   628	        }
   629	        let v = self.inner.embed(input)?;
   630	        self.live_misses.fetch_add(1, Ordering::Relaxed);
   631	        self.cache.write().expect("cache write lock").insert(key, v.clone());
   632	        Ok(v)
   633	    }
   634	}
