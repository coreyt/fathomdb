   399	        let _ = engine.search(&q.text).expect("baseline warmup");
   400	    }
   401	    let mut baseline = Vec::with_capacity(queries.len());
   402	    for q in &queries {
   403	        let started = Instant::now();
   404	        let _ = engine.search(&q.text).expect("baseline measure");
   405	        baseline.push(started.elapsed());
   406	    }
   407	    let baseline_p99 = percentile_ceil(&baseline, 99, 100);
   408	
   409	    // Modest concurrent stress: DEVLOOP_AC019_THREADS readers, mixed FTS5 +
   410	    // vector + canonical reads via the single `search()` path.
   411	    let query_texts: Arc<Vec<String>> = Arc::new(queries.iter().map(|q| q.text.clone()).collect());
   412	    let engine = Arc::new(engine);
   413	    let barrier = Arc::new(Barrier::new(DEVLOOP_AC019_THREADS + 1));
   414	    let sink: Arc<Mutex<Vec<Duration>>> = Arc::new(Mutex::new(Vec::new()));
   415	    let mut handles = Vec::with_capacity(DEVLOOP_AC019_THREADS);
   416	    for tid in 0..DEVLOOP_AC019_THREADS {
   417	        let engine = Arc::clone(&engine);
   418	        let barrier = Arc::clone(&barrier);
   419	        let qs = Arc::clone(&query_texts);
   420	        let sink = Arc::clone(&sink);
   421	        handles.push(thread::spawn(move || {
   422	            let mut local = Vec::with_capacity(DEVLOOP_AC019_QUERIES_PER_THREAD);
   423	            let base = tid * DEVLOOP_AC019_QUERIES_PER_THREAD;
   424	            barrier.wait();
   425	            for i in 0..DEVLOOP_AC019_QUERIES_PER_THREAD {
   426	                let q = &qs[(base + i) % qs.len()];
   427	                let started = Instant::now();
   428	                let _ = engine.search(q).expect("stress search");
   429	                local.push(started.elapsed());
   430	            }
   431	            sink.lock().unwrap().extend(local);
   432	        }));
   433	    }
   434	    let stress_started = Instant::now();
   435	    barrier.wait();
   436	    for h in handles {
   437	        h.join().expect("stress thread");
   438	    }
   439	    let stress_elapsed = stress_started.elapsed();
   440	
   441	    let stress_samples = std::mem::take(&mut *sink.lock().unwrap());
   442	    let n_stress = stress_samples.len();
   443	    let stress_p50 = percentile_ceil(&stress_samples, 50, 100);
   444	    let stress_p99 = percentile_ceil(&stress_samples, 99, 100);
   445	
   446	    // REPORT-ONLY (mirrors the canonical synthetic AC-019 disposition, HITL
   447	    // 2026-06-01): synthetic isotropic data cannot meet the baseline-relative
   448	    // `max(baseline_p99*N, floor)` bound, so the devloop does not assert it.
   449	    // The verdict-quality AC-019 signal is the real-corpus canonical gate.
   450	    //
   451	    // The first line is the SAME keyed `DEVLOOP_NUMBERS` schema as AC-013 /
   452	    // AC-013b (PR-7's stable contract): p50_ms/p99_ms carry the stress-tail
   453	    // percentiles; recall_at_10=NA. The AC-019-specific detail (baseline,
   454	    // thread shape, wall time, disposition) follows on a separate line so the
   455	    // common contract stays uniform across all three ACs.
   456	    emit_numbers("019", report.nodes, n_stress, (stress_p50, stress_p99), None, &cache_field(&report, embedder), embedder);
   457	    eprintln!(
   458	        "DEVLOOP_AC019_DETAIL ac=019 threads={threads} per_thread={per} stress_ms={se} \
   459	         baseline_p99_ms={bp} stress_p50_ms={sp50} stress_p99_ms={sp99} disposition=report_only",
   460	        threads = DEVLOOP_AC019_THREADS,
   461	        per = DEVLOOP_AC019_QUERIES_PER_THREAD,
   462	        se = stress_elapsed.as_millis(),
   463	        bp = baseline_p99.as_millis(),
   464	        sp50 = stress_p50.as_millis(),
   465	        sp99 = stress_p99.as_millis(),
   466	    );
   467	}

