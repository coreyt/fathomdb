   482	// ── Caching embedder ──────────────────────────────────────────────────--
   483	
   484	/// Wraps any [`Embedder`] with an on-disk, per-(model, subset) vector
   485	/// cache keyed by `sha256(identity || subset_label || doc-id manifest)`.
   486	/// Serves repeat embeds of the same text from memory; persists the full
   487	/// embed set deterministically (sorted by text digest) so two equivalent
   488	/// constructions produce byte-identical cache files.
   489	struct CachingEmbedder {
   490	    inner: Arc<dyn Embedder>,
   491	    identity: EmbedderIdentity,
   492	    /// text-sha256 -> vector
   493	    cache: RwLock<VecCache>,
   494	    cache_path: PathBuf,
   495	    meta_path: PathBuf,
   496	    doc_manifest_sha: String,
   497	    subset_label: String,
   498	    /// `true` if a valid cache file was loaded at construction.
   499	    loaded_from_disk: bool,
   500	    /// `Some(reason)` when construction was a cache miss (cold/partial/
   501	    /// stale); `None` on a trusted hit. Observable counterpart to the
   502	    /// `CORPUS_CACHE_MISS` log line so tests can lock the loud-miss
   503	    /// contract without scraping stderr.
   504	    miss_reason: Option<String>,
   505	    /// distinct texts embedded live (misses) since construction.
   506	    live_misses: AtomicUsize,
   507	}
   508	
   509	impl CachingEmbedder {
   510	    fn load(
   511	        inner: Arc<dyn Embedder>,
   512	        identity: EmbedderIdentity,
   513	        cache_dir: PathBuf,
   514	        subset_label: &str,
   515	        docs: &[Doc],
   516	    ) -> Self {
   517	        let doc_manifest_sha = doc_manifest_sha(docs);
   518	        let key = cache_key(&identity, subset_label, &doc_manifest_sha);
   519	        let cache_path = cache_dir.join(format!("{key}.bin"));
   520	        let meta_path = cache_dir.join(format!("{key}.meta.json"));
   521	
   522	        // Every miss — cold (no file), partial (blob xor sidecar), or
   523	        // stale/corrupt — is LOUD: a `CORPUS_CACHE_MISS reason=…` line plus
   524	        // an observable `miss_reason` on the returned embedder. A miss never
   525	        // fails; we fall through to live embedding.
   526	        let (cache, loaded, miss_reason) =
   527	            match read_cache(&cache_path, &meta_path, &identity, &doc_manifest_sha) {
   528	                Ok(Some(entries)) => (entries, true, None),
   529	                Ok(None) => (HashMap::new(), false, Some("cold".to_string())),
   530	                Err(reason) => (HashMap::new(), false, Some(reason)),
   531	            };
   532	        if let Some(reason) = &miss_reason {
   533	            eprintln!(
   534	                "CORPUS_CACHE_MISS reason={reason} label={subset_label} path={}",
   535	                cache_path.display()
   536	            );
   537	        }
   538	
   539	        Self {
   540	            inner,
   541	            identity,
   542	            cache: RwLock::new(cache),
   543	            cache_path,
   544	            meta_path,
   545	            doc_manifest_sha,
   546	            subset_label: subset_label.to_string(),
   547	            loaded_from_disk: loaded,
   548	            miss_reason,
   549	            live_misses: AtomicUsize::new(0),
   550	        }
   551	    }
   552	
   553	    /// Persist the current embed set atomically. Returns
   554	    /// `(loaded_from_disk, live_miss_count)`. A no-op rewrite on a fully
   555	    /// warm run (loaded + zero misses) is skipped so warm runs do no disk
   556	    /// I/O; otherwise the blob is written deterministically.
   557	    fn persist(&self) -> (bool, usize) {
   558	        let live = self.live_misses.load(Ordering::Relaxed);
   559	        if self.loaded_from_disk && live == 0 {
   560	            return (true, 0);
   561	        }
   562	        if let Err(e) = self.write_cache() {
   563	            eprintln!(
   564	                "CORPUS_CACHE_WRITE_FAIL reason={e} label={} path={}",
   565	                self.subset_label,
   566	                self.cache_path.display()
   567	            );
   568	        }
   569	        (self.loaded_from_disk, live)
   570	    }
   571	
   572	    fn write_cache(&self) -> Result<(), String> {
   573	        if let Some(parent) = self.cache_path.parent() {
   574	            fs::create_dir_all(parent).map_err(|e| format!("mkdir {}: {e}", parent.display()))?;
   575	        }
   576	        let dim = self.identity.dimension as usize;
   577	        let guard = self.cache.read().expect("cache read lock");
   578	
   579	        // Deterministic order: sort entries by their text digest.
   580	        let mut keys: Vec<&[u8; 32]> = guard.keys().collect();
   581	        keys.sort_unstable();
   582	
   583	        let mut blob: Vec<u8> = Vec::with_capacity(12 + keys.len() * (32 + dim * 4));
   584	        blob.extend_from_slice(&CACHE_FORMAT_VERSION.to_le_bytes());
   585	        blob.extend_from_slice(&(self.identity.dimension).to_le_bytes());
   586	        blob.extend_from_slice(&(keys.len() as u32).to_le_bytes());
   587	        for k in &keys {
   588	            let v = &guard[*k];
   589	            debug_assert_eq!(v.len(), dim, "cached vector dim mismatch");
   590	            blob.extend_from_slice(&k[..]);
   591	            for f in v {
   592	                blob.extend_from_slice(&f.to_le_bytes());
   593	            }
   594	        }
   595	        let entry_count = keys.len();
   596	        drop(guard);
   597	
   598	        let meta = serde_json::json!({
   599	            "format_version": CACHE_FORMAT_VERSION,
   600	            "tool_version": TOOL_VERSION,
   601	            "identity": {
   602	                "name": self.identity.name,
   603	                "revision": self.identity.revision,
   604	                "dimension": self.identity.dimension,
   605	            },
   606	            "subset_label": self.subset_label,
   607	            "doc_manifest_sha": self.doc_manifest_sha,
   608	            "dim": self.identity.dimension,
   609	            "entry_count": entry_count,
   610	        });
   611	        let meta_bytes = serde_json::to_vec_pretty(&meta).map_err(|e| e.to_string())?;
   612	
   613	        atomic_write(&self.cache_path, &blob)?;
   614	        atomic_write(&self.meta_path, &meta_bytes)?;
   615	        Ok(())
   616	    }
   617	}
