   246	// ── Shared setup ───────────────────────────────────────────────────────────
   247	
   248	/// Open the engine, ingest, drain, and hard-assert the structural invariants
   249	/// (batch-collapse RED-shows here). Returns the opened engine, the held-out
   250	/// query set, the ingest report, and the embedder label.
   251	fn setup() -> Option<(tempfile::TempDir, Engine, Vec<HeldOutQuery>, corpus_harness::IngestReport, &'static str)>
   252	{
   253	    let (fx, embedder) = devloop_fixture();
   254	    let (dir, engine) = fx.open_or_skip()?;
   255	    let report = fx.ingest_into(&engine);
   256	    engine.drain(15_000).expect("drain after ingest");
   257	
   258	    // STRUCTURAL invariants — HARD assert (batch-collapse `4a95cfd` RED-shows
   259	    // here: a collapsed batch leaves vector_default short of the ingested doc
   260	    // count).
   261	    fx.assert_vec0_row_count_matches_ingest(&engine);
   262	    fx.assert_fts_index_populated(&engine);
   263	
   264	    let queries = fx.query_set(DEVLOOP_SAMPLES, DEVLOOP_SEED);
   265	    assert!(!queries.is_empty(), "devloop query_set produced no queries");
   266	    Some((dir, engine, queries, report, embedder))
   267	}
