   331	    /// cache cannot capture the projection embeds.
   332	    pub fn ingest_into(&self, engine: &Engine) -> IngestReport {
   333	        let embedder = self.ensure_embedder();
   334	        let (nodes, edges, edges_by_relation) = corpus_subset::ingest(engine, &self.docs);
