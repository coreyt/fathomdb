    74	// ── HITL-locked devloop budget (2026-06-01) ───────────────────────────────
    75	//
    76	// N≈1000 (`CorpusFixture::medium`). Soft budget ≈ 2–3× the canonical 10k tier
    77	// (p50 80 / p99 300) at 10× smaller N: loose enough that ~10× small-N sample
    78	// noise does not flap, tight enough that the scanner-throughput regression
    79	// (orders-of-magnitude inflation) trips. Recall floor 0.85 (the canonical 0.90
    80	// is the N=7667 ANN-fidelity anchor; small-N fidelity is noisier).
    81	
    82	/// Soft p50 budget — WARN only.
    83	const DEVLOOP_BUDGET_P50: Duration = Duration::from_millis(50);
    84	/// Soft p99 budget — WARN only.
    85	const DEVLOOP_BUDGET_P99: Duration = Duration::from_millis(150);
    86	/// Soft recall@10 floor — WARN only.
    87	const DEVLOOP_RECALL_FLOOR: f64 = 0.85;
    88	/// Catastrophic ceiling multiplier over the soft budget — HARD assert.
    89	/// 10× headroom: an orders-of-magnitude scanner regression clears it; routine
    90	/// small-N noise never does.
    91	const DEVLOOP_CATASTROPHIC_MULT: u32 = 10;
    92	
    93	/// Held-out query sample size for the latency + recall passes.
    94	const DEVLOOP_SAMPLES: usize = 100;
    95	/// Fixed seed so the query set (and therefore the measurement) is reproducible
    96	/// run-to-run for trend tracking.
    97	const DEVLOOP_SEED: u64 = 0x0DEF_1009_0DEF_1009;
    98	
    99	// AC-019 devloop stress shape — modest, report-only.
   100	const DEVLOOP_AC019_THREADS: usize = 4;
   101	const DEVLOOP_AC019_QUERIES_PER_THREAD: usize = 50;
   102	
   103	// ── Embedder selection ─────────────────────────────────────────────────────
   104	
   105	/// Opt-in real-embedder path: `DEVLOOP_REAL_EMBEDDER=1`. Requires the
   106	/// `default-embedder` feature too (the fixture SKIPs otherwise). Default is
   107	/// synthetic, the always-runs inner-loop signal.
   108	fn real_embedder_requested() -> bool {
   109	    matches!(std::env::var("DEVLOOP_REAL_EMBEDDER"), Ok(v) if v == "1" || v.eq_ignore_ascii_case("true"))
   110	}
   111	
   112	/// Build the N≈1000 devloop fixture. Synthetic by default; real BGE when
   113	/// opted in (and available). Returns the fixture plus a label for the
   114	/// `DEVLOOP_NUMBERS embedder=` field.
   115	fn devloop_fixture() -> (CorpusFixture, &'static str) {
   116	    if real_embedder_requested() {
   117	        (CorpusFixture::medium().with_real_embedder(), "real")
   118	    } else {
   119	        (CorpusFixture::medium().with_synthetic_embedder(), "synthetic")
   120	    }
   121	}
   122	
   123	/// Reconstruct an embedder that produces byte-identical vectors to the one the
   124	/// fixture used, for the f32 brute-force recall ground truth. Synthetic
   125	/// vectors depend only on `dim` + text, so `VaryingEmbedder::new` matches the
   126	/// fixture's caching wrapper exactly.
   127	#[cfg(feature = "default-embedder")]
   128	fn ground_truth_embedder(real: bool) -> Arc<dyn Embedder> {
   129	    if real {
   130	        Arc::new(fathomdb_embedder::CandleBgeEmbedder::new().expect("construct real bge embedder"))
   131	    } else {
   132	        Arc::new(VaryingEmbedder::new(CORPUS_DIM))
   133	    }
   134	}
   135	
   136	#[cfg(not(feature = "default-embedder"))]
   137	fn ground_truth_embedder(_real: bool) -> Arc<dyn Embedder> {
   138	    // Real path is unreachable here — the fixture SKIPs without the feature.
   139	    Arc::new(VaryingEmbedder::new(CORPUS_DIM))
   140	}
