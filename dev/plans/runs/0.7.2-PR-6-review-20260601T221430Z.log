   142	// ── Small local stats helper (each test file is its own crate) ─────────────
   143	
   144	/// Inclusive (ceil) percentile over a latency sample, mirroring
   145	/// `perf_gates.rs::percentile_ceil`'s contract for parity of reported numbers.
   146	fn percentile_ceil(samples: &[Duration], numerator: usize, denominator: usize) -> Duration {
   147	    if samples.is_empty() {
   148	        return Duration::ZERO;
   149	    }
   150	    let mut sorted = samples.to_vec();
   151	    sorted.sort_unstable();
   152	    // index = ceil(p/100 * n) - 1, clamped into range.
   153	    let rank = (sorted.len() * numerator).div_ceil(denominator);
   154	    let idx = rank.saturating_sub(1).min(sorted.len() - 1);
   155	    sorted[idx]
   156	}
   157	
   158	// ── Reporting (the stable `DEVLOOP_NUMBERS` contract PR-7 consumes) ─────────
   159	
   160	/// Cache disposition string for the `cache=` field, derived from the ingest
   161	/// report. `hit` = warm; `cold`/`<reason>` = a loud miss; `na` = synthetic
   162	/// (the cache is irrelevant — synthetic embed is instant).
   163	fn cache_field(report: &corpus_harness::IngestReport, embedder: &str) -> String {
   164	    if embedder == "synthetic" {
   165	        return "na".to_string();
   166	    }
   167	    match &report.cache_miss_reason {
   168	        None => "hit".to_string(),
   169	        Some(reason) => reason.replace(' ', "_"),
   170	    }
   171	}
   172	
   173	/// Emit the stable, parseable trend line. `recall` is `None` for the
   174	/// latency-only AC-013 pass.
   175	fn emit_numbers(
   176	    ac: &str,
   177	    n: usize,
   178	    samples: usize,
   179	    (p50, p99): (Duration, Duration),
   180	    recall: Option<f64>,
   181	    cache: &str,
   182	    embedder: &str,
   183	) {
   184	    let recall_field = match recall {
   185	        Some(r) => format!("{r:.4}"),
   186	        None => "NA".to_string(),
   187	    };
   188	    eprintln!(
   189	        "DEVLOOP_NUMBERS ac={ac} n={n} samples={samples} p50_ms={p50} p99_ms={p99} \
   190	         recall_at_10={recall_field} cache={cache} embedder={embedder}",
   191	        p50 = p50.as_millis(),
   192	        p99 = p99.as_millis(),
   193	    );
   194	}
   195	
   196	/// Notify-only soft-budget check for latency. Prints a loud WARN per breached
   197	/// metric; never fails.
   198	fn warn_if_over_latency(ac: &str, p50: Duration, p99: Duration) {
   199	    if p50 > DEVLOOP_BUDGET_P50 {
   200	        eprintln!(
   201	            "DEVLOOP_PERF_WARN ac={ac} metric=p50 value_ms={} budget_ms={} status=OVER",
   202	            p50.as_millis(),
   203	            DEVLOOP_BUDGET_P50.as_millis(),
   204	        );
   205	    }
   206	    if p99 > DEVLOOP_BUDGET_P99 {
   207	        eprintln!(
   208	            "DEVLOOP_PERF_WARN ac={ac} metric=p99 value_ms={} budget_ms={} status=OVER",
   209	            p99.as_millis(),
   210	            DEVLOOP_BUDGET_P99.as_millis(),
   211	        );
   212	    }
   213	}
   214	
   215	/// Notify-only soft-floor check for recall. Prints a loud WARN if under; never
   216	/// fails.
   217	fn warn_if_under_recall(ac: &str, recall: f64) {
   218	    if recall < DEVLOOP_RECALL_FLOOR {
   219	        eprintln!(
   220	            "DEVLOOP_PERF_WARN ac={ac} metric=recall_at_10 value={recall:.4} floor={floor:.2} status=UNDER",
   221	            floor = DEVLOOP_RECALL_FLOOR,
   222	        );
   223	    }
   224	}
   225	
   226	/// The ONE hard latency gate: a catastrophic ceiling at 10× the soft budget.
   227	/// Routine small-N noise never clears it; the scanner-throughput regression
   228	/// (orders-of-magnitude inflation) does. This is the RED-shows hook for
   229	/// `53a270d`.
   230	fn enforce_catastrophic_ceiling(ac: &str, p50: Duration, p99: Duration) {
   231	    let ceil_p50 = DEVLOOP_BUDGET_P50 * DEVLOOP_CATASTROPHIC_MULT;
   232	    let ceil_p99 = DEVLOOP_BUDGET_P99 * DEVLOOP_CATASTROPHIC_MULT;
   233	    assert!(
   234	        p50 <= ceil_p50,
   235	        "DEVLOOP CATASTROPHIC ({ac}): p50={p50:?} > {ceil_p50:?} (10× soft budget) — \
   236	         an orders-of-magnitude latency regression (e.g. projection-scanner throughput, \
   237	         see 53a270d), not sample noise"
   238	    );
   239	    assert!(
   240	        p99 <= ceil_p99,
   241	        "DEVLOOP CATASTROPHIC ({ac}): p99={p99:?} > {ceil_p99:?} (10× soft budget) — \
   242	         an orders-of-magnitude latency regression, not sample noise"
   243	    );
   244	}
