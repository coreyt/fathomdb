   636	// ── Cache key + IO helpers ────────────────────────────────────────────--
   637	
   638	fn text_sha256(text: &str) -> [u8; 32] {
   639	    let mut h = Sha256::new();
   640	    h.update(text.as_bytes());
   641	    h.finalize().into()
   642	}
   643	
   644	/// sha256 over the sorted, deduped doc-id list (newline-joined). Stable
   645	/// regardless of the doc set's in-memory order.
   646	fn doc_manifest_sha(docs: &[Doc]) -> String {
   647	    let mut ids: Vec<&str> = docs.iter().map(|d| d.doc_id.as_str()).collect();
   648	    ids.sort_unstable();
   649	    ids.dedup();
   650	    let mut h = Sha256::new();
   651	    for id in ids {
   652	        h.update(id.as_bytes());
   653	        h.update(b"\n");
   654	    }
   655	    hex(&h.finalize())
   656	}
   657	
   658	/// Cache file stem: `sha256(name \0 revision \0 dim \0 label \0 manifest)`.
   659	/// Any of identity (name/revision/dim), subset label, or doc-manifest
   660	/// changing yields a different file — the invalidation contract.
   661	fn cache_key(identity: &EmbedderIdentity, label: &str, doc_manifest_sha: &str) -> String {
   662	    let mut h = Sha256::new();
   663	    h.update(identity.name.as_bytes());
   664	    h.update(b"\0");
   665	    h.update(identity.revision.as_bytes());
   666	    h.update(b"\0");
   667	    h.update(identity.dimension.to_le_bytes());
   668	    h.update(b"\0");
   669	    h.update(label.as_bytes());
   670	    h.update(b"\0");
   671	    h.update(doc_manifest_sha.as_bytes());
   672	    hex(&h.finalize())
   673	}
   674	
   675	fn hex(bytes: &[u8]) -> String {
   676	    let mut s = String::with_capacity(bytes.len() * 2);
   677	    for b in bytes {
   678	        s.push_str(&format!("{b:02x}"));
   679	    }
   680	    s
   681	}
