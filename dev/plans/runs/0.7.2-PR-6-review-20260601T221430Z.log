   269	// ── AC-013 devloop — vector retrieval latency ──────────────────────────────
   270	
   271	#[test]
   272	fn ac_013_devloop() {
   273	    let Some((_dir, engine, queries, report, embedder)) = setup() else {
   274	        return;
   275	    };
   276	
   277	    // Warmup pass (discarded), then measure — mirrors the canonical protocol.
   278	    for q in &queries {
   279	        let _ = engine.search(&q.text).expect("warmup search");
   280	    }
   281	    let mut samples = Vec::with_capacity(queries.len());
   282	    for q in &queries {
   283	        let started = Instant::now();
   284	        let _ = engine.search(&q.text).expect("measure search");
   285	        samples.push(started.elapsed());
   286	    }
   287	
   288	    let p50 = percentile_ceil(&samples, 50, 100);
   289	    let p99 = percentile_ceil(&samples, 99, 100);
   290	
   291	    emit_numbers("013", report.nodes, samples.len(), (p50, p99), None, &cache_field(&report, embedder), embedder);
   292	
   293	    // Latency gates apply on the SYNTHETIC path only — there `search` embed is
   294	    // instant, so the measured latency isolates RETRIEVAL (the same reason
   295	    // canonical AC-013 uses the synthetic embedder). On the real path the
   296	    // numbers are report-only: the warmup pass primes the in-memory query
   297	    // cache so the measure pass is embed-cache-warm, but tying retrieval gates
   298	    // to a candle-dependent run would conflate embed and retrieval cost. Real
   299	    // is the RECALL signal (see ac_013b_devloop); synthetic is the LATENCY one.
   300	    if embedder == "synthetic" {
   301	        warn_if_over_latency("013", p50, p99); // notify-only
   302	        enforce_catastrophic_ceiling("013", p50, p99); // hard (scanner regression RED-shows here)
   303	    } else {
   304	        eprintln!("DEVLOOP_PERF_INFO ac=013 metric=latency disposition=report_only embedder={embedder}");
   305	    }
   306	}
   307	
   308	// ── AC-013b devloop — recall@10 ANN fidelity (notify-only) ─────────────────
   309	
   310	#[test]
   311	fn ac_013b_devloop() {
   312	    let Some((_dir, engine, queries, report, embedder)) = setup() else {
   313	        return;
   314	    };
   315	
   316	    // f32 brute-force ground truth over the SAME model (ANN fidelity, NOT
   317	    // IR-relevance) — mirrors the canonical AC-013b SQL (lib.rs:2317-2342):
   318	    // rowid lookup against vector_default, body fetch against canonical_nodes
   319	    // by write_cursor. The recall metric is `prod top-10 ∩ f32-GT top-10 / 10`.
   320	    let gt_embedder = ground_truth_embedder(embedder == "real");
   321	    let db_path = engine.path().to_path_buf();
   322	    let conn = rusqlite::Connection::open(&db_path).expect("raw ground-truth conn");
   323	    conn.pragma_update(None, "query_only", "ON").ok();
   324	
   325	    let mut total_hits = 0usize;
   326	    let mut total_queries = 0usize;
   327	    for q in &queries {
   328	        let vector = gt_embedder.embed(&q.text).expect("embed gt");
   329	        let vector_json = serde_json::to_string(&vector).expect("json");
   330	
   331	        let mut gt_rowid_stmt = conn
   332	            .prepare(
   333	                "SELECT rowid FROM vector_default WHERE embedding MATCH vec_f32(?1) \
   334	                 ORDER BY distance LIMIT 10",
   335	            )
   336	            .expect("prepare gt rowid");
   337	        let gt_rowids: Vec<i64> = gt_rowid_stmt
   338	            .query_map([&vector_json], |row| row.get::<_, i64>(0))
   339	            .expect("gt rowid query")
   340	            .filter_map(Result::ok)
   341	            .collect();
   342	
   343	        let mut body_stmt = conn
   344	            .prepare("SELECT body FROM canonical_nodes WHERE write_cursor = ?1 LIMIT 1")
   345	            .expect("prepare body");
   346	        let mut gt_bodies = Vec::with_capacity(gt_rowids.len());
   347	        for rowid in &gt_rowids {
   348	            if let Ok(body) = body_stmt.query_row([rowid], |row| row.get::<_, String>(0)) {
   349	                gt_bodies.push(body);
   350	            }
   351	        }
   352	
   353	        let prod = engine.search(&q.text).expect("measure search").results;
   354	        let gt_set: std::collections::HashSet<&String> = gt_bodies.iter().collect();
   355	        total_hits += prod.iter().filter(|b| gt_set.contains(b)).count();
   356	        total_queries += 1;
   357	    }
   358	
   359	    let recall = total_hits as f64 / (10.0 * total_queries.max(1) as f64);
   360	    // recall is a quality signal, not a latency one — pass NA latency fields.
   361	    emit_numbers(
   362	        "013b",
   363	        report.nodes,
   364	        total_queries,
   365	        (Duration::ZERO, Duration::ZERO),
   366	        Some(recall),
   367	        &cache_field(&report, embedder),
   368	        embedder,
   369	    );
   370	
   371	    // The 0.85 floor is a REAL-embedder (dense BGE) ANN-fidelity number. The
   372	    // synthetic `VaryingEmbedder` places only 6 non-zero coords in 768 dims, so
   373	    // sign-bit quantization cannot separate documents and measured recall vs
   374	    // exact-f32 is ~0.35 at N≈1000 — a property of the synthetic DATA, not a
   375	    // regression (the same reason AC-019 is report-only on synthetic). So:
   376	    //   - synthetic → REPORT-ONLY (emit the number for PR-7 trend tracking; no
   377	    //     WARN, which would otherwise fire every run and train devs to ignore
   378	    //     it). A recall *regression* still shows as a downward trend PR-7 flags.
   379	    //   - real      → notify-only WARN against the 0.85 floor.
