   349	    /// Held-out query set (EU-0 §1.2): deterministically shuffle the doc
   350	    /// pool with `seed`, synthesize a title-or-lead query per doc (never
   351	    /// the verbatim body), and return up to `n` of them. Each query carries
   352	    /// its source doc for target exclusion at recall time.
   353	    pub fn query_set(&self, n: usize, seed: u64) -> Vec<HeldOutQuery> {
   354	        if self.docs.is_empty() {
   355	            return Vec::new();
   356	        }
   357	        let mut indices: Vec<usize> = (0..self.docs.len()).collect();
   358	        // Deterministic Fisher-Yates so queries spread across sources
   359	        // rather than clustering at the head of the sorted list.
   360	        let mut rng = SplitMix64::new(seed);
   361	        for i in (1..indices.len()).rev() {
   362	            let j = rng.next_in(i + 1);
   363	            indices.swap(i, j);
   364	        }
   365	        let mut out = Vec::with_capacity(n.min(self.docs.len()));
   366	        for &idx in &indices {
   367	            if out.len() >= n {
   368	                break;
   369	            }
   370	            let doc = &self.docs[idx];
   371	            if let Some(text) = synth_query(doc) {
   372	                out.push(HeldOutQuery {
   373	                    text,
   374	                    target_doc_id: doc.doc_id.clone(),
   375	                    target_body: doc.body.clone(),
   376	                });
   377	            }
   378	        }
   379	        out
   380	    }
