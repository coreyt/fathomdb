   220	/// `53a270d`.
   221	fn enforce_catastrophic_ceiling(ac: &str, p50: Duration, p99: Duration) {
   222	    let ceil_p50 = DEVLOOP_BUDGET_P50 * DEVLOOP_CATASTROPHIC_MULT;
   223	    let ceil_p99 = DEVLOOP_BUDGET_P99 * DEVLOOP_CATASTROPHIC_MULT;
   224	    assert!(
   225	        p50 <= ceil_p50,
   226	        "DEVLOOP CATASTROPHIC ({ac}): p50={p50:?} > {ceil_p50:?} (10× soft budget) — \
   227	         an orders-of-magnitude latency regression (e.g. projection-scanner throughput, \
   228	         see 53a270d), not sample noise"
   229	    );
   230	    assert!(
   231	        p99 <= ceil_p99,
   232	        "DEVLOOP CATASTROPHIC ({ac}): p99={p99:?} > {ceil_p99:?} (10× soft budget) — \
   233	         an orders-of-magnitude latency regression, not sample noise"
   234	    );
   235	}
   236	
   237	// ── Shared setup ───────────────────────────────────────────────────────────
   238	
   239	/// Open the engine, ingest, drain, and hard-assert the structural invariants
   240	/// (batch-collapse RED-shows here). Returns the opened engine, the held-out
   241	/// query set, the ingest report, and the embedder label.
   242	fn setup() -> Option<(tempfile::TempDir, Engine, Vec<HeldOutQuery>, corpus_harness::IngestReport, &'static str)>
   243	{
   244	    let (fx, embedder) = devloop_fixture();
   245	    let (dir, engine) = fx.open_or_skip()?;
   246	    let report = fx.ingest_into(&engine);
   247	    engine.drain(15_000).expect("drain after ingest");
   248	
   249	    // STRUCTURAL invariants — HARD assert (batch-collapse `4a95cfd` RED-shows
   250	    // here: a collapsed batch leaves vector_default short of the ingested doc
   251	    // count).
   252	    fx.assert_vec0_row_count_matches_ingest(&engine);
   253	    fx.assert_fts_index_populated(&engine);
   254	
   255	    let queries = fx.query_set(DEVLOOP_SAMPLES, DEVLOOP_SEED);
   256	    assert!(!queries.is_empty(), "devloop query_set produced no queries");
   257	    Some((dir, engine, queries, report, embedder))
   258	}
