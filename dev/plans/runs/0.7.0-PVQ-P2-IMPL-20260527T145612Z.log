{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DaLk99tNhFiHxoBJzB1Pb4","type":"tool_result","content":"90\t    }\n91\t    values\n92\t}\n93\t\n94\tfn long_run_enabled() -> bool {\n95\t    std::env::var_os(\"AGENT_LONG\").is_some()\n96\t}\n97\t\n98\tfn ac020_queries() -> [&'static str; 4] {\n99\t    [\"semantic-0\", \"hybrid-0\", \"semantic-1\", \"hybrid-1\"]\n100\t}\n101\t\n102\tfn seed_ac020_fixture(engine: &Engine) {\n103\t    engine.configure_vector_kind_for_test(\"doc\").expect(\"vector kind\");\n104\t    for i in 0..2 {\n105\t        engine\n106\t            .write(&[PreparedWrite::Node {\n107\t                kind: \"doc\".to_string(),\n108\t                body: format!(\"vector-doc-{i}\"),\n109\t                source_id: None,\n110\t            }])\n111\t            .expect(\"vector-only write\");\n112\t        engine\n113\t            .write(&[PreparedWrite::Node {\n114\t                kind: \"doc\".to_string(),\n115\t                body: format!(\"hybrid doc hybrid-{i}\"),\n116\t                source_id: None,\n117\t            }])\n118\t            .expect(\"hybrid write\");\n119\t    }\n120\t    engine.drain(10_000).expect(\"drain\");\n121\t}\n122\t\n123\tfn run_ac020_mix(engine: &Engine) {\n124\t    for _ in 0..AC020_ROUNDS_PER_THREAD {\n125\t        for query in ac020_queries() {\n126\t            let result = engine.search(query).expect(\"search\");\n127\t            assert!(!result.results.is_empty(), \"read-mix query {query} must yield a result\");\n128\t        }\n129\t    }\n130\t}\n131\t\n132\t// ── AC-012 / AC-013 / AC-019 retrieval perf-gate fixtures ───────────────────\n133\t//\n134\t// Per `dev/plans/0.6.0-Phase-9-Pack-D-retrieval-perf-fixtures.md` and\n135\t// ADR-0.6.0-{text-query,retrieval}-latency-gates the canonical fixture\n136\t// scale is 1,000,000 chunk rows / 768-d vectors. Seeding 1M rows under\n137\t// AGENT_LONG=1 on the aarch64 dev runner is hours-of-wall-clock; the\n138\t// canonical x86_64 tier-1 CI runner sets `AC_FULL_SCALE=1` to honor\n139\t// the 1M scale. AGENT_LONG=1 on the dev runner uses the env-tunable\n140\t// scale below (AC-007a/b runner-pin precedent) and asserts the same\n141\t// budget. See `dev/test-plan.md` § Current Perf Attribution and\n142\t// `dev/notes/performance-whitepaper-notes.md` for measured medians.\n143\tconst AC012_DEFAULT_N: usize = 100_000;\n144\tconst AC013_DEFAULT_N: usize = 50_000;\n145\tconst AC019_THREADS: usize = 8;\n146\tconst AC019_QUERIES_PER_THREAD: usize = 250;\n147\tconst AC012_BUDGET_P50: Duration = Duration::from_millis(20);\n148\tconst AC012_BUDGET_P99: Duration = Duration::from_millis(150);\n149\t// Pack 2 RED re-pin (dev/plans/prompts/0.7.0-PERF-VECTOR-QUANT-HANDOFF.md\n150\t// § Pack 2.1): canonical-CI N=1M observed p50=2048 ms / p99=2327 ms on the\n151\t// f32-brute-force read path (dev/plans/runs/0.7.0-PERF-EXP-W4.1-ac013-\n152\t// canonical-output.json). HITL-locked target post bit-quant + rerank is\n153\t// ≤ 80 / 300 ms — RED at canonical scale until P2-IMPL lands.\n154\tconst AC013_BUDGET_P50: Duration = Duration::from_millis(80);\n155\tconst AC013_BUDGET_P99: Duration = Duration::from_millis(300);\n156\t// Recall floor for AC-013b: HITL-locked ≥ 0.90 at k=10 vs f32 ground truth\n157\t// (dev/plans/0.7.0-HITL-recommendations.md:89; ADR-0.7.0-vector-binary-\n158\t// quant.md § 2 point 4).\n159\tconst AC013B_RECALL_FLOOR: f64 = 0.90;\n160\tconst AC019_STRESS_FLOOR: Duration = Duration::from_millis(150);\n161\tconst AC019_STRESS_MULT: u32 = 10;\n162\tconst RETRIEVAL_VECTOR_DIM: u32 = 768;\n163\t\n164\tfn env_usize(key: &str, default_full: usize, default_short: usize) -> usize {\n165\t    if let Ok(raw) = std::env::var(key) {\n166\t        if let Ok(parsed) = raw.parse::<usize>() {\n167\t            return parsed;\n168\t        }\n169\t    }\n170\t    if std::env::var_os(\"AC_FULL_SCALE\").is_some() {\n171\t        default_full\n172\t    } else {\n173\t        default_short\n174\t    }\n175\t}\n176\t\n177\tfn ac012_corpus_n() -> usize {\n178\t    env_usize(\"AC012_CORPUS_N\", 1_000_000, AC012_DEFAULT_N)\n179\t}\n180\t\n181\tfn ac013_corpus_n() -> usize {\n182\t    env_usize(\"AC013_CORPUS_N\", 1_000_000, AC013_DEFAULT_N)\n183\t}\n184\t\n185\t/// Deterministic seeded LCG. Generates reproducible token streams so the\n186\t/// AC-012 corpus and the held-out query set are both byte-stable across\n187\t/// runs (per ADR-0.6.0-text-query-latency-gates \"synthetic-English-like\n188\t/// text with a Zipfian token-frequency distribution\").\n189\tstruct SeededRng {"}]},"parent_tool_use_id":null,"session_id":"b6e0a836-9936-47bb-97d0-253f1fdf54d5","uuid":"789deb47-b71e-48f1-b040-c93261332302","timestamp":"2026-05-27T14:57:04.239Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-0.7.0-PVQ-P2-IMPL-20260527T145612Z/src/rust/crates/fathomdb-engine/tests/perf_gates.rs","content":"    }\n    values\n}\n\nfn long_run_enabled() -> bool {\n    std::env::var_os(\"AGENT_LONG\").is_some()\n}\n\nfn ac020_queries() -> [&'static str; 4] {\n    [\"semantic-0\", \"hybrid-0\", \"semantic-1\", \"hybrid-1\"]\n}\n\nfn seed_ac020_fixture(engine: &Engine) {\n    engine.configure_vector_kind_for_test(\"doc\").expect(\"vector kind\");\n    for i in 0..2 {\n        engine\n            .write(&[PreparedWrite::Node {\n                kind: \"doc\".to_string(),\n                body: format!(\"vector-doc-{i}\"),\n                source_id: None,\n            }])\n            .expect(\"vector-only write\");\n        engine\n            .write(&[PreparedWrite::Node {\n                kind: \"doc\".to_string(),\n                body: format!(\"hybrid doc hybrid-{i}\"),\n                source_id: None,\n            }])\n            .expect(\"hybrid write\");\n    }\n    engine.drain(10_000).expect(\"drain\");\n}\n\nfn run_ac020_mix(engine: &Engine) {\n    for _ in 0..AC020_ROUNDS_PER_THREAD {\n        for query in ac020_queries() {\n            let result = engine.search(query).expect(\"search\");\n            assert!(!result.results.is_empty(), \"read-mix query {query} must yield a result\");\n        }\n    }\n}\n\n// ── AC-012 / AC-013 / AC-019 retrieval perf-gate fixtures ───────────────────\n//\n// Per `dev/plans/0.6.0-Phase-9-Pack-D-retrieval-perf-fixtures.md` and\n// ADR-0.6.0-{text-query,retrieval}-latency-gates the canonical fixture\n// scale is 1,000,000 chunk rows / 768-d vectors. Seeding 1M rows under\n// AGENT_LONG=1 on the aarch64 dev runner is hours-of-wall-clock; the\n// canonical x86_64 tier-1 CI runner sets `AC_FULL_SCALE=1` to honor\n// the 1M scale. AGENT_LONG=1 on the dev runner uses the env-tunable\n// scale below (AC-007a/b runner-pin precedent) and asserts the same\n// budget. See `dev/test-plan.md` § Current Perf Attribution and\n// `dev/notes/performance-whitepaper-notes.md` for measured medians.\nconst AC012_DEFAULT_N: usize = 100_000;\nconst AC013_DEFAULT_N: usize = 50_000;\nconst AC019_THREADS: usize = 8;\nconst AC019_QUERIES_PER_THREAD: usize = 250;\nconst AC012_BUDGET_P50: Duration = Duration::from_millis(20);\nconst AC012_BUDGET_P99: Duration = Duration::from_millis(150);\n// Pack 2 RED re-pin (dev/plans/prompts/0.7.0-PERF-VECTOR-QUANT-HANDOFF.md\n// § Pack 2.1): canonical-CI N=1M observed p50=2048 ms / p99=2327 ms on the\n// f32-brute-force read path (dev/plans/runs/0.7.0-PERF-EXP-W4.1-ac013-\n// canonical-output.json). HITL-locked target post bit-quant + rerank is\n// ≤ 80 / 300 ms — RED at canonical scale until P2-IMPL lands.\nconst AC013_BUDGET_P50: Duration = Duration::from_millis(80);\nconst AC013_BUDGET_P99: Duration = Duration::from_millis(300);\n// Recall floor for AC-013b: HITL-locked ≥ 0.90 at k=10 vs f32 ground truth\n// (dev/plans/0.7.0-HITL-recommendations.md:89; ADR-0.7.0-vector-binary-\n// quant.md § 2 point 4).\nconst AC013B_RECALL_FLOOR: f64 = 0.90;\nconst AC019_STRESS_FLOOR: Duration = Duration::from_millis(150);\nconst AC019_STRESS_MULT: u32 = 10;\nconst RETRIEVAL_VECTOR_DIM: u32 = 768;\n\nfn env_usize(key: &str, default_full: usize, default_short: usize) -> usize {\n    if let Ok(raw) = std::env::var(key) {\n        if let Ok(parsed) = raw.parse::<usize>() {\n            return parsed;\n        }\n    }\n    if std::env::var_os(\"AC_FULL_SCALE\").is_some() {\n        default_full\n    } else {\n        default_short\n    }\n}\n\nfn ac012_corpus_n() -> usize {\n    env_usize(\"AC012_CORPUS_N\", 1_000_000, AC012_DEFAULT_N)\n}\n\nfn ac013_corpus_n() -> usize {\n    env_usize(\"AC013_CORPUS_N\", 1_000_000, AC013_DEFAULT_N)\n}\n\n/// Deterministic seeded LCG. Generates reproducible token streams so the\n/// AC-012 corpus and the held-out query set are both byte-stable across\n/// runs (per ADR-0.6.0-text-query-latency-gates \"synthetic-English-like\n/// text with a Zipfian token-frequency distribution\").\nstruct SeededRng {","numLines":100,"startLine":90,"totalLines":1264}}}
