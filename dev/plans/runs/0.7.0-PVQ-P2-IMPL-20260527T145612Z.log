{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JBH9KKYYovqDg8HPHKszGs","type":"tool_result","content":"540\t}\n541\t\n542\t#[test]\n543\tfn ac_013b_recall_at_10_floor() {\n544\t    // Pack 2 RED: pre-IMPL the production read path is byte-equal to the\n545\t    // brute-force f32 ground truth, so recall = 1.0 at land time. Post-\n546\t    // P2-IMPL the production path switches to bit-KNN + f32 rerank; this\n547\t    // test then measures how well the candidate set preserves the f32\n548\t    // top-10. HITL-locked floor is 0.90 (see AC013B_RECALL_FLOOR).\n549\t    if !long_run_enabled() {\n550\t        return;\n551\t    }\n552\t\n553\t    let n = ac013_corpus_n();\n554\t    let (_dir, path) = fixture_path(\"ac013b_recall\");\n555\t    let embedder = Arc::new(VaryingEmbedder::new(RETRIEVAL_VECTOR_DIM));\n556\t    let opened = Engine::open_with_embedder_for_test(&path, embedder.clone()).expect(\"open\");\n557\t    let _seed_elapsed = seed_ac013_corpus(&opened.engine, n);\n558\t\n559\t    let queries = ac013_query_bodies(PERF_SAMPLES);\n560\t\n561\t    // Raw read-only connection for the f32 ground-truth pass. sqlite_vec\n562\t    // is process-global after Engine::open, so vec0 vtabs are reachable.\n563\t    // Mirrors the SQL at src/rust/crates/fathomdb-engine/src/lib.rs:2317-\n564\t    // 2342 (rowid lookup against vector_default, body fetch against\n565\t    // canonical_nodes by write_cursor).\n566\t    let db_path = opened.engine.path().to_path_buf();\n567\t    let conn = rusqlite::Connection::open(&db_path).expect(\"raw ground-truth conn\");\n568\t    conn.pragma_update(None, \"query_only\", \"ON\").ok();\n569\t\n570\t    let mut total_hits = 0usize;\n571\t    let mut total_queries = 0usize;\n572\t\n573\t    for q in &queries {\n574\t        let vector = embedder.embed(q).expect(\"embed\");\n575\t        let vector_json = serde_json::to_string(&vector).expect(\"json\");\n576\t\n577\t        let mut gt_rowid_stmt = conn\n578\t            .prepare(\n579\t                \"SELECT rowid\n580\t                 FROM vector_default\n581\t                 WHERE embedding MATCH vec_f32(?1)\n582\t                 ORDER BY distance\n583\t                 LIMIT 10\",\n584\t            )\n585\t            .expect(\"prepare gt rowid\");\n586\t        let gt_rowids: Vec<i64> = gt_rowid_stmt\n587\t            .query_map([&vector_json], |row| row.get::<_, i64>(0))\n588\t            .expect(\"gt rowid query\")\n589\t            .filter_map(|r| r.ok())\n590\t            .collect();\n591\t\n592\t        let mut body_stmt = conn\n593\t            .prepare(\"SELECT body FROM canonical_nodes WHERE write_cursor = ?1 LIMIT 1\")\n594\t            .expect(\"prepare body\");\n595\t        let mut gt_bodies = Vec::with_capacity(gt_rowids.len());\n596\t        for rowid in &gt_rowids {\n597\t            if let Ok(body) = body_stmt.query_row([rowid], |row| row.get::<_, String>(0)) {\n598\t                gt_bodies.push(body);\n599\t            }\n600\t        }\n601\t\n602\t        let prod = opened.engine.search(q).expect(\"measure search\").results;\n603\t\n604\t        let gt_set: std::collections::HashSet<&String> = gt_bodies.iter().collect();\n605\t        let hits = prod.iter().filter(|b| gt_set.contains(b)).count();\n606\t        total_hits += hits;\n607\t        total_queries += 1;\n608\t    }\n609\t\n610\t    let recall = total_hits as f64 / (10.0 * total_queries.max(1) as f64);\n611\t    eprintln!(\"RECALL_NUMBERS n={n} samples={s} recall_at_10={recall:.4}\", s = total_queries,);\n612\t\n613\t    assert!(\n614\t        recall >= AC013B_RECALL_FLOOR,\n615\t        \"AC-013b failed: recall@10 {recall:.4} < floor {floor:.2} at n={n}\",\n616\t        floor = AC013B_RECALL_FLOOR,\n617\t    );\n618\t}\n619\t\n620\t#[test]\n621\tfn ac_017_vector_projection_freshness_p99_le_five_seconds() {\n622\t    let (_dir, path) = fixture_path(\"projection_freshness\");\n623\t    let embedder = Arc::new(DeterministicEmbedder::new(384, Duration::from_millis(1)));\n624\t    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n625\t    opened.engine.configure_vector_kind_for_test(\"doc\").expect(\"vector kind\");\n626\t\n627\t    let mut samples = Vec::with_capacity(PERF_SAMPLES);\n628\t    for i in 0..PERF_SAMPLES {\n629\t        let commit_started = Instant::now();\n630\t        let receipt = opened\n631\t            .engine\n632\t            .write(&[PreparedWrite::Node {\n633\t                kind: \"doc\".to_string(),\n634\t                body: format!(\"projection doc {i}\"),\n635\t                source_id: None,\n636\t            }])\n637\t            .expect(\"write\");\n638\t\n639\t        loop {\n640\t            let result = opened.engine.search(\"projection\").expect(\"search\");\n641\t            if result.projection_cursor >= receipt.cursor {\n642\t                samples.push(commit_started.elapsed());\n643\t                break;\n644\t            }\n645\t            assert!(\n646\t                commit_started.elapsed() < Duration::from_secs(5),\n647\t                \"projection cursor did not reach commit cursor within 5 s for write {}\",\n648\t                receipt.cursor\n649\t            );\n650\t            thread::sleep(Duration::from_millis(1));\n651\t        }\n652\t    }\n653\t\n654\t    let p99 = percentile_ceil(&samples, 99, 100);\n655\t    assert!(\n656\t        p99 <= Duration::from_secs(5),\n657\t        \"AC-017 failed: p99 freshness {:?} exceeded 5 s over {} samples\",\n658\t        p99,\n659\t        samples.len()\n660\t    );\n661\t}\n662\t\n663\t#[test]\n664\tfn ac_018_drain_of_100_vectors_le_two_seconds() {\n665\t    let (_dir, path) = fixture_path(\"drain_100_vectors\");\n666\t    let embedder = Arc::new(DeterministicEmbedder::new(384, Duration::from_millis(1)));\n667\t    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n668\t    opened.engine.configure_vector_kind_for_test(\"doc\").expect(\"vector kind\");\n669\t"}]},"parent_tool_use_id":null,"session_id":"b6e0a836-9936-47bb-97d0-253f1fdf54d5","uuid":"bcd0edcd-c67a-4aa3-b098-4f6e7cdb7ceb","timestamp":"2026-05-27T14:56:49.697Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-0.7.0-PVQ-P2-IMPL-20260527T145612Z/src/rust/crates/fathomdb-engine/tests/perf_gates.rs","content":"}\n\n#[test]\nfn ac_013b_recall_at_10_floor() {\n    // Pack 2 RED: pre-IMPL the production read path is byte-equal to the\n    // brute-force f32 ground truth, so recall = 1.0 at land time. Post-\n    // P2-IMPL the production path switches to bit-KNN + f32 rerank; this\n    // test then measures how well the candidate set preserves the f32\n    // top-10. HITL-locked floor is 0.90 (see AC013B_RECALL_FLOOR).\n    if !long_run_enabled() {\n        return;\n    }\n\n    let n = ac013_corpus_n();\n    let (_dir, path) = fixture_path(\"ac013b_recall\");\n    let embedder = Arc::new(VaryingEmbedder::new(RETRIEVAL_VECTOR_DIM));\n    let opened = Engine::open_with_embedder_for_test(&path, embedder.clone()).expect(\"open\");\n    let _seed_elapsed = seed_ac013_corpus(&opened.engine, n);\n\n    let queries = ac013_query_bodies(PERF_SAMPLES);\n\n    // Raw read-only connection for the f32 ground-truth pass. sqlite_vec\n    // is process-global after Engine::open, so vec0 vtabs are reachable.\n    // Mirrors the SQL at src/rust/crates/fathomdb-engine/src/lib.rs:2317-\n    // 2342 (rowid lookup against vector_default, body fetch against\n    // canonical_nodes by write_cursor).\n    let db_path = opened.engine.path().to_path_buf();\n    let conn = rusqlite::Connection::open(&db_path).expect(\"raw ground-truth conn\");\n    conn.pragma_update(None, \"query_only\", \"ON\").ok();\n\n    let mut total_hits = 0usize;\n    let mut total_queries = 0usize;\n\n    for q in &queries {\n        let vector = embedder.embed(q).expect(\"embed\");\n        let vector_json = serde_json::to_string(&vector).expect(\"json\");\n\n        let mut gt_rowid_stmt = conn\n            .prepare(\n                \"SELECT rowid\n                 FROM vector_default\n                 WHERE embedding MATCH vec_f32(?1)\n                 ORDER BY distance\n                 LIMIT 10\",\n            )\n            .expect(\"prepare gt rowid\");\n        let gt_rowids: Vec<i64> = gt_rowid_stmt\n            .query_map([&vector_json], |row| row.get::<_, i64>(0))\n            .expect(\"gt rowid query\")\n            .filter_map(|r| r.ok())\n            .collect();\n\n        let mut body_stmt = conn\n            .prepare(\"SELECT body FROM canonical_nodes WHERE write_cursor = ?1 LIMIT 1\")\n            .expect(\"prepare body\");\n        let mut gt_bodies = Vec::with_capacity(gt_rowids.len());\n        for rowid in &gt_rowids {\n            if let Ok(body) = body_stmt.query_row([rowid], |row| row.get::<_, String>(0)) {\n                gt_bodies.push(body);\n            }\n        }\n\n        let prod = opened.engine.search(q).expect(\"measure search\").results;\n\n        let gt_set: std::collections::HashSet<&String> = gt_bodies.iter().collect();\n        let hits = prod.iter().filter(|b| gt_set.contains(b)).count();\n        total_hits += hits;\n        total_queries += 1;\n    }\n\n    let recall = total_hits as f64 / (10.0 * total_queries.max(1) as f64);\n    eprintln!(\"RECALL_NUMBERS n={n} samples={s} recall_at_10={recall:.4}\", s = total_queries,);\n\n    assert!(\n        recall >= AC013B_RECALL_FLOOR,\n        \"AC-013b failed: recall@10 {recall:.4} < floor {floor:.2} at n={n}\",\n        floor = AC013B_RECALL_FLOOR,\n    );\n}\n\n#[test]\nfn ac_017_vector_projection_freshness_p99_le_five_seconds() {\n    let (_dir, path) = fixture_path(\"projection_freshness\");\n    let embedder = Arc::new(DeterministicEmbedder::new(384, Duration::from_millis(1)));\n    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n    opened.engine.configure_vector_kind_for_test(\"doc\").expect(\"vector kind\");\n\n    let mut samples = Vec::with_capacity(PERF_SAMPLES);\n    for i in 0..PERF_SAMPLES {\n        let commit_started = Instant::now();\n        let receipt = opened\n            .engine\n            .write(&[PreparedWrite::Node {\n                kind: \"doc\".to_string(),\n                body: format!(\"projection doc {i}\"),\n                source_id: None,\n            }])\n            .expect(\"write\");\n\n        loop {\n            let result = opened.engine.search(\"projection\").expect(\"search\");\n            if result.projection_cursor >= receipt.cursor {\n                samples.push(commit_started.elapsed());\n                break;\n            }\n            assert!(\n                commit_started.elapsed() < Duration::from_secs(5),\n                \"projection cursor did not reach commit cursor within 5 s for write {}\",\n                receipt.cursor\n            );\n            thread::sleep(Duration::from_millis(1));\n        }\n    }\n\n    let p99 = percentile_ceil(&samples, 99, 100);\n    assert!(\n        p99 <= Duration::from_secs(5),\n        \"AC-017 failed: p99 freshness {:?} exceeded 5 s over {} samples\",\n        p99,\n        samples.len()\n    );\n}\n\n#[test]\nfn ac_018_drain_of_100_vectors_le_two_seconds() {\n    let (_dir, path) = fixture_path(\"drain_100_vectors\");\n    let embedder = Arc::new(DeterministicEmbedder::new(384, Duration::from_millis(1)));\n    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n    opened.engine.configure_vector_kind_for_test(\"doc\").expect(\"vector kind\");\n","numLines":130,"startLine":540,"totalLines":1264}}}
