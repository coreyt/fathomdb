# Reproduce the current line-scanning logic in-memory to validate edge cases.
def strip_line(raw, depth):
    out = []
    j = 0
    while j < len(raw):
        if depth == 0 and raw[j:j+2] == '/*':
            depth = 1
            j += 2
        elif depth > 0 and raw[j:j+2] == '/*':
            depth += 1
            j += 2
        elif depth > 0 and raw[j:j+2] == '*/':
            depth -= 1
            j += 2
        elif depth > 0:
            j += 1
        else:
            out.append(raw[j])
            j += 1
    return ''.join(out).strip(), depth

cases = [
    ('nested_then_code', '/* outer /* inner */ still outer */ pub fn legacy_foo() {}', 0),
    ('close_then_code', '*/ pub fn legacy_foo() {}', 1),
    ('mixed_comment_code_comment', '/* text */ pub fn legacy_foo() {} /* text */', 0),
    ('depth_1_2_1_0', '/* /* */ */', 0),
]
for name, raw, depth0 in cases:
    stripped, depth1 = strip_line(raw, depth0)
    print(name, '=>', {'stripped': stripped, 'depth_end': depth1})
