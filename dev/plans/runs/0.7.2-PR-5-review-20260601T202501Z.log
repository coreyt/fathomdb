 succeeded in 0ms:
            .collect();
        candidates.sort_by_key(|w| std::cmp::Reverse(w.len()));
        if let Some(w) = candidates.first() {
            return Some((*w).to_string());
        }
    }
    None
}

fn is_stop_word(w: &str) -> bool {
    matches!(
        w.to_ascii_lowercase().as_str(),
        "their"
            | "there"
            | "these"
            | "those"
            | "which"
            | "would"
            | "could"
            | "about"
            | "after"
            | "before"
            | "where"
            | "while"
            | "subject"
            | "from"
            | "recipients"
            | "file"
            | "project"
            | "redacted"
    )
}

