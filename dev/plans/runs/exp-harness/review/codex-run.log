/bin/bash -lc "python3 - <<'PY'
import json, pathlib, re
base=pathlib.Path('dev/plans/runs/exp-harness/data/transcripts')

def is_boundary(rec,msg):
    if rec.get('type')"'!='"'user' or msg.get('role')"'!='"'user': return False
    c=msg.get('content')
    if isinstance(c,list) and any(isinstance(b,dict) and b.get('type')=='tool_result' for b in c): return False
    if rec.get('isMeta'):
        return isinstance(c,str) and 'sent a message' in c
    return True

def text_of(c):
    if isinstance(c,str): return c
    if isinstance(c,list): return ' '.join(b.get('text','') for b in c if isinstance(b,dict) and b.get('type')=='text')
    return ''
for path in sorted(base.glob('*.jsonl')):
    cur=-1; segs=[]
    tool_counts={}; tool_paths=[]; notes=[]; assistants=[]
    for ln,line in enumerate(path.read_text().splitlines(),1):
        if not line.strip(): continue
        rec=json.loads(line); msg=rec.get('message') or {}; c=msg.get('content')
        if is_boundary(rec,msg):
            cur+=1; segs.append({'ln':ln,'ts':rec.get('timestamp'),'prompt':text_of(c).replace('\\n',' ')[:220], 'tools':[], 'assistant':[]})
        if rec.get('type')=='assistant':
            if cur<0: cur=0; segs.append({'ln':ln,'ts':rec.get('timestamp'),'prompt':'(pre)','tools':[], 'assistant':[]})
            # content blocks
            for b in (c if isinstance(c,list) else []):
                if isinstance(b,dict) and b.get('type')=='tool_use':
                    name=b.get('name'); tool_counts[name]=tool_counts.get(name,0)+1
                    inp=b.get('input') or {}
                    p=inp.get('file_path') or inp.get('path') or inp.get('command') or ''
                    segs[cur]['tools'].append((name,p[:160]))
                    if p: tool_paths.append((cur,name,p[:220]))
                if isinstance(b,dict) and b.get('type')=='text':
                    t=b.get('text','').replace('\\n',' ')
                    if 'auto mode could not evaluate' in t or 'security' in t.lower() or 'error' in t.lower():
                        notes.append((cur,t[:220]))
                    if t.strip():
                        segs[cur]['assistant'].append(t[:260])
    print('\\n###',path.name,'segments',len(segs),'tools',tool_counts)
    for i,s in enumerate(segs):
        print(f\"seg{i} line{s['ln']} {s['ts']} prompt: {s['prompt']}\")
        if s['tools']:
            print('  tools:', '; '.join(f'{n}:{p}' for n,p in s['tools'][:8]))
        if s['assistant']:
            print('  reply:', s['assistant'][-1][:260])
    if notes:
        print('  NOTES', notes[:4])
