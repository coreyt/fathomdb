    45	    identity: EmbedderIdentity,
    46	    in_flight: AtomicUsize,
    47	    max_in_flight: Arc<AtomicUsize>,
    48	    delay: Duration,
    49	}
    50	
    51	impl ConcurrencyProbeEmbedder {
    52	    fn new(max_in_flight: Arc<AtomicUsize>, delay: Duration) -> Self {
    53	        Self {
    54	            identity: EmbedderIdentity::new("probe", "rev-a", DIM),
    55	            in_flight: AtomicUsize::new(0),
    56	            max_in_flight,
    57	            delay,
    58	        }
    59	    }
    60	}
    61	
    62	impl Embedder for ConcurrencyProbeEmbedder {
    63	    fn identity(&self) -> EmbedderIdentity {
