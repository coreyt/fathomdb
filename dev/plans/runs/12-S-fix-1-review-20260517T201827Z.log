     1	#!/usr/bin/env bash
     2	# Aggregate security-fixture gate. Runs the AC-036, AC-037, AC-038,
     3	# AC-050a, and AC-050c gates that live under scripts/security/.
     4	#
     5	# Exit semantics:
     6	#   0  — every gate green.
     7	#   1  — at least one gate found a real violation.
     8	#   2  — toolchain blocker (e.g. strace missing for AC-036/AC-037);
     9	#        gates that BLOCKER do not fail the overall script unless
    10	#        STRICT=1 is set.
    11	#
    12	# Wiring: scripts/agent-verify.sh invokes this with STRICT=1, so any
    13	# blocker fails the agent loop on hosts where bootstrap.sh has run.
    14	# Local dev hosts without strace must either run scripts/bootstrap.sh
    15	# (which apt-installs strace on Debian) or install strace manually.
    16	set -uo pipefail
    17	
    18	SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    19	SEC="$SCRIPT_DIR/security"
    20	
    21	violations=0
    22	blockers=0
    23	
    24	run_gate() {
    25	    local label="$1"
    26	    shift
    27	    echo "==> $label"
    28	    set +e
    29	    "$@"
    30	    local rc=$?
    31	    set -e
    32	    if [ "$rc" -eq 0 ]; then
    33	        echo "    PASS"
    34	    elif [ "$rc" -eq 2 ]; then
    35	        echo "    BLOCKER (toolchain missing)" >&2
    36	        blockers=$((blockers + 1))
    37	    else
    38	        echo "    FAIL (rc=$rc)" >&2
    39	        violations=$((violations + 1))
    40	    fi
    41	}
    42	
    43	run_gate "AC-036 no-listen-syscall"     bash "$SEC/check-no-listen.sh"
    44	run_gate "AC-037 netns-deny-egress"     bash "$SEC/check-netns-deny-egress.sh"
    45	run_gate "AC-038 FTS5-injection-safe"   cargo test -p fathomdb-engine --test fts5_injection_safety --quiet
    46	run_gate "AC-050a ast-scan rust"        python3 "$SEC/ast_scan.py" --language rust
    47	run_gate "AC-050a ast-scan python"      python3 "$SEC/ast_scan.py" --language python
    48	run_gate "AC-050a ast-scan ts"          python3 "$SEC/ast_scan.py" --language ts
    49	run_gate "AC-050c removal-detect"       bash "$SEC/check-removal-changelog.sh"
    50	
    51	echo
    52	echo "agent-security: $violations violation(s), $blockers blocker(s)"
    53	
    54	if [ "$violations" -gt 0 ]; then
    55	    exit 1
    56	fi
    57	if [ "$blockers" -gt 0 ] && [ "${STRICT:-0}" = "1" ]; then
    58	    exit 2
    59	fi
    60	exit 0

