dev/plans/runs/12-TX-ts-python-parity-20260517T204414Z.log:515:{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0193Kt2Wunoi1oDvdGTeCa1x","type":"tool_result","content":"1\t\"\"\"FFI safety-contract tests for the PyO3 binding.\n2\t\n3\tCovers AC-067 (panic catch), AC-068a (embedded NUL rejected), and\n4\tAC-068b (unpaired UTF-16 surrogate rejected). The contract is locked\n5\there for Python and mirrored by the napi-rs binding in Phase 11b.\n6\t\"\"\"\n7\t\n8\tfrom __future__ import annotations\n9\t\n10\timport os\n11\t\n12\timport pytest\n13\t\n14\tfrom fathomdb import Engine, admin\n15\tfrom fathomdb._fathomdb import force_panic_for_test\n16\tfrom fathomdb.errors import EngineError, WriteValidationError\n17\t\n18\t\n19\tdef test_panic_surfaces_as_python_exception(db_path: str) -> None:\n20\t    \"\"\"AC-067 — engine panics must not abort the host process.\n21\t\n22\t    The binding must raise PyO3's `PanicException` (not `EngineError`):\n23\t    panic is a contract bug, not a typed engine outcome, so callers that\n24\t    catch `EngineError` must not silently swallow it.\n25\t    \"\"\"\n26\t\n27\t    pid_before = os.getpid()\n28\t    with pytest.raises(BaseException) as excinfo:\n29\t        force_panic_for_test()\n30\t    pid_after = os.getpid()\n31\t    assert pid_before == pid_after, \"host process must not be aborted by engine panic\"\n32\t\n33\t    exc_type = type(excinfo.value)\n34\t    assert exc_type.__name__ == \"PanicException\", (\n35\t        f\"expected pyo3 PanicException, got {exc_type.__module__}.{exc_type.__name__}\"\n36\t    )\n37\t    assert exc_type.__module__ == \"pyo3_runtime\", (\n38\t        f\"PanicException must come from pyo3_runtime, got {exc_type.__module__}\"\n39\t    )\n40\t    assert not isinstance(excinfo.value, EngineError), (\n41\t        \"PanicException must NOT subclass EngineError\"\n42\t    )\n43\t\n44\t    # Subsequent engine work must still succeed.\n45\t    engine = Engine.open(db_path)\n46\t    try:\n47\t        snapshot = engine.counters()\n48\t        assert snapshot is not None\n49\t    finally:\n50\t        engine.close()\n51\t\n52\t\n53\tdef test_embedded_nul_in_body_rejected_before_write(db_path: str) -> None:\n54\t    \"\"\"AC-068a — embedded NUL in any FFI string raises\n55\t    WriteValidationError, and no row is written.\"\"\"\n56\t\n57\t    engine = Engine.open(db_path)\n58\t    try:\n59\t        # Register a latest-state collection so the body would otherwise\n60\t        # commit a row.\n61\t        admin.configure(engine, name=\"nul_col\", body=\"{}\")\n62\t        before = engine._native.counters().write_rows\n63\t\n64\t        with pytest.raises(WriteValidationError) as excinfo:\n65\t            engine.write(\n66\t                [\n67\t                    {\n68\t                        \"op_store\": {\n69\t                            \"collection\": \"nul_col\",\n70\t                            \"record_key\": \"k1\",\n71\t                            \"body\": '{\"x\":\"a\\x00b\"}',\n72\t                        }\n73\t                    }\n74\t                ]\n75\t            )\n76\t        assert isinstance(excinfo.value, EngineError)\n77\t\n78\t        after = engine._native.counters().write_rows\n79\t        assert after == before, \"no row may be written when a NUL is rejected\"\n80\t    finally:\n81\t        engine.close()\n82\t\n83\t\n84\tdef test_unpaired_surrogate_in_body_rejected_before_write(db_path: str) -> None:\n85\t    \"\"\"AC-068b — lone UTF-16 surrogate codepoints raise\n86\t    WriteValidationError, and no row is written.\"\"\"\n87\t\n88\t    engine = Engine.open(db_path)\n89\t    try:\n90\t        admin.configure(engine, name=\"sur_col\", body=\"{}\")\n91\t        before = engine._native.counters().write_rows\n92\t\n93\t        with pytest.raises(WriteValidationError) as excinfo:\n94\t            engine.write(\n95\t                [\n96\t                    {\n97\t                        \"op_store\": {\n98\t                            \"collection\": \"sur_col\",\n99\t                            \"record_key\": \"k1\",\n100\t                            \"body\": '{\"x\":\"a\\ud800b\"}',\n101\t                        }\n102\t                    }\n103\t                ]\n104\t            )\n105\t        assert isinstance(excinfo.value, EngineError)\n106\t\n107\t        after = engine._native.counters().write_rows\n108\t        assert after == before, \"no row may be written when a surrogate is rejected\"\n109\t    finally:\n110\t        engine.close()\n111\t\n112\t\n113\tdef test_embedded_nul_in_node_kind_rejected(db_path: str) -> None:\n114\t    \"\"\"AC-068a — applies to every FFI string field, not just bodies.\"\"\"\n115\t\n116\t    engine = Engine.open(db_path)\n117\t    try:\n118\t        with pytest.raises(WriteValidationError):\n119\t            engine.write([{\"kind\": \"do\\x00c\", \"body\": \"{}\"}])\n120\t    finally:\n121\t        engine.close()\n122\t"}]},"parent_tool_use_id":null,"session_id":"e03e003f-16a4-48ce-9857-522e8e7e136e","uuid":"c4342d12-c487-4ba7-b7bd-26f5e78f848d","timestamp":"2026-05-17T20:45:36.233Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-TX-ts-python-parity-20260517T204414Z/src/python/tests/test_ffi_safety.py","content":"\"\"\"FFI safety-contract tests for the PyO3 binding.\n\nCovers AC-067 (panic catch), AC-068a (embedded NUL rejected), and\nAC-068b (unpaired UTF-16 surrogate rejected). The contract is locked\nhere for Python and mirrored by the napi-rs binding in Phase 11b.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport os\n\nimport pytest\n\nfrom fathomdb import Engine, admin\nfrom fathomdb._fathomdb import force_panic_for_test\nfrom fathomdb.errors import EngineError, WriteValidationError\n\n\ndef test_panic_surfaces_as_python_exception(db_path: str) -> None:\n    \"\"\"AC-067 — engine panics must not abort the host process.\n\n    The binding must raise PyO3's `PanicException` (not `EngineError`):\n    panic is a contract bug, not a typed engine outcome, so callers that\n    catch `EngineError` must not silently swallow it.\n    \"\"\"\n\n    pid_before = os.getpid()\n    with pytest.raises(BaseException) as excinfo:\n        force_panic_for_test()\n    pid_after = os.getpid()\n    assert pid_before == pid_after, \"host process must not be aborted by engine panic\"\n\n    exc_type = type(excinfo.value)\n    assert exc_type.__name__ == \"PanicException\", (\n        f\"expected pyo3 PanicException, got {exc_type.__module__}.{exc_type.__name__}\"\n    )\n    assert exc_type.__module__ == \"pyo3_runtime\", (\n        f\"PanicException must come from pyo3_runtime, got {exc_type.__module__}\"\n    )\n    assert not isinstance(excinfo.value, EngineError), (\n        \"PanicException must NOT subclass EngineError\"\n    )\n\n    # Subsequent engine work must still succeed.\n    engine = Engine.open(db_path)\n    try:\n        snapshot = engine.counters()\n        assert snapshot is not None\n    finally:\n        engine.close()\n\n\ndef test_embedded_nul_in_body_rejected_before_write(db_path: str) -> None:\n    \"\"\"AC-068a — embedded NUL in any FFI string raises\n    WriteValidationError, and no row is written.\"\"\"\n\n    engine = Engine.open(db_path)\n    try:\n        # Register a latest-state collection so the body would otherwise\n        # commit a row.\n        admin.configure(engine, name=\"nul_col\", body=\"{}\")\n        before = engine._native.counters().write_rows\n\n        with pytest.raises(WriteValidationError) as excinfo:\n            engine.write(\n                [\n                    {\n                        \"op_store\": {\n                            \"collection\": \"nul_col\",\n                            \"record_key\": \"k1\",\n                            \"body\": '{\"x\":\"a\\x00b\"}',\n                        }\n                    }\n                ]\n            )\n        assert isinstance(excinfo.value, EngineError)\n\n        after = engine._native.counters().write_rows\n        assert after == before, \"no row may be written when a NUL is rejected\"\n    finally:\n        engine.close()\n\n\ndef test_unpaired_surrogate_in_body_rejected_before_write(db_path: str) -> None:\n    \"\"\"AC-068b — lone UTF-16 surrogate codepoints raise\n    WriteValidationError, and no row is written.\"\"\"\n\n    engine = Engine.open(db_path)\n    try:\n        admin.configure(engine, name=\"sur_col\", body=\"{}\")\n        before = engine._native.counters().write_rows\n\n        with pytest.raises(WriteValidationError) as excinfo:\n            engine.write(\n                [\n                    {\n                        \"op_store\": {\n                            \"collection\": \"sur_col\",\n                            \"record_key\": \"k1\",\n                            \"body\": '{\"x\":\"a\\ud800b\"}',\n                        }\n                    }\n                ]\n            )\n        assert isinstance(excinfo.value, EngineError)\n\n        after = engine._native.counters().write_rows\n        assert after == before, \"no row may be written when a surrogate is rejected\"\n    finally:\n        engine.close()\n\n\ndef test_embedded_nul_in_node_kind_rejected(db_path: str) -> None:\n    \"\"\"AC-068a — applies to every FFI string field, not just bodies.\"\"\"\n\n    engine = Engine.open(db_path)\n    try:\n        with pytest.raises(WriteValidationError):\n            engine.write([{\"kind\": \"do\\x00c\", \"body\": \"{}\"}])\n    finally:\n        engine.close()\n","numLines":122,"startLine":1,"totalLines":122}}}
dev/plans/runs/12-TX-ts-python-parity-20260517T204414Z.log:529:{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LXhMJS2xheCKP4ysmDKupw","type":"tool_result","content":"1\t// FFI safety-contract tests for the napi-rs binding.\n2\t//\n3\t// Covers AC-067 (panic catch), AC-068a (embedded NUL rejected), and\n4\t// AC-068b (unpaired UTF-16 surrogate rejected). Mirrors\n5\t// `src/python/tests/test_ffi_safety.py` from Phase 11a.\n6\t\n7\timport test from \"node:test\";\n8\timport assert from \"node:assert/strict\";\n9\t\n10\timport { Engine, admin } from \"../src/index.js\";\n11\timport {\n12\t  FathomDbError,\n13\t  FathomDbPanicError,\n14\t  WriteValidationError,\n15\t  rethrowTyped,\n16\t} from \"../src/errors.js\";\n17\timport { native } from \"../src/binding.js\";\n18\timport { freshDbPath } from \"./helpers.js\";\n19\t\n20\tconst NUL = String.fromCharCode(0);\n21\tconst SURROGATE = String.fromCharCode(0xd800);\n22\t\n23\ttest(\"AC-067 panic surfaces as FathomDbPanicError, process unchanged\", async () => {\n24\t  const pidBefore = process.pid;\n25\t\n26\t  assert.equal(typeof native.forcePanicForTest, \"function\", \"force-panic hook must be exposed\");\n27\t\n28\t  assert.throws(\n29\t    () => {\n30\t      try {\n31\t        native.forcePanicForTest!();\n32\t      } catch (err) {\n33\t        rethrowTyped(err);\n34\t      }\n35\t    },\n36\t    (err: unknown) => {\n37\t      assert.ok(err instanceof FathomDbPanicError, \"must be FathomDbPanicError\");\n38\t      assert.ok(!(err instanceof FathomDbError), \"panic must NOT subclass FathomDbError\");\n39\t      return true;\n40\t    },\n41\t  );\n42\t\n43\t  assert.equal(process.pid, pidBefore, \"host process must not be aborted by engine panic\");\n44\t\n45\t  const engine = await Engine.open(freshDbPath());\n46\t  try {\n47\t    const snap = engine.counters();\n48\t    assert.ok(snap !== undefined);\n49\t  } finally {\n50\t    await engine.close();\n51\t  }\n52\t});\n53\t\n54\ttest(\"AC-067 panic on sync accessor surfaces as FathomDbPanicError\", () => {\n55\t  assert.equal(\n56\t    typeof native.forcePanicInAccessorForTest,\n57\t    \"function\",\n58\t    \"sync force-panic hook must be exposed\",\n59\t  );\n60\t\n61\t  assert.throws(\n62\t    () => {\n63\t      try {\n64\t        native.forcePanicInAccessorForTest!();\n65\t      } catch (err) {\n66\t        rethrowTyped(err);\n67\t      }\n68\t    },\n69\t    (err: unknown) => {\n70\t      assert.ok(err instanceof FathomDbPanicError, \"must be FathomDbPanicError\");\n71\t      assert.ok(!(err instanceof FathomDbError), \"panic must NOT subclass FathomDbError\");\n72\t      assert.match((err as Error).message, /engine panic/);\n73\t      return true;\n74\t    },\n75\t  );\n76\t});\n77\t\n78\ttest(\"AC-068a embedded NUL in op-store body rejected as WriteValidationError\", async () => {\n79\t  const engine = await Engine.open(freshDbPath());\n80\t  try {\n81\t    await admin.configure(engine, { name: \"nul_col\", body: \"{}\" });\n82\t    const before = engine.counters().writeRows;\n83\t\n84\t    await assert.rejects(\n85\t      () =>\n86\t        engine.write([\n87\t          {\n88\t            opStore: {\n89\t              collection: \"nul_col\",\n90\t              recordKey: \"k1\",\n91\t              body: `{\"x\":\"a${NUL}b\"}`,\n92\t            },\n93\t          },\n94\t        ]),\n95\t      (err: unknown) => {\n96\t        assert.ok(err instanceof WriteValidationError, \"must be WriteValidationError\");\n97\t        assert.ok(err instanceof FathomDbError, \"must extend FathomDbError\");\n98\t        return true;\n99\t      },\n100\t    );\n101\t\n102\t    const after = engine.counters().writeRows;\n103\t    assert.equal(after, before, \"no row may be written when a NUL is rejected\");\n104\t  } finally {\n105\t    await engine.close();\n106\t  }\n107\t});\n108\t\n109\ttest(\"AC-068b unpaired UTF-16 surrogate in op-store body rejected as WriteValidationError\", async () => {\n110\t  const engine = await Engine.open(freshDbPath());\n111\t  try {\n112\t    await admin.configure(engine, { name: \"sur_col\", body: \"{}\" });\n113\t    const before = engine.counters().writeRows;\n114\t\n115\t    await assert.rejects(\n116\t      () =>\n117\t        engine.write([\n118\t          {\n119\t            opStore: {\n120\t              collection: \"sur_col\",\n121\t              recordKey: \"k1\",\n122\t              body: `{\"x\":\"a${SURROGATE}b\"}`,\n123\t            },\n124\t          },\n125\t        ]),\n126\t      (err: unknown) => {\n127\t        assert.ok(err instanceof WriteValidationError, \"must be WriteValidationError\");\n128\t        assert.ok(err instanceof FathomDbError, \"must extend FathomDbError\");\n129\t        return true;\n130\t      },\n131\t    );\n132\t\n133\t    const after = engine.counters().writeRows;\n134\t    assert.equal(after, before, \"no row may be written when a surrogate is rejected\");\n135\t  } finally {\n136\t    await engine.close();\n137\t  }\n138\t});\n139\t\n140\ttest(\"AC-068a embedded NUL in node kind also rejected before write\", async () => {\n141\t  const engine = await Engine.open(freshDbPath());\n142\t  try {\n143\t    await assert.rejects(\n144\t      () => engine.write([{ kind: `do${NUL}c`, body: \"{}\" }]),\n145\t      (err: unknown) => {\n146\t        assert.ok(err instanceof WriteValidationError);\n147\t        return true;\n148\t      },\n149\t    );\n150\t  } finally {\n151\t    await engine.close();\n152\t  }\n153\t});\n154\t"}]},"parent_tool_use_id":null,"session_id":"e03e003f-16a4-48ce-9857-522e8e7e136e","uuid":"ac279bd8-7e60-4a5f-8e91-ef2903f4e393","timestamp":"2026-05-17T20:45:37.973Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-TX-ts-python-parity-20260517T204414Z/src/ts/tests/ffi-safety.test.ts","content":"// FFI safety-contract tests for the napi-rs binding.\n//\n// Covers AC-067 (panic catch), AC-068a (embedded NUL rejected), and\n// AC-068b (unpaired UTF-16 surrogate rejected). Mirrors\n// `src/python/tests/test_ffi_safety.py` from Phase 11a.\n\nimport test from \"node:test\";\nimport assert from \"node:assert/strict\";\n\nimport { Engine, admin } from \"../src/index.js\";\nimport {\n  FathomDbError,\n  FathomDbPanicError,\n  WriteValidationError,\n  rethrowTyped,\n} from \"../src/errors.js\";\nimport { native } from \"../src/binding.js\";\nimport { freshDbPath } from \"./helpers.js\";\n\nconst NUL = String.fromCharCode(0);\nconst SURROGATE = String.fromCharCode(0xd800);\n\ntest(\"AC-067 panic surfaces as FathomDbPanicError, process unchanged\", async () => {\n  const pidBefore = process.pid;\n\n  assert.equal(typeof native.forcePanicForTest, \"function\", \"force-panic hook must be exposed\");\n\n  assert.throws(\n    () => {\n      try {\n        native.forcePanicForTest!();\n      } catch (err) {\n        rethrowTyped(err);\n      }\n    },\n    (err: unknown) => {\n      assert.ok(err instanceof FathomDbPanicError, \"must be FathomDbPanicError\");\n      assert.ok(!(err instanceof FathomDbError), \"panic must NOT subclass FathomDbError\");\n      return true;\n    },\n  );\n\n  assert.equal(process.pid, pidBefore, \"host process must not be aborted by engine panic\");\n\n  const engine = await Engine.open(freshDbPath());\n  try {\n    const snap = engine.counters();\n    assert.ok(snap !== undefined);\n  } finally {\n    await engine.close();\n  }\n});\n\ntest(\"AC-067 panic on sync accessor surfaces as FathomDbPanicError\", () => {\n  assert.equal(\n    typeof native.forcePanicInAccessorForTest,\n    \"function\",\n    \"sync force-panic hook must be exposed\",\n  );\n\n  assert.throws(\n    () => {\n      try {\n        native.forcePanicInAccessorForTest!();\n      } catch (err) {\n        rethrowTyped(err);\n      }\n    },\n    (err: unknown) => {\n      assert.ok(err instanceof FathomDbPanicError, \"must be FathomDbPanicError\");\n      assert.ok(!(err instanceof FathomDbError), \"panic must NOT subclass FathomDbError\");\n      assert.match((err as Error).message, /engine panic/);\n      return true;\n    },\n  );\n});\n\ntest(\"AC-068a embedded NUL in op-store body rejected as WriteValidationError\", async () => {\n  const engine = await Engine.open(freshDbPath());\n  try {\n    await admin.configure(engine, { name: \"nul_col\", body: \"{}\" });\n    const before = engine.counters().writeRows;\n\n    await assert.rejects(\n      () =>\n        engine.write([\n          {\n            opStore: {\n              collection: \"nul_col\",\n              recordKey: \"k1\",\n              body: `{\"x\":\"a${NUL}b\"}`,\n            },\n          },\n        ]),\n      (err: unknown) => {\n        assert.ok(err instanceof WriteValidationError, \"must be WriteValidationError\");\n        assert.ok(err instanceof FathomDbError, \"must extend FathomDbError\");\n        return true;\n      },\n    );\n\n    const after = engine.counters().writeRows;\n    assert.equal(after, before, \"no row may be written when a NUL is rejected\");\n  } finally {\n    await engine.close();\n  }\n});\n\ntest(\"AC-068b unpaired UTF-16 surrogate in op-store body rejected as WriteValidationError\", async () => {\n  const engine = await Engine.open(freshDbPath());\n  try {\n    await admin.configure(engine, { name: \"sur_col\", body: \"{}\" });\n    const before = engine.counters().writeRows;\n\n    await assert.rejects(\n      () =>\n        engine.write([\n          {\n            opStore: {\n              collection: \"sur_col\",\n              recordKey: \"k1\",\n              body: `{\"x\":\"a${SURROGATE}b\"}`,\n            },\n          },\n        ]),\n      (err: unknown) => {\n        assert.ok(err instanceof WriteValidationError, \"must be WriteValidationError\");\n        assert.ok(err instanceof FathomDbError, \"must extend FathomDbError\");\n        return true;\n      },\n    );\n\n    const after = engine.counters().writeRows;\n    assert.equal(after, before, \"no row may be written when a surrogate is rejected\");\n  } finally {\n    await engine.close();\n  }\n});\n\ntest(\"AC-068a embedded NUL in node kind also rejected before write\", async () => {\n  const engine = await Engine.open(freshDbPath());\n  try {\n    await assert.rejects(\n      () => engine.write([{ kind: `do${NUL}c`, body: \"{}\" }]),\n      (err: unknown) => {\n        assert.ok(err instanceof WriteValidationError);\n        return true;\n      },\n    );\n  } finally {\n    await engine.close();\n  }\n});\n","numLines":154,"startLine":1,"totalLines":154}}}
dev/plans/runs/12-TX-ts-python-parity-20260517T204414Z.log:601:{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G5LoDt8WzPoy9Rd5DNZZFQ","type":"tool_result","content":"757:Mainline next: Wave 3 first slice **12-TX** TS Python-parity. Per\n758-plan ordering: TS parity lands after 12-P + 12-V-VERBS so TS\n759-doesn't chase a moving runtime surface.\n760-\n761-Phase 11 was sliced (decision 2026-05-16, post-10b close) into four\n762-serial sub-phases. Each got its own implementer prompt + codex review.\n763-\n764-| Slice | Scope                                                                            | Prompt                                      | AC ids                                       |\n765-| ----- | -------------------------------------------------------------------------------- | ------------------------------------------- | -------------------------------------------- |\n766-| 11a   | PyO3 binding: new `fathomdb-py` crate, maturin backend, FFI safety contract      | `dev/plans/prompts/11a-pyo3-binding.md`     | AC-057a, AC-060a, AC-060b, AC-067, AC-068a/b |\n767-| 11b   | napi-rs binding: TS surface mirror, Promise API, handoff pool                    | `dev/plans/prompts/11b-napi-binding.md`     | AC-057a, AC-060a, AC-060b, AC-067, AC-068a/b |\n768-| 11c   | Two-axis version single-source-of-truth + `scripts/set-version.sh` rewrite       | `dev/plans/prompts/11c-set-version.md`      | AC-051a/b                                    |\n769-| 11d   | `.github/workflows/release.yml` restoration: 8-tier publish + post-publish smoke | `dev/plans/prompts/11d-release-workflow.md` | AC-052, AC-053                               |\n770-\n771-Ordering rationale: 11a first because it locks the FFI safety contract\n772-(GIL release / panic catching / string validation / typed error map)\n773-that 11b mirrors. 11c before 11d because `set-version.sh` is a\n774-`release.yml` dependency. 11a → 11b → 11c → 11d is the canonical\n775-sequence; 11a/11b may be parallelized after the 11a contract is locked\n776-if review bandwidth allows.\n777-\n778-Phase 12 non-performance slices can also continue. Pack 7 remains proposed\n779-follow-on perf work only and does not block the bindings path.\n780-\n781-## Path to Client-Ready (0.6.0 GA)\n782-\n783-Sequence to take `0.6.0-rewrite` from \"Phase 11 complete\" to\n784-**published + smoke-verified + client-installable**. Eight slices,\n785-mostly serial. Drives Phase 12 + release-tag + post-publish smoke +\n786-external-user docs.\n787-\n788-Gating principle: each slice has an explicit exit criterion;\n789-mainline does not advance until that criterion is green AND any\n790-deferrals are HITL-acknowledged in writing.\n791-\n792-### Status at start of path (2026-05-17, tip `085727e`+)\n793-\n794-- Engine core: ✅ (Phases 5-9 closed)\n795-- CLI doctor + recover: ✅ (Phase 10a closed)\n796-- Logical-id verbs (purge / restore): ⚠️ DEFERRED to 0.7.x (10b-B)\n797-- Bindings (PyO3 + napi-rs): ✅ (Phase 11a + 11b closed)\n798-- Two-axis version substrate + set-version.sh: ✅ (Phase 11c closed)\n799-- release.yml + post-publish-smoke + co-tagging + actionlint: ✅\n800-  (Phase 11d closed)\n801-- Durability harnesses (AC-034a..AC-035c): ❌ not started\n802-- Security fixtures (AC-064 / AC-065 / AC-066 + AST + linter): ❌ not started\n803-- Perf gates AC-012 / AC-013 / AC-019 / AC-020: ⚠️ DEFERRED for 0.6.0\n804-- Registry-installed wheel smoke (AC-056): ⏳ scripts ready (11d);\n805-  cannot run until something is actually published\n806-- External-user docs: ❌ no mkdocs API ref, no quickstart, no\n807-  install-from-PyPI page (only `dev/interfaces/python.md` internal spec)\n--\n819:| 12-TX  | TypeScript SDK → Python-parity. Close the feature gap so TS clients aren't second-class at GA. Scoped after 12-P + 12-V-VERBS so TS doesn't chase a moving runtime surface | Documented parity matrix all green; TS tests cover the same five-verb surface + instrumentation as Python       | yes       |\n820-