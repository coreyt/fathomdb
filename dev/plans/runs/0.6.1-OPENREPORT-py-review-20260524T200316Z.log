    45	    engine = Engine.open(db_path)
    46	    try:
    47	        first = engine.open_report()
    48	        second = engine.open_report()
    49	
    50	        assert first.schema_version_before == second.schema_version_before
    51	        assert first.schema_version_after == second.schema_version_after
    52	        assert first.embedder_warmup_ms == second.embedder_warmup_ms
    53	        assert first.query_backend == second.query_backend
    54	        assert first.default_embedder.name == second.default_embedder.name
    55	        assert first.default_embedder.revision == second.default_embedder.revision
    56	        assert first.default_embedder.dimension == second.default_embedder.dimension
    57	
    58	        assert len(first.migration_steps) == len(second.migration_steps)
    59	        for a, b in zip(first.migration_steps, second.migration_steps):
    60	            assert a.step_id == b.step_id
    61	            assert a.duration_ms == b.duration_ms
    62	            assert a.failed == b.failed
    63	    finally:
    64	        engine.close()
    65	
    66	
    67	def test_open_signature_returns_engine_handle(db_path: str) -> None:
    68	    """Shape D guarantee — `Engine.open` still returns just the engine."""
    69	
    70	    engine = Engine.open(db_path)
    71	    try:
    72	        assert isinstance(engine, Engine)
    73	    finally:
    74	        engine.close()

