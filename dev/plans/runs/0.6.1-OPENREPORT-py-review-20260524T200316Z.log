    75	// ===== String validation (AC-068a / AC-068b) =========================
    76	
    77	/// Reject strings carrying an embedded NUL or an unpaired UTF-16
    78	/// surrogate codepoint (`U+D800..=U+DFFF`).
    79	///
    80	/// Both are valid Python `str` values but invalid for SQLite text
    81	/// columns; AC-068a/b requires the binding to reject them BEFORE the
    82	/// writer transaction opens (no-row-written invariant).
    83	pub fn validate_ffi_string(value: &str) -> Result<(), String> {
    84	    if value.as_bytes().contains(&0) {
    85	        return Err("embedded NUL byte in FFI string".to_string());
    86	    }
    87	    for ch in value.chars() {
    88	        let cp = ch as u32;
    89	        if (0xD800..=0xDFFF).contains(&cp) {
    90	            return Err(format!("unpaired UTF-16 surrogate U+{cp:04X} in FFI string"));
    91	        }
    92	    }
    93	    Ok(())
    94	}
    95	
    96	fn validate_ffi_string_py(value: &str) -> PyResult<()> {
    97	    validate_ffi_string(value).map_err(WriteValidationError::new_err)
    98	}
    99	
   100	/// Extract a Python string into a Rust `String` and run
   101	/// [`validate_ffi_string_py`]. PyO3's built-in `str` extraction already
   102	/// fails on lone surrogates (the underlying `PyUnicode_AsUTF8AndSize`
   103	/// raises `UnicodeEncodeError`); we re-raise those as the typed
   104	/// `WriteValidationError` so callers can dispatch on a single class.
   105	fn extract_validated_str(value: &Bound<'_, PyAny>) -> PyResult<String> {
   106	    match value.extract::<String>() {
   107	        Ok(s) => {
   108	            validate_ffi_string_py(&s)?;
   109	            Ok(s)
   110	        }
   111	        Err(_) => Err(WriteValidationError::new_err(
   112	            "string contains characters not representable as UTF-8 (lone surrogate)",
   113	        )),
   114	    }
   115	}
   116	
   117	// ===== Error mapping ==================================================
   118	
   119	/// Translate every `EngineError` variant to its Python counterpart.
   120	///
   121	/// No catch-all arm: drift between the Rust enum and the Python class
   122	/// set is a compile error.
   123	fn engine_error_to_py(err: RustEngineError) -> PyErr {
   124	    match err {
   125	        RustEngineError::Storage => StorageError::new_err("storage error"),
   126	        RustEngineError::Projection => ProjectionError::new_err("projection error"),
   127	        RustEngineError::Vector => VectorError::new_err("vector error"),
   128	        RustEngineError::Embedder => EmbedderError::new_err("embedder error"),
   129	        RustEngineError::EmbedderNotConfigured => {
   130	            EmbedderNotConfiguredError::new_err("embedder is not configured")
   131	        }
   132	        RustEngineError::KindNotVectorIndexed => {
   133	            KindNotVectorIndexedError::new_err("kind is not configured for vector indexing")
   134	        }
   135	        RustEngineError::EmbedderDimensionMismatch { expected, actual } => {
   136	            let exc = EmbedderDimensionMismatchError::new_err(format!(
   137	                "embedder vector dimension mismatch: stored {expected}, supplied {actual}",
   138	            ));
   139	            Python::with_gil(|py| {
   140	                let v = exc.value_bound(py);
   141	                let _ = v.setattr("stored", expected);
   142	                let _ = v.setattr("supplied", actual);
   143	            });
   144	            exc
   145	        }
   146	        RustEngineError::Scheduler => SchedulerError::new_err("scheduler error"),
   147	        RustEngineError::OpStore => OpStoreError::new_err("op-store error"),
   148	        RustEngineError::WriteValidation => WriteValidationError::new_err("write validation error"),
   149	        RustEngineError::SchemaValidation => {
   150	            SchemaValidationError::new_err("schema validation error")
   151	        }
   152	        RustEngineError::Overloaded => OverloadedError::new_err("engine overloaded"),
   153	        RustEngineError::Closing => ClosingError::new_err("engine is closing"),
   154	    }
   155	}
   156	
   157	fn corruption_kind_str(kind: CorruptionKind) -> &'static str {
   158	    match kind {
   159	        CorruptionKind::WalReplayFailure => "WalReplayFailure",
   160	        CorruptionKind::HeaderMalformed => "HeaderMalformed",
   161	        CorruptionKind::SchemaInconsistent => "SchemaInconsistent",
   162	        CorruptionKind::EmbedderIdentityDrift => "EmbedderIdentityDrift",
   163	    }
   164	}
   165	
   166	fn open_stage_str(stage: OpenStage) -> &'static str {
   167	    match stage {
   168	        OpenStage::HeaderProbe => "HeaderProbe",
   169	        OpenStage::WalReplay => "WalReplay",
   170	        OpenStage::SchemaProbe => "SchemaProbe",
   171	        OpenStage::EmbedderIdentity => "EmbedderIdentity",
   172	    }
   173	}
   174	
   175	fn engine_open_error_to_py(err: EngineOpenError) -> PyErr {
   176	    match err {
   177	        EngineOpenError::DatabaseLocked { holder_pid } => {
   178	            let exc = DatabaseLockedError::new_err(match holder_pid {
   179	                Some(pid) => format!("database is locked by process {pid}"),
   180	                None => "database is locked by another engine instance".to_string(),
   181	            });
   182	            Python::with_gil(|py| {
   183	                let _ = exc.value_bound(py).setattr("holder_pid", holder_pid);
   184	            });
   185	            exc
   186	        }
   187	        EngineOpenError::Corruption(detail) => corruption_to_py(detail),
   188	        EngineOpenError::IncompatibleSchemaVersion { seen, supported } => {
   189	            IncompatibleSchemaVersionError::new_err(format!(
   190	                "database schema version {seen} is incompatible with supported version {supported}"
   191	            ))
   192	        }
   193	        EngineOpenError::MigrationError {
   194	            schema_version_before,
   195	            schema_version_current,
   196	            step_id,
   197	        } => MigrationError::new_err(format!(
   198	            "schema migration failed at step {step_id}; schema version remained between {schema_version_before} and {schema_version_current}"
   199	        )),
   200	        EngineOpenError::EmbedderIdentityMismatch { stored, supplied } => {
   201	            let exc = EmbedderIdentityMismatchError::new_err(format!(
   202	                "embedder identity mismatch: stored {}@{}, supplied {}@{}",
   203	                stored.name, stored.revision, supplied.name, supplied.revision,
   204	            ));
   205	            Python::with_gil(|py| {
   206	                let v = exc.value_bound(py);
   207	                let _ = v.setattr("stored_name", stored.name);
   208	                let _ = v.setattr("stored_revision", stored.revision);
   209	                let _ = v.setattr("supplied_name", supplied.name);
   210	                let _ = v.setattr("supplied_revision", supplied.revision);
   211	            });
   212	            exc
   213	        }
   214	        EngineOpenError::EmbedderDimensionMismatch { stored, supplied } => {
   215	            let exc = EmbedderDimensionMismatchError::new_err(format!(
   216	                "embedder vector dimension mismatch: stored {stored}, supplied {supplied}",
   217	            ));
   218	            Python::with_gil(|py| {
   219	                let v = exc.value_bound(py);
   220	                let _ = v.setattr("stored", stored);
   221	                let _ = v.setattr("supplied", supplied);
   222	            });
   223	            exc
   224	        }
   225	        EngineOpenError::Io { message } => {
   226	            StorageError::new_err(format!("database I/O error: {message}"))
   227	        }
   228	    }
   229	}
   230	
   231	fn corruption_to_py(detail: CorruptionDetail) -> PyErr {
   232	    let kind = corruption_kind_str(detail.kind);
   233	    let stage = open_stage_str(detail.stage);
   234	    let recovery_hint_code = detail.recovery_hint.code;
   235	    let doc_anchor = detail.recovery_hint.doc_anchor;
   236	    let exc = CorruptionError::new_err(format!(
   237	        "corruption {kind} at stage {stage} ({recovery_hint_code})"
   238	    ));
   239	    Python::with_gil(|py| {
   240	        let v = exc.value_bound(py);
   241	        let _ = v.setattr("kind", kind);
   242	        let _ = v.setattr("stage", stage);
   243	        let _ = v.setattr("recovery_hint_code", recovery_hint_code);
   244	        let _ = v.setattr("doc_anchor", doc_anchor);
   245	    });
   246	    exc
   247	}
   248	
   249	/// Run the engine call inside `py.allow_threads` and `catch_unwind`;
   250	/// translate any escaping panic to `EngineError`.
   251	///
   252	/// `AssertUnwindSafe` wraps the caller's closure so we do not need to
   253	/// require `UnwindSafe` from `f`. The engine's `Arc<dyn Embedder>`
   254	/// makes the natural `UnwindSafe` bound unsatisfiable; the engine
   255	/// itself takes care of its own atomicity post-panic.
   256	fn call_engine<R: Send>(
   257	    py: Python<'_>,
   258	    f: impl FnOnce() -> Result<R, RustEngineError> + Send,
   259	) -> PyResult<R> {
   260	    let wrapped = AssertUnwindSafe(f);
   261	    let result = py.allow_threads(|| catch_unwind(wrapped));
   262	    match result {
   263	        Ok(Ok(value)) => Ok(value),
   264	        Ok(Err(err)) => Err(engine_error_to_py(err)),
   265	        Err(_) => Err(PanicException::new_err("engine panic (see logs)")),
   266	    }
   267	}
