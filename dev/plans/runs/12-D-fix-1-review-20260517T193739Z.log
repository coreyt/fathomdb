   389	// ── Finding 1: bounded WAL sidecar probe ────────────────────────────────────
   390	//
   391	// `probe_wal_sidecar` must only read the 32-byte WAL header, never the
   392	// full sidecar. Without this guard, an unclean shutdown that leaves a
   393	// large -wal file behind would force `Engine::open` to slurp the whole
   394	// file into memory before SQLite itself touches recovery — measurable
   395	// latency + RSS regression on the open path. Test makes the WAL sidecar
   396	// 256 MiB; bounded read returns in ~ms, a full read pays ~hundreds of
   397	// ms (alloc + copy) and would flunk the wall-clock bound.
   398	#[test]
   399	fn probe_wal_sidecar_bounded_read() {
   400	    let _guard = serial_guard();
   401	    let dir = TempDir::new().expect("tempdir");
   402	    let path = dir.path().join("bounded.sqlite");
   403	    // Seed a real DB so the open path reaches `probe_wal_sidecar`.
   404	    let opened = Engine::open(&path).expect("seed open");
   405	    opened.engine.close().expect("seed close");
   406	    drop(opened);
   407	
   408	    let wal_path = corruption::wal_sidecar_path(&path);
   409	    let mut file = std::fs::OpenOptions::new()
   410	        .create(true)
   411	        .write(true)
   412	        .truncate(true)
   413	        .open(&wal_path)
   414	        .expect("create large wal");
   415	    // Valid WAL magic + version, invalid page size so the probe still
   416	    // rejects; the rest of the sidecar is sparse zeros. A full-file
   417	    // read pays for the entire 256 MiB.
   418	    let mut header = [0u8; 32];
   419	    header[0..4].copy_from_slice(&0x377f_0683_u32.to_be_bytes());
   420	    header[4..8].copy_from_slice(&3_007_000_u32.to_be_bytes());
   421	    header[8..12].copy_from_slice(&0x0080_0000_u32.to_be_bytes());
   422	    use std::io::Write;
   423	    file.write_all(&header).expect("wal header");
   424	    const WAL_LEN: u64 = 256 * 1024 * 1024;
   425	    file.set_len(WAL_LEN).expect("set_len 256 MiB sparse");
   426	    file.sync_all().expect("fsync large wal");
   427	    drop(file);
   428	
   429	    let started = std::time::Instant::now();
   430	    let result = Engine::open(&path);
   431	    let elapsed = started.elapsed();
   432	
   433	    assert!(
   434	        matches!(result, Err(EngineOpenError::Corruption(_))),
