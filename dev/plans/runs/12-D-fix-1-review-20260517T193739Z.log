   197	fn assert_shape(detail: &CorruptionDetail, expected: &Expected) {
   198	    assert_eq!(detail.kind, expected.kind, "kind mismatch");
   199	    assert_eq!(detail.stage, expected.stage, "stage mismatch");
   200	    // AC-035b: `OpenStage` must remain in `{WalReplay, HeaderProbe,
   201	    // SchemaProbe, EmbedderIdentity}`. Compile-time enforced by
   202	    // exhaustive match below; any future LockAcquisition-style variant
   203	    // would cause this match to non-exhaustively fail to compile.
   204	    match detail.stage {
   205	        OpenStage::WalReplay
   206	        | OpenStage::HeaderProbe
   207	        | OpenStage::SchemaProbe
   208	        | OpenStage::EmbedderIdentity => {}
   209	    }
   210	    // AC-035b: opaque SQLite paths must surface as OpaqueSqliteError with
   211	    // a typed extended_code; CorruptionLocator must never expose a
   212	    // free-form Unspecified variant.
   213	    match detail.locator {
   214	        CorruptionLocator::OpaqueSqliteError { sqlite_extended_code: _ }
   215	        | CorruptionLocator::FileOffset { .. }
   216	        | CorruptionLocator::PageId { .. }
   217	        | CorruptionLocator::TableRow { .. }
   218	        | CorruptionLocator::Vec0ShadowRow { .. }
   219	        | CorruptionLocator::MigrationStep { .. } => {}
   220	    }
   221	    assert_eq!(
   222	        detail.recovery_hint.code, expected.code,
   223	        "recovery_hint.code mismatch for {:?}",
   224	        expected.kind
   225	    );
   226	    assert_eq!(
   227	        detail.recovery_hint.doc_anchor, expected.doc_anchor,
   228	        "recovery_hint.doc_anchor mismatch for {:?}",
   229	        expected.kind
   230	    );
   231	}
