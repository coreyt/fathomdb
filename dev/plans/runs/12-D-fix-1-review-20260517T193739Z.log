   356	/// Test-binary-as-sibling entry. Re-invoked from `assert_lock_released_*`
   357	/// with `FATHOMDB_TEST_LOCK_PROBE` set to the engine's `.lock` path.
   358	/// Attempts `flock(LOCK_EX | LOCK_NB)` and exits 0 on success / 1 on
   359	/// `EWOULDBLOCK`, giving the parent a true sibling-process check
   360	/// (AC-035c contract) instead of the in-process fd reacquire.
   361	/// Without the env var the test is a no-op so plain
   362	/// `cargo test --test durability_open_path -- --ignored` is safe.
   363	#[cfg(target_os = "linux")]
   364	#[test]
   365	#[ignore = "test-binary-as-sibling entry-point for the AC-035c lock-released harness"]
   366	fn _lock_acquire_probe_entry() {
   367	    let Some(lock_path) = std::env::var_os("FATHOMDB_TEST_LOCK_PROBE") else {
   368	        return;
   369	    };
   370	    let path = PathBuf::from(lock_path);
   371	    let probe =
   372	        File::options().read(true).write(true).open(&path).expect("sibling: open lock file");
   373	    let probe_fd: i32 = std::os::unix::io::AsRawFd::as_raw_fd(&probe);
   374	    let rc = unsafe { libc::flock(probe_fd, libc::LOCK_EX | libc::LOCK_NB) };
   375	    if rc == 0 {
   376	        let _ = unsafe { libc::flock(probe_fd, libc::LOCK_UN) };
   377	        std::process::exit(0);
   378	    }
   379	    std::process::exit(1);
   380	}
