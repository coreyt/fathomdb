   382	#[cfg(target_os = "linux")]
   383	fn lock_path_for(db_path: &Path) -> PathBuf {
   384	    let mut lock = db_path.as_os_str().to_owned();
   385	    lock.push(".lock");
   386	    PathBuf::from(lock)
   387	}
