   125	/// Null out the `dimension` column of the default embedder profile row
   126	/// so that on reopen `check_embedder_profile` cannot decode the stored
   127	/// identity. The engine maps this to
   128	/// `EngineOpenError::Corruption(CorruptionDetail { kind:
   129	/// EmbedderIdentityDrift, stage: EmbedderIdentity, .. })`.
   130	///
   131	/// MUST be called against a CLOSED database. Uses a raw rusqlite
   132	/// connection to bypass the engine's open path so the corruption is
   133	/// committed before the test re-opens.
   134	#[allow(dead_code)]
   135	pub fn corrupt_embedder_profile_row(db_path: &Path) {
   136	    let conn = rusqlite::Connection::open(db_path).expect("open db for profile corruption");
   137	    // NEGATIVE dimension passes the `NOT NULL` constraint but fails
   138	    // `row.get::<_, u32>(2)` with `IntegralValueOutOfRange`, which the
   139	    // engine maps to `Corruption(EmbedderIdentityDrift)`. NULL would
   140	    // hit the `NOT NULL` schema constraint and never commit.
   141	    conn.execute(
   142	        "UPDATE _fathomdb_embedder_profiles SET dimension = -1 WHERE profile = 'default'",
   143	        [],
   144	    )
   145	    .expect("set embedder profile dimension to -1");
   146	    // Force a checkpoint so the corruption lands in the main DB file
   147	    // rather than sitting in the -wal sidecar (the open path examines
   148	    // both, but we want the corruption to survive a -wal teardown).
   149	    conn.execute_batch("PRAGMA wal_checkpoint(TRUNCATE)").ok();
   150	    drop(conn);
   151	}

