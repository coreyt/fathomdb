+        File::options().read(true).write(true).open(&path).expect("sibling: open lock file");
+    let probe_fd: i32 = std::os::unix::io::AsRawFd::as_raw_fd(&probe);
+    let rc = unsafe { libc::flock(probe_fd, libc::LOCK_EX | libc::LOCK_NB) };
+    if rc == 0 {
