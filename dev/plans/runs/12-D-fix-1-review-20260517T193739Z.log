   271	#[cfg(target_os = "linux")]
   272	fn assert_lock_released_and_no_engine_residue(kind: CorruptionKind) {
   273	    let _guard = serial_guard();
   274	    let (_dir, path) = fixture_for(kind);
   275	    // Trigger the failed open; the lock must be released by the time
   276	    // the call returns.
   277	    let err = Engine::open(&path).expect_err("must fail");
   278	    assert!(matches!(err, EngineOpenError::Corruption(_)));
   279	
   280	    let lock_path = lock_path_for(&path);
   281	    assert!(lock_path.exists(), "engine should have created the lockfile before releasing it");
   282	
   283	    // True sibling-process check (AC-035c contract): a separate
   284	    // process B must observe the lock as acquirable. Re-entering the
   285	    // test binary with `FATHOMDB_TEST_LOCK_PROBE` routes to
   286	    // `_lock_acquire_probe_entry`, which exits 0 on `flock(LOCK_EX |
   287	    // LOCK_NB)` success and 1 on EWOULDBLOCK. Same-process fd
   288	    // reacquire is useful signal but is not the documented contract.
   289	    let exe = std::env::current_exe().expect("current_exe");
   290	    let probe_status = std::process::Command::new(&exe)
   291	        .args(["--exact", "--ignored", "_lock_acquire_probe_entry"])
   292	        .env("FATHOMDB_TEST_LOCK_PROBE", &lock_path)
   293	        .stdout(std::process::Stdio::null())
   294	        .stderr(std::process::Stdio::null())
   295	        .status()
   296	        .expect("spawn lock-probe sibling");
   297	    assert!(
   298	        probe_status.success(),
   299	        "AC-035c: sibling process could not acquire .lock after failed \
   300	         open ({}): probe exit {:?}",
   301	        lock_path.display(),
   302	        probe_status.code(),
   303	    );
   304	
   305	    // Same-process fd reacquire kept as a sanity check on top of the
   306	    // sibling-process contract.
   307	    let probe = File::options().read(true).write(true).open(&lock_path).expect("open lock file");
   308	    let probe_fd: i32 = std::os::unix::io::AsRawFd::as_raw_fd(&probe);
   309	    let rc = unsafe { libc::flock(probe_fd, libc::LOCK_EX | libc::LOCK_NB) };
   310	    assert_eq!(
   311	        rc,
   312	        0,
   313	        "AC-035c: lock must be releasable after failed open ({}): errno = {}",
   314	        lock_path.display(),
   315	        std::io::Error::last_os_error()
   316	    );
   317	    let _ = unsafe { libc::flock(probe_fd, libc::LOCK_UN) };
   318	
   319	    // /proc/self/fd: assert no fd points at the database file. The
   320	    // canonical absolute path of `path` must not appear as the
   321	    // destination of any open fd in this process.
   322	    let canonical = path.canonicalize().expect("canonicalize db path");
   323	    let fd_dir = PathBuf::from("/proc/self/fd");
   324	    for entry in fs::read_dir(&fd_dir).expect("read /proc/self/fd") {
   325	        let entry = entry.expect("dirent");
   326	        let link = match fs::read_link(entry.path()) {
   327	            Ok(target) => target,
   328	            // The fd may have been closed between readdir and readlink;
   329	            // race is fine for this assertion.
   330	            Err(_) => continue,
   331	        };
   332	        assert_ne!(
   333	            link,
   334	            canonical,
   335	            "AC-035c: /proc/self/fd/{} still points at the database \
   336	             file after a failed open",
   337	            entry.file_name().to_string_lossy()
   338	        );
   339	    }
   340	
   341	    // /proc/self/task: no thread named per fathomdb conventions
   342	    // (`fathomdb-reader-N`, etc.) must be live in this process.
   343	    let task_dir = PathBuf::from("/proc/self/task");
   344	    for entry in fs::read_dir(&task_dir).expect("read /proc/self/task") {
   345	        let entry = entry.expect("task dirent");
   346	        let comm_path = entry.path().join("comm");
   347	        let Ok(comm_bytes) = fs::read(&comm_path) else { continue };
   348	        let comm = String::from_utf8_lossy(&comm_bytes).trim().to_string();
   349	        assert!(
   350	            !comm.starts_with("fathomdb-"),
   351	            "AC-035c: thread named '{comm}' is still live after a failed open"
   352	        );
   353	    }
   354	}
