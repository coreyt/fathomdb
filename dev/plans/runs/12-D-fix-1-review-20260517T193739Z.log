     const WAL_MAGIC_MASK: u32 = 0xFFFF_FFFE;
     const WAL_MAGIC: u32 = 0x377F_0682;
     const SQLITE_MAX_PAGE_SIZE: u32 = 65536;
     let magic_ok = (magic & WAL_MAGIC_MASK) == WAL_MAGIC;
     let page_size_ok =
