   246	/// Run the engine call inside `py.allow_threads` and `catch_unwind`;
   247	/// translate any escaping panic to `EngineError`.
   248	///
   249	/// `AssertUnwindSafe` wraps the caller's closure so we do not need to
   250	/// require `UnwindSafe` from `f`. The engine's `Arc<dyn Embedder>`
   251	/// makes the natural `UnwindSafe` bound unsatisfiable; the engine
   252	/// itself takes care of its own atomicity post-panic.
   253	fn call_engine<R: Send>(
   254	    py: Python<'_>,
   255	    f: impl FnOnce() -> Result<R, RustEngineError> + Send,
   256	) -> PyResult<R> {
   257	    let wrapped = AssertUnwindSafe(f);
   258	    let result = py.allow_threads(|| catch_unwind(wrapped));
   259	    match result {
   260	        Ok(Ok(value)) => Ok(value),
   261	        Ok(Err(err)) => Err(engine_error_to_py(err)),
   262	        Err(_) => Err(PanicException::new_err("engine panic (see logs)")),
   263	    }
   264	}
