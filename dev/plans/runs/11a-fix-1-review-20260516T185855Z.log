   228	fn corruption_to_py(detail: CorruptionDetail) -> PyErr {
   229	    let kind = corruption_kind_str(detail.kind);
   230	    let stage = open_stage_str(detail.stage);
   231	    let recovery_hint_code = detail.recovery_hint.code;
   232	    let doc_anchor = detail.recovery_hint.doc_anchor;
   233	    let exc = CorruptionError::new_err(format!(
   234	        "corruption {kind} at stage {stage} ({recovery_hint_code})"
   235	    ));
   236	    Python::with_gil(|py| {
   237	        let v = exc.value_bound(py);
   238	        let _ = v.setattr("kind", kind);
   239	        let _ = v.setattr("stage", stage);
   240	        let _ = v.setattr("recovery_hint_code", recovery_hint_code);
   241	        let _ = v.setattr("doc_anchor", doc_anchor);
   242	    });
   243	    exc
   244	}
