    72	// ===== String validation (AC-068a / AC-068b) =========================
    73	
    74	/// Reject strings carrying an embedded NUL or an unpaired UTF-16
    75	/// surrogate codepoint (`U+D800..=U+DFFF`).
    76	///
    77	/// Both are valid Python `str` values but invalid for SQLite text
    78	/// columns; AC-068a/b requires the binding to reject them BEFORE the
    79	/// writer transaction opens (no-row-written invariant).
    80	pub fn validate_ffi_string(value: &str) -> Result<(), String> {
    81	    if value.as_bytes().contains(&0) {
    82	        return Err("embedded NUL byte in FFI string".to_string());
    83	    }
    84	    for ch in value.chars() {
    85	        let cp = ch as u32;
    86	        if (0xD800..=0xDFFF).contains(&cp) {
    87	            return Err(format!("unpaired UTF-16 surrogate U+{cp:04X} in FFI string"));
    88	        }
    89	    }
    90	    Ok(())
    91	}
    92	
    93	fn validate_ffi_string_py(value: &str) -> PyResult<()> {
    94	    validate_ffi_string(value).map_err(WriteValidationError::new_err)
    95	}
    96	
    97	/// Extract a Python string into a Rust `String` and run
    98	/// [`validate_ffi_string_py`]. PyO3's built-in `str` extraction already
    99	/// fails on lone surrogates (the underlying `PyUnicode_AsUTF8AndSize`
   100	/// raises `UnicodeEncodeError`); we re-raise those as the typed
   101	/// `WriteValidationError` so callers can dispatch on a single class.
   102	fn extract_validated_str(value: &Bound<'_, PyAny>) -> PyResult<String> {
   103	    match value.extract::<String>() {
   104	        Ok(s) => {
   105	            validate_ffi_string_py(&s)?;
   106	            Ok(s)
   107	        }
   108	        Err(_) => Err(WriteValidationError::new_err(
   109	            "string contains characters not representable as UTF-8 (lone surrogate)",
   110	        )),
   111	    }
   112	}
