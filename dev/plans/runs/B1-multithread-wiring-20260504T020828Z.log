{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01MABN9BHAyJBv5pPRkEGXZC","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FxxaSerKW1Lbo3SUN2bGmi","name":"Write","input":{"file_path":"/tmp/fdb-pack5-B1-multithread-wiring-20260504T020828Z/src/rust/crates/fathomdb-engine/tests/multithread_wiring.rs","content":"//! Phase B.1 — Runtime MULTITHREAD wiring (plan §5).\n//!\n//! Asserts `init_sqlite_runtime()` runs before any `Connection::open`\n//! and captures `sqlite3_config(SQLITE_CONFIG_MULTITHREAD)` returning\n//! `SQLITE_OK = 0`.\n//!\n//! Differentiator from §5 prior revert: §5 placed the `sqlite3_config`\n//! call inside `register_sqlite_vec_extension`'s `Once`, AFTER rusqlite\n//! had already triggered `sqlite3_initialize()` via `Connection::open`.\n//! That made `sqlite3_config` return `SQLITE_MISUSE = 21` silently —\n//! the §5 revert never asserted the rc, so the no-op slipped through.\n//!\n//! `sqlite3_threadsafe()` is NOT used here. SQLite header sqlite3.h:249-252\n//! states `sqlite3_threadsafe()` returns the *compile-time* setting and\n//! is unchanged by `sqlite3_config()`. libsqlite3-sys-0.30.1 compiles\n//! with `-DSQLITE_THREADSAFE=1`, so that value is pinned to `1` until\n//! C.1 (compile-time rebuild). See B.1 prompt UPDATE 2026-05-03.\n\nuse fathomdb_engine::{sqlite_runtime_config_rc, Engine};\nuse tempfile::TempDir;\n\nconst SQLITE_OK: i32 = 0;\n\n#[test]\nfn init_sqlite_runtime_runs_on_engine_open_and_captures_sqlite_ok() {\n    // We cannot reliably observe the pre-open `None` state because other\n    // tests in the same process may have already opened an engine. The\n    // load-bearing assertion is the post-open value: it MUST be SQLITE_OK\n    // (0). The §5 revert would observe SQLITE_MISUSE (21) here.\n    let dir = TempDir::new().expect(\"tempdir\");\n    let path = dir.path().join(\"b1.sqlite\");\n    let _opened = Engine::open(&path).expect(\"engine open\");\n\n    let rc = sqlite_runtime_config_rc().expect(\"init_sqlite_runtime ran\");\n    assert_eq!(\n        rc, SQLITE_OK,\n        \"sqlite3_config(SQLITE_CONFIG_MULTITHREAD) must return SQLITE_OK; \\\n         got {rc} (SQLITE_MISUSE = 21 indicates the §5 ordering bug — \\\n         config called after sqlite3_initialize)\"\n    );\n}\n\n#[test]\nfn init_sqlite_runtime_is_idempotent_across_engine_reopens() {\n    let dir = TempDir::new().expect(\"tempdir\");\n    let path = dir.path().join(\"b1_reopen.sqlite\");\n    let opened1 = Engine::open(&path).expect(\"first open\");\n    let rc1 = sqlite_runtime_config_rc().expect(\"init ran\");\n    drop(opened1);\n\n    let _opened2 = Engine::open(&path).expect(\"reopen\");\n    let rc2 = sqlite_runtime_config_rc().expect(\"still cached\");\n\n    assert_eq!(rc1, SQLITE_OK);\n    assert_eq!(rc2, SQLITE_OK, \"second open must observe the same cached rc, not re-shutdown\");\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":757,"cache_read_input_tokens":59833,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":757},"output_tokens":69,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"e8e03970-0bb0-4f28-945f-ef09a4c5917b","uuid":"b93d158f-1ae9-472e-a8e6-1542d790d793"}
