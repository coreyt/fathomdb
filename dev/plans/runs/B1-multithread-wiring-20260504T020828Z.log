 // (0). The §5 revert would observe SQLITE_MISUSE (21) here.\n    let dir = TempDir::new().expect(\"tempdir\");\n    let path = dir.path().join(\"b1.sqlite\");\n    let _opened = Engine::open(&path).expect(\"engine open\");\n\n    let rc = sqlite_runtime_config_rc().expect(\"init_sqlite_runtime ran\");\n    assert_eq!(\n        rc, SQLITE_OK,\n        \"sqlite3_config(SQLITE_CONFIG_MULTITHREAD) must return SQLITE_OK; \\\n         got {rc} (SQLITE_MISUSE = 21 indicates the §5 ordering bug — \\\n         config called after sqlite3_initialize)\"\n    );\n}\n\n#[test]\nfn init_sqlite_runtime_is_idempotent_across_engine_reopens() {\n    let dir = TempDir::new().expect(\"tempdir\");\n    let path = dir.path().join(\"b1_reopen.sqlite\");\n    let opened1 = Engine::open(&path).expect(\"first open\");\n    let rc1 = sqlite_runtime_config_rc().expect(\"init ran\");\n    drop(opened1);\n\n    let _opened2 = Engine::open(&path).expect(\"reopen\");\n    let rc2 = sqlite_runtime_config_rc().expect(\"still cached\");\n\n    assert_eq!(rc1, SQLITE_OK);\n    assert_eq!(rc2, SQLITE_OK, \"second open must observe the same cached rc, not re-shutdown\");\n}\n","structuredPatch":[],"originalFile":null,"userModified":false}}
