    80	/// Default connect timeout (design §2).
    81	const DEFAULT_CONNECT_TIMEOUT: Duration = Duration::from_secs(10);
    82	/// Default read timeout (design §2).
    83	const DEFAULT_READ_TIMEOUT: Duration = Duration::from_secs(60);
    84	/// Total attempts including the first (design §2).
    85	///
    86	/// Design §2 calls out "three attempts per file, with exponential backoff
    87	/// of 1s, 2s, 4s between attempts." We interpret that literally as **3
    88	/// attempt slots** (initial + 2 retries), with sleeps of **1s and 2s**
    89	/// between them — the trailing "4s" in the design phrasing is the
    90	/// hypothetical sleep that would precede a fourth slot we never make.
    91	/// See Issue 4 in the EU-3 FIX-1 review notes.
    92	const MAX_ATTEMPTS: u32 = 3;
    93	/// Default lock acquisition timeout (design §10).
    94	const DEFAULT_LOCK_TIMEOUT: Duration = Duration::from_secs(120);
    95	
    96	/// Env var consulted for the lock timeout override (design §10).
    97	pub(crate) const ENV_LOCK_TIMEOUT: &str = "FATHOMDB_EMBEDDER_LOCK_TIMEOUT_S";
    98	
    99	/// Env var consulted for the HTTP connect timeout override (design §2).
   100	pub(crate) const ENV_CONNECT_TIMEOUT: &str = "FATHOMDB_EMBEDDER_CONNECT_TIMEOUT_S";
   101	
   102	/// Env var consulted for the HTTP read timeout override (design §2).
   103	pub(crate) const ENV_READ_TIMEOUT: &str = "FATHOMDB_EMBEDDER_READ_TIMEOUT_S";
   104	
   105	/// Parse a `u64`-seconds env var, returning the default on missing/invalid.
   106	/// On invalid input emits a `stderr` warning (no panic, no `unwrap`).
   107	fn parse_secs_env_or_default(var: &str, default: Duration) -> Duration {
   108	    match std::env::var(var) {
   109	        Ok(s) => match s.parse::<u64>() {
   110	            Ok(n) => Duration::from_secs(n),
   111	            Err(_) => {
   112	                eprintln!(
   113	                    "fathomdb-embedder: invalid value for {var} ({s:?}); falling back to default \
   114	                     {default:?}"
   115	                );
   116	                default
   117	            }
   118	        },
   119	        Err(_) => default,
   120	    }

