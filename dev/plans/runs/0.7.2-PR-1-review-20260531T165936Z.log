   462	fn load_with_config_internal(cfg: LoaderConfig) -> Result<LoadedWeights, EmbedderLoadError> {
   463	    let cache_dir = cfg.cache_dir_internal();
   464	    fs::create_dir_all(&cache_dir)
   465	        .map_err(|source| EmbedderLoadError::CacheIoError { path: cache_dir.clone(), source })?;
   466	
   467	    let mut events = Vec::new();
   468	    let mut bytes_downloaded: u64 = 0;
   469	
   470	    let files = [
   471	        ("config.json", cfg.config_sha.clone()),
   472	        ("tokenizer.json", cfg.tokenizer_sha.clone()),
   473	        ("model.safetensors", cfg.model_sha.clone()),
   474	    ];
   475	
   476	    let mut paths = Vec::with_capacity(3);
   477	    for (file_name, expected_sha) in &files {
   478	        let final_path = cache_dir.join(file_name);
   479	
   480	        // Fast path: cache already valid; no lock needed (design §10).
   481	        if file_matches_sha(&final_path, expected_sha)? {
   482	            events.push(EmbedderEvent::DefaultEmbedderCacheHit {
   483	                file: (*file_name).to_string(),
   484	                sha256: expected_sha.clone(),
   485	                cache_path: final_path.clone(),
   486	            });
   487	            paths.push(final_path);
   488	            continue;
   489	        }
   490	
   491	        // HF-hub read-only compat probe (design §4): if the user already
   492	        // has the file under `$HF_HOME/hub/...` and its sha matches the
   493	        // pinned constant, copy/hard-link it into our cache and short-circuit
   494	        // network. The HF-hub layout is NEVER written to.
   495	        if let Some(hub_path) = hf_hub_candidate_path(&cfg, file_name) {
   496	            if file_matches_sha(&hub_path, expected_sha)? {
   497	                materialize_from_hf_hub(&hub_path, &final_path)?;
   498	                events.push(EmbedderEvent::DefaultEmbedderCacheHit {
   499	                    file: (*file_name).to_string(),
   500	                    sha256: expected_sha.clone(),
   501	                    cache_path: final_path.clone(),
   502	                });
   503	                paths.push(final_path);
   504	                continue;
   505	            }
   506	        }
   507	
   508	        // Cold or stale: lock, re-check, fetch.
   509	        let (n, fetched_event) = fetch_under_lock(&cfg, &cache_dir, file_name, expected_sha)?;
   510	        bytes_downloaded = bytes_downloaded.saturating_add(n);
   511	        match fetched_event {
   512	            FetchOutcome::Downloaded(ev) => events.push(ev),
   513	            FetchOutcome::CacheHitAfterLock(ev) => events.push(ev),
   514	        }
   515	        paths.push(final_path);
   516	    }
   517	
   518	    Ok(LoadedWeights {
   519	        config_json_path: paths[0].clone(),
   520	        tokenizer_json_path: paths[1].clone(),

