    38	use std::io::{Read, Seek, SeekFrom, Write};
    39	use std::path::{Path, PathBuf};
    40	use std::sync::OnceLock;
    41	use std::time::{Duration, Instant};
    42	
    43	use fs2::FileExt;
    44	use sha2::{Digest, Sha256};
    45	use thiserror::Error;
