    47	// ----- Pinned constants (design §1) -----------------------------------------
    48	
    49	/// Hugging Face model repository hosting the default embedder weights.
    50	pub(crate) const HF_REPO: &str = "BAAI/bge-small-en-v1.5";
    51	
    52	/// Pinned revision (commit SHA) on the HF repo. Bumping this is a deliberate
