    72	def placebo_doc(body: str, graph: dict, *, foreign: list[str], seed: int) -> str:
    73	    """Length-matched control: append the SAME token budget as the real enrichment,
    74	    drawn from a FOREIGN vocab (deterministic). If recall moves ≈ as much as real
    75	    enrichment, the effect is a length/corpus-stat artifact, not a lexical bridge."""
