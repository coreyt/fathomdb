   139	    systems: dict[str, Any] = {}
   140	    for bv in bs:
   141	        systems[f"bm25_plain_b{bv}"] = NaiveRAGAdapter(smoke.documents, b=bv)
   142	        systems[f"bm25_enriched_b{bv}"] = NaiveRAGAdapter(enriched, b=bv)
   143	    systems["fathomdb_fts_only"] = _fts_adapter(smoke.documents, str(db_dir / "fts_plain.sqlite"))
