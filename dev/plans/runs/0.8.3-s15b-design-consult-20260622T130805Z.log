   157	    print(f"\n[BEST enriched] R@10={best_e[0]} at b={best_e[1]} | FTS bar={bar} | "
   158	          f"{'BEATS' if (best_e[0] is not None and bar is not None and best_e[0] > bar) else 'does NOT beat'} the bar")
   159	    for v in systems.values():
   160	        eng = getattr(v, "_engine", None)
   161	        if eng is not None:
   162	            eng.close()
   163	    return 0
