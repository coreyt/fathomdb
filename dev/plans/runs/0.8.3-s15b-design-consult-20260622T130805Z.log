   147	         "bs": bs, "retrieval_loop": retrieval}, indent=2), encoding="utf-8")
   148	    print(f"[r6-b-sweep] wrote {output}\n\n=== pooled R@10 (BM25 b-sweep) ===")
   149	    pooled = {v: _pooled_r10(retrieval, v) for v in systems}
