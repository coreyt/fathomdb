   190	    import hashlib
   191	
   192	    enriched = {s: enrich_doc(b, graphs.get(s, {})) for s, b in smoke.documents.items()}
   193	    # Global foreign vocab as single tokens. Per-doc placebo EXCLUDES the doc's own
   194	    # entity tokens (codex §9 [P2] #1 — placebo must be foreign-only) and uses a
   195	    # process-STABLE seed (hashlib, not the salted built-in hash — [P2] #2).
   196	    global_tokens = [t for g in graphs.values() for n in _entities(g) for t in n.split()]
