   641	    def score_answer(
   642	        self, ground_truth: list[str] | tuple[str, ...] | None, system_answer: Optional[str]
   643	    ) -> float:
   644	        gt = list(ground_truth or [])
   645	        if gt:  # an answer exists
   646	            if system_answer is None:
   647	                return 0.0  # abstention miss — counted, never skipped
   648	            return 1.0 if _match(gt, system_answer) else 0.0
   649	        # negative class: no answer exists
