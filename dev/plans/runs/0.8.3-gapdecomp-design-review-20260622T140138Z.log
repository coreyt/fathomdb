   121	    n = len(deltas)
   122	    if n == 0:
   123	        return {"point": None, "ci_lo": None, "ci_hi": None, "mde": None, "n": 0}
   124	    arr = np.asarray(deltas, dtype=float)
   125	    point = float(arr.mean())
   126	    if n == 1:
   127	        return {"point": round(point, 6), "ci_lo": round(point, 6), "ci_hi": round(point, 6), "mde": None, "n": 1}
   128	    rng = np.random.default_rng(seed)
   129	    lo = _percentile_ci_low(arr, rng, n_boot=n_boot)
   130	    hi = _percentile_ci_high(arr, rng, n_boot=n_boot)
   131	    sd = float(arr.std(ddof=1))
   132	    mde = (_Z_975 + _Z_80) * sd / math.sqrt(n)
   133	    return {
   134	        "point": round(point, 6),
   135	        "ci_lo": round(lo, 6),
   136	        "ci_hi": round(hi, 6),
   137	        "mde": round(mde, 6),
   138	        "n": n,
   139	    }
