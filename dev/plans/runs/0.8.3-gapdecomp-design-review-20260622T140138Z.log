   259	def resume_map(prior: Mapping[str, Any]) -> dict[tuple[str, str], Optional[str]]:
   260	    """``(qid, arm) -> answer`` from a prior checkpoint's ``records``.
   261	
   262	    Membership (not value-non-``None``) is the reuse signal: a key-present ``None`` is
   263	    a legitimate prior abstention (reused, scored, no re-call); an ABSENT key is a
   264	    prior failure (re-called). Empty map → a full from-scratch pass."""
   265	    out: dict[tuple[str, str], Optional[str]] = {}
   266	    for r in prior.get("records") or []:
   267	        qid = r.get("qid")
   268	        if qid is None:
   269	            continue
   270	        for arm, ans in (r.get("answers") or {}).items():
   271	            out[(str(qid), str(arm))] = ans
   272	    return out
