   362	/// Ingest a list of docs into the engine using the same node/edge
   363	/// mapping as `examples/ingest_corpus.rs`. Returns a tuple of
   364	/// (nodes_written, edges_written, edges_by_relation).
   365	///
   366	/// Uses batched `engine.write` calls — one batch per phase (nodes,
   367	/// then edges). The engine allocates a distinct write_cursor per row
   368	/// inside the batch, so a batch of N vector-indexed nodes produces N
   369	/// rows in `vector_default`.
   370	pub fn ingest(engine: &Engine, docs: &[Doc]) -> (usize, usize, BTreeMap<String, usize>) {
   371	    let mut edges_by_relation: BTreeMap<String, usize> = BTreeMap::new();
   372	    let doc_ids: HashSet<String> = docs.iter().map(|d| d.doc_id.clone()).collect();
   373	
   374	    // NB: tests deliberately use the locked vector kind ("doc") for
   375	    // every doc rather than the doc's source_type. The
   376	    // configure_vector_kind_for_test API lets us register exactly one
   377	    // kind as vector-indexed; all corpus nodes share that kind so
   378	    // engine.search can score them uniformly. The doc's *semantic*
   379	    // source_type is preserved in source_id-style metadata downstream.
   380	    let node_batch: Vec<PreparedWrite> = docs
   381	        .iter()
   382	        .map(|doc| PreparedWrite::Node {
   383	            kind: VECTOR_KIND.to_string(),
   384	            body: doc.body.clone(),
   385	            source_id: Some(doc.doc_id.clone()),
   386	        })
   387	        .collect();
   388	    let nodes_written = node_batch.len();
   389	    if !node_batch.is_empty() {
   390	        engine.write(&node_batch).expect("write nodes batch");
   391	    }
   392	
   393	    let mut edge_batch: Vec<PreparedWrite> = Vec::new();
   394	    for doc in docs {
   395	        let Some(parent) = doc.parent_doc_id.as_ref() else { continue };
   396	        if !doc_ids.contains(parent) {
   397	            continue;
   398	        }
   399	        let kind = doc.relation_hint.clone().unwrap_or_else(|| "linked".to_string());
   400	        *edges_by_relation.entry(kind.clone()).or_insert(0) += 1;
   401	        edge_batch.push(PreparedWrite::Edge {
   402	            kind,
   403	            from: parent.clone(),
   404	            to: doc.doc_id.clone(),
   405	            source_id: Some(doc.doc_id.clone()),
   406	        });
   407	    }
   408	    let edges_written = edge_batch.len();
   409	    if !edge_batch.is_empty() {
   410	        engine.write(&edge_batch).expect("write edges batch");
   411	    }
   412	
   413	    engine.drain(30_000).expect("drain after ingest");
   414	    (nodes_written, edges_written, edges_by_relation)
   415	}
