   752	/// Atomic write: `path.tmp` → fsync-free rename. Rename is atomic on the
   753	/// same filesystem, so a reader never observes a half-written file.
   754	fn atomic_write(path: &Path, bytes: &[u8]) -> Result<(), String> {
   755	    let tmp = path.with_extension(format!(
   756	        "{}.tmp",
   757	        path.extension().and_then(|e| e.to_str()).unwrap_or("")
   758	    ));
   759	    {
   760	        let mut f = fs::File::create(&tmp).map_err(|e| format!("create {}: {e}", tmp.display()))?;
   761	        f.write_all(bytes).map_err(|e| format!("write {}: {e}", tmp.display()))?;
   762	    }
   763	    fs::rename(&tmp, path).map_err(|e| format!("rename -> {}: {e}", path.display()))?;
   764	    Ok(())
   765	}
