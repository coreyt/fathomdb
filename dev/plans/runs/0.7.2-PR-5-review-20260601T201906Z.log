   482	/// cache keyed by `sha256(identity || subset_label || doc-id manifest)`.
   483	/// Serves repeat embeds of the same text from memory; persists the full
   484	/// embed set deterministically (sorted by text digest) so two equivalent
   485	/// constructions produce byte-identical cache files.
   486	struct CachingEmbedder {
   487	    inner: Arc<dyn Embedder>,
   488	    identity: EmbedderIdentity,
   489	    /// text-sha256 -> vector
   490	    cache: RwLock<VecCache>,
   491	    cache_path: PathBuf,
   492	    meta_path: PathBuf,
   493	    doc_manifest_sha: String,
   494	    subset_label: String,
   495	    /// `true` if a valid cache file was loaded at construction.
   496	    loaded_from_disk: bool,
   497	    /// distinct texts embedded live (misses) since construction.
   498	    live_misses: AtomicUsize,
   499	}
   500	
   501	impl CachingEmbedder {
   502	    fn load(
   503	        inner: Arc<dyn Embedder>,
   504	        identity: EmbedderIdentity,
   505	        cache_dir: PathBuf,
   506	        subset_label: &str,
   507	        docs: &[Doc],
   508	    ) -> Self {
   509	        let doc_manifest_sha = doc_manifest_sha(docs);
   510	        let key = cache_key(&identity, subset_label, &doc_manifest_sha);
   511	        let cache_path = cache_dir.join(format!("{key}.bin"));
   512	        let meta_path = cache_dir.join(format!("{key}.meta.json"));
   513	
   514	        let mut cache = HashMap::new();
   515	        let mut loaded = false;
   516	        match read_cache(&cache_path, &meta_path, &identity, &doc_manifest_sha) {
   517	            Ok(Some(entries)) => {
   518	                cache = entries;
   519	                loaded = true;
   520	            }
   521	            Ok(None) => {
   522	                // Cold cache — expected on first run; quiet.
   523	            }
   524	            Err(reason) => {
   525	                eprintln!(
   526	                    "CORPUS_CACHE_MISS reason={reason} label={subset_label} path={}",
   527	                    cache_path.display()
   528	                );
   529	            }
   530	        }
   531	
   532	        Self {
   533	            inner,
   534	            identity,
   535	            cache: RwLock::new(cache),
   536	            cache_path,
   537	            meta_path,
   538	            doc_manifest_sha,
   539	            subset_label: subset_label.to_string(),
   540	            loaded_from_disk: loaded,
   541	            live_misses: AtomicUsize::new(0),
   542	        }
   543	    }
   544	
   545	    /// Persist the current embed set atomically. Returns
   546	    /// `(loaded_from_disk, live_miss_count)`. A no-op rewrite on a fully
   547	    /// warm run (loaded + zero misses) is skipped so warm runs do no disk
   548	    /// I/O; otherwise the blob is written deterministically.
   549	    fn persist(&self) -> (bool, usize) {
   550	        let live = self.live_misses.load(Ordering::Relaxed);
   551	        if self.loaded_from_disk && live == 0 {
   552	            return (true, 0);
   553	        }
   554	        if let Err(e) = self.write_cache() {
   555	            eprintln!(
   556	                "CORPUS_CACHE_WRITE_FAIL reason={e} label={} path={}",
   557	                self.subset_label,
   558	                self.cache_path.display()
   559	            );
   560	        }
   561	        (self.loaded_from_disk, live)
   562	    }
   563	
   564	    fn write_cache(&self) -> Result<(), String> {
   565	        if let Some(parent) = self.cache_path.parent() {
   566	            fs::create_dir_all(parent).map_err(|e| format!("mkdir {}: {e}", parent.display()))?;
   567	        }
   568	        let dim = self.identity.dimension as usize;
   569	        let guard = self.cache.read().expect("cache read lock");
   570	
   571	        // Deterministic order: sort entries by their text digest.
   572	        let mut keys: Vec<&[u8; 32]> = guard.keys().collect();
   573	        keys.sort_unstable();
   574	
   575	        let mut blob: Vec<u8> = Vec::with_capacity(12 + keys.len() * (32 + dim * 4));
   576	        blob.extend_from_slice(&CACHE_FORMAT_VERSION.to_le_bytes());
   577	        blob.extend_from_slice(&(self.identity.dimension).to_le_bytes());
   578	        blob.extend_from_slice(&(keys.len() as u32).to_le_bytes());
   579	        for k in &keys {
   580	            let v = &guard[*k];
   581	            debug_assert_eq!(v.len(), dim, "cached vector dim mismatch");
   582	            blob.extend_from_slice(&k[..]);
   583	            for f in v {
   584	                blob.extend_from_slice(&f.to_le_bytes());
   585	            }
   586	        }
   587	        let entry_count = keys.len();
   588	        drop(guard);
   589	
   590	        let meta = serde_json::json!({
   591	            "format_version": CACHE_FORMAT_VERSION,
   592	            "tool_version": TOOL_VERSION,
   593	            "identity": {
   594	                "name": self.identity.name,
   595	                "revision": self.identity.revision,
   596	                "dimension": self.identity.dimension,
   597	            },
   598	            "subset_label": self.subset_label,
   599	            "doc_manifest_sha": self.doc_manifest_sha,
   600	            "dim": self.identity.dimension,
   601	            "entry_count": entry_count,
   602	        });
   603	        let meta_bytes = serde_json::to_vec_pretty(&meta).map_err(|e| e.to_string())?;
   604	
   605	        atomic_write(&self.cache_path, &blob)?;
   606	        atomic_write(&self.meta_path, &meta_bytes)?;
   607	        Ok(())
   608	    }
   609	}
   610	
   611	impl Embedder for CachingEmbedder {
   612	    fn identity(&self) -> EmbedderIdentity {
   613	        self.identity.clone()
   614	    }
   615	
   616	    fn embed(&self, input: &str) -> Result<Vector, EmbedderError> {
   617	        let key = text_sha256(input);
