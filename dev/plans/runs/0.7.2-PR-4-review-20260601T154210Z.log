": {\n      \"cpu_model\": \"AMD EPYC 7763 64-Core Processor\",\n      \"cores\": 4,\n      \"os\": \"Ubuntu 24.04.4 LTS\",\n      \"kernel\": \"Linux 6.17.0-1013-azure x86_64\",\n      \"glibc\": \"2.39\",\n      \"rustc\": \"rustc 1.95.0 (59807616e 2026-04-14)\",\n      \"libsqlite3_sys\": \"libsqlite3-sys-0.28.0\"\n    },\n    \"results\": {\n      \"ac013\": {\n        \"n\": 1000000,\n        \"samples\": 1000,\n        \"seed_ms\": 562576,\n        \"p50_ms\": 2048,\n        \"p99_ms\": 2327\n      },\n      \"ac019\": {\n        \"n\": 1000000,\n        \"threads\": 8,\n        \"per_thread\": 250,\n        \"stress_ms\": 1273088,\n        \"seed_ms\": 557942,\n        \"baseline_p99_ms\": 2096,\n        \"stress_p99_ms\": 8388,\n        \"bound_ms\": 20964\n      }\n    }\n  },\n  \"verdict\": \"PENDING\",\n  \"evidence_notes\": \"\",\n  \"next_step\": \"\",\n  \"canonical_ci_url\": null\n---\ngrep: crates/fathomdb-engine/Cargo.toml: No such file or directory\nsrc/rust/crates/fathomdb-engine/Cargo.toml:18:sqlite-vec = \"=0.1.7\"","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
