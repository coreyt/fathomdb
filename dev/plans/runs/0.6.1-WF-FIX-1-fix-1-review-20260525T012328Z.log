   191	if out="$("$HELPER" 2>&1)"; then
   192	  fail "missing-arg-case: should have failed"
   193	else
   194	  if printf '%s' "$out" | grep -qi 'usage'; then
   195	    pass "missing arg → usage"
   196	  else
   197	    fail "missing-arg-case: wrong diagnostic: $out"
   198	  fi
   199	fi
   200	
   201	# 7) Regression guard: helper must set a User-Agent header (crates.io
   202	# returns HTTP 403 without one — same constraint as assert-co-tagging.sh).
   203	if grep -q 'User-Agent:' "$HELPER"; then
   204	  pass "helper sets User-Agent for crates.io"
   205	else
