   210	#    invoked. Before the fix the jq lookup silently falls through to "not found",
   211	#    the helper returns 1 and invokes cargo publish — a fail-open bug.
   212	reset_shim_log
   213	set +e
   214	out="$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.1 run_helper fathomdb-broken 2>&1)"
   215	malformed_rc=$?
