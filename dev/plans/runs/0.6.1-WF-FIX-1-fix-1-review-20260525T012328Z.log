   233	  else
   234	    fail "manifest-inline-case: log='$out' shim_log='$(cat "$CARGO_LOG")'"
   235	  fi
   236	else
   237	  fail "manifest-inline-case: helper exited non-zero: $out"
   238	fi
   239	
   240	# 10) [FINDING 2b] Manifest reader — workspace-inherited version. Read version
   241	#     from the real fathomdb-engine Cargo.toml (version.workspace = true →
   242	#     0.6.1 per [workspace.package]); no CARGO_PUBLISH_IF_NEW_LOCAL_VERSION
   243	#     bypass. Registry has only 0.6.1-rc.1 and 0.6.0 → publish.
   244	reset_shim_log
   245	if out="$(run_helper fathomdb-engine 2>&1)"; then
   246	  if grep -q -- '-p fathomdb-engine' "$CARGO_LOG" \
   247	     && grep -q 'publish' "$CARGO_LOG" \
   248	     && ! grep -q -- '--dry-run' "$CARGO_LOG"; then
   249	    pass "manifest reader: workspace-inherited version (0.6.1) → cargo publish"
   250	  else
   251	    fail "manifest-workspace-case: shim_log='$(cat "$CARGO_LOG")' helper='$out'"
   252	  fi
   253	else
   254	  fail "manifest-workspace-case: helper exited non-zero: $out"
   255	fi
