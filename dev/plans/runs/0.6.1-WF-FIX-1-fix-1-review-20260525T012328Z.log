    kill "$PID" 2>/dev/null || true
    wait "$PID" 2>/dev/null || true
    PID=0
  fi
}

# Install a fake `cargo` shim that records its argv and exits with the
# code from $CARGO_SHIM_EXIT (default 0). The shim does NOT touch the
