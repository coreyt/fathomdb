   168	reset_shim_log
   169	if out="$(CARGO_PUBLISH_IF_NEW_LOCAL_VERSION=0.6.0 \
   170	            run_helper --dry-run fathomdb-embedder-api 2>&1)"; then
   171	  if grep -q -- '--dry-run' "$CARGO_LOG" \
   172	     && grep -q -- '-p fathomdb-embedder-api' "$CARGO_LOG"; then
   173	    pass "--dry-run forwards regardless of registry state"
   174	  else
