   223	fi
   224	
   225	# 9) [FINDING 2a] Manifest reader — inline version. Read version directly from
   226	#    the real fathomdb-embedder-api Cargo.toml (version = "0.6.0"); no
   227	#    CARGO_PUBLISH_IF_NEW_LOCAL_VERSION bypass. Registry has 0.6.0 → skip.
   228	reset_shim_log
   229	if out="$(run_helper fathomdb-embedder-api 2>&1)"; then
   230	  if printf '%s' "$out" | grep -q 'already published; skipping' \
   231	     && ! [ -s "$CARGO_LOG" ]; then
