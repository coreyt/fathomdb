     queued_jobs: usize,
     frozen: bool,
     pending_scan: bool,
     stopping: bool,
     in_flight: BTreeSet<u64>,
 }
 
 struct ProjectionRuntimeShared {
     path: PathBuf,
     embedder: Option<Arc<dyn Embedder>>,
     embedder_identity: EmbedderIdentity,
     state: Mutex<ProjectionRuntimeState>,
     state_cvar: Condvar,
