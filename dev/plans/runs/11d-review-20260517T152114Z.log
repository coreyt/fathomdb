--- scripts/tests/test_assert_co_tagging.sh
     1	#!/usr/bin/env bash
     2	# scripts/tests/test_assert_co_tagging.sh — coverage for the sibling-package
     3	# co-tagging assert per AC-052. Runs offline against a python3 -m http.server
     4	# fixture so the test never hits crates.io.
     5	#
     6	# Verifies the script asserts that, for a given Axis-W version, all three
     7	# sibling crates (fathomdb, fathomdb-embedder at Axis W; fathomdb-embedder-api
     8	# at Axis E) exist in the registry.
     9	set -euo pipefail
    10	
    11	SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    12	REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
    13	ASSERT="$REPO_ROOT/scripts/release/assert-co-tagging.sh"
    14	FIX="$REPO_ROOT/dev/release/fixtures/co-tagging"
    15	
    16	FAILED=0
    17	SERVE_DIR="$(mktemp -d)"
    18	PORT=0
    19	PID=0
    20	
    21	cleanup() {
    22	  if [ "$PID" -ne 0 ]; then
    23	    kill "$PID" 2>/dev/null || true
    24	    wait "$PID" 2>/dev/null || true
    25	  fi
    26	  rm -rf "$SERVE_DIR"
    27	}
    28	trap cleanup EXIT
    29	
    30	pass() { printf 'PASS  %s\n' "$1"; }
    31	fail() { printf 'FAIL  %s\n' "$1" >&2; FAILED=$((FAILED + 1)); }
    32	
    33	# Mirror the crates.io URL shape: /api/v1/crates/<name>. http.server will
    34	# serve these paths as regular files when no directory of that name exists.
    35	mkdir -p "$SERVE_DIR/api/v1/crates"
    36	
    37	start_server() {
    38	  local layout="$1"  # 'ok' or 'missing-embedder'
    39	  cp "$FIX/fathomdb-ok.json"               "$SERVE_DIR/api/v1/crates/fathomdb"
    40	  cp "$FIX/fathomdb-embedder-api-ok.json"  "$SERVE_DIR/api/v1/crates/fathomdb-embedder-api"
    41	  case "$layout" in
    42	    ok)               cp "$FIX/fathomdb-embedder-ok.json"      "$SERVE_DIR/api/v1/crates/fathomdb-embedder" ;;
    43	    missing-embedder) cp "$FIX/fathomdb-embedder-missing.json" "$SERVE_DIR/api/v1/crates/fathomdb-embedder" ;;
    44	  esac
    45	  ( cd "$SERVE_DIR" && python3 -u -m http.server 0 ) >"$SERVE_DIR/server.log" 2>&1 &
    46	  PID=$!
    47	  # Wait for the server to print its bound port.
    48	  for _ in $(seq 1 50); do
    49	    if grep -qE 'Serving HTTP on .* port [0-9]+' "$SERVE_DIR/server.log" 2>/dev/null; then
    50	      PORT="$(sed -nE 's/.*port ([0-9]+).*/\1/p' "$SERVE_DIR/server.log" | head -1)"
    51	      break
    52	    fi
    53	    sleep 0.05
    54	  done
    55	  if [ "$PORT" -eq 0 ]; then
    56	    fail "fixture http server failed to bind"
    57	    return 1
    58	  fi
    59	}
    60	
    61	stop_server() {
    62	  if [ "$PID" -ne 0 ]; then
    63	    kill "$PID" 2>/dev/null || true
    64	    wait "$PID" 2>/dev/null || true
    65	    PID=0
    66	  fi
    67	  # Reset served files between fixture layouts.
    68	  rm -rf "$SERVE_DIR/api"
    69	  mkdir -p "$SERVE_DIR/api/v1/crates"
    70	}
    71	
    72	# Positive case: all three crates present at 0.6.0 (Axis W) /
    73	# 0.6.0 (Axis E read from src/rust/crates/fathomdb-embedder-api/Cargo.toml).
    74	start_server ok
    75	if ASSERT_CO_TAGGING_REGISTRY="http://127.0.0.1:${PORT}" "$ASSERT" 0.6.0 >/dev/null 2>&1; then
    76	  pass "all three sibling crates present at 0.6.0 → pass"
    77	else
    78	  fail "all-present case should succeed"
    79	fi
    80	stop_server
    81	
    82	# Negative case: fathomdb-embedder is missing 0.6.0 → fail with
    83	# structured `co-tagging-violation:` diagnostic naming the package.
    84	start_server missing-embedder
    85	if out="$(ASSERT_CO_TAGGING_REGISTRY="http://127.0.0.1:${PORT}" "$ASSERT" 0.6.0 2>&1)"; then
    86	  fail "missing-embedder case should fail"
    87	else
    88	  printf '%s' "$out" | grep -q 'co-tagging-violation:' \
    89	    && printf '%s' "$out" | grep -q 'fathomdb-embedder' \
    90	    && pass "missing-embedder produces structured co-tagging-violation diagnostic" \
    91	    || fail "wrong diagnostic for missing-embedder; got: $out"
    92	fi
    93	stop_server
    94	
    95	# Bad version argument → exit non-zero with usage-like diagnostic.
    96	if out="$("$ASSERT" not-a-semver 2>&1)"; then
    97	  fail "non-semver version should be rejected"
    98	else
    99	  printf '%s' "$out" | grep -qiE 'usage|invalid|version' \
   100	    && pass "non-semver version rejected" \
   101	    || fail "wrong diagnostic for non-semver; got: $out"
   102	fi
   103	
   104	# Missing argument → exit non-zero with usage.
   105	if out="$("$ASSERT" 2>&1)"; then
   106	  fail "missing version arg should fail"
   107	else
   108	  printf '%s' "$out" | grep -qi 'usage' \
   109	    && pass "missing version arg → usage" \
   110	    || fail "wrong diagnostic for missing arg; got: $out"
   111	fi
   112	
   113	if [ "$FAILED" -gt 0 ]; then
   114	  printf '\n%d test(s) failed\n' "$FAILED" >&2
   115	  exit 1
   116	fi
   117	printf '\nAll assert-co-tagging tests passed\n'
--- scripts/verify-release-gates.sh
     1	#!/usr/bin/env bash
     2	# scripts/verify-release-gates.sh — release-time preflight.
     3	#
     4	# Asserts (in order, fail-fast):
     5	#   1. GITHUB_REF_NAME is set and looks like `v<axis-W-version>`, and the
     6	#      bare version matches Axis W (Cargo.toml [workspace.package].version).
     7	#   2. set-version.sh --check-files passes (two-axis lockstep + inheritance).
     8	#   3. HEAD commit is reachable from `main` (overridable via env for tests).
     9	#   4. CHANGELOG.md has a section heading matching the tag's Axis-W version.
    10	#   5. Every publishable workspace crate has `description`, `license`, and
    11	#      `repository` fields populated (cargo publish requires these; failing
    12	#      early beats failing at T4 after T1+T2+T3 succeed).
    13	#
    14	# Test seams (env overrides; do not use in CI):
    15	#   RELEASE_GATES_SKIP_GIT_REACH=1  Skip check 3 entirely.
    16	#   RELEASE_GATES_HEAD_REF=<ref>    Compare against this ref instead of main.
    17	#   RELEASE_GATES_CHANGELOG=<path>  Use this CHANGELOG file instead of repo root.
    18	#
    19	# Owner: dev/design/release.md § Tiered publish order (entry gate to T1).
    20	set -euo pipefail
    21	
    22	REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
    23	CARGO="$REPO_ROOT/Cargo.toml"
    24	CRATES_DIR="$REPO_ROOT/src/rust/crates"
    25	SET_VERSION="$REPO_ROOT/scripts/set-version.sh"
    26	
    27	die() {
    28	  printf 'release-gate: %s\n' "$*" >&2
    29	  exit 1
    30	}
    31	
    32	# Mirror of set-version.sh's reader; duplicated here to avoid sourcing a
    33	# script that has top-level dispatch logic.
    34	read_workspace_version() {
    35	  awk '
    36	    /^\[workspace\.package\]/ { in_block = 1; next }
    37	    /^\[/                     { in_block = 0 }
    38	    in_block && /^version[[:space:]]*=/ {
    39	      n = split($0, parts, "\"")
    40	      if (n >= 3) { print parts[2] }
    41	      exit
    42	    }
    43	  ' "$CARGO"
    44	}
    45	
    46	# --- Check 1: tag presence + Axis W match -----------------------------------
    47	
    48	if [ -z "${GITHUB_REF_NAME:-}" ]; then
    49	  die "GITHUB_REF_NAME is not set; this script must run under a tag push (refs/tags/v*)"
    50	fi
    51	
    52	TAG="$GITHUB_REF_NAME"
    53	case "$TAG" in
    54	  v*) ;;
    55	  *) die "tag '$TAG' does not start with 'v'; release tags must look like v<axis-W-version>" ;;
    56	esac
    57	
    58	TAG_VERSION="${TAG#v}"
    59	WS_VERSION="$(read_workspace_version)"
    60	if [ -z "$WS_VERSION" ]; then
    61	  die "Cargo.toml: no [workspace.package] version found"
    62	fi
    63	if [ "$TAG_VERSION" != "$WS_VERSION" ]; then
    64	  die "tag/workspace version mismatch — tag is '$TAG_VERSION', Cargo.toml [workspace.package].version is '$WS_VERSION'"
    65	fi
    66	
    67	# --- Check 2: --check-files lockstep ----------------------------------------
    68	
    69	if ! cf_out="$(bash "$SET_VERSION" --check-files 2>&1)"; then
    70	  printf '%s\n' "$cf_out" >&2
    71	  die "set-version.sh --check-files failed; resolve the version drift above before tagging"
    72	fi
    73	
    74	# --- Check 3: HEAD reachable from main --------------------------------------
    75	
    76	if [ "${RELEASE_GATES_SKIP_GIT_REACH:-0}" != "1" ]; then
    77	  main_ref="${RELEASE_GATES_HEAD_REF:-refs/heads/main}"
    78	  if ! git -C "$REPO_ROOT" rev-parse --verify "$main_ref" >/dev/null 2>&1; then
    79	    die "cannot resolve $main_ref; release tags must be cut from a commit on main"
    80	  fi
    81	  head_sha="$(git -C "$REPO_ROOT" rev-parse HEAD)"
    82	  if ! git -C "$REPO_ROOT" merge-base --is-ancestor "$head_sha" "$main_ref" 2>/dev/null; then
    83	    die "HEAD ($head_sha) is not reachable from $main_ref; release tags must be cut from main"
    84	  fi
    85	fi
    86	
    87	# --- Check 4: CHANGELOG heading for this version ----------------------------
    88	
    89	CHANGELOG="${RELEASE_GATES_CHANGELOG:-$REPO_ROOT/CHANGELOG.md}"
    90	if [ ! -f "$CHANGELOG" ]; then
    91	  die "CHANGELOG.md not found at $CHANGELOG; create one with a '## $WS_VERSION' section before tagging"
    92	fi
    93	if ! grep -qE "^##[[:space:]]+v?${WS_VERSION//./\\.}([[:space:]].*)?\$" "$CHANGELOG"; then
    94	  die "CHANGELOG.md has no '## $WS_VERSION' (or '## v$WS_VERSION') section heading"
    95	fi
    96	
    97	# --- Check 5: cargo publish required fields ---------------------------------
    98	# `license.workspace = true` + `repository.workspace = true` are inherited
    99	# from [workspace.package]; we only need to check `description` is present
   100	# per-crate (cargo emits a warning but accepts publish without it — we
   101	# treat it as required for first-class packages).
   102	
   103	PUBLISHABLE_CRATES=(
   104	  fathomdb
   105	  fathomdb-cli
   106	  fathomdb-embedder
   107	  fathomdb-embedder-api
   108	  fathomdb-engine
   109	  fathomdb-query
   110	  fathomdb-schema
   111	)
   112	
   113	# Read the [package] block until next [section] and check field presence.
   114	has_package_field() {
   115	  local manifest="$1" field="$2"
   116	  awk -v field="$field" '
   117	    /^\[package\]/ { in_block = 1; next }
   118	    /^\[/ && in_block { exit }
   119	    in_block && $0 ~ ("^" field "[[:space:]]*[=.]") { found = 1; exit }
   120	    END { exit (found ? 0 : 1) }
   121	  ' "$manifest"
   122	}
   123	
   124	missing=0
   125	for crate in "${PUBLISHABLE_CRATES[@]}"; do
   126	  manifest="$CRATES_DIR/$crate/Cargo.toml"
   127	  if [ ! -f "$manifest" ]; then
   128	    printf 'release-gate: %s: manifest missing\n' "$manifest" >&2
   129	    missing=1
   130	    continue
   131	  fi
   132	  for field in description license repository; do
   133	    if ! has_package_field "$manifest" "$field"; then
   134	      printf 'release-gate: %s: missing required field "%s" in [package]\n' \
   135	        "$manifest" "$field" >&2
   136	      missing=1
   137	    fi
   138	  done
   139	done
   140	if [ "$missing" -ne 0 ]; then
   141	  die "one or more crates are missing cargo publish metadata; fix and retag"
   142	fi
   143	
   144	printf 'release-gate: ok — tag=%s, axis-W=%s\n' "$TAG" "$WS_VERSION"
--- scripts/agent-lint.sh
     1	#!/usr/bin/env bash
     2	# Lint all language surfaces. Pass-through diagnostics unparaphrased on failure.
     3	set -euo pipefail
     4	
     5	SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
     6	# shellcheck source=lib/agent-output.sh
     7	. "$SCRIPT_DIR/lib/agent-output.sh"
