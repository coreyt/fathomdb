--- scripts/release/assert-co-tagging.sh
     1	#!/usr/bin/env bash
     2	# scripts/release/assert-co-tagging.sh — REQ-048 / AC-052 sibling-package
     3	# co-tagging assertion. Run after publish-rust-t7-cli + publish-pypi +
     4	# publish-npm complete; verifies that all three sibling crates exist on
     5	# crates.io at the expected versions before the release is marked done.
     6	#
     7	#   $1 = Axis W version (the tag's bare version)
     8	#
     9	# Axis E version is read from the embedder-api crate manifest at HEAD,
    10	# matching `dev/design/release.md § Version axes`.
    11	#
    12	# Env override (for tests):
    13	#   ASSERT_CO_TAGGING_REGISTRY — base URL (e.g. http://127.0.0.1:PORT)
    14	#                                used in place of https://crates.io.
    15	set -euo pipefail
    16	
    17	REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
    18	EMB_API_MANIFEST="$REPO_ROOT/src/rust/crates/fathomdb-embedder-api/Cargo.toml"
    19	
    20	usage() {
    21	  cat <<'USAGE' >&2
    22	Usage: assert-co-tagging.sh <axis-W-version>
    23	
    24	Asserts that fathomdb, fathomdb-embedder, and fathomdb-embedder-api
    25	all exist in the registry at the expected versions for this tag.
    26	USAGE
    27	}
    28	
    29	if [ "$#" -ne 1 ]; then
    30	  usage
    31	  exit 2
    32	fi
    33	
    34	VERSION="$1"
    35	if ! printf '%s' "$VERSION" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
    36	  printf 'assert-co-tagging: invalid version "%s" — expected semver MAJOR.MINOR.PATCH\n' \
    37	    "$VERSION" >&2
    38	  usage
    39	  exit 2
    40	fi
    41	
    42	# Read Axis E version from the embedder-api crate manifest. Matches the
    43	# reader in scripts/set-version.sh.
    44	read_embedder_api_version() {
    45	  awk '
    46	    /^\[package\]/ { in_block = 1; next }
    47	    /^\[/          { in_block = 0 }
    48	    in_block && /^version[[:space:]]*=[[:space:]]*"/ {
    49	      n = split($0, parts, "\"")
    50	      if (n >= 3) { print parts[2] }
    51	      exit
    52	    }
    53	  ' "$EMB_API_MANIFEST"
    54	}
    55	
    56	EMB_API_VERSION="$(read_embedder_api_version)"
    57	if [ -z "$EMB_API_VERSION" ]; then
    58	  printf 'assert-co-tagging: cannot read Axis E version from %s\n' \
    59	    "$EMB_API_MANIFEST" >&2
    60	  exit 1
    61	fi
    62	
    63	REGISTRY_BASE="${ASSERT_CO_TAGGING_REGISTRY:-https://crates.io}"
    64	
    65	# Returns 0 if $expected_version appears in versions[].num for $crate;
    66	# 1 otherwise. Curl failure is fatal (network/registry outage at the
    67	# release-finalize step is a real signal, not a soft-skip).
    68	assert_crate_has_version() {
    69	  local crate="$1" expected="$2"
    70	  local url="${REGISTRY_BASE}/api/v1/crates/${crate}"
    71	  local body
    72	  if ! body="$(curl --silent --show-error --fail --max-time 30 "$url" 2>&1)"; then
    73	    printf 'assert-co-tagging: registry query failed for %s — %s\n' \
    74	      "$crate" "$body" >&2
    75	    return 2
    76	  fi
    77	  if printf '%s' "$body" | jq -e --arg v "$expected" \
    78	       '.versions | map(.num) | index($v) != null' >/dev/null 2>&1; then
    79	    return 0
    80	  fi
    81	  printf 'co-tagging-violation: %s %s not in registry\n' \
    82	    "$crate" "$expected" >&2
    83	  return 1
    84	}
    85	
    86	rc=0
    87	assert_crate_has_version fathomdb              "$VERSION"         || rc=1
    88	assert_crate_has_version fathomdb-embedder     "$VERSION"         || rc=1
    89	assert_crate_has_version fathomdb-embedder-api "$EMB_API_VERSION" || rc=1
    90	
    91	if [ "$rc" -eq 0 ]; then
    92	  printf 'assert-co-tagging: ok — axis-W=%s, axis-E=%s present in registry\n' \
    93	    "$VERSION" "$EMB_API_VERSION"
    94	fi
    95	exit "$rc"
