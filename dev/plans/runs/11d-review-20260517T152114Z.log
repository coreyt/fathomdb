    12	
    13	if [ "$#" -ne 1 ]; then
    14	  printf 'usage: %s <version>\n' "$0" >&2
    15	  exit 2
    16	fi
    17	VERSION="$1"
    18	if ! printf '%s' "$VERSION" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
    19	  printf 'smoke-pypi-wheel: invalid version "%s" — expected semver MAJOR.MINOR.PATCH\n' \
    20	    "$VERSION" >&2
    21	  exit 2
    22	fi
    23	
    24	WORK="$(mktemp -d)"
    25	trap 'rm -rf "$WORK"' EXIT
    26	
    27	python3 -m venv "$WORK/venv"
    28	# shellcheck source=/dev/null
    29	. "$WORK/venv/bin/activate"
    30	pip install --quiet --upgrade pip
    31	pip install --quiet "fathomdb==${VERSION}"
    32	
    33	DB="$WORK/smoke.fdb"
    34	python3 - "$DB" <<'PY'
    35	import sys
    36	from fathomdb import Engine
    37	db_path = sys.argv[1]
    38	e = Engine.open(db_path)
    39	e.write([])
    40	e.search("smoke")
    41	e.close()
    42	print("ok")
    43	PY
    44	
    45	printf 'smoke-pypi-wheel: ok — fathomdb %s installed + open/write/search/close + process exit clean\n' \
    46	  "$VERSION"
