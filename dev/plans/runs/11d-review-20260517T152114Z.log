     1	#!/usr/bin/env bash
     2	# scripts/tests/test_smoke_scripts.sh — STRUCTURAL coverage for the three
     3	# post-publish smoke scripts under scripts/release/smoke/.
     4	#
     5	# WHY this is structural (no shelled-out integration):
     6	#   The smoke scripts install from real registries (crates.io / PyPI /
     7	#   npm). Running them in unit tests would require network, the published
     8	#   artifact already existing at the test version, and tens of seconds of
     9	#   wall time per script — all flaky in CI. Their behavior is exercised
    10	#   in production at tag time by the release workflow's post-publish-smoke
    11	#   job. What we CAN test cheaply is that the script body has the
    12	#   contract-shape we depend on:
    13	#     * hardened bash (`set -euo pipefail`).
    14	#     * version regex check on $1 BEFORE any registry call.
    15	#     * mktemp -d + EXIT trap for cleanup (no leaked work dirs on failure).
    16	#     * version-pinned install command (the published version is the
    17	#       version under test, not "latest" or "*").
    18	#   These are the structural invariants that, if broken, would cause the
    19	#   real smoke job to install the wrong artifact or leak files.
    20	set -euo pipefail
    21	
    22	SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    23	REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
    24	SMOKE_DIR="$REPO_ROOT/scripts/release/smoke"
    25	
    26	FAILED=0
    27	pass() { printf 'PASS  %s\n' "$1"; }
    28	fail() { printf 'FAIL  %s\n' "$1" >&2; FAILED=$((FAILED + 1)); }
    29	
    30	# Asserts a string is present in the file body; fails with the literal
    31	# needle in the diagnostic so debugging is one grep away.
    32	assert_contains() {
    33	  local label="$1" file="$2" needle="$3"
    34	  if grep -qF -- "$needle" "$file"; then
    35	    pass "$label"
    36	  else
    37	    fail "$label (missing literal: $needle)"
    38	  fi
    39	}
    40	
    41	assert_matches() {
    42	  local label="$1" file="$2" pattern="$3"
    43	  if grep -qE -- "$pattern" "$file"; then
    44	    pass "$label"
    45	  else
    46	    fail "$label (no match for pattern: $pattern)"
    47	  fi
    48	}
    49	
    50	check_common() {
    51	  local script="$1" label_prefix="$2"
    52	  [ -x "$script" ] || fail "$label_prefix: not executable"
    53	  # Shebang.
    54	  if head -1 "$script" | grep -qE '^#!.*bash'; then
    55	    pass "$label_prefix: bash shebang"
    56	  else
    57	    fail "$label_prefix: missing bash shebang"
    58	  fi
    59	  assert_contains "$label_prefix: set -euo pipefail" "$script" 'set -euo pipefail'
    60	  # Version regex — semver MAJOR.MINOR.PATCH guard on $1.
    61	  assert_matches  "$label_prefix: version regex guard on \$1" "$script" \
    62	    '\^\[0-9\]\+\\\.\[0-9\]\+\\\.\[0-9\]\+\$'
    63	  assert_contains "$label_prefix: mktemp -d for fixture dir" "$script" 'mktemp -d'
    64	  assert_contains "$label_prefix: EXIT trap cleanup" "$script" "trap 'rm -rf"
    65	}
    66	
    67	CRATES="$SMOKE_DIR/smoke-crates-cli.sh"
    68	PYPI="$SMOKE_DIR/smoke-pypi-wheel.sh"
    69	NPM="$SMOKE_DIR/smoke-npm-package.sh"
