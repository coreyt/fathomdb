     1	#!/usr/bin/env bash
     2	# scripts/release/smoke/smoke-crates-cli.sh — AC-056 crates.io smoke.
     3	#
     4	#   $1 = version (e.g. 0.6.0)
     5	#
     6	# Installs fathomdb-cli from crates.io (NOT from this workspace), creates a
     7	# fresh fixture DB in a tempdir, runs `fathomdb doctor check-integrity
     8	# --json` against it, asserts exit 0 + valid JSON output. Engine::open
     9	# creates the DB file lazily, so the smoke does not need an init verb.
    10	#
    11	# Per `feedback_release_verification`: green CI + published artifact is NOT
    12	# done. This script is the gate that proves the published crate actually
    13	# installs and runs cleanly on a fresh ubuntu — distinct from the CI build,
    14	# which only proves the workspace tree compiles.
    15	set -euo pipefail
    16	
    17	if [ "$#" -ne 1 ]; then
    18	  printf 'usage: %s <version>\n' "$0" >&2
    19	  exit 2
    20	fi
    21	VERSION="$1"
    22	if ! printf '%s' "$VERSION" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
    23	  printf 'smoke-crates-cli: invalid version "%s" — expected semver MAJOR.MINOR.PATCH\n' \
    24	    "$VERSION" >&2
    25	  exit 2
    26	fi
    27	
    28	WORK="$(mktemp -d)"
    29	trap 'rm -rf "$WORK"' EXIT
    30	
    31	# `cargo install` honors --root for the install prefix; binary lands at
    32	# $WORK/bin/fathomdb.
    33	cargo install fathomdb-cli --version "$VERSION" --root "$WORK" --locked
    34	
    35	DB="$WORK/smoke.fdb"
    36	OUT="$("$WORK/bin/fathomdb" doctor check-integrity --json "$DB")"
    37	printf '%s\n' "$OUT" | jq -e . >/dev/null
    38	
    39	printf 'smoke-crates-cli: ok — fathomdb-cli %s installed + check-integrity returned valid JSON\n' \
    40	  "$VERSION"
