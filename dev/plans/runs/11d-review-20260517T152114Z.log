    81	assert_contains "smoke-pypi-wheel: pinned pip install" "$PYPI" \
    82	  'pip install --quiet "fathomdb==${VERSION}"'
    83	assert_contains "smoke-pypi-wheel: open/close exercise" "$PYPI" 'Engine.open'
    84	assert_contains "smoke-pypi-wheel: close call" "$PYPI" 'e.close()'
    85	
    86	check_common "$NPM" "smoke-npm-package"
    87	assert_contains "smoke-npm-package: fresh npm init" "$NPM" 'npm init -y'
    88	assert_contains "smoke-npm-package: pinned npm install" "$NPM" \
    89	  'npm install --silent "fathomdb@${VERSION}"'
    90	assert_contains "smoke-npm-package: Engine.open exercise" "$NPM" 'Engine.open'
    91	assert_contains "smoke-npm-package: close call" "$NPM" 'await e.close()'
