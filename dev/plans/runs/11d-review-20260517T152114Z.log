          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}
      - name: Wait for crates.io index propagation
        if: ${{ inputs.dry_run != true }}
        run: sleep 60

  publish-rust-t5-embedder:
    runs-on: ubuntu-latest
    # T5 depends on Axis E (T1) in graph terms but waits for T4 here so the
    # 60s index-propagation cadence stays linear; parallelizing T5 with T4
    # would race the crates.io index from two directions for no real wall-
    # clock win.
    needs: publish-rust-t4-engine
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
        with:
          toolchain: stable
      - name: cargo publish fathomdb-embedder
        run: |
          if [ "${DRY_RUN}" = "true" ]; then
            cargo publish --dry-run -p fathomdb-embedder
          else
            cargo publish -p fathomdb-embedder --token "${CARGO_REGISTRY_TOKEN}"
          fi
        env:
          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}
      - name: Wait for crates.io index propagation
        if: ${{ inputs.dry_run != true }}
        run: sleep 60

  publish-rust-t6-facade:
    runs-on: ubuntu-latest
    needs: publish-rust-t5-embedder
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
        with:
          toolchain: stable
      - name: cargo publish fathomdb (facade)
        run: |
          if [ "${DRY_RUN}" = "true" ]; then
            cargo publish --dry-run -p fathomdb
          else
            cargo publish -p fathomdb --token "${CARGO_REGISTRY_TOKEN}"
          fi
        env:
          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}
      - name: Wait for crates.io index propagation
        if: ${{ inputs.dry_run != true }}
        run: sleep 60

  publish-rust-t7-cli:
    runs-on: ubuntu-latest
    needs: publish-rust-t6-facade
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
        with:
          toolchain: stable
      - name: cargo publish fathomdb-cli
        run: |
          if [ "${DRY_RUN}" = "true" ]; then
            cargo publish --dry-run -p fathomdb-cli
          else
            cargo publish -p fathomdb-cli --token "${CARGO_REGISTRY_TOKEN}"
          fi
        env:
          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}
      - name: Wait for crates.io index propagation
        if: ${{ inputs.dry_run != true }}
        run: sleep 60

  # --- Tier 8: binding-package parallel publishes ----------------------------
  # PyPI + npm wrap fathomdb-engine directly (PyO3 / napi-rs). They publish
  # in parallel after T4 resolves on crates.io — independent of T5..T7.

  publish-pypi:
    runs-on: ubuntu-latest
    needs: publish-rust-t4-engine
    environment:
      name: pypi
    steps:
      - uses: actions/download-artifact@3e5f45b2cfb9172054b4087a40e8e0b5a5461e7c # v8.0.1
        with:
          pattern: python-dist-*
          merge-multiple: true
          path: dist
      - name: Publish to PyPI (or test.pypi on dry-run)
        uses: pypa/gh-action-pypi-publish@cef221092ed1bacb1cc03d23a2d87d1d172e277b # v1.14.0
        with:
          packages-dir: dist
          repository-url: ${{ env.DRY_RUN == 'true' && 'https://test.pypi.org/legacy/' || '' }}

  publish-npm:
    runs-on: ubuntu-latest
    needs: publish-rust-t4-engine
    permissions:
      contents: read
      id-token: write
    defaults:
      run:
        working-directory: src/ts
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
      - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0
        with:
          node-version: "22"
          registry-url: "https://registry.npmjs.org"
      # Pull every platform binary into src/ts/ as siblings of dist/ — the
      # napi loader expects fathomdb.<platform>-<arch>.node relative to
      # the compiled JS, and the package.json `files` list ships them.
      - uses: actions/download-artifact@3e5f45b2cfb9172054b4087a40e8e0b5a5461e7c # v8.0.1
        with:
          pattern: napi-*
          merge-multiple: true
          path: src/ts
      - name: List staged artifacts
        run: ls -la
      - name: Install + build TypeScript
        run: |
          npm ci
          # The native binaries are already downloaded from build-napi;
          # only the tsc step is needed here.
          npx tsc -p tsconfig.json
      # npm OIDC trusted publishing requires npm >= 11.5.1 but Node 22
      # ships with npm 10.x. Using npx to invoke the latest npm avoids
      # the MODULE_NOT_FOUND bug from `npm install -g npm@latest` while
      # still getting a version that supports OIDC. --access public makes
      # the bare (unscoped) package publishable; --provenance attests
      # the build came from this workflow run.
      - name: Publish to npm (or dry-run rehearsal)
        run: |
          if [ "${DRY_RUN}" = "true" ]; then
            npx npm@latest publish --dry-run --access public --provenance
          else
            npx npm@latest publish --provenance --access public
          fi

  # --- Post-publish verification --------------------------------------------
  # AC-056: a published artifact is not "done" until it installs cleanly from
  # the registry on a fresh machine and the SDK opens + closes + process-exits.
  # Skipped on dry-run — install-from-test.pypi does not mirror prod closely
  # enough to make the smoke meaningful, and npm has no comparable staging.
  post-publish-smoke:
    runs-on: ubuntu-latest
    if: ${{ inputs.dry_run != true }}
    needs:
      - publish-rust-t7-cli
      - publish-pypi
      - publish-npm
    strategy:
      fail-fast: false
      matrix:
        smoke:
          - crates-cli
          - pypi-wheel
          - npm-package
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
      - uses: actions/setup-python@a309ff8b426b58ec0e2a45f0f869d46889d02405 # v6.2.0
        if: matrix.smoke == 'pypi-wheel'
        with:
          python-version: "3.12"
      - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0
        if: matrix.smoke == 'npm-package'
        with:
          node-version: "22"
      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
        if: matrix.smoke == 'crates-cli'
        with:
          toolchain: stable
      - name: Resolve tag version
        id: ver
        run: |
          v="${GITHUB_REF_NAME#v}"
          echo "version=${v}" >> "$GITHUB_OUTPUT"
      - name: Run smoke
        run: bash "scripts/release/smoke/smoke-${{ matrix.smoke }}.sh" "${{ steps.ver.outputs.version }}"

  # AC-052: sibling triple (fathomdb + fathomdb-embedder + fathomdb-embedder-
  # api) must all exist in the registry at the expected versions after the
  # tier 1..7 publishes complete. Skipped on dry-run since no real publish
  # happened.
  co-tagging-assert:
    runs-on: ubuntu-latest
    if: ${{ inputs.dry_run != true }}
    needs:
      - publish-rust-t7-cli
      - publish-pypi
      - publish-npm
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
      - name: Resolve tag version
        id: ver
        run: |
          v="${GITHUB_REF_NAME#v}"
          echo "version=${v}" >> "$GITHUB_OUTPUT"
      - name: Assert sibling-package co-tagging
        run: bash scripts/release/assert-co-tagging.sh "${{ steps.ver.outputs.version }}"

  # AC-054 partial: only this job marks the release complete by creating the
  # GitHub Release. If any smoke or co-tagging job is red, this job does not
  # run, so the release is never marked done. Skipped on dry-run.
  github-release:
    runs-on: ubuntu-latest
    if: ${{ inputs.dry_run != true }}
    needs:
      - post-publish-smoke
      - co-tagging-assert
    steps:
      - uses: actions/download-artifact@3e5f45b2cfb9172054b4087a40e8e0b5a5461e7c # v8.0.1
        with:
          pattern: python-dist-*
          merge-multiple: true
          path: dist
      - uses: softprops/action-gh-release@153bb8e04406b158c6c84fc1615b65b24149a1fe # v2.6.1
        with:
          files: dist/*

