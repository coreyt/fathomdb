    15	
    16	# Migration authoring policy
    17	run_capped lint-migrations "$SCRIPT_DIR/agent-lint-migrations.sh"
    18	
    19	# Python: ruff if available
    20	ruff_bin=""
    21	if [ -x .venv/bin/ruff ]; then
    22	  ruff_bin=".venv/bin/ruff"
    23	elif command -v ruff >/dev/null 2>&1; then
    24	  ruff_bin="$(command -v ruff)"
    25	fi
    26	
    27	if [ -n "$ruff_bin" ]; then
    28	  run_capped lint-python "$ruff_bin" check src/python
    29	else
    30	  skip_notice lint-python "ruff not installed"
    31	fi
    32	
    33	# TypeScript: ESLint not configured yet
    34	skip_notice lint-ts "ESLint not configured"
    35	
    36	# Workflows: actionlint is the canonical validator per feedback_workflow_validation
    37	# (yaml.safe_load passes schema-invalid syntax GitHub silently rejects).
    38	if command -v actionlint >/dev/null 2>&1; then
    39	  run_capped lint-actions actionlint .github/workflows/*.yml
    40	else
    41	  skip_notice lint-actions "actionlint not installed (run scripts/bootstrap.sh)"
    42	fi
    43	
    44	# Markdown: structural + format + link integrity
    45	"$SCRIPT_DIR/agent-lint-md.sh"
--- scripts/bootstrap.sh
     1	#!/usr/bin/env bash
     2	set -euo pipefail
     3	
     4	cd "$(git rev-parse --show-toplevel)"
     5	
     6	echo "FathomDB scaffold bootstrap"
     7	echo "Public docs live in docs/ and build with MkDocs."
     8	echo "Internal engineering docs live in dev/."
     9	echo "Rust workspace members live under src/rust/crates/."
    10	echo "Run scripts/agent-verify.sh during the agent loop, scripts/check.sh as the broader CI gate."
    11	
    12	# Repo-tracked git hooks (pre-commit fmt/lint, pre-push agent-verify).
    13	scripts/install-hooks.sh
    14	
    15	# Python dev tooling — pytest, hypothesis, ruff, pyright.
    16	if [ -f src/python/pyproject.toml ]; then
    17	  echo "Installing Python dev tooling into .venv (pytest + hypothesis + ruff + pyright)..."
    18	  python3 -m venv .venv
    19	  .venv/bin/python -m pip install --quiet --upgrade pip
    20	  .venv/bin/python -m pip install --quiet -e 'src/python[dev]'
    21	  .venv/bin/python -c 'import pytest, hypothesis'
    22	  .venv/bin/pyright -p src/python >/dev/null
    23	fi
    24	
    25	# TypeScript dev tooling.
    26	if [ -f src/ts/package.json ] && [ ! -d src/ts/node_modules ]; then
    27	  echo "Installing TypeScript dev tooling..."
    28	  (cd src/ts && npm install --silent)
    29	fi
    30	
    31	# Repo-wide markdown tooling (markdownlint-cli2 + prettier).
    32	if [ -f package.json ] && [ ! -d node_modules ]; then
    33	  echo "Installing markdown dev tooling (markdownlint-cli2 + prettier)..."
    34	  npm install --silent
    35	fi
    36	
    37	# Lychee link checker (Rust binary).
    38	if ! command -v lychee >/dev/null 2>&1; then
    39	  echo "Installing lychee link checker..."
    40	  cargo install --locked --quiet lychee
    41	fi
    42	
    43	# actionlint — workflow validator. Pinned: yaml.safe_load passes
    44	# schema-invalid syntax that GitHub silently rejects, so we need a real
    45	# linter for .github/workflows/*.yml. Version pin matches a recent stable
    46	# release; bump deliberately, not drifted.
    47	if ! command -v actionlint >/dev/null 2>&1; then
    48	  if command -v go >/dev/null 2>&1; then
    49	    echo "Installing actionlint v1.7.7 via go install..."
    50	    GO111MODULE=on go install github.com/rhysd/actionlint/cmd/actionlint@v1.7.7
    51	  else
    52	    echo "actionlint not installed and go toolchain unavailable; install actionlint manually" >&2
    53	    echo "  see https://github.com/rhysd/actionlint/releases (pin v1.7.7)" >&2
    54	  fi
    55	fi

