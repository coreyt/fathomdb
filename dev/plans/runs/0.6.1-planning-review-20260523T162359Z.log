     1	#!/usr/bin/env bash
     2	# AC-037 netns-deny-egress fixture. Runs the security_cycle binary
     3	# inside an unprivileged user + network namespace with loopback as
     4	# the only interface, traces `connect()` syscalls, and asserts every
     5	# observed connect targets AF_UNIX or 127.0.0.1 / ::1.
     6	#
     7	# Exits:
     8	#   0 — clean trace (no off-loopback connect attempts).
     9	#   1 — at least one off-loopback connect observed.
    10	#   2 — toolchain blocker (strace missing, unprivileged userns
    11	#       disabled, binary missing).
    12	set -euo pipefail
    13	
    14	SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    15	REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
    16	
    17	if ! command -v strace >/dev/null 2>&1; then
    18	    echo "AC-037 BLOCKER: strace not installed. Add to scripts/bootstrap.sh" >&2
    19	    exit 2
    20	fi
    21	if ! command -v unshare >/dev/null 2>&1; then
    22	    echo "AC-037 BLOCKER: unshare(1) not available" >&2
    23	    exit 2
    24	fi
    25	if [ -r /proc/sys/kernel/unprivileged_userns_clone ]; then
    26	    if [ "$(cat /proc/sys/kernel/unprivileged_userns_clone)" != "1" ]; then
    27	        echo "AC-037 BLOCKER: unprivileged user namespaces disabled by kernel" >&2
    28	        echo "  sysctl kernel.unprivileged_userns_clone=1 required" >&2
    29	        exit 2
    30	    fi
    31	fi
    32	
    33	BIN="$REPO_ROOT/target/debug/examples/security_cycle"
    34	if [ ! -x "$BIN" ]; then
    35	    (cd "$REPO_ROOT" && cargo build -p fathomdb-engine --example security_cycle --quiet)
    36	fi
    37	if [ ! -x "$BIN" ]; then
    38	    echo "AC-037 BLOCKER: security_cycle binary missing: $BIN" >&2
    39	    exit 2
    40	fi
    41	
    42	TMPDIR="$(mktemp -d -t fdb-ac037-XXXXXX)"
    43	trap 'rm -rf "$TMPDIR"' EXIT
    44	TRACE="$TMPDIR/strace.log"
    45	DB="$TMPDIR/cycle.sqlite"
    46	
    47	# Probe unprivileged userns+netns up-front. If unshare fails the
    48	# kernel-level capability is missing — surface as a toolchain blocker
    49	# rather than letting the wrapper raise a confusing strace error.
    50	if ! unshare -rUn true >/dev/null 2>&1; then
    51	    echo "AC-037 BLOCKER: unshare -rUn failed; rootless userns+netns unavailable" >&2
    52	    exit 2
    53	fi
    54	
    55	# unshare -rUn: rootless user namespace + fresh network namespace.
    56	# Inside the netns we bring loopback up so the engine's intra-process
    57	# UNIX/loopback bookkeeping (none expected) can still proceed.
    58	# strace -f follows the engine's reader-pool threads.
    59	if ! unshare -rUn -- bash -c '
    60	    set -euo pipefail
    61	    ip link set lo up || true
    62	    exec strace -f -e trace=connect -o "$1" "$2" "$3" >/dev/null
    63	' bash "$TRACE" "$BIN" "$DB"; then
    64	    echo "AC-037: security_cycle exited non-zero in netns under strace" >&2
    65	    cat "$TRACE" >&2 || true
    66	    exit 1
    67	fi
    68	
    69	# Any connect() outside loopback is a violation. AF_UNIX paths show
    70	# as connect(fd, {sa_family=AF_UNIX, sun_path="..."}). AF_INET shows
    71	# as sin_addr=inet_addr("...") or sin_addr=htonl(0x7f000001).
    72	# Allowlisted patterns: AF_UNIX, 127.x.x.x, ::1, AF_NETLINK (kernel
    73	# RTNL chatter for ip link), AF_UNSPEC.
    74	VIOLATIONS="$(grep -E 'connect\(' "$TRACE" | \
    75	    grep -vE 'AF_UNIX|AF_UNSPEC|AF_NETLINK|127\.|sin_addr=htonl\(0x7f000001\)|inet_pton\(AF_INET6,\s*"::1"|inet6_addr.*::1' || true)"
    76	
    77	if [ -n "$VIOLATIONS" ]; then
    78	    echo "AC-037 VIOLATION: off-loopback connect() observed:" >&2
    79	    echo "$VIOLATIONS" >&2
    80	    exit 1
    81	fi
    82	
    83	echo "AC-037 OK: all connect() syscalls were loopback / AF_UNIX / AF_NETLINK."
