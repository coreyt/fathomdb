   352	fn build_report(dir: &Path) -> Result<Report, String> {
   353	    if !dir.is_dir() {
   354	        return Err(format!("perf-history directory not found: {}", dir.display()));
   355	    }
   356	
   357	    // Group by (ac_id, n). BTreeMap gives deterministic, sorted output.
   358	    let mut groups: BTreeMap<(String, u64), Vec<Record>> = BTreeMap::new();
   359	
   360	    let entries =
   361	        std::fs::read_dir(dir).map_err(|e| format!("cannot read dir {}: {e}", dir.display()))?;
   362	    for entry in entries {
   363	        let entry = entry.map_err(|e| format!("dir entry error: {e}"))?;
   364	        let path = entry.path();
   365	        if path.extension().and_then(|s| s.to_str()) != Some("json") {
   366	            continue;
   367	        }
   368	        let rec = load_record(&path)?;
   369	        groups.entry((rec.ac_id.clone(), rec.n)).or_default().push(rec);
   370	    }
   371	
   372	    if groups.is_empty() {
   373	        return Err(format!("no *.json perf records found in {}", dir.display()));
   374	    }
   375	
   376	    let mut report = Report { flagged: false, groups: Vec::new() };
   377	    for ((ac_id, n), mut runs) in groups {
   378	        // Sort oldest -> newest by parsed UTC epoch (not the raw string, which
   379	        // would mis-order offset/Z-mixed timestamps). Tie-break on commit_sha
   380	        // for a deterministic "latest" when two runs share an instant.
   381	        runs.sort_by(|a, b| {
   382	            a.ts_epoch.cmp(&b.ts_epoch).then_with(|| a.commit_sha.cmp(&b.commit_sha))
   383	        });
   384	        let v = evaluate_group(&ac_id, n, &runs);
   385	        report.flagged |= v.flagged;
   386	        report.groups.push(v);
   387	    }
   388	    Ok(report)
   389	}
   390	
   391	fn print_human(report: &Report) {
   392	    println!("perf-regression-check — {} group(s)\n", report.groups.len());
