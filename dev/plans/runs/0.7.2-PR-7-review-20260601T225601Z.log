   123	/// Parse a strict RFC3339 timestamp to UTC epoch seconds for ordering.
   124	///
   125	/// Accepts `YYYY-MM-DDTHH:MM:SS(.fraction)?(Z|±HH:MM)`. Any deviation returns
   126	/// `Err`, so a malformed timestamp fails loudly (exit 2) instead of corrupting
   127	/// "latest by timestamp" via a lexical string sort. Dependency-free (the
   128	/// workspace pulls in no date crate); uses Howard Hinnant's days-from-civil
   129	/// algorithm for the proleptic-Gregorian day count.
   130	fn parse_rfc3339_epoch(s: &str) -> Result<i64, String> {
   131	    let (date, rest) = s.split_once('T').ok_or_else(|| format!("missing 'T': {s}"))?;
   132	    let d: Vec<&str> = date.split('-').collect();
   133	    if d.len() != 3 {
   134	        return Err(format!("bad date: {s}"));
   135	    }
   136	    let year: i64 = d[0].parse().map_err(|_| format!("bad year: {s}"))?;
   137	    let month: i64 = d[1].parse().map_err(|_| format!("bad month: {s}"))?;
   138	    let day: i64 = d[2].parse().map_err(|_| format!("bad day: {s}"))?;
   139	    if !(1..=12).contains(&month) {
   140	        return Err(format!("month out of range: {s}"));
   141	    }
   142	    // Month-specific day count with proleptic-Gregorian leap-year handling, so
   143	    // impossible dates (2026-02-31, 2026-02-29 in a non-leap year) are rejected
   144	    // rather than silently normalized by days_from_civil.
   145	    let leap = (year % 4 == 0 && year % 100 != 0) || (year % 400 == 0);
   146	    let days_in_month = match month {
   147	        1 | 3 | 5 | 7 | 8 | 10 | 12 => 31,
   148	        4 | 6 | 9 | 11 => 30,
   149	        2 if leap => 29,
   150	        2 => 28,
   151	        _ => 0,
   152	    };
   153	    if !(1..=days_in_month).contains(&day) {
   154	        return Err(format!("day out of range for month: {s}"));
   155	    }
   156	
   157	    // Split the time-of-day from the zone designator (Z or ±HH:MM).
   158	    let (time_part, offset_secs) = if let Some(t) = rest.strip_suffix('Z') {
   159	        (t, 0i64)
   160	    } else {
   161	        let sign_idx =
   162	            rest.rfind(['+', '-']).ok_or_else(|| format!("missing zone designator: {s}"))?;
   163	        let (t, off) = rest.split_at(sign_idx);
   164	        let sign = if off.starts_with('-') { -1 } else { 1 };
   165	        let (oh, om) = off[1..].split_once(':').ok_or_else(|| format!("bad zone offset: {s}"))?;
   166	        let oh: i64 = oh.parse().map_err(|_| format!("bad offset hour: {s}"))?;
   167	        let om: i64 = om.parse().map_err(|_| format!("bad offset minute: {s}"))?;
