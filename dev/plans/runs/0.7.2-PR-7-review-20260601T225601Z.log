   195	        return Err(format!("time out of range: {s}"));
   196	    }
   197	
   198	    // days_from_civil (Howard Hinnant): days since 1970-01-01, proleptic Gregorian.
   199	    let y = if month <= 2 { year - 1 } else { year };
