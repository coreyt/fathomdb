   395	            "REGRESSION"
   396	        } else if g.status == "insufficient-history" {
   397	            "insufficient"
   398	        } else {
   399	            "ok"
   400	        };
   401	        println!(
   402	            "[{marker}] {} @ n={} — {} run(s), latest {} ({})",
   403	            g.ac_id, g.n, g.runs, g.latest_commit, g.latest_timestamp
   404	        );
   405	        for reason in &g.reasons {
   406	            println!("    - {reason}");
   407	        }
   408	    }
   409	    println!();
   410	    if report.flagged {
   411	        println!("RESULT: regression(s) flagged.");
   412	    } else {
   413	        println!("RESULT: no regressions.");
   414	    }
   415	}
