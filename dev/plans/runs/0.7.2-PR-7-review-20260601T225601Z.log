   238	/// Median of a slice (sorted copy; mean of the two middle elements for an even
   239	/// count). Returns `None` for an empty slice.
   240	fn median(values: &[f64]) -> Option<f64> {
   241	    if values.is_empty() {
   242	        return None;
   243	    }
   244	    let mut v = values.to_vec();
   245	    v.sort_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal));
   246	    let mid = v.len() / 2;
   247	    if v.len() % 2 == 1 {
   248	        Some(v[mid])
   249	    } else {
   250	        Some((v[mid - 1] + v[mid]) / 2.0)
   251	    }
   252	}
