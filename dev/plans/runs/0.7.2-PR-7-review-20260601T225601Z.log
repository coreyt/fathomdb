   307	        let prior_vals: Vec<f64> = window.iter().filter_map(get).collect();
   308	        if let (Some(latest_v), Some(med)) = (get(latest), median(&prior_vals)) {
   309	            if med > 0.0 {
   310	                let frac = (latest_v - med) / med;
   311	                if frac > LATENCY_DEGRADATION_FRACTION {
   312	                    verdict.flagged = true;
   313	                    verdict.reasons.push(format!(
   314	                        "{label} {latest_v:.2} ms is {:.1}% over rolling median {med:.2} ms (threshold {:.0}%) at commit {}",
   315	                        frac * 100.0,
   316	                        LATENCY_DEGRADATION_FRACTION * 100.0,
   317	                        latest.commit_sha,
   318	                    ));
   319	                }
   320	            }
   321	        }
   322	    }
   323	
   324	    // Recall: flag if degraded > RECALL_DEGRADATION_ABSOLUTE (absolute drop).
   325	    let prior_recall: Vec<f64> = window.iter().filter_map(|r| r.recall).collect();
   326	    if let (Some(latest_r), Some(med)) = (latest.recall, median(&prior_recall)) {
   327	        let drop = med - latest_r;
   328	        if drop > RECALL_DEGRADATION_ABSOLUTE {
   329	            verdict.flagged = true;
   330	            verdict.reasons.push(format!(
   331	                "recall {latest_r:.4} is {drop:.4} below rolling median {med:.4} (threshold {RECALL_DEGRADATION_ABSOLUTE}) at commit {}",
   332	                latest.commit_sha,
   333	            ));
   334	        }
   335	    }
   336	
   337	    if verdict.flagged {
   338	        verdict.status = "regression".to_string();
   339	    }
