{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MokmRGCM4ks2HjY8Ni4bY1","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t# scripts/tests/test_set_version.sh — coverage for set-version.sh\n3\t# two-axis enforcement per dev/design/release.md § Version axes.\n4\tset -euo pipefail\n5\t\n6\tSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n7\tREPO_ROOT=\"$(cd \"$SCRIPT_DIR/../..\" && pwd)\"\n8\tSV=\"$REPO_ROOT/scripts/set-version.sh\"\n9\t\n10\tCARGO=\"$REPO_ROOT/Cargo.toml\"\n11\tPYPROJ=\"$REPO_ROOT/src/python/pyproject.toml\"\n12\tNPMPKG=\"$REPO_ROOT/src/ts/package.json\"\n13\tEMBAPI=\"$REPO_ROOT/src/rust/crates/fathomdb-embedder-api/Cargo.toml\"\n14\t\n15\tFAILED=0\n16\tTMPDIR_ROOT=\"$(mktemp -d)\"\n17\ttrap 'restore; rm -rf \"$TMPDIR_ROOT\"' EXIT\n18\t\n19\t# Snapshot the four manifests so the test never leaves the tree dirty.\n20\tSNAP=\"$TMPDIR_ROOT/snap\"\n21\tmkdir -p \"$SNAP\"\n22\tcp \"$CARGO\" \"$SNAP/Cargo.toml\"\n23\tcp \"$PYPROJ\" \"$SNAP/pyproject.toml\"\n24\tcp \"$NPMPKG\" \"$SNAP/package.json\"\n25\tcp \"$EMBAPI\" \"$SNAP/embedder-api.toml\"\n26\t\n27\trestore() {\n28\t  cp \"$SNAP/Cargo.toml\" \"$CARGO\" 2>/dev/null || true\n29\t  cp \"$SNAP/pyproject.toml\" \"$PYPROJ\" 2>/dev/null || true\n30\t  cp \"$SNAP/package.json\" \"$NPMPKG\" 2>/dev/null || true\n31\t  cp \"$SNAP/embedder-api.toml\" \"$EMBAPI\" 2>/dev/null || true\n32\t}\n33\t\n34\tpass() { printf 'PASS  %s\\n' \"$1\"; }\n35\tfail() { printf 'FAIL  %s\\n' \"$1\" >&2; FAILED=$((FAILED + 1)); }\n36\t\n37\t# Extract Axis W workspace version from Cargo.toml [workspace.package].\n38\tws_version() {\n39\t  awk '\n40\t    /^\\[workspace\\.package\\]/ { in_block = 1; next }\n41\t    /^\\[/                     { in_block = 0 }\n42\t    in_block && /^version[[:space:]]*=/ {\n43\t      n = split($0, parts, \"\\\"\")\n44\t      if (n >= 3) { print parts[2] }\n45\t      exit\n46\t    }\n47\t  ' \"$CARGO\"\n48\t}\n49\t\n50\t# Extract Axis E embedder-api version from its [package] block.\n51\temb_version() {\n52\t  awk '\n53\t    /^\\[package\\]/ { in_block = 1; next }\n54\t    /^\\[/          { in_block = 0 }\n55\t    in_block && /^version[[:space:]]*=/ {\n56\t      n = split($0, parts, \"\\\"\")\n57\t      if (n >= 3) { print parts[2] }\n58\t      exit\n59\t    }\n60\t  ' \"$EMBAPI\"\n61\t}\n62\t\n63\tpy_version() {\n64\t  awk '\n65\t    /^\\[project\\]/ { in_block = 1; next }\n66\t    /^\\[/          { in_block = 0 }\n67\t    in_block && /^version[[:space:]]*=/ {\n68\t      n = split($0, parts, \"\\\"\")\n69\t      if (n >= 3) { print parts[2] }\n70\t      exit\n71\t    }\n72\t  ' \"$PYPROJ\"\n73\t}\n74\t\n75\tnpm_version() {\n76\t  sed -n 's/.*\"version\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p' \"$NPMPKG\" | head -1\n77\t}\n78\t\n79\t# 1. --check-files clean tree → 0.\n80\trestore\n81\tif \"$SV\" --check-files >/dev/null 2>&1; then\n82\t  pass \"check-files clean tree exits 0\"\n83\telse\n84\t  fail \"check-files clean tree should exit 0\"\n85\tfi\n86\t\n87\t# 2. --workspace 9.9.9 updates all Axis W manifests; Axis E untouched.\n88\trestore\n89\tORIG_EMB=\"$(emb_version)\"\n90\t\"$SV\" --workspace 9.9.9 >/dev/null\n91\tif [ \"$(ws_version)\" = \"9.9.9\" ] && [ \"$(py_version)\" = \"9.9.9\" ] && [ \"$(npm_version)\" = \"9.9.9\" ]; then\n92\t  pass \"workspace 9.9.9 updates Cargo+pyproject+package.json\"\n93\telse\n94\t  fail \"workspace 9.9.9 did not propagate: ws=$(ws_version) py=$(py_version) npm=$(npm_version)\"\n95\tfi\n96\tif [ \"$(emb_version)\" = \"$ORIG_EMB\" ]; then\n97\t  pass \"workspace 9.9.9 leaves Axis E ($ORIG_EMB) untouched\"\n98\telse\n99\t  fail \"workspace 9.9.9 mutated Axis E: $ORIG_EMB → $(emb_version)\"\n100\tfi\n101\tif \"$SV\" --check-files >/dev/null 2>&1; then\n102\t  pass \"check-files clean after --workspace 9.9.9\"\n103\telse\n104\t  fail \"check-files should be clean after --workspace 9.9.9\"\n105\tfi\n106\t\n107\t# 3. --embedder-api 8.8.8 updates only Axis E; Axis W untouched