{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016vSNBZh3d1wKQCdaJLzVEv","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t# scripts/set-version.sh — two-axis version single source of truth.\n3\t#\n4\t# Axis W (workspace lockstep): Cargo.toml [workspace.package].version,\n5\t# src/python/pyproject.toml [project].version, src/ts/package.json\n6\t# top-level \"version\". Inherited by every workspace crate via\n7\t# `version.workspace = true`.\n8\t#\n9\t# Axis E (embedder-api independent semver):\n10\t# src/rust/crates/fathomdb-embedder-api/Cargo.toml [package].version.\n11\t#\n12\t# Owner: dev/design/release.md § Version axes.\n13\tset -euo pipefail\n14\t\n15\tusage() {\n16\t  cat <<'USAGE' >&2\n17\tUsage: scripts/set-version.sh <mode> [args]\n18\t\n19\tModes:\n20\t  --workspace <new-w-version>     Set Axis W (Cargo workspace + python + ts).\n21\t  --embedder-api <new-e-version>  Set Axis E (fathomdb-embedder-api only).\n22\t  --check-files                   Verify both axes are internally consistent.\n23\t\n24\tExamples:\n25\t  scripts/set-version.sh --workspace 0.6.1\n26\t  scripts/set-version.sh --embedder-api 0.7.0\n27\t  scripts/set-version.sh --check-files\n28\tUSAGE\n29\t}\n30\t\n31\tdie_usage() {\n32\t  if [ -n \"${1:-}\" ]; then\n33\t    printf 'error: %s\\n' \"$1\" >&2\n34\t  fi\n35\t  usage\n36\t  exit 2\n37\t}\n38\t\n39\tREPO_ROOT=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\"\n40\tCARGO=\"$REPO_ROOT/Cargo.toml\"\n41\tPYPROJ=\"$REPO_ROOT/src/python/pyproject.toml\"\n42\tNPMPKG=\"$REPO_ROOT/src/ts/package.json\"\n43\tEMB_API_DIR=\"$REPO_ROOT/src/rust/crates/fathomdb-embedder-api\"\n44\tEMB_API=\"$EMB_API_DIR/Cargo.toml\"\n45\tCRATES_DIR=\"$REPO_ROOT/src/rust/crates\"\n46\t\n47\t# Atomic write: edits \"$1\" with awk program \"$2\" via a tmpfile mv.\n48\tawk_inplace() {\n49\t  local target=\"$1\"\n50\t  local prog=\"$2\"\n51\t  local tmp\n52\t  tmp=\"$(mktemp \"${target}.XXXXXX\")\"\n53\t  awk \"$prog\" \"$target\" >\"$tmp\"\n54\t  mv \"$tmp\" \"$target\"\n55\t}\n56\t\n57\t# Set [workspace.package].version in Cargo.toml.\n58\tset_workspace_version() {\n59\t  local new=\"$1\"\n60\t  awk_inplace \"$CARGO\" '\n61\t    BEGIN { in_block = 0 }\n62\t    /^\\[workspace\\.package\\]/ { in_block = 1; print; next }\n63\t    /^\\[/ { in_block = 0; print; next }\n64\t    {\n65\t      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n66\t        print \"version = \\\"'\"$new\"'\\\"\"\n67\t      } else {\n68\t        print\n69\t      }\n70\t    }\n71\t  '\n72\t}\n73\t\n74\t# Set [project].version in pyproject.toml.\n75\tset_pyproject_version() {\n76\t  local new=\"$1\"\n77\t  awk_inplace \"$PYPROJ\" '\n78\t    BEGIN { in_block = 0 }\n79\t    /^\\[project\\]/ { in_block = 1; print; next }\n80\t    /^\\[/ { in_block = 0; print; next }\n81\t    {\n82\t      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n83\t        print \"version = \\\"'\"$new\"'\\\"\"\n84\t      } else {\n85\t        print\n86\t      }\n87\t    }\n88\t  '\n89\t}\n90\t\n91\t# Set the top-level \"version\" field in package.json.\n92\t# Constraint: only rewrite the first occurrence so a nested \"version\" inside\n93\t# devDependencies cannot be touched.\n94\tset_npm_version() {\n95\t  local new=\"$1\"\n96\t  local tmp\n97\t  tmp=\"$(mktemp \"${NPMPKG}.XXXXXX\")\"\n98\t  awk -v new=\"$new\" '\n99\t    BEGIN { done = 0 }\n100\t    {\n101\t      if (!done && match($0, /\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/)) {\n102\t        sub(/\"version\"[[:space:]]*:[[:space:]]*\"[^\"]*\"/, \"\\\"version\\\": \\\"\" new \"\\\"\")\n103\t        done = 1\n104\t      }\n105\t      print\n106\t    }\n107\t  ' \"$NPMPKG\" >\"$tmp\"\n108\t  mv \"$tmp\" \"$NPMPKG\"\n109\t}\n110\t\n111\t# Set [package].version in fathomdb-embedder-api/Cargo.toml. Preserves any\n112\t# leading comment lines inside the [package] block (so the Axis-E why-comment\n113\t# survives re-runs).\n114\tset_embedder_api_version() {\n115\t  local new=\"$1\"\n116\t  awk_inplace \"$EMB_API\" '\n117\t    BEGIN { in_block = 0 }\n118\t    /^\\[package\\]/ { in_block = 1; print; next }\n119\t    /^\\[/ { in_block = 0; print; next }\n120\t    {\n121\t      if (in_block && $0 ~ /^version[[:space:]]*=/) {\n122\t        print \"version = \\\"'\"$new\"'\\\"\"\n123\t      } else {\n124\t        print\n125\t      }\n126\t    }\n127\t  '\n128\t}\n129\t\n130\t# --- readers ---------------------------------------------------------------\n131\t\n132\tread_workspace_version() {\n133\t  awk '\n134\t    /^\\[workspace\\.package\\]/ { in_block = 1; next }\n135\t    /^\\[/                     { in_block = 0 }\n136\t    in_block && /^version[[:space:]]*=/ {\n137\t      n = split($0, parts, \"\\\"\")\n138\t      if (n >= 3) { print parts[2] }\n139\t      exit\n140\t    }\n141\t  ' \"$CARGO\"\n142\t}\n143\t\n144\tread_pyproject_version() {\n145\t  awk '\n146\t    /^\\[project\\]/ { in_block = 1; next }\n147\t    /^\\[/          { in_block = 0 }\n148\t    in_block && /^version[[:space:]]*=/ {\n149\t      n = split($0, parts, \"\\\"\")\n150\t      if (n >= 3) { print parts[2] }\n151\t      exit\n152\t    }\n153\t  ' \"$PYPROJ\"\n154\t}\n155\t\n156\tread_npm_version() {\n157\t  sed -n 's/.*\"version\"[[:space:]]*:[[:space:]]*\"\\([^\"]*\\)\".*/\\1/p' \"$NPMPKG\" | head -1\n158\t}\n159\t\n160\t# Returns the literal text of the version line inside [package] of the\n161\t# embedder-api crate (e.g. `version = \"0.6.0\"` or `version.workspace = true`).\n162\tread_embedder_api_version_line() {\n163\t  awk '\n164\t    /^\\[package\\]/ { in_block = 1; next }\n165\t    /^\\[/          { in_block = 0 }\n166\t    in_block && /^version[[:space:]]*[=.]/ {\n167\t      print\n168\t      exit\n169\t    }\n170\t  ' \"$EMB_API\"\n171\t}\n172\t\n173\t# Parse out the value portion: returns \"0.6.0\" for `version = \"0.6.0\"`, or\n174\t# the literal \"workspace\" sentinel for `version.workspace = true`.\n175\tembedder_api_version_value() {\n176\t  local line\n177\t  line=\"$(read_embedder_api_version_line)\"\n178\t  case \"$line\" in\n179\t    version.workspace*) printf 'workspace' ;;\n180\t    version[[:space:]]*=*\\\"*) printf '%s' \"$line\" | sed -n 's/.*\"\\([^\"]*\\)\".*/\\1/p' ;;\n181\t    *) printf 'unknown' ;;\n182\t  esac\n183\t}\n184\t\n185\t# --- check-files -----------------------------------------------------------\n186\t\n187\tcheck_files() {\n188\t  local ws py npm emb\n189\t  ws=\"$(read_workspace_version)\"\n190\t  py=\"$(read_pyproject_version)\"\n191\t  npm=\"$(read_npm_version)\"\n192\t  emb=\"$(embedder_api_version_value)\"\n193\t\n194\t  local rc=0\n195\t\n196\t  if [ -z \"$ws\" ]; then\n197\t    printf 'error: %s: no [workspace.package] version found\\n' \"$CARGO\" >&2\n198\t    rc=1\n199\t  fi\n200\t\n201\t  if [ \"$py\" != \"$ws\" ]; then\n202\t    printf 'drift: %s: Axis W version \"%s\" != Cargo.toml workspace \"%s\"\\n' \"$PYPROJ\" \"$py\" \"$ws\" >&2\n203\t    rc=1\n204\t  fi\n205\t\n206\t  if [ \"$npm\" != \"$ws\" ]; then\n207\t    printf 'drift: %s: Axis W version \"%s\" != Cargo.toml workspace \"%s\"\\n' \"$NPMPKG\" \"$npm\" \"$ws\" >&2\n208\t    rc=1\n209\t  fi\n210\t\n211\t  case \"$emb\" in\n212\t    workspace)\n213\t      printf 'drift: %s: Axis E must declare explicit [package] version (found `version.workspace = true`)\\n' \"$EMB_API\" >&2\n214\t      rc=1\n215\t      ;;\n216\t    unknown|'')\n217\t      printf 'drift: %s: Axis E [package] version not parseable\\n' \"$EMB_API\" >&2\n218\t      rc=1\n219\t      ;;\n220\t  esac\n221\t\n222\t  # Every workspace crate except fathomdb-embedder-api must inherit Axis W\n223\t  # via `version.workspace = true`. Catch silent decoupling regressions.\n224\t  local crate manifest line\n225\t  for crate in \"$CRATES_DIR\"/*; do\n226\t    [ -d \"$crate\" ] || continue\n227\t    manifest=\"$crate/Cargo.toml\"\n228\t    [ -f \"$manifest\" ] || continue\n229\t    if [ \"$crate\" = \"$EMB_API_DIR\" ]; then\n230\t      continue\n231\t    fi\n232\t    line=\"$(awk '\n233\t      /^\\[package\\]/ { in_block = 1; next }\n234\t      /^\\[/          { in_block = 0 }\n235\t      in_block && /^version[[:space:]]*[=.]/ {\n236\t        print\n237\t        exit\n238\t      }\n239\t    ' \"$manifest\")\"\n240\t    case \"$line\" in\n241\t      version.workspace[[:space:]]*=[[:space:]]*true) ;;\n242\t      '')\n243\t        printf 'drift: %s: missing [package] version declaration\\n' \"$manifest\" >&2\n244\t        rc=1\n245\t        ;;\n246\t      *)\n247\t        printf 'drift: %s: Axis W crate must use `version.workspace = true`; found `%s`\\n' \"$manifest\" \"$line\" >&2\n248\t        rc=1\n249\t        ;;\n250\t    esac\n251\t  done\n252\t\n253\t  if [ $rc -eq 0 ]; then\n254\t    printf 'ok: Axis W = %s; Axis E = %s\\n' \"$ws\" \"$emb\"\n255\t  fi\n256\t  return $rc\n257\t}\n258\t\n259\t# --- dispatch --------------------------------------------------------------\n260\t\n261\tif [ $# -eq 0 ]; then\n262\t  die_usage \"no mode given\"\n263\tfi\n264\t\n265\tmode=\"$1\"\n266\tshift || true\n267\t\n268\tcase \"$mode\" in\n269\t  --workspace)\n270\t    if [ $# -ne 1 ] || [ -z \"${1:-}\" ]; then\n271\t      die_usage \"--workspace requires <new-w-version>\"\n272\t    fi\n273\t    new=\"$1\"\n274\t    set_workspace_version \"$new\"\n275\t    set_pyproject_version \"$new\"\n276\t    set_npm_version \"$new\"\n277\t    check_files\n278\t    ;;\n279\t  --embedder-api)\n280\t    if [ $# -ne 1 ] || [ -z \"${1:-}\" ]; then\n281\t      die_usage \"--embedder-api requires <new-e-version>\"\n282\t    fi\n283\t    new=\"$1\"\n284\t    set_embedder_api_version \"$new\"\n285\t    check_files\n286\t    ;;\n287\t  --check-files)\n288\t    if [ $# -ne 0 ]; then\n289\t      die_usage \"--check-files takes no arguments\"\n290\t    fi\n291\t    check_files\n292\t    ;;\n293\t  -h|--help)\n294\t    usage\n295\t    exit 0\n296\t    ;;\n297\t  *)\n298\t    die_usage \"unknown mode: $mode\"\n299\t    ;;\n300\tesac\n301\t"}]},"parent_tool_use_id":null,"session_id":"6b342a