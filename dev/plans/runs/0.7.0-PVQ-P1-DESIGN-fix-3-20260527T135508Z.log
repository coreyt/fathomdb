 \"created_at filled by strftime('%s','now') at INSERT time; removed Rust-side <now> rendering claim and lib.rs:1119 anchor.\",\n      \"citations\": [\"https://www.sqlite.org/lang_datefunc.html\"],\n      \"uniform_timestamp_note\": \"SQLite documents that built-in date/time functions return the same value across all rows in a single statement when no varying arguments are passed.\"\n    },\n    {\n      \"id\": \"fix-3.3\",\n      \"severity\": \"low\",\n      \"summary\": \"D8 stale 'INSERT INTO vector_default_v2 ... SELECT v.rowid' reference rewritten against the staged-copy migration shape.\",\n      \"citations\": [\n        \"src/rust/crates/fathomdb-engine/src/lib.rs:2174-2175\",\n        \"src/rust/crates/fathomdb-engine/src/lib.rs:2177\",\n        \"src/rust/crates/fathomdb-engine/src/lib.rs:2181\",\n        \"src/rust/crates/fathomdb-engine/src/lib.rs:2265\"\n      ]\n    }\n  ],\n  \"apply_one_verification\": {\n    \"execution_model\": \"multi-statement\",\n    \"evidence\": \"fathomdb-schema/src/lib.rs:276 invokes conn.execute_batch(migration.sql); :274 begins the transaction with BEGIN IMMEDIATE; :282 commits; :284 rolls back on error.\",\n    \"consequence\": \"Preflight assertion can live as a prefix statement in the same migration SQL string; no Rust-side preflight or single-statement CTE workaround required.\"\n  },\n  \"files_changed\": [\n    \"dev/design/0.7.0-vector-quant-pack1.md\"\n  ],\n  \"outputs\": [\n    \"dev/design/0.7.0-vector-quant-pack1.md (D4 + D8 edited; Fix-3 changelog appended; status -> draft fix-3)\",\n    \"dev/plans/runs/0.7.0-PVQ-P1-DESIGN-fix-3-output.json\"\n  ],\n  \"constraints_honored\": {\n    \"additive_commit_on_top_of_f7343c8\": true,\n    \"no_code_changes\": true,\n    \"rust_anchors_verified\": true,\n    \"ascii_only\": true\n  }\n}\n","structuredPatch":[],"originalFile":null,"userModified":false}}
