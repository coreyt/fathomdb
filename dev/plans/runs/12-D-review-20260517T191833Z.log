  3018	/// Pre-`pragma WAL` sidecar validation. SQLite silently discards a WAL
  3019	/// file whose header magic is wrong or whose advertised page size is
  3020	/// outside `[512, SQLITE_MAX_PAGE_SIZE]`, which would cause us to lose
  3021	/// committed frames at open time. AC-035a requires that we instead
  3022	/// refuse to open with `Corruption(WalReplayFailure)` rather than
  3023	/// silently rebuild from a truncated WAL.
  3024	fn probe_wal_sidecar(db_path: &Path) -> Result<(), EngineOpenError> {
  3025	    let mut wal_path = db_path.as_os_str().to_owned();
  3026	    wal_path.push("-wal");
  3027	    let wal_path = PathBuf::from(wal_path);
  3028	    let bytes = match std::fs::read(&wal_path) {
  3029	        Ok(bytes) => bytes,
  3030	        Err(err) if err.kind() == std::io::ErrorKind::NotFound => return Ok(()),
  3031	        Err(_) => return Ok(()),
  3032	    };
  3033	    // A short (< 32-byte) sidecar carries no committed frames; SQLite
  3034	    // treats it as empty and re-initializes WAL state, which is safe.
  3035	    if bytes.len() < 32 {
  3036	        return Ok(());
  3037	    }
  3038	    let magic = u32::from_be_bytes([bytes[0], bytes[1], bytes[2], bytes[3]]);
  3039	    let page_size = u32::from_be_bytes([bytes[8], bytes[9], bytes[10], bytes[11]]);
  3040	    // WAL_MAGIC mask per SQLite `walIndexRecover`: low bit distinguishes
  3041	    // big-endian vs little-endian checksum encoding; the rest of the
  3042	    // magic is fixed.
  3043	    const WAL_MAGIC_MASK: u32 = 0xFFFF_FFFE;
  3044	    const WAL_MAGIC: u32 = 0x377F_0682;
  3045	    const SQLITE_MAX_PAGE_SIZE: u32 = 65536;
  3046	    let magic_ok = (magic & WAL_MAGIC_MASK) == WAL_MAGIC;
  3047	    let page_size_ok =
  3048	        page_size.is_power_of_two() && (512..=SQLITE_MAX_PAGE_SIZE).contains(&page_size);
  3049	    if magic_ok && page_size_ok {
  3050	        return Ok(());
  3051	    }
  3052	    Err(EngineOpenError::Corruption(CorruptionDetail {
  3053	        kind: CorruptionKind::WalReplayFailure,
  3054	        stage: OpenStage::WalReplay,
  3055	        locator: CorruptionLocator::FileOffset { offset: if !magic_ok { 0 } else { 8 } },
  3056	        recovery_hint: RecoveryHint {
  3057	            code: "E_CORRUPT_WAL_REPLAY",
  3058	            doc_anchor: "design/recovery.md#wal-replay-failures",
  3059	        },
  3060	    }))
  3061	}
