{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FqJJ2zr8Ue2n8Uo8gt6Wgs","type":"tool_result","content":"3358\t) -> rusqlite::Result<()> {\n3359\t    let tx = connection.transaction()?;\n3360\t\n3361\t    for (write, plan) in batch.iter().zip(plans) {\n3362\t        match (write, plan) {\n3363\t            (PreparedWrite::Node { kind, body, source_id }, WritePlan::Node) => {\n3364\t                tx.execute(\n3365\t                    \"INSERT INTO canonical_nodes(write_cursor, kind, body, source_id)\n3366\t                     VALUES(?1, ?2, ?3, ?4)\",\n3367\t                    params![cursor, kind, body, source_id],\n3368\t                )?;\n3369\t                tx.execute(\n3370\t                    \"INSERT INTO search_index(body, kind, write_cursor) VALUES(?1, ?2, ?3)\",\n3371\t                    params![body, kind, cursor],\n3372\t                )?;\n3373\t                if kind_is_vector_indexed(&tx, kind).unwrap_or(false) {\n3374\t                    tx.execute(\n3375\t                        \"INSERT INTO _fathomdb_projection_state(kind, last_enqueued_cursor, updated_at)\n3376\t                         VALUES(?1, ?2, 0)\n3377\t                         ON CONFLICT(kind) DO UPDATE SET last_enqueued_cursor = excluded.last_enqueued_cursor\",\n3378\t                        params![kind, cursor],\n3379\t                    )?;\n3380\t                }\n3381\t            }\n3382\t            (PreparedWrite::Edge { kind, from, to, source_id }, WritePlan::Edge) => {\n3383\t                tx.execute(\n3384\t                    \"INSERT INTO canonical_edges(write_cursor, kind, from_id, to_id, source_id)\n3385\t                     VALUES(?1, ?2, ?3, ?4, ?5)\",\n3386\t                    params![cursor, kind, from, to, source_id],\n3387\t                )?;\n3388\t            }\n3389\t            (\n3390\t                PreparedWrite::AdminSchema { name, kind, schema_json, retention_json },\n3391\t                WritePlan::AdminSchema,\n3392\t            ) => {\n3393\t                tx.execute(\n3394\t                    \"INSERT INTO operational_collections(\n3395\t                        name, kind, schema_json, retention_json, format_version, created_at\n3396\t                     ) VALUES(?1, ?2, ?3, ?4, 1, 0)\n3397\t                     ON CONFLICT(name) DO UPDATE SET\n3398\t                        schema_json = excluded.schema_json,\n3399\t                        retention_json = excluded.retention_json\",\n3400\t                    params![name, kind, schema_json, retention_json],\n3401\t                )?;\n3402\t            }\n3403\t            (\n3404\t                PreparedWrite::OpStore { collection, record_key, schema_id, body },\n3405\t                WritePlan::AppendOnlyLog,\n3406\t            ) => {\n3407\t                tx.execute(\n3408\t                    \"INSERT INTO operational_mutations(\n3409\t                        collection_name, record_key, op_kind, payload_json, schema_id, write_cursor\n3410\t                     ) VALUES(?1, ?2, 'append', ?3, ?4, ?5)\",\n3411\t                    params![collection, record_key, body, schema_id, cursor],\n3412\t                )?;\n3413\t            }\n3414\t            (\n3415\t                PreparedWrite::OpStore { collection, record_key, schema_id, body },\n3416\t                WritePlan::LatestState,\n3417\t            ) => {\n3418\t                tx.execute(\n3419\t                    \"INSERT INTO operational_state(\n3420\t                        collection_name, record_key, payload_json, schema_id, write_cursor\n3421\t                     ) VALUES(?1, ?2, ?3, ?4, ?5)\n3422\t                     ON CONFLICT(collection_name, record_key) DO UPDATE SET\n3423\t                        payload_json = excluded.payload_json,\n3424\t                        schema_id = excluded.schema_id,\n3425\t                        write_cursor = excluded.write_cursor\",\n3426\t                    params![collection, record_key, body, schema_id, cursor],\n3427\t                )?;\n3428\t            }\n3429\t            _ => return Err(rusqlite::Error::InvalidQuery),\n3430\t        }\n3431\t    }\n3432\t\n3433\t    if !pending_projection {\n3434\t        record_projection_terminal(&tx, cursor, \"up_to_date\")?;\n3435\t    }\n3436\t    enforce_provenance_retention(&tx, provenance_row_cap)?;\n3437\t    advance_projection_cursor(&tx)?;\n3438\t\n3439\t    tx.commit()\n3440\t}\n3441\t\n3442\tfn load_next_cursor(connection: &Connection) -> u64 {\n3443\t    let nodes = max_cursor(connection, \"canonical_nodes\").unwrap_or(0);\n3444\t    let edges = max_cursor(connection, \"canonical_edges\").unwrap_or(0);\n3445\t    let mutations = max_cursor(connection, \"operational_mutations\").unwrap_or(0);\n3446\t    let state = max_cursor(connection, \"operational_state\").unwrap_or(0);\n3447\t    nodes.max(edges).max(mutations).max(state)\n3448\t}\n3449\t\n3450\tfn max_cursor(connection: &Connection, table: &str) -> rusqlite::Result<u64> {\n3451\t    let sql = format!(\"SELECT COALESCE(MAX(write_cursor), 0) FROM {table}\");\n3452\t    connection.query_row(&sql, [], |row| row.get::<_, u64>(0))\n3453\t}\n3454\t\n3455\t/// Map a rusqlite error to its stable SQLite extended-code name.\n3456\t///\n3457\t/// Returns `None` for non-`SqliteFailure` variants (e.g. JSON conversion\n3458\t/// failures, type mismatches at the rusqlite layer) — those are not\n3459\t/// SQLite-internal events and should not be surfaced under\n3460\t/// `EventSource::SqliteInternal`. The names returned here are the\n3461\t/// canonical `SQLITE_*` symbol names from `sqlite3.h` and are stable\n3462\t/// dispatch keys for AC-021 / AC-006 binding adapters.\n3463\t///\n3464\t/// Only the subset of codes the engine can reach in 0.6.0 is enumerated\n3465\t/// — bare-extended-code matching covers the rest with a stable\n3466\t/// `\"SQLITE_UNKNOWN\"` fallback so subscribers always see a typed code.\n3467\t///\n3468\t/// Diagnostic completeness for unmapped codes: when this helper returns\n3469\t/// `\"SQLITE_UNKNOWN\"`, the numeric extended code is not lost — it\n3470\t/// remains on the underlying `rusqlite::Error::SqliteFailure` carried\n3471\t/// in the engine error chain that subscribers can inspect via\n3472\t/// `EngineError`'s `source()`. Expanding the enumerated subset (or\n3473\t/// surfacing the numeric code as a typed payload field) is a 0.7+\n3474\t/// improvement.\n3475\tfn sqlite_extended_code_name(err: &rusqlite::Error) -> Option<&'static str> {\n3476\t    let sqlite_error = err.sqlite_error()?;\n3477\t    let extended = sqlite_error.extended_code;\n3478\t    Some(match extended {\n3479\t        rusqlite::ffi::SQLITE_SCHEMA => \"SQLITE_SCHEMA\",\n3480\t        rusqlite::ffi::SQLITE_BUSY => \"SQLITE_BUSY\",\n3481\t        rusqlite::ffi::SQLITE_LOCKED => \"SQLITE_LOCKED\",\n3482\t        rusqlite::ffi::SQLITE_CORRUPT => \"SQLITE_CORRUPT\",\n3483\t        rusqlite::ffi::SQLITE_NOTADB => \"SQLITE_NOTADB\",\n3484\t        rusqlite::ffi::SQLITE_IOERR => \"SQLITE_IOERR\",\n3485\t        rusqlite::ffi::SQLITE_FULL => \"SQLITE_FULL\",\n3486\t        rusqlite::ffi::SQLITE_READONLY => \"SQLITE_READONLY\",\n3487\t        rusqlite::ffi::SQLITE_CONSTRAINT => \"SQLITE_CONSTRAINT\",\n3488\t        rusqlite::ffi::SQLITE_MISUSE => \"SQLITE_MISUSE\",\n3489\t        rusqlite::ffi::SQLITE_INTERRUPT => \"SQLITE_INTERRUPT\",\n3490\t        rusqlite::ffi::SQLITE_NOMEM => \"SQLITE_NOMEM\",\n3491\t        rusqlite::ffi::SQLITE_PERM => \"SQLITE_PERM\",\n3492\t        rusqlite::ffi::SQLITE_ABORT => \"SQLITE_ABORT\",\n3493\t        rusqlite::ffi::SQLITE_PROTOCOL => \"SQLITE_PROTOCOL\",\n3494\t        rusqlite::ffi::SQLITE_RANGE => \"SQLITE_RANGE\",\n3495\t        rusqlite::ffi::SQLITE_TOOBIG => \"SQLITE_TOOBIG\",\n3496\t        rusqlite::ffi::SQLITE_MISMATCH => \"SQLITE_MISMATCH\",\n3497\t        rusqlite::ffi::SQLITE_AUTH => \"SQLITE_AUTH\",\n3498\t        rusqlite::ffi::SQLITE_NOTFOUND => \"SQLITE_NOTFOUND\",\n3499\t        rusqlite::ffi::SQLITE_CANTOPEN => \"SQLITE_CANTOPEN\",\n3500\t        _ => \"SQLITE_UNKNOWN\",\n3501\t    })\n3502\t}\n3503\t\n3504\tfn sqlite_extended_code_name_from_int(extended: i32) -> &'static str {\n3505\t    match extended {\n3506\t        rusqlite::ffi::SQLITE_SCHEMA => \"SQLITE_SCHEMA\",\n3507\t        rusqlite::ffi::SQLITE_BUSY => \"SQLITE_BUSY\",\n3508\t        rusqlite::ffi::SQLITE_LOCKED => \"SQLITE_LOCKED\",\n3509\t        rusqlite::ffi::SQLITE_CORRUPT => \"SQLITE_CORRUPT\",\n3510\t        rusqlite::ffi::SQLITE_NOTADB => \"SQLITE_NOTADB\",\n3511\t        rusqlite::ffi::SQLITE_IOERR => \"SQLITE_IOERR\",\n3512\t        rusqlite::ffi::SQLITE_FULL => \"SQLITE_FULL\",\n3513\t        rusqlite::ffi::SQLITE_READONLY => \"SQLITE_READONLY\",\n3514\t        rusqlite::ffi::SQLITE_CONSTRAINT => \"SQLITE_CONSTRAINT\",\n3515\t        rusqlite::ffi::SQLITE_MISUSE => \"SQLITE_MISUSE\",\n3516\t        rusqlite::ffi::SQLITE_INTERRUPT => \"SQLITE_INTERRUPT\",\n3517\t        rusqlite::ffi::SQLITE_NOMEM => \"SQLITE_NOMEM\",\n3518\t        rusqlite::ffi::SQLITE_PERM => \"SQLITE_PERM\",\n3519\t        rusqlite::ffi::SQLITE_ABORT => \"SQLITE_ABORT\",\n3520\t        rusqlite::ffi::SQLITE_PROTOCOL => \"SQLITE_PROTOCOL\",\n3521\t        rusqlite::ffi::SQLITE_RANGE => \"SQLITE_RANGE\",\n3522\t        rusqlite::ffi::SQLITE_TOOBIG => \"SQLITE_TOOBIG\",\n3523\t        rusqlite::ffi::SQLITE_MISMATCH => \"SQLITE_MISMATCH\",\n3524\t        rusqlite::ffi::SQLITE_AUTH => \"SQLITE_AUTH\",\n3525\t        rusqlite::ffi::SQLITE_NOTFOUND => \"SQLITE_NOTFOUND\",\n3526\t        rusqlite::ffi::SQLITE_CANTOPEN => \"SQLITE_CANTOPEN\",\n3527\t        _ => \"SQLITE_UNKNOWN\",\n3528\t    }\n3529\t}\n3530\t\n3531\tfn map_open_sqlite_error(err: rusqlite::Error, stage: OpenStage) -> EngineOpenError {\n3532\t    let Some(sqlite_error) = err.sqlite_error() else {\n3533\t        return EngineOpenError::Io { message: \"could not open database\".to_string() };\n3534\t    };\n3535\t    match sqlite_error.extended_code {\n3536\t        rusqlite::ffi::SQLITE_CORRUPT | rusqlite::ffi::SQLITE_NOTADB => {\n3537\t            EngineOpenError::Corruption(CorruptionDetail {\n3538\t                kind: match stage {\n3539\t                    OpenStage::WalReplay => CorruptionKind::WalReplayFailure,\n3540\t                    OpenStage::HeaderProbe => CorruptionKind::HeaderMalformed,\n3541\t                    OpenStage::SchemaProbe => CorruptionKind::SchemaInconsistent,\n3542\t                    OpenStage::EmbedderIdentity => CorruptionKind::EmbedderIdentityDrift,\n3543\t                },\n3544\t                stage,\n3545\t                locator: CorruptionLocator::OpaqueSqliteError {\n3546\t                    sqlite_extended_code: sqlite_error.extended_code,\n3547\t                },\n3548\t                recovery_hint: RecoveryHint {\n3549\t                    code: match stage {\n3550\t                        OpenStage::WalReplay => \"E_CORRUPT_WAL_REPLAY\",\n3551\t                        OpenStage::HeaderProbe => \"E_CORRUPT_HEADER\",\n3552\t                        OpenStage::SchemaProbe => \"E_CORRUPT_SCHEMA\",\n3553\t                        OpenStage::EmbedderIdentity => \"E_CORRUPT_EMBEDDER_IDENTITY\",\n3554\t                    },\n3555\t                    doc_anchor: match stage {\n3556\t                        OpenStage::WalReplay => \"design/recovery.md#wal-replay-failures\",\n3557\t                        OpenStage::HeaderProbe => \"design/recovery.md#header-malformed\","}]},"parent_tool_use_id":null,"session_id":"4e0d30c0-d2ee-4cef-baf2-390d4427d50f","uuid":"a0d5c384-53f3-406c-8a45-2109410bfa78","timestamp":"2026-05-16T13:11:24.055Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-10b-B-purge-restore-20260516T131040Z/src/rust/crates/fathomdb-engine/src/lib.rs","content":") -> rusqlite::Result<()> {\n    let tx = connection.transaction()?;\n\n    for (write, plan) in batch.iter().zip(plans) {\n        match (write, plan) {\n            (PreparedWrite::Node { kind, body, source_id }, WritePlan::Node) => {\n                tx.execute(\n                    \"INSERT INTO canonical_nodes(write_cursor, kind, body, source_id)\n                     VALUES(?1, ?2, ?3, ?4)\",\n                    params![cursor, kind, body, source_id],\n                )?;\n                tx.execute(\n                    \"INSERT INTO search_index(body, kind, write_cursor) VALUES(?1, ?2, ?3)\",\n                    params![body, kind, cursor],\n                )?;\n                if kind_is_vector_indexed(&tx, kind).unwrap_or(false) {\n                    tx.execute(\n                        \"INSERT INTO _fathomdb_projection_state(kind, last_enqueued_cursor, updated_at)\n                         VALUES(?1, ?2, 0)\n                         ON CONFLICT(kind) DO UPDATE SET last_enqueued_cursor = excluded.last_enqueued_cursor\",\n                        params![kind, cursor],\n                    )?;\n                }\n            }\n            (PreparedWrite::Edge { kind, from, to, source_id }, WritePlan::Edge) => {\n                tx.execute(\n                    \"INSERT INTO canonical_edges(write_cursor, kind, from_id, to_id, source_id)\n                     VALUES(?1, ?2, ?3, ?4, ?5)\",\n                    params![cursor, kind, from, to, source_id],\n                )?;\n            }\n            (\n                PreparedWrite::AdminSchema { name, kind, schema_json, retention_json },\n                WritePlan::AdminSchema,\n            ) => {\n                tx.execute(\n                    \"INSERT INTO operational_collections(\n                        name, kind, schema_json, retention_json, format_version, created_at\n                     ) VALUES(?1, ?2, ?3, ?4, 1, 0)\n                     ON CONFLICT(name) DO UPDATE SET\n                        schema_json = excluded.schema_json,\n                        retention_json = excluded.retention_json\",\n                    params![name, kind, schema_json, retention_json],\n                )?;\n            }\n            (\n                PreparedWrite::OpStore { collection, record_key, schema_id, body },\n                WritePlan::AppendOnlyLog,\n            ) => {\n                tx.execute(\n                    \"INSERT INTO operational_mutations(\n                        collection_name, record_key, op_kind, payload_json, schema_id, write_cursor\n                     ) VALUES(?1, ?2, 'append', ?3, ?4, ?5)\",\n                    params![collection, record_key, body, schema_id, cursor],\n                )?;\n            }\n            (\n                PreparedWrite::OpStore { collection, record_key, schema_id, body },\n                WritePlan::LatestState,\n            ) => {\n                tx.execute(\n                    \"INSERT INTO operational_state(\n                        collection_name, record_key, payload_json, schema_id, write_cursor\n                     ) VALUES(?1, ?2, ?3, ?4, ?5)\n                     ON CONFLICT(collection_name, record_key) DO UPDATE SET\n                        payload_json = excluded.payload_json,\n                        schema_id = excluded.schema_id,\n                        write_cursor = excluded.write_cursor\",\n                    params![collection, record_key, body, schema_id, cursor],\n                )?;\n            }\n            _ => return Err(rusqlite::Error::InvalidQuery),\n        }\n    }\n\n    if !pending_projection {\n        record_projection_terminal(&tx, cursor, \"up_to_date\")?;\n    }\n    enforce_provenance_retention(&tx, provenance_row_cap)?;\n    advance_projection_cursor(&tx)?;\n\n    tx.commit()\n}\n\nfn load_next_cursor(connection: &Connection) -> u64 {\n    let nodes = max_cursor(connection, \"canonical_nodes\").unwrap_or(0);\n    let edges = max_cursor(connection, \"canonical_edges\").unwrap_or(0);\n    let mutations = max_cursor(connection, \"operational_mutations\").unwrap_or(0);\n    let state = max_cursor(connection, \"operational_state\").unwrap_or(0);\n    nodes.max(edges).max(mutations).max(state)\n}\n\nfn max_cursor(connection: &Connection, table: &str) -> rusqlite::Result<u64> {\n    let sql = format!(\"SELECT COALESCE(MAX(write_cursor), 0) FROM {table}\");\n    connection.query_row(&sql, [], |row| row.get::<_, u64>(0))\n}\n\n/// Map a rusqlite error to its stable SQLite extended-code name.\n///\n/// Returns `None` for non-`SqliteFailure` variants (e.g. JSON conversion\n/// failures, type mismatches at the rusqlite layer) — those are not\n/// SQLite-internal events and should not be surfaced under\n/// `EventSource::SqliteInternal`. The names returned here are the\n/// canonical `SQLITE_*` symbol names from `sqlite3.h` and are stable\n/// dispatch keys for AC-021 / AC-006 binding adapters.\n///\n/// Only the subset of codes the engine can reach in 0.6.0 is enumerated\n/// — bare-extended-code matching covers the rest with a stable\n/// `\"SQLITE_UNKNOWN\"` fallback so subscribers always see a typed code.\n///\n/// Diagnostic completeness for unmapped codes: when this helper returns\n/// `\"SQLITE_UNKNOWN\"`, the numeric extended code is not lost — it\n/// remains on the underlying `rusqlite::Error::SqliteFailure` carried\n/// in the engine error chain that subscribers can inspect via\n/// `EngineError`'s `source()`. Expanding the enumerated subset (or\n/// surfacing the numeric code as a typed payload field) is a 0.7+\n/// improvement.\nfn sqlite_extended_code_name(err: &rusqlite::Error) -> Option<&'static str> {\n    let sqlite_error = err.sqlite_error()?;\n    let extended = sqlite_error.extended_code;\n    Some(match extended {\n        rusqlite::ffi::SQLITE_SCHEMA => \"SQLITE_SCHEMA\",\n        rusqlite::ffi::SQLITE_BUSY => \"SQLITE_BUSY\",\n        rusqlite::ffi::SQLITE_LOCKED => \"SQLITE_LOCKED\",\n        rusqlite::ffi::SQLITE_CORRUPT => \"SQLITE_CORRUPT\",\n        rusqlite::ffi::SQLITE_NOTADB => \"SQLITE_NOTADB\",\n        rusqlite::ffi::SQLITE_IOERR => \"SQLITE_IOERR\",\n        rusqlite::ffi::SQLITE_FULL => \"SQLITE_FULL\",\n        rusqlite::ffi::SQLITE_READONLY => \"SQLITE_READONLY\",\n        rusqlite::ffi::SQLITE_CONSTRAINT => \"SQLITE_CONSTRAINT\",\n        rusqlite::ffi::SQLITE_MISUSE => \"SQLITE_MISUSE\",\n        rusqlite::ffi::SQLITE_INTERRUPT => \"SQLITE_INTERRUPT\",\n        rusqlite::ffi::SQLITE_NOMEM => \"SQLITE_NOMEM\",\n        rusqlite::ffi::SQLITE_PERM => \"SQLITE_PERM\",\n        rusqlite::ffi::SQLITE_ABORT => \"SQLITE_ABORT\",\n        rusqlite::ffi::SQLITE_PROTOCOL => \"SQLITE_PROTOCOL\",\n        rusqlite::ffi::SQLITE_RANGE => \"SQLITE_RANGE\",\n        rusqlite::ffi::SQLITE_TOOBIG => \"SQLITE_TOOBIG\",\n        rusqlite::ffi::SQLITE_MISMATCH => \"SQLITE_MISMATCH\",\n        rusqlite::ffi::SQLITE_AUTH => \"SQLITE_AUTH\",\n        rusqlite::ffi::SQLITE_NOTFOUND => \"SQLITE_NOTFOUND\",\n        rusqlite::ffi::SQLITE_CANTOPEN => \"SQLITE_CANTOPEN\",\n        _ => \"SQLITE_UNKNOWN\",\n    })\n}\n\nfn sqlite_extended_code_name_from_int(extended: i32) -> &'static str {\n    match extended {\n        rusqlite::ffi::SQLITE_SCHEMA => \"SQLITE_SCHEMA\",\n        rusqlite::ffi::SQLITE_BUSY => \"SQLITE_BUSY\",\n        rusqlite::ffi::SQLITE_LOCKED => \"SQLITE_LOCKED\",\n        rusqlite::ffi::SQLITE_CORRUPT => \"SQLITE_CORRUPT\",\n        rusqlite::ffi::SQLITE_NOTADB => \"SQLITE_NOTADB\",\n        rusqlite::ffi::SQLITE_IOERR => \"SQLITE_IOERR\",\n        rusqlite::ffi::SQLITE_FULL => \"SQLITE_FULL\",\n        rusqlite::ffi::SQLITE_READONLY => \"SQLITE_READONLY\",\n        rusqlite::ffi::SQLITE_CONSTRAINT => \"SQLITE_CONSTRAINT\",\n        rusqlite::ffi::SQLITE_MISUSE => \"SQLITE_MISUSE\",\n        rusqlite::ffi::SQLITE_INTERRUPT => \"SQLITE_INTERRUPT\",\n        rusqlite::ffi::SQLITE_NOMEM => \"SQLITE_NOMEM\",\n        rusqlite::ffi::SQLITE_PERM => \"SQLITE_PERM\",\n        rusqlite::ffi::SQLITE_ABORT => \"SQLITE_ABORT\",\n        rusqlite::ffi::SQLITE_PROTOCOL => \"SQLITE_PROTOCOL\",\n        rusqlite::ffi::SQLITE_RANGE => \"SQLITE_RANGE\",\n        rusqlite::ffi::SQLITE_TOOBIG => \"SQLITE_TOOBIG\",\n        rusqlite::ffi::SQLITE_MISMATCH => \"SQLITE_MISMATCH\",\n        rusqlite::ffi::SQLITE_AUTH => \"SQLITE_AUTH\",\n        rusqlite::ffi::SQLITE_NOTFOUND => \"SQLITE_NOTFOUND\",\n        rusqlite::ffi::SQLITE_CANTOPEN => \"SQLITE_CANTOPEN\",\n        _ => \"SQLITE_UNKNOWN\",\n    }\n}\n\nfn map_open_sqlite_error(err: rusqlite::Error, stage: OpenStage) -> EngineOpenError {\n    let Some(sqlite_error) = err.sqlite_error() else {\n        return EngineOpenError::Io { message: \"could not open database\".to_string() };\n    };\n    match sqlite_error.extended_code {\n        rusqlite::ffi::SQLITE_CORRUPT | rusqlite::ffi::SQLITE_NOTADB => {\n            EngineOpenError::Corruption(CorruptionDetail {\n                kind: match stage {\n                    OpenStage::WalReplay => CorruptionKind::WalReplayFailure,\n                    OpenStage::HeaderProbe => CorruptionKind::HeaderMalformed,\n                    OpenStage::SchemaProbe => CorruptionKind::SchemaInconsistent,\n                    OpenStage::EmbedderIdentity => CorruptionKind::EmbedderIdentityDrift,\n                },\n                stage,\n                locator: CorruptionLocator::OpaqueSqliteError {\n                    sqlite_extended_code: sqlite_error.extended_code,\n                },\n                recovery_hint: RecoveryHint {\n                    code: match stage {\n                        OpenStage::WalReplay => \"E_CORRUPT_WAL_REPLAY\",\n                        OpenStage::HeaderProbe => \"E_CORRUPT_HEADER\",\n                        OpenStage::SchemaProbe => \"E_CORRUPT_SCHEMA\",\n                        OpenStage::EmbedderIdentity => \"E_CORRUPT_EMBEDDER_IDENTITY\",\n                    },\n                    doc_anchor: match stage {\n                        OpenStage::WalReplay => \"design/recovery.md#wal-replay-failures\",\n                        OpenStage::HeaderProbe => \"design/recovery.md#header-malformed\",","numLines