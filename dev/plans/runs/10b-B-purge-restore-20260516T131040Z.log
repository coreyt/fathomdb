r than silently corrupt the rebuild.\n2228\t        let drain_result = self.drain(REBUILD_DRAIN_TIMEOUT_MS);\n2229\t        let result = drain_result.and_then(|()| self.rebuild_shadow_state(include_fts, kind));\n2230\t        self.projection_runtime.set_frozen(false);\n2231\t        result\n2232\t    }\n2233\t\n2234\t    fn rebuild_shadow_state(\n2235\t        &self,\n2236\t        include_fts: bool,\n2237\t        kind: RebuildKind,\n2238\t    ) -> Result<RebuildReport, EngineError> {\n2239\t        let mut connection = self.connection.lock().map_err(|_| EngineError::Storage)?;\n2240\t        let connection = connection.as_mut().ok_or(EngineError::Closing)?;\n2241\t        let tx = connection.transaction().map_err(|_| EngineError::Storage)?;\n2242\t        let mut rows_invalidated: u64 = 0;\n2243\t        if include_fts {\n2244\t            let n = tx.execute(\"DELETE FROM search_index\", []).map_err(|_| EngineError::Storage)?;\n2245\t            rows_invalidated = rows_invalidated.saturating_add(n as u64);\n2246\t        }\n2247\t        let n = tx.execute(\"DELETE FROM vector_default\", []).map_err(|_| EngineError::Storage)?;\n2248\t        rows_invalidated = rows_invalidated.saturating_add(n as u64);\n2249\t        let n = tx\n2250\t            .execute(\"DELETE FROM _fathomdb_vector_rows\", [])\n2251\t            .map_err(|_| EngineError::Storage)?;\n2252\t        rows_invalidated = rows_invalidated.saturating_add(n as u64);\n2253\t        let n = tx\n2254\t            .execute(\"DELETE FROM _fathomdb_projection_terminal\", [])\n2255\t            .map_err(|_| EngineError::Storage)?;\n2256\t        rows_invalidated = rows_invalidated.saturating_add(n as u64);\n2257\t        store_projection_cursor(&tx, 0).map_err(|_| EngineError::Storage)?;\n2258\t        let mut rows_rebuilt: u64 = 0;\n2259\t        if include_fts {\n2260\t            for row in canonical_node_rows(&tx).map_err(|_| EngineError::Storage)? {\n2261\t                tx.execute(\n2262\t             