{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YBGnabH4AZciKYUTN3mkML","type":"tool_result","content":"3230\t\n3231\tfn collect_projection_jobs(\n3232\t    connection: &Connection,\n3233\t    batch: &[PreparedWrite],\n3234\t) -> Result<Vec<ProjectionJob>, EngineError> {\n3235\t    let mut jobs = Vec::new();\n3236\t    for write in batch {\n3237\t        if let PreparedWrite::Node { kind, body, .. } = write {\n3238\t            if kind_is_vector_indexed(connection, kind)? {\n3239\t                jobs.push(ProjectionJob { cursor: 0, kind: kind.clone(), body: body.clone() });\n3240\t            }\n3241\t        }\n3242\t    }\n3243\t    Ok(jobs)\n3244\t}\n3245\t\n3246\tfn validate_write(\n3247\t    connection: &Connection,\n3248\t    write: &PreparedWrite,\n3249\t) -> Result<WritePlan, EngineError> {\n3250\t    match write {\n3251\t        PreparedWrite::Node { kind, body, source_id } => {\n3252\t            if kind.trim().is_empty() || body.trim().is_empty() {\n3253\t                return Err(EngineError::WriteValidation);\n3254\t            }\n3255\t            if let Some(source_id) = source_id {\n3256\t                if source_id.is_empty() {\n3257\t                    return Err(EngineError::WriteValidation);\n3258\t                }\n3259\t            }\n3260\t            Ok(WritePlan::Node)\n3261\t        }\n3262\t        PreparedWrite::Edge { kind, from, to, source_id } => {\n3263\t            if kind.trim().is_empty() || from.trim().is_empty() || to.trim().is_empty() {\n3264\t                return Err(EngineError::WriteValidation);\n3265\t            }\n3266\t            if let Some(source_id) = source_id {\n3267\t                if source_id.is_empty() {\n3268\t                    return Err(EngineError::WriteValidation);\n3269\t                }\n3270\t            }\n3271\t            Ok(WritePlan::Edge)\n3272\t        }\n3273\t        PreparedWrite::AdminSchema { name, kind, schema_json, retention_json } => {\n3274\t            if name.trim().is_empty()\n3275\t                || !matches!(kind.as_str(), \"append_only_log\" | \"latest_state\")\n3276\t                || serde_json::from_str::<Value>(schema_json).is_err()\n3277\t                || serde_json::from_str::<Value>(retention_json).is_err()\n3278\t                || contains_external_ref(schema_json)\n3279\t            {\n3280\t                return Err(EngineError::SchemaValidation);\n3281\t            }\n3282\t            Ok(WritePlan::AdminSchema)\n3283\t        }\n3284\t        PreparedWrite::OpStore { collection, record_key, schema_id, body } => {\n3285\t            if collection.trim().is_empty() || record_key.trim().is_empty() {\n3286\t                return Err(EngineError::WriteValidation);\n3287\t            }\n3288\t            let (kind, schema_json) = collection_metadata(connection, collection)?;\n3289\t            if let Some(schema_id) = schema_id {\n3290\t                if schema_id != collection {\n3291\t                    return Err(EngineError::SchemaValidation);\n3292\t                }\n3293\t                validate_payload(&schema_json, body)?;\n3294\t            } else if serde_json::from_str::<Value>(body).is_err() {\n3295\t                return Err(EngineError::SchemaValidation);\n3296\t            }\n3297\t\n3298\t            match kind.as_str() {\n3299\t                \"append_only_log\" => Ok(WritePlan::AppendOnlyLog),\n3300\t                \"latest_state\" => Ok(WritePlan::LatestState),\n3301\t                _ => Err(EngineError::OpStore),\n3302\t            }\n3303\t        }\n3304\t    }\n3305\t}\n3306\t\n3307\tfn collection_metadata(\n3308\t    connection: &Connection,\n3309\t    collection: &str,\n3310\t) -> Result<(String, String), EngineError> {\n3311\t    connection\n3312\t        .query_row(\n3313\t            \"SELECT kind, schema_json FROM operational_collections WHERE name = ?1\",\n3314\t            [collection],\n3315\t            |row| Ok((row.get::<_, String>(0)?, row.get::<_, String>(1)?)),\n3316\t        )\n3317\t        .map_err(|_| EngineError::OpStore)\n3318\t}\n3319\t\n3320\tfn validate_payload(schema_json: &str, body: &str) -> Result<(), EngineError> {\n3321\t    let schema =\n3322\t        serde_json::from_str::<Value>(schema_json).map_err(|_| EngineError::SchemaValidation)?;\n3323\t    let payload = serde_json::from_str::<Value>(body).map_err(|_| EngineError::SchemaValidation)?;\n3324\t\n3325\t    let compiled = JSONSchema::compile(&schema).map_err(|_| EngineError::SchemaValidation)?;\n3326\t    compiled.validate(&payload).map_err(|_| EngineError::SchemaValidation)?;\n3327\t\n3328\t    Ok(())\n3329\t}\n3330\t\n3331\tfn contains_external_ref(schema_json: &str) -> bool {\n3332\t    let Ok(value) = serde_json::from_str::<Value>(schema_json) else {\n3333\t        return false;\n3334\t    };\n3335\t    value_contains_external_ref(&value)\n3336\t}\n3337\t\n3338\tfn value_contains_external_ref(value: &Value) -> bool {\n3339\t    match value {\n3340\t        Value::Object(object) => object.iter().any(|(key, value)| {\n3341\t            if key == \"$ref\" {\n3342\t                return value.as_str().is_some_and(|uri| !uri.starts_with('#'));\n3343\t            }\n3344\t            value_contains_external_ref(value)\n3345\t        }),\n3346\t        Value::Array(values) => values.iter().any(value_contains_external_ref),\n3347\t        _ => false,\n3348\t    }\n3349\t}\n3350\t\n3351\tfn commit_batch(\n3352\t    connection: &mut Connection,\n3353\t    batch: &[PreparedWrite],\n3354\t    plans: &[WritePlan],\n3355\t    cursor: u64,\n3356\t    pending_projection: bool,\n3357\t    provenance_row_cap: u64,\n3358\t) -> rusqlite::Result<()> {\n3359\t    let tx = connection.transaction()?;"}]},"parent_tool_use_id":null,"session_id":"4e0d30c0-d2ee-4cef-baf2-390d4427d50f","uuid":"604a260d-619c-43f0-b21e-a99195134a86","timestamp":"2026-05-16T13:11:21.984Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-10b-B-purge-restore-20260516T131040Z/src/rust/crates/fathomdb-engine/src/lib.rs","content":"\nfn collect_projection_jobs(\n    connection: &Connection,\n    batch: &[PreparedWrite],\n) -> Result<Vec<ProjectionJob>, EngineError> {\n    let mut jobs = Vec::new();\n    for write in batch {\n        if let PreparedWrite::Node { kind, body, .. } = write {\n            if kind_is_vector_indexed(connection, kind)? {\n                jobs.push(ProjectionJob { cursor: 0, kind: kind.clone(), body: body.clone() });\n            }\n        }\n    }\n    Ok(jobs)\n}\n\nfn validate_write(\n    connection: &Connection,\n    write: &PreparedWrite,\n) -> Result<WritePlan, EngineError> {\n    match write {\n        PreparedWrite::Node { kind, body, source_id } => {\n            if kind.trim().is_empty() || body.trim().is_empty() {\n                return Err(EngineError::WriteValidation);\n            }\n            if let Some(source_id) = source_id {\n                if source_id.is_empty() {\n                    return Err(EngineError::WriteValidation);\n                }\n            }\n            Ok(WritePlan::Node)\n        }\n        PreparedWrite::Edge { kind, from, to, source_id } => {\n            if kind.trim().is_empty() || from.trim().is_empty() || to.trim().is_empty() {\n                return Err(EngineError::WriteValidation);\n            }\n            if let Some(source_id) = source_id {\n                if source_id.is_empty() {\n                    return Err(EngineError::WriteValidation);\n                }\n            }\n            Ok(WritePlan::Edge)\n        }\n        PreparedWrite::AdminSchema { name, kind, schema_json, retention_json } => {\n            if name.trim().is_empty()\n                || !matches!(kind.as_str(), \"append_only_log\" | \"latest_state\")\n                || serde_json::from_str::<Value>(schema_json).is_err()\n                || serde_json::from_str::<Value>(retention_json).is_err()\n                || contains_external_ref(schema_json)\n            {\n                return Err(EngineError::SchemaValidation);\n            }\n            Ok(WritePlan::AdminSchema)\n        }\n        PreparedWrite::OpStore { collection, record_key, schema_id, body } => {\n            if collection.trim().is_empty() || record_key.trim().is_empty() {\n                return Err(EngineError::WriteValidation);\n            }\n            let (kind, schema_json) = collection_metadata(connection, collection)?;\n            if let Some(schema_id) = schema_id {\n                if schema_id != collection {\n                    return Err(EngineError::SchemaValidation);\n                }\n                validate_payload(&schema_json, body)?;\n            } else if serde_json::from_str::<Value>(body).is_err() {\n                return Err(EngineError::SchemaValidation);\n            }\n\n            match kind.as_str() {\n                \"append_only_log\" => Ok(WritePlan::AppendOnlyLog),\n                \"latest_state\" => Ok(WritePlan::LatestState),\n                _ => Err(EngineError::OpStore),\n            }\n        }\n    }\n}\n\nfn collection_metadata(\n    connection: &Connection,\n    collection: &str,\n) -> Result<(String, String), EngineError> {\n    connection\n        .query_row(\n            \"SELECT kind, schema_json FROM operational_collections WHERE name = ?1\",\n            [collection],\n            |row| Ok((row.get::<_, String>(0)?, row.get::<_, String>(1)?)),\n        )\n        .map_err(|_| EngineError::OpStore)\n}\n\nfn validate_payload(schema_json: &str, body: &str) -> Result<(), EngineError> {\n    let schema =\n        serde_json::from_str::<Value>(schema_json).map_err(|_| EngineError::SchemaValidation)?;\n    let payload = serde_json::from_str::<Value>(body).map_err(|_| EngineError::SchemaValidation)?;\n\n    let compiled = JSONSchema::compile(&schema).map_err(|_| EngineError::SchemaValidation)?;\n    compiled.validate(&payload).map_err(|_| EngineError::SchemaValidation)?;\n\n    Ok(())\n}\n\nfn contains_external_ref(schema_json: &str) -> bool {\n    let Ok(value) = serde_json::from_str::<Value>(schema_json) else {\n        return false;\n    };\n    value_contains_external_ref(&value)\n}\n\nfn value_contains_external_ref(value: &Value) -> bool {\n    match value {\n        Value::Object(object) => object.iter().any(|(key, value)| {\n            if key == \"$ref\" {\n                return value.as_str().is_some_and(|uri| !uri.starts_with('#'));\n            }\n            value_contains_external_ref(value)\n        }),\n        Value::Array(values) => values.iter().any(value_contains_external_ref),\n        _ => false,\n    }\n}\n\nfn commit_batch(\n    connection: &mut Connection,\n    batch: &[PreparedWrite],\n    plans: &[WritePlan],\n    cursor: u64,\n    pending_projection: bool,\n    provenance_row_cap: u64,\n) -> rusqlite::Result<()> {\n    let tx = connection.transaction()?;","numLines":130,"startLine":3230,"totalLines":3828}}}
