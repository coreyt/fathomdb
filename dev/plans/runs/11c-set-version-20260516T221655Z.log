{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M58JAgScu7W6f4nSAVxuBV","type":"tool_result","content":"The file /tmp/fdb-11c-set-version-20260516T221655Z/dev/release/tests/pip_skew.sh has been updated successfully. (file state is current in your context — no need to Read it back)"}]},"parent_tool_use_id":null,"session_id":"4cda15f5-dd21-46d9-b4db-04d61e252748","uuid":"e4556541-272c-484f-97fb-ec55d846b277","timestamp":"2026-05-16T22:21:12.377Z","tool_use_result":{"filePath":"/tmp/fdb-11c-set-version-20260516T221655Z/dev/release/tests/pip_skew.sh","oldString":"WORK=\"$(mktemp -d)\"\ntrap 'rm -rf \"$WORK\"' EXIT\n\nVENV=\"$WORK/venv\"\nWHEELS=\"$WORK/wheels\"\nmkdir -p \"$WHEELS\"\n\npython3 -m venv \"$VENV\"\nPIP=\"$VENV/bin/pip\"\n\n# Build wheels for the two api versions + two probes into a local\n# find-links directory. --no-build-isolation avoids a network fetch of\n# the build backend; setuptools+wheel are already in the venv.\n\"$PIP\" install --quiet --upgrade pip setuptools wheel >/dev/null\nfor pkg in api-v1 api-v2 probe-a probe-b; do\n  \"$PIP\" wheel --quiet --no-deps --no-build-isolation \\\n    --wheel-dir \"$WHEELS\" \"$FIXTURE/$pkg\" >/dev/null\ndone","newString":"WORK=\"$(mktemp -d)\"\ntrap 'rm -rf \"$WORK\"' EXIT\n\nVENV=\"$WORK/venv\"\nWHEELS=\"$WORK/wheels\"\nSRC=\"$WORK/src\"\nmkdir -p \"$WHEELS\"\n\n# Copy the fixture into a writable workdir so the wheel build does not\n# leak build/ or *.egg-info under the tracked fixture path.\ncp -r \"$FIXTURE\" \"$SRC\"\n\npython3 -m venv \"$VENV\"\nPIP=\"$VENV/bin/pip\"\n\n# Build wheels for the two api versions + two probes into a local\n# find-links directory. --no-build-isolation avoids a network fetch of\n# the build backend; setuptools+wheel are already in the venv.\n\"$PIP\" install --quiet --upgrade pip setuptools wheel >/dev/null\nfor pkg in api-v1 api-v2 probe-a probe-b; do\n  \"$PIP\" wheel --quiet --no-deps --no-build-isolation \\\n    --wheel-dir \"$WHEELS\" \"$SRC/$pkg\" >/dev/null\ndone","originalFile":"#!/usr/bin/env bash\n# AC-051b: pip version-skew detected at resolve time.\n#\n# Builds four synthetic wheels (api-v1, api-v2, probe-a, probe-b) where\n# probe-a pins mock-skew-api==0.6.0 and probe-b pins\n# mock-skew-api==99.99.99. Installing both into one environment forces\n# the pip resolver to fail with a conflict naming mock-skew-api. The\n# stand-in names map back to the real packages once REQ-048 publishing\n# lands (see fixtures/pip-skew/constraints.txt).\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nFIXTURE=\"$SCRIPT_DIR/../fixtures/pip-skew\"\n\nif ! command -v python3 >/dev/null 2>&1; then\n  echo \"skip: python3 not on PATH\" >&2\n  exit 0\nfi\n\nif ! python3 -c 'import setuptools, wheel' >/dev/null 2>&1; then\n  echo \"skip: setuptools/wheel not importable; install python build deps\" >&2\n  exit 0\nfi\n\nWORK=\"$(mktemp -d)\"\ntrap 'rm -rf \"$WORK\"' EXIT\n\nVENV=\"$WORK/venv\"\nWHEELS=\"$WORK/wheels\"\nmkdir -p \"$WHEELS\"\n\npython3 -m venv \"$VENV\"\nPIP=\"$VENV/bin/pip\"\n\n# Build wheels for the two api versions + two probes into a local\n# find-links directory. --no-build-isolation avoids a network fetch of\n# the build backend; setuptools+wheel are already in the venv.\n\"$PIP\" install --quiet --upgrade pip setuptools wheel >/dev/null\nfor pkg in api-v1 api-v2 probe-a probe-b; do\n  \"$PIP\" wheel --quiet --no-deps --no-build-isolation \\\n    --wheel-dir \"$WHEELS\" \"$FIXTURE/$pkg\" >/dev/null\ndone\n\n# Resolve both probes against the local index only. Expect failure.\nif out=\"$(\"$PIP\" install --dry-run --no-index \\\n  --find-links \"$WHEELS\" \\\n  mock-fathomdb==0.6.0 mock-fathomdb-embedder==0.6.0 2>&1)\"; then\n  printf 'FAIL: pip resolved unexpectedly; expected conflict\\n%s\\n' \"$out\" >&2\n  exit 1\nfi\n\nif ! printf '%s' \"$out\" | grep -q 'mock-skew-api'; then\n  printf 'FAIL: pip error did not name mock-skew-api\\n%s\\n' \"$out\" >&2\n  exit 1\nfi\n\nprintf 'PASS: AC-051b — pip resolver detected mock-skew-api skew\\n'\n","structuredPatch":[{"oldStart":27,"oldLines":8,"newStart":27,"newLines":13,"lines":[" "," VENV=\"$WORK/venv\""," WHEELS=\"$WORK/wheels\"","+SRC=\"$WORK/src\""," mkdir -p \"$WHEELS\""," ","+# Copy the fixture into a writable workdir so the wheel build does not","+# leak build/ or *.egg-info under the tracked fixture path.","+cp -r \"$FIXTURE\" \"$SRC\"","+"," python3 -m venv \"$VENV\""," PIP=\"$VENV/bin/pip\""," "]},{"oldStart":38,"oldLines":7,"newStart":43,"newLines":7,"lines":[" \"$PIP\" install --quiet --upgrade pip setuptools wheel >/dev/null"," for pkg in api-v1 api-v2 probe-a probe-b; do","   \"$PIP\" wheel --quiet --no-deps --no-build-isolation \\","-    --wheel-dir \"$WHEELS\" \"$FIXTURE/$pkg\" >/dev/null","+    --wheel-dir \"$WHEELS\" \"$SRC/$pkg\" >/dev/null"," done"," "," # Resolve both probes against the local index only. Expect failure."]}],"userModified":false,"replaceAll":false}}
