-embedder==0.6.0 2>&1)\"; then\n  printf 'FAIL: pip resolved unexpectedly; expected conflict\\n%s\\n' \"$out\" >&2\n  exit 1\nfi\n\nif ! printf '%s' \"$out\" | grep -q 'mock-skew-api'; then\n  printf 'FAIL: pip error did not name mock-skew-api\\n%s\\n' \"$out\" >&2\n  exit 1\nfi\n\nprintf 'PASS: AC-051b — pip resolver detected mock-skew-api skew\\n'\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":383,"cache_read_input_tokens":87762,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":383},"output_tokens":62,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"4cda15f5-dd21-46d9-b4db-04d61e252748","uuid":"072424d4-a8ac-4c49-ab3b-9bd407ff64ee"}
