{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GatsiSR6XFxGFGy8gzkhMU","type":"tool_result","content":"1\t// FFI safety-contract tests for the napi-rs binding.\n2\t//\n3\t// Covers AC-067 (panic catch), AC-068a (embedded NUL rejected), and\n4\t// AC-068b (unpaired UTF-16 surrogate rejected). Mirrors\n5\t// `src/python/tests/test_ffi_safety.py` from Phase 11a.\n6\t\n7\timport test from \"node:test\";\n8\timport assert from \"node:assert/strict\";\n9\t\n10\timport { Engine, admin } from \"../src/index.js\";\n11\timport {\n12\t  FathomDbError,\n13\t  FathomDbPanicError,\n14\t  WriteValidationError,\n15\t  rethrowTyped,\n16\t} from \"../src/errors.js\";\n17\timport { native } from \"../src/binding.js\";\n18\timport { freshDbPath } from \"./helpers.js\";\n19\t\n20\tconst NUL = String.fromCharCode(0);\n21\tconst SURROGATE = String.fromCharCode(0xd800);\n22\t\n23\ttest(\"AC-067 panic surfaces as FathomDbPanicError, process unchanged\", async () => {\n24\t  const pidBefore = process.pid;\n25\t\n26\t  assert.equal(typeof native.forcePanicForTest, \"function\", \"force-panic hook must be exposed\");\n27\t\n28\t  assert.throws(\n29\t    () => {\n30\t      try {\n31\t        native.forcePanicForTest!();\n32\t      } catch (err) {\n33\t        rethrowTyped(err);\n34\t      }\n35\t    },\n36\t    (err: unknown) => {\n37\t      assert.ok(err instanceof FathomDbPanicError, \"must be FathomDbPanicError\");\n38\t      assert.ok(!(err instanceof FathomDbError), \"panic must NOT subclass FathomDbError\");\n39\t      return true;\n40\t    },\n41\t  );\n42\t\n43\t  assert.equal(process.pid, pidBefore, \"host process must not be aborted by engine panic\");\n44\t\n45\t  const engine = await Engine.open(freshDbPath());\n46\t  try {\n47\t    const snap = engine.counters();\n48\t    assert.ok(snap !== undefined);\n49\t  } finally {\n50\t    await engine.close();\n51\t  }\n52\t});\n53\t\n54\ttest(\"AC-068a embedded NUL in op-store body rejected as WriteValidationError\", async () => {\n55\t  const engine = await Engine.open(freshDbPath());\n56\t  try {\n57\t    await admin.configure(engine, { name: \"nul_col\", body: \"{}\" });\n58\t    const before = engine.counters().writeRows;\n59\t\n60\t    await assert.rejects(\n61\t      () =>\n62\t        engine.write([\n63\t          {\n64\t            opStore: {\n65\t              collection: \"nul_col\",\n66\t              recordKey: \"k1\",\n67\t              body: `{\"x\":\"a${NUL}b\"}`,\n68\t            },\n69\t          },\n70\t        ]),\n71\t      (err: unknown) => {\n72\t        assert.ok(err instanceof WriteValidationError, \"must be WriteValidationError\");\n73\t        assert.ok(err instanceof FathomDbError, \"must extend FathomDbError\");\n74\t        return true;\n75\t      },\n76\t    );\n77\t\n78\t    const after = engine.counters().writeRows;\n79\t    assert.equal(after, before, \"no row may be written when a NUL is rejected\");\n80\t  } finally {\n81\t    await engine.close();\n82\t  }\n83\t});\n84\t\n85\ttest(\"AC-068b unpaired UTF-16 surrogate in op-store body rejected as WriteValidationError\", async () => {\n86\t  const engine = await Engine.open(freshDbPath());\n87\t  try {\n88\t    await admin.configure(engine, { name: \"sur_col\", body: \"{}\" });\n89\t    const before = engine.counters().writeRows;\n90\t\n91\t    await assert.rejects(\n92\t      () =>\n93\t        engine.write([\n94\t          {\n95\t            opStore: {\n96\t              collection: \"sur_col\",\n97\t              recordKey: \"k1\",\n98\t              body: `{\"x\":\"a${SURROGATE}b\"}`,\n99\t            },\n100\t          },\n101\t        ]),\n102\t      (err: unknown) => {\n103\t        assert.ok(err instanceof WriteValidationError, \"must be WriteValidationError\");\n104\t        assert.ok(err instanceof FathomDbError, \"must extend FathomDbError\");\n105\t        return true;\n106\t      },\n107\t    );\n108\t\n109\t    const after = engine.counters().writeRows;\n110\t    assert.equal(after, before, \"no row may be written when a surrogate is rejected\");\n111\t  } finally {\n112\t    await engine.close();\n113\t  }\n114\t});\n115\t\n116\ttest(\"AC-068a embedded NUL in node kind also rejected before write\", async () => {\n117\t  const engine = await Engine.open(freshDbPath());\n118\t  try {\n119\t    await assert.rejects(\n120\t      () => engine.write([{ kind: `do${NUL}c`, body: \"{}\" }]),\n121\t      (err: unknown) => {\n122\t        assert.ok(err instanceof WriteValidationError);\n123\t        return true;\n124\t      },\n125\t    );\n126\t  } finally {\n127\t    await engine.close();\n128\t  }\n129\t});\n130\t"}]},"parent_tool_use_id":null,"session_id":"a52cedd5-f91e-4c7f-aa9c-db400e73d860","uuid":"54efb5e4-90c8-41d4-80e8-fb8641bf396f","timestamp":"2026-05-16T21:44:26.696Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-11b-napi-binding-20260516T210327Z/src/ts/tests/ffi-safety.test.ts","content":"// FFI safety-contract tests for the napi-rs binding.\n//\n// Covers AC-067 (panic catch), AC-068a (embedded NUL rejected), and\n// AC-068b (unpaired UTF-16 surrogate rejected). Mirrors\n// `src/python/tests/test_ffi_safety.py` from Phase 11a.\n\nimport test from \"node:test\";\nimport assert from \"node:assert/strict\";\n\nimport { Engine, admin } from \"../src/index.js\";\nimport {\n  FathomDbError,\n  FathomDbPanicError,\n  WriteValidationError,\n  rethrowTyped,\n} from \"../src/errors.js\";\nimport { native } from \"../src/binding.js\";\nimport { freshDbPath } from \"./helpers.js\";\n\nconst NUL = String.fromCharCode(0);\nconst SURROGATE = String.fromCharCode(0xd800);\n\ntest(\"AC-067 panic surfaces as FathomDbPanicError, process unchanged\", async () => {\n  const pidBefore = process.pid;\n\n  assert.equal(typeof native.forcePanicForTest, \"function\", \"force-panic hook must be exposed\");\n\n  assert.throws(\n    () => {\n      try {\n        native.forcePanicForTest!();\n      } catch (err) {\n        rethrowTyped(err);\n      }\n    },\n    (err: unknown) => {\n      assert.ok(err instanceof FathomDbPanicError, \"must be FathomDbPanicError\");\n      assert.ok(!(err instanceof FathomDbError), \"panic must NOT subclass FathomDbError\");\n      return true;\n    },\n  );\n\n  assert.equal(process.pid, pidBefore, \"host process must not be aborted by engine panic\");\n\n  const engine = await Engine.open(freshDbPath());\n  try {\n    const snap = engine.counters();\n    assert.ok(snap !== undefined);\n  } finally {\n    await engine.close();\n  }\n});\n\ntest(\"AC-068a embedded NUL in op-store body rejected as WriteValidationError\", async () => {\n  const engine = await Engine.open(freshDbPath());\n  try {\n    await admin.configure(engine, { name: \"nul_col\", body: \"{}\" });\n    const before = engine.counters().writeRows;\n\n    await assert.rejects(\n      () =>\n        engine.write([\n          {\n            opStore: {\n              collection: \"nul_col\",\n              recordKey: \"k1\",\n              body: `{\"x\":\"a${NUL}b\"}`,\n            },\n          },\n        ]),\n      (err: unknown) => {\n        assert.ok(err instanceof WriteValidationError, \"must be WriteValidationError\");\n        assert.ok(err instanceof FathomDbError, \"must extend FathomDbError\");\n        return true;\n      },\n    );\n\n    const after = engine.counters().writeRows;\n    assert.equal(after, before, \"no row may be written when a NUL is rejected\");\n  } finally {\n    await engine.close();\n  }\n});\n\ntest(\"AC-068b unpaired UTF-16 surrogate in op-store body rejected as WriteValidationError\", async () => {\n  const engine = await Engine.open(freshDbPath());\n  try {\n    await admin.configure(engine, { name: \"sur_col\", body: \"{}\" });\n    const before = engine.counters().writeRows;\n\n    await assert.rejects(\n      () =>\n        engine.write([\n          {\n            opStore: {\n              collection: \"sur_col\",\n              recordKey: \"k1\",\n              body: `{\"x\":\"a${SURROGATE}b\"}`,\n            },\n          },\n        ]),\n      (err: unknown) => {\n        assert.ok(err instanceof WriteValidationError, \"must be WriteValidationError\");\n        assert.ok(err instanceof FathomDbError, \"must extend FathomDbError\");\n        return true;\n      },\n    );\n\n    const after = engine.counters().writeRows;\n    assert.equal(after, before, \"no row may be written when a surrogate is rejected\");\n  } finally {\n    await engine.close();\n  }\n});\n\ntest(\"AC-068a embedded NUL in node kind also rejected before write\", async () => {\n  const engine = await Engine.open(freshDbPath());\n  try {\n    await assert.rejects(\n      () => engine.write([{ kind: `do${NUL}c`, body: \"{}\" }]),\n      (err: unknown) => {\n        assert.ok(err instanceof WriteValidationError);\n        return true;\n      },\n    );\n  } finally {\n    await engine.close();\n  }\n});\n","numLines":130,"startLine":1,"totalLines":130}}}
