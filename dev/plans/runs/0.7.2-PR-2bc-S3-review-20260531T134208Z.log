   246	/// Generate one synthetic chunk body of approximately `target_bytes`
   247	/// (~500 B per ADR) using the Zipfian sampler. Tokens are space-joined.
   248	fn synth_chunk_body(rng: &mut SeededRng, vocab: &[String], cumulative: &[f64]) -> String {
   249	    // Tokens average ~7 chars + 1 separator, target ~500 B => ~63 tokens.
   250	    let mut body = String::with_capacity(512);
   251	    let token_count = 55 + rng.next_in(20);
   252	    for i in 0..token_count {
   253	        if i > 0 {
   254	            body.push(' ');
   255	        }
   256	        body.push_str(&vocab[zipf_index(rng, cumulative)]);
   257	    }
   258	    body
   259	}
   260	
   261	/// Choose a held-out query token from the 50th–90th percentile
   262	/// term-frequency band per ADR-0.6.0-text-query-latency-gates. Vocab is
   263	/// indexed by descending frequency rank (rank 0 most frequent), so the
   264	/// band maps to indices [0.10*vocab, 0.50*vocab) (frequency rank space).
   265	/// The Zipfian sampler yields rank 0 most often, so this band carves out
   266	/// the body of the distribution.
   267	fn ac012_query_token_band(vocab: &[String]) -> Vec<String> {
   268	    let lo = vocab.len() / 10;
   269	    let hi = vocab.len() / 2;
   270	    vocab[lo..hi].to_vec()
   271	}
