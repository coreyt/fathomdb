   408	/// Build a held-out reproducible query set drawn from the same
   409	/// distribution as the indexed corpus (ADR-0.6.0-retrieval-latency-gates
   410	/// "Query vectors drawn from a held-out slice of the same distribution").
   411	fn ac013_query_bodies(count: usize) -> Vec<String> {
   412	    let vocab = perf_vocab();
   413	    let cumulative = zipf_cumulative(vocab.len());
   414	    // Use a different seed than the corpus so the query set is held out
   415	    // (not byte-equal to seeded chunks but drawn from same distribution).
   416	    let mut rng = SeededRng::new(0x0AC0_130D_EC0D_E000);
   417	    (0..count).map(|_| synth_chunk_body(&mut rng, &vocab, &cumulative)).collect()
   418	}
   419	
   420	/// Bounded-size histogram for AC-019 tail-latency capture. Single
   421	/// power-of-two bucketing in microseconds; avoids unbounded
   422	/// `Vec<Duration>` per the Pack D plan (`Histogram::record` style).
   423	struct LatencyHistogram {
   424	    /// Bucket i spans [2^i us, 2^(i+1) us). 32 buckets covers 1 us .. ~71 minutes.
   425	    buckets: [u64; 32],
   426	    count: u64,
   427	}
   428	
   429	impl LatencyHistogram {
   430	    fn new() -> Self {
   431	        Self { buckets: [0; 32], count: 0 }
   432	    }
   433	
   434	    fn record(&mut self, d: Duration) {
   435	        let us = d.as_micros().max(1) as u64;
   436	        let bucket = (63 - us.leading_zeros()) as usize;
   437	        let bucket = bucket.min(self.buckets.len() - 1);
   438	        self.buckets[bucket] += 1;
   439	        self.count += 1;
   440	    }
   441	
   442	    fn merge(&mut self, other: &LatencyHistogram) {
   443	        for i in 0..self.buckets.len() {
   444	            self.buckets[i] += other.buckets[i];
   445	        }
   446	        self.count += other.count;
   447	    }
   448	
   449	    /// Return the upper bound of the bucket containing the requested
   450	    /// percentile (numerator/denominator). Conservative ceiling.
   451	    fn percentile_ceil(&self, numerator: u64, denominator: u64) -> Duration {
   452	        if self.count == 0 {
   453	            return Duration::ZERO;
   454	        }
   455	        let target = (self.count * numerator).div_ceil(denominator);
   456	        let mut acc: u64 = 0;
   457	        for (i, count) in self.buckets.iter().enumerate() {
   458	            acc += count;
   459	            if acc >= target {
   460	                let upper_us = 1u64 << (i + 1);
   461	                return Duration::from_micros(upper_us);
   462	            }
   463	        }
   464	        let i = self.buckets.len() - 1;
   465	        Duration::from_micros(1u64 << (i + 1))
   466	    }
   467	}
