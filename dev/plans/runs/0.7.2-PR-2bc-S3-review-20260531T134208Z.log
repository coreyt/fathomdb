   300	/// Deterministic dense isotropic embedder. Seeds an xorshift64 PRNG
   301	/// from FNV-1a of the input and fills every coordinate with a
   302	/// uniformly-distributed value in [-1, 1), then L2-normalizes.
   303	///
   304	/// **Why dense, not sparse.** A prior version of this struct placed
   305	/// mass on only 6 of `dim` coordinates (FNV-driven slot picks). That
   306	/// is pathological for binary quantization: `vec_quantize_binary`
   307	/// takes the sign bit of every coordinate, so for a dim-768 sparse
   308	/// vector with 6 non-zero coords, ~762 of 768 sign bits encode the
   309	/// IEEE sign of an exact 0.0 (positive). The bit-distance between
   310	/// any two corpus vectors then carries only ~6 bits of signal — bit-
   311	/// KNN top-K=64 returns near-random candidates and AC-013b recall@10
   312	/// collapsed to 0.157 on N=10K once the unrelated batch-collapse bug
   313	/// was fixed. See `dev/plans/runs/STATUS-perf-vector-quant.md`
   314	/// "Fixture-replacement evaluation" for the full analysis.
   315	///
   316	/// **Why isotropic.** Per-coordinate variance is uniform across
   317	/// dim, which is the regime where Charikar's `1 − θ/π` SimHash
   318	/// collision-probability bound is tight. Real embeddings are
   319	/// anisotropic (Ethayarajh 2019; Gao 2019 "cone effect") and will
   320	/// score *lower* than this fixture under sign-bit quantization —
   321	/// see the e5-base-v2 reference at 74.8% NDCG@10 retention. So this
   322	/// fixture's recall@10 is a NECESSARY-but-not-SUFFICIENT condition
   323	/// for the AC-013b 0.90 HITL-locked floor against real embeddings;
   324	/// real-embedding validation is deferred to 0.7.1 EMBEDDER-UNDEFER
   325	/// per `dev/plans/prompts/0.7.1-EMBEDDER-UNDEFER-HANDOFF.md`.
   326	#[derive(Clone, Debug)]
   327	struct VaryingEmbedder {
   328	    identity: EmbedderIdentity,
   329	    dim: u32,
   330	}
   331	
   332	impl VaryingEmbedder {
   333	    fn new(dim: u32) -> Self {
   334	        Self { identity: EmbedderIdentity::new("varying", "perf-gates-dense", dim), dim }
   335	    }
   336	
   337	    fn vector_for(&self, text: &str) -> Vector {
   338	        let dim = self.dim as usize;
   339	        // FNV-1a 64-bit on the input — same hash as the prior sparse
   340	        // version, so seed determinism is unchanged.
   341	        let mut h: u64 = 0xcbf29ce484222325;
   342	        for &b in text.as_bytes() {
   343	            h ^= b as u64;
   344	            h = h.wrapping_mul(0x100000001b3);
   345	        }
   346	        // Avoid the all-zero xorshift fixed point for empty input.
   347	        if h == 0 {
   348	            h = 0xdeadbeef_cafebabe;
   349	        }
   350	        let mut state = h;
   351	        let mut v = Vec::with_capacity(dim);
   352	        for _ in 0..dim {
   353	            // xorshift64 — full-period, zero-pole-avoidance above.
   354	            state ^= state << 13;
   355	            state ^= state >> 7;
   356	            state ^= state << 17;
   357	            // Map u64 → [-1, 1) via the i32 cast of the low 32 bits.
   358	            let x = ((state as u32) as i32 as f32) / (i32::MAX as f32 + 1.0);
   359	            v.push(x);
   360	        }
   361	        let norm: f32 = v.iter().map(|x| x * x).sum::<f32>().sqrt().max(1e-6);
   362	        for x in &mut v {
   363	            *x /= norm;
   364	        }
   365	        v
   366	    }
   367	}
   368	
   369	impl Embedder for VaryingEmbedder {
   370	    fn identity(&self) -> EmbedderIdentity {
   371	        self.identity.clone()
   372	    }
   373	
   374	    fn embed(&self, text: &str) -> Result<Vector, EmbedderError> {
   375	        Ok(self.vector_for(text))
   376	    }
   377	}
