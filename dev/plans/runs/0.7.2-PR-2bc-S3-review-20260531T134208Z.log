   379	/// AC-013 deterministic seeder: N vector rows with varying embeddings.
   380	/// Returns elapsed seed time. Bodies double as both FTS5 documents and
   381	/// the input to the embedder, so the same fixture supports AC-019's
   382	/// FTS+vector mixed workload.
   383	fn seed_ac013_corpus(engine: &Engine, n: usize) -> Duration {
   384	    const BATCH: usize = 1024;
   385	    let vocab = perf_vocab();
   386	    let cumulative = zipf_cumulative(vocab.len());
   387	    let mut rng = SeededRng::new(0x0AC0_13D0_13D0);
   388	    engine.configure_vector_kind_for_test("doc").expect("vector kind");
   389	    let started = Instant::now();
   390	    let mut written = 0usize;
   391	    while written < n {
   392	        let take = BATCH.min(n - written);
   393	        let mut batch = Vec::with_capacity(take);
   394	        for _ in 0..take {
   395	            batch.push(PreparedWrite::Node {
   396	                kind: "doc".to_string(),
   397	                body: synth_chunk_body(&mut rng, &vocab, &cumulative),
   398	                source_id: None,
   399	            });
   400	        }
   401	        engine.write(&batch).expect("ac-013 seed write");
   402	        written += take;
