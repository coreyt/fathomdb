   273	/// AC-012 deterministic seeder: 1 chunk body per write batch (4096 nodes
   274	/// per `engine.write()`). Returns elapsed seed time for diagnostics.
   275	fn seed_ac012_corpus(engine: &Engine, n: usize) -> Duration {
   276	    const BATCH: usize = 4096;
   277	    let vocab = perf_vocab();
   278	    let cumulative = zipf_cumulative(vocab.len());
   279	    let mut rng = SeededRng::new(0x0AC0_12C0_12C0);
   280	    let started = Instant::now();
   281	    let mut written = 0usize;
   282	    while written < n {
   283	        let take = BATCH.min(n - written);
   284	        let mut batch = Vec::with_capacity(take);
   285	        for _ in 0..take {
   286	            batch.push(PreparedWrite::Node {
   287	                kind: "doc".to_string(),
   288	                body: synth_chunk_body(&mut rng, &vocab, &cumulative),
   289	                source_id: None,
   290	            });
   291	        }
   292	        engine.write(&batch).expect("ac-012 seed write");
   293	        written += take;
   294	    }
   295	    // No vector kind configured -> projection runtime still drains FTS index.
   296	    engine.drain(600_000).expect("ac-012 drain");
   297	    started.elapsed()
   298	}
