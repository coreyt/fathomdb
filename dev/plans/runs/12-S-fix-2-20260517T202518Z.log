{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PoLmZ1jX7iMUPb3z4K2PZa","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t# Self-test for AC-050a AST no-shim scanner (scripts/security/ast_scan.py).\n3\t# Drives clean + dirty fixtures per language, plus targeted sub-fixtures\n4\t# for the verb-reroute, crate-root, and block-comment rules.\n5\tset -euo pipefail\n6\t\n7\tSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n8\tREPO_ROOT=\"$(cd \"$SCRIPT_DIR/../..\" && pwd)\"\n9\tSCAN=\"$REPO_ROOT/scripts/security/ast_scan.py\"\n10\tFIX=\"$SCRIPT_DIR/fixtures/ast-shim\"\n11\t\n12\tfail() { echo \"FAIL: $*\" >&2; exit 1; }\n13\t\n14\trun_clean() {\n15\t    local lang=\"$1\" path=\"$2\"\n16\t    if ! python3 \"$SCAN\" --language \"$lang\" --path \"$path\" --repo-root \"$REPO_ROOT\" >/dev/null 2>&1; then\n17\t        fail \"$lang clean fixture ($path) must exit 0\"\n18\t    fi\n19\t}\n20\t\n21\trun_dirty() {\n22\t    local lang=\"$1\" path=\"$2\" expect_pattern=\"$3\"\n23\t    local errf\n24\t    errf=$(mktemp)\n25\t    set +e\n26\t    python3 \"$SCAN\" --language \"$lang\" --path \"$path\" --repo-root \"$REPO_ROOT\" >/dev/null 2>\"$errf\"\n27\t    local rc=$?\n28\t    set -e\n29\t    if [ \"$rc\" -ne 1 ]; then\n30\t        cat \"$errf\" >&2\n31\t        rm -f \"$errf\"\n32\t        fail \"$lang dirty fixture ($path) must exit 1, got $rc\"\n33\t    fi\n34\t    if ! grep -qE \"$expect_pattern\" \"$errf\"; then\n35\t        cat \"$errf\" >&2\n36\t        rm -f \"$errf\"\n37\t        fail \"$lang dirty fixture ($path): expected pattern '$expect_pattern' missing\"\n38\t    fi\n39\t    rm -f \"$errf\"\n40\t}\n41\t\n42\t# V05_VERBS must be non-empty — sentinel that the rule is enforced.\n43\tverb_count=$(python3 -c 'import sys; sys.path.insert(0, \"'\"$REPO_ROOT\"'/scripts/security\"); import ast_scan; print(len(ast_scan.V05_VERBS))')\n44\tif [ \"$verb_count\" -lt 1 ]; then\n45\t    fail \"V05_VERBS is empty — verb-reroute rule is unenforced\"\n46\tfi\n47\techo \"OK V05_VERBS populated ($verb_count entries)\"\n48\t\n49\tfor lang in rust python ts; do\n50\t    run_clean \"$lang\" \"$FIX/$lang/clean\"\n51\t    echo \"OK $lang clean\"\n52\t    run_dirty \"$lang\" \"$FIX/$lang/dirty\" \"(legacy_|compat_v0_5|allow\\\\(deprecated\\\\)|verb re-route)\"\n53\t    echo \"OK $lang dirty\"\n54\tdone\n55\t\n56\t# Targeted sub-rules: each fixture lives in its own directory so the\n57\t# scanner's rglob finds exactly one file and the assertion is isolated.\n58\trun_dirty rust \"$FIX/rust/crate-root\" \"rust-crate-root-allow-deprecated\"\n59\techo \"OK rust crate-root rule (lib.rs isolated)\"\n60\t\n61\trun_dirty rust \"$FIX/rust/verb-reroute\" \"rust-05x-verb-reroute\"\n62\techo \"OK rust v05 verb-reroute\"\n63\t\n64\trun_dirty python \"$FIX/python/verb-reroute\" \"python-05x-verb-reroute\"\n65\techo \"OK python v05 verb-reroute\"\n66\t\n67\trun_dirty ts \"$FIX/ts/verb-reroute\" \"ts-05x-verb-reroute\"\n68\techo \"OK ts v05 verb-reroute\"\n69\t\n70\t# Block-comment stripping: banned names inside /* */ must NOT flag\n71\t# (asserted by the rust/clean directory passing — block_comment_safe.rs\n72\t# embeds banned names in /* */, /*! */, and /** */ doc comments).\n73\t# Real code OUTSIDE a block comment in a file that ALSO contains a\n74\t# block comment must still flag.\n75\trun_dirty rust \"$FIX/rust/block-comment-real\" \"(legacy_|rust-public-symbol)\"\n76\techo \"OK rust block-comment does not swallow real code\"\n77\t\n78\techo \"test_ast_scan.sh: all language fixtures pass\"\n79\t"}]},"parent_tool_use_id":null,"session_id":"f65dbf99-f9f1-4790-ba7d-e368b4b1cf58","uuid":"f08a3221-adf4-4a9e-9230-0f683a00cea6","timestamp":"2026-05-17T20:25:25.564Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-S-security-fixtures-20260517T195735Z/scripts/tests/test_ast_scan.sh","content":"#!/usr/bin/env bash\n# Self-test for AC-050a AST no-shim scanner (scripts/security/ast_scan.py).\n# Drives clean + dirty fixtures per language, plus targeted sub-fixtures\n# for the verb-reroute, crate-root, and block-comment rules.\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nREPO_ROOT=\"$(cd \"$SCRIPT_DIR/../..\" && pwd)\"\nSCAN=\"$REPO_ROOT/scripts/security/ast_scan.py\"\nFIX=\"$SCRIPT_DIR/fixtures/ast-shim\"\n\nfail() { echo \"FAIL: $*\" >&2; exit 1; }\n\nrun_clean() {\n    local lang=\"$1\" path=\"$2\"\n    if ! python3 \"$SCAN\" --language \"$lang\" --path \"$path\" --repo-root \"$REPO_ROOT\" >/dev/null 2>&1; then\n        fail \"$lang clean fixture ($path) must exit 0\"\n    fi\n}\n\nrun_dirty() {\n    local lang=\"$1\" path=\"$2\" expect_pattern=\"$3\"\n    local errf\n    errf=$(mktemp)\n    set +e\n    python3 \"$SCAN\" --language \"$lang\" --path \"$path\" --repo-root \"$REPO_ROOT\" >/dev/null 2>\"$errf\"\n    local rc=$?\n    set -e\n    if [ \"$rc\" -ne 1 ]; then\n        cat \"$errf\" >&2\n        rm -f \"$errf\"\n        fail \"$lang dirty fixture ($path) must exit 1, got $rc\"\n    fi\n    if ! grep -qE \"$expect_pattern\" \"$errf\"; then\n        cat \"$errf\" >&2\n        rm -f \"$errf\"\n        fail \"$lang dirty fixture ($path): expected pattern '$expect_pattern' missing\"\n    fi\n    rm -f \"$errf\"\n}\n\n# V05_VERBS must be non-empty — sentinel that the rule is enforced.\nverb_count=$(python3 -c 'import sys; sys.path.insert(0, \"'\"$REPO_ROOT\"'/scripts/security\"); import ast_scan; print(len(ast_scan.V05_VERBS))')\nif [ \"$verb_count\" -lt 1 ]; then\n    fail \"V05_VERBS is empty — verb-reroute rule is unenforced\"\nfi\necho \"OK V05_VERBS populated ($verb_count entries)\"\n\nfor lang in rust python ts; do\n    run_clean \"$lang\" \"$FIX/$lang/clean\"\n    echo \"OK $lang clean\"\n    run_dirty \"$lang\" \"$FIX/$lang/dirty\" \"(legacy_|compat_v0_5|allow\\\\(deprecated\\\\)|verb re-route)\"\n    echo \"OK $lang dirty\"\ndone\n\n# Targeted sub-rules: each fixture lives in its own directory so the\n# scanner's rglob finds exactly one file and the assertion is isolated.\nrun_dirty rust \"$FIX/rust/crate-root\" \"rust-crate-root-allow-deprecated\"\necho \"OK rust crate-root rule (lib.rs isolated)\"\n\nrun_dirty rust \"$FIX/rust/verb-reroute\" \"rust-05x-verb-reroute\"\necho \"OK rust v05 verb-reroute\"\n\nrun_dirty python \"$FIX/python/verb-reroute\" \"python-05x-verb-reroute\"\necho \"OK python v05 verb-reroute\"\n\nrun_dirty ts \"$FIX/ts/verb-reroute\" \"ts-05x-verb-reroute\"\necho \"OK ts v05 verb-reroute\"\n\n# Block-comment stripping: banned names inside /* */ must NOT flag\n# (asserted by the rust/clean directory passing — block_comment_safe.rs\n# embeds banned names in /* */, /*! */, and /** */ doc comments).\n# Real code OUTSIDE a block comment in a file that ALSO contains a\n# block comment must still flag.\nrun_dirty rust \"$FIX/rust/block-comment-real\" \"(legacy_|rust-public-symbol)\"\necho \"OK rust block-comment does not swallow real code\"\n\necho \"test_ast_scan.sh: all language fixtures pass\"\n","numLines":79,"startLine":1,"totalLines":79}}}
