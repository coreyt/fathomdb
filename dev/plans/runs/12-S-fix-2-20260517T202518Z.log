{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X1jWQAVdz7gwq7HTRzN9bH","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\t\"\"\"AC-050a AST no-shim scanner.\n3\t\n4\tScans Rust, Python, and TypeScript source trees for banned shim\n5\tpatterns that would let 0.5.x compatibility code linger past the\n6\t0.6.0 rewrite cutover. Banned patterns:\n7\t\n8\t  * Module / file names matching ``legacy_*`` or ``compat_v0_5*``.\n9\t  * Symbol declarations (fn/class/struct/etc.) with those prefixes.\n10\t  * Crate-root ``#![allow(deprecated)]`` (Rust ``lib.rs`` / ``main.rs``).\n11\t  * Re-route stubs from a configured set of 0.5.x verb names\n12\t    (empty by default — no-op until the verb list lands).\n13\t\n14\tThe Python surface is parsed with the stdlib ``ast`` module. Rust\n15\tand TypeScript surfaces are tokenized with grammar-scoped regex\n16\t(line-anchored, comment-aware where it matters). Full ``syn`` /\n17\t``ts-morph`` integration is filed as a follow-up; the patterns this\n18\tscanner hunts are textual and bounded.\n19\t\"\"\"\n20\t\n21\tfrom __future__ import annotations\n22\t\n23\timport argparse\n24\timport ast\n25\timport re\n26\timport sys\n27\tfrom dataclasses import dataclass\n28\tfrom pathlib import Path\n29\t\n30\t\n31\t# 0.5.x verb names whose re-route stubs are banned at the public API\n32\t# surface. Inventoried from pre-0.6.0 source (`git show 39ee271^:`):\n33\t# python/fathomdb/_engine.py + _admin.py, plus the TS facade. A name\n34\t# belongs here only if the 0.5.x verb has NO 0.6.0 equivalent (or\n35\t# its 0.6.0 name differs). Verbs whose name is unchanged across the\n36\t# rewrite (open/close/write/search/drain/configure/counters/...) are\n37\t# intentionally excluded — they ARE the 0.6.0 surface. Removed verbs\n38\t# kept in 0.6.0 under the same name (check_integrity/safe_export/\n39\t# excise_source) are also excluded.\n40\t#\n41\t# Why: the verb-reroute rule (AC-050a) catches `pub fn <old>() { new() }`\n42\t# shims that would re-introduce 0.5.x compatibility surface. An empty\n43\t# list silently disables the rule.\n44\tV05_VERBS: tuple[str, ...] = (\n45\t    # Engine surface removed/redesigned in 0.6.0\n46\t    \"submit\",\n47\t    \"touch_last_accessed\",\n48\t    \"fallback_search\",\n49\t    \"telemetry_snapshot\",\n50\t    # AdminClient surface collapsed into `admin.configure(name, body)`\n51\t    \"check_semantics\",\n52\t    \"rebuild\",\n53\t    \"rebuild_missing\",\n54\t    \"restore_vector_profiles\",\n55\t    \"regenerate_vector_embeddings\",\n56\t    \"restore_logical_id\",\n57\t    \"purge_logical_id\",\n58\t    \"configure_fts\",\n59\t    \"configure_vec\",\n60\t    \"configure_vec_kinds\",\n61\t    \"configure_embedding\",\n62\t    \"capabilities\",\n63\t    \"current_config\",\n64\t    \"describe_kind\",\n65\t    \"drain_vector_projection\",\n66\t    \"preview_projection_impact\",\n67\t    \"get_fts_profile\",\n68\t    \"get_vec_profile\",\n69\t    \"register_fts_property_schema\",\n70\t    \"describe_fts_property_schema\",\n71\t    \"list_fts_property_schemas\",\n72\t    \"remove_fts_property_schema\",\n73\t    \"get_rebuild_progress\",\n74\t    \"register_operational_collection\",\n75\t    \"describe_operational_collection\",\n76\t    \"trace_operational_collection\",\n77\t    \"read_operational_collection\",\n78\t    \"rebuild_operational_current\",\n79\t)\n80\t\n81\tFORBIDDEN_PREFIX = re.compile(r\"^(legacy_|compat_v0_5)\")\n82\t\n83\tPATH_EXCLUDES = (\n84\t    \"node_modules\",\n85\t    \"target\",\n86\t    \".venv\",\n87\t    \"dist\",\n88\t    \"build\",\n89\t    \"__pycache__\",\n90\t)\n91\t\n92\t\n93\t@dataclass(frozen=True)\n94\tclass Finding:\n95\t    path: Path\n96\t    line: int\n97\t    rule: str\n98\t    detail: str\n99\t\n100\t    def render(self, root: Path) -> str:"}]},"parent_tool_use_id":null,"session_id":"f65dbf99-f9f1-4790-ba7d-e368b4b1cf58","uuid":"c97329a6-4219-49c8-87d4-ded961ba4825","timestamp":"2026-05-17T20:25:48.858Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-S-security-fixtures-20260517T195735Z/scripts/security/ast_scan.py","content":"#!/usr/bin/env python3\n\"\"\"AC-050a AST no-shim scanner.\n\nScans Rust, Python, and TypeScript source trees for banned shim\npatterns that would let 0.5.x compatibility code linger past the\n0.6.0 rewrite cutover. Banned patterns:\n\n  * Module / file names matching ``legacy_*`` or ``compat_v0_5*``.\n  * Symbol declarations (fn/class/struct/etc.) with those prefixes.\n  * Crate-root ``#![allow(deprecated)]`` (Rust ``lib.rs`` / ``main.rs``).\n  * Re-route stubs from a configured set of 0.5.x verb names\n    (empty by default — no-op until the verb list lands).\n\nThe Python surface is parsed with the stdlib ``ast`` module. Rust\nand TypeScript surfaces are tokenized with grammar-scoped regex\n(line-anchored, comment-aware where it matters). Full ``syn`` /\n``ts-morph`` integration is filed as a follow-up; the patterns this\nscanner hunts are textual and bounded.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport ast\nimport re\nimport sys\nfrom dataclasses import dataclass\nfrom pathlib import Path\n\n\n# 0.5.x verb names whose re-route stubs are banned at the public API\n# surface. Inventoried from pre-0.6.0 source (`git show 39ee271^:`):\n# python/fathomdb/_engine.py + _admin.py, plus the TS facade. A name\n# belongs here only if the 0.5.x verb has NO 0.6.0 equivalent (or\n# its 0.6.0 name differs). Verbs whose name is unchanged across the\n# rewrite (open/close/write/search/drain/configure/counters/...) are\n# intentionally excluded — they ARE the 0.6.0 surface. Removed verbs\n# kept in 0.6.0 under the same name (check_integrity/safe_export/\n# excise_source) are also excluded.\n#\n# Why: the verb-reroute rule (AC-050a) catches `pub fn <old>() { new() }`\n# shims that would re-introduce 0.5.x compatibility surface. An empty\n# list silently disables the rule.\nV05_VERBS: tuple[str, ...] = (\n    # Engine surface removed/redesigned in 0.6.0\n    \"submit\",\n    \"touch_last_accessed\",\n    \"fallback_search\",\n    \"telemetry_snapshot\",\n    # AdminClient surface collapsed into `admin.configure(name, body)`\n    \"check_semantics\",\n    \"rebuild\",\n    \"rebuild_missing\",\n    \"restore_vector_profiles\",\n    \"regenerate_vector_embeddings\",\n    \"restore_logical_id\",\n    \"purge_logical_id\",\n    \"configure_fts\",\n    \"configure_vec\",\n    \"configure_vec_kinds\",\n    \"configure_embedding\",\n    \"capabilities\",\n    \"current_config\",\n    \"describe_kind\",\n    \"drain_vector_projection\",\n    \"preview_projection_impact\",\n    \"get_fts_profile\",\n    \"get_vec_profile\",\n    \"register_fts_property_schema\",\n    \"describe_fts_property_schema\",\n    \"list_fts_property_schemas\",\n    \"remove_fts_property_schema\",\n    \"get_rebuild_progress\",\n    \"register_operational_collection\",\n    \"describe_operational_collection\",\n    \"trace_operational_collection\",\n    \"read_operational_collection\",\n    \"rebuild_operational_current\",\n)\n\nFORBIDDEN_PREFIX = re.compile(r\"^(legacy_|compat_v0_5)\")\n\nPATH_EXCLUDES = (\n    \"node_modules\",\n    \"target\",\n    \".venv\",\n    \"dist\",\n    \"build\",\n    \"__pycache__\",\n)\n\n\n@dataclass(frozen=True)\nclass Finding:\n    path: Path\n    line: int\n    rule: str\n    detail: str\n\n    def render(self, root: Path) -> str:","numLines":100,"startLine":1,"totalLines":323}}}
