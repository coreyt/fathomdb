{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RVDkt7XU1oMCgaiTnQjJyt","type":"tool_result","content":"1\t// Exception-hierarchy assertions for the TypeScript SDK.\n2\t//\n3\t// Per `dev/design/errors.md` § Binding-facing class matrix and\n4\t// `dev/design/bindings.md` § 3, every leaf class extends FathomDbError so\n5\t// callers can `instanceof` narrow per variant or catch the catch-all base.\n6\t\n7\timport test from \"node:test\";\n8\timport assert from \"node:assert/strict\";\n9\t\n10\timport { Engine } from \"../src/index.js\";\n11\timport {\n12\t  ClosingError,\n13\t  CorruptionError,\n14\t  DatabaseLockedError,\n15\t  EmbedderDimensionMismatchError,\n16\t  EmbedderError,\n17\t  EmbedderIdentityMismatchError,\n18\t  EmbedderNotConfiguredError,\n19\t  FathomDbError,\n20\t  IncompatibleSchemaVersionError,\n21\t  KindNotVectorIndexedError,\n22\t  MigrationError,\n23\t  OpStoreError,\n24\t  OverloadedError,\n25\t  ProjectionError,\n26\t  SchedulerError,\n27\t  SchemaValidationError,\n28\t  StorageError,\n29\t  VectorError,\n30\t  WriteValidationError,\n31\t} from \"../src/errors.js\";\n32\timport { freshDbPath } from \"./helpers.js\";\n33\t\n34\tconst LEAF_CLASSES = [\n35\t  StorageError,\n36\t  ProjectionError,\n37\t  VectorError,\n38\t  EmbedderError,\n39\t  SchedulerError,\n40\t  OpStoreError,\n41\t  WriteValidationError,\n42\t  SchemaValidationError,\n43\t  OverloadedError,\n44\t  ClosingError,\n45\t  DatabaseLockedError,\n46\t  CorruptionError,\n47\t  IncompatibleSchemaVersionError,\n48\t  MigrationError,\n49\t  EmbedderIdentityMismatchError,\n50\t  EmbedderDimensionMismatchError,\n51\t  EmbedderNotConfiguredError,\n52\t  KindNotVectorIndexedError,\n53\t] as const;\n54\t\n55\ttest(\"every leaf class extends FathomDbError\", () => {\n56\t  for (const Cls of LEAF_CLASSES) {\n57\t    const instance = Object.create(Cls.prototype) as object;\n58\t    assert.ok(instance instanceof FathomDbError, `${Cls.name} must extend FathomDbError`);\n59\t    assert.notEqual(Cls, FathomDbError);\n60\t  }\n61\t});\n62\t\n63\ttest(\"EmbedderNotConfiguredError sits under EmbedderError under FathomDbError\", () => {\n64\t  const err = Object.create(EmbedderNotConfiguredError.prototype) as object;\n65\t  assert.ok(err instanceof EmbedderNotConfiguredError);\n66\t  assert.ok(err instanceof EmbedderError);\n67\t  assert.ok(err instanceof FathomDbError);\n68\t  assert.notEqual(EmbedderNotConfiguredError, EmbedderError);\n69\t});\n70\t\n71\ttest(\"KindNotVectorIndexedError sits under VectorError under FathomDbError\", () => {\n72\t  const err = Object.create(KindNotVectorIndexedError.prototype) as object;\n73\t  assert.ok(err instanceof KindNotVectorIndexedError);\n74\t  assert.ok(err instanceof VectorError);\n75\t  assert.ok(err instanceof FathomDbError);\n76\t  assert.notEqual(KindNotVectorIndexedError, VectorError);\n77\t});\n78\t\n79\ttest(\"CorruptionError carries typed recovery hint payload\", () => {\n80\t  const err = new CorruptionError({\n81\t    kind: \"HeaderMalformed\",\n82\t    stage: \"HeaderProbe\",\n83\t    recoveryHintCode: \"E_CORRUPT_HEADER\",\n84\t    docAnchor: \"design/recovery.md#header-malformed\",\n85\t  });\n86\t  assert.ok(err instanceof FathomDbError);\n87\t  assert.equal(err.kind, \"HeaderMalformed\");\n88\t  assert.equal(err.stage, \"HeaderProbe\");\n89\t  assert.equal(err.recoveryHintCode, \"E_CORRUPT_HEADER\");\n90\t  assert.equal(err.docAnchor, \"design/recovery.md#header-malformed\");\n91\t});\n92\t\n93\ttest(\"DatabaseLockedError carries typed holderPid\", () => {\n94\t  const err = new DatabaseLockedError({ holderPid: 12345 });\n95\t  assert.equal(err.holderPid, 12345);\n96\t});\n97\t\n98\ttest(\"EmbedderIdentityMismatchError carries typed identity attrs\", () => {\n99\t  const err = new EmbedderIdentityMismatchError({\n100\t    storedName: \"model-a\",\n101\t    storedRevision: \"0\",\n102\t    suppliedName: \"model-b\",\n103\t    suppliedRevision: \"1\",\n104\t  });\n105\t  assert.equal(err.storedName, \"model-a\");\n106\t  assert.equal(err.suppliedName, \"model-b\");\n107\t});\n108\t\n109\ttest(\"EmbedderDimensionMismatchError carries typed dimensions\", () => {\n110\t  const err = new EmbedderDimensionMismatchError({ stored: 384, supplied: 768 });\n111\t  assert.equal(err.stored, 384);\n112\t  assert.equal(err.supplied, 768);\n113\t});\n114\t\n115\ttest(\"search rejects empty query via WriteValidationError under FathomDbError root\", async () => {\n116\t  // Per dev/design/errors.md section Binding-facing class matrix, the\n117\t  // empty-query rejection must surface as the typed WriteValidationError\n118\t  // leaf beneath the single-rooted FathomDbError, not as a bare Error.\n119\t  const engine = await Engine.open(freshDbPath());\n120\t  try {\n121\t    await assert.rejects(\n122\t      () => engine.search(\"\"),\n123\t      (err: unknown) => {\n124\t        assert.ok(err instanceof FathomDbError, \"must be a FathomDbError\");\n125\t        assert.ok(err instanceof WriteValidationError, \"must be a WriteValidationError\");\n126\t        return true;\n127\t      },\n128\t    );\n129\t  } finally {\n130\t    await engine.close();\n131\t  }\n132\t});\n133\t"}]},"parent_tool_use_id":null,"session_id":"e03e003f-16a4-48ce-9857-522e8e7e136e","uuid":"eb544c92-ebd5-40ef-b87c-3c4dede59fa4","timestamp":"2026-05-17T20:45:23.541Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-TX-ts-python-parity-20260517T204414Z/src/ts/tests/errors.test.ts","content":"// Exception-hierarchy assertions for the TypeScript SDK.\n//\n// Per `dev/design/errors.md` § Binding-facing class matrix and\n// `dev/design/bindings.md` § 3, every leaf class extends FathomDbError so\n// callers can `instanceof` narrow per variant or catch the catch-all base.\n\nimport test from \"node:test\";\nimport assert from \"node:assert/strict\";\n\nimport { Engine } from \"../src/index.js\";\nimport {\n  ClosingError,\n  CorruptionError,\n  DatabaseLockedError,\n  EmbedderDimensionMismatchError,\n  EmbedderError,\n  EmbedderIdentityMismatchError,\n  EmbedderNotConfiguredError,\n  FathomDbError,\n  IncompatibleSchemaVersionError,\n  KindNotVectorIndexedError,\n  MigrationError,\n  OpStoreError,\n  OverloadedError,\n  ProjectionError,\n  SchedulerError,\n  SchemaValidationError,\n  StorageError,\n  VectorError,\n  WriteValidationError,\n} from \"../src/errors.js\";\nimport { freshDbPath } from \"./helpers.js\";\n\nconst LEAF_CLASSES = [\n  StorageError,\n  ProjectionError,\n  VectorError,\n  EmbedderError,\n  SchedulerError,\n  OpStoreError,\n  WriteValidationError,\n  SchemaValidationError,\n  OverloadedError,\n  ClosingError,\n  DatabaseLockedError,\n  CorruptionError,\n  IncompatibleSchemaVersionError,\n  MigrationError,\n  EmbedderIdentityMismatchError,\n  EmbedderDimensionMismatchError,\n  EmbedderNotConfiguredError,\n  KindNotVectorIndexedError,\n] as const;\n\ntest(\"every leaf class extends FathomDbError\", () => {\n  for (const Cls of LEAF_CLASSES) {\n    const instance = Object.create(Cls.prototype) as object;\n    assert.ok(instance instanceof FathomDbError, `${Cls.name} must extend FathomDbError`);\n    assert.notEqual(Cls, FathomDbError);\n  }\n});\n\ntest(\"EmbedderNotConfiguredError sits under EmbedderError under FathomDbError\", () => {\n  const err = Object.create(EmbedderNotConfiguredError.prototype) as object;\n  assert.ok(err instanceof EmbedderNotConfiguredError);\n  assert.ok(err instanceof EmbedderError);\n  assert.ok(err instanceof FathomDbError);\n  assert.notEqual(EmbedderNotConfiguredError, EmbedderError);\n});\n\ntest(\"KindNotVectorIndexedError sits under VectorError under FathomDbError\", () => {\n  const err = Object.create(KindNotVectorIndexedError.prototype) as object;\n  assert.ok(err instanceof KindNotVectorIndexedError);\n  assert.ok(err instanceof VectorError);\n  assert.ok(err instanceof FathomDbError);\n  assert.notEqual(KindNotVectorIndexedError, VectorError);\n});\n\ntest(\"CorruptionError carries typed recovery hint payload\", () => {\n  const err = new CorruptionError({\n    kind: \"HeaderMalformed\",\n    stage: \"HeaderProbe\",\n    recoveryHintCode: \"E_CORRUPT_HEADER\",\n    docAnchor: \"design/recovery.md#header-malformed\",\n  });\n  assert.ok(err instanceof FathomDbError);\n  assert.equal(err.kind, \"HeaderMalformed\");\n  assert.equal(err.stage, \"HeaderProbe\");\n  assert.equal(err.recoveryHintCode, \"E_CORRUPT_HEADER\");\n  assert.equal(err.docAnchor, \"design/recovery.md#header-malformed\");\n});\n\ntest(\"DatabaseLockedError carries typed holderPid\", () => {\n  const err = new DatabaseLockedError({ holderPid: 12345 });\n  assert.equal(err.holderPid, 12345);\n});\n\ntest(\"EmbedderIdentityMismatchError carries typed identity attrs\", () => {\n  const err = new EmbedderIdentityMismatchError({\n    storedName: \"model-a\",\n    storedRevision: \"0\",\n    suppliedName: \"model-b\",\n    suppliedRevision: \"1\",\n  });\n  assert.equal(err.storedName, \"model-a\");\n  assert.equal(err.suppliedName, \"model-b\");\n});\n\ntest(\"EmbedderDimensionMismatchError carries typed dimensions\", () => {\n  const err = new EmbedderDimensionMismatchError({ stored: 384, supplied: 768 });\n  assert.equal(err.stored, 384);\n  assert.equal(err.supplied, 768);\n});\n\ntest(\"search rejects empty query via WriteValidationError under FathomDbError root\", async () => {\n  // Per dev/design/errors.md section Binding-facing class matrix, the\n  // empty-query rejection must surface as the typed WriteValidationError\n  // leaf beneath the single-rooted FathomDbError, not as a bare Error.\n  const engine = await Engine.open(freshDbPath());\n  try {\n    await assert.rejects(\n      () => engine.search(\"\"),\n      (err: unknown) => {\n        assert.ok(err instanceof FathomDbError, \"must be a FathomDbError\");\n        assert.ok(err instanceof WriteValidationError, \"must be a WriteValidationError\");\n        return true;\n      },\n    );\n  } finally {\n    await engine.close();\n  }\n});\n","numLines":133,"startLine":1,"totalLines":133}}}
