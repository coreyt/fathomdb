{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Dgy8joofhjppsU9axptQX4","type":"tool_result","content":"1\t\"\"\"Admin namespace exposing the `configure` verb beside `Engine`.\n2\t\n3\tPer `dev/interfaces/python.md` § Runtime surface, `admin.configure` is the\n4\tfifth canonical SDK verb. The native binding (`fathomdb._fathomdb`)\n5\tperforms the writer-thread wiring; this module exposes the typed\n6\tPython signature and converts the native receipt to the public\n7\t`WriteReceipt` dataclass.\n8\t\"\"\"\n9\t\n10\tfrom __future__ import annotations\n11\t\n12\tfrom typing import TYPE_CHECKING\n13\t\n14\tfrom fathomdb._fathomdb import admin_configure as _native_configure\n15\tfrom fathomdb.types import WriteReceipt\n16\t\n17\tif TYPE_CHECKING:\n18\t    from fathomdb.engine import Engine\n19\t\n20\t\n21\tdef configure(engine: \"Engine\", *, name: str, body: str) -> WriteReceipt:\n22\t    \"\"\"Submit an admin schema configuration.\"\"\"\n23\t\n24\t    if not name:\n25\t        raise ValueError(\"admin.configure requires a non-empty name\")\n26\t    if body is None:\n27\t        raise ValueError(\"admin.configure requires a body\")\n28\t    receipt = _native_configure(engine._native, name, body)\n29\t    return WriteReceipt(cursor=receipt.cursor)\n30\t\n31\t\n32\t__all__ = [\"configure\"]\n33\t"}]},"parent_tool_use_id":null,"session_id":"e03e003f-16a4-48ce-9857-522e8e7e136e","uuid":"6bad62a1-aa4d-434d-a83b-e612edbac490","timestamp":"2026-05-17T20:44:53.059Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-TX-ts-python-parity-20260517T204414Z/src/python/fathomdb/admin.py","content":"\"\"\"Admin namespace exposing the `configure` verb beside `Engine`.\n\nPer `dev/interfaces/python.md` § Runtime surface, `admin.configure` is the\nfifth canonical SDK verb. The native binding (`fathomdb._fathomdb`)\nperforms the writer-thread wiring; this module exposes the typed\nPython signature and converts the native receipt to the public\n`WriteReceipt` dataclass.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom typing import TYPE_CHECKING\n\nfrom fathomdb._fathomdb import admin_configure as _native_configure\nfrom fathomdb.types import WriteReceipt\n\nif TYPE_CHECKING:\n    from fathomdb.engine import Engine\n\n\ndef configure(engine: \"Engine\", *, name: str, body: str) -> WriteReceipt:\n    \"\"\"Submit an admin schema configuration.\"\"\"\n\n    if not name:\n        raise ValueError(\"admin.configure requires a non-empty name\")\n    if body is None:\n        raise ValueError(\"admin.configure requires a body\")\n    receipt = _native_configure(engine._native, name, body)\n    return WriteReceipt(cursor=receipt.cursor)\n\n\n__all__ = [\"configure\"]\n","numLines":33,"startLine":1,"totalLines":33}}}
