{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019nRbs6bLi7Mp3Z4nub6ZuK","type":"tool_result","content":"1\t\"\"\"Public surface assertions for the Python SDK.\n2\t\n3\tBinds AC-057a (REQ-053): five-verb runtime SDK surface.\n4\t\n5\tPins the five-verb top-level surface, the engine-attached instrumentation\n6\tmethods, the keyword vs EngineConfig forms of `Engine.open`, and the\n7\tsoft-fallback record shape per `dev/interfaces/python.md` and\n8\t`dev/design/bindings.md` § 3.\n9\t\"\"\"\n10\t\n11\tfrom __future__ import annotations\n12\t\n13\timport inspect\n14\t\n15\timport fathomdb\n16\tfrom fathomdb import Engine, EngineConfig, SearchResult, SoftFallback, WriteReceipt, admin\n17\t\n18\t\n19\tdef test_top_level_exports_match_canonical_set() -> None:\n20\t    expected = {\n21\t        \"Engine\",\n22\t        \"EngineConfig\",\n23\t        \"SearchResult\",\n24\t        \"SoftFallback\",\n25\t        \"WriteReceipt\",\n26\t        \"admin\",\n27\t        \"errors\",\n28\t    }\n29\t    assert expected.issubset(set(fathomdb.__all__))\n30\t\n31\t\n32\tdef test_admin_is_module_level_namespace() -> None:\n33\t    assert inspect.ismodule(admin)\n34\t    assert hasattr(admin, \"configure\")\n35\t\n36\t\n37\tdef test_engine_exposes_five_verbs_plus_instrumentation() -> None:\n38\t    for verb in (\"open\", \"write\", \"search\", \"close\"):\n39\t        assert hasattr(Engine, verb), f\"Engine must expose {verb}\"\n40\t\n41\t    for instr in (\n42\t        \"drain\",\n43\t        \"counters\",\n44\t        \"set_profiling\",\n45\t        \"set_slow_threshold_ms\",\n46\t        \"attach_logging_subscriber\",\n47\t    ):\n48\t        assert hasattr(Engine, instr), f\"Engine must expose {instr}\"\n49\t\n50\t\n51\tdef test_engine_open_accepts_kwargs_and_engine_config(tmp_path) -> None:\n52\t    a = Engine.open(\n53\t        str(tmp_path / \"a.sqlite\"),\n54\t        embedder_pool_size=2,\n55\t        scheduler_runtime_threads=4,\n56\t        provenance_row_cap=1024,\n57\t        embedder_call_timeout_ms=30_000,\n58\t        slow_threshold_ms=250,\n59\t    )\n60\t    cfg = EngineConfig(\n61\t        embedder_pool_size=2,\n62\t        scheduler_runtime_threads=4,\n63\t        provenance_row_cap=1024,\n64\t        embedder_call_timeout_ms=30_000,\n65\t        slow_threshold_ms=250,\n66\t    )\n67\t    b = Engine.open(str(tmp_path / \"b.sqlite\"), config=cfg)\n68\t\n69\t    assert a.config == b.config\n70\t    a.close()\n71\t    b.close()\n72\t\n73\t\n74\tdef test_engine_open_rejects_kwargs_and_config_together(db_path: str) -> None:\n75\t    cfg = EngineConfig()\n76\t    try:\n77\t        Engine.open(db_path, config=cfg, embedder_pool_size=2)\n78\t    except ValueError:\n79\t        return\n80\t    raise AssertionError(\"Engine.open must reject config + kwargs in the same call\")\n81\t\n82\t\n83\tdef test_write_receipt_carries_cursor(db_path: str) -> None:\n84\t    engine = Engine.open(db_path)\n85\t    try:\n86\t        receipt = engine.write([{\"kind\": \"doc\", \"body\": \"{}\"}])\n87\t        assert isinstance(receipt, WriteReceipt)\n88\t        assert isinstance(receipt.cursor, int)\n89\t    finally:\n90\t        engine.close()\n91\t\n92\t\n93\tdef test_search_result_carries_optional_soft_fallback(db_path: str) -> None:\n94\t    engine = Engine.open(db_path)\n95\t    try:\n96\t        result = engine.search(\"hello\")\n97\t        assert isinstance(result, SearchResult)\n98\t        assert isinstance(result.projection_cursor, int)\n99\t        assert result.soft_fallback is None\n100\t    finally:\n101\t        engine.close()\n102\t\n103\t\n104\tdef test_soft_fallback_branch_is_typed() -> None:\n105\t    f = SoftFallback(branch=\"vector\")\n106\t    assert f.branch == \"vector\"\n107\t    f = SoftFallback(branch=\"text\")\n108\t    assert f.branch == \"text\"\n109\t\n110\t\n111\tdef test_admin_configure_returns_write_receipt_shape(db_path: str) -> None:\n112\t    engine = Engine.open(db_path)\n113\t    try:\n114\t        receipt = admin.configure(engine, name=\"default\", body=\"{}\")\n115\t        assert isinstance(receipt, WriteReceipt)\n116\t        assert isinstance(receipt.cursor, int)\n117\t    finally:\n118\t        engine.close()\n119\t\n120\t\n121\tdef test_engine_attached_stub_methods_return_canonical_types(db_path: str) -> None:\n122\t    engine = Engine.open(db_path)\n123\t    try:\n124\t        engine.drain(timeout_s=0)\n125\t        snapshot = engine.counters()\n126\t        assert snapshot is not None\n127\t\n128\t        engine.set_profiling(enabled=True)\n129\t        engine.set_slow_threshold_ms(value=100)\n130\t\n131\t        import logging\n132\t\n133\t        engine.attach_logging_subscriber(logging.getLogger(\"fathomdb-test\"))\n134\t    finally:\n135\t        engine.close()\n136\t"}]},"parent_tool_use_id":null,"session_id":"e03e003f-16a4-48ce-9857-522e8e7e136e","uuid":"6b8ae809-2141-4bb1-9e87-efc678b2a57f","timestamp":"2026-05-17T20:45:16.313Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-TX-ts-python-parity-20260517T204414Z/src/python/tests/test_surface.py","content":"\"\"\"Public surface assertions for the Python SDK.\n\nBinds AC-057a (REQ-053): five-verb runtime SDK surface.\n\nPins the five-verb top-level surface, the engine-attached instrumentation\nmethods, the keyword vs EngineConfig forms of `Engine.open`, and the\nsoft-fallback record shape per `dev/interfaces/python.md` and\n`dev/design/bindings.md` § 3.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport inspect\n\nimport fathomdb\nfrom fathomdb import Engine, EngineConfig, SearchResult, SoftFallback, WriteReceipt, admin\n\n\ndef test_top_level_exports_match_canonical_set() -> None:\n    expected = {\n        \"Engine\",\n        \"EngineConfig\",\n        \"SearchResult\",\n        \"SoftFallback\",\n        \"WriteReceipt\",\n        \"admin\",\n        \"errors\",\n    }\n    assert expected.issubset(set(fathomdb.__all__))\n\n\ndef test_admin_is_module_level_namespace() -> None:\n    assert inspect.ismodule(admin)\n    assert hasattr(admin, \"configure\")\n\n\ndef test_engine_exposes_five_verbs_plus_instrumentation() -> None:\n    for verb in (\"open\", \"write\", \"search\", \"close\"):\n        assert hasattr(Engine, verb), f\"Engine must expose {verb}\"\n\n    for instr in (\n        \"drain\",\n        \"counters\",\n        \"set_profiling\",\n        \"set_slow_threshold_ms\",\n        \"attach_logging_subscriber\",\n    ):\n        assert hasattr(Engine, instr), f\"Engine must expose {instr}\"\n\n\ndef test_engine_open_accepts_kwargs_and_engine_config(tmp_path) -> None:\n    a = Engine.open(\n        str(tmp_path / \"a.sqlite\"),\n        embedder_pool_size=2,\n        scheduler_runtime_threads=4,\n        provenance_row_cap=1024,\n        embedder_call_timeout_ms=30_000,\n        slow_threshold_ms=250,\n    )\n    cfg = EngineConfig(\n        embedder_pool_size=2,\n        scheduler_runtime_threads=4,\n        provenance_row_cap=1024,\n        embedder_call_timeout_ms=30_000,\n        slow_threshold_ms=250,\n    )\n    b = Engine.open(str(tmp_path / \"b.sqlite\"), config=cfg)\n\n    assert a.config == b.config\n    a.close()\n    b.close()\n\n\ndef test_engine_open_rejects_kwargs_and_config_together(db_path: str) -> None:\n    cfg = EngineConfig()\n    try:\n        Engine.open(db_path, config=cfg, embedder_pool_size=2)\n    except ValueError:\n        return\n    raise AssertionError(\"Engine.open must reject config + kwargs in the same call\")\n\n\ndef test_write_receipt_carries_cursor(db_path: str) -> None:\n    engine = Engine.open(db_path)\n    try:\n        receipt = engine.write([{\"kind\": \"doc\", \"body\": \"{}\"}])\n        assert isinstance(receipt, WriteReceipt)\n        assert isinstance(receipt.cursor, int)\n    finally:\n        engine.close()\n\n\ndef test_search_result_carries_optional_soft_fallback(db_path: str) -> None:\n    engine = Engine.open(db_path)\n    try:\n        result = engine.search(\"hello\")\n        assert isinstance(result, SearchResult)\n        assert isinstance(result.projection_cursor, int)\n        assert result.soft_fallback is None\n    finally:\n        engine.close()\n\n\ndef test_soft_fallback_branch_is_typed() -> None:\n    f = SoftFallback(branch=\"vector\")\n    assert f.branch == \"vector\"\n    f = SoftFallback(branch=\"text\")\n    assert f.branch == \"text\"\n\n\ndef test_admin_configure_returns_write_receipt_shape(db_path: str) -> None:\n    engine = Engine.open(db_path)\n    try:\n        receipt = admin.configure(engine, name=\"default\", body=\"{}\")\n        assert isinstance(receipt, WriteReceipt)\n        assert isinstance(receipt.cursor, int)\n    finally:\n        engine.close()\n\n\ndef test_engine_attached_stub_methods_return_canonical_types(db_path: str) -> None:\n    engine = Engine.open(db_path)\n    try:\n        engine.drain(timeout_s=0)\n        snapshot = engine.counters()\n        assert snapshot is not None\n\n        engine.set_profiling(enabled=True)\n        engine.set_slow_threshold_ms(value=100)\n\n        import logging\n\n        engine.attach_logging_subscriber(logging.getLogger(\"fathomdb-test\"))\n    finally:\n        engine.close()\n","numLines":136,"startLine":1,"totalLines":136}}}
