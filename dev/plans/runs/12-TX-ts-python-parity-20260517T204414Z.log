{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HQsKCojE7HCvKUFwDJFF1K","type":"tool_result","content":"1\t// Native-binding loader. Locates the platform-tagged `.node` artifact\n2\t// produced by `napi build` and re-exports it as a typed module.\n3\t\n4\timport { existsSync } from \"node:fs\";\n5\timport { createRequire } from \"node:module\";\n6\timport { dirname, join } from \"node:path\";\n7\timport { fileURLToPath } from \"node:url\";\n8\t\n9\tconst require = createRequire(import.meta.url);\n10\tconst here = dirname(fileURLToPath(import.meta.url));\n11\t\n12\t// `napi build` writes `<name>.<triple>.node` next to the package.json\n13\t// (cwd of the build script). Walk up from this file's compiled location\n14\t// to find candidates.\n15\tconst SEARCH_ROOTS = [\n16\t  join(here, \"..\"), // dist/src/ -> dist/\n17\t  join(here, \"..\", \"..\"), // dist/src/ -> dist/.. (pkg root)\n18\t  here, // co-located fallback\n19\t];\n20\t\n21\tconst TRIPLES = [\n22\t  \"linux-x64-gnu\",\n23\t  \"linux-x64-musl\",\n24\t  \"linux-arm64-gnu\",\n25\t  \"linux-arm64-musl\",\n26\t  \"linux-arm-gnueabihf\",\n27\t  \"darwin-x64\",\n28\t  \"darwin-arm64\",\n29\t  \"darwin-universal\",\n30\t  \"win32-x64-msvc\",\n31\t  \"win32-ia32-msvc\",\n32\t  \"win32-arm64-msvc\",\n33\t  \"freebsd-x64\",\n34\t  \"android-arm64\",\n35\t  \"android-arm-eabi\",\n36\t];\n37\t\n38\tfunction loadNative(): unknown {\n39\t  for (const root of SEARCH_ROOTS) {\n40\t    for (const triple of TRIPLES) {\n41\t      const candidate = join(root, `fathomdb.${triple}.node`);\n42\t      if (existsSync(candidate)) {\n43\t        return require(candidate);\n44\t      }\n45\t    }\n46\t  }\n47\t  throw new Error(\n48\t    \"fathomdb native binding not found. Run `npm run build` to compile it.\",\n49\t  );\n50\t}\n51\t\n52\tinterface NativeWriteReceipt {\n53\t  cursor: number;\n54\t}\n55\t\n56\tinterface NativeSoftFallback {\n57\t  branch: string;\n58\t}\n59\t\n60\tinterface NativeSearchResult {\n61\t  projectionCursor: number;\n62\t  softFallback: NativeSoftFallback | null;\n63\t  results: string[];\n64\t}\n65\t\n66\tinterface NativeCounterSnapshot {\n67\t  queries: number;\n68\t  writes: number;\n69\t  writeRows: number;\n70\t  adminOps: number;\n71\t  cacheHit: number;\n72\t  cacheMiss: number;\n73\t}\n74\t\n75\tinterface NativeAttachSubscriberOptions {\n76\t  heartbeatIntervalMs?: number;\n77\t}\n78\t\n79\tinterface NativeEngineConfig {\n80\t  embedderPoolSize?: number;\n81\t  schedulerRuntimeThreads?: number;\n82\t  provenanceRowCap?: number;\n83\t  embedderCallTimeoutMs?: number;\n84\t  slowThresholdMs?: number;\n85\t}\n86\t\n87\tinterface NativeEngineOpenOptions {\n88\t  engineConfig?: NativeEngineConfig;\n89\t}\n90\t\n91\tinterface NativeAdminConfigureOptions {\n92\t  name: string;\n93\t  body: string;\n94\t}\n95\t\n96\texport interface NativeEngine {\n97\t  write(batch: unknown[]): Promise<NativeWriteReceipt>;\n98\t  search(query: string): Promise<NativeSearchResult>;\n99\t  close(): Promise<void>;\n100\t  drain(timeoutMs: number): Promise<void>;\n101\t  counters(): NativeCounterSnapshot;\n102\t  setProfiling(enabled: boolean): void;\n103\t  setSlowThresholdMs(value: number): void;\n104\t  attachSubscriber(callback: unknown, options?: NativeAttachSubscriberOptions): void;\n105\t}\n106\t\n107\texport interface NativeModule {\n108\t  Engine: {\n109\t    open(path: string, options?: NativeEngineOpenOptions): Promise<NativeEngine>;\n110\t  };\n111\t  adminConfigure(\n112\t    engine: NativeEngine,\n113\t    options: NativeAdminConfigureOptions,\n114\t  ): Promise<NativeWriteReceipt>;\n115\t  forcePanicForTest?: () => void;\n116\t  forcePanicInAccessorForTest?: () => void;\n117\t}\n118\t\n119\texport const native = loadNative() as NativeModule;\n120\t"}]},"parent_tool_use_id":null,"session_id":"e03e003f-16a4-48ce-9857-522e8e7e136e","uuid":"fcdaff9b-4a9a-49e3-99e4-2f70e3df4b8e","timestamp":"2026-05-17T20:44:59.966Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-TX-ts-python-parity-20260517T204414Z/src/ts/src/binding.ts","content":"// Native-binding loader. Locates the platform-tagged `.node` artifact\n// produced by `napi build` and re-exports it as a typed module.\n\nimport { existsSync } from \"node:fs\";\nimport { createRequire } from \"node:module\";\nimport { dirname, join } from \"node:path\";\nimport { fileURLToPath } from \"node:url\";\n\nconst require = createRequire(import.meta.url);\nconst here = dirname(fileURLToPath(import.meta.url));\n\n// `napi build` writes `<name>.<triple>.node` next to the package.json\n// (cwd of the build script). Walk up from this file's compiled location\n// to find candidates.\nconst SEARCH_ROOTS = [\n  join(here, \"..\"), // dist/src/ -> dist/\n  join(here, \"..\", \"..\"), // dist/src/ -> dist/.. (pkg root)\n  here, // co-located fallback\n];\n\nconst TRIPLES = [\n  \"linux-x64-gnu\",\n  \"linux-x64-musl\",\n  \"linux-arm64-gnu\",\n  \"linux-arm64-musl\",\n  \"linux-arm-gnueabihf\",\n  \"darwin-x64\",\n  \"darwin-arm64\",\n  \"darwin-universal\",\n  \"win32-x64-msvc\",\n  \"win32-ia32-msvc\",\n  \"win32-arm64-msvc\",\n  \"freebsd-x64\",\n  \"android-arm64\",\n  \"android-arm-eabi\",\n];\n\nfunction loadNative(): unknown {\n  for (const root of SEARCH_ROOTS) {\n    for (const triple of TRIPLES) {\n      const candidate = join(root, `fathomdb.${triple}.node`);\n      if (existsSync(candidate)) {\n        return require(candidate);\n      }\n    }\n  }\n  throw new Error(\n    \"fathomdb native binding not found. Run `npm run build` to compile it.\",\n  );\n}\n\ninterface NativeWriteReceipt {\n  cursor: number;\n}\n\ninterface NativeSoftFallback {\n  branch: string;\n}\n\ninterface NativeSearchResult {\n  projectionCursor: number;\n  softFallback: NativeSoftFallback | null;\n  results: string[];\n}\n\ninterface NativeCounterSnapshot {\n  queries: number;\n  writes: number;\n  writeRows: number;\n  adminOps: number;\n  cacheHit: number;\n  cacheMiss: number;\n}\n\ninterface NativeAttachSubscriberOptions {\n  heartbeatIntervalMs?: number;\n}\n\ninterface NativeEngineConfig {\n  embedderPoolSize?: number;\n  schedulerRuntimeThreads?: number;\n  provenanceRowCap?: number;\n  embedderCallTimeoutMs?: number;\n  slowThresholdMs?: number;\n}\n\ninterface NativeEngineOpenOptions {\n  engineConfig?: NativeEngineConfig;\n}\n\ninterface NativeAdminConfigureOptions {\n  name: string;\n  body: string;\n}\n\nexport interface NativeEngine {\n  write(batch: unknown[]): Promise<NativeWriteReceipt>;\n  search(query: string): Promise<NativeSearchResult>;\n  close(): Promise<void>;\n  drain(timeoutMs: number): Promise<void>;\n  counters(): NativeCounterSnapshot;\n  setProfiling(enabled: boolean): void;\n  setSlowThresholdMs(value: number): void;\n  attachSubscriber(callback: unknown, options?: NativeAttachSubscriberOptions): void;\n}\n\nexport interface NativeModule {\n  Engine: {\n    open(path: string, options?: NativeEngineOpenOptions): Promise<NativeEngine>;\n  };\n  adminConfigure(\n    engine: NativeEngine,\n    options: NativeAdminConfigureOptions,\n  ): Promise<NativeWriteReceipt>;\n  forcePanicForTest?: () => void;\n  forcePanicInAccessorForTest?: () => void;\n}\n\nexport const native = loadNative() as NativeModule;\n","numLines":120,"startLine":1,"totalLines":120}}}
