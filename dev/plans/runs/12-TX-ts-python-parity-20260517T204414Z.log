{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PehHyREUXqtyhYSuiYivHM","type":"tool_result","content":"310\t            results: r.results,\n311\t        }\n312\t    }\n313\t}\n314\t\n315\t#[pyclass(module = \"fathomdb._fathomdb\", name = \"CounterSnapshot\", frozen, get_all)]\n316\t#[derive(Clone)]\n317\tstruct PyCounterSnapshot {\n318\t    queries: u64,\n319\t    writes: u64,\n320\t    write_rows: u64,\n321\t    admin_ops: u64,\n322\t    cache_hit: u64,\n323\t    cache_miss: u64,\n324\t}\n325\t\n326\t// ===== Engine =========================================================\n327\t\n328\t#[pyclass(module = \"fathomdb._fathomdb\", name = \"Engine\")]\n329\tstruct PyEngine {\n330\t    inner: Arc<RustEngine>,\n331\t}\n332\t\n333\t#[pymethods]\n334\timpl PyEngine {\n335\t    #[staticmethod]\n336\t    #[pyo3(signature = (path))]\n337\t    fn open(py: Python<'_>, path: String) -> PyResult<Self> {\n338\t        validate_ffi_string_py(&path)?;\n339\t        let opened = py\n340\t            .allow_threads(|| catch_unwind(AssertUnwindSafe(|| RustEngine::open(path))))\n341\t            .map_err(|_| PanicException::new_err(\"engine panic during open\"))?\n342\t            .map_err(engine_open_error_to_py)?;\n343\t        Ok(Self { inner: Arc::new(opened.engine) })\n344\t    }\n345\t\n346\t    fn write(&self, py: Python<'_>, batch: Bound<'_, PyList>) -> PyResult<PyWriteReceipt> {\n347\t        let prepared = translate_batch(&batch)?;\n348\t        let engine = Arc::clone(&self.inner);\n349\t        let receipt = call_engine(py, move || engine.write(&prepared))?;\n350\t        Ok(PyWriteReceipt::from_rust(receipt))\n351\t    }\n352\t\n353\t    fn search(&self, py: Python<'_>, query: &str) -> PyResult<PySearchResult> {\n354\t        validate_ffi_string_py(query)?;\n355\t        let engine = Arc::clone(&self.inner);\n356\t        let query = query.to_string();\n357\t        let result = call_engine(py, move || engine.search(&query))?;\n358\t        Ok(PySearchResult::from_rust(result))\n359\t    }\n360\t\n361\t    fn close(&self, py: Python<'_>) -> PyResult<()> {\n362\t        let engine = Arc::clone(&self.inner);\n363\t        call_engine(py, move || engine.close())\n364\t    }\n365\t\n366\t    #[pyo3(signature = (timeout_s = 0.0))]\n367\t    fn drain(&self, py: Python<'_>, timeout_s: f64) -> PyResult<()> {\n368\t        let ms =\n369\t            if timeout_s.is_finite() && timeout_s > 0.0 { (timeout_s * 1000.0) as u64 } else { 0 };\n370\t        let engine = Arc::clone(&self.inner);\n371\t        call_engine(py, move || engine.drain(ms))\n372\t    }\n373\t\n374\t    fn counters(&self) -> PyCounterSnapshot {\n375\t        let snap = self.inner.counters();\n376\t        PyCounterSnapshot {\n377\t            queries: snap.queries,\n378\t            writes: snap.writes,\n379\t            write_rows: snap.write_rows,\n380\t            admin_ops: snap.admin_ops,\n381\t            cache_hit: snap.cache_hit,\n382\t            cache_miss: snap.cache_miss,\n383\t        }\n384\t    }\n385\t\n386\t    fn set_profiling(&self, enabled: bool) -> PyResult<()> {\n387\t        self.inner.set_profiling(enabled).map_err(engine_error_to_py)\n388\t    }\n389\t\n390\t    fn set_slow_threshold_ms(&self, value: u64) -> PyResult<()> {\n391\t        self.inner.set_slow_threshold_ms(value).map_err(engine_error_to_py)\n392\t    }\n393\t\n394\t    #[pyo3(signature = (logger, heartbeat_interval_ms = None))]\n395\t    fn attach_logging_subscriber(\n396\t        &self,\n397\t        logger: Bound<'_, PyAny>,\n398\t        heartbeat_interval_ms: Option<u64>,\n399\t    ) -> PyResult<()> {"}]},"parent_tool_use_id":null,"session_id":"e03e003f-16a4-48ce-9857-522e8e7e136e","uuid":"d1840d8b-1395-4e8a-8afa-848d7a388008","timestamp":"2026-05-17T20:45:28.801Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-TX-ts-python-parity-20260517T204414Z/src/rust/crates/fathomdb-py/src/lib.rs","content":"            results: r.results,\n        }\n    }\n}\n\n#[pyclass(module = \"fathomdb._fathomdb\", name = \"CounterSnapshot\", frozen, get_all)]\n#[derive(Clone)]\nstruct PyCounterSnapshot {\n    queries: u64,\n    writes: u64,\n    write_rows: u64,\n    admin_ops: u64,\n    cache_hit: u64,\n    cache_miss: u64,\n}\n\n// ===== Engine =========================================================\n\n#[pyclass(module = \"fathomdb._fathomdb\", name = \"Engine\")]\nstruct PyEngine {\n    inner: Arc<RustEngine>,\n}\n\n#[pymethods]\nimpl PyEngine {\n    #[staticmethod]\n    #[pyo3(signature = (path))]\n    fn open(py: Python<'_>, path: String) -> PyResult<Self> {\n        validate_ffi_string_py(&path)?;\n        let opened = py\n            .allow_threads(|| catch_unwind(AssertUnwindSafe(|| RustEngine::open(path))))\n            .map_err(|_| PanicException::new_err(\"engine panic during open\"))?\n            .map_err(engine_open_error_to_py)?;\n        Ok(Self { inner: Arc::new(opened.engine) })\n    }\n\n    fn write(&self, py: Python<'_>, batch: Bound<'_, PyList>) -> PyResult<PyWriteReceipt> {\n        let prepared = translate_batch(&batch)?;\n        let engine = Arc::clone(&self.inner);\n        let receipt = call_engine(py, move || engine.write(&prepared))?;\n        Ok(PyWriteReceipt::from_rust(receipt))\n    }\n\n    fn search(&self, py: Python<'_>, query: &str) -> PyResult<PySearchResult> {\n        validate_ffi_string_py(query)?;\n        let engine = Arc::clone(&self.inner);\n        let query = query.to_string();\n        let result = call_engine(py, move || engine.search(&query))?;\n        Ok(PySearchResult::from_rust(result))\n    }\n\n    fn close(&self, py: Python<'_>) -> PyResult<()> {\n        let engine = Arc::clone(&self.inner);\n        call_engine(py, move || engine.close())\n    }\n\n    #[pyo3(signature = (timeout_s = 0.0))]\n    fn drain(&self, py: Python<'_>, timeout_s: f64) -> PyResult<()> {\n        let ms =\n            if timeout_s.is_finite() && timeout_s > 0.0 { (timeout_s * 1000.0) as u64 } else { 0 };\n        let engine = Arc::clone(&self.inner);\n        call_engine(py, move || engine.drain(ms))\n    }\n\n    fn counters(&self) -> PyCounterSnapshot {\n        let snap = self.inner.counters();\n        PyCounterSnapshot {\n            queries: snap.queries,\n            writes: snap.writes,\n            write_rows: snap.write_rows,\n            admin_ops: snap.admin_ops,\n            cache_hit: snap.cache_hit,\n            cache_miss: snap.cache_miss,\n        }\n    }\n\n    fn set_profiling(&self, enabled: bool) -> PyResult<()> {\n        self.inner.set_profiling(enabled).map_err(engine_error_to_py)\n    }\n\n    fn set_slow_threshold_ms(&self, value: u64) -> PyResult<()> {\n        self.inner.set_slow_threshold_ms(value).map_err(engine_error_to_py)\n    }\n\n    #[pyo3(signature = (logger, heartbeat_interval_ms = None))]\n    fn attach_logging_subscriber(\n        &self,\n        logger: Bound<'_, PyAny>,\n        heartbeat_interval_ms: Option<u64>,\n    ) -> PyResult<()> {","numLines":90,"startLine":310,"totalLines":615}}}
