{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018YKsimgJtTtsEX2FYpcu1Z","type":"tool_result","content":"1\t// AC-060a — typed error payload coverage for the napi-rs binding.\n2\t//\n3\t// The engine returns enum variants with typed fields; the binding\n4\t// translator (`engine_error_to_napi` / `engine_open_error_to_napi`)\n5\t// encodes those fields in a JSON envelope that the TS-side\n6\t// `rethrowTyped` reconstitutes into typed leaf classes. Mirrors\n7\t// `src/python/tests/test_typed_errors.py` from Phase 11a.\n8\t\n9\timport test from \"node:test\";\n10\timport assert from \"node:assert/strict\";\n11\t\n12\timport { Engine } from \"../src/index.js\";\n13\timport {\n14\t  CorruptionError,\n15\t  DatabaseLockedError,\n16\t  EmbedderDimensionMismatchError,\n17\t  EmbedderError,\n18\t  EmbedderIdentityMismatchError,\n19\t  EmbedderNotConfiguredError,\n20\t  FathomDbError,\n21\t  KindNotVectorIndexedError,\n22\t  VectorError,\n23\t} from \"../src/errors.js\";\n24\timport { freshDbPath } from \"./helpers.js\";\n25\t\n26\ttest(\"DatabaseLockedError carries holderPid attr\", () => {\n27\t  const err = new DatabaseLockedError({ holderPid: 12345 });\n28\t  assert.equal(err.holderPid, 12345);\n29\t});\n30\t\n31\ttest(\"opening the same database twice surfaces DatabaseLockedError with holderPid\", async () => {\n32\t  const path = freshDbPath();\n33\t  const a = await Engine.open(path);\n34\t  try {\n35\t    await assert.rejects(\n36\t      () => Engine.open(path),\n37\t      (err: unknown) => {\n38\t        assert.ok(err instanceof DatabaseLockedError, \"must be DatabaseLockedError\");\n39\t        assert.ok(err instanceof FathomDbError);\n40\t        const holder = (err as DatabaseLockedError).holderPid;\n41\t        assert.ok(\n42\t          holder === undefined || typeof holder === \"number\",\n43\t          \"holderPid must be undefined or number\",\n44\t        );\n45\t        return true;\n46\t      },\n47\t    );\n48\t  } finally {\n49\t    await a.close();\n50\t  }\n51\t});\n52\t\n53\ttest(\"CorruptionError carries typed kind/stage/recoveryHintCode/docAnchor\", () => {\n54\t  const err = new CorruptionError({\n55\t    kind: \"HeaderMalformed\",\n56\t    stage: \"HeaderProbe\",\n57\t    recoveryHintCode: \"E_CORRUPT_HEADER\",\n58\t    docAnchor: \"design/recovery.md#header-malformed\",\n59\t  });\n60\t  assert.equal(err.kind, \"HeaderMalformed\");\n61\t  assert.equal(err.stage, \"HeaderProbe\");\n62\t  assert.equal(err.recoveryHintCode, \"E_CORRUPT_HEADER\");\n63\t  assert.equal(err.docAnchor, \"design/recovery.md#header-malformed\");\n64\t});\n65\t\n66\ttest(\"EmbedderDimensionMismatchError carries typed stored/supplied\", () => {\n67\t  const err = new EmbedderDimensionMismatchError({ stored: 384, supplied: 768 });\n68\t  assert.equal(err.stored, 384);\n69\t  assert.equal(err.supplied, 768);\n70\t  assert.equal(typeof err.stored, \"number\");\n71\t  assert.equal(typeof err.supplied, \"number\");\n72\t});\n73\t\n74\ttest(\"EmbedderIdentityMismatchError carries typed identity attrs\", () => {\n75\t  const err = new EmbedderIdentityMismatchError({\n76\t    storedName: \"model-a\",\n77\t    storedRevision: \"0\",\n78\t    suppliedName: \"model-b\",\n79\t    suppliedRevision: \"1\",\n80\t  });\n81\t  assert.equal(err.storedName, \"model-a\");\n82\t  assert.equal(err.storedRevision, \"0\");\n83\t  assert.equal(err.suppliedName, \"model-b\");\n84\t  assert.equal(err.suppliedRevision, \"1\");\n85\t});\n86\t\n87\ttest(\"EmbedderNotConfiguredError is a distinct leaf under EmbedderError\", () => {\n88\t  const err = new EmbedderNotConfiguredError(\"no embedder\");\n89\t  assert.ok(err instanceof EmbedderNotConfiguredError);\n90\t  assert.ok(err instanceof EmbedderError);\n91\t  assert.ok(err instanceof FathomDbError);\n92\t  assert.notEqual(EmbedderNotConfiguredError, EmbedderError);\n93\t});\n94\t\n95\ttest(\"KindNotVectorIndexedError is a distinct leaf under VectorError\", () => {\n96\t  const err = new KindNotVectorIndexedError(\"kind X not vector indexed\");\n97\t  assert.ok(err instanceof KindNotVectorIndexedError);\n98\t  assert.ok(err instanceof VectorError);\n99\t  assert.ok(err instanceof FathomDbError);\n100\t  assert.notEqual(KindNotVectorIndexedError, VectorError);\n101\t});\n102\t"}]},"parent_tool_use_id":null,"session_id":"e03e003f-16a4-48ce-9857-522e8e7e136e","uuid":"6aaf82a6-dd11-43c6-b993-990e27fd5a7e","timestamp":"2026-05-17T20:45:33.285Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-TX-ts-python-parity-20260517T204414Z/src/ts/tests/typed-errors.test.ts","content":"// AC-060a — typed error payload coverage for the napi-rs binding.\n//\n// The engine returns enum variants with typed fields; the binding\n// translator (`engine_error_to_napi` / `engine_open_error_to_napi`)\n// encodes those fields in a JSON envelope that the TS-side\n// `rethrowTyped` reconstitutes into typed leaf classes. Mirrors\n// `src/python/tests/test_typed_errors.py` from Phase 11a.\n\nimport test from \"node:test\";\nimport assert from \"node:assert/strict\";\n\nimport { Engine } from \"../src/index.js\";\nimport {\n  CorruptionError,\n  DatabaseLockedError,\n  EmbedderDimensionMismatchError,\n  EmbedderError,\n  EmbedderIdentityMismatchError,\n  EmbedderNotConfiguredError,\n  FathomDbError,\n  KindNotVectorIndexedError,\n  VectorError,\n} from \"../src/errors.js\";\nimport { freshDbPath } from \"./helpers.js\";\n\ntest(\"DatabaseLockedError carries holderPid attr\", () => {\n  const err = new DatabaseLockedError({ holderPid: 12345 });\n  assert.equal(err.holderPid, 12345);\n});\n\ntest(\"opening the same database twice surfaces DatabaseLockedError with holderPid\", async () => {\n  const path = freshDbPath();\n  const a = await Engine.open(path);\n  try {\n    await assert.rejects(\n      () => Engine.open(path),\n      (err: unknown) => {\n        assert.ok(err instanceof DatabaseLockedError, \"must be DatabaseLockedError\");\n        assert.ok(err instanceof FathomDbError);\n        const holder = (err as DatabaseLockedError).holderPid;\n        assert.ok(\n          holder === undefined || typeof holder === \"number\",\n          \"holderPid must be undefined or number\",\n        );\n        return true;\n      },\n    );\n  } finally {\n    await a.close();\n  }\n});\n\ntest(\"CorruptionError carries typed kind/stage/recoveryHintCode/docAnchor\", () => {\n  const err = new CorruptionError({\n    kind: \"HeaderMalformed\",\n    stage: \"HeaderProbe\",\n    recoveryHintCode: \"E_CORRUPT_HEADER\",\n    docAnchor: \"design/recovery.md#header-malformed\",\n  });\n  assert.equal(err.kind, \"HeaderMalformed\");\n  assert.equal(err.stage, \"HeaderProbe\");\n  assert.equal(err.recoveryHintCode, \"E_CORRUPT_HEADER\");\n  assert.equal(err.docAnchor, \"design/recovery.md#header-malformed\");\n});\n\ntest(\"EmbedderDimensionMismatchError carries typed stored/supplied\", () => {\n  const err = new EmbedderDimensionMismatchError({ stored: 384, supplied: 768 });\n  assert.equal(err.stored, 384);\n  assert.equal(err.supplied, 768);\n  assert.equal(typeof err.stored, \"number\");\n  assert.equal(typeof err.supplied, \"number\");\n});\n\ntest(\"EmbedderIdentityMismatchError carries typed identity attrs\", () => {\n  const err = new EmbedderIdentityMismatchError({\n    storedName: \"model-a\",\n    storedRevision: \"0\",\n    suppliedName: \"model-b\",\n    suppliedRevision: \"1\",\n  });\n  assert.equal(err.storedName, \"model-a\");\n  assert.equal(err.storedRevision, \"0\");\n  assert.equal(err.suppliedName, \"model-b\");\n  assert.equal(err.suppliedRevision, \"1\");\n});\n\ntest(\"EmbedderNotConfiguredError is a distinct leaf under EmbedderError\", () => {\n  const err = new EmbedderNotConfiguredError(\"no embedder\");\n  assert.ok(err instanceof EmbedderNotConfiguredError);\n  assert.ok(err instanceof EmbedderError);\n  assert.ok(err instanceof FathomDbError);\n  assert.notEqual(EmbedderNotConfiguredError, EmbedderError);\n});\n\ntest(\"KindNotVectorIndexedError is a distinct leaf under VectorError\", () => {\n  const err = new KindNotVectorIndexedError(\"kind X not vector indexed\");\n  assert.ok(err instanceof KindNotVectorIndexedError);\n  assert.ok(err instanceof VectorError);\n  assert.ok(err instanceof FathomDbError);\n  assert.notEqual(KindNotVectorIndexedError, VectorError);\n});\n","numLines":102,"startLine":1,"totalLines":102}}}
