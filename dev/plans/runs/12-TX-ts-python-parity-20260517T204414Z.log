{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0122Ha5hLdcBev13GvKzHbh3","type":"tool_result","content":"1\t\"\"\"Exception hierarchy assertions for the Python SDK.\n2\t\n3\tPins the single rooted hierarchy beneath `EngineError` and the leaf-class\n4\tmatrix from `dev/design/errors.md`. Per ADR-0.6.0-error-taxonomy and\n5\t`dev/design/bindings.md` § 3, callers dispatch on `except <Specific>` not on\n6\tmessage text; this test file uses `issubclass` to enforce the hierarchy.\n7\t\"\"\"\n8\t\n9\tfrom __future__ import annotations\n10\t\n11\timport pytest\n12\t\n13\tfrom fathomdb import Engine\n14\tfrom fathomdb.errors import (\n15\t    ClosingError,\n16\t    CorruptionError,\n17\t    DatabaseLockedError,\n18\t    EmbedderDimensionMismatchError,\n19\t    EmbedderError,\n20\t    EmbedderIdentityMismatchError,\n21\t    EngineError,\n22\t    IncompatibleSchemaVersionError,\n23\t    MigrationError,\n24\t    OpStoreError,\n25\t    OverloadedError,\n26\t    ProjectionError,\n27\t    SchedulerError,\n28\t    SchemaValidationError,\n29\t    StorageError,\n30\t    VectorError,\n31\t    WriteValidationError,\n32\t)\n33\t\n34\tLEAF_CLASSES = [\n35\t    StorageError,\n36\t    ProjectionError,\n37\t    VectorError,\n38\t    EmbedderError,\n39\t    SchedulerError,\n40\t    OpStoreError,\n41\t    WriteValidationError,\n42\t    SchemaValidationError,\n43\t    OverloadedError,\n44\t    ClosingError,\n45\t    DatabaseLockedError,\n46\t    CorruptionError,\n47\t    IncompatibleSchemaVersionError,\n48\t    MigrationError,\n49\t    EmbedderIdentityMismatchError,\n50\t    EmbedderDimensionMismatchError,\n51\t]\n52\t\n53\t\n54\t@pytest.mark.parametrize(\"cls\", LEAF_CLASSES)\n55\tdef test_every_leaf_extends_engine_error(cls: type[EngineError]) -> None:\n56\t    assert issubclass(cls, EngineError)\n57\t    assert cls is not EngineError\n58\t\n59\t\n60\tdef test_engine_error_is_the_single_root() -> None:\n61\t    for cls in LEAF_CLASSES:\n62\t        bases = {b for b in cls.__mro__ if b not in (cls, object, BaseException, Exception)}\n63\t        assert EngineError in bases, f\"{cls.__name__} must descend from EngineError\"\n64\t\n65\t\n66\tdef test_corruption_error_carries_typed_recovery_hint() -> None:\n67\t    err = CorruptionError(\n68\t        kind=\"HeaderMalformed\",\n69\t        stage=\"HeaderProbe\",\n70\t        recovery_hint_code=\"E_CORRUPT_HEADER\",\n71\t        doc_anchor=\"design/recovery.md#header-malformed\",\n72\t    )\n73\t    assert err.kind == \"HeaderMalformed\"\n74\t    assert err.stage == \"HeaderProbe\"\n75\t    assert err.recovery_hint_code == \"E_CORRUPT_HEADER\"\n76\t    assert err.doc_anchor == \"design/recovery.md#header-malformed\"\n77\t\n78\t\n79\tdef test_database_locked_carries_typed_attrs() -> None:\n80\t    err = DatabaseLockedError(holder_pid=12345)\n81\t    assert err.holder_pid == 12345\n82\t\n83\t\n84\tdef test_embedder_identity_mismatch_carries_typed_attrs() -> None:\n85\t    err = EmbedderIdentityMismatchError(\n86\t        stored_name=\"model-a\",\n87\t        stored_revision=\"0\",\n88\t        supplied_name=\"model-b\",\n89\t        supplied_revision=\"1\",\n90\t    )\n91\t    assert err.stored_name == \"model-a\"\n92\t    assert err.supplied_name == \"model-b\"\n93\t\n94\t\n95\tdef test_embedder_dimension_mismatch_carries_typed_attrs() -> None:\n96\t    err = EmbedderDimensionMismatchError(stored=384, supplied=768)\n97\t    assert err.stored == 384\n98\t    assert err.supplied == 768\n99\t\n100\t\n101\tdef test_search_rejects_empty_query_via_write_validation_under_engine_error(\n102\t    db_path: str,\n103\t) -> None:\n104\t    # Per dev/design/errors.md section Binding-facing class matrix, the\n105\t    # empty-query rejection must surface as the typed WriteValidationError\n106\t    # leaf beneath the single-rooted EngineError, not as a bare ValueError.\n107\t    engine = Engine.open(db_path)\n108\t    try:\n109\t        with pytest.raises(WriteValidationError) as excinfo:\n110\t            engine.search(\"\")\n111\t        assert isinstance(excinfo.value, EngineError)\n112\t        assert isinstance(excinfo.value, WriteValidationError)\n113\t    finally:\n114\t        engine.close()\n115\t"}]},"parent_tool_use_id":null,"session_id":"e03e003f-16a4-48ce-9857-522e8e7e136e","uuid":"0c045d87-2d26-443e-bf73-9c862795f91f","timestamp":"2026-05-17T20:45:21.445Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-TX-ts-python-parity-20260517T204414Z/src/python/tests/test_errors.py","content":"\"\"\"Exception hierarchy assertions for the Python SDK.\n\nPins the single rooted hierarchy beneath `EngineError` and the leaf-class\nmatrix from `dev/design/errors.md`. Per ADR-0.6.0-error-taxonomy and\n`dev/design/bindings.md` § 3, callers dispatch on `except <Specific>` not on\nmessage text; this test file uses `issubclass` to enforce the hierarchy.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport pytest\n\nfrom fathomdb import Engine\nfrom fathomdb.errors import (\n    ClosingError,\n    CorruptionError,\n    DatabaseLockedError,\n    EmbedderDimensionMismatchError,\n    EmbedderError,\n    EmbedderIdentityMismatchError,\n    EngineError,\n    IncompatibleSchemaVersionError,\n    MigrationError,\n    OpStoreError,\n    OverloadedError,\n    ProjectionError,\n    SchedulerError,\n    SchemaValidationError,\n    StorageError,\n    VectorError,\n    WriteValidationError,\n)\n\nLEAF_CLASSES = [\n    StorageError,\n    ProjectionError,\n    VectorError,\n    EmbedderError,\n    SchedulerError,\n    OpStoreError,\n    WriteValidationError,\n    SchemaValidationError,\n    OverloadedError,\n    ClosingError,\n    DatabaseLockedError,\n    CorruptionError,\n    IncompatibleSchemaVersionError,\n    MigrationError,\n    EmbedderIdentityMismatchError,\n    EmbedderDimensionMismatchError,\n]\n\n\n@pytest.mark.parametrize(\"cls\", LEAF_CLASSES)\ndef test_every_leaf_extends_engine_error(cls: type[EngineError]) -> None:\n    assert issubclass(cls, EngineError)\n    assert cls is not EngineError\n\n\ndef test_engine_error_is_the_single_root() -> None:\n    for cls in LEAF_CLASSES:\n        bases = {b for b in cls.__mro__ if b not in (cls, object, BaseException, Exception)}\n        assert EngineError in bases, f\"{cls.__name__} must descend from EngineError\"\n\n\ndef test_corruption_error_carries_typed_recovery_hint() -> None:\n    err = CorruptionError(\n        kind=\"HeaderMalformed\",\n        stage=\"HeaderProbe\",\n        recovery_hint_code=\"E_CORRUPT_HEADER\",\n        doc_anchor=\"design/recovery.md#header-malformed\",\n    )\n    assert err.kind == \"HeaderMalformed\"\n    assert err.stage == \"HeaderProbe\"\n    assert err.recovery_hint_code == \"E_CORRUPT_HEADER\"\n    assert err.doc_anchor == \"design/recovery.md#header-malformed\"\n\n\ndef test_database_locked_carries_typed_attrs() -> None:\n    err = DatabaseLockedError(holder_pid=12345)\n    assert err.holder_pid == 12345\n\n\ndef test_embedder_identity_mismatch_carries_typed_attrs() -> None:\n    err = EmbedderIdentityMismatchError(\n        stored_name=\"model-a\",\n        stored_revision=\"0\",\n        supplied_name=\"model-b\",\n        supplied_revision=\"1\",\n    )\n    assert err.stored_name == \"model-a\"\n    assert err.supplied_name == \"model-b\"\n\n\ndef test_embedder_dimension_mismatch_carries_typed_attrs() -> None:\n    err = EmbedderDimensionMismatchError(stored=384, supplied=768)\n    assert err.stored == 384\n    assert err.supplied == 768\n\n\ndef test_search_rejects_empty_query_via_write_validation_under_engine_error(\n    db_path: str,\n) -> None:\n    # Per dev/design/errors.md section Binding-facing class matrix, the\n    # empty-query rejection must surface as the typed WriteValidationError\n    # leaf beneath the single-rooted EngineError, not as a bare ValueError.\n    engine = Engine.open(db_path)\n    try:\n        with pytest.raises(WriteValidationError) as excinfo:\n            engine.search(\"\")\n        assert isinstance(excinfo.value, EngineError)\n        assert isinstance(excinfo.value, WriteValidationError)\n    finally:\n        engine.close()\n","numLines":115,"startLine":1,"totalLines":115}}}
