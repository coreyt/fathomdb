{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EMoLkTBnxs8kwCBSxJCQmj","type":"tool_result","content":"1\t\"\"\"AC-060b — payload-vs-schema validation surfaces as\n2\t`SchemaValidationError` and writes no row.\n3\t\n4\tA registered op-store schema is the contract the engine validates\n5\tagainst on each op-store write; a body that violates the schema must\n6\tfail BEFORE the row commits.\n7\t\"\"\"\n8\t\n9\tfrom __future__ import annotations\n10\t\n11\timport pytest\n12\t\n13\tfrom fathomdb import Engine, admin\n14\tfrom fathomdb.errors import SchemaValidationError\n15\t\n16\t\n17\tdef test_op_store_write_violating_schema_raises_and_writes_no_row(db_path: str) -> None:\n18\t    engine = Engine.open(db_path)\n19\t    try:\n20\t        schema_body = '{\"type\":\"object\",\"required\":[\"foo\"]}'\n21\t        admin.configure(engine, name=\"strict_col\", body=schema_body)\n22\t        before = engine._native.counters().write_rows\n23\t\n24\t        with pytest.raises(SchemaValidationError):\n25\t            engine.write(\n26\t                [\n27\t                    {\n28\t                        \"op_store\": {\n29\t                            \"collection\": \"strict_col\",\n30\t                            \"record_key\": \"k1\",\n31\t                            \"schema_id\": \"strict_col\",\n32\t                            \"body\": \"{}\",\n33\t                        }\n34\t                    }\n35\t                ]\n36\t            )\n37\t        after = engine._native.counters().write_rows\n38\t        assert after == before, \"schema-violating write must not commit a row\"\n39\t    finally:\n40\t        engine.close()\n41\t"}]},"parent_tool_use_id":null,"session_id":"e03e003f-16a4-48ce-9857-522e8e7e136e","uuid":"e2d262ba-733a-4ebb-9d2e-a7d959c352d0","timestamp":"2026-05-17T20:45:40.569Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-TX-ts-python-parity-20260517T204414Z/src/python/tests/test_save_time_validation.py","content":"\"\"\"AC-060b — payload-vs-schema validation surfaces as\n`SchemaValidationError` and writes no row.\n\nA registered op-store schema is the contract the engine validates\nagainst on each op-store write; a body that violates the schema must\nfail BEFORE the row commits.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport pytest\n\nfrom fathomdb import Engine, admin\nfrom fathomdb.errors import SchemaValidationError\n\n\ndef test_op_store_write_violating_schema_raises_and_writes_no_row(db_path: str) -> None:\n    engine = Engine.open(db_path)\n    try:\n        schema_body = '{\"type\":\"object\",\"required\":[\"foo\"]}'\n        admin.configure(engine, name=\"strict_col\", body=schema_body)\n        before = engine._native.counters().write_rows\n\n        with pytest.raises(SchemaValidationError):\n            engine.write(\n                [\n                    {\n                        \"op_store\": {\n                            \"collection\": \"strict_col\",\n                            \"record_key\": \"k1\",\n                            \"schema_id\": \"strict_col\",\n                            \"body\": \"{}\",\n                        }\n                    }\n                ]\n            )\n        after = engine._native.counters().write_rows\n        assert after == before, \"schema-violating write must not commit a row\"\n    finally:\n        engine.close()\n","numLines":41,"startLine":1,"totalLines":41}}}
