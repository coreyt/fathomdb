{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017q3b1tBvvbVXC4RPsKakHG","type":"tool_result","content":"1\t// AC-041 — recovery tooling unreachable from the TypeScript runtime SDK.\n2\t//\n3\t// Mirrors the introspection style of `surface.test.ts`. Asserts the public\n4\t// module exports, the `Engine` class (static + instance), and the `admin`\n5\t// namespace expose none of the canonical recovery-verb names. Recovery is\n6\t// CLI-only per `dev/interfaces/cli.md`; the runtime SDK five-verb surface\n7\t// (open/write/search/close/admin.configure) does not mirror it.\n8\t\n9\timport test from \"node:test\";\n10\timport assert from \"node:assert/strict\";\n11\t\n12\timport * as fathomdb from \"../src/index.js\";\n13\timport { Engine, admin } from \"../src/index.js\";\n14\timport { freshDbPath } from \"./helpers.js\";\n15\t\n16\tconst FORBIDDEN = new Set([\"recover\", \"restore\", \"repair\", \"fix\", \"rebuild\"]);\n17\t\n18\tfunction publicNames(obj: object): Set<string> {\n19\t  return new Set(Object.keys(obj as Record<string, unknown>).filter((n) => !n.startsWith(\"_\")));\n20\t}\n21\t\n22\tfunction intersection<T>(a: Set<T>, b: Set<T>): T[] {\n23\t  return [...a].filter((x) => b.has(x));\n24\t}\n25\t\n26\ttest(\"module top-level exports include no recovery verbs\", () => {\n27\t  const names = publicNames(fathomdb);\n28\t  assert.deepEqual(intersection(names, FORBIDDEN), []);\n29\t});\n30\t\n31\ttest(\"Engine class statics include no recovery methods\", () => {\n32\t  const names = publicNames(Engine as unknown as object);\n33\t  assert.deepEqual(intersection(names, FORBIDDEN), []);\n34\t});\n35\t\n36\ttest(\"Engine instance has no recovery methods\", async () => {\n37\t  const engine = await Engine.open(freshDbPath());\n38\t  try {\n39\t    const proto = Object.getPrototypeOf(engine) as object;\n40\t    const protoNames = new Set(\n41\t      Object.getOwnPropertyNames(proto).filter((n) => !n.startsWith(\"_\") && n !== \"constructor\"),\n42\t    );\n43\t    const ownNames = publicNames(engine);\n44\t    const all = new Set<string>([...protoNames, ...ownNames]);\n45\t    assert.deepEqual(intersection(all, FORBIDDEN), []);\n46\t  } finally {\n47\t    await engine.close();\n48\t  }\n49\t});\n50\t\n51\ttest(\"admin namespace exports no recovery verbs\", () => {\n52\t  const names = publicNames(admin);\n53\t  assert.deepEqual(intersection(names, FORBIDDEN), []);\n54\t});\n55\t"}]},"parent_tool_use_id":null,"session_id":"e03e003f-16a4-48ce-9857-522e8e7e136e","uuid":"677a05f4-c24a-40ac-b83f-f1d495486dbc","timestamp":"2026-05-17T20:45:43.913Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-TX-ts-python-parity-20260517T204414Z/src/ts/tests/no-recovery-surface.test.ts","content":"// AC-041 — recovery tooling unreachable from the TypeScript runtime SDK.\n//\n// Mirrors the introspection style of `surface.test.ts`. Asserts the public\n// module exports, the `Engine` class (static + instance), and the `admin`\n// namespace expose none of the canonical recovery-verb names. Recovery is\n// CLI-only per `dev/interfaces/cli.md`; the runtime SDK five-verb surface\n// (open/write/search/close/admin.configure) does not mirror it.\n\nimport test from \"node:test\";\nimport assert from \"node:assert/strict\";\n\nimport * as fathomdb from \"../src/index.js\";\nimport { Engine, admin } from \"../src/index.js\";\nimport { freshDbPath } from \"./helpers.js\";\n\nconst FORBIDDEN = new Set([\"recover\", \"restore\", \"repair\", \"fix\", \"rebuild\"]);\n\nfunction publicNames(obj: object): Set<string> {\n  return new Set(Object.keys(obj as Record<string, unknown>).filter((n) => !n.startsWith(\"_\")));\n}\n\nfunction intersection<T>(a: Set<T>, b: Set<T>): T[] {\n  return [...a].filter((x) => b.has(x));\n}\n\ntest(\"module top-level exports include no recovery verbs\", () => {\n  const names = publicNames(fathomdb);\n  assert.deepEqual(intersection(names, FORBIDDEN), []);\n});\n\ntest(\"Engine class statics include no recovery methods\", () => {\n  const names = publicNames(Engine as unknown as object);\n  assert.deepEqual(intersection(names, FORBIDDEN), []);\n});\n\ntest(\"Engine instance has no recovery methods\", async () => {\n  const engine = await Engine.open(freshDbPath());\n  try {\n    const proto = Object.getPrototypeOf(engine) as object;\n    const protoNames = new Set(\n      Object.getOwnPropertyNames(proto).filter((n) => !n.startsWith(\"_\") && n !== \"constructor\"),\n    );\n    const ownNames = publicNames(engine);\n    const all = new Set<string>([...protoNames, ...ownNames]);\n    assert.deepEqual(intersection(all, FORBIDDEN), []);\n  } finally {\n    await engine.close();\n  }\n});\n\ntest(\"admin namespace exports no recovery verbs\", () => {\n  const names = publicNames(admin);\n  assert.deepEqual(intersection(names, FORBIDDEN), []);\n});\n","numLines":55,"startLine":1,"totalLines":55}}}
