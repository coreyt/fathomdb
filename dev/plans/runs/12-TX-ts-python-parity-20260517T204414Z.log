{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R35PiHFp4qJbsGz45sMpfd","type":"tool_result","content":"1\t// Single-rooted FathomDbError hierarchy for the TypeScript SDK.\n2\t//\n3\t// Layout owned by `dev/design/errors.md` § Binding-facing class matrix\n4\t// and `dev/design/bindings.md` § 3. Per-leaf payloads are typed object\n5\t// arguments; callers narrow with `instanceof`.\n6\t//\n7\t// The napi-rs binding cannot throw a Rust-defined JS class with a TS\n8\t// `instanceof` chain. Instead, it throws `Error` whose `message` is a\n9\t// JSON envelope `{ code, message, payload }`. `rethrowTyped` parses\n10\t// that envelope and constructs the matching leaf class so `instanceof\n11\t// FathomDbError` narrowing works on the TS side.\n12\t\n13\texport class FathomDbError extends Error {\n14\t  constructor(message: string) {\n15\t    super(message);\n16\t    this.name = new.target.name;\n17\t  }\n18\t}\n19\t\n20\texport class StorageError extends FathomDbError {}\n21\texport class ProjectionError extends FathomDbError {}\n22\texport class VectorError extends FathomDbError {}\n23\texport class EmbedderError extends FathomDbError {}\n24\texport class SchedulerError extends FathomDbError {}\n25\texport class OpStoreError extends FathomDbError {}\n26\texport class WriteValidationError extends FathomDbError {}\n27\texport class SchemaValidationError extends FathomDbError {}\n28\texport class OverloadedError extends FathomDbError {}\n29\texport class ClosingError extends FathomDbError {}\n30\t\n31\texport class EmbedderNotConfiguredError extends EmbedderError {}\n32\texport class KindNotVectorIndexedError extends VectorError {}\n33\t\n34\texport interface DatabaseLockedErrorPayload {\n35\t  holderPid?: number;\n36\t}\n37\t\n38\texport class DatabaseLockedError extends FathomDbError {\n39\t  readonly holderPid?: number;\n40\t  constructor(payload: DatabaseLockedErrorPayload = {}) {\n41\t    super(`database locked (holderPid=${payload.holderPid ?? \"unknown\"})`);\n42\t    this.holderPid = payload.holderPid;\n43\t  }\n44\t}\n45\t\n46\texport interface CorruptionErrorPayload {\n47\t  kind: string;\n48\t  stage: string;\n49\t  recoveryHintCode: string;\n50\t  docAnchor: string;\n51\t}\n52\t\n53\texport class CorruptionError extends FathomDbError {\n54\t  readonly kind: string;\n55\t  readonly stage: string;\n56\t  readonly recoveryHintCode: string;\n57\t  readonly docAnchor: string;\n58\t  constructor(payload: CorruptionErrorPayload) {\n59\t    super(`corruption ${payload.kind} at stage ${payload.stage} (${payload.recoveryHintCode})`);\n60\t    this.kind = payload.kind;\n61\t    this.stage = payload.stage;\n62\t    this.recoveryHintCode = payload.recoveryHintCode;\n63\t    this.docAnchor = payload.docAnchor;\n64\t  }\n65\t}\n66\t\n67\texport class IncompatibleSchemaVersionError extends FathomDbError {}\n68\texport class MigrationError extends FathomDbError {}\n69\t\n70\texport interface EmbedderIdentityMismatchPayload {\n71\t  storedName: string;\n72\t  storedRevision: string;\n73\t  suppliedName: string;\n74\t  suppliedRevision: string;\n75\t}\n76\t\n77\texport class EmbedderIdentityMismatchError extends FathomDbError {\n78\t  readonly storedName: string;\n79\t  readonly storedRevision: string;\n80\t  readonly suppliedName: string;\n81\t  readonly suppliedRevision: string;\n82\t  constructor(payload: EmbedderIdentityMismatchPayload) {\n83\t    super(\n84\t      `embedder identity mismatch: stored ${payload.storedName}@${payload.storedRevision}, ` +\n85\t        `supplied ${payload.suppliedName}@${payload.suppliedRevision}`,\n86\t    );\n87\t    this.storedName = payload.storedName;\n88\t    this.storedRevision = payload.storedRevision;\n89\t    this.suppliedName = payload.suppliedName;\n90\t    this.suppliedRevision = payload.suppliedRevision;\n91\t  }\n92\t}\n93\t\n94\texport interface EmbedderDimensionMismatchPayload {\n95\t  stored: number;\n96\t  supplied: number;\n97\t}\n98\t\n99\texport class EmbedderDimensionMismatchError extends FathomDbError {\n100\t  readonly stored: number;\n101\t  readonly supplied: number;\n102\t  constructor(payload: EmbedderDimensionMismatchPayload) {\n103\t    super(\n104\t      `embedder vector dimension mismatch: stored ${payload.stored}, supplied ${payload.supplied}`,\n105\t    );\n106\t    this.stored = payload.stored;\n107\t    this.supplied = payload.supplied;\n108\t  }\n109\t}\n110\t\n111\t// Panic is a contract bug, not a typed engine outcome — intentionally\n112\t// NOT a FathomDbError subclass so callers that catch FathomDbError do\n113\t// not silently swallow it. Mirrors PyO3 PanicException in 11a.\n114\texport class FathomDbPanicError extends Error {\n115\t  constructor(message: string) {\n116\t    super(message);\n117\t    this.name = \"FathomDbPanicError\";\n118\t  }\n119\t}\n120\t\n121\t// ===== Typed-error rethrow ============================================\n122\t\n123\ttype ErrorCode =\n124\t  | \"FDB_STORAGE\"\n125\t  | \"FDB_PROJECTION\"\n126\t  | \"FDB_VECTOR\"\n127\t  | \"FDB_EMBEDDER\"\n128\t  | \"FDB_EMBEDDER_NOT_CONFIGURED\"\n129\t  | \"FDB_KIND_NOT_VECTOR_INDEXED\"\n130\t  | \"FDB_EMBEDDER_DIMENSION_MISMATCH\"\n131\t  | \"FDB_SCHEDULER\"\n132\t  | \"FDB_OP_STORE\"\n133\t  | \"FDB_WRITE_VALIDATION\"\n134\t  | \"FDB_SCHEMA_VALIDATION\"\n135\t  | \"FDB_OVERLOADED\"\n136\t  | \"FDB_CLOSING\"\n137\t  | \"FDB_DATABASE_LOCKED\"\n138\t  | \"FDB_CORRUPTION\"\n139\t  | \"FDB_INCOMPATIBLE_SCHEMA_VERSION\"\n140\t  | \"FDB_MIGRATION\"\n141\t  | \"FDB_EMBEDDER_IDENTITY_MISMATCH\"\n142\t  | \"FDB_PANIC\";\n143\t\n144\tinterface Envelope {\n145\t  code: ErrorCode;\n146\t  message: string;\n147\t  payload: Record<string, unknown> | null;\n148\t}\n149\t\n150\tfunction parseEnvelope(raw: unknown): Envelope | null {\n151\t  if (typeof raw !== \"string\" || raw.length === 0 || raw[0] !== \"{\") {\n152\t    return null;\n153\t  }\n154\t  let parsed: unknown;\n155\t  try {\n156\t    parsed = JSON.parse(raw);\n157\t  } catch {\n158\t    return null;\n159\t  }\n160\t  if (parsed === null || typeof parsed !== \"object\") {\n161\t    return null;\n162\t  }\n163\t  const obj = parsed as Record<string, unknown>;\n164\t  if (typeof obj.code !== \"string\" || typeof obj.message !== \"string\") {\n165\t    return null;\n166\t  }\n167\t  return {\n168\t    code: obj.code as ErrorCode,\n169\t    message: obj.message,\n170\t    payload: (obj.payload as Record<string, unknown> | null) ?? null,\n171\t  };\n172\t}\n173\t\n174\tfunction build(envelope: Envelope): Error {\n175\t  const p = envelope.payload ?? {};\n176\t  switch (envelope.code) {\n177\t    case \"FDB_STORAGE\":\n178\t      return new StorageError(envelope.message);\n179\t    case \"FDB_PROJECTION\":\n180\t      return new ProjectionError(envelope.message);\n181\t    case \"FDB_VECTOR\":\n182\t      return new VectorError(envelope.message);\n183\t    case \"FDB_EMBEDDER\":\n184\t      return new EmbedderError(envelope.message);\n185\t    case \"FDB_EMBEDDER_NOT_CONFIGURED\":\n186\t      return new EmbedderNotConfiguredError(envelope.message);\n187\t    case \"FDB_KIND_NOT_VECTOR_INDEXED\":\n188\t      return new KindNotVectorIndexedError(envelope.message);\n189\t    case \"FDB_EMBEDDER_DIMENSION_MISMATCH\":\n190\t      return new EmbedderDimensionMismatchError({\n191\t        stored: Number(p.stored),\n192\t        supplied: Number(p.supplied),\n193\t      });\n194\t    case \"FDB_SCHEDULER\":\n195\t      return new SchedulerError(envelope.message);\n196\t    case \"FDB_OP_STORE\":\n197\t      return new OpStoreError(envelope.message);\n198\t    case \"FDB_WRITE_VALIDATION\":\n199\t      return new WriteValidationError(envelope.message);\n200\t    case \"FDB_SCHEMA_VALIDATION\":\n201\t      return new SchemaValidationError(envelope.message);\n202\t    case \"FDB_OVERLOADED\":\n203\t      return new OverloadedError(envelope.message);\n204\t    case \"FDB_CLOSING\":\n205\t      return new ClosingError(envelope.message);\n206\t    case \"FDB_DATABASE_LOCKED\":\n207\t      return new DatabaseLockedError({\n208\t        holderPid: typeof p.holderPid === \"number\" ? p.holderPid : undefined,\n209\t      });\n210\t    case \"FDB_CORRUPTION\":\n211\t      return new CorruptionError({\n212\t        kind: String(p.kind ?? \"\"),\n213\t        stage: String(p.stage ?? \"\"),\n214\t        recoveryHintCode: String(p.recoveryHintCode ?? \"\"),\n215\t        docAnchor: String(p.docAnchor ?? \"\"),\n216\t      });\n217\t    case \"FDB_INCOMPATIBLE_SCHEMA_VERSION\":\n218\t      return new IncompatibleSchemaVersionError(envelope.message);\n219\t    case \"FDB_MIGRATION\":\n220\t      return new MigrationError(envelope.message);\n221\t    case \"FDB_EMBEDDER_IDENTITY_MISMATCH\":\n222\t      return new EmbedderIdentityMismatchError({\n223\t        storedName: String(p.storedName ?? \"\"),\n224\t        storedRevision: String(p.storedRevision ?? \"\"),\n225\t        suppliedName: String(p.suppliedName ?? \"\"),\n226\t        suppliedRevision: String(p.suppliedRevision ?? \"\"),\n227\t      });\n228\t    case \"FDB_PANIC\":\n229\t      return new FathomDbPanicError(envelope.message);\n230\t    default: {\n231\t      // Exhaustiveness — if ErrorCode union grows and switch arms\n232\t      // don't cover it, this branch becomes reachable and TS narrows\n233\t      // `envelope.code` to `never`, surfacing as a compile error.\n234\t      const _exhaustive: never = envelope.code;\n235\t      return new Error(`unrecognised error code: ${String(_exhaustive)}`);\n236\t    }\n237\t  }\n238\t}\n239\t\n240\t/**\n241\t * Re-raise a binding-thrown error as the corresponding TS leaf class.\n242\t *\n243\t * Errors not carrying the JSON envelope are rethrown unchanged so\n244\t * non-binding errors (e.g. native panics from outside the catch\n245\t * surface) reach the caller untouched.\n246\t */\n247\texport function rethrowTyped(err: unknown): never {\n248\t  if (err instanceof Error) {\n249\t    const env = parseEnvelope(err.message);\n250\t    if (env !== null) {\n251\t      throw build(env);\n252\t    }\n253\t  }\n254\t  throw err;\n255\t}\n256\t"}]},"parent_tool_use_id":null,"session_id":"e03e003f-16a4-48ce-9857-522e8e7e136e","uuid":"030ece7a-4e80-4b99-97b6-b25df07a9ee5","timestamp":"2026-05-17T20:44:23.663Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-TX-ts-python-parity-20260517T204414Z/src/ts/src/errors.ts","content":"// Single-rooted FathomDbError hierarchy for the TypeScript SDK.\n//\n// Layout owned by `dev/design/errors.md` § Binding-facing class matrix\n// and `dev/design/bindings.md` § 3. Per-leaf payloads are typed object\n// arguments; callers narrow with `instanceof`.\n//\n// The napi-rs binding cannot throw a Rust-defined JS class with a TS\n// `instanceof` chain. Instead, it throws `Error` whose `message` is a\n// JSON envelope `{ code, message, payload }`. `rethrowTyped` parses\n// that envelope and constructs the matching leaf class so `instanceof\n// FathomDbError` narrowing works on the TS side.\n\nexport class FathomDbError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = new.target.name;\n  }\n}\n\nexport class StorageError extends FathomDbError {}\nexport class ProjectionError extends FathomDbError {}\nexport class VectorError extends FathomDbError {}\nexport class EmbedderError extends FathomDbError {}\nexport class SchedulerError extends FathomDbError {}\nexport class OpStoreError extends FathomDbError {}\nexport class WriteValidationError extends FathomDbError {}\nexport class SchemaValidationError extends FathomDbError {}\nexport class OverloadedError extends FathomDbError {}\nexport class ClosingError extends FathomDbError {}\n\nexport class EmbedderNotConfiguredError extends EmbedderError {}\nexport class KindNotVectorIndexedError extends VectorError {}\n\nexport interface DatabaseLockedErrorPayload {\n  holderPid?: number;\n}\n\nexport class DatabaseLockedError extends FathomDbError {\n  readonly holderPid?: number;\n  constructor(payload: DatabaseLockedErrorPayload = {}) {\n    super(`database locked (holderPid=${payload.holderPid ?? \"unknown\"})`);\n    this.holderPid = payload.holderPid;\n  }\n}\n\nexport interface CorruptionErrorPayload {\n  kind: string;\n  stage: string;\n  recoveryHintCode: string;\n  docAnchor: string;\n}\n\nexport class CorruptionError extends FathomDbError {\n  readonly kind: string;\n  readonly stage: string;\n  readonly recoveryHintCode: string;\n  readonly docAnchor: string;\n  constructor(payload: CorruptionErrorPayload) {\n    super(`corruption ${payload.kind} at stage ${payload.stage} (${payload.recoveryHintCode})`);\n    this.kind = payload.kind;\n    this.stage = payload.stage;\n    this.recoveryHintCode = payload.recoveryHintCode;\n    this.docAnchor = payload.docAnchor;\n  }\n}\n\nexport class IncompatibleSchemaVersionError extends FathomDbError {}\nexport class MigrationError extends FathomDbError {}\n\nexport interface EmbedderIdentityMismatchPayload {\n  storedName: string;\n  storedRevision: string;\n  suppliedName: string;\n  suppliedRevision: string;\n}\n\nexport class EmbedderIdentityMismatchError extends FathomDbError {\n  readonly storedName: string;\n  readonly storedRevision: string;\n  readonly suppliedName: string;\n  readonly suppliedRevision: string;\n  constructor(payload: EmbedderIdentityMismatchPayload) {\n    super(\n      `embedder identity mismatch: stored ${payload.storedName}@${payload.storedRevision}, ` +\n        `supplied ${payload.suppliedName}@${payload.suppliedRevision}`,\n    );\n    this.storedName = payload.storedName;\n    this.storedRevision = payload.storedRevision;\n    this.suppliedName = payload.suppliedName;\n    this.suppliedRevision = payload.suppliedRevision;\n  }\n}\n\nexport interface EmbedderDimensionMismatchPayload {\n  stored: number;\n  supplied: number;\n}\n\nexport class EmbedderDimensionMismatchError extends FathomDbError {\n  readonly stored: number;\n  readonly supplied: number;\n  constructor(payload: EmbedderDimensionMismatchPayload) {\n    super(\n      `embedder vector dimension mismatch: stored ${payload.stored}, supplied ${payload.supplied}`,\n    );\n    this.stored = payload.stored;\n    this.supplied = payload.supplied;\n  }\n}\n\n// Panic is a contract bug, not a typed engine outcome — intentionally\n// NOT a FathomDbError subclass so callers that catch FathomDbError do\n// not silently swallow it. Mirrors PyO3 PanicException in 11a.\nexport class FathomDbPanicError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = \"FathomDbPanicError\";\n  }\n}\n\n// ===== Typed-error rethrow ============================================\n\ntype ErrorCode =\n  | \"FDB_STORAGE\"\n  | \"FDB_PROJECTION\"\n  | \"FDB_VECTOR\"\n  | \"FDB_EMBEDDER\"\n  | \"FDB_EMBEDDER_NOT_CONFIGURED\"\n  | \"FDB_KIND_NOT_VECTOR_INDEXED\"\n  | \"FDB_EMBEDDER_DIMENSION_MISMATCH\"\n  | \"FDB_SCHEDULER\"\n  | \"FDB_OP_STORE\"\n  | \"FDB_WRITE_VALIDATION\"\n  | \"FDB_SCHEMA_VALIDATION\"\n  | \"FDB_OVERLOADED\"\n  | \"FDB_CLOSING\"\n  | \"FDB_DATABASE_LOCKED\"\n  | \"FDB_CORRUPTION\"\n  | \"FDB_INCOMPATIBLE_SCHEMA_VERSION\"\n  | \"FDB_MIGRATION\"\n  | \"FDB_EMBEDDER_IDENTITY_MISMATCH\"\n  | \"FDB_PANIC\";\n\ninterface Envelope {\n  code: ErrorCode;\n  message: string;\n  payload: Record<string, unknown> | null;\n}\n\nfunction parseEnvelope(raw: unknown): Envelope | null {\n  if (typeof raw !== \"string\" || raw.length === 0 || raw[0] !== \"{\") {\n    return null;\n  }\n  let parsed: unknown;\n  try {\n    parsed = JSON.parse(raw);\n  } catch {\n    return null;\n  }\n  if (parsed === null || typeof parsed !== \"object\") {\n    return null;\n  }\n  const obj = parsed as Record<string, unknown>;\n  if (typeof obj.code !== \"string\" || typeof obj.message !== \"string\") {\n    return null;\n  }\n  return {\n    code: obj.code as ErrorCode,\n    message: obj.message,\n    payload: (obj.payload as Record<string, unknown> | null) ?? null,\n  };\n}\n\nfunction build(envelope: Envelope): Error {\n  const p = envelope.payload ?? {};\n  switch (envelope.code) {\n    case \"FDB_STORAGE\":\n      return new StorageError(envelope.message);\n    case \"FDB_PROJECTION\":\n      return new ProjectionError(envelope.message);\n    case \"FDB_VECTOR\":\n      return new VectorError(envelope.message);\n    case \"FDB_EMBEDDER\":\n      return new EmbedderError(envelope.message);\n    case \"FDB_EMBEDDER_NOT_CONFIGURED\":\n      return new EmbedderNotConfiguredError(envelope.message);\n    case \"FDB_KIND_NOT_VECTOR_INDEXED\":\n      return new KindNotVectorIndexedError(envelope.message);\n    case \"FDB_EMBEDDER_DIMENSION_MISMATCH\":\n      return new EmbedderDimensionMismatchError({\n        stored: Number(p.stored),\n        supplied: Number(p.supplied),\n      });\n    case \"FDB_SCHEDULER\":\n      return new SchedulerError(envelope.message);\n    case \"FDB_OP_STORE\":\n      return new OpStoreError(envelope.message);\n    case \"FDB_WRITE_VALIDATION\":\n      return new WriteValidationError(envelope.message);\n    case \"FDB_SCHEMA_VALIDATION\":\n      return new SchemaValidationError(envelope.message);\n    case \"FDB_OVERLOADED\":\n      return new OverloadedError(envelope.message);\n    case \"FDB_CLOSING\":\n      return new ClosingError(envelope.message);\n    case \"FDB_DATABASE_LOCKED\":\n      return new DatabaseLockedError({\n        holderPid: typeof p.holderPid === \"number\" ? p.holderPid : undefined,\n      });\n    case \"FDB_CORRUPTION\":\n      return new CorruptionError({\n        kind: String(p.kind ?? \"\"),\n        stage: String(p.stage ?? \"\"),\n        recoveryHintCode: String(p.recoveryHintCode ?? \"\"),\n        docAnchor: String(p.docAnchor ?? \"\"),\n      });\n    case \"FDB_INCOMPATIBLE_SCHEMA_VERSION\":\n      return new IncompatibleSchemaVersionError(envelope.message);\n    case \"FDB_MIGRATION\":\n      return new MigrationError(envelope.message);\n    case \"FDB_EMBEDDER_IDENTITY_MISMATCH\":\n      return new EmbedderIdentityMismatchError({\n        storedName: String(p.storedName ?? \"\"),\n        storedRevision: String(p.storedRevision ?? \"\"),\n        suppliedName: String(p.suppliedName ?? \"\"),\n        suppliedRevision: String(p.suppliedRevision ?? \"\"),\n      });\n    case \"FDB_PANIC\":\n      return new FathomDbPanicError(envelope.message);\n    default: {\n      // Exhaustiveness — if ErrorCode union grows and switch arms\n      // don't cover it, this branch becomes reachable and TS narrows\n      // `envelope.code` to `never`, surfacing as a compile error.\n      const _exhaustive: never = envelope.code;\n      return new Error(`unrecognised error code: ${String(_exhaustive)}`);\n    }\n  }\n}\n\n/**\n * Re-raise a binding-thrown error as the corresponding TS leaf class.\n *\n * Errors not carrying the JSON envelope are rethrown unchanged so\n * non-binding errors (e.g. native panics from outside the catch\n * surface) reach the caller untouched.\n */\nexport function rethrowTyped(err: unknown): never {\n  if (err instanceof Error) {\n    const env = parseEnvelope(err.message);\n    if (env !== null) {\n      throw build(env);\n    }\n  }\n  throw err;\n}\n","numLines":256,"startLine":1,"totalLines":256}}}
