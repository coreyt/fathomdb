{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y2pQej9yMmPbLHs5okBd5o","type":"tool_result","content":"1\t// Surface assertions for the TypeScript SDK.\n2\t//\n3\t// Binds AC-057a (REQ-053): five-verb runtime SDK surface.\n4\t//\n5\t// Pins the five-verb top-level surface, the engine-attached\n6\t// instrumentation methods, the options.engineConfig camelCase knobs,\n7\t// the soft-fallback record shape, and the FathomDbError single-rooted\n8\t// hierarchy per `dev/interfaces/typescript.md` and\n9\t// `dev/design/bindings.md` § 3.\n10\t\n11\timport test from \"node:test\";\n12\timport assert from \"node:assert/strict\";\n13\t\n14\timport { Engine, admin, type EngineConfig, type SoftFallback } from \"../src/index.js\";\n15\timport { freshDbPath } from \"./helpers.js\";\n16\t\n17\ttest(\"Engine exposes five-verb shape plus instrumentation methods\", async () => {\n18\t  assert.equal(typeof Engine.open, \"function\", \"Engine.open must be a static method\");\n19\t\n20\t  const engine = await Engine.open(freshDbPath());\n21\t  try {\n22\t    for (const v of [\"write\", \"search\", \"close\"] as const) {\n23\t      assert.equal(\n24\t        typeof (engine as unknown as Record<string, unknown>)[v],\n25\t        \"function\",\n26\t        `engine must expose ${v}`,\n27\t      );\n28\t    }\n29\t\n30\t    for (const m of [\n31\t      \"drain\",\n32\t      \"counters\",\n33\t      \"setProfiling\",\n34\t      \"setSlowThresholdMs\",\n35\t      \"attachSubscriber\",\n36\t    ] as const) {\n37\t      assert.equal(\n38\t        typeof (engine as unknown as Record<string, unknown>)[m],\n39\t        \"function\",\n40\t        `engine must expose ${m}`,\n41\t      );\n42\t    }\n43\t  } finally {\n44\t    await engine.close();\n45\t  }\n46\t});\n47\t\n48\ttest(\"admin.configure is exported beside Engine\", async () => {\n49\t  assert.equal(typeof admin.configure, \"function\");\n50\t  const engine = await Engine.open(freshDbPath());\n51\t  try {\n52\t    const receipt = await admin.configure(engine, { name: \"default\", body: \"{}\" });\n53\t    assert.equal(typeof receipt.cursor, \"number\");\n54\t  } finally {\n55\t    await engine.close();\n56\t  }\n57\t});\n58\t\n59\ttest(\"Engine.open accepts engineConfig with camelCase knobs\", async () => {\n60\t  const cfg: EngineConfig = {\n61\t    embedderPoolSize: 2,\n62\t    schedulerRuntimeThreads: 4,\n63\t    provenanceRowCap: 1024,\n64\t    embedderCallTimeoutMs: 30_000,\n65\t    slowThresholdMs: 250,\n66\t  };\n67\t  const engine = await Engine.open(freshDbPath(), { engineConfig: cfg });\n68\t  try {\n69\t    assert.equal(engine.config.embedderPoolSize, 2);\n70\t    assert.equal(engine.config.schedulerRuntimeThreads, 4);\n71\t    assert.equal(engine.config.provenanceRowCap, 1024);\n72\t    assert.equal(engine.config.embedderCallTimeoutMs, 30_000);\n73\t    assert.equal(engine.config.slowThresholdMs, 250);\n74\t  } finally {\n75\t    await engine.close();\n76\t  }\n77\t});\n78\t\n79\ttest(\"write returns a typed receipt with cursor\", async () => {\n80\t  const engine = await Engine.open(freshDbPath());\n81\t  try {\n82\t    const receipt = await engine.write([{ kind: \"doc\", body: \"{}\" }]);\n83\t    assert.equal(typeof receipt.cursor, \"number\");\n84\t  } finally {\n85\t    await engine.close();\n86\t  }\n87\t});\n88\t\n89\ttest(\"search returns soft-fallback null by default\", async () => {\n90\t  const engine = await Engine.open(freshDbPath());\n91\t  try {\n92\t    const result = await engine.search(\"hello\");\n93\t    assert.equal(result.softFallback, null);\n94\t    assert.equal(typeof result.projectionCursor, \"number\");\n95\t  } finally {\n96\t    await engine.close();\n97\t  }\n98\t});\n99\t\n100\ttest(\"SoftFallback branch is the typed two-member union\", () => {\n101\t  const v: SoftFallback = { branch: \"vector\" };\n102\t  const t: SoftFallback = { branch: \"text\" };\n103\t  assert.equal(v.branch, \"vector\");\n104\t  assert.equal(t.branch, \"text\");\n105\t});\n106\t\n107\ttest(\"instrumentation stubs return canonical types\", async () => {\n108\t  const engine = await Engine.open(freshDbPath());\n109\t  try {\n110\t    await engine.drain(0);\n111\t    const snap = engine.counters();\n112\t    assert.ok(snap !== undefined);\n113\t    engine.setProfiling(true);\n114\t    engine.setSlowThresholdMs(100);\n115\t    engine.attachSubscriber(() => undefined, {});\n116\t  } finally {\n117\t    await engine.close();\n118\t  }\n119\t});\n120\t"}]},"parent_tool_use_id":null,"session_id":"e03e003f-16a4-48ce-9857-522e8e7e136e","uuid":"f9a77475-1596-4e81-b9c5-4270a2274c9b","timestamp":"2026-05-17T20:45:18.041Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-TX-ts-python-parity-20260517T204414Z/src/ts/tests/surface.test.ts","content":"// Surface assertions for the TypeScript SDK.\n//\n// Binds AC-057a (REQ-053): five-verb runtime SDK surface.\n//\n// Pins the five-verb top-level surface, the engine-attached\n// instrumentation methods, the options.engineConfig camelCase knobs,\n// the soft-fallback record shape, and the FathomDbError single-rooted\n// hierarchy per `dev/interfaces/typescript.md` and\n// `dev/design/bindings.md` § 3.\n\nimport test from \"node:test\";\nimport assert from \"node:assert/strict\";\n\nimport { Engine, admin, type EngineConfig, type SoftFallback } from \"../src/index.js\";\nimport { freshDbPath } from \"./helpers.js\";\n\ntest(\"Engine exposes five-verb shape plus instrumentation methods\", async () => {\n  assert.equal(typeof Engine.open, \"function\", \"Engine.open must be a static method\");\n\n  const engine = await Engine.open(freshDbPath());\n  try {\n    for (const v of [\"write\", \"search\", \"close\"] as const) {\n      assert.equal(\n        typeof (engine as unknown as Record<string, unknown>)[v],\n        \"function\",\n        `engine must expose ${v}`,\n      );\n    }\n\n    for (const m of [\n      \"drain\",\n      \"counters\",\n      \"setProfiling\",\n      \"setSlowThresholdMs\",\n      \"attachSubscriber\",\n    ] as const) {\n      assert.equal(\n        typeof (engine as unknown as Record<string, unknown>)[m],\n        \"function\",\n        `engine must expose ${m}`,\n      );\n    }\n  } finally {\n    await engine.close();\n  }\n});\n\ntest(\"admin.configure is exported beside Engine\", async () => {\n  assert.equal(typeof admin.configure, \"function\");\n  const engine = await Engine.open(freshDbPath());\n  try {\n    const receipt = await admin.configure(engine, { name: \"default\", body: \"{}\" });\n    assert.equal(typeof receipt.cursor, \"number\");\n  } finally {\n    await engine.close();\n  }\n});\n\ntest(\"Engine.open accepts engineConfig with camelCase knobs\", async () => {\n  const cfg: EngineConfig = {\n    embedderPoolSize: 2,\n    schedulerRuntimeThreads: 4,\n    provenanceRowCap: 1024,\n    embedderCallTimeoutMs: 30_000,\n    slowThresholdMs: 250,\n  };\n  const engine = await Engine.open(freshDbPath(), { engineConfig: cfg });\n  try {\n    assert.equal(engine.config.embedderPoolSize, 2);\n    assert.equal(engine.config.schedulerRuntimeThreads, 4);\n    assert.equal(engine.config.provenanceRowCap, 1024);\n    assert.equal(engine.config.embedderCallTimeoutMs, 30_000);\n    assert.equal(engine.config.slowThresholdMs, 250);\n  } finally {\n    await engine.close();\n  }\n});\n\ntest(\"write returns a typed receipt with cursor\", async () => {\n  const engine = await Engine.open(freshDbPath());\n  try {\n    const receipt = await engine.write([{ kind: \"doc\", body: \"{}\" }]);\n    assert.equal(typeof receipt.cursor, \"number\");\n  } finally {\n    await engine.close();\n  }\n});\n\ntest(\"search returns soft-fallback null by default\", async () => {\n  const engine = await Engine.open(freshDbPath());\n  try {\n    const result = await engine.search(\"hello\");\n    assert.equal(result.softFallback, null);\n    assert.equal(typeof result.projectionCursor, \"number\");\n  } finally {\n    await engine.close();\n  }\n});\n\ntest(\"SoftFallback branch is the typed two-member union\", () => {\n  const v: SoftFallback = { branch: \"vector\" };\n  const t: SoftFallback = { branch: \"text\" };\n  assert.equal(v.branch, \"vector\");\n  assert.equal(t.branch, \"text\");\n});\n\ntest(\"instrumentation stubs return canonical types\", async () => {\n  const engine = await Engine.open(freshDbPath());\n  try {\n    await engine.drain(0);\n    const snap = engine.counters();\n    assert.ok(snap !== undefined);\n    engine.setProfiling(true);\n    engine.setSlowThresholdMs(100);\n    engine.attachSubscriber(() => undefined, {});\n  } finally {\n    await engine.close();\n  }\n});\n","numLines":120,"startLine":1,"totalLines":120}}}
