{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0197qAS7zSkLqc4KFc8wUPBw","type":"tool_result","content":"1\t// FathomDB TypeScript SDK public surface.\n2\t//\n3\t// Five-verb top-level surface (Engine.open, engine.write, engine.search,\n4\t// engine.close, admin.configure), engine-attached instrumentation, and\n5\t// the FathomDbError leaf-class hierarchy per\n6\t// `dev/interfaces/typescript.md` and `dev/design/bindings.md` § 3. The\n7\t// runtime is the napi-rs binding in `fathomdb-napi`; this file is a\n8\t// thin TS wrapper that funnels every native error through\n9\t// `rethrowTyped`.\n10\t\n11\timport { native, type NativeEngine } from \"./binding.js\";\n12\timport { rethrowTyped } from \"./errors.js\";\n13\timport { validateFfiString, validateFfiTree } from \"./validation.js\";\n14\t\n15\texport * from \"./errors.js\";\n16\t\n17\texport interface EngineConfig {\n18\t  embedderPoolSize?: number;\n19\t  schedulerRuntimeThreads?: number;\n20\t  provenanceRowCap?: number;\n21\t  embedderCallTimeoutMs?: number;\n22\t  slowThresholdMs?: number;\n23\t}\n24\t\n25\texport interface EngineOpenOptions {\n26\t  engineConfig?: EngineConfig;\n27\t}\n28\t\n29\texport interface WriteReceipt {\n30\t  cursor: number;\n31\t}\n32\t\n33\texport type SoftFallbackBranch = \"vector\" | \"text\";\n34\t\n35\texport interface SoftFallback {\n36\t  branch: SoftFallbackBranch;\n37\t}\n38\t\n39\texport interface SearchResult {\n40\t  projectionCursor: number;\n41\t  softFallback: SoftFallback | null;\n42\t  results: string[];\n43\t}\n44\t\n45\texport interface CounterSnapshot {\n46\t  queries: number;\n47\t  writes: number;\n48\t  writeRows: number;\n49\t  adminOps: number;\n50\t  cacheHit: number;\n51\t  cacheMiss: number;\n52\t}\n53\t\n54\texport interface SubscriberEvent {\n55\t  [key: string]: unknown;\n56\t}\n57\t\n58\texport type SubscriberCallback = (event: SubscriberEvent) => void;\n59\t\n60\texport interface AttachSubscriberOptions {\n61\t  heartbeatIntervalMs?: number;\n62\t}\n63\t\n64\texport interface AdminConfigureOptions {\n65\t  name: string;\n66\t  body: string;\n67\t}\n68\t\n69\tasync function intercept<T>(fn: () => Promise<T>): Promise<T> {\n70\t  try {\n71\t    return await fn();\n72\t  } catch (err) {\n73\t    rethrowTyped(err);\n74\t  }\n75\t}\n76\t\n77\tfunction interceptSync<T>(fn: () => T): T {\n78\t  try {\n79\t    return fn();\n80\t  } catch (err) {\n81\t    rethrowTyped(err);\n82\t  }\n83\t}\n84\t\n85\texport class Engine {\n86\t  readonly #native: NativeEngine;\n87\t  readonly config: EngineConfig;\n88\t\n89\t  private constructor(inner: NativeEngine, config: EngineConfig) {\n90\t    this.#native = inner;\n91\t    this.config = config;\n92\t  }\n93\t\n94\t  static async open(path: string, options: EngineOpenOptions = {}): Promise<Engine> {\n95\t    validateFfiString(path);\n96\t    const inner = await intercept(() => native.Engine.open(path, options));\n97\t    return new Engine(inner, options.engineConfig ?? {});\n98\t  }\n99\t\n100\t  async write(batch: unknown[] = []): Promise<WriteReceipt> {\n101\t    validateFfiTree(batch);\n102\t    return intercept(() => this.#native.write(batch));\n103\t  }\n104\t\n105\t  async search(query: string): Promise<SearchResult> {\n106\t    validateFfiString(query);\n107\t    const r = await intercept(() => this.#native.search(query));\n108\t    const branch = r.softFallback?.branch;\n109\t    return {\n110\t      projectionCursor: r.projectionCursor,\n111\t      softFallback:\n112\t        branch === \"vector\" || branch === \"text\" ? { branch } : null,\n113\t      results: r.results,\n114\t    };\n115\t  }\n116\t\n117\t  async close(): Promise<void> {\n118\t    await intercept(() => this.#native.close());\n119\t  }\n120\t\n121\t  async drain(timeoutMs: number): Promise<void> {\n122\t    await intercept(() => this.#native.drain(timeoutMs));\n123\t  }\n124\t\n125\t  counters(): CounterSnapshot {\n126\t    return interceptSync(() => this.#native.counters());\n127\t  }\n128\t\n129\t  setProfiling(enabled: boolean): void {\n130\t    interceptSync(() => this.#native.setProfiling(enabled));\n131\t  }\n132\t\n133\t  setSlowThresholdMs(value: number): void {\n134\t    interceptSync(() => this.#native.setSlowThresholdMs(value));\n135\t  }\n136\t\n137\t  attachSubscriber(callback: SubscriberCallback, options: AttachSubscriberOptions = {}): void {\n138\t    interceptSync(() => this.#native.attachSubscriber(callback, options));\n139\t  }\n140\t\n141\t  /** @internal — handle to the napi-rs binding, used by `admin.configure`. */\n142\t  get _native(): NativeEngine {\n143\t    return this.#native;\n144\t  }\n145\t}\n146\t\n147\texport const admin = {\n148\t  async configure(engine: Engine, options: AdminConfigureOptions): Promise<WriteReceipt> {\n149\t    validateFfiString(options.name);\n150\t    validateFfiString(options.body);\n151\t    return intercept(() => native.adminConfigure(engine._native, options));\n152\t  },\n153\t};\n154\t"}]},"parent_tool_use_id":null,"session_id":"e03e003f-16a4-48ce-9857-522e8e7e136e","uuid":"2b9e2f64-ba01-4726-8d8d-a6bd30eaaf69","timestamp":"2026-05-17T20:44:29.236Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-TX-ts-python-parity-20260517T204414Z/src/ts/src/index.ts","content":"// FathomDB TypeScript SDK public surface.\n//\n// Five-verb top-level surface (Engine.open, engine.write, engine.search,\n// engine.close, admin.configure), engine-attached instrumentation, and\n// the FathomDbError leaf-class hierarchy per\n// `dev/interfaces/typescript.md` and `dev/design/bindings.md` § 3. The\n// runtime is the napi-rs binding in `fathomdb-napi`; this file is a\n// thin TS wrapper that funnels every native error through\n// `rethrowTyped`.\n\nimport { native, type NativeEngine } from \"./binding.js\";\nimport { rethrowTyped } from \"./errors.js\";\nimport { validateFfiString, validateFfiTree } from \"./validation.js\";\n\nexport * from \"./errors.js\";\n\nexport interface EngineConfig {\n  embedderPoolSize?: number;\n  schedulerRuntimeThreads?: number;\n  provenanceRowCap?: number;\n  embedderCallTimeoutMs?: number;\n  slowThresholdMs?: number;\n}\n\nexport interface EngineOpenOptions {\n  engineConfig?: EngineConfig;\n}\n\nexport interface WriteReceipt {\n  cursor: number;\n}\n\nexport type SoftFallbackBranch = \"vector\" | \"text\";\n\nexport interface SoftFallback {\n  branch: SoftFallbackBranch;\n}\n\nexport interface SearchResult {\n  projectionCursor: number;\n  softFallback: SoftFallback | null;\n  results: string[];\n}\n\nexport interface CounterSnapshot {\n  queries: number;\n  writes: number;\n  writeRows: number;\n  adminOps: number;\n  cacheHit: number;\n  cacheMiss: number;\n}\n\nexport interface SubscriberEvent {\n  [key: string]: unknown;\n}\n\nexport type SubscriberCallback = (event: SubscriberEvent) => void;\n\nexport interface AttachSubscriberOptions {\n  heartbeatIntervalMs?: number;\n}\n\nexport interface AdminConfigureOptions {\n  name: string;\n  body: string;\n}\n\nasync function intercept<T>(fn: () => Promise<T>): Promise<T> {\n  try {\n    return await fn();\n  } catch (err) {\n    rethrowTyped(err);\n  }\n}\n\nfunction interceptSync<T>(fn: () => T): T {\n  try {\n    return fn();\n  } catch (err) {\n    rethrowTyped(err);\n  }\n}\n\nexport class Engine {\n  readonly #native: NativeEngine;\n  readonly config: EngineConfig;\n\n  private constructor(inner: NativeEngine, config: EngineConfig) {\n    this.#native = inner;\n    this.config = config;\n  }\n\n  static async open(path: string, options: EngineOpenOptions = {}): Promise<Engine> {\n    validateFfiString(path);\n    const inner = await intercept(() => native.Engine.open(path, options));\n    return new Engine(inner, options.engineConfig ?? {});\n  }\n\n  async write(batch: unknown[] = []): Promise<WriteReceipt> {\n    validateFfiTree(batch);\n    return intercept(() => this.#native.write(batch));\n  }\n\n  async search(query: string): Promise<SearchResult> {\n    validateFfiString(query);\n    const r = await intercept(() => this.#native.search(query));\n    const branch = r.softFallback?.branch;\n    return {\n      projectionCursor: r.projectionCursor,\n      softFallback:\n        branch === \"vector\" || branch === \"text\" ? { branch } : null,\n      results: r.results,\n    };\n  }\n\n  async close(): Promise<void> {\n    await intercept(() => this.#native.close());\n  }\n\n  async drain(timeoutMs: number): Promise<void> {\n    await intercept(() => this.#native.drain(timeoutMs));\n  }\n\n  counters(): CounterSnapshot {\n    return interceptSync(() => this.#native.counters());\n  }\n\n  setProfiling(enabled: boolean): void {\n    interceptSync(() => this.#native.setProfiling(enabled));\n  }\n\n  setSlowThresholdMs(value: number): void {\n    interceptSync(() => this.#native.setSlowThresholdMs(value));\n  }\n\n  attachSubscriber(callback: SubscriberCallback, options: AttachSubscriberOptions = {}): void {\n    interceptSync(() => this.#native.attachSubscriber(callback, options));\n  }\n\n  /** @internal — handle to the napi-rs binding, used by `admin.configure`. */\n  get _native(): NativeEngine {\n    return this.#native;\n  }\n}\n\nexport const admin = {\n  async configure(engine: Engine, options: AdminConfigureOptions): Promise<WriteReceipt> {\n    validateFfiString(options.name);\n    validateFfiString(options.body);\n    return intercept(() => native.adminConfigure(engine._native, options));\n  },\n};\n","numLines":154,"startLine":1,"totalLines":154}}}
