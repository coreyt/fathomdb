{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Pd75j9Xt9xXyBoLxtk6oMC","type":"tool_result","content":"1\t\"\"\"AC-060a — typed error payload coverage.\n2\t\n3\tThe engine returns enum variants with typed fields; the binding\n4\ttranslator (`engine_error_to_py` / `engine_open_error_to_py`) attaches\n5\tthose fields as Python attributes on the raised exception so callers\n6\tcan dispatch and inspect without parsing message text.\n7\t\"\"\"\n8\t\n9\tfrom __future__ import annotations\n10\t\n11\timport pytest\n12\t\n13\tfrom fathomdb import Engine\n14\tfrom fathomdb.errors import (\n15\t    CorruptionError,\n16\t    DatabaseLockedError,\n17\t    EmbedderDimensionMismatchError,\n18\t    EmbedderError,\n19\t    EmbedderNotConfiguredError,\n20\t    EngineError,\n21\t    KindNotVectorIndexedError,\n22\t    VectorError,\n23\t)\n24\t\n25\t\n26\tdef test_database_locked_error_attr_round_trip() -> None:\n27\t    err = DatabaseLockedError(holder_pid=12345)\n28\t    assert err.holder_pid == 12345\n29\t\n30\t\n31\tdef test_database_locked_engine_triggered(db_path: str) -> None:\n32\t    \"\"\"Opening the same database twice in one process must surface\n33\t    `DatabaseLockedError` with the `holder_pid` attribute populated\n34\t    (or `None` when the lockfile is unparseable).\"\"\"\n35\t\n36\t    a = Engine.open(db_path)\n37\t    try:\n38\t        with pytest.raises(DatabaseLockedError) as excinfo:\n39\t            Engine.open(db_path)\n40\t        assert hasattr(excinfo.value, \"holder_pid\")\n41\t        assert excinfo.value.holder_pid is None or isinstance(\n42\t            excinfo.value.holder_pid, int\n43\t        )\n44\t    finally:\n45\t        a.close()\n46\t\n47\t\n48\tdef test_corruption_error_attrs_round_trip() -> None:\n49\t    err = CorruptionError(\n50\t        kind=\"HeaderMalformed\",\n51\t        stage=\"HeaderProbe\",\n52\t        recovery_hint_code=\"E_CORRUPT_HEADER\",\n53\t        doc_anchor=\"design/recovery.md#header-malformed\",\n54\t    )\n55\t    assert err.kind == \"HeaderMalformed\"\n56\t    assert err.stage == \"HeaderProbe\"\n57\t    assert err.recovery_hint_code == \"E_CORRUPT_HEADER\"\n58\t    assert err.doc_anchor == \"design/recovery.md#header-malformed\"\n59\t\n60\t\n61\tdef test_embedder_not_configured_is_distinct_leaf_under_embedder_error() -> None:\n62\t    err = EmbedderNotConfiguredError(\"no embedder\")\n63\t    assert isinstance(err, EmbedderNotConfiguredError)\n64\t    assert isinstance(err, EmbedderError)\n65\t    assert isinstance(err, EngineError)\n66\t    assert EmbedderNotConfiguredError is not EmbedderError\n67\t\n68\t\n69\tdef test_kind_not_vector_indexed_is_distinct_leaf_under_vector_error() -> None:\n70\t    err = KindNotVectorIndexedError(\"kind X not vector indexed\")\n71\t    assert isinstance(err, KindNotVectorIndexedError)\n72\t    assert isinstance(err, VectorError)\n73\t    assert isinstance(err, EngineError)\n74\t    assert KindNotVectorIndexedError is not VectorError\n75\t\n76\t\n77\tdef test_embedder_dimension_mismatch_attrs_round_trip() -> None:\n78\t    err = EmbedderDimensionMismatchError(stored=384, supplied=768)\n79\t    assert err.stored == 384\n80\t    assert err.supplied == 768\n81\t    assert isinstance(err.stored, int)\n82\t    assert isinstance(err.supplied, int)\n83\t"}]},"parent_tool_use_id":null,"session_id":"e03e003f-16a4-48ce-9857-522e8e7e136e","uuid":"70078b56-e8d4-47ae-84e4-d2bdaef213d7","timestamp":"2026-05-17T20:45:31.722Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-TX-ts-python-parity-20260517T204414Z/src/python/tests/test_typed_errors.py","content":"\"\"\"AC-060a — typed error payload coverage.\n\nThe engine returns enum variants with typed fields; the binding\ntranslator (`engine_error_to_py` / `engine_open_error_to_py`) attaches\nthose fields as Python attributes on the raised exception so callers\ncan dispatch and inspect without parsing message text.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport pytest\n\nfrom fathomdb import Engine\nfrom fathomdb.errors import (\n    CorruptionError,\n    DatabaseLockedError,\n    EmbedderDimensionMismatchError,\n    EmbedderError,\n    EmbedderNotConfiguredError,\n    EngineError,\n    KindNotVectorIndexedError,\n    VectorError,\n)\n\n\ndef test_database_locked_error_attr_round_trip() -> None:\n    err = DatabaseLockedError(holder_pid=12345)\n    assert err.holder_pid == 12345\n\n\ndef test_database_locked_engine_triggered(db_path: str) -> None:\n    \"\"\"Opening the same database twice in one process must surface\n    `DatabaseLockedError` with the `holder_pid` attribute populated\n    (or `None` when the lockfile is unparseable).\"\"\"\n\n    a = Engine.open(db_path)\n    try:\n        with pytest.raises(DatabaseLockedError) as excinfo:\n            Engine.open(db_path)\n        assert hasattr(excinfo.value, \"holder_pid\")\n        assert excinfo.value.holder_pid is None or isinstance(\n            excinfo.value.holder_pid, int\n        )\n    finally:\n        a.close()\n\n\ndef test_corruption_error_attrs_round_trip() -> None:\n    err = CorruptionError(\n        kind=\"HeaderMalformed\",\n        stage=\"HeaderProbe\",\n        recovery_hint_code=\"E_CORRUPT_HEADER\",\n        doc_anchor=\"design/recovery.md#header-malformed\",\n    )\n    assert err.kind == \"HeaderMalformed\"\n    assert err.stage == \"HeaderProbe\"\n    assert err.recovery_hint_code == \"E_CORRUPT_HEADER\"\n    assert err.doc_anchor == \"design/recovery.md#header-malformed\"\n\n\ndef test_embedder_not_configured_is_distinct_leaf_under_embedder_error() -> None:\n    err = EmbedderNotConfiguredError(\"no embedder\")\n    assert isinstance(err, EmbedderNotConfiguredError)\n    assert isinstance(err, EmbedderError)\n    assert isinstance(err, EngineError)\n    assert EmbedderNotConfiguredError is not EmbedderError\n\n\ndef test_kind_not_vector_indexed_is_distinct_leaf_under_vector_error() -> None:\n    err = KindNotVectorIndexedError(\"kind X not vector indexed\")\n    assert isinstance(err, KindNotVectorIndexedError)\n    assert isinstance(err, VectorError)\n    assert isinstance(err, EngineError)\n    assert KindNotVectorIndexedError is not VectorError\n\n\ndef test_embedder_dimension_mismatch_attrs_round_trip() -> None:\n    err = EmbedderDimensionMismatchError(stored=384, supplied=768)\n    assert err.stored == 384\n    assert err.supplied == 768\n    assert isinstance(err.stored, int)\n    assert isinstance(err.supplied, int)\n","numLines":83,"startLine":1,"totalLines":83}}}
