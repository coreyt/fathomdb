    # Phase 1 — retrieval (CPU; sequential). Build every (question, arm) answer task.
    @dataclass
    class _Task:
        qr: "QuestionResult"
        q: Question
        arm: str
        context: list[str]

    tasks: list[_Task] = []
    for q in questions:
