dev/plans/runs/12-D-durability-harnesses-20260517T185755Z.log:100:{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016Ep3Gm3KQpfm1vgEbhaD4u","type":"tool_result","content":"380\tfn ac_005b_profile_record_typed_numeric_fields() {\n381\t    let (_dir, engine) = fixture();\n382\t    let sink = Arc::new(CapturingSubscriber::default());\n383\t    let _sub = engine.subscribe(sink.clone());\n384\t    engine.set_profiling(true).expect(\"enable profiling\");\n385\t    let _ = engine.search(\"hello\").expect(\"search\");\n386\t\n387\t    let records = sink.profile_records.lock().unwrap();\n388\t    let record = records.first().expect(\"at least one profile record\");\n389\t    let _: u64 = record.wall_clock_ms;\n390\t    let _: u64 = record.step_count;\n391\t    let _: i64 = record.cache_delta;\n392\t}\n393\t\n394\t// AC-006: SQLite-internal events surfaced with typed source tag.\n395\t//\n396\t// Page-1 magic-header bit-flip flavor: documented page-corruption tool\n397\t// (`corruption::corrupt_database_header`) overwrites the SQLite magic\n398\t// string. Reopen surfaces `SQLITE_NOTADB` and the engine emits a\n399\t// `(SqliteInternal, Corruption, code = \"SQLITE_NOTADB\")` event.\n400\t#[test]\n401\tfn ac_006_sqlite_internal_events_typed_source() {\n402\t    let dir = TempDir::new().unwrap();\n403\t    let path = dir.path().join(\"corrupt-open.sqlite\");\n404\t    let opened = Engine::open(&path).expect(\"seed database\");\n405\t    opened.engine.close().expect(\"close before corruption\");\n406\t    corruption::corrupt_database_header(&path);\n407\t\n408\t    let sink = Arc::new(CapturingSubscriber::default());\n409\t    let err = Engine::open_with_subscriber_for_test(&path, sink.clone())\n410\t        .expect_err(\"corrupted database must fail open\");\n411\t\n412\t    assert!(matches!(err, EngineOpenError::Corruption(_)));\n413\t\n414\t    let captured = sink.events.lock().unwrap();\n415\t    assert!(captured.iter().any(|e| {\n416\t        e.source == EventSource::SqliteInternal\n417\t            && e.category == EventCategory::Corruption\n418\t            && e.code == Some(\"SQLITE_NOTADB\")\n419\t    }));\n420\t}\n421\t\n422\t// AC-006: Interior-page bit-flip flavor.\n423\t//\n424\t// Documented page-corruption tool (`corruption::corrupt_interior_page_byte`)\n425\t// XORs a byte inside the page-1 b-tree header (offset 100, the first byte\n426\t// of the b-tree page header that follows the SQLite file header). The\n427\t// SQLite magic string is preserved, so reopen reaches the engine's\n428\t// schema probe (`PRAGMA schema_version`); decoding the corrupt b-tree\n429\t// page surfaces `SQLITE_CORRUPT`. The engine emits a\n430\t// `(SqliteInternal, Corruption, code = \"SQLITE_CORRUPT\")` event.\n431\t#[test]\n432\tfn ac_006_interior_page_corruption_emits_sqlite_corrupt() {\n433\t    let dir = TempDir::new().unwrap();\n434\t    let path = dir.path().join(\"corrupt-interior.sqlite\");\n435\t    let opened = Engine::open(&path).expect(\"seed database\");\n436\t    // Force some user data so b-tree pages have non-trivial content;\n437\t    // not strictly required for the SQLITE_CORRUPT trip, but makes the\n438\t    // corruption locator deterministic across runs.\n439\t    opened\n440\t        .engine\n441\t        .write(&[PreparedWrite::Node {\n442\t            kind: \"doc\".to_string(),\n443\t            body: \"interior\".to_string(),\n444\t            source_id: None,\n445\t        }])\n446\t        .expect(\"seed write\");\n447\t    opened.engine.close().expect(\"close before corruption\");\n448\t    // Page index 0, byte offset 100 (start of the page-1 b-tree header),\n449\t    // XOR mask 0xFF (flips every bit). Preserves the magic header.\n450\t    corruption::corrupt_interior_page_byte(&path, 0, 100, 0xFF);\n451\t\n452\t    let sink = Arc::new(CapturingSubscriber::default());\n453\t    let err = Engine::open_with_subscriber_for_test(&path, sink.clone())\n454\t        .expect_err(\"corrupted interior page must fail open\");\n455\t\n456\t    assert!(matches!(err, EngineOpenError::Corruption(_)));\n457\t\n458\t    let captured = sink.events.lock().unwrap();\n459\t    assert!(\n460\t        captured.iter().any(|e| {\n461\t            e.source == EventSource::SqliteInternal\n462\t                && e.category == EventCategory::Corruption\n463\t                && e.code == Some(\"SQLITE_CORRUPT\")\n464\t        }),\n465\t        \"expected (SqliteInternal, Corruption, SQLITE_CORRUPT) event, saw: {:?}\",\n466\t        captured.iter().map(|e| (e.source, e.category, e.code)).collect::<Vec<_>>(),\n467\t    );\n468\t}\n469\t\n470\t// AC-007a: Slow-statement event when wall-clock crosses default threshold.\n471\t//\n472\t// Measurement: default threshold = 100 ms (REQ-006a). The\n473\t// deterministic-slow-cte fixture (≥ 200 ms guaranteed by recursive-CTE\n474\t// counter) emits exactly one slow-statement signal identifying the SQL.\n475\t#[test]\n476\tfn ac_007a_slow_statement_event_at_default_threshold() {\n477\t    let (_dir, engine) = fixture();\n478\t    let sink = Arc::new(CapturingSubscriber::default());\n479\t    let _sub = engine.subscribe(sink.clone());\n480\t    engine.execute_for_test(SLOW_CTE).expect(\"slow cte\");\n481\t\n482\t    let signals = sink.slow_statements.lock().unwrap();\n483\t    assert_eq!(\n484\t        signals.len(),\n485\t        1,\n486\t        \"expected exactly one slow-statement signal at default threshold, saw {}\",\n487\t        signals.len(),\n488\t    );\n489\t    assert!(\n490\t        signals[0].statement.contains(\"RECURSIVE\"),\n491\t        \"slow signal must identify the statement; got: {:?}\",\n492\t        signals[0].statement,\n493\t    );\n494\t    assert!(\n495\t        signals[0].wall_clock_ms >= 100,\n496\t        \"slow signal wall_clock_ms must be ≥ 100 ms (default threshold); got {} ms\",\n497\t        signals[0].wall_clock_ms,\n498\t    );\n499\t}"}]},"parent_tool_use_id":null,"session_id":"af81e32e-38ea-41b6-ab82-41ce4c91617f","uuid":"8525f326-d2f8-45af-bf2f-3b92fff60518","timestamp":"2026-05-17T18:58:07.342Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-D-durability-harnesses-20260517T185755Z/src/rust/crates/fathomdb-engine/tests/lifecycle_observability.rs","content":"fn ac_005b_profile_record_typed_numeric_fields() {\n    let (_dir, engine) = fixture();\n    let sink = Arc::new(CapturingSubscriber::default());\n    let _sub = engine.subscribe(sink.clone());\n    engine.set_profiling(true).expect(\"enable profiling\");\n    let _ = engine.search(\"hello\").expect(\"search\");\n\n    let records = sink.profile_records.lock().unwrap();\n    let record = records.first().expect(\"at least one profile record\");\n    let _: u64 = record.wall_clock_ms;\n    let _: u64 = record.step_count;\n    let _: i64 = record.cache_delta;\n}\n\n// AC-006: SQLite-internal events surfaced with typed source tag.\n//\n// Page-1 magic-header bit-flip flavor: documented page-corruption tool\n// (`corruption::corrupt_database_header`) overwrites the SQLite magic\n// string. Reopen surfaces `SQLITE_NOTADB` and the engine emits a\n// `(SqliteInternal, Corruption, code = \"SQLITE_NOTADB\")` event.\n#[test]\nfn ac_006_sqlite_internal_events_typed_source() {\n    let dir = TempDir::new().unwrap();\n    let path = dir.path().join(\"corrupt-open.sqlite\");\n    let opened = Engine::open(&path).expect(\"seed database\");\n    opened.engine.close().expect(\"close before corruption\");\n    corruption::corrupt_database_header(&path);\n\n    let sink = Arc::new(CapturingSubscriber::default());\n    let err = Engine::open_with_subscriber_for_test(&path, sink.clone())\n        .expect_err(\"corrupted database must fail open\");\n\n    assert!(matches!(err, EngineOpenError::Corruption(_)));\n\n    let captured = sink.events.lock().unwrap();\n    assert!(captured.iter().any(|e| {\n        e.source == EventSource::SqliteInternal\n            && e.category == EventCategory::Corruption\n            && e.code == Some(\"SQLITE_NOTADB\")\n    }));\n}\n\n// AC-006: Interior-page bit-flip flavor.\n//\n// Documented page-corruption tool (`corruption::corrupt_interior_page_byte`)\n// XORs a byte inside the page-1 b-tree header (offset 100, the first byte\n// of the b-tree page header that follows the SQLite file header). The\n// SQLite magic string is preserved, so reopen reaches the engine's\n// schema probe (`PRAGMA schema_version`); decoding the corrupt b-tree\n// page surfaces `SQLITE_CORRUPT`. The engine emits a\n// `(SqliteInternal, Corruption, code = \"SQLITE_CORRUPT\")` event.\n#[test]\nfn ac_006_interior_page_corruption_emits_sqlite_corrupt() {\n    let dir = TempDir::new().unwrap();\n    let path = dir.path().join(\"corrupt-interior.sqlite\");\n    let opened = Engine::open(&path).expect(\"seed database\");\n    // Force some user data so b-tree pages have non-trivial content;\n    // not strictly required for the SQLITE_CORRUPT trip, but makes the\n    // corruption locator deterministic across runs.\n    opened\n        .engine\n        .write(&[PreparedWrite::Node {\n            kind: \"doc\".to_string(),\n            body: \"interior\".to_string(),\n            source_id: None,\n        }])\n        .expect(\"seed write\");\n    opened.engine.close().expect(\"close before corruption\");\n    // Page index 0, byte offset 100 (start of the page-1 b-tree header),\n    // XOR mask 0xFF (flips every bit). Preserves the magic header.\n    corruption::corrupt_interior_page_byte(&path, 0, 100, 0xFF);\n\n    let sink = Arc::new(CapturingSubscriber::default());\n    let err = Engine::open_with_subscriber_for_test(&path, sink.clone())\n        .expect_err(\"corrupted interior page must fail open\");\n\n    assert!(matches!(err, EngineOpenError::Corruption(_)));\n\n    let captured = sink.events.lock().unwrap();\n    assert!(\n        captured.iter().any(|e| {\n            e.source == EventSource::SqliteInternal\n                && e.category == EventCategory::Corruption\n                && e.code == Some(\"SQLITE_CORRUPT\")\n        }),\n        \"expected (SqliteInternal, Corruption, SQLITE_CORRUPT) event, saw: {:?}\",\n        captured.iter().map(|e| (e.source, e.category, e.code)).collect::<Vec<_>>(),\n    );\n}\n\n// AC-007a: Slow-statement event when wall-clock crosses default threshold.\n//\n// Measurement: default threshold = 100 ms (REQ-006a). The\n// deterministic-slow-cte fixture (≥ 200 ms guaranteed by recursive-CTE\n// counter) emits exactly one slow-statement signal identifying the SQL.\n#[test]\nfn ac_007a_slow_statement_event_at_default_threshold() {\n    let (_dir, engine) = fixture();\n    let sink = Arc::new(CapturingSubscriber::default());\n    let _sub = engine.subscribe(sink.clone());\n    engine.execute_for_test(SLOW_CTE).expect(\"slow cte\");\n\n    let signals = sink.slow_statements.lock().unwrap();\n    assert_eq!(\n        signals.len(),\n        1,\n        \"expected exactly one slow-statement signal at default threshold, saw {}\",\n        signals.len(),\n    );\n    assert!(\n        signals[0].statement.contains(\"RECURSIVE\"),\n        \"slow signal must identify the statement; got: {:?}\",\n        signals[0].statement,\n    );\n    assert!(\n        signals[0].wall_clock_ms >= 100,\n        \"slow signal wall_clock_ms must be ≥ 100 ms (default threshold); got {} ms\",\n        signals[0].wall_clock_ms,\n    );\n}","numLines":120,"startLine":380,"totalLines":663}}}
