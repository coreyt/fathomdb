// markdownlint config. https://github.com/DavidAnson/markdownlint/blob/main/doc/Rules.md
{
  "default": true,

  // MD013 line-length: disabled. Tables, URLs, and quoted research artifacts
  // routinely exceed any sensible cap. Wrapping mid-line in agent-facing
  // markdown also fights prose-position discipline.
  "MD013": false,

  // MD033 inline HTML: allowed. mkdocs themes use HTML for tabs/admonitions;
  // ADRs occasionally use <details>.
  "MD033": false,

  // MD041 first-line-h1: keep on. Top-level files should start with H1.

  // MD024 duplicate headings: allow within different sections (siblings).
  "MD024": { "siblings_only": true },

  // MD036 emphasis-as-heading: allowed (used in research artifacts).
  "MD036": false,

  // MD025 single-title: don't count frontmatter `title:` as an H1.
  // All docs use YAML frontmatter + a body H1; treating frontmatter title
  // as an H1 would make every such file a false positive.
  "MD025": { "front_matter_title": "" },

  // MD049/MD050 emphasis-style: align with prettier's default (underscore for
  // _emphasis_, double-asterisk for **strong**) so the two formatters don't
  // fight. Prettier writes `_emphasis_`; without this override markdownlint
  // would re-flag every prettier-formatted file.
  "MD049": { "style": "underscore" },
  "MD050": { "style": "asterisk" }
}

---
// markdownlint-cli2 globs and ignore patterns.
//
// Scope: all actively-maintained markdown. Only build outputs, vendored
// deps, tool caches, and the dev/archive historical record are excluded.
{
  "config": {
    "extends": ".markdownlint.jsonc"
  },
  "globs": ["**/*.md"],
  "ignores": [
    // Vendored / build outputs
    "node_modules/**",
    "src/ts/node_modules/**",
    "target/**",
    "site/**",
    "dist/**",
    "**/dist/**",
    ".venv/**",
    "**/.venv/**",
    ".cache/**",
    ".wake/**",

    // Research substrate — bare URLs are intentional citations.
    "dev/tmp/**",
    "dev/tmp2/**",
    "dev/tmp3/**",

    // Memex-related scratch notes (gitignored, mirrors .gitignore dev/memex/).
    "dev/memex/**",

    // Archived / resolved artifacts — historical record, not actively maintained.
    "dev/archive/**",

    // Agent-emitted run logs + reviewer verdicts — verbatim subagent output;
    // not actively maintained, formatting drifts per agent.
    "dev/plans/runs/**",

    // Local-only agent config (gitignored, not part of repo).
    ".claude/**",

    // Public docs are gated by `mkdocs build --strict` already.
    "docs/**"
  ]
}

