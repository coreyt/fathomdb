dev/plans/runs/11b-fix-1-20260516T214419Z.log:32:{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RKdkrummhUEZ7LYrci3P7a","type":"tool_result","content":"1\t//! napi-rs binding from the TypeScript SDK to `fathomdb-engine`.\n2\t//!\n3\t//! FFI safety contract (mirrors the PyO3 binding in `fathomdb-py`):\n4\t//!\n5\t//! 1. Every method that may block inside the engine runs its blocking\n6\t//!    body inside `tokio::task::spawn_blocking`, so the libuv main\n7\t//!    thread is never tied up. napi-rs's `#[napi] async fn` wraps\n8\t//!    return values as JS `Promise<T>`.\n9\t//! 2. Engine entry points return typed errors via [`engine_error_to_napi`] /\n10\t//!    [`engine_open_error_to_napi`] — single-switch mapping with no\n11\t//!    catch-all arm; the binding fails to compile when the Rust variant\n12\t//!    set drifts from the TS leaf-class set (AC-060a).\n13\t//! 3. Every string crossing the FFI is checked by [`validate_ffi_string`]\n14\t//!    for embedded NUL or unpaired UTF-16 surrogates BEFORE the writer\n15\t//!    transaction opens (AC-068a / AC-068b).\n16\t//! 4. Engine panics are caught via `catch_unwind` inside the spawn-blocking\n17\t//!    body and rethrown as a distinct `FathomDbPanicError` (code\n18\t//!    `FDB_PANIC`); the host process is not aborted (AC-067).\n19\t//\n20\t// why: napi-rs catches panics by default but throws a generic JS\n21\t// `Error` with `Status::GenericFailure` and a Rust-formatted message,\n22\t// which is hard to assert on. Explicit `catch_unwind` + a stable\n23\t// `FDB_PANIC` code lets the TS-side `rethrowTyped` map panics to a\n24\t// distinct `FathomDbPanicError` class that is intentionally NOT a\n25\t// `FathomDbError` subclass: panic is a contract bug, not a typed\n26\t// engine outcome.\n27\t\n28\tuse std::panic::{catch_unwind, AssertUnwindSafe};\n29\tuse std::sync::Arc;\n30\t\n31\tuse fathomdb_engine::{\n32\t    CorruptionDetail, CorruptionKind, Engine as RustEngine, EngineError as RustEngineError,\n33\t    EngineOpenError, OpenStage, PreparedWrite, SearchResult as RustSearchResult,\n34\t    SoftFallbackBranch, WriteReceipt as RustWriteReceipt,\n35\t};\n36\tuse napi::{Error, JsUnknown, Result, Status};\n37\tuse napi_derive::napi;\n38\tuse serde::Serialize;\n39\tuse serde_json::{json, Value as JsonValue};\n40\t\n41\t// ===== Error-code constants ===========================================\n42\t//\n43\t// One per typed leaf class on the TS side. The single-switch translator\n44\t// below maps every engine variant to exactly one of these codes; the TS\n45\t// `rethrowTyped` table maps each code to exactly one leaf class. Drift\n46\t// fails to compile (Rust side) or fails an exhaustiveness check (TS).\n47\t\n48\tconst CODE_STORAGE: &str = \"FDB_STORAGE\";\n49\tconst CODE_PROJECTION: &str = \"FDB_PROJECTION\";\n50\tconst CODE_VECTOR: &str = \"FDB_VECTOR\";\n51\tconst CODE_EMBEDDER: &str = \"FDB_EMBEDDER\";\n52\tconst CODE_EMBEDDER_NOT_CONFIGURED: &str = \"FDB_EMBEDDER_NOT_CONFIGURED\";\n53\tconst CODE_KIND_NOT_VECTOR_INDEXED: &str = \"FDB_KIND_NOT_VECTOR_INDEXED\";\n54\tconst CODE_EMBEDDER_DIMENSION_MISMATCH: &str = \"FDB_EMBEDDER_DIMENSION_MISMATCH\";\n55\tconst CODE_SCHEDULER: &str = \"FDB_SCHEDULER\";\n56\tconst CODE_OP_STORE: &str = \"FDB_OP_STORE\";\n57\tconst CODE_WRITE_VALIDATION: &str = \"FDB_WRITE_VALIDATION\";\n58\tconst CODE_SCHEMA_VALIDATION: &str = \"FDB_SCHEMA_VALIDATION\";\n59\tconst CODE_OVERLOADED: &str = \"FDB_OVERLOADED\";\n60\tconst CODE_CLOSING: &str = \"FDB_CLOSING\";\n61\tconst CODE_DATABASE_LOCKED: &str = \"FDB_DATABASE_LOCKED\";\n62\tconst CODE_CORRUPTION: &str = \"FDB_CORRUPTION\";\n63\tconst CODE_INCOMPATIBLE_SCHEMA_VERSION: &str = \"FDB_INCOMPATIBLE_SCHEMA_VERSION\";\n64\tconst CODE_MIGRATION: &str = \"FDB_MIGRATION\";\n65\tconst CODE_EMBEDDER_IDENTITY_MISMATCH: &str = \"FDB_EMBEDDER_IDENTITY_MISMATCH\";\n66\tconst CODE_PANIC: &str = \"FDB_PANIC\";\n67\t\n68\t// ===== Typed-error encoder ============================================\n69\t\n70\t/// Encode a typed-error envelope as JSON in `err.message` so the\n71\t/// TS-side `rethrowTyped` can reconstitute the right leaf class with\n72\t/// the right payload. napi-rs 2.x has no public API for throwing a\n73\t/// Rust-defined JS class directly; the envelope-in-message pattern is\n74\t/// the canonical workaround.\n75\t#[derive(Serialize)]\n76\tstruct TypedEnvelope<'a> {\n77\t    code: &'a str,\n78\t    message: String,\n79\t    payload: JsonValue,\n80\t}\n81\t\n82\tfn typed_error(code: &'static str, message: impl Into<String>, payload: JsonValue) -> Error {\n83\t    let envelope = TypedEnvelope { code, message: message.into(), payload };\n84\t    // serde_json serialization is infallible for our envelope shape;\n85\t    // unwrap is safe.\n86\t    let reason = serde_json::to_string(&envelope).unwrap();\n87\t    Error::new(Status::GenericFailure, reason)\n88\t}\n89\t\n90\t// ===== String validation (AC-068a / AC-068b) =========================\n91\t\n92\t/// Reject strings carrying an embedded NUL or an unpaired UTF-16\n93\t/// surrogate codepoint (`U+D800..=U+DFFF`).\n94\t///\n95\t/// JavaScript strings are UTF-16 by spec, so lone surrogates are\n96\t/// representable on the JS side (`String.fromCharCode(0xD800)`). The\n97\t/// napi-rs string conversion translates UTF-16 → UTF-8 and accepts\n98\t/// some malformed inputs; this helper rejects them BEFORE the writer\n99\t/// transaction opens (no-row-written invariant).\n100\tpub fn validate_ffi_string(value: &str) -> std::result::Result<(), String> {\n101\t    if value.as_bytes().contains(&0) {\n102\t        return Err(\"embedded NUL byte in FFI string\".to_string());\n103\t    }\n104\t    for ch in value.chars() {\n105\t        let cp = ch as u32;\n106\t        if (0xD800..=0xDFFF).contains(&cp) {\n107\t            return Err(format!(\"unpaired UTF-16 surrogate U+{cp:04X} in FFI string\"));\n108\t        }\n109\t    }\n110\t    Ok(())\n111\t}\n112\t\n113\tfn validate_ffi_string_napi(value: &str) -> Result<()> {\n114\t    validate_ffi_string(value)\n115\t        .map_err(|msg| typed_error(CODE_WRITE_VALIDATION, msg, JsonValue::Null))\n116\t}\n117\t\n118\t// ===== Error mapping ==================================================\n119\t\n120\t/// Translate every `EngineError` variant to its typed JS counterpart.\n121\t///\n122\t/// No catch-all arm: drift between the Rust enum and the TS class set\n123\t/// is a compile error.\n124\tfn engine_error_to_napi(err: RustEngineError) -> Error {\n125\t    match err {\n126\t        RustEngineError::Storage => typed_error(CODE_STORAGE, \"storage error\", JsonValue::Null),\n127\t        RustEngineError::Projection => {\n128\t            typed_error(CODE_PROJECTION, \"projection error\", JsonValue::Null)\n129\t        }\n130\t        RustEngineError::Vector => typed_error(CODE_VECTOR, \"vector error\", JsonValue::Null),\n131\t        RustEngineError::Embedder => typed_error(CODE_EMBEDDER, \"embedder error\", JsonValue::Null),\n132\t        RustEngineError::EmbedderNotConfigured => {\n133\t            typed_error(CODE_EMBEDDER_NOT_CONFIGURED, \"embedder is not configured\", JsonValue::Null)\n134\t        }\n135\t        RustEngineError::KindNotVectorIndexed => typed_error(\n136\t            CODE_KIND_NOT_VECTOR_INDEXED,\n137\t            \"kind is not configured for vector indexing\",\n138\t            JsonValue::Null,\n139\t        ),\n140\t        RustEngineError::EmbedderDimensionMismatch { expected, actual } => typed_error(\n141\t            CODE_EMBEDDER_DIMENSION_MISMATCH,\n142\t            format!(\"embedder vector dimension mismatch: stored {expected}, supplied {actual}\"),\n143\t            json!({ \"stored\": expected, \"supplied\": actual }),\n144\t        ),\n145\t        RustEngineError::Scheduler => {\n146\t            typed_error(CODE_SCHEDULER, \"scheduler error\", JsonValue::Null)\n147\t        }\n148\t        RustEngineError::OpStore => typed_error(CODE_OP_STORE, \"op-store error\", JsonValue::Null),\n149\t        RustEngineError::WriteValidation => {\n150\t            typed_error(CODE_WRITE_VALIDATION, \"write validation error\", JsonValue::Null)\n151\t        }\n152\t        RustEngineError::SchemaValidation => {\n153\t            typed_error(CODE_SCHEMA_VALIDATION, \"schema validation error\", JsonValue::Null)\n154\t        }\n155\t        RustEngineError::Overloaded => {\n156\t            typed_error(CODE_OVERLOADED, \"engine overloaded\", JsonValue::Null)\n157\t        }\n158\t        RustEngineError::Closing => typed_error(CODE_CLOSING, \"engine is closing\", JsonValue::Null),\n159\t    }\n160\t}\n161\t\n162\tfn corruption_kind_str(kind: CorruptionKind) -> &'static str {\n163\t    match kind {\n164\t        CorruptionKind::WalReplayFailure => \"WalReplayFailure\",\n165\t        CorruptionKind::HeaderMalformed => \"HeaderMalformed\",\n166\t        CorruptionKind::SchemaInconsistent => \"SchemaInconsistent\",\n167\t        CorruptionKind::EmbedderIdentityDrift => \"EmbedderIdentityDrift\",\n168\t    }\n169\t}\n170\t\n171\tfn open_stage_str(stage: OpenStage) -> &'static str {\n172\t    match stage {\n173\t        OpenStage::HeaderProbe => \"HeaderProbe\",\n174\t        OpenStage::WalReplay => \"WalReplay\",\n175\t        OpenStage::SchemaProbe => \"SchemaProbe\",\n176\t        OpenStage::EmbedderIdentity => \"EmbedderIdentity\",\n177\t    }\n178\t}\n179\t\n180\tfn corruption_to_napi(detail: CorruptionDetail) -> Error {\n181\t    let kind = corruption_kind_str(detail.kind);\n182\t    let stage = open_stage_str(detail.stage);\n183\t    let recovery_hint_code = detail.recovery_hint.code;\n184\t    let doc_anchor = detail.recovery_hint.doc_anchor;\n185\t    typed_error(\n186\t        CODE_CORRUPTION,\n187\t        format!(\"corruption {kind} at stage {stage} ({recovery_hint_code})\"),\n188\t        json!({\n189\t            \"kind\": kind,\n190\t            \"stage\": stage,\n191\t            \"recoveryHintCode\": recovery_hint_code,\n192\t            \"docAnchor\": doc_anchor,\n193\t        }),\n194\t    )\n195\t}\n196\t\n197\tfn engine_open_error_to_napi(err: EngineOpenError) -> Error {\n198\t    match err {\n199\t        EngineOpenError::DatabaseLocked { holder_pid } => typed_error(\n200\t            CODE_DATABASE_LOCKED,\n201\t            match holder_pid {\n202\t                Some(pid) => format!(\"database is locked by process {pid}\"),\n203\t                None => \"database is locked by another engine instance\".to_string(),\n204\t            },\n205\t            json!({ \"holderPid\": holder_pid }),\n206\t        ),\n207\t        EngineOpenError::Corruption(detail) => corruption_to_napi(detail),\n208\t        EngineOpenError::IncompatibleSchemaVersion { seen, supported } => typed_error(\n209\t            CODE_INCOMPATIBLE_SCHEMA_VERSION,\n210\t            format!(\n211\t                \"database schema version {seen} is incompatible with supported version {supported}\"\n212\t            ),\n213\t            json!({ \"seen\": seen, \"supported\": supported }),\n214\t        ),\n215\t        EngineOpenError::MigrationError {\n216\t            schema_version_before,\n217\t            schema_version_current,\n218\t            step_id,\n219\t        } => typed_error(\n220\t            CODE_MIGRATION,\n221\t            format!(\n222\t                \"schema migration failed at step {step_id}; schema version remained between {schema_version_before} and {schema_version_current}\"\n223\t            ),\n224\t            json!({\n225\t                \"schemaVersionBefore\": schema_version_before,\n226\t                \"schemaVersionCurrent\": schema_version_current,\n227\t                \"stepId\": step_id,\n228\t            }),\n229\t        ),\n230\t        EngineOpenError::EmbedderIdentityMismatch { stored, supplied } => typed_error(\n231\t            CODE_EMBEDDER_IDENTITY_MISMATCH,\n232\t            format!(\n233\t                \"embedder identity mismatch: stored {}@{}, supplied {}@{}\",\n234\t                stored.name, stored.revision, supplied.name, supplied.revision,\n235\t            ),\n236\t            json!({\n237\t                \"storedName\": stored.name,\n238\t                \"storedRevision\": stored.revision,\n239\t                \"suppliedName\": supplied.name,\n240\t                \"suppliedRevision\": supplied.revision,\n241\t            }),\n242\t        ),\n243\t        EngineOpenError::EmbedderDimensionMismatch { stored, supplied } => typed_error(\n244\t            CODE_EMBEDDER_DIMENSION_MISMATCH,\n245\t            format!(\n246\t                \"embedder vector dimension mismatch: stored {stored}, supplied {supplied}\"\n247\t            ),\n248\t            json!({ \"stored\": stored, \"supplied\": supplied }),\n249\t        ),\n250\t        EngineOpenError::Io { message } => typed_error(\n251\t            CODE_STORAGE,\n252\t            format!(\"database I/O error: {message}\"),\n253\t            JsonValue::Null,\n254\t        ),\n255\t    }\n256\t}\n257\t\n258\tfn panic_error() -> Error {\n259\t    typed_error(CODE_PANIC, \"engine panic (see logs)\", JsonValue::Null)\n260\t}\n261\t\n262\t/// Run a blocking engine call inside `tokio::task::spawn_blocking` so\n263\t/// the libuv event loop stays free, wrapping it in `catch_unwind` so\n264\t/// panics surface as the typed [`panic_error`] rather than aborting the\n265\t/// host process. `AssertUnwindSafe` lets us thread the closure through\n266\t/// without requiring `UnwindSafe` from the engine's `Arc<dyn Embedder>`\n267\t/// substrate.\n268\tasync fn call_engine<R, F>(f: F) -> Result<R>\n269\twhere\n270\t    R: Send + 'static,\n271\t    F: FnOnce() -> std::result::Result<R, RustEngineError> + Send + 'static,\n272\t{\n273\t    let join_result = tokio::task::spawn_blocking(move || catch_unwind(AssertUnwindSafe(f))).await;\n274\t    match join_result {\n275\t        Ok(Ok(Ok(value))) => Ok(value),\n276\t        Ok(Ok(Err(err))) => Err(engine_error_to_napi(err)),\n277\t        Ok(Err(_panic)) => Err(panic_error()),\n278\t        Err(join_err) => Err(typed_error(\n279\t            CODE_PANIC,\n280\t            format!(\"spawn_blocking join error: {join_err}\"),\n281\t            JsonValue::Null,\n282\t        )),\n283\t    }\n284\t}\n285\t\n286\t// ===== Data classes ===================================================\n287\t\n288\t#[napi(object)]\n289\tpub struct WriteReceipt {\n290\t    pub cursor: i64,\n291\t}\n292\t\n293\timpl WriteReceipt {\n294\t    fn from_rust(r: RustWriteReceipt) -> Self {\n295\t        Self { cursor: r.cursor as i64 }\n296\t    }\n297\t}\n298\t\n299\t#[napi(object)]\n300\tpub struct SoftFallback {\n301\t    /// \"vector\" | \"text\"\n302\t    pub branch: String,\n303\t}\n304\t\n305\t#[napi(object)]\n306\tpub struct SearchResult {\n307\t    pub projection_cursor: i64,\n308\t    pub soft_fallback: Option<SoftFallback>,\n309\t    pub results: Vec<String>,\n310\t}\n311\t\n312\timpl SearchResult {\n313\t    fn from_rust(r: RustSearchResult) -> Self {\n314\t        Self {\n315\t            projection_cursor: r.projection_cursor as i64,\n316\t            soft_fallback: r.soft_fallback.as_ref().map(|s| SoftFallback {\n317\t                branch: match s.branch {\n318\t                    SoftFallbackBranch::Vector => \"vector\".to_string(),\n319\t                    SoftFallbackBranch::Text => \"text\".to_string(),\n320\t                },\n321\t            }),\n322\t            results: r.results,\n323\t        }\n324\t    }\n325\t}\n326\t\n327\t#[napi(object)]\n328\tpub struct CounterSnapshot {\n329\t    pub queries: i64,\n330\t    pub writes: i64,\n331\t    pub write_rows: i64,\n332\t    pub admin_ops: i64,\n333\t    pub cache_hit: i64,\n334\t    pub cache_miss: i64,\n335\t}\n336\t\n337\t#[napi(object)]\n338\tpub struct AttachSubscriberOptions {\n339\t    pub heartbeat_interval_ms: Option<u32>,\n340\t}\n341\t\n342\t#[napi(object)]\n343\tpub struct EngineConfig {\n344\t    pub embedder_pool_size: Option<u32>,\n345\t    pub scheduler_runtime_threads: Option<u32>,\n346\t    pub provenance_row_cap: Option<u32>,\n347\t    pub embedder_call_timeout_ms: Option<u32>,\n348\t    pub slow_threshold_ms: Option<u32>,\n349\t}\n350\t\n351\t#[napi(object)]\n352\tpub struct EngineOpenOptions {\n353\t    pub engine_config: Option<EngineConfig>,\n354\t}\n355\t\n356\t#[napi(object)]\n357\tpub struct AdminConfigureOptions {\n358\t    pub name: String,\n359\t    pub body: String,\n360\t}\n361\t\n362\t// ===== Engine =========================================================\n363\t\n364\t#[napi]\n365\tpub struct Engine {\n366\t    inner: Arc<RustEngine>,\n367\t}\n368\t\n369\t#[napi]\n370\timpl Engine {\n371\t    /// Promise-returning open per `dev/interfaces/typescript.md`. The\n372\t    /// blocking SQLite work runs on a tokio blocking thread.\n373\t    #[napi(factory)]\n374\t    pub async fn open(path: String, options: Option<EngineOpenOptions>) -> Result<Engine> {\n375\t        validate_ffi_string_napi(&path)?;\n376\t        let _ = options; // engineConfig knobs are recognised but not yet plumbed; see fathomdb-py.\n377\t        let join_result = tokio::task::spawn_blocking(move || {\n378\t            catch_unwind(AssertUnwindSafe(|| RustEngine::open(path)))\n379\t        })\n380\t        .await;\n381\t        let opened = match join_result {\n382\t            Ok(Ok(Ok(opened))) => opened,\n383\t            Ok(Ok(Err(err))) => return Err(engine_open_error_to_napi(err)),\n384\t            Ok(Err(_panic)) => return Err(panic_error()),\n385\t            Err(join_err) => {\n386\t                return Err(typed_error(\n387\t                    CODE_PANIC,\n388\t                    format!(\"spawn_blocking join error: {join_err}\"),\n389\t                    JsonValue::Null,\n390\t                ))\n391\t            }\n392\t        };\n393\t        Ok(Engine { inner: Arc::new(opened.engine) })\n394\t    }\n395\t\n396\t    #[napi]\n397\t    pub async fn write(&self, batch: Vec<JsonValue>) -> Result<WriteReceipt> {\n398\t        let prepared = translate_batch(batch)?;\n399\t        let engine = Arc::clone(&self.inner);\n400\t        let receipt = call_engine(move || engine.write(&prepared)).await?;\n401\t        Ok(WriteReceipt::from_rust(receipt))\n402\t    }\n403\t\n404\t    #[napi]\n405\t    pub async fn search(&self, query: String) -> Result<SearchResult> {\n406\t        validate_ffi_string_napi(&query)?;\n407\t        if query.trim().is_empty() {\n408\t            return Err(typed_error(\n409\t                CODE_WRITE_VALIDATION,\n410\t                \"query must not be empty\",\n411\t                JsonValue::Null,\n412\t            ));\n413\t        }\n414\t        let engine = Arc::clone(&self.inner);\n415\t        let result = call_engine(move || engine.search(&query)).await?;\n416\t        Ok(SearchResult::from_rust(result))\n417\t    }\n418\t\n419\t    #[napi]\n420\t    pub async fn close(&self) -> Result<()> {\n421\t        let engine = Arc::clone(&self.inner);\n422\t        call_engine(move || engine.close()).await\n423\t    }\n424\t\n425\t    #[napi]\n426\t    pub async fn drain(&self, timeout_ms: u32) -> Result<()> {\n427\t        let engine = Arc::clone(&self.inner);\n428\t        let ms = timeout_ms as u64;\n429\t        call_engine(move || engine.drain(ms)).await\n430\t    }\n431\t\n432\t    #[napi]\n433\t    pub fn counters(&self) -> CounterSnapshot {\n434\t        let snap = self.inner.counters();\n435\t        CounterSnapshot {\n436\t            queries: snap.queries as i64,\n437\t            writes: snap.writes as i64,\n438\t            write_rows: snap.write_rows as i64,\n439\t            admin_ops: snap.admin_ops as i64,\n440\t            cache_hit: snap.cache_hit as i64,\n441\t            cache_miss: snap.cache_miss as i64,\n442\t        }\n443\t    }\n444\t\n445\t    #[napi]\n446\t    pub fn set_profiling(&self, enabled: bool) -> Result<()> {\n447\t        self.inner.set_profiling(enabled).map_err(engine_error_to_napi)\n448\t    }\n449\t\n450\t    #[napi]\n451\t    pub fn set_slow_threshold_ms(&self, value: u32) -> Result<()> {\n452\t        self.inner.set_slow_threshold_ms(value as u64).map_err(engine_error_to_napi)\n453\t    }\n454\t\n455\t    /// Subscriber wiring lands in a later 0.6.x slice; the binding\n456\t    /// accepts the call so callers can wire a callback against the\n457\t    /// public surface without a runtime error.\n458\t    #[napi]\n459\t    pub fn attach_subscriber(\n460\t        &self,\n461\t        callback: JsUnknown,\n462\t        options: Option<AttachSubscriberOptions>,\n463\t    ) -> Result<()> {\n464\t        let _ = callback;\n465\t        let _ = options;\n466\t        Ok(())\n467\t    }\n468\t}\n469\t\n470\t// ===== admin.configure ================================================\n471\t\n472\t#[napi(js_name = \"adminConfigure\")]\n473\tpub async fn admin_configure(\n474\t    engine: &Engine,\n475\t    options: AdminConfigureOptions,\n476\t) -> Result<WriteReceipt> {\n477\t    validate_ffi_string_napi(&options.name)?;\n478\t    validate_ffi_string_napi(&options.body)?;\n479\t    if options.name.is_empty() {\n480\t        return Err(typed_error(\n481\t            CODE_WRITE_VALIDATION,\n482\t            \"admin.configure requires a non-empty name\",\n483\t            JsonValue::Null,\n484\t        ));\n485\t    }\n486\t    // why: `dev/interfaces/typescript.md` § Runtime surface pins the\n487\t    // admin.configure({ name, body }) signature; the engine's\n488\t    // `PreparedWrite::AdminSchema` requires `kind ∈ {latest_state,\n489\t    // append_only_log}`. The TS verb is sugar over latest-state\n490\t    // collection registration in 0.6.0.\n491\t    let batch = vec![PreparedWrite::AdminSchema {\n492\t        name: options.name,\n493\t        kind: \"latest_state\".to_string(),\n494\t        schema_json: options.body,\n495\t        retention_json: \"{}\".to_string(),\n496\t    }];\n497\t    let inner = Arc::clone(&engine.inner);\n498\t    let receipt = call_engine(move || inner.write(&batch)).await?;\n499\t    Ok(WriteReceipt::from_rust(receipt))\n500\t}\n501\t\n502\t// ===== Batch translation ==============================================\n503\t//\n504\t// The TS surface accepts a JS array of typed-write objects. Each item\n505\t// is one of:\n506\t//   { node: { kind, body?, sourceId? } }\n507\t//   { edge: { kind, from, to, sourceId? } }\n508\t//   { opStore: { collection, recordKey, schemaId?, body } }\n509\t//   { adminSchema: { name, kind, schemaJson, retentionJson? } }\n510\t// Plus a bare `{ kind, body?, sourceId? }` shape treated as Node (parity\n511\t// with the Python stub). serde_json::Value is the cheapest cross-thread\n512\t// representation; napi-rs converts JS objects via the `serde-json`\n513\t// feature.\n514\t\n515\tfn translate_batch(batch: Vec<JsonValue>) -> Result<Vec<PreparedWrite>> {\n516\t    batch.into_iter().map(translate_write_item).collect()\n517\t}\n518\t\n519\tfn json_get<'a>(v: &'a JsonValue, key: &str) -> Option<&'a JsonValue> {\n520\t    v.as_object().and_then(|m| m.get(key))\n521\t}\n522\t\n523\tfn json_str(v: &JsonValue, key: &str) -> Result<Option<String>> {\n524\t    match json_get(v, key) {\n525\t        Some(JsonValue::Null) | None => Ok(None),\n526\t        Some(JsonValue::String(s)) => {\n527\t            validate_ffi_string_napi(s)?;\n528\t            Ok(Some(s.clone()))\n529\t        }\n530\t        Some(_other) => Err(typed_error(\n531\t            CODE_WRITE_VALIDATION,\n532\t            format!(\"field {key:?} must be a string\"),\n533\t            JsonValue::Null,\n534\t        )),\n535\t    }\n536\t}\n537\t\n538\tfn json_str_required(v: &JsonValue, key: &str) -> Result<String> {\n539\t    json_str(v, key)?.ok_or_else(|| {\n540\t        typed_error(\n541\t            CODE_WRITE_VALIDATION,\n542\t            format!(\"write item missing required field {key:?}\"),\n543\t            JsonValue::Null,\n544\t        )\n545\t    })\n546\t}\n547\t\n548\tfn json_serialised(v: &JsonValue, key: &str) -> Result<Option<String>> {\n549\t    match json_get(v, key) {\n550\t        Some(JsonValue::Null) | None => Ok(None),\n551\t        Some(JsonValue::String(s)) => {\n552\t            validate_ffi_string_napi(s)?;\n553\t            Ok(Some(s.clone()))\n554\t        }\n555\t        Some(other) => {\n556\t            let serialised = serde_json::to_string(other).map_err(|e| {\n557\t                typed_error(\n558\t                    CODE_WRITE_VALIDATION,\n559\t                    format!(\"field {key:?} not serialisable: {e}\"),\n560\t                    JsonValue::Null,\n561\t                )\n562\t            })?;\n563\t            validate_ffi_string_napi(&serialised)?;\n564\t            Ok(Some(serialised))\n565\t        }\n566\t    }\n567\t}\n568\t\n569\tfn json_serialised_required(v: &JsonValue, key: &str) -> Result<String> {\n570\t    json_serialised(v, key)?.ok_or_else(|| {\n571\t        typed_error(\n572\t            CODE_WRITE_VALIDATION,\n573\t            format!(\"write item missing required field {key:?}\"),\n574\t            JsonValue::Null,\n575\t        )\n576\t    })\n577\t}\n578\t\n579\tfn translate_write_item(item: JsonValue) -> Result<PreparedWrite> {\n580\t    if !item.is_object() {\n581\t        return Err(typed_error(\n582\t            CODE_WRITE_VALIDATION,\n583\t            \"write item must be an object\",\n584\t            JsonValue::Null,\n585\t        ));\n586\t    }\n587\t    if let Some(inner) = json_get(&item, \"edge\") {\n588\t        return translate_edge(inner);\n589\t    }\n590\t    if let Some(inner) = json_get(&item, \"opStore\").or_else(|| json_get(&item, \"op_store\")) {\n591\t        return translate_op_store(inner);\n592\t    }\n593\t    if let Some(inner) = json_get(&item, \"adminSchema\").or_else(|| json_get(&item, \"admin_schema\"))\n594\t    {\n595\t        return translate_admin_schema(inner);\n596\t    }\n597\t    if let Some(inner) = json_get(&item, \"node\") {\n598\t        return translate_node(inner);\n599\t    }\n600\t    translate_node(&item)\n601\t}\n602\t\n603\t/// Look up `camelCase` first, then `snake_case`, returning the first\n604\t/// present string. Both forms are checked so callers porting from the\n605\t/// Python stub keep working without surface-level rewrites.\n606\tfn json_str_alt(item: &JsonValue, camel: &str, snake: &str) -> Result<Option<String>> {\n607\t    if let Some(v) = json_str(item, camel)? {\n608\t        return Ok(Some(v));\n609\t    }\n610\t    json_str(item, snake)\n611\t}\n612\t\n613\tfn json_str_alt_required(item: &JsonValue, camel: &str, snake: &str) -> Result<String> {\n614\t    json_str_alt(item, camel, snake)?.ok_or_else(|| {\n615\t        typed_error(\n616\t            CODE_WRITE_VALIDATION,\n617\t            format!(\"write item missing required field {camel:?}\"),\n618\t            JsonValue::Null,\n619\t        )\n620\t    })\n621\t}\n622\t\n623\tfn json_serialised_alt(item: &JsonValue, camel: &str, snake: &str) -> Result<Option<String>> {\n624\t    if let Some(v) = json_serialised(item, camel)? {\n625\t        return Ok(Some(v));\n626\t    }\n627\t    json_serialised(item, snake)\n628\t}\n629\t\n630\tfn json_serialised_alt_required(item: &JsonValue, camel: &str, snake: &str) -> Result<String> {\n631\t    json_serialised_alt(item, camel, snake)?.ok_or_else(|| {\n632\t        typed_error(\n633\t            CODE_WRITE_VALIDATION,\n634\t            format!(\"write item missing required field {camel:?}\"),\n635\t            JsonValue::Null,\n636\t        )\n637\t    })\n638\t}\n639\t\n640\tfn translate_node(item: &JsonValue) -> Result<PreparedWrite> {\n641\t    let kind = json_str_required(item, \"kind\")?;\n642\t    let body = json_serialised(item, \"body\")?.unwrap_or_else(|| \"{}\".to_string());\n643\t    let source_id = json_str_alt(item, \"sourceId\", \"source_id\")?;\n644\t    Ok(PreparedWrite::Node { kind, body, source_id })\n645\t}\n646\t\n647\tfn translate_edge(item: &JsonValue) -> Result<PreparedWrite> {\n648\t    let kind = json_str_required(item, \"kind\")?;\n649\t    let from = json_str_required(item, \"from\")?;\n650\t    let to = json_str_required(item, \"to\")?;\n651\t    let source_id = json_str_alt(item, \"sourceId\", \"source_id\")?;\n652\t    Ok(PreparedWrite::Edge { kind, from, to, source_id })\n653\t}\n654\t\n655\tfn translate_op_store(item: &JsonValue) -> Result<PreparedWrite> {\n656\t    let collection = json_str_required(item, \"collection\")?;\n657\t    let record_key = json_str_alt_required(item, \"recordKey\", \"record_key\")?;\n658\t    let schema_id = json_str_alt(item, \"schemaId\", \"schema_id\")?;\n659\t    let body = json_serialised_required(item, \"body\")?;\n660\t    Ok(PreparedWrite::OpStore { collection, record_key, schema_id, body })\n661\t}\n662\t\n663\tfn translate_admin_schema(item: &JsonValue) -> Result<PreparedWrite> {\n664\t    let name = json_str_required(item, \"name\")?;\n665\t    let kind = json_str_required(item, \"kind\")?;\n666\t    let schema_json = json_serialised_alt_required(item, \"schemaJson\", \"schema_json\")?;\n667\t    let retention_json = json_serialised_alt(item, \"retentionJson\", \"retention_json\")?\n668\t        .unwrap_or_else(|| \"{}\".to_string());\n669\t    Ok(PreparedWrite::AdminSchema { name, kind, schema_json, retention_json })\n670\t}\n671\t\n672\t// ===== Test hooks =====================================================\n673\t\n674\t/// AC-067 force-panic probe. Gated by `cfg(any(test, feature =\n675\t/// \"test-hooks\"))` so release npm builds without the feature flag do\n676\t/// not expose it.\n677\t#[cfg(any(test, feature = \"test-hooks\"))]\n678\t#[napi(js_name = \"forcePanicForTest\")]\n679\tpub fn force_panic_for_test() -> Result<()> {\n680\t    call_panicking_engine_for_test()\n681\t}\n682\t\n683\t#[cfg(any(test, feature = \"test-hooks\"))]\n684\tfn call_panicking_engine_for_test() -> Result<()> {\n685\t    // Run the panic through the same catch_unwind path that real\n686\t    // engine calls use so the TS-side test exercises the production\n687\t    // panic-translation seam.\n688\t    let join_result = std::panic::catch_unwind(AssertUnwindSafe(\n689\t        || -> std::result::Result<(), RustEngineError> {\n690\t            panic!(\"force_panic_for_test: AC-067 probe\");\n691\t        },\n692\t    ));\n693\t    match join_result {\n694\t        Ok(Ok(())) => Ok(()),\n695\t        Ok(Err(err)) => Err(engine_error_to_napi(err)),\n696\t        Err(_) => Err(panic_error()),\n697\t    }\n698\t}\n699\t\n700\t#[cfg(test)]\n701\tmod tests {\n702\t    use super::*;\n703\t\n704\t    #[test]\n705\t    fn validate_ffi_string_accepts_plain_ascii() {\n706\t        assert!(validate_ffi_string(\"hello\").is_ok());\n707\t    }\n708\t\n709\t    #[test]\n710\t    fn validate_ffi_string_accepts_non_ascii_utf8() {\n711\t        assert!(validate_ffi_string(\"héllo 🦀 文字\").is_ok());\n712\t    }\n713\t\n714\t    #[test]\n715\t    fn validate_ffi_string_rejects_embedded_nul() {\n716\t        let err = validate_ffi_string(\"a\\0b\").unwrap_err();\n717\t        assert!(err.contains(\"NUL\"), \"expected NUL diagnostic, got {err:?}\");\n718\t    }\n719\t\n720\t    #[test]\n721\t    fn validate_ffi_string_accepts_replacement_codepoint() {\n722\t        // U+FFFD is the only \"high unicode\" codepoint a Rust &str can\n723\t        // hold near the surrogate range; the codepoints U+D800..U+DFFF\n724\t        // themselves cannot appear in valid UTF-8, so the runtime\n725\t        // guard is exercised when JS surrogates round-trip through\n726\t        // napi-rs string conversion (covered by ffi-safety.test.ts).\n727\t        assert!(validate_ffi_string(\"\\u{FFFD}\").is_ok());\n728\t    }\n729\t}\n730\t"}]},"parent_tool_use_id":null,"session_id":"a52cedd5-f91e-4c7f-aa9c-db400e73d860","uuid":"cb00141d-1710-4f13-acdc-e15c8bdc4e83","timestamp":"2026-05-16T21:44:24.744Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-11b-napi-binding-20260516T210327Z/src/rust/crates/fathomdb-napi/src/lib.rs","content":"//! napi-rs binding from the TypeScript SDK to `fathomdb-engine`.\n//!\n//! FFI safety contract (mirrors the PyO3 binding in `fathomdb-py`):\n//!\n//! 1. Every method that may block inside the engine runs its blocking\n//!    body inside `tokio::task::spawn_blocking`, so the libuv main\n//!    thread is never tied up. napi-rs's `#[napi] async fn` wraps\n//!    return values as JS `Promise<T>`.\n//! 2. Engine entry points return typed errors via [`engine_error_to_napi`] /\n//!    [`engine_open_error_to_napi`] — single-switch mapping with no\n//!    catch-all arm; the binding fails to compile when the Rust variant\n//!    set drifts from the TS leaf-class set (AC-060a).\n//! 3. Every string crossing the FFI is checked by [`validate_ffi_string`]\n//!    for embedded NUL or unpaired UTF-16 surrogates BEFORE the writer\n//!    transaction opens (AC-068a / AC-068b).\n//! 4. Engine panics are caught via `catch_unwind` inside the spawn-blocking\n//!    body and rethrown as a distinct `FathomDbPanicError` (code\n//!    `FDB_PANIC`); the host process is not aborted (AC-067).\n//\n// why: napi-rs catches panics by default but throws a generic JS\n// `Error` with `Status::GenericFailure` and a Rust-formatted message,\n// which is hard to assert on. Explicit `catch_unwind` + a stable\n// `FDB_PANIC` code lets the TS-side `rethrowTyped` map panics to a\n// distinct `FathomDbPanicError` class that is intentionally NOT a\n// `FathomDbError` subclass: panic is a contract bug, not a typed\n// engine outcome.\n\nuse std::panic::{catch_unwind, AssertUnwindSafe};\nuse std::sync::Arc;\n\nuse fathomdb_engine::{\n    CorruptionDetail, CorruptionKind, Engine as RustEngine, EngineError as RustEngineError,\n    EngineOpenError, OpenStage, PreparedWrite, SearchResult as RustSearchResult,\n    SoftFallbackBranch, WriteReceipt as RustWriteReceipt,\n};\nuse napi::{Error, JsUnknown, Result, Status};\nuse napi_derive::napi;\nuse serde::Serialize;\nuse serde_json::{json, Value as JsonValue};\n\n// ===== Error-code constants ===========================================\n//\n// One per typed leaf class on the TS side. The single-switch translator\n// below maps every engine variant to exactly one of these codes; the TS\n// `rethrowTyped` table maps each code to exactly one leaf class. Drift\n// fails to compile (Rust side) or fails an exhaustiveness check (TS).\n\nconst CODE_STORAGE: &str = \"FDB_STORAGE\";\nconst CODE_PROJECTION: &str = \"FDB_PROJECTION\";\nconst CODE_VECTOR: &str = \"FDB_VECTOR\";\nconst CODE_EMBEDDER: &str = \"FDB_EMBEDDER\";\nconst CODE_EMBEDDER_NOT_CONFIGURED: &str = \"FDB_EMBEDDER_NOT_CONFIGURED\";\nconst CODE_KIND_NOT_VECTOR_INDEXED: &str = \"FDB_KIND_NOT_VECTOR_INDEXED\";\nconst CODE_EMBEDDER_DIMENSION_MISMATCH: &str = \"FDB_EMBEDDER_DIMENSION_MISMATCH\";\nconst CODE_SCHEDULER: &str = \"FDB_SCHEDULER\";\nconst CODE_OP_STORE: &str = \"FDB_OP_STORE\";\nconst CODE_WRITE_VALIDATION: &str = \"FDB_WRITE_VALIDATION\";\nconst CODE_SCHEMA_VALIDATION: &str = \"FDB_SCHEMA_VALIDATION\";\nconst CODE_OVERLOADED: &str = \"FDB_OVERLOADED\";\nconst CODE_CLOSING: &str = \"FDB_CLOSING\";\nconst CODE_DATABASE_LOCKED: &str = \"FDB_DATABASE_LOCKED\";\nconst CODE_CORRUPTION: &str = \"FDB_CORRUPTION\";\nconst CODE_INCOMPATIBLE_SCHEMA_VERSION: &str = \"FDB_INCOMPATIBLE_SCHEMA_VERSION\";\nconst CODE_MIGRATION: &str = \"FDB_MIGRATION\";\nconst CODE_EMBEDDER_IDENTITY_MISMATCH: &str = \"FDB_EMBEDDER_IDENTITY_MISMATCH\";\nconst CODE_PANIC: &str = \"FDB_PANIC\";\n\n// ===== Typed-error encoder ============================================\n\n/// Encode a typed-error envelope as JSON in `err.message` so the\n/// TS-side `rethrowTyped` can reconstitute the right leaf class with\n/// the right payload. napi-rs 2.x has no public API for throwing a\n/// Rust-defined JS class directly; the envelope-in-message pattern is\n/// the canonical workaround.\n#[derive(Serialize)]\nstruct TypedEnvelope<'a> {\n    code: &'a str,\n    message: String,\n    payload: JsonValue,\n}\n\nfn typed_error(code: &'static str, message: impl Into<String>, payload: JsonValue) -> Error {\n    let envelope = TypedEnvelope { code, message: message.into(), payload };\n    // serde_json serialization is infallible for our envelope shape;\n    // unwrap is safe.\n    let reason = serde_json::to_string(&envelope).unwrap();\n    Error::new(Status::GenericFailure, reason)\n}\n\n// ===== String validation (AC-068a / AC-068b) =========================\n\n/// Reject strings carrying an embedded NUL or an unpaired UTF-16\n/// surrogate codepoint (`U+D800..=U+DFFF`).\n///\n/// JavaScript strings are UTF-16 by spec, so lone surrogates are\n/// representable on the JS side (`String.fromCharCode(0xD800)`). The\n/// napi-rs string conversion translates UTF-16 → UTF-8 and accepts\n/// some malformed inputs; this helper rejects them BEFORE the writer\n/// transaction opens (no-row-written invariant).\npub fn validate_ffi_string(value: &str) -> std::result::Result<(), String> {\n    if value.as_bytes().contains(&0) {\n        return Err(\"embedded NUL byte in FFI string\".to_string());\n    }\n    for ch in value.chars() {\n        let cp = ch as u32;\n        if (0xD800..=0xDFFF).contains(&cp) {\n            return Err(format!(\"unpaired UTF-16 surrogate U+{cp:04X} in FFI string\"));\n        }\n    }\n    Ok(())\n}\n\nfn validate_ffi_string_napi(value: &str) -> Result<()> {\n    validate_ffi_string(value)\n        .map_err(|msg| typed_error(CODE_WRITE_VALIDATION, msg, JsonValue::Null))\n}\n\n// ===== Error mapping ==================================================\n\n/// Translate every `EngineError` variant to its typed JS counterpart.\n///\n/// No catch-all arm: drift between the Rust enum and the TS class set\n/// is a compile error.\nfn engine_error_to_napi(err: RustEngineError) -> Error {\n    match err {\n        RustEngineError::Storage => typed_error(CODE_STORAGE, \"storage error\", JsonValue::Null),\n        RustEngineError::Projection => {\n            typed_error(CODE_PROJECTION, \"projection error\", JsonValue::Null)\n        }\n        RustEngineError::Vector => typed_error(CODE_VECTOR, \"vector error\", JsonValue::Null),\n        RustEngineError::Embedder => typed_error(CODE_EMBEDDER, \"embedder error\", JsonValue::Null),\n        RustEngineError::EmbedderNotConfigured => {\n            typed_error(CODE_EMBEDDER_NOT_CONFIGURED, \"embedder is not configured\", JsonValue::Null)\n        }\n        RustEngineError::KindNotVectorIndexed => typed_error(\n            CODE_KIND_NOT_VECTOR_INDEXED,\n            \"kind is not configured for vector indexing\",\n            JsonValue::Null,\n        ),\n        RustEngineError::EmbedderDimensionMismatch { expected, actual } => typed_error(\n            CODE_EMBEDDER_DIMENSION_MISMATCH,\n            format!(\"embedder vector dimension mismatch: stored {expected}, supplied {actual}\"),\n            json!({ \"stored\": expected, \"supplied\": actual }),\n        ),\n        RustEngineError::Scheduler => {\n            typed_error(CODE_SCHEDULER, \"scheduler error\", JsonValue::Null)\n        }\n        RustEngineError::OpStore => typed_error(CODE_OP_STORE, \"op-store error\", JsonValue::Null),\n        RustEngineError::WriteValidation => {\n            typed_error(CODE_WRITE_VALIDATION, \"write validation error\", JsonValue::Null)\n        }\n        RustEngineError::SchemaValidation => {\n            typed_error(CODE_SCHEMA_VALIDATION, \"schema validation error\", JsonValue::Null)\n        }\n        RustEngineError::Overloaded => {\n            typed_error(CODE_OVERLOADED, \"engine overloaded\", JsonValue::Null)\n        }\n        RustEngineError::Closing => typed_error(CODE_CLOSING, \"engine is closing\", JsonValue::Null),\n    }\n}\n\nfn corruption_kind_str(kind: CorruptionKind) -> &'static str {\n    match kind {\n        CorruptionKind::WalReplayFailure => \"WalReplayFailure\",\n        CorruptionKind::HeaderMalformed => \"HeaderMalformed\",\n        CorruptionKind::SchemaInconsistent => \"SchemaInconsistent\",\n        CorruptionKind::EmbedderIdentityDrift => \"EmbedderIdentityDrift\",\n    }\n}\n\nfn open_stage_str(stage: OpenStage) -> &'static str {\n    match stage {\n        OpenStage::HeaderProbe => \"HeaderProbe\",\n        OpenStage::WalReplay => \"WalReplay\",\n        OpenStage::SchemaProbe => \"SchemaProbe\",\n        OpenStage::EmbedderIdentity => \"EmbedderIdentity\",\n    }\n}\n\nfn corruption_to_napi(detail: CorruptionDetail) -> Error {\n    let kind = corruption_kind_str(detail.kind);\n    let stage = open_stage_str(detail.stage);\n    let recovery_hint_code = detail.recovery_hint.code;\n    let doc_anchor = detail.recovery_hint.doc_anchor;\n    typed_error(\n        CODE_CORRUPTION,\n        format!(\"corruption {kind} at stage {stage} ({recovery_hint_code})\"),\n        json!({\n            \"kind\": kind,\n            \"stage\": stage,\n            \"recoveryHintCode\": recovery_hint_code,\n            \"docAnchor\": doc_anchor,\n        }),\n    )\n}\n\nfn engine_open_error_to_napi(err: EngineOpenError) -> Error {\n    match err {\n        EngineOpenError::DatabaseLocked { holder_pid } => typed_error(\n            CODE_DATABASE_LOCKED,\n            match holder_pid {\n                Some(pid) => format!(\"database is locked by process {pid}\"),\n                None => \"database is locked by another engine instance\".to_string(),\n            },\n            json!({ \"holderPid\": holder_pid }),\n        ),\n        EngineOpenError::Corruption(detail) => corruption_to_napi(detail),\n        EngineOpenError::IncompatibleSchemaVersion { seen, supported } => typed_error(\n            CODE_INCOMPATIBLE_SCHEMA_VERSION,\n            format!(\n                \"database schema version {seen} is incompatible with supported version {supported}\"\n            ),\n            json!({ \"seen\": seen, \"supported\": supported }),\n        ),\n        EngineOpenError::MigrationError {\n            schema_version_before,\n            schema_version_current,\n            step_id,\n        } => typed_error(\n            CODE_MIGRATION,\n            format!(\n                \"schema migration failed at step {step_id}; schema version remained between {schema_version_before} and {schema_version_current}\"\n            ),\n            json!({\n                \"schemaVersionBefore\": schema_version_before,\n                \"schemaVersionCurrent\": schema_version_current,\n                \"stepId\": step_id,\n            }),\n        ),\n        EngineOpenError::EmbedderIdentityMismatch { stored, supplied } => typed_error(\n            CODE_EMBEDDER_IDENTITY_MISMATCH,\n            format!(\n                \"embedder identity mismatch: stored {}@{}, supplied {}@{}\",\n                stored.name, stored.revision, supplied.name, supplied.revision,\n            ),\n            json!({\n                \"storedName\": stored.name,\n                \"storedRevision\": stored.revision,\n                \"suppliedName\": supplied.name,\n                \"suppliedRevision\": supplied.revision,\n            }),\n        ),\n        EngineOpenError::EmbedderDimensionMismatch { stored, supplied } => typed_error(\n            CODE_EMBEDDER_DIMENSION_MISMATCH,\n            format!(\n                \"embedder vector dimension mismatch: stored {stored}, supplied {supplied}\"\n            ),\n            json!({ \"stored\": stored, \"supplied\": supplied }),\n        ),\n        EngineOpenError::Io { message } => typed_error(\n            CODE_STORAGE,\n            format!(\"database I/O error: {message}\"),\n            JsonValue::Null,\n        ),\n    }\n}\n\nfn panic_error() -> Error {\n    typed_error(CODE_PANIC, \"engine panic (see logs)\", JsonValue::Null)\n}\n\n/// Run a blocking engine call inside `tokio::task::spawn_blocking` so\n/// the libuv event loop stays free, wrapping it in `catch_unwind` so\n/// panics surface as the typed [`panic_error`] rather than aborting the\n/// host process. `AssertUnwindSafe` lets us thread the closure through\n/// without requiring `UnwindSafe` from the engine's `Arc<dyn Embedder>`\n/// substrate.\nasync fn call_engine<R, F>(f: F) -> Result<R>\nwhere\n    R: Send + 'static,\n    F: FnOnce() -> std::result::Result<R, RustEngineError> + Send + 'static,\n{\n    let join_result = tokio::task::spawn_blocking(move || catch_unwind(AssertUnwindSafe(f))).await;\n    match join_result {\n        Ok(Ok(Ok(value))) => Ok(value),\n        Ok(Ok(Err(err))) => Err(engine_error_to_napi(err)),\n        Ok(Err(_panic)) => Err(panic_error()),\n        Err(join_err) => Err(typed_error(\n            CODE_PANIC,\n            format!(\"spawn_blocking join error: {join_err}\"),\n            JsonValue::Null,\n        )),\n    }\n}\n\n// ===== Data classes ===================================================\n\n#[napi(object)]\npub struct WriteReceipt {\n    pub cursor: i64,\n}\n\nimpl WriteReceipt {\n    fn from_rust(r: RustWriteReceipt) -> Self {\n        Self { cursor: r.cursor as i64 }\n    }\n}\n\n#[napi(object)]\npub struct SoftFallback {\n    /// \"vector\" | \"text\"\n    pub branch: String,\n}\n\n#[napi(object)]\npub struct SearchResult {\n    pub projection_cursor: i64,\n    pub soft_fallback: Option<SoftFallback>,\n    pub results: Vec<String>,\n}\n\nimpl SearchResult {\n    fn from_rust(r: RustSearchResult) -> Self {\n        Self {\n            projection_cursor: r.projection_cursor as i64,\n            soft_fallback: r.soft_fallback.as_ref().map(|s| SoftFallback {\n                branch: match s.branch {\n                    SoftFallbackBranch::Vector => \"vector\".to_string(),\n                    SoftFallbackBranch::Text => \"text\".to_string(),\n                },\n            }),\n            results: r.results,\n        }\n    }\n}\n\n#[napi(object)]\npub struct CounterSnapshot {\n    pub queries: i64,\n    pub writes: i64,\n    pub write_rows: i64,\n    pub admin_ops: i64,\n    pub cache_hit: i64,\n    pub cache_miss: i64,\n}\n\n#[napi(object)]\npub struct AttachSubscriberOptions {\n    pub heartbeat_interval_ms: Option<u32>,\n}\n\n#[napi(object)]\npub struct EngineConfig {\n    pub embedder_pool_size: Option<u32>,\n    pub scheduler_runtime_threads: Option<u32>,\n    pub provenance_row_cap: Option<u32>,\n    pub embedder_call_timeout_ms: Option<u32>,\n    pub slow_threshold_ms: Option<u32>,\n}\n\n#[napi(object)]\npub struct EngineOpenOptions {\n    pub engine_config: Option<EngineConfig>,\n}\n\n#[napi(object)]\npub struct AdminConfigureOptions {\n    pub name: String,\n    pub body: String,\n}\n\n// ===== Engine =========================================================\n\n#[napi]\npub struct Engine {\n    inner: Arc<RustEngine>,\n}\n\n#[napi]\nimpl Engine {\n    /// Promise-returning open per `dev/interfaces/typescript.md`. The\n    /// blocking SQLite work runs on a tokio blocking thread.\n    #[napi(factory)]\n    pub async fn open(path: String, options: Option<EngineOpenOptions>) -> Result<Engine> {\n        validate_ffi_string_napi(&path)?;\n        let _ = options; // engineConfig knobs are recognised but not yet plumbed; see fathomdb-py.\n        let join_result = tokio::task::spawn_blocking(move || {\n            catch_unwind(AssertUnwindSafe(|| RustEngine::open(path)))\n        })\n        .await;\n        let opened = match join_result {\n            Ok(Ok(Ok(opened))) => opened,\n            Ok(Ok(Err(err))) => return Err(engine_open_error_to_napi(err)),\n            Ok(Err(_panic)) => return Err(panic_error()),\n            Err(join_err) => {\n                return Err(typed_error(\n                    CODE_PANIC,\n                    format!(\"spawn_blocking join error: {join_err}\"),\n                    JsonValue::Null,\n                ))\n            }\n        };\n        Ok(Engine { inner: Arc::new(opened.engine) })\n    }\n\n    #[napi]\n    pub async fn write(&self, batch: Vec<JsonValue>) -> Result<WriteReceipt> {\n        let prepared = translate_batch(batch)?;\n        let engine = Arc::clone(&self.inner);\n        let receipt = call_engine(move || engine.write(&prepared)).await?;\n        Ok(WriteReceipt::from_rust(receipt))\n    }\n\n    #[napi]\n    pub async fn search(&self, query: String) -> Result<SearchResult> {\n        validate_ffi_string_napi(&query)?;\n        if query.trim().is_empty() {\n            return Err(typed_error(\n                CODE_WRITE_VALIDATION,\n                \"query must not be empty\",\n                JsonValue::Null,\n            ));\n        }\n        let engine = Arc::clone(&self.inner);\n        let result = call_engine(move || engine.search(&query)).await?;\n        Ok(SearchResult::from_rust(result))\n    }\n\n    #[napi]\n    pub async fn close(&self) -> Result<()> {\n        let engine = Arc::clone(&self.inner);\n        call_engine(move || engine.close()).await\n    }\n\n    #[napi]\n    pub async fn drain(&self, timeout_ms: u32) -> Result<()> {\n        let engine = Arc::clone(&self.inner);\n        let ms = timeout_ms as u64;\n        call_engine(move || engine.drain(ms)).await\n    }\n\n    #[napi]\n    pub fn counters(&self) -> CounterSnapshot {\n        let snap = self.inner.counters();\n        CounterSnapshot {\n            queries: snap.queries as i64,\n            writes: snap.writes as i64,\n            write_rows: snap.write_rows as i64,\n            admin_ops: snap.admin_ops as i64,\n            cache_hit: snap.cache_hit as i64,\n            cache_miss: snap.cache_miss as i64,\n        }\n    }\n\n    #[napi]\n    pub fn set_profiling(&self, enabled: bool) -> Result<()> {\n        self.inner.set_profiling(enabled).map_err(engine_error_to_napi)\n    }\n\n    #[napi]\n    pub fn set_slow_threshold_ms(&self, value: u32) -> Result<()> {\n        self.inner.set_slow_threshold_ms(value as u64).map_err(engine_error_to_napi)\n    }\n\n    /// Subscriber wiring lands in a later 0.6.x slice; the binding\n    /// accepts the call so callers can wire a callback against the\n    /// public surface without a runtime error.\n    #[napi]\n    pub fn attach_subscriber(\n        &self,\n        callback: JsUnknown,\n        options: Option<AttachSubscriberOptions>,\n    ) -> Result<()> {\n        let _ = callback;\n        let _ = options;\n        Ok(())\n    }\n}\n\n// ===== admin.configure ================================================\n\n#[napi(js_name = \"adminConfigure\")]\npub async fn admin_configure(\n    engine: &Engine,\n    options: AdminConfigureOptions,\n) -> Result<WriteReceipt> {\n    validate_ffi_string_napi(&options.name)?;\n    validate_ffi_string_napi(&options.body)?;\n    if options.name.is_empty() {\n        return Err(typed_error(\n            CODE_WRITE_VALIDATION,\n            \"admin.configure requires a non-empty name\",\n            JsonValue::Null,\n        ));\n    }\n    // why: `dev/interfaces/typescript.md` § Runtime surface pins the\n    // admin.configure({ name, body }) signature; the engine's\n    // `PreparedWrite::AdminSchema` requires `kind ∈ {latest_state,\n    // append_only_log}`. The TS verb is sugar over latest-state\n    // collection registration in 0.6.0.\n    let batch = vec![PreparedWrite::AdminSchema {\n        name: options.name,\n        kind: \"latest_state\".to_string(),\n        schema_json: options.body,\n        retention_json: \"{}\".to_string(),\n    }];\n    let inner = Arc::clone(&engine.inner);\n    let receipt = call_engine(move || inner.write(&batch)).await?;\n    Ok(WriteReceipt::from_rust(receipt))\n}\n\n// ===== Batch translation ==============================================\n//\n// The TS surface accepts a JS array of typed-write objects. Each item\n// is one of:\n//   { node: { kind, body?, sourceId? } }\n//   { edge: { kind, from, to, sourceId? } }\n//   { opStore: { collection, recordKey, schemaId?, body } }\n//   { adminSchema: { name, kind, schemaJson, retentionJson? } }\n// Plus a bare `{ kind, body?, sourceId? }` shape treated as Node (parity\n// with the Python stub). serde_json::Value is the cheapest cross-thread\n// representation; napi-rs converts JS objects via the `serde-json`\n// feature.\n\nfn translate_batch(batch: Vec<JsonValue>) -> Result<Vec<PreparedWrite>> {\n    batch.into_iter().map(translate_write_item).collect()\n}\n\nfn json_get<'a>(v: &'a JsonValue, key: &str) -> Option<&'a JsonValue> {\n    v.as_object().and_then(|m| m.get(key))\n}\n\nfn json_str(v: &JsonValue, key: &str) -> Result<Option<String>> {\n    match json_get(v, key) {\n        Some(JsonValue::Null) | None => Ok(None),\n        Some(JsonValue::String(s)) => {\n            validate_ffi_string_napi(s)?;\n            Ok(Some(s.clone()))\n        }\n        Some(_other) => Err(typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"field {key:?} must be a string\"),\n            JsonValue::Null,\n        )),\n    }\n}\n\nfn json_str_required(v: &JsonValue, key: &str) -> Result<String> {\n    json_str(v, key)?.ok_or_else(|| {\n        typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"write item missing required field {key:?}\"),\n            JsonValue::Null,\n        )\n    })\n}\n\nfn json_serialised(v: &JsonValue, key: &str) -> Result<Option<String>> {\n    match json_get(v, key) {\n        Some(JsonValue::Null) | None => Ok(None),\n        Some(JsonValue::String(s)) => {\n            validate_ffi_string_napi(s)?;\n            Ok(Some(s.clone()))\n        }\n        Some(other) => {\n            let serialised = serde_json::to_string(other).map_err(|e| {\n                typed_error(\n                    CODE_WRITE_VALIDATION,\n                    format!(\"field {key:?} not serialisable: {e}\"),\n                    JsonValue::Null,\n                )\n            })?;\n            validate_ffi_string_napi(&serialised)?;\n            Ok(Some(serialised))\n        }\n    }\n}\n\nfn json_serialised_required(v: &JsonValue, key: &str) -> Result<String> {\n    json_serialised(v, key)?.ok_or_else(|| {\n        typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"write item missing required field {key:?}\"),\n            JsonValue::Null,\n        )\n    })\n}\n\nfn translate_write_item(item: JsonValue) -> Result<PreparedWrite> {\n    if !item.is_object() {\n        return Err(typed_error(\n            CODE_WRITE_VALIDATION,\n            \"write item must be an object\",\n            JsonValue::Null,\n        ));\n    }\n    if let Some(inner) = json_get(&item, \"edge\") {\n        return translate_edge(inner);\n    }\n    if let Some(inner) = json_get(&item, \"opStore\").or_else(|| json_get(&item, \"op_store\")) {\n        return translate_op_store(inner);\n    }\n    if let Some(inner) = json_get(&item, \"adminSchema\").or_else(|| json_get(&item, \"admin_schema\"))\n    {\n        return translate_admin_schema(inner);\n    }\n    if let Some(inner) = json_get(&item, \"node\") {\n        return translate_node(inner);\n    }\n    translate_node(&item)\n}\n\n/// Look up `camelCase` first, then `snake_case`, returning the first\n/// present string. Both forms are checked so callers porting from the\n/// Python stub keep working without surface-level rewrites.\nfn json_str_alt(item: &JsonValue, camel: &str, snake: &str) -> Result<Option<String>> {\n    if let Some(v) = json_str(item, camel)? {\n        return Ok(Some(v));\n    }\n    json_str(item, snake)\n}\n\nfn json_str_alt_required(item: &JsonValue, camel: &str, snake: &str) -> Result<String> {\n    json_str_alt(item, camel, snake)?.ok_or_else(|| {\n        typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"write item missing required field {camel:?}\"),\n            JsonValue::Null,\n        )\n    })\n}\n\nfn json_serialised_alt(item: &JsonValue, camel: &str, snake: &str) -> Result<Option<String>> {\n    if let Some(v) = json_serialised(item, camel)? {\n        return Ok(Some(v));\n    }\n    json_serialised(item, snake)\n}\n\nfn json_serialised_alt_required(item: &JsonValue, camel: &str, snake: &str) -> Result<String> {\n    json_serialised_alt(item, camel, snake)?.ok_or_else(|| {\n        typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"write item missing required field {camel:?}\"),\n            JsonValue::Null,\n        )\n    })\n}\n\nfn translate_node(item: &JsonValue) -> Result<PreparedWrite> {\n    let kind = json_str_required(item, \"kind\")?;\n    let body = json_serialised(item, \"body\")?.unwrap_or_else(|| \"{}\".to_string());\n    let source_id = json_str_alt(item, \"sourceId\", \"source_id\")?;\n    Ok(PreparedWrite::Node { kind, body, source_id })\n}\n\nfn translate_edge(item: &JsonValue) -> Result<PreparedWrite> {\n    let kind = json_str_required(item, \"kind\")?;\n    let from = json_str_required(item, \"from\")?;\n    let to = json_str_required(item, \"to\")?;\n    let source_id = json_str_alt(item, \"sourceId\", \"source_id\")?;\n    Ok(PreparedWrite::Edge { kind, from, to, source_id })\n}\n\nfn translate_op_store(item: &JsonValue) -> Result<PreparedWrite> {\n    let collection = json_str_required(item, \"collection\")?;\n    let record_key = json_str_alt_required(item, \"recordKey\", \"record_key\")?;\n    let schema_id = json_str_alt(item, \"schemaId\", \"schema_id\")?;\n    let body = json_serialised_required(item, \"body\")?;\n    Ok(PreparedWrite::OpStore { collection, record_key, schema_id, body })\n}\n\nfn translate_admin_schema(item: &JsonValue) -> Result<PreparedWrite> {\n    let name = json_str_required(item, \"name\")?;\n    let kind = json_str_required(item, \"kind\")?;\n    let schema_json = json_serialised_alt_required(item, \"schemaJson\", \"schema_json\")?;\n    let retention_json = json_serialised_alt(item, \"retentionJson\", \"retention_json\")?\n        .unwrap_or_else(|| \"{}\".to_string());\n    Ok(PreparedWrite::AdminSchema { name, kind, schema_json, retention_json })\n}\n\n// ===== Test hooks =====================================================\n\n/// AC-067 force-panic probe. Gated by `cfg(any(test, feature =\n/// \"test-hooks\"))` so release npm builds without the feature flag do\n/// not expose it.\n#[cfg(any(test, feature = \"test-hooks\"))]\n#[napi(js_name = \"forcePanicForTest\")]\npub fn force_panic_for_test() -> Result<()> {\n    call_panicking_engine_for_test()\n}\n\n#[cfg(any(test, feature = \"test-hooks\"))]\nfn call_panicking_engine_for_test() -> Result<()> {\n    // Run the panic through the same catch_unwind path that real\n    // engine calls use so the TS-side test exercises the production\n    // panic-translation seam.\n    let join_result = std::panic::catch_unwind(AssertUnwindSafe(\n        || -> std::result::Result<(), RustEngineError> {\n            panic!(\"force_panic_for_test: AC-067 probe\");\n        },\n    ));\n    match join_result {\n        Ok(Ok(())) => Ok(()),\n        Ok(Err(err)) => Err(engine_error_to_napi(err)),\n        Err(_) => Err(panic_error()),\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn validate_ffi_string_accepts_plain_ascii() {\n        assert!(validate_ffi_string(\"hello\").is_ok());\n    }\n\n    #[test]\n    fn validate_ffi_string_accepts_non_ascii_utf8() {\n        assert!(validate_ffi_string(\"héllo 🦀 文字\").is_ok());\n    }\n\n    #[test]\n    fn validate_ffi_string_rejects_embedded_nul() {\n        let err = validate_ffi_string(\"a\\0b\").unwrap_err();\n        assert!(err.contains(\"NUL\"), \"expected NUL diagnostic, got {err:?}\");\n    }\n\n    #[test]\n    fn validate_ffi_string_accepts_replacement_codepoint() {\n        // U+FFFD is the only \"high unicode\" codepoint a Rust &str can\n        // hold near the surrogate range; the codepoints U+D800..U+DFFF\n        // themselves cannot appear in valid UTF-8, so the runtime\n        // guard is exercised when JS surrogates round-trip through\n        // napi-rs string conversion (covered by ffi-safety.test.ts).\n        assert!(validate_ffi_string(\"\\u{FFFD}\").is_ok());\n    }\n}\n","numLines":730,"startLine":1,"totalLines":730}}}
dev/plans/runs/11b-fix-1-20260516T214419Z.log:189:{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xy6G4wg9NViwvwKJTtSrtY","type":"tool_result","content":"The file /tmp/fdb-11b-napi-binding-20260516T210327Z/src/rust/crates/fathomdb-napi/src/lib.rs has been updated successfully. (file state is current in your context — no need to Read it back)"}]},"parent_tool_use_id":null,"session_id":"a52cedd5-f91e-4c7f-aa9c-db400e73d860","uuid":"873e8a30-d550-4065-be64-199db1b951c8","timestamp":"2026-05-16T21:44:52.023Z","tool_use_result":{"filePath":"/tmp/fdb-11b-napi-binding-20260516T210327Z/src/rust/crates/fathomdb-napi/src/lib.rs","oldString":"async fn call_engine<R, F>(f: F) -> Result<R>\nwhere\n    R: Send + 'static,\n    F: FnOnce() -> std::result::Result<R, RustEngineError> + Send + 'static,\n{\n    let join_result = tokio::task::spawn_blocking(move || catch_unwind(AssertUnwindSafe(f))).await;\n    match join_result {\n        Ok(Ok(Ok(value))) => Ok(value),\n        Ok(Ok(Err(err))) => Err(engine_error_to_napi(err)),\n        Ok(Err(_panic)) => Err(panic_error()),\n        Err(join_err) => Err(typed_error(\n            CODE_PANIC,\n            format!(\"spawn_blocking join error: {join_err}\"),\n            JsonValue::Null,\n        )),\n    }\n}","newString":"async fn call_engine<R, F>(f: F) -> Result<R>\nwhere\n    R: Send + 'static,\n    F: FnOnce() -> std::result::Result<R, RustEngineError> + Send + 'static,\n{\n    let join_result = tokio::task::spawn_blocking(move || catch_unwind(AssertUnwindSafe(f))).await;\n    match join_result {\n        Ok(Ok(Ok(value))) => Ok(value),\n        Ok(Ok(Err(err))) => Err(engine_error_to_napi(err)),\n        Ok(Err(_panic)) => Err(panic_error()),\n        Err(join_err) => Err(typed_error(\n            CODE_PANIC,\n            format!(\"spawn_blocking join error: {join_err}\"),\n            JsonValue::Null,\n        )),\n    }\n}\n\n/// Sync sibling of [`call_engine`]: wrap a non-blocking accessor in\n/// `catch_unwind` so a panic on the JS thread surfaces as [`panic_error`]\n/// instead of unwinding into napi-rs's default `GenericFailure` path.\nfn call_engine_sync<R, F>(f: F) -> Result<R>\nwhere\n    F: FnOnce() -> Result<R>,\n{\n    match catch_unwind(AssertUnwindSafe(f)) {\n        Ok(result) => result,\n        Err(_panic) => Err(panic_error()),\n    }\n}","originalFile":"//! napi-rs binding from the TypeScript SDK to `fathomdb-engine`.\n//!\n//! FFI safety contract (mirrors the PyO3 binding in `fathomdb-py`):\n//!\n//! 1. Every method that may block inside the engine runs its blocking\n//!    body inside `tokio::task::spawn_blocking`, so the libuv main\n//!    thread is never tied up. napi-rs's `#[napi] async fn` wraps\n//!    return values as JS `Promise<T>`.\n//! 2. Engine entry points return typed errors via [`engine_error_to_napi`] /\n//!    [`engine_open_error_to_napi`] — single-switch mapping with no\n//!    catch-all arm; the binding fails to compile when the Rust variant\n//!    set drifts from the TS leaf-class set (AC-060a).\n//! 3. Every string crossing the FFI is checked by [`validate_ffi_string`]\n//!    for embedded NUL or unpaired UTF-16 surrogates BEFORE the writer\n//!    transaction opens (AC-068a / AC-068b).\n//! 4. Engine panics are caught via `catch_unwind` inside the spawn-blocking\n//!    body and rethrown as a distinct `FathomDbPanicError` (code\n//!    `FDB_PANIC`); the host process is not aborted (AC-067).\n//\n// why: napi-rs catches panics by default but throws a generic JS\n// `Error` with `Status::GenericFailure` and a Rust-formatted message,\n// which is hard to assert on. Explicit `catch_unwind` + a stable\n// `FDB_PANIC` code lets the TS-side `rethrowTyped` map panics to a\n// distinct `FathomDbPanicError` class that is intentionally NOT a\n// `FathomDbError` subclass: panic is a contract bug, not a typed\n// engine outcome.\n\nuse std::panic::{catch_unwind, AssertUnwindSafe};\nuse std::sync::Arc;\n\nuse fathomdb_engine::{\n    CorruptionDetail, CorruptionKind, Engine as RustEngine, EngineError as RustEngineError,\n    EngineOpenError, OpenStage, PreparedWrite, SearchResult as RustSearchResult,\n    SoftFallbackBranch, WriteReceipt as RustWriteReceipt,\n};\nuse napi::{Error, JsUnknown, Result, Status};\nuse napi_derive::napi;\nuse serde::Serialize;\nuse serde_json::{json, Value as JsonValue};\n\n// ===== Error-code constants ===========================================\n//\n// One per typed leaf class on the TS side. The single-switch translator\n// below maps every engine variant to exactly one of these codes; the TS\n// `rethrowTyped` table maps each code to exactly one leaf class. Drift\n// fails to compile (Rust side) or fails an exhaustiveness check (TS).\n\nconst CODE_STORAGE: &str = \"FDB_STORAGE\";\nconst CODE_PROJECTION: &str = \"FDB_PROJECTION\";\nconst CODE_VECTOR: &str = \"FDB_VECTOR\";\nconst CODE_EMBEDDER: &str = \"FDB_EMBEDDER\";\nconst CODE_EMBEDDER_NOT_CONFIGURED: &str = \"FDB_EMBEDDER_NOT_CONFIGURED\";\nconst CODE_KIND_NOT_VECTOR_INDEXED: &str = \"FDB_KIND_NOT_VECTOR_INDEXED\";\nconst CODE_EMBEDDER_DIMENSION_MISMATCH: &str = \"FDB_EMBEDDER_DIMENSION_MISMATCH\";\nconst CODE_SCHEDULER: &str = \"FDB_SCHEDULER\";\nconst CODE_OP_STORE: &str = \"FDB_OP_STORE\";\nconst CODE_WRITE_VALIDATION: &str = \"FDB_WRITE_VALIDATION\";\nconst CODE_SCHEMA_VALIDATION: &str = \"FDB_SCHEMA_VALIDATION\";\nconst CODE_OVERLOADED: &str = \"FDB_OVERLOADED\";\nconst CODE_CLOSING: &str = \"FDB_CLOSING\";\nconst CODE_DATABASE_LOCKED: &str = \"FDB_DATABASE_LOCKED\";\nconst CODE_CORRUPTION: &str = \"FDB_CORRUPTION\";\nconst CODE_INCOMPATIBLE_SCHEMA_VERSION: &str = \"FDB_INCOMPATIBLE_SCHEMA_VERSION\";\nconst CODE_MIGRATION: &str = \"FDB_MIGRATION\";\nconst CODE_EMBEDDER_IDENTITY_MISMATCH: &str = \"FDB_EMBEDDER_IDENTITY_MISMATCH\";\nconst CODE_PANIC: &str = \"FDB_PANIC\";\n\n// ===== Typed-error encoder ============================================\n\n/// Encode a typed-error envelope as JSON in `err.message` so the\n/// TS-side `rethrowTyped` can reconstitute the right leaf class with\n/// the right payload. napi-rs 2.x has no public API for throwing a\n/// Rust-defined JS class directly; the envelope-in-message pattern is\n/// the canonical workaround.\n#[derive(Serialize)]\nstruct TypedEnvelope<'a> {\n    code: &'a str,\n    message: String,\n    payload: JsonValue,\n}\n\nfn typed_error(code: &'static str, message: impl Into<String>, payload: JsonValue) -> Error {\n    let envelope = TypedEnvelope { code, message: message.into(), payload };\n    // serde_json serialization is infallible for our envelope shape;\n    // unwrap is safe.\n    let reason = serde_json::to_string(&envelope).unwrap();\n    Error::new(Status::GenericFailure, reason)\n}\n\n// ===== String validation (AC-068a / AC-068b) =========================\n\n/// Reject strings carrying an embedded NUL or an unpaired UTF-16\n/// surrogate codepoint (`U+D800..=U+DFFF`).\n///\n/// JavaScript strings are UTF-16 by spec, so lone surrogates are\n/// representable on the JS side (`String.fromCharCode(0xD800)`). The\n/// napi-rs string conversion translates UTF-16 → UTF-8 and accepts\n/// some malformed inputs; this helper rejects them BEFORE the writer\n/// transaction opens (no-row-written invariant).\npub fn validate_ffi_string(value: &str) -> std::result::Result<(), String> {\n    if value.as_bytes().contains(&0) {\n        return Err(\"embedded NUL byte in FFI string\".to_string());\n    }\n    for ch in value.chars() {\n        let cp = ch as u32;\n        if (0xD800..=0xDFFF).contains(&cp) {\n            return Err(format!(\"unpaired UTF-16 surrogate U+{cp:04X} in FFI string\"));\n        }\n    }\n    Ok(())\n}\n\nfn validate_ffi_string_napi(value: &str) -> Result<()> {\n    validate_ffi_string(value)\n        .map_err(|msg| typed_error(CODE_WRITE_VALIDATION, msg, JsonValue::Null))\n}\n\n// ===== Error mapping ==================================================\n\n/// Translate every `EngineError` variant to its typed JS counterpart.\n///\n/// No catch-all arm: drift between the Rust enum and the TS class set\n/// is a compile error.\nfn engine_error_to_napi(err: RustEngineError) -> Error {\n    match err {\n        RustEngineError::Storage => typed_error(CODE_STORAGE, \"storage error\", JsonValue::Null),\n        RustEngineError::Projection => {\n            typed_error(CODE_PROJECTION, \"projection error\", JsonValue::Null)\n        }\n        RustEngineError::Vector => typed_error(CODE_VECTOR, \"vector error\", JsonValue::Null),\n        RustEngineError::Embedder => typed_error(CODE_EMBEDDER, \"embedder error\", JsonValue::Null),\n        RustEngineError::EmbedderNotConfigured => {\n            typed_error(CODE_EMBEDDER_NOT_CONFIGURED, \"embedder is not configured\", JsonValue::Null)\n        }\n        RustEngineError::KindNotVectorIndexed => typed_error(\n            CODE_KIND_NOT_VECTOR_INDEXED,\n            \"kind is not configured for vector indexing\",\n            JsonValue::Null,\n        ),\n        RustEngineError::EmbedderDimensionMismatch { expected, actual } => typed_error(\n            CODE_EMBEDDER_DIMENSION_MISMATCH,\n            format!(\"embedder vector dimension mismatch: stored {expected}, supplied {actual}\"),\n            json!({ \"stored\": expected, \"supplied\": actual }),\n        ),\n        RustEngineError::Scheduler => {\n            typed_error(CODE_SCHEDULER, \"scheduler error\", JsonValue::Null)\n        }\n        RustEngineError::OpStore => typed_error(CODE_OP_STORE, \"op-store error\", JsonValue::Null),\n        RustEngineError::WriteValidation => {\n            typed_error(CODE_WRITE_VALIDATION, \"write validation error\", JsonValue::Null)\n        }\n        RustEngineError::SchemaValidation => {\n            typed_error(CODE_SCHEMA_VALIDATION, \"schema validation error\", JsonValue::Null)\n        }\n        RustEngineError::Overloaded => {\n            typed_error(CODE_OVERLOADED, \"engine overloaded\", JsonValue::Null)\n        }\n        RustEngineError::Closing => typed_error(CODE_CLOSING, \"engine is closing\", JsonValue::Null),\n    }\n}\n\nfn corruption_kind_str(kind: CorruptionKind) -> &'static str {\n    match kind {\n        CorruptionKind::WalReplayFailure => \"WalReplayFailure\",\n        CorruptionKind::HeaderMalformed => \"HeaderMalformed\",\n        CorruptionKind::SchemaInconsistent => \"SchemaInconsistent\",\n        CorruptionKind::EmbedderIdentityDrift => \"EmbedderIdentityDrift\",\n    }\n}\n\nfn open_stage_str(stage: OpenStage) -> &'static str {\n    match stage {\n        OpenStage::HeaderProbe => \"HeaderProbe\",\n        OpenStage::WalReplay => \"WalReplay\",\n        OpenStage::SchemaProbe => \"SchemaProbe\",\n        OpenStage::EmbedderIdentity => \"EmbedderIdentity\",\n    }\n}\n\nfn corruption_to_napi(detail: CorruptionDetail) -> Error {\n    let kind = corruption_kind_str(detail.kind);\n    let stage = open_stage_str(detail.stage);\n    let recovery_hint_code = detail.recovery_hint.code;\n    let doc_anchor = detail.recovery_hint.doc_anchor;\n    typed_error(\n        CODE_CORRUPTION,\n        format!(\"corruption {kind} at stage {stage} ({recovery_hint_code})\"),\n        json!({\n            \"kind\": kind,\n            \"stage\": stage,\n            \"recoveryHintCode\": recovery_hint_code,\n            \"docAnchor\": doc_anchor,\n        }),\n    )\n}\n\nfn engine_open_error_to_napi(err: EngineOpenError) -> Error {\n    match err {\n        EngineOpenError::DatabaseLocked { holder_pid } => typed_error(\n            CODE_DATABASE_LOCKED,\n            match holder_pid {\n                Some(pid) => format!(\"database is locked by process {pid}\"),\n                None => \"database is locked by another engine instance\".to_string(),\n            },\n            json!({ \"holderPid\": holder_pid }),\n        ),\n        EngineOpenError::Corruption(detail) => corruption_to_napi(detail),\n        EngineOpenError::IncompatibleSchemaVersion { seen, supported } => typed_error(\n            CODE_INCOMPATIBLE_SCHEMA_VERSION,\n            format!(\n                \"database schema version {seen} is incompatible with supported version {supported}\"\n            ),\n            json!({ \"seen\": seen, \"supported\": supported }),\n        ),\n        EngineOpenError::MigrationError {\n            schema_version_before,\n            schema_version_current,\n            step_id,\n        } => typed_error(\n            CODE_MIGRATION,\n            format!(\n                \"schema migration failed at step {step_id}; schema version remained between {schema_version_before} and {schema_version_current}\"\n            ),\n            json!({\n                \"schemaVersionBefore\": schema_version_before,\n                \"schemaVersionCurrent\": schema_version_current,\n                \"stepId\": step_id,\n            }),\n        ),\n        EngineOpenError::EmbedderIdentityMismatch { stored, supplied } => typed_error(\n            CODE_EMBEDDER_IDENTITY_MISMATCH,\n            format!(\n                \"embedder identity mismatch: stored {}@{}, supplied {}@{}\",\n                stored.name, stored.revision, supplied.name, supplied.revision,\n            ),\n            json!({\n                \"storedName\": stored.name,\n                \"storedRevision\": stored.revision,\n                \"suppliedName\": supplied.name,\n                \"suppliedRevision\": supplied.revision,\n            }),\n        ),\n        EngineOpenError::EmbedderDimensionMismatch { stored, supplied } => typed_error(\n            CODE_EMBEDDER_DIMENSION_MISMATCH,\n            format!(\n                \"embedder vector dimension mismatch: stored {stored}, supplied {supplied}\"\n            ),\n            json!({ \"stored\": stored, \"supplied\": supplied }),\n        ),\n        EngineOpenError::Io { message } => typed_error(\n            CODE_STORAGE,\n            format!(\"database I/O error: {message}\"),\n            JsonValue::Null,\n        ),\n    }\n}\n\nfn panic_error() -> Error {\n    typed_error(CODE_PANIC, \"engine panic (see logs)\", JsonValue::Null)\n}\n\n/// Run a blocking engine call inside `tokio::task::spawn_blocking` so\n/// the libuv event loop stays free, wrapping it in `catch_unwind` so\n/// panics surface as the typed [`panic_error`] rather than aborting the\n/// host process. `AssertUnwindSafe` lets us thread the closure through\n/// without requiring `UnwindSafe` from the engine's `Arc<dyn Embedder>`\n/// substrate.\nasync fn call_engine<R, F>(f: F) -> Result<R>\nwhere\n    R: Send + 'static,\n    F: FnOnce() -> std::result::Result<R, RustEngineError> + Send + 'static,\n{\n    let join_result = tokio::task::spawn_blocking(move || catch_unwind(AssertUnwindSafe(f))).await;\n    match join_result {\n        Ok(Ok(Ok(value))) => Ok(value),\n        Ok(Ok(Err(err))) => Err(engine_error_to_napi(err)),\n        Ok(Err(_panic)) => Err(panic_error()),\n        Err(join_err) => Err(typed_error(\n            CODE_PANIC,\n            format!(\"spawn_blocking join error: {join_err}\"),\n            JsonValue::Null,\n        )),\n    }\n}\n\n// ===== Data classes ===================================================\n\n#[napi(object)]\npub struct WriteReceipt {\n    pub cursor: i64,\n}\n\nimpl WriteReceipt {\n    fn from_rust(r: RustWriteReceipt) -> Self {\n        Self { cursor: r.cursor as i64 }\n    }\n}\n\n#[napi(object)]\npub struct SoftFallback {\n    /// \"vector\" | \"text\"\n    pub branch: String,\n}\n\n#[napi(object)]\npub struct SearchResult {\n    pub projection_cursor: i64,\n    pub soft_fallback: Option<SoftFallback>,\n    pub results: Vec<String>,\n}\n\nimpl SearchResult {\n    fn from_rust(r: RustSearchResult) -> Self {\n        Self {\n            projection_cursor: r.projection_cursor as i64,\n            soft_fallback: r.soft_fallback.as_ref().map(|s| SoftFallback {\n                branch: match s.branch {\n                    SoftFallbackBranch::Vector => \"vector\".to_string(),\n                    SoftFallbackBranch::Text => \"text\".to_string(),\n                },\n            }),\n            results: r.results,\n        }\n    }\n}\n\n#[napi(object)]\npub struct CounterSnapshot {\n    pub queries: i64,\n    pub writes: i64,\n    pub write_rows: i64,\n    pub admin_ops: i64,\n    pub cache_hit: i64,\n    pub cache_miss: i64,\n}\n\n#[napi(object)]\npub struct AttachSubscriberOptions {\n    pub heartbeat_interval_ms: Option<u32>,\n}\n\n#[napi(object)]\npub struct EngineConfig {\n    pub embedder_pool_size: Option<u32>,\n    pub scheduler_runtime_threads: Option<u32>,\n    pub provenance_row_cap: Option<u32>,\n    pub embedder_call_timeout_ms: Option<u32>,\n    pub slow_threshold_ms: Option<u32>,\n}\n\n#[napi(object)]\npub struct EngineOpenOptions {\n    pub engine_config: Option<EngineConfig>,\n}\n\n#[napi(object)]\npub struct AdminConfigureOptions {\n    pub name: String,\n    pub body: String,\n}\n\n// ===== Engine =========================================================\n\n#[napi]\npub struct Engine {\n    inner: Arc<RustEngine>,\n}\n\n#[napi]\nimpl Engine {\n    /// Promise-returning open per `dev/interfaces/typescript.md`. The\n    /// blocking SQLite work runs on a tokio blocking thread.\n    #[napi(factory)]\n    pub async fn open(path: String, options: Option<EngineOpenOptions>) -> Result<Engine> {\n        validate_ffi_string_napi(&path)?;\n        let _ = options; // engineConfig knobs are recognised but not yet plumbed; see fathomdb-py.\n        let join_result = tokio::task::spawn_blocking(move || {\n            catch_unwind(AssertUnwindSafe(|| RustEngine::open(path)))\n        })\n        .await;\n        let opened = match join_result {\n            Ok(Ok(Ok(opened))) => opened,\n            Ok(Ok(Err(err))) => return Err(engine_open_error_to_napi(err)),\n            Ok(Err(_panic)) => return Err(panic_error()),\n            Err(join_err) => {\n                return Err(typed_error(\n                    CODE_PANIC,\n                    format!(\"spawn_blocking join error: {join_err}\"),\n                    JsonValue::Null,\n                ))\n            }\n        };\n        Ok(Engine { inner: Arc::new(opened.engine) })\n    }\n\n    #[napi]\n    pub async fn write(&self, batch: Vec<JsonValue>) -> Result<WriteReceipt> {\n        let prepared = translate_batch(batch)?;\n        let engine = Arc::clone(&self.inner);\n        let receipt = call_engine(move || engine.write(&prepared)).await?;\n        Ok(WriteReceipt::from_rust(receipt))\n    }\n\n    #[napi]\n    pub async fn search(&self, query: String) -> Result<SearchResult> {\n        validate_ffi_string_napi(&query)?;\n        if query.trim().is_empty() {\n            return Err(typed_error(\n                CODE_WRITE_VALIDATION,\n                \"query must not be empty\",\n                JsonValue::Null,\n            ));\n        }\n        let engine = Arc::clone(&self.inner);\n        let result = call_engine(move || engine.search(&query)).await?;\n        Ok(SearchResult::from_rust(result))\n    }\n\n    #[napi]\n    pub async fn close(&self) -> Result<()> {\n        let engine = Arc::clone(&self.inner);\n        call_engine(move || engine.close()).await\n    }\n\n    #[napi]\n    pub async fn drain(&self, timeout_ms: u32) -> Result<()> {\n        let engine = Arc::clone(&self.inner);\n        let ms = timeout_ms as u64;\n        call_engine(move || engine.drain(ms)).await\n    }\n\n    #[napi]\n    pub fn counters(&self) -> CounterSnapshot {\n        let snap = self.inner.counters();\n        CounterSnapshot {\n            queries: snap.queries as i64,\n            writes: snap.writes as i64,\n            write_rows: snap.write_rows as i64,\n            admin_ops: snap.admin_ops as i64,\n            cache_hit: snap.cache_hit as i64,\n            cache_miss: snap.cache_miss as i64,\n        }\n    }\n\n    #[napi]\n    pub fn set_profiling(&self, enabled: bool) -> Result<()> {\n        self.inner.set_profiling(enabled).map_err(engine_error_to_napi)\n    }\n\n    #[napi]\n    pub fn set_slow_threshold_ms(&self, value: u32) -> Result<()> {\n        self.inner.set_slow_threshold_ms(value as u64).map_err(engine_error_to_napi)\n    }\n\n    /// Subscriber wiring lands in a later 0.6.x slice; the binding\n    /// accepts the call so callers can wire a callback against the\n    /// public surface without a runtime error.\n    #[napi]\n    pub fn attach_subscriber(\n        &self,\n        callback: JsUnknown,\n        options: Option<AttachSubscriberOptions>,\n    ) -> Result<()> {\n        let _ = callback;\n        let _ = options;\n        Ok(())\n    }\n}\n\n// ===== admin.configure ================================================\n\n#[napi(js_name = \"adminConfigure\")]\npub async fn admin_configure(\n    engine: &Engine,\n    options: AdminConfigureOptions,\n) -> Result<WriteReceipt> {\n    validate_ffi_string_napi(&options.name)?;\n    validate_ffi_string_napi(&options.body)?;\n    if options.name.is_empty() {\n        return Err(typed_error(\n            CODE_WRITE_VALIDATION,\n            \"admin.configure requires a non-empty name\",\n            JsonValue::Null,\n        ));\n    }\n    // why: `dev/interfaces/typescript.md` § Runtime surface pins the\n    // admin.configure({ name, body }) signature; the engine's\n    // `PreparedWrite::AdminSchema` requires `kind ∈ {latest_state,\n    // append_only_log}`. The TS verb is sugar over latest-state\n    // collection registration in 0.6.0.\n    let batch = vec![PreparedWrite::AdminSchema {\n        name: options.name,\n        kind: \"latest_state\".to_string(),\n        schema_json: options.body,\n        retention_json: \"{}\".to_string(),\n    }];\n    let inner = Arc::clone(&engine.inner);\n    let receipt = call_engine(move || inner.write(&batch)).await?;\n    Ok(WriteReceipt::from_rust(receipt))\n}\n\n// ===== Batch translation ==============================================\n//\n// The TS surface accepts a JS array of typed-write objects. Each item\n// is one of:\n//   { node: { kind, body?, sourceId? } }\n//   { edge: { kind, from, to, sourceId? } }\n//   { opStore: { collection, recordKey, schemaId?, body } }\n//   { adminSchema: { name, kind, schemaJson, retentionJson? } }\n// Plus a bare `{ kind, body?, sourceId? }` shape treated as Node (parity\n// with the Python stub). serde_json::Value is the cheapest cross-thread\n// representation; napi-rs converts JS objects via the `serde-json`\n// feature.\n\nfn translate_batch(batch: Vec<JsonValue>) -> Result<Vec<PreparedWrite>> {\n    batch.into_iter().map(translate_write_item).collect()\n}\n\nfn json_get<'a>(v: &'a JsonValue, key: &str) -> Option<&'a JsonValue> {\n    v.as_object().and_then(|m| m.get(key))\n}\n\nfn json_str(v: &JsonValue, key: &str) -> Result<Option<String>> {\n    match json_get(v, key) {\n        Some(JsonValue::Null) | None => Ok(None),\n        Some(JsonValue::String(s)) => {\n            validate_ffi_string_napi(s)?;\n            Ok(Some(s.clone()))\n        }\n        Some(_other) => Err(typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"field {key:?} must be a string\"),\n            JsonValue::Null,\n        )),\n    }\n}\n\nfn json_str_required(v: &JsonValue, key: &str) -> Result<String> {\n    json_str(v, key)?.ok_or_else(|| {\n        typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"write item missing required field {key:?}\"),\n            JsonValue::Null,\n        )\n    })\n}\n\nfn json_serialised(v: &JsonValue, key: &str) -> Result<Option<String>> {\n    match json_get(v, key) {\n        Some(JsonValue::Null) | None => Ok(None),\n        Some(JsonValue::String(s)) => {\n            validate_ffi_string_napi(s)?;\n            Ok(Some(s.clone()))\n        }\n        Some(other) => {\n            let serialised = serde_json::to_string(other).map_err(|e| {\n                typed_error(\n                    CODE_WRITE_VALIDATION,\n                    format!(\"field {key:?} not serialisable: {e}\"),\n                    JsonValue::Null,\n                )\n            })?;\n            validate_ffi_string_napi(&serialised)?;\n            Ok(Some(serialised))\n        }\n    }\n}\n\nfn json_serialised_required(v: &JsonValue, key: &str) -> Result<String> {\n    json_serialised(v, key)?.ok_or_else(|| {\n        typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"write item missing required field {key:?}\"),\n            JsonValue::Null,\n        )\n    })\n}\n\nfn translate_write_item(item: JsonValue) -> Result<PreparedWrite> {\n    if !item.is_object() {\n        return Err(typed_error(\n            CODE_WRITE_VALIDATION,\n            \"write item must be an object\",\n            JsonValue::Null,\n        ));\n    }\n    if let Some(inner) = json_get(&item, \"edge\") {\n        return translate_edge(inner);\n    }\n    if let Some(inner) = json_get(&item, \"opStore\").or_else(|| json_get(&item, \"op_store\")) {\n        return translate_op_store(inner);\n    }\n    if let Some(inner) = json_get(&item, \"adminSchema\").or_else(|| json_get(&item, \"admin_schema\"))\n    {\n        return translate_admin_schema(inner);\n    }\n    if let Some(inner) = json_get(&item, \"node\") {\n        return translate_node(inner);\n    }\n    translate_node(&item)\n}\n\n/// Look up `camelCase` first, then `snake_case`, returning the first\n/// present string. Both forms are checked so callers porting from the\n/// Python stub keep working without surface-level rewrites.\nfn json_str_alt(item: &JsonValue, camel: &str, snake: &str) -> Result<Option<String>> {\n    if let Some(v) = json_str(item, camel)? {\n        return Ok(Some(v));\n    }\n    json_str(item, snake)\n}\n\nfn json_str_alt_required(item: &JsonValue, camel: &str, snake: &str) -> Result<String> {\n    json_str_alt(item, camel, snake)?.ok_or_else(|| {\n        typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"write item missing required field {camel:?}\"),\n            JsonValue::Null,\n        )\n    })\n}\n\nfn json_serialised_alt(item: &JsonValue, camel: &str, snake: &str) -> Result<Option<String>> {\n    if let Some(v) = json_serialised(item, camel)? {\n        return Ok(Some(v));\n    }\n    json_serialised(item, snake)\n}\n\nfn json_serialised_alt_required(item: &JsonValue, camel: &str, snake: &str) -> Result<String> {\n    json_serialised_alt(item, camel, snake)?.ok_or_else(|| {\n        typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"write item missing required field {camel:?}\"),\n            JsonValue::Null,\n        )\n    })\n}\n\nfn translate_node(item: &JsonValue) -> Result<PreparedWrite> {\n    let kind = json_str_required(item, \"kind\")?;\n    let body = json_serialised(item, \"body\")?.unwrap_or_else(|| \"{}\".to_string());\n    let source_id = json_str_alt(item, \"sourceId\", \"source_id\")?;\n    Ok(PreparedWrite::Node { kind, body, source_id })\n}\n\nfn translate_edge(item: &JsonValue) -> Result<PreparedWrite> {\n    let kind = json_str_required(item, \"kind\")?;\n    let from = json_str_required(item, \"from\")?;\n    let to = json_str_required(item, \"to\")?;\n    let source_id = json_str_alt(item, \"sourceId\", \"source_id\")?;\n    Ok(PreparedWrite::Edge { kind, from, to, source_id })\n}\n\nfn translate_op_store(item: &JsonValue) -> Result<PreparedWrite> {\n    let collection = json_str_required(item, \"collection\")?;\n    let record_key = json_str_alt_required(item, \"recordKey\", \"record_key\")?;\n    let schema_id = json_str_alt(item, \"schemaId\", \"schema_id\")?;\n    let body = json_serialised_required(item, \"body\")?;\n    Ok(PreparedWrite::OpStore { collection, record_key, schema_id, body })\n}\n\nfn translate_admin_schema(item: &JsonValue) -> Result<PreparedWrite> {\n    let name = json_str_required(item, \"name\")?;\n    let kind = json_str_required(item, \"kind\")?;\n    let schema_json = json_serialised_alt_required(item, \"schemaJson\", \"schema_json\")?;\n    let retention_json = json_serialised_alt(item, \"retentionJson\", \"retention_json\")?\n        .unwrap_or_else(|| \"{}\".to_string());\n    Ok(PreparedWrite::AdminSchema { name, kind, schema_json, retention_json })\n}\n\n// ===== Test hooks =====================================================\n\n/// AC-067 force-panic probe. Gated by `cfg(any(test, feature =\n/// \"test-hooks\"))` so release npm builds without the feature flag do\n/// not expose it.\n#[cfg(any(test, feature = \"test-hooks\"))]\n#[napi(js_name = \"forcePanicForTest\")]\npub fn force_panic_for_test() -> Result<()> {\n    call_panicking_engine_for_test()\n}\n\n#[cfg(any(test, feature = \"test-hooks\"))]\nfn call_panicking_engine_for_test() -> Result<()> {\n    // Run the panic through the same catch_unwind path that real\n    // engine calls use so the TS-side test exercises the production\n    // panic-translation seam.\n    let join_result = std::panic::catch_unwind(AssertUnwindSafe(\n        || -> std::result::Result<(), RustEngineError> {\n            panic!(\"force_panic_for_test: AC-067 probe\");\n        },\n    ));\n    match join_result {\n        Ok(Ok(())) => Ok(()),\n        Ok(Err(err)) => Err(engine_error_to_napi(err)),\n        Err(_) => Err(panic_error()),\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn validate_ffi_string_accepts_plain_ascii() {\n        assert!(validate_ffi_string(\"hello\").is_ok());\n    }\n\n    #[test]\n    fn validate_ffi_string_accepts_non_ascii_utf8() {\n        assert!(validate_ffi_string(\"héllo 🦀 文字\").is_ok());\n    }\n\n    #[test]\n    fn validate_ffi_string_rejects_embedded_nul() {\n        let err = validate_ffi_string(\"a\\0b\").unwrap_err();\n        assert!(err.contains(\"NUL\"), \"expected NUL diagnostic, got {err:?}\");\n    }\n\n    #[test]\n    fn validate_ffi_string_accepts_replacement_codepoint() {\n        // U+FFFD is the only \"high unicode\" codepoint a Rust &str can\n        // hold near the surrogate range; the codepoints U+D800..U+DFFF\n        // themselves cannot appear in valid UTF-8, so the runtime\n        // guard is exercised when JS surrogates round-trip through\n        // napi-rs string conversion (covered by ffi-safety.test.ts).\n        assert!(validate_ffi_string(\"\\u{FFFD}\").is_ok());\n    }\n}\n","structuredPatch":[{"oldStart":283,"oldLines":6,"newStart":283,"newLines":19,"lines":["     }"," }"," ","+/// Sync sibling of [`call_engine`]: wrap a non-blocking accessor in","+/// `catch_unwind` so a panic on the JS thread surfaces as [`panic_error`]","+/// instead of unwinding into napi-rs's default `GenericFailure` path.","+fn call_engine_sync<R, F>(f: F) -> Result<R>","+where","+    F: FnOnce() -> Result<R>,","+{","+    match catch_unwind(AssertUnwindSafe(f)) {","+        Ok(result) => result,","+        Err(_panic) => Err(panic_error()),","+    }","+}","+"," // ===== Data classes ==================================================="," "," #[napi(object)]"]}],"userModified":false,"replaceAll":false}}
dev/plans/runs/11b-fix-1-20260516T214419Z.log:221:{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014vhdn6rzrsQXJ8AeSvam7w","type":"tool_result","content":"The file /tmp/fdb-11b-napi-binding-20260516T210327Z/src/rust/crates/fathomdb-napi/src/lib.rs has been updated successfully. (file state is current in your context — no need to Read it back)"}]},"parent_tool_use_id":null,"session_id":"a52cedd5-f91e-4c7f-aa9c-db400e73d860","uuid":"662f84e7-9730-4acf-a264-a7941218b193","timestamp":"2026-05-16T21:44:56.900Z","tool_use_result":{"filePath":"/tmp/fdb-11b-napi-binding-20260516T210327Z/src/rust/crates/fathomdb-napi/src/lib.rs","oldString":"    #[napi]\n    pub fn counters(&self) -> CounterSnapshot {\n        let snap = self.inner.counters();\n        CounterSnapshot {\n            queries: snap.queries as i64,\n            writes: snap.writes as i64,\n            write_rows: snap.write_rows as i64,\n            admin_ops: snap.admin_ops as i64,\n            cache_hit: snap.cache_hit as i64,\n            cache_miss: snap.cache_miss as i64,\n        }\n    }\n\n    #[napi]\n    pub fn set_profiling(&self, enabled: bool) -> Result<()> {\n        self.inner.set_profiling(enabled).map_err(engine_error_to_napi)\n    }\n\n    #[napi]\n    pub fn set_slow_threshold_ms(&self, value: u32) -> Result<()> {\n        self.inner.set_slow_threshold_ms(value as u64).map_err(engine_error_to_napi)\n    }\n\n    /// Subscriber wiring lands in a later 0.6.x slice; the binding\n    /// accepts the call so callers can wire a callback against the\n    /// public surface without a runtime error.\n    #[napi]\n    pub fn attach_subscriber(\n        &self,\n        callback: JsUnknown,\n        options: Option<AttachSubscriberOptions>,\n    ) -> Result<()> {\n        let _ = callback;\n        let _ = options;\n        Ok(())\n    }\n}","newString":"    #[napi]\n    pub fn counters(&self) -> Result<CounterSnapshot> {\n        let engine = Arc::clone(&self.inner);\n        call_engine_sync(move || {\n            let snap = engine.counters();\n            Ok(CounterSnapshot {\n                queries: snap.queries as i64,\n                writes: snap.writes as i64,\n                write_rows: snap.write_rows as i64,\n                admin_ops: snap.admin_ops as i64,\n                cache_hit: snap.cache_hit as i64,\n                cache_miss: snap.cache_miss as i64,\n            })\n        })\n    }\n\n    #[napi]\n    pub fn set_profiling(&self, enabled: bool) -> Result<()> {\n        let engine = Arc::clone(&self.inner);\n        call_engine_sync(move || engine.set_profiling(enabled).map_err(engine_error_to_napi))\n    }\n\n    #[napi]\n    pub fn set_slow_threshold_ms(&self, value: u32) -> Result<()> {\n        let engine = Arc::clone(&self.inner);\n        call_engine_sync(move || {\n            engine.set_slow_threshold_ms(value as u64).map_err(engine_error_to_napi)\n        })\n    }\n\n    /// Subscriber wiring lands in a later 0.6.x slice; the binding\n    /// accepts the call so callers can wire a callback against the\n    /// public surface without a runtime error.\n    #[napi]\n    pub fn attach_subscriber(\n        &self,\n        callback: JsUnknown,\n        options: Option<AttachSubscriberOptions>,\n    ) -> Result<()> {\n        let _ = callback;\n        let _ = options;\n        call_engine_sync(|| Ok(()))\n    }\n}","originalFile":"//! napi-rs binding from the TypeScript SDK to `fathomdb-engine`.\n//!\n//! FFI safety contract (mirrors the PyO3 binding in `fathomdb-py`):\n//!\n//! 1. Every method that may block inside the engine runs its blocking\n//!    body inside `tokio::task::spawn_blocking`, so the libuv main\n//!    thread is never tied up. napi-rs's `#[napi] async fn` wraps\n//!    return values as JS `Promise<T>`.\n//! 2. Engine entry points return typed errors via [`engine_error_to_napi`] /\n//!    [`engine_open_error_to_napi`] — single-switch mapping with no\n//!    catch-all arm; the binding fails to compile when the Rust variant\n//!    set drifts from the TS leaf-class set (AC-060a).\n//! 3. Every string crossing the FFI is checked by [`validate_ffi_string`]\n//!    for embedded NUL or unpaired UTF-16 surrogates BEFORE the writer\n//!    transaction opens (AC-068a / AC-068b).\n//! 4. Engine panics are caught via `catch_unwind` inside the spawn-blocking\n//!    body and rethrown as a distinct `FathomDbPanicError` (code\n//!    `FDB_PANIC`); the host process is not aborted (AC-067).\n//\n// why: napi-rs catches panics by default but throws a generic JS\n// `Error` with `Status::GenericFailure` and a Rust-formatted message,\n// which is hard to assert on. Explicit `catch_unwind` + a stable\n// `FDB_PANIC` code lets the TS-side `rethrowTyped` map panics to a\n// distinct `FathomDbPanicError` class that is intentionally NOT a\n// `FathomDbError` subclass: panic is a contract bug, not a typed\n// engine outcome.\n\nuse std::panic::{catch_unwind, AssertUnwindSafe};\nuse std::sync::Arc;\n\nuse fathomdb_engine::{\n    CorruptionDetail, CorruptionKind, Engine as RustEngine, EngineError as RustEngineError,\n    EngineOpenError, OpenStage, PreparedWrite, SearchResult as RustSearchResult,\n    SoftFallbackBranch, WriteReceipt as RustWriteReceipt,\n};\nuse napi::{Error, JsUnknown, Result, Status};\nuse napi_derive::napi;\nuse serde::Serialize;\nuse serde_json::{json, Value as JsonValue};\n\n// ===== Error-code constants ===========================================\n//\n// One per typed leaf class on the TS side. The single-switch translator\n// below maps every engine variant to exactly one of these codes; the TS\n// `rethrowTyped` table maps each code to exactly one leaf class. Drift\n// fails to compile (Rust side) or fails an exhaustiveness check (TS).\n\nconst CODE_STORAGE: &str = \"FDB_STORAGE\";\nconst CODE_PROJECTION: &str = \"FDB_PROJECTION\";\nconst CODE_VECTOR: &str = \"FDB_VECTOR\";\nconst CODE_EMBEDDER: &str = \"FDB_EMBEDDER\";\nconst CODE_EMBEDDER_NOT_CONFIGURED: &str = \"FDB_EMBEDDER_NOT_CONFIGURED\";\nconst CODE_KIND_NOT_VECTOR_INDEXED: &str = \"FDB_KIND_NOT_VECTOR_INDEXED\";\nconst CODE_EMBEDDER_DIMENSION_MISMATCH: &str = \"FDB_EMBEDDER_DIMENSION_MISMATCH\";\nconst CODE_SCHEDULER: &str = \"FDB_SCHEDULER\";\nconst CODE_OP_STORE: &str = \"FDB_OP_STORE\";\nconst CODE_WRITE_VALIDATION: &str = \"FDB_WRITE_VALIDATION\";\nconst CODE_SCHEMA_VALIDATION: &str = \"FDB_SCHEMA_VALIDATION\";\nconst CODE_OVERLOADED: &str = \"FDB_OVERLOADED\";\nconst CODE_CLOSING: &str = \"FDB_CLOSING\";\nconst CODE_DATABASE_LOCKED: &str = \"FDB_DATABASE_LOCKED\";\nconst CODE_CORRUPTION: &str = \"FDB_CORRUPTION\";\nconst CODE_INCOMPATIBLE_SCHEMA_VERSION: &str = \"FDB_INCOMPATIBLE_SCHEMA_VERSION\";\nconst CODE_MIGRATION: &str = \"FDB_MIGRATION\";\nconst CODE_EMBEDDER_IDENTITY_MISMATCH: &str = \"FDB_EMBEDDER_IDENTITY_MISMATCH\";\nconst CODE_PANIC: &str = \"FDB_PANIC\";\n\n// ===== Typed-error encoder ============================================\n\n/// Encode a typed-error envelope as JSON in `err.message` so the\n/// TS-side `rethrowTyped` can reconstitute the right leaf class with\n/// the right payload. napi-rs 2.x has no public API for throwing a\n/// Rust-defined JS class directly; the envelope-in-message pattern is\n/// the canonical workaround.\n#[derive(Serialize)]\nstruct TypedEnvelope<'a> {\n    code: &'a str,\n    message: String,\n    payload: JsonValue,\n}\n\nfn typed_error(code: &'static str, message: impl Into<String>, payload: JsonValue) -> Error {\n    let envelope = TypedEnvelope { code, message: message.into(), payload };\n    // serde_json serialization is infallible for our envelope shape;\n    // unwrap is safe.\n    let reason = serde_json::to_string(&envelope).unwrap();\n    Error::new(Status::GenericFailure, reason)\n}\n\n// ===== String validation (AC-068a / AC-068b) =========================\n\n/// Reject strings carrying an embedded NUL or an unpaired UTF-16\n/// surrogate codepoint (`U+D800..=U+DFFF`).\n///\n/// JavaScript strings are UTF-16 by spec, so lone surrogates are\n/// representable on the JS side (`String.fromCharCode(0xD800)`). The\n/// napi-rs string conversion translates UTF-16 → UTF-8 and accepts\n/// some malformed inputs; this helper rejects them BEFORE the writer\n/// transaction opens (no-row-written invariant).\npub fn validate_ffi_string(value: &str) -> std::result::Result<(), String> {\n    if value.as_bytes().contains(&0) {\n        return Err(\"embedded NUL byte in FFI string\".to_string());\n    }\n    for ch in value.chars() {\n        let cp = ch as u32;\n        if (0xD800..=0xDFFF).contains(&cp) {\n            return Err(format!(\"unpaired UTF-16 surrogate U+{cp:04X} in FFI string\"));\n        }\n    }\n    Ok(())\n}\n\nfn validate_ffi_string_napi(value: &str) -> Result<()> {\n    validate_ffi_string(value)\n        .map_err(|msg| typed_error(CODE_WRITE_VALIDATION, msg, JsonValue::Null))\n}\n\n// ===== Error mapping ==================================================\n\n/// Translate every `EngineError` variant to its typed JS counterpart.\n///\n/// No catch-all arm: drift between the Rust enum and the TS class set\n/// is a compile error.\nfn engine_error_to_napi(err: RustEngineError) -> Error {\n    match err {\n        RustEngineError::Storage => typed_error(CODE_STORAGE, \"storage error\", JsonValue::Null),\n        RustEngineError::Projection => {\n            typed_error(CODE_PROJECTION, \"projection error\", JsonValue::Null)\n        }\n        RustEngineError::Vector => typed_error(CODE_VECTOR, \"vector error\", JsonValue::Null),\n        RustEngineError::Embedder => typed_error(CODE_EMBEDDER, \"embedder error\", JsonValue::Null),\n        RustEngineError::EmbedderNotConfigured => {\n            typed_error(CODE_EMBEDDER_NOT_CONFIGURED, \"embedder is not configured\", JsonValue::Null)\n        }\n        RustEngineError::KindNotVectorIndexed => typed_error(\n            CODE_KIND_NOT_VECTOR_INDEXED,\n            \"kind is not configured for vector indexing\",\n            JsonValue::Null,\n        ),\n        RustEngineError::EmbedderDimensionMismatch { expected, actual } => typed_error(\n            CODE_EMBEDDER_DIMENSION_MISMATCH,\n            format!(\"embedder vector dimension mismatch: stored {expected}, supplied {actual}\"),\n            json!({ \"stored\": expected, \"supplied\": actual }),\n        ),\n        RustEngineError::Scheduler => {\n            typed_error(CODE_SCHEDULER, \"scheduler error\", JsonValue::Null)\n        }\n        RustEngineError::OpStore => typed_error(CODE_OP_STORE, \"op-store error\", JsonValue::Null),\n        RustEngineError::WriteValidation => {\n            typed_error(CODE_WRITE_VALIDATION, \"write validation error\", JsonValue::Null)\n        }\n        RustEngineError::SchemaValidation => {\n            typed_error(CODE_SCHEMA_VALIDATION, \"schema validation error\", JsonValue::Null)\n        }\n        RustEngineError::Overloaded => {\n            typed_error(CODE_OVERLOADED, \"engine overloaded\", JsonValue::Null)\n        }\n        RustEngineError::Closing => typed_error(CODE_CLOSING, \"engine is closing\", JsonValue::Null),\n    }\n}\n\nfn corruption_kind_str(kind: CorruptionKind) -> &'static str {\n    match kind {\n        CorruptionKind::WalReplayFailure => \"WalReplayFailure\",\n        CorruptionKind::HeaderMalformed => \"HeaderMalformed\",\n        CorruptionKind::SchemaInconsistent => \"SchemaInconsistent\",\n        CorruptionKind::EmbedderIdentityDrift => \"EmbedderIdentityDrift\",\n    }\n}\n\nfn open_stage_str(stage: OpenStage) -> &'static str {\n    match stage {\n        OpenStage::HeaderProbe => \"HeaderProbe\",\n        OpenStage::WalReplay => \"WalReplay\",\n        OpenStage::SchemaProbe => \"SchemaProbe\",\n        OpenStage::EmbedderIdentity => \"EmbedderIdentity\",\n    }\n}\n\nfn corruption_to_napi(detail: CorruptionDetail) -> Error {\n    let kind = corruption_kind_str(detail.kind);\n    let stage = open_stage_str(detail.stage);\n    let recovery_hint_code = detail.recovery_hint.code;\n    let doc_anchor = detail.recovery_hint.doc_anchor;\n    typed_error(\n        CODE_CORRUPTION,\n        format!(\"corruption {kind} at stage {stage} ({recovery_hint_code})\"),\n        json!({\n            \"kind\": kind,\n            \"stage\": stage,\n            \"recoveryHintCode\": recovery_hint_code,\n            \"docAnchor\": doc_anchor,\n        }),\n    )\n}\n\nfn engine_open_error_to_napi(err: EngineOpenError) -> Error {\n    match err {\n        EngineOpenError::DatabaseLocked { holder_pid } => typed_error(\n            CODE_DATABASE_LOCKED,\n            match holder_pid {\n                Some(pid) => format!(\"database is locked by process {pid}\"),\n                None => \"database is locked by another engine instance\".to_string(),\n            },\n            json!({ \"holderPid\": holder_pid }),\n        ),\n        EngineOpenError::Corruption(detail) => corruption_to_napi(detail),\n        EngineOpenError::IncompatibleSchemaVersion { seen, supported } => typed_error(\n            CODE_INCOMPATIBLE_SCHEMA_VERSION,\n            format!(\n                \"database schema version {seen} is incompatible with supported version {supported}\"\n            ),\n            json!({ \"seen\": seen, \"supported\": supported }),\n        ),\n        EngineOpenError::MigrationError {\n            schema_version_before,\n            schema_version_current,\n            step_id,\n        } => typed_error(\n            CODE_MIGRATION,\n            format!(\n                \"schema migration failed at step {step_id}; schema version remained between {schema_version_before} and {schema_version_current}\"\n            ),\n            json!({\n                \"schemaVersionBefore\": schema_version_before,\n                \"schemaVersionCurrent\": schema_version_current,\n                \"stepId\": step_id,\n            }),\n        ),\n        EngineOpenError::EmbedderIdentityMismatch { stored, supplied } => typed_error(\n            CODE_EMBEDDER_IDENTITY_MISMATCH,\n            format!(\n                \"embedder identity mismatch: stored {}@{}, supplied {}@{}\",\n                stored.name, stored.revision, supplied.name, supplied.revision,\n            ),\n            json!({\n                \"storedName\": stored.name,\n                \"storedRevision\": stored.revision,\n                \"suppliedName\": supplied.name,\n                \"suppliedRevision\": supplied.revision,\n            }),\n        ),\n        EngineOpenError::EmbedderDimensionMismatch { stored, supplied } => typed_error(\n            CODE_EMBEDDER_DIMENSION_MISMATCH,\n            format!(\n                \"embedder vector dimension mismatch: stored {stored}, supplied {supplied}\"\n            ),\n            json!({ \"stored\": stored, \"supplied\": supplied }),\n        ),\n        EngineOpenError::Io { message } => typed_error(\n            CODE_STORAGE,\n            format!(\"database I/O error: {message}\"),\n            JsonValue::Null,\n        ),\n    }\n}\n\nfn panic_error() -> Error {\n    typed_error(CODE_PANIC, \"engine panic (see logs)\", JsonValue::Null)\n}\n\n/// Run a blocking engine call inside `tokio::task::spawn_blocking` so\n/// the libuv event loop stays free, wrapping it in `catch_unwind` so\n/// panics surface as the typed [`panic_error`] rather than aborting the\n/// host process. `AssertUnwindSafe` lets us thread the closure through\n/// without requiring `UnwindSafe` from the engine's `Arc<dyn Embedder>`\n/// substrate.\nasync fn call_engine<R, F>(f: F) -> Result<R>\nwhere\n    R: Send + 'static,\n    F: FnOnce() -> std::result::Result<R, RustEngineError> + Send + 'static,\n{\n    let join_result = tokio::task::spawn_blocking(move || catch_unwind(AssertUnwindSafe(f))).await;\n    match join_result {\n        Ok(Ok(Ok(value))) => Ok(value),\n        Ok(Ok(Err(err))) => Err(engine_error_to_napi(err)),\n        Ok(Err(_panic)) => Err(panic_error()),\n        Err(join_err) => Err(typed_error(\n            CODE_PANIC,\n            format!(\"spawn_blocking join error: {join_err}\"),\n            JsonValue::Null,\n        )),\n    }\n}\n\n/// Sync sibling of [`call_engine`]: wrap a non-blocking accessor in\n/// `catch_unwind` so a panic on the JS thread surfaces as [`panic_error`]\n/// instead of unwinding into napi-rs's default `GenericFailure` path.\nfn call_engine_sync<R, F>(f: F) -> Result<R>\nwhere\n    F: FnOnce() -> Result<R>,\n{\n    match catch_unwind(AssertUnwindSafe(f)) {\n        Ok(result) => result,\n        Err(_panic) => Err(panic_error()),\n    }\n}\n\n// ===== Data classes ===================================================\n\n#[napi(object)]\npub struct WriteReceipt {\n    pub cursor: i64,\n}\n\nimpl WriteReceipt {\n    fn from_rust(r: RustWriteReceipt) -> Self {\n        Self { cursor: r.cursor as i64 }\n    }\n}\n\n#[napi(object)]\npub struct SoftFallback {\n    /// \"vector\" | \"text\"\n    pub branch: String,\n}\n\n#[napi(object)]\npub struct SearchResult {\n    pub projection_cursor: i64,\n    pub soft_fallback: Option<SoftFallback>,\n    pub results: Vec<String>,\n}\n\nimpl SearchResult {\n    fn from_rust(r: RustSearchResult) -> Self {\n        Self {\n            projection_cursor: r.projection_cursor as i64,\n            soft_fallback: r.soft_fallback.as_ref().map(|s| SoftFallback {\n                branch: match s.branch {\n                    SoftFallbackBranch::Vector => \"vector\".to_string(),\n                    SoftFallbackBranch::Text => \"text\".to_string(),\n                },\n            }),\n            results: r.results,\n        }\n    }\n}\n\n#[napi(object)]\npub struct CounterSnapshot {\n    pub queries: i64,\n    pub writes: i64,\n    pub write_rows: i64,\n    pub admin_ops: i64,\n    pub cache_hit: i64,\n    pub cache_miss: i64,\n}\n\n#[napi(object)]\npub struct AttachSubscriberOptions {\n    pub heartbeat_interval_ms: Option<u32>,\n}\n\n#[napi(object)]\npub struct EngineConfig {\n    pub embedder_pool_size: Option<u32>,\n    pub scheduler_runtime_threads: Option<u32>,\n    pub provenance_row_cap: Option<u32>,\n    pub embedder_call_timeout_ms: Option<u32>,\n    pub slow_threshold_ms: Option<u32>,\n}\n\n#[napi(object)]\npub struct EngineOpenOptions {\n    pub engine_config: Option<EngineConfig>,\n}\n\n#[napi(object)]\npub struct AdminConfigureOptions {\n    pub name: String,\n    pub body: String,\n}\n\n// ===== Engine =========================================================\n\n#[napi]\npub struct Engine {\n    inner: Arc<RustEngine>,\n}\n\n#[napi]\nimpl Engine {\n    /// Promise-returning open per `dev/interfaces/typescript.md`. The\n    /// blocking SQLite work runs on a tokio blocking thread.\n    #[napi(factory)]\n    pub async fn open(path: String, options: Option<EngineOpenOptions>) -> Result<Engine> {\n        validate_ffi_string_napi(&path)?;\n        let _ = options; // engineConfig knobs are recognised but not yet plumbed; see fathomdb-py.\n        let join_result = tokio::task::spawn_blocking(move || {\n            catch_unwind(AssertUnwindSafe(|| RustEngine::open(path)))\n        })\n        .await;\n        let opened = match join_result {\n            Ok(Ok(Ok(opened))) => opened,\n            Ok(Ok(Err(err))) => return Err(engine_open_error_to_napi(err)),\n            Ok(Err(_panic)) => return Err(panic_error()),\n            Err(join_err) => {\n                return Err(typed_error(\n                    CODE_PANIC,\n                    format!(\"spawn_blocking join error: {join_err}\"),\n                    JsonValue::Null,\n                ))\n            }\n        };\n        Ok(Engine { inner: Arc::new(opened.engine) })\n    }\n\n    #[napi]\n    pub async fn write(&self, batch: Vec<JsonValue>) -> Result<WriteReceipt> {\n        let prepared = translate_batch(batch)?;\n        let engine = Arc::clone(&self.inner);\n        let receipt = call_engine(move || engine.write(&prepared)).await?;\n        Ok(WriteReceipt::from_rust(receipt))\n    }\n\n    #[napi]\n    pub async fn search(&self, query: String) -> Result<SearchResult> {\n        validate_ffi_string_napi(&query)?;\n        if query.trim().is_empty() {\n            return Err(typed_error(\n                CODE_WRITE_VALIDATION,\n                \"query must not be empty\",\n                JsonValue::Null,\n            ));\n        }\n        let engine = Arc::clone(&self.inner);\n        let result = call_engine(move || engine.search(&query)).await?;\n        Ok(SearchResult::from_rust(result))\n    }\n\n    #[napi]\n    pub async fn close(&self) -> Result<()> {\n        let engine = Arc::clone(&self.inner);\n        call_engine(move || engine.close()).await\n    }\n\n    #[napi]\n    pub async fn drain(&self, timeout_ms: u32) -> Result<()> {\n        let engine = Arc::clone(&self.inner);\n        let ms = timeout_ms as u64;\n        call_engine(move || engine.drain(ms)).await\n    }\n\n    #[napi]\n    pub fn counters(&self) -> CounterSnapshot {\n        let snap = self.inner.counters();\n        CounterSnapshot {\n            queries: snap.queries as i64,\n            writes: snap.writes as i64,\n            write_rows: snap.write_rows as i64,\n            admin_ops: snap.admin_ops as i64,\n            cache_hit: snap.cache_hit as i64,\n            cache_miss: snap.cache_miss as i64,\n        }\n    }\n\n    #[napi]\n    pub fn set_profiling(&self, enabled: bool) -> Result<()> {\n        self.inner.set_profiling(enabled).map_err(engine_error_to_napi)\n    }\n\n    #[napi]\n    pub fn set_slow_threshold_ms(&self, value: u32) -> Result<()> {\n        self.inner.set_slow_threshold_ms(value as u64).map_err(engine_error_to_napi)\n    }\n\n    /// Subscriber wiring lands in a later 0.6.x slice; the binding\n    /// accepts the call so callers can wire a callback against the\n    /// public surface without a runtime error.\n    #[napi]\n    pub fn attach_subscriber(\n        &self,\n        callback: JsUnknown,\n        options: Option<AttachSubscriberOptions>,\n    ) -> Result<()> {\n        let _ = callback;\n        let _ = options;\n        Ok(())\n    }\n}\n\n// ===== admin.configure ================================================\n\n#[napi(js_name = \"adminConfigure\")]\npub async fn admin_configure(\n    engine: &Engine,\n    options: AdminConfigureOptions,\n) -> Result<WriteReceipt> {\n    validate_ffi_string_napi(&options.name)?;\n    validate_ffi_string_napi(&options.body)?;\n    if options.name.is_empty() {\n        return Err(typed_error(\n            CODE_WRITE_VALIDATION,\n            \"admin.configure requires a non-empty name\",\n            JsonValue::Null,\n        ));\n    }\n    // why: `dev/interfaces/typescript.md` § Runtime surface pins the\n    // admin.configure({ name, body }) signature; the engine's\n    // `PreparedWrite::AdminSchema` requires `kind ∈ {latest_state,\n    // append_only_log}`. The TS verb is sugar over latest-state\n    // collection registration in 0.6.0.\n    let batch = vec![PreparedWrite::AdminSchema {\n        name: options.name,\n        kind: \"latest_state\".to_string(),\n        schema_json: options.body,\n        retention_json: \"{}\".to_string(),\n    }];\n    let inner = Arc::clone(&engine.inner);\n    let receipt = call_engine(move || inner.write(&batch)).await?;\n    Ok(WriteReceipt::from_rust(receipt))\n}\n\n// ===== Batch translation ==============================================\n//\n// The TS surface accepts a JS array of typed-write objects. Each item\n// is one of:\n//   { node: { kind, body?, sourceId? } }\n//   { edge: { kind, from, to, sourceId? } }\n//   { opStore: { collection, recordKey, schemaId?, body } }\n//   { adminSchema: { name, kind, schemaJson, retentionJson? } }\n// Plus a bare `{ kind, body?, sourceId? }` shape treated as Node (parity\n// with the Python stub). serde_json::Value is the cheapest cross-thread\n// representation; napi-rs converts JS objects via the `serde-json`\n// feature.\n\nfn translate_batch(batch: Vec<JsonValue>) -> Result<Vec<PreparedWrite>> {\n    batch.into_iter().map(translate_write_item).collect()\n}\n\nfn json_get<'a>(v: &'a JsonValue, key: &str) -> Option<&'a JsonValue> {\n    v.as_object().and_then(|m| m.get(key))\n}\n\nfn json_str(v: &JsonValue, key: &str) -> Result<Option<String>> {\n    match json_get(v, key) {\n        Some(JsonValue::Null) | None => Ok(None),\n        Some(JsonValue::String(s)) => {\n            validate_ffi_string_napi(s)?;\n            Ok(Some(s.clone()))\n        }\n        Some(_other) => Err(typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"field {key:?} must be a string\"),\n            JsonValue::Null,\n        )),\n    }\n}\n\nfn json_str_required(v: &JsonValue, key: &str) -> Result<String> {\n    json_str(v, key)?.ok_or_else(|| {\n        typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"write item missing required field {key:?}\"),\n            JsonValue::Null,\n        )\n    })\n}\n\nfn json_serialised(v: &JsonValue, key: &str) -> Result<Option<String>> {\n    match json_get(v, key) {\n        Some(JsonValue::Null) | None => Ok(None),\n        Some(JsonValue::String(s)) => {\n            validate_ffi_string_napi(s)?;\n            Ok(Some(s.clone()))\n        }\n        Some(other) => {\n            let serialised = serde_json::to_string(other).map_err(|e| {\n                typed_error(\n                    CODE_WRITE_VALIDATION,\n                    format!(\"field {key:?} not serialisable: {e}\"),\n                    JsonValue::Null,\n                )\n            })?;\n            validate_ffi_string_napi(&serialised)?;\n            Ok(Some(serialised))\n        }\n    }\n}\n\nfn json_serialised_required(v: &JsonValue, key: &str) -> Result<String> {\n    json_serialised(v, key)?.ok_or_else(|| {\n        typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"write item missing required field {key:?}\"),\n            JsonValue::Null,\n        )\n    })\n}\n\nfn translate_write_item(item: JsonValue) -> Result<PreparedWrite> {\n    if !item.is_object() {\n        return Err(typed_error(\n            CODE_WRITE_VALIDATION,\n            \"write item must be an object\",\n            JsonValue::Null,\n        ));\n    }\n    if let Some(inner) = json_get(&item, \"edge\") {\n        return translate_edge(inner);\n    }\n    if let Some(inner) = json_get(&item, \"opStore\").or_else(|| json_get(&item, \"op_store\")) {\n        return translate_op_store(inner);\n    }\n    if let Some(inner) = json_get(&item, \"adminSchema\").or_else(|| json_get(&item, \"admin_schema\"))\n    {\n        return translate_admin_schema(inner);\n    }\n    if let Some(inner) = json_get(&item, \"node\") {\n        return translate_node(inner);\n    }\n    translate_node(&item)\n}\n\n/// Look up `camelCase` first, then `snake_case`, returning the first\n/// present string. Both forms are checked so callers porting from the\n/// Python stub keep working without surface-level rewrites.\nfn json_str_alt(item: &JsonValue, camel: &str, snake: &str) -> Result<Option<String>> {\n    if let Some(v) = json_str(item, camel)? {\n        return Ok(Some(v));\n    }\n    json_str(item, snake)\n}\n\nfn json_str_alt_required(item: &JsonValue, camel: &str, snake: &str) -> Result<String> {\n    json_str_alt(item, camel, snake)?.ok_or_else(|| {\n        typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"write item missing required field {camel:?}\"),\n            JsonValue::Null,\n        )\n    })\n}\n\nfn json_serialised_alt(item: &JsonValue, camel: &str, snake: &str) -> Result<Option<String>> {\n    if let Some(v) = json_serialised(item, camel)? {\n        return Ok(Some(v));\n    }\n    json_serialised(item, snake)\n}\n\nfn json_serialised_alt_required(item: &JsonValue, camel: &str, snake: &str) -> Result<String> {\n    json_serialised_alt(item, camel, snake)?.ok_or_else(|| {\n        typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"write item missing required field {camel:?}\"),\n            JsonValue::Null,\n        )\n    })\n}\n\nfn translate_node(item: &JsonValue) -> Result<PreparedWrite> {\n    let kind = json_str_required(item, \"kind\")?;\n    let body = json_serialised(item, \"body\")?.unwrap_or_else(|| \"{}\".to_string());\n    let source_id = json_str_alt(item, \"sourceId\", \"source_id\")?;\n    Ok(PreparedWrite::Node { kind, body, source_id })\n}\n\nfn translate_edge(item: &JsonValue) -> Result<PreparedWrite> {\n    let kind = json_str_required(item, \"kind\")?;\n    let from = json_str_required(item, \"from\")?;\n    let to = json_str_required(item, \"to\")?;\n    let source_id = json_str_alt(item, \"sourceId\", \"source_id\")?;\n    Ok(PreparedWrite::Edge { kind, from, to, source_id })\n}\n\nfn translate_op_store(item: &JsonValue) -> Result<PreparedWrite> {\n    let collection = json_str_required(item, \"collection\")?;\n    let record_key = json_str_alt_required(item, \"recordKey\", \"record_key\")?;\n    let schema_id = json_str_alt(item, \"schemaId\", \"schema_id\")?;\n    let body = json_serialised_required(item, \"body\")?;\n    Ok(PreparedWrite::OpStore { collection, record_key, schema_id, body })\n}\n\nfn translate_admin_schema(item: &JsonValue) -> Result<PreparedWrite> {\n    let name = json_str_required(item, \"name\")?;\n    let kind = json_str_required(item, \"kind\")?;\n    let schema_json = json_serialised_alt_required(item, \"schemaJson\", \"schema_json\")?;\n    let retention_json = json_serialised_alt(item, \"retentionJson\", \"retention_json\")?\n        .unwrap_or_else(|| \"{}\".to_string());\n    Ok(PreparedWrite::AdminSchema { name, kind, schema_json, retention_json })\n}\n\n// ===== Test hooks =====================================================\n\n/// AC-067 force-panic probe. Gated by `cfg(any(test, feature =\n/// \"test-hooks\"))` so release npm builds without the feature flag do\n/// not expose it.\n#[cfg(any(test, feature = \"test-hooks\"))]\n#[napi(js_name = \"forcePanicForTest\")]\npub fn force_panic_for_test() -> Result<()> {\n    call_panicking_engine_for_test()\n}\n\n#[cfg(any(test, feature = \"test-hooks\"))]\nfn call_panicking_engine_for_test() -> Result<()> {\n    // Run the panic through the same catch_unwind path that real\n    // engine calls use so the TS-side test exercises the production\n    // panic-translation seam.\n    let join_result = std::panic::catch_unwind(AssertUnwindSafe(\n        || -> std::result::Result<(), RustEngineError> {\n            panic!(\"force_panic_for_test: AC-067 probe\");\n        },\n    ));\n    match join_result {\n        Ok(Ok(())) => Ok(()),\n        Ok(Err(err)) => Err(engine_error_to_napi(err)),\n        Err(_) => Err(panic_error()),\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn validate_ffi_string_accepts_plain_ascii() {\n        assert!(validate_ffi_string(\"hello\").is_ok());\n    }\n\n    #[test]\n    fn validate_ffi_string_accepts_non_ascii_utf8() {\n        assert!(validate_ffi_string(\"héllo 🦀 文字\").is_ok());\n    }\n\n    #[test]\n    fn validate_ffi_string_rejects_embedded_nul() {\n        let err = validate_ffi_string(\"a\\0b\").unwrap_err();\n        assert!(err.contains(\"NUL\"), \"expected NUL diagnostic, got {err:?}\");\n    }\n\n    #[test]\n    fn validate_ffi_string_accepts_replacement_codepoint() {\n        // U+FFFD is the only \"high unicode\" codepoint a Rust &str can\n        // hold near the surrogate range; the codepoints U+D800..U+DFFF\n        // themselves cannot appear in valid UTF-8, so the runtime\n        // guard is exercised when JS surrogates round-trip through\n        // napi-rs string conversion (covered by ffi-safety.test.ts).\n        assert!(validate_ffi_string(\"\\u{FFFD}\").is_ok());\n    }\n}\n","structuredPatch":[{"oldStart":443,"oldLines":26,"newStart":443,"newLines":33,"lines":["     }"," ","     #[napi]","-    pub fn counters(&self) -> CounterSnapshot {","-        let snap = self.inner.counters();","-        CounterSnapshot {","-            queries: snap.queries as i64,","-            writes: snap.writes as i64,","-            write_rows: snap.write_rows as i64,","-            admin_ops: snap.admin_ops as i64,","-            cache_hit: snap.cache_hit as i64,","-            cache_miss: snap.cache_miss as i64,","-        }","+    pub fn counters(&self) -> Result<CounterSnapshot> {","+        let engine = Arc::clone(&self.inner);","+        call_engine_sync(move || {","+            let snap = engine.counters();","+            Ok(CounterSnapshot {","+                queries: snap.queries as i64,","+                writes: snap.writes as i64,","+                write_rows: snap.write_rows as i64,","+                admin_ops: snap.admin_ops as i64,","+                cache_hit: snap.cache_hit as i64,","+                cache_miss: snap.cache_miss as i64,","+            })","+        })","     }"," ","     #[napi]","     pub fn set_profiling(&self, enabled: bool) -> Result<()> {","-        self.inner.set_profiling(enabled).map_err(engine_error_to_napi)","+        let engine = Arc::clone(&self.inner);","+        call_engine_sync(move || engine.set_profiling(enabled).map_err(engine_error_to_napi))","     }"," ","     #[napi]","     pub fn set_slow_threshold_ms(&self, value: u32) -> Result<()> {","-        self.inner.set_slow_threshold_ms(value as u64).map_err(engine_error_to_napi)","+        let engine = Arc::clone(&self.inner);","+        call_engine_sync(move || {","+            engine.set_slow_threshold_ms(value as u64).map_err(engine_error_to_napi)","+        })","     }"," ","     /// Subscriber wiring lands in a later 0.6.x slice; the binding"]},{"oldStart":476,"oldLines":7,"newStart":483,"newLines":7,"lines":["     ) -> Result<()> {","         let _ = callback;","         let _ = options;","-        Ok(())","+        call_engine_sync(|| Ok(()))","     }"," }"," "]}],"userModified":false,"replaceAll":false}}
dev/plans/runs/11b-fix-1-20260516T214419Z.log:247:{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012oYrgXJLyTNsCnX4xkizA9","type":"tool_result","content":"The file /tmp/fdb-11b-napi-binding-20260516T210327Z/src/rust/crates/fathomdb-napi/src/lib.rs has been updated successfully. (file state is current in your context — no need to Read it back)"}]},"parent_tool_use_id":null,"session_id":"a52cedd5-f91e-4c7f-aa9c-db400e73d860","uuid":"151f645f-5ab4-4851-9565-5f66d4ae3a90","timestamp":"2026-05-16T21:45:00.612Z","tool_use_result":{"filePath":"/tmp/fdb-11b-napi-binding-20260516T210327Z/src/rust/crates/fathomdb-napi/src/lib.rs","oldString":"#[cfg(any(test, feature = \"test-hooks\"))]\nfn call_panicking_engine_for_test() -> Result<()> {","newString":"/// AC-067 sync-path probe: exercises [`call_engine_sync`] so the\n/// TS-side test asserts that panics on a sync `#[napi]` accessor land\n/// as `FathomDbPanicError` (code `FDB_PANIC`) too, not just the async\n/// path covered by [`force_panic_for_test`].\n#[cfg(any(test, feature = \"test-hooks\"))]\n#[napi(js_name = \"forcePanicInAccessorForTest\")]\npub fn force_panic_in_accessor_for_test() -> Result<()> {\n    call_engine_sync(|| -> Result<()> {\n        panic!(\"force_panic_in_accessor_for_test: AC-067 sync probe\");\n    })\n}\n\n#[cfg(any(test, feature = \"test-hooks\"))]\nfn call_panicking_engine_for_test() -> Result<()> {","originalFile":"//! napi-rs binding from the TypeScript SDK to `fathomdb-engine`.\n//!\n//! FFI safety contract (mirrors the PyO3 binding in `fathomdb-py`):\n//!\n//! 1. Every method that may block inside the engine runs its blocking\n//!    body inside `tokio::task::spawn_blocking`, so the libuv main\n//!    thread is never tied up. napi-rs's `#[napi] async fn` wraps\n//!    return values as JS `Promise<T>`.\n//! 2. Engine entry points return typed errors via [`engine_error_to_napi`] /\n//!    [`engine_open_error_to_napi`] — single-switch mapping with no\n//!    catch-all arm; the binding fails to compile when the Rust variant\n//!    set drifts from the TS leaf-class set (AC-060a).\n//! 3. Every string crossing the FFI is checked by [`validate_ffi_string`]\n//!    for embedded NUL or unpaired UTF-16 surrogates BEFORE the writer\n//!    transaction opens (AC-068a / AC-068b).\n//! 4. Engine panics are caught via `catch_unwind` inside the spawn-blocking\n//!    body and rethrown as a distinct `FathomDbPanicError` (code\n//!    `FDB_PANIC`); the host process is not aborted (AC-067).\n//\n// why: napi-rs catches panics by default but throws a generic JS\n// `Error` with `Status::GenericFailure` and a Rust-formatted message,\n// which is hard to assert on. Explicit `catch_unwind` + a stable\n// `FDB_PANIC` code lets the TS-side `rethrowTyped` map panics to a\n// distinct `FathomDbPanicError` class that is intentionally NOT a\n// `FathomDbError` subclass: panic is a contract bug, not a typed\n// engine outcome.\n\nuse std::panic::{catch_unwind, AssertUnwindSafe};\nuse std::sync::Arc;\n\nuse fathomdb_engine::{\n    CorruptionDetail, CorruptionKind, Engine as RustEngine, EngineError as RustEngineError,\n    EngineOpenError, OpenStage, PreparedWrite, SearchResult as RustSearchResult,\n    SoftFallbackBranch, WriteReceipt as RustWriteReceipt,\n};\nuse napi::{Error, JsUnknown, Result, Status};\nuse napi_derive::napi;\nuse serde::Serialize;\nuse serde_json::{json, Value as JsonValue};\n\n// ===== Error-code constants ===========================================\n//\n// One per typed leaf class on the TS side. The single-switch translator\n// below maps every engine variant to exactly one of these codes; the TS\n// `rethrowTyped` table maps each code to exactly one leaf class. Drift\n// fails to compile (Rust side) or fails an exhaustiveness check (TS).\n\nconst CODE_STORAGE: &str = \"FDB_STORAGE\";\nconst CODE_PROJECTION: &str = \"FDB_PROJECTION\";\nconst CODE_VECTOR: &str = \"FDB_VECTOR\";\nconst CODE_EMBEDDER: &str = \"FDB_EMBEDDER\";\nconst CODE_EMBEDDER_NOT_CONFIGURED: &str = \"FDB_EMBEDDER_NOT_CONFIGURED\";\nconst CODE_KIND_NOT_VECTOR_INDEXED: &str = \"FDB_KIND_NOT_VECTOR_INDEXED\";\nconst CODE_EMBEDDER_DIMENSION_MISMATCH: &str = \"FDB_EMBEDDER_DIMENSION_MISMATCH\";\nconst CODE_SCHEDULER: &str = \"FDB_SCHEDULER\";\nconst CODE_OP_STORE: &str = \"FDB_OP_STORE\";\nconst CODE_WRITE_VALIDATION: &str = \"FDB_WRITE_VALIDATION\";\nconst CODE_SCHEMA_VALIDATION: &str = \"FDB_SCHEMA_VALIDATION\";\nconst CODE_OVERLOADED: &str = \"FDB_OVERLOADED\";\nconst CODE_CLOSING: &str = \"FDB_CLOSING\";\nconst CODE_DATABASE_LOCKED: &str = \"FDB_DATABASE_LOCKED\";\nconst CODE_CORRUPTION: &str = \"FDB_CORRUPTION\";\nconst CODE_INCOMPATIBLE_SCHEMA_VERSION: &str = \"FDB_INCOMPATIBLE_SCHEMA_VERSION\";\nconst CODE_MIGRATION: &str = \"FDB_MIGRATION\";\nconst CODE_EMBEDDER_IDENTITY_MISMATCH: &str = \"FDB_EMBEDDER_IDENTITY_MISMATCH\";\nconst CODE_PANIC: &str = \"FDB_PANIC\";\n\n// ===== Typed-error encoder ============================================\n\n/// Encode a typed-error envelope as JSON in `err.message` so the\n/// TS-side `rethrowTyped` can reconstitute the right leaf class with\n/// the right payload. napi-rs 2.x has no public API for throwing a\n/// Rust-defined JS class directly; the envelope-in-message pattern is\n/// the canonical workaround.\n#[derive(Serialize)]\nstruct TypedEnvelope<'a> {\n    code: &'a str,\n    message: String,\n    payload: JsonValue,\n}\n\nfn typed_error(code: &'static str, message: impl Into<String>, payload: JsonValue) -> Error {\n    let envelope = TypedEnvelope { code, message: message.into(), payload };\n    // serde_json serialization is infallible for our envelope shape;\n    // unwrap is safe.\n    let reason = serde_json::to_string(&envelope).unwrap();\n    Error::new(Status::GenericFailure, reason)\n}\n\n// ===== String validation (AC-068a / AC-068b) =========================\n\n/// Reject strings carrying an embedded NUL or an unpaired UTF-16\n/// surrogate codepoint (`U+D800..=U+DFFF`).\n///\n/// JavaScript strings are UTF-16 by spec, so lone surrogates are\n/// representable on the JS side (`String.fromCharCode(0xD800)`). The\n/// napi-rs string conversion translates UTF-16 → UTF-8 and accepts\n/// some malformed inputs; this helper rejects them BEFORE the writer\n/// transaction opens (no-row-written invariant).\npub fn validate_ffi_string(value: &str) -> std::result::Result<(), String> {\n    if value.as_bytes().contains(&0) {\n        return Err(\"embedded NUL byte in FFI string\".to_string());\n    }\n    for ch in value.chars() {\n        let cp = ch as u32;\n        if (0xD800..=0xDFFF).contains(&cp) {\n            return Err(format!(\"unpaired UTF-16 surrogate U+{cp:04X} in FFI string\"));\n        }\n    }\n    Ok(())\n}\n\nfn validate_ffi_string_napi(value: &str) -> Result<()> {\n    validate_ffi_string(value)\n        .map_err(|msg| typed_error(CODE_WRITE_VALIDATION, msg, JsonValue::Null))\n}\n\n// ===== Error mapping ==================================================\n\n/// Translate every `EngineError` variant to its typed JS counterpart.\n///\n/// No catch-all arm: drift between the Rust enum and the TS class set\n/// is a compile error.\nfn engine_error_to_napi(err: RustEngineError) -> Error {\n    match err {\n        RustEngineError::Storage => typed_error(CODE_STORAGE, \"storage error\", JsonValue::Null),\n        RustEngineError::Projection => {\n            typed_error(CODE_PROJECTION, \"projection error\", JsonValue::Null)\n        }\n        RustEngineError::Vector => typed_error(CODE_VECTOR, \"vector error\", JsonValue::Null),\n        RustEngineError::Embedder => typed_error(CODE_EMBEDDER, \"embedder error\", JsonValue::Null),\n        RustEngineError::EmbedderNotConfigured => {\n            typed_error(CODE_EMBEDDER_NOT_CONFIGURED, \"embedder is not configured\", JsonValue::Null)\n        }\n        RustEngineError::KindNotVectorIndexed => typed_error(\n            CODE_KIND_NOT_VECTOR_INDEXED,\n            \"kind is not configured for vector indexing\",\n            JsonValue::Null,\n        ),\n        RustEngineError::EmbedderDimensionMismatch { expected, actual } => typed_error(\n            CODE_EMBEDDER_DIMENSION_MISMATCH,\n            format!(\"embedder vector dimension mismatch: stored {expected}, supplied {actual}\"),\n            json!({ \"stored\": expected, \"supplied\": actual }),\n        ),\n        RustEngineError::Scheduler => {\n            typed_error(CODE_SCHEDULER, \"scheduler error\", JsonValue::Null)\n        }\n        RustEngineError::OpStore => typed_error(CODE_OP_STORE, \"op-store error\", JsonValue::Null),\n        RustEngineError::WriteValidation => {\n            typed_error(CODE_WRITE_VALIDATION, \"write validation error\", JsonValue::Null)\n        }\n        RustEngineError::SchemaValidation => {\n            typed_error(CODE_SCHEMA_VALIDATION, \"schema validation error\", JsonValue::Null)\n        }\n        RustEngineError::Overloaded => {\n            typed_error(CODE_OVERLOADED, \"engine overloaded\", JsonValue::Null)\n        }\n        RustEngineError::Closing => typed_error(CODE_CLOSING, \"engine is closing\", JsonValue::Null),\n    }\n}\n\nfn corruption_kind_str(kind: CorruptionKind) -> &'static str {\n    match kind {\n        CorruptionKind::WalReplayFailure => \"WalReplayFailure\",\n        CorruptionKind::HeaderMalformed => \"HeaderMalformed\",\n        CorruptionKind::SchemaInconsistent => \"SchemaInconsistent\",\n        CorruptionKind::EmbedderIdentityDrift => \"EmbedderIdentityDrift\",\n    }\n}\n\nfn open_stage_str(stage: OpenStage) -> &'static str {\n    match stage {\n        OpenStage::HeaderProbe => \"HeaderProbe\",\n        OpenStage::WalReplay => \"WalReplay\",\n        OpenStage::SchemaProbe => \"SchemaProbe\",\n        OpenStage::EmbedderIdentity => \"EmbedderIdentity\",\n    }\n}\n\nfn corruption_to_napi(detail: CorruptionDetail) -> Error {\n    let kind = corruption_kind_str(detail.kind);\n    let stage = open_stage_str(detail.stage);\n    let recovery_hint_code = detail.recovery_hint.code;\n    let doc_anchor = detail.recovery_hint.doc_anchor;\n    typed_error(\n        CODE_CORRUPTION,\n        format!(\"corruption {kind} at stage {stage} ({recovery_hint_code})\"),\n        json!({\n            \"kind\": kind,\n            \"stage\": stage,\n            \"recoveryHintCode\": recovery_hint_code,\n            \"docAnchor\": doc_anchor,\n        }),\n    )\n}\n\nfn engine_open_error_to_napi(err: EngineOpenError) -> Error {\n    match err {\n        EngineOpenError::DatabaseLocked { holder_pid } => typed_error(\n            CODE_DATABASE_LOCKED,\n            match holder_pid {\n                Some(pid) => format!(\"database is locked by process {pid}\"),\n                None => \"database is locked by another engine instance\".to_string(),\n            },\n            json!({ \"holderPid\": holder_pid }),\n        ),\n        EngineOpenError::Corruption(detail) => corruption_to_napi(detail),\n        EngineOpenError::IncompatibleSchemaVersion { seen, supported } => typed_error(\n            CODE_INCOMPATIBLE_SCHEMA_VERSION,\n            format!(\n                \"database schema version {seen} is incompatible with supported version {supported}\"\n            ),\n            json!({ \"seen\": seen, \"supported\": supported }),\n        ),\n        EngineOpenError::MigrationError {\n            schema_version_before,\n            schema_version_current,\n            step_id,\n        } => typed_error(\n            CODE_MIGRATION,\n            format!(\n                \"schema migration failed at step {step_id}; schema version remained between {schema_version_before} and {schema_version_current}\"\n            ),\n            json!({\n                \"schemaVersionBefore\": schema_version_before,\n                \"schemaVersionCurrent\": schema_version_current,\n                \"stepId\": step_id,\n            }),\n        ),\n        EngineOpenError::EmbedderIdentityMismatch { stored, supplied } => typed_error(\n            CODE_EMBEDDER_IDENTITY_MISMATCH,\n            format!(\n                \"embedder identity mismatch: stored {}@{}, supplied {}@{}\",\n                stored.name, stored.revision, supplied.name, supplied.revision,\n            ),\n            json!({\n                \"storedName\": stored.name,\n                \"storedRevision\": stored.revision,\n                \"suppliedName\": supplied.name,\n                \"suppliedRevision\": supplied.revision,\n            }),\n        ),\n        EngineOpenError::EmbedderDimensionMismatch { stored, supplied } => typed_error(\n            CODE_EMBEDDER_DIMENSION_MISMATCH,\n            format!(\n                \"embedder vector dimension mismatch: stored {stored}, supplied {supplied}\"\n            ),\n            json!({ \"stored\": stored, \"supplied\": supplied }),\n        ),\n        EngineOpenError::Io { message } => typed_error(\n            CODE_STORAGE,\n            format!(\"database I/O error: {message}\"),\n            JsonValue::Null,\n        ),\n    }\n}\n\nfn panic_error() -> Error {\n    typed_error(CODE_PANIC, \"engine panic (see logs)\", JsonValue::Null)\n}\n\n/// Run a blocking engine call inside `tokio::task::spawn_blocking` so\n/// the libuv event loop stays free, wrapping it in `catch_unwind` so\n/// panics surface as the typed [`panic_error`] rather than aborting the\n/// host process. `AssertUnwindSafe` lets us thread the closure through\n/// without requiring `UnwindSafe` from the engine's `Arc<dyn Embedder>`\n/// substrate.\nasync fn call_engine<R, F>(f: F) -> Result<R>\nwhere\n    R: Send + 'static,\n    F: FnOnce() -> std::result::Result<R, RustEngineError> + Send + 'static,\n{\n    let join_result = tokio::task::spawn_blocking(move || catch_unwind(AssertUnwindSafe(f))).await;\n    match join_result {\n        Ok(Ok(Ok(value))) => Ok(value),\n        Ok(Ok(Err(err))) => Err(engine_error_to_napi(err)),\n        Ok(Err(_panic)) => Err(panic_error()),\n        Err(join_err) => Err(typed_error(\n            CODE_PANIC,\n            format!(\"spawn_blocking join error: {join_err}\"),\n            JsonValue::Null,\n        )),\n    }\n}\n\n/// Sync sibling of [`call_engine`]: wrap a non-blocking accessor in\n/// `catch_unwind` so a panic on the JS thread surfaces as [`panic_error`]\n/// instead of unwinding into napi-rs's default `GenericFailure` path.\nfn call_engine_sync<R, F>(f: F) -> Result<R>\nwhere\n    F: FnOnce() -> Result<R>,\n{\n    match catch_unwind(AssertUnwindSafe(f)) {\n        Ok(result) => result,\n        Err(_panic) => Err(panic_error()),\n    }\n}\n\n// ===== Data classes ===================================================\n\n#[napi(object)]\npub struct WriteReceipt {\n    pub cursor: i64,\n}\n\nimpl WriteReceipt {\n    fn from_rust(r: RustWriteReceipt) -> Self {\n        Self { cursor: r.cursor as i64 }\n    }\n}\n\n#[napi(object)]\npub struct SoftFallback {\n    /// \"vector\" | \"text\"\n    pub branch: String,\n}\n\n#[napi(object)]\npub struct SearchResult {\n    pub projection_cursor: i64,\n    pub soft_fallback: Option<SoftFallback>,\n    pub results: Vec<String>,\n}\n\nimpl SearchResult {\n    fn from_rust(r: RustSearchResult) -> Self {\n        Self {\n            projection_cursor: r.projection_cursor as i64,\n            soft_fallback: r.soft_fallback.as_ref().map(|s| SoftFallback {\n                branch: match s.branch {\n                    SoftFallbackBranch::Vector => \"vector\".to_string(),\n                    SoftFallbackBranch::Text => \"text\".to_string(),\n                },\n            }),\n            results: r.results,\n        }\n    }\n}\n\n#[napi(object)]\npub struct CounterSnapshot {\n    pub queries: i64,\n    pub writes: i64,\n    pub write_rows: i64,\n    pub admin_ops: i64,\n    pub cache_hit: i64,\n    pub cache_miss: i64,\n}\n\n#[napi(object)]\npub struct AttachSubscriberOptions {\n    pub heartbeat_interval_ms: Option<u32>,\n}\n\n#[napi(object)]\npub struct EngineConfig {\n    pub embedder_pool_size: Option<u32>,\n    pub scheduler_runtime_threads: Option<u32>,\n    pub provenance_row_cap: Option<u32>,\n    pub embedder_call_timeout_ms: Option<u32>,\n    pub slow_threshold_ms: Option<u32>,\n}\n\n#[napi(object)]\npub struct EngineOpenOptions {\n    pub engine_config: Option<EngineConfig>,\n}\n\n#[napi(object)]\npub struct AdminConfigureOptions {\n    pub name: String,\n    pub body: String,\n}\n\n// ===== Engine =========================================================\n\n#[napi]\npub struct Engine {\n    inner: Arc<RustEngine>,\n}\n\n#[napi]\nimpl Engine {\n    /// Promise-returning open per `dev/interfaces/typescript.md`. The\n    /// blocking SQLite work runs on a tokio blocking thread.\n    #[napi(factory)]\n    pub async fn open(path: String, options: Option<EngineOpenOptions>) -> Result<Engine> {\n        validate_ffi_string_napi(&path)?;\n        let _ = options; // engineConfig knobs are recognised but not yet plumbed; see fathomdb-py.\n        let join_result = tokio::task::spawn_blocking(move || {\n            catch_unwind(AssertUnwindSafe(|| RustEngine::open(path)))\n        })\n        .await;\n        let opened = match join_result {\n            Ok(Ok(Ok(opened))) => opened,\n            Ok(Ok(Err(err))) => return Err(engine_open_error_to_napi(err)),\n            Ok(Err(_panic)) => return Err(panic_error()),\n            Err(join_err) => {\n                return Err(typed_error(\n                    CODE_PANIC,\n                    format!(\"spawn_blocking join error: {join_err}\"),\n                    JsonValue::Null,\n                ))\n            }\n        };\n        Ok(Engine { inner: Arc::new(opened.engine) })\n    }\n\n    #[napi]\n    pub async fn write(&self, batch: Vec<JsonValue>) -> Result<WriteReceipt> {\n        let prepared = translate_batch(batch)?;\n        let engine = Arc::clone(&self.inner);\n        let receipt = call_engine(move || engine.write(&prepared)).await?;\n        Ok(WriteReceipt::from_rust(receipt))\n    }\n\n    #[napi]\n    pub async fn search(&self, query: String) -> Result<SearchResult> {\n        validate_ffi_string_napi(&query)?;\n        if query.trim().is_empty() {\n            return Err(typed_error(\n                CODE_WRITE_VALIDATION,\n                \"query must not be empty\",\n                JsonValue::Null,\n            ));\n        }\n        let engine = Arc::clone(&self.inner);\n        let result = call_engine(move || engine.search(&query)).await?;\n        Ok(SearchResult::from_rust(result))\n    }\n\n    #[napi]\n    pub async fn close(&self) -> Result<()> {\n        let engine = Arc::clone(&self.inner);\n        call_engine(move || engine.close()).await\n    }\n\n    #[napi]\n    pub async fn drain(&self, timeout_ms: u32) -> Result<()> {\n        let engine = Arc::clone(&self.inner);\n        let ms = timeout_ms as u64;\n        call_engine(move || engine.drain(ms)).await\n    }\n\n    #[napi]\n    pub fn counters(&self) -> Result<CounterSnapshot> {\n        let engine = Arc::clone(&self.inner);\n        call_engine_sync(move || {\n            let snap = engine.counters();\n            Ok(CounterSnapshot {\n                queries: snap.queries as i64,\n                writes: snap.writes as i64,\n                write_rows: snap.write_rows as i64,\n                admin_ops: snap.admin_ops as i64,\n                cache_hit: snap.cache_hit as i64,\n                cache_miss: snap.cache_miss as i64,\n            })\n        })\n    }\n\n    #[napi]\n    pub fn set_profiling(&self, enabled: bool) -> Result<()> {\n        let engine = Arc::clone(&self.inner);\n        call_engine_sync(move || engine.set_profiling(enabled).map_err(engine_error_to_napi))\n    }\n\n    #[napi]\n    pub fn set_slow_threshold_ms(&self, value: u32) -> Result<()> {\n        let engine = Arc::clone(&self.inner);\n        call_engine_sync(move || {\n            engine.set_slow_threshold_ms(value as u64).map_err(engine_error_to_napi)\n        })\n    }\n\n    /// Subscriber wiring lands in a later 0.6.x slice; the binding\n    /// accepts the call so callers can wire a callback against the\n    /// public surface without a runtime error.\n    #[napi]\n    pub fn attach_subscriber(\n        &self,\n        callback: JsUnknown,\n        options: Option<AttachSubscriberOptions>,\n    ) -> Result<()> {\n        let _ = callback;\n        let _ = options;\n        call_engine_sync(|| Ok(()))\n    }\n}\n\n// ===== admin.configure ================================================\n\n#[napi(js_name = \"adminConfigure\")]\npub async fn admin_configure(\n    engine: &Engine,\n    options: AdminConfigureOptions,\n) -> Result<WriteReceipt> {\n    validate_ffi_string_napi(&options.name)?;\n    validate_ffi_string_napi(&options.body)?;\n    if options.name.is_empty() {\n        return Err(typed_error(\n            CODE_WRITE_VALIDATION,\n            \"admin.configure requires a non-empty name\",\n            JsonValue::Null,\n        ));\n    }\n    // why: `dev/interfaces/typescript.md` § Runtime surface pins the\n    // admin.configure({ name, body }) signature; the engine's\n    // `PreparedWrite::AdminSchema` requires `kind ∈ {latest_state,\n    // append_only_log}`. The TS verb is sugar over latest-state\n    // collection registration in 0.6.0.\n    let batch = vec![PreparedWrite::AdminSchema {\n        name: options.name,\n        kind: \"latest_state\".to_string(),\n        schema_json: options.body,\n        retention_json: \"{}\".to_string(),\n    }];\n    let inner = Arc::clone(&engine.inner);\n    let receipt = call_engine(move || inner.write(&batch)).await?;\n    Ok(WriteReceipt::from_rust(receipt))\n}\n\n// ===== Batch translation ==============================================\n//\n// The TS surface accepts a JS array of typed-write objects. Each item\n// is one of:\n//   { node: { kind, body?, sourceId? } }\n//   { edge: { kind, from, to, sourceId? } }\n//   { opStore: { collection, recordKey, schemaId?, body } }\n//   { adminSchema: { name, kind, schemaJson, retentionJson? } }\n// Plus a bare `{ kind, body?, sourceId? }` shape treated as Node (parity\n// with the Python stub). serde_json::Value is the cheapest cross-thread\n// representation; napi-rs converts JS objects via the `serde-json`\n// feature.\n\nfn translate_batch(batch: Vec<JsonValue>) -> Result<Vec<PreparedWrite>> {\n    batch.into_iter().map(translate_write_item).collect()\n}\n\nfn json_get<'a>(v: &'a JsonValue, key: &str) -> Option<&'a JsonValue> {\n    v.as_object().and_then(|m| m.get(key))\n}\n\nfn json_str(v: &JsonValue, key: &str) -> Result<Option<String>> {\n    match json_get(v, key) {\n        Some(JsonValue::Null) | None => Ok(None),\n        Some(JsonValue::String(s)) => {\n            validate_ffi_string_napi(s)?;\n            Ok(Some(s.clone()))\n        }\n        Some(_other) => Err(typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"field {key:?} must be a string\"),\n            JsonValue::Null,\n        )),\n    }\n}\n\nfn json_str_required(v: &JsonValue, key: &str) -> Result<String> {\n    json_str(v, key)?.ok_or_else(|| {\n        typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"write item missing required field {key:?}\"),\n            JsonValue::Null,\n        )\n    })\n}\n\nfn json_serialised(v: &JsonValue, key: &str) -> Result<Option<String>> {\n    match json_get(v, key) {\n        Some(JsonValue::Null) | None => Ok(None),\n        Some(JsonValue::String(s)) => {\n            validate_ffi_string_napi(s)?;\n            Ok(Some(s.clone()))\n        }\n        Some(other) => {\n            let serialised = serde_json::to_string(other).map_err(|e| {\n                typed_error(\n                    CODE_WRITE_VALIDATION,\n                    format!(\"field {key:?} not serialisable: {e}\"),\n                    JsonValue::Null,\n                )\n            })?;\n            validate_ffi_string_napi(&serialised)?;\n            Ok(Some(serialised))\n        }\n    }\n}\n\nfn json_serialised_required(v: &JsonValue, key: &str) -> Result<String> {\n    json_serialised(v, key)?.ok_or_else(|| {\n        typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"write item missing required field {key:?}\"),\n            JsonValue::Null,\n        )\n    })\n}\n\nfn translate_write_item(item: JsonValue) -> Result<PreparedWrite> {\n    if !item.is_object() {\n        return Err(typed_error(\n            CODE_WRITE_VALIDATION,\n            \"write item must be an object\",\n            JsonValue::Null,\n        ));\n    }\n    if let Some(inner) = json_get(&item, \"edge\") {\n        return translate_edge(inner);\n    }\n    if let Some(inner) = json_get(&item, \"opStore\").or_else(|| json_get(&item, \"op_store\")) {\n        return translate_op_store(inner);\n    }\n    if let Some(inner) = json_get(&item, \"adminSchema\").or_else(|| json_get(&item, \"admin_schema\"))\n    {\n        return translate_admin_schema(inner);\n    }\n    if let Some(inner) = json_get(&item, \"node\") {\n        return translate_node(inner);\n    }\n    translate_node(&item)\n}\n\n/// Look up `camelCase` first, then `snake_case`, returning the first\n/// present string. Both forms are checked so callers porting from the\n/// Python stub keep working without surface-level rewrites.\nfn json_str_alt(item: &JsonValue, camel: &str, snake: &str) -> Result<Option<String>> {\n    if let Some(v) = json_str(item, camel)? {\n        return Ok(Some(v));\n    }\n    json_str(item, snake)\n}\n\nfn json_str_alt_required(item: &JsonValue, camel: &str, snake: &str) -> Result<String> {\n    json_str_alt(item, camel, snake)?.ok_or_else(|| {\n        typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"write item missing required field {camel:?}\"),\n            JsonValue::Null,\n        )\n    })\n}\n\nfn json_serialised_alt(item: &JsonValue, camel: &str, snake: &str) -> Result<Option<String>> {\n    if let Some(v) = json_serialised(item, camel)? {\n        return Ok(Some(v));\n    }\n    json_serialised(item, snake)\n}\n\nfn json_serialised_alt_required(item: &JsonValue, camel: &str, snake: &str) -> Result<String> {\n    json_serialised_alt(item, camel, snake)?.ok_or_else(|| {\n        typed_error(\n            CODE_WRITE_VALIDATION,\n            format!(\"write item missing required field {camel:?}\"),\n            JsonValue::Null,\n        )\n    })\n}\n\nfn translate_node(item: &JsonValue) -> Result<PreparedWrite> {\n    let kind = json_str_required(item, \"kind\")?;\n    let body = json_serialised(item, \"body\")?.unwrap_or_else(|| \"{}\".to_string());\n    let source_id = json_str_alt(item, \"sourceId\", \"source_id\")?;\n    Ok(PreparedWrite::Node { kind, body, source_id })\n}\n\nfn translate_edge(item: &JsonValue) -> Result<PreparedWrite> {\n    let kind = json_str_required(item, \"kind\")?;\n    let from = json_str_required(item, \"from\")?;\n    let to = json_str_required(item, \"to\")?;\n    let source_id = json_str_alt(item, \"sourceId\", \"source_id\")?;\n    Ok(PreparedWrite::Edge { kind, from, to, source_id })\n}\n\nfn translate_op_store(item: &JsonValue) -> Result<PreparedWrite> {\n    let collection = json_str_required(item, \"collection\")?;\n    let record_key = json_str_alt_required(item, \"recordKey\", \"record_key\")?;\n    let schema_id = json_str_alt(item, \"schemaId\", \"schema_id\")?;\n    let body = json_serialised_required(item, \"body\")?;\n    Ok(PreparedWrite::OpStore { collection, record_key, schema_id, body })\n}\n\nfn translate_admin_schema(item: &JsonValue) -> Result<PreparedWrite> {\n    let name = json_str_required(item, \"name\")?;\n    let kind = json_str_required(item, \"kind\")?;\n    let schema_json = json_serialised_alt_required(item, \"schemaJson\", \"schema_json\")?;\n    let retention_json = json_serialised_alt(item, \"retentionJson\", \"retention_json\")?\n        .unwrap_or_else(|| \"{}\".to_string());\n    Ok(PreparedWrite::AdminSchema { name, kind, schema_json, retention_json })\n}\n\n// ===== Test hooks =====================================================\n\n/// AC-067 force-panic probe. Gated by `cfg(any(test, feature =\n/// \"test-hooks\"))` so release npm builds without the feature flag do\n/// not expose it.\n#[cfg(any(test, feature = \"test-hooks\"))]\n#[napi(js_name = \"forcePanicForTest\")]\npub fn force_panic_for_test() -> Result<()> {\n    call_panicking_engine_for_test()\n}\n\n#[cfg(any(test, feature = \"test-hooks\"))]\nfn call_panicking_engine_for_test() -> Result<()> {\n    // Run the panic through the same catch_unwind path that real\n    // engine calls use so the TS-side test exercises the production\n    // panic-translation seam.\n    let join_result = std::panic::catch_unwind(AssertUnwindSafe(\n        || -> std::result::Result<(), RustEngineError> {\n            panic!(\"force_panic_for_test: AC-067 probe\");\n        },\n    ));\n    match join_result {\n        Ok(Ok(())) => Ok(()),\n        Ok(Err(err)) => Err(engine_error_to_napi(err)),\n        Err(_) => Err(panic_error()),\n    }\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn validate_ffi_string_accepts_plain_ascii() {\n        assert!(validate_ffi_string(\"hello\").is_ok());\n    }\n\n    #[test]\n    fn validate_ffi_string_accepts_non_ascii_utf8() {\n        assert!(validate_ffi_string(\"héllo 🦀 文字\").is_ok());\n    }\n\n    #[test]\n    fn validate_ffi_string_rejects_embedded_nul() {\n        let err = validate_ffi_string(\"a\\0b\").unwrap_err();\n        assert!(err.contains(\"NUL\"), \"expected NUL diagnostic, got {err:?}\");\n    }\n\n    #[test]\n    fn validate_ffi_string_accepts_replacement_codepoint() {\n        // U+FFFD is the only \"high unicode\" codepoint a Rust &str can\n        // hold near the surrogate range; the codepoints U+D800..U+DFFF\n        // themselves cannot appear in valid UTF-8, so the runtime\n        // guard is exercised when JS surrogates round-trip through\n        // napi-rs string conversion (covered by ffi-safety.test.ts).\n        assert!(validate_ffi_string(\"\\u{FFFD}\").is_ok());\n    }\n}\n","structuredPatch":[{"oldStart":700,"oldLines":7,"newStart":700,"newLines":19,"lines":["     call_panicking_engine_for_test()"," }"," ","+/// AC-067 sync-path probe: exercises [`call_engine_sync`] so the","+/// TS-side test asserts that panics on a sync `#[napi]` accessor land","+/// as `FathomDbPanicError` (code `FDB_PANIC`) too, not just the async","+/// path covered by [`force_panic_for_test`]."," #[cfg(any(test, feature = \"test-hooks\"))]","+#[napi(js_name = \"forcePanicInAccessorForTest\")]","+pub fn force_panic_in_accessor_for_test() -> Result<()> {","+    call_engine_sync(|| -> Result<()> {","+        panic!(\"force_panic_in_accessor_for_test: AC-067 sync probe\");","+    })","+}","+","+#[cfg(any(test, feature = \"test-hooks\"))]"," fn call_panicking_engine_for_test() -> Result<()> {","     // Run the panic through the same catch_unwind path that real","     // engine calls use so the TS-side test exercises the production"]}],"userModified":false,"replaceAll":false}}
