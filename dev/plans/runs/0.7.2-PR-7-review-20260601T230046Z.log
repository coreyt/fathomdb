   441	fn main() -> ExitCode {
   442	    let mut dir: Option<PathBuf> = None;
   443	    let mut json = false;
   444	    for arg in std::env::args().skip(1) {
   445	        match arg.as_str() {
   446	            "--json" => json = true,
   447	            "-h" | "--help" => {
   448	                print_usage();
   449	                return ExitCode::from(0);
   450	            }
   451	            other if other.starts_with('-') => {
   452	                eprintln!("unknown flag: {other}");
   453	                print_usage();
   454	                return ExitCode::from(2);
   455	            }
   456	            other => {
   457	                if dir.is_some() {
   458	                    eprintln!("unexpected extra argument: {other}");
   459	                    print_usage();
   460	                    return ExitCode::from(2);
   461	                }
   462	                dir = Some(PathBuf::from(other));
   463	            }
   464	        }
   465	    }
   466	
   467	    let dir = match dir {
   468	        Some(d) => d,
   469	        None => {
   470	            print_usage();
   471	            return ExitCode::from(2);
   472	        }
   473	    };
