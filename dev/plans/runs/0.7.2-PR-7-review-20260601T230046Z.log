   405	    println!("perf-regression-check — {} group(s)\n", report.groups.len());
   406	    for g in &report.groups {
   407	        let marker = if g.flagged {
   408	            "REGRESSION"
   409	        } else if g.status == "insufficient-history" {
   410	            "insufficient"
   411	        } else {
   412	            "ok"
   413	        };
   414	        println!(
   415	            "[{marker}] {} @ n={} — {} run(s), latest {} ({})",
   416	            g.ac_id, g.n, g.runs, g.latest_commit, g.latest_timestamp
   417	        );
   418	        for reason in &g.reasons {
   419	            println!("    - {reason}");
   420	        }
   421	    }
   422	    println!();
   423	    if report.flagged {
   424	        println!("RESULT: regression(s) flagged.");
   425	    } else {
