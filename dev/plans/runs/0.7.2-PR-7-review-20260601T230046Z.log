   365	fn build_report(dir: &Path) -> Result<Report, String> {
   366	    if !dir.is_dir() {
   367	        return Err(format!("perf-history directory not found: {}", dir.display()));
   368	    }
   369	
   370	    // Group by (ac_id, n). BTreeMap gives deterministic, sorted output.
   371	    let mut groups: BTreeMap<(String, u64), Vec<Record>> = BTreeMap::new();
   372	
   373	    let entries =
   374	        std::fs::read_dir(dir).map_err(|e| format!("cannot read dir {}: {e}", dir.display()))?;
   375	    for entry in entries {
   376	        let entry = entry.map_err(|e| format!("dir entry error: {e}"))?;
   377	        let path = entry.path();
   378	        if path.extension().and_then(|s| s.to_str()) != Some("json") {
   379	            continue;
   380	        }
   381	        let rec = load_record(&path)?;
   382	        groups.entry((rec.ac_id.clone(), rec.n)).or_default().push(rec);
   383	    }
   384	
   385	    if groups.is_empty() {
   386	        return Err(format!("no *.json perf records found in {}", dir.display()));
   387	    }
   388	
   389	    let mut report = Report { flagged: false, groups: Vec::new() };
   390	    for ((ac_id, n), mut runs) in groups {
   391	        // Sort oldest -> newest by parsed UTC epoch (not the raw string, which
   392	        // would mis-order offset/Z-mixed timestamps). Tie-break on commit_sha
   393	        // for a deterministic "latest" when two runs share an instant.
   394	        runs.sort_by(|a, b| {
   395	            a.ts_epoch.cmp(&b.ts_epoch).then_with(|| a.commit_sha.cmp(&b.commit_sha))
   396	        });
   397	        let v = evaluate_group(&ac_id, n, &runs);
   398	        report.flagged |= v.flagged;
   399	        report.groups.push(v);
   400	    }
   401	    Ok(report)
   402	}
