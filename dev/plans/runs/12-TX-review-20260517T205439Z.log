    98	
    99	export class EmbedderDimensionMismatchError extends FathomDbError {
   100	  readonly stored: number;
   101	  readonly supplied: number;
   102	  constructor(payload: EmbedderDimensionMismatchPayload) {
   103	    super(
   104	      `embedder vector dimension mismatch: stored ${payload.stored}, supplied ${payload.supplied}`,
   105	    );
   106	    this.stored = payload.stored;
   107	    this.supplied = payload.supplied;
   108	  }
