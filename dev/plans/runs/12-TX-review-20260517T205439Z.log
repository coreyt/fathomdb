   110	
   111	// Panic is a contract bug, not a typed engine outcome — intentionally
   112	// NOT a FathomDbError subclass so callers that catch FathomDbError do
   113	// not silently swallow it. Mirrors PyO3 PanicException in 11a.
   114	export class FathomDbPanicError extends Error {
   115	  constructor(message: string) {
   116	    super(message);
   117	    this.name = "FathomDbPanicError";
   118	  }
   119	}
   120	
   121	// ===== Typed-error rethrow ============================================
   122	
   123	type ErrorCode =
   124	  | "FDB_STORAGE"
   125	  | "FDB_PROJECTION"
   126	  | "FDB_VECTOR"
   127	  | "FDB_EMBEDDER"
   128	  | "FDB_EMBEDDER_NOT_CONFIGURED"
   129	  | "FDB_KIND_NOT_VECTOR_INDEXED"
   130	  | "FDB_EMBEDDER_DIMENSION_MISMATCH"
   131	  | "FDB_SCHEDULER"
   132	  | "FDB_OP_STORE"
   133	  | "FDB_WRITE_VALIDATION"
   134	  | "FDB_SCHEMA_VALIDATION"
   135	  | "FDB_OVERLOADED"
   136	  | "FDB_CLOSING"
   137	  | "FDB_DATABASE_LOCKED"
   138	  | "FDB_CORRUPTION"
   139	  | "FDB_INCOMPATIBLE_SCHEMA_VERSION"
   140	  | "FDB_MIGRATION"
   141	  | "FDB_EMBEDDER_IDENTITY_MISMATCH"
   142	  | "FDB_PANIC";
   143	
   144	interface Envelope {
   145	  code: ErrorCode;
   146	  message: string;
   147	  payload: Record<string, unknown> | null;
   148	}
   149	
   150	function parseEnvelope(raw: unknown): Envelope | null {
   151	  if (typeof raw !== "string" || raw.length === 0 || raw[0] !== "{") {
   152	    return null;
   153	  }
   154	  let parsed: unknown;
   155	  try {
   156	    parsed = JSON.parse(raw);
   157	  } catch {
   158	    return null;
   159	  }
   160	  if (parsed === null || typeof parsed !== "object") {
   161	    return null;
   162	  }
   163	  const obj = parsed as Record<string, unknown>;
   164	  if (typeof obj.code !== "string" || typeof obj.message !== "string") {
   165	    return null;
   166	  }
   167	  return {
   168	    code: obj.code as ErrorCode,
   169	    message: obj.message,
   170	    payload: (obj.payload as Record<string, unknown> | null) ?? null,
   171	  };
   172	}
   173	
   174	function build(envelope: Envelope): Error {
   175	  const p = envelope.payload ?? {};
   176	  switch (envelope.code) {
   177	    case "FDB_STORAGE":
   178	      return new StorageError(envelope.message);
   179	    case "FDB_PROJECTION":
   180	      return new ProjectionError(envelope.message);
   181	    case "FDB_VECTOR":
   182	      return new VectorError(envelope.message);
   183	    case "FDB_EMBEDDER":
   184	      return new EmbedderError(envelope.message);
   185	    case "FDB_EMBEDDER_NOT_CONFIGURED":
   186	      return new EmbedderNotConfiguredError(envelope.message);
   187	    case "FDB_KIND_NOT_VECTOR_INDEXED":
   188	      return new KindNotVectorIndexedError(envelope.message);
   189	    case "FDB_EMBEDDER_DIMENSION_MISMATCH":
   190	      return new EmbedderDimensionMismatchError({
   191	        stored: Number(p.stored),
   192	        supplied: Number(p.supplied),
   193	      });
   194	    case "FDB_SCHEDULER":
   195	      return new SchedulerError(envelope.message);
   196	    case "FDB_OP_STORE":
   197	      return new OpStoreError(envelope.message);
   198	    case "FDB_WRITE_VALIDATION":
   199	      return new WriteValidationError(envelope.message);
   200	    case "FDB_SCHEMA_VALIDATION":
   201	      return new SchemaValidationError(envelope.message);
   202	    case "FDB_OVERLOADED":
   203	      return new OverloadedError(envelope.message);
   204	    case "FDB_CLOSING":
   205	      return new ClosingError(envelope.message);
   206	    case "FDB_DATABASE_LOCKED":
   207	      return new DatabaseLockedError({
   208	        holderPid: typeof p.holderPid === "number" ? p.holderPid : undefined,
   209	      });
   210	    case "FDB_CORRUPTION":
   211	      return new CorruptionError({
   212	        kind: String(p.kind ?? ""),
   213	        stage: String(p.stage ?? ""),
   214	        recoveryHintCode: String(p.recoveryHintCode ?? ""),
   215	        docAnchor: String(p.docAnchor ?? ""),
   216	      });
   217	    case "FDB_INCOMPATIBLE_SCHEMA_VERSION":
   218	      return new IncompatibleSchemaVersionError(envelope.message);
   219	    case "FDB_MIGRATION":
   220	      return new MigrationError(envelope.message);
   221	    case "FDB_EMBEDDER_IDENTITY_MISMATCH":
   222	      return new EmbedderIdentityMismatchError({
   223	        storedName: String(p.storedName ?? ""),
   224	        storedRevision: String(p.storedRevision ?? ""),
   225	        suppliedName: String(p.suppliedName ?? ""),
   226	        suppliedRevision: String(p.suppliedRevision ?? ""),
   227	      });
   228	    case "FDB_PANIC":
   229	      return new FathomDbPanicError(envelope.message);
   230	    default: {
   231	      // Exhaustiveness — if ErrorCode union grows and switch arms
   232	      // don't cover it, this branch becomes reachable and TS narrows
   233	      // `envelope.code` to `never`, surfacing as a compile error.
   234	      const _exhaustive: never = envelope.code;
   235	      return new Error(`unrecognised error code: ${String(_exhaustive)}`);
   236	    }
   237	  }
   238	}
   239	
   240	/**
   241	 * Re-raise a binding-thrown error as the corresponding TS leaf class.
   242	 *
   243	 * Errors not carrying the JSON envelope are rethrown unchanged so
   244	 * non-binding errors (e.g. native panics from outside the catch
   245	 * surface) reach the caller untouched.
   246	 */
   247	export function rethrowTyped(err: unknown): never {
   248	  if (err instanceof Error) {
   249	    const env = parseEnvelope(err.message);
   250	    if (env !== null) {
   251	      throw build(env);
   252	    }
   253	  }
   254	  throw err;
   255	}

