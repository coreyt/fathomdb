    StorageError,
    ProjectionError,
    VectorError,
    EmbedderError,
    SchedulerError,
    OpStoreError,
    WriteValidationError,
    SchemaValidationError,
    OverloadedError,
    ClosingError,
    DatabaseLockedError,
