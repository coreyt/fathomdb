def test_top_level_exports_match_canonical_set() -> None:
    expected = {
        "Engine",
        "EngineConfig",
        "SearchResult",
        "SoftFallback",
        "WriteReceipt",
        "admin",
        "errors",
    }
    assert expected.issubset(set(fathomdb.__all__))


