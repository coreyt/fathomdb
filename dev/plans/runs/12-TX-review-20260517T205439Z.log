dev/plans/runs/10b-A-low-risk-seams-20260515T234104Z.log:260:{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FNqY4Fhkxmts4y1tSaMoJ1","type":"tool_result","content":"1\tuse std::fmt::{Display, Formatter};\n2\tuse std::time::Instant;\n3\t\n4\tuse rusqlite::Connection;\n5\t\n6\tpub const SCHEMA_VERSION: u32 = 8;\n7\t\n8\t/// SQLite `PRAGMA` name carrying the on-disk schema-version sentinel.\n9\t///\n10\t/// Public on-disk surface per `dev/interfaces/wire.md` § Schema-version\n11\t/// sentinel; advanced by successful migrations per `dev/design/migrations.md`.\n12\tpub const PRAGMA_USER_VERSION: &str = \"user_version\";\n13\t\n14\t/// Suffix of the canonical SQLite database file (`<db-name>.sqlite`).\n15\tpub const SQLITE_SUFFIX: &str = \".sqlite\";\n16\t\n17\t/// Suffix of the SQLite write-ahead log file (`<db-name>.sqlite-wal`).\n18\tpub const WAL_SUFFIX: &str = \"-wal\";\n19\t\n20\t/// Suffix of the sidecar lock file (`<db-name>.sqlite.lock`).\n21\t///\n22\t/// Per `dev/design/bindings.md` § 7, this sidecar flock is the load-bearing\n23\t/// cross-process exclusion layer; it surfaces lock contention before SQLite\n24\t/// I/O begins.\n25\tpub const LOCK_SUFFIX: &str = \".lock\";\n26\t\n27\t/// Suffix of the optional SQLite rollback journal file\n28\t/// (`<db-name>.sqlite-journal`).\n29\tpub const JOURNAL_SUFFIX: &str = \"-journal\";\n30\t\n31\t#[must_use]\n32\tpub fn bootstrap_steps() -> &'static [&'static str] {\n33\t    &[\"create canonical tables\", \"register projection metadata\", \"seed rewrite-era configuration\"]\n34\t}\n35\t\n36\t#[derive(Clone, Copy, Debug, Eq, PartialEq)]\n37\tpub struct Migration {\n38\t    pub step_id: u32,\n39\t    pub sql: &'static str,\n40\t}\n41\t\n42\t#[derive(Clone, Debug, Eq, PartialEq)]\n43\tpub struct MigrationStepReport {\n44\t    pub step_id: u32,\n45\t    pub duration_ms: Option<u64>,\n46\t    pub failed: bool,\n47\t}\n48\t\n49\t#[derive(Clone, Debug, Eq, PartialEq)]\n50\tpub struct MigrationReport {\n51\t    pub schema_version_before: u32,\n52\t    pub schema_version_after: u32,\n53\t    pub migration_steps: Vec<MigrationStepReport>,\n54\t}\n55\t\n56\t#[derive(Clone, Debug, Eq, PartialEq)]\n57\tpub struct MigrationFailureReport {\n58\t    pub schema_version_before: u32,\n59\t    pub schema_version_current: u32,\n60\t    pub migration_steps: Vec<MigrationStepReport>,\n61\t}\n62\t\n63\t#[derive(Clone, Debug, Eq, PartialEq)]\n64\tpub enum MigrationError {\n65\t    IncompatibleSchemaVersion { seen: u32, supported: u32 },\n66\t    MigrationError(MigrationFailureReport),\n67\t    Storage { message: &'static str },\n68\t}\n69\t\n70\timpl Display for MigrationError {\n71\t    fn fmt(&self, f: &mut Formatter<'_>) -> std::fmt::Result {\n72\t        match self {\n73\t            Self::IncompatibleSchemaVersion { seen, supported } => {\n74\t                write!(f, \"database schema version {seen} is incompatible with supported version {supported}\")\n75\t            }\n76\t            Self::MigrationError(report) => write!(\n77\t                f,\n78\t                \"schema migration failed at step {}\",\n79\t                report.migration_steps.last().map_or(0, |step| step.step_id)\n80\t            ),\n81\t            Self::Storage { message } => write!(f, \"schema storage error: {message}\"),\n82\t        }\n83\t    }\n84\t}\n85\t\n86\timpl std::error::Error for MigrationError {}\n87\t\n88\tpub const MIGRATIONS: &[Migration] = &[\n89\t    Migration {\n90\t        step_id: 1,\n91\t        sql: \"CREATE TABLE IF NOT EXISTS _fathomdb_schema_meta(key TEXT PRIMARY KEY, value TEXT NOT NULL)\",\n92\t    },\n93\t    Migration {\n94\t        step_id: 2,\n95\t        sql: \"CREATE TABLE IF NOT EXISTS _fathomdb_migrations(step_id INTEGER PRIMARY KEY, applied_at_ms INTEGER NOT NULL);\n96\t              CREATE TABLE IF NOT EXISTS canonical_nodes(write_cursor INTEGER NOT NULL, kind TEXT NOT NULL, body TEXT NOT NULL);\n97\t              CREATE TABLE IF NOT EXISTS canonical_edges(write_cursor INTEGER NOT NULL, kind TEXT NOT NULL, from_id TEXT NOT NULL, to_id TEXT NOT NULL);\",\n98\t    },\n99\t    Migration {\n100\t        step_id: 3,\n101\t        sql: \"CREATE TABLE IF NOT EXISTS _fathomdb_embedder_profiles(profile TEXT PRIMARY KEY, name TEXT NOT NULL, revision TEXT NOT NULL, dimension INTEGER NOT NULL)\",\n102\t    },\n103\t    Migration {\n104\t        step_id: 4,\n105\t        sql: \"CREATE TABLE IF NOT EXISTS operational_collections(\n106\t                  name TEXT PRIMARY KEY,\n107\t                  kind TEXT NOT NULL CHECK(kind IN ('append_only_log', 'latest_state')),\n108\t                  schema_json TEXT NOT NULL,\n109\t                  retention_json TEXT NOT NULL,\n110\t                  format_version INTEGER NOT NULL,\n111\t                  created_at INTEGER NOT NULL\n112\t              );\n113\t              CREATE TABLE IF NOT EXISTS operational_mutations(\n114\t                  id INTEGER PRIMARY KEY AUTOINCREMENT,\n115\t                  collection_name TEXT NOT NULL,\n116\t                  record_key TEXT NOT NULL,\n117\t                  op_kind TEXT NOT NULL CHECK(op_kind = 'append'),\n118\t                  payload_json TEXT NOT NULL,\n119\t                  schema_id TEXT,\n120\t                  write_cursor INTEGER NOT NULL\n121\t              );\n122\t              CREATE TABLE IF NOT EXISTS operational_state(\n123\t                  collection_name TEXT NOT NULL,\n124\t                  record_key TEXT NOT NULL,\n125\t                  payload_json TEXT NOT NULL,\n126\t                  schema_id TEXT,\n127\t                  write_cursor INTEGER NOT NULL,\n128\t                  PRIMARY KEY(collection_name, record_key)\n129\t              );\n130\t              CREATE TABLE IF NOT EXISTS _fathomdb_open_state(key TEXT PRIMARY KEY, value TEXT NOT NULL);\n131\t              INSERT OR IGNORE INTO operational_collections(\n132\t                  name, kind, schema_json, retention_json, format_version, created_at\n133\t              ) VALUES (\n134\t                  'projection_failures',\n135\t                  'append_only_log',\n136\t                  '{\\\"type\\\":\\\"object\\\"}',\n137\t                  '{}',\n138\t                  1,\n139\t                  0\n140\t              );\",\n141\t    },\n142\t    Migration {\n143\t        step_id: 5,\n144\t        sql: \"CREATE VIRTUAL TABLE IF NOT EXISTS search_index USING fts5(\n145\t                  body,\n146\t                  kind UNINDEXED,\n147\t                  write_cursor UNINDEXED\n148\t              );\",\n149\t    },\n150\t    Migration {\n151\t        step_id: 6,\n152\t        sql: \"CREATE TABLE IF NOT EXISTS _fathomdb_projection_state(\n153\t                  kind TEXT PRIMARY KEY,\n154\t                  last_enqueued_cursor INTEGER NOT NULL DEFAULT 0,\n155\t                  updated_at INTEGER NOT NULL DEFAULT 0\n156\t              );\n157\t              CREATE TABLE IF NOT EXISTS _fathomdb_vector_kinds(\n158\t                  kind TEXT PRIMARY KEY,\n159\t                  profile TEXT NOT NULL,\n160\t                  created_at INTEGER NOT NULL DEFAULT 0\n161\t              );\n162\t              CREATE TABLE IF NOT EXISTS _fathomdb_vector_rows(\n163\t                  rowid INTEGER PRIMARY KEY,\n164\t                  kind TEXT NOT NULL,\n165\t                  write_cursor INTEGER NOT NULL UNIQUE\n166\t              );\",\n167\t    },\n168\t    Migration {\n169\t        step_id: 7,\n170\t        sql: \"CREATE TABLE IF NOT EXISTS _fathomdb_projection_terminal(\n171\t                  write_cursor INTEGER PRIMARY KEY,\n172\t                  state TEXT NOT NULL CHECK(state IN ('failed', 'up_to_date'))\n173\t              );\",\n174\t    },\n175\t    // Phase 9 Pack B — REQ-026 / AC-028a/b/c / AC-042 recovery seam.\n176\t    // `source_id` is nullable; existing canonical rows back-fill to NULL,\n177\t    // so reads from older callers stay schema-stable. REQ-045 accretion\n178\t    // offset is documented in `migrations/008_source_id.sql` as inherently\n179\t    // impossible for this slice (every existing canonical column is\n180\t    // load-bearing for replay / projections / recovery locators); the\n181\t    // next schema-touching pack carries the offset budget for two adds.\n182\t    Migration {\n183\t        step_id: 8,\n184\t        sql: \"ALTER TABLE canonical_nodes ADD COLUMN source_id TEXT;\n185\t              ALTER TABLE canonical_edges ADD COLUMN source_id TEXT;\n186\t              CREATE INDEX IF NOT EXISTS canonical_nodes_source_id_idx\n187\t                  ON canonical_nodes(source_id);\n188\t              CREATE INDEX IF NOT EXISTS canonical_edges_source_id_idx\n189\t                  ON canonical_edges(source_id);\",\n190\t    },\n191\t];\n192\t\n193\tpub fn migrate(conn: &Connection) -> Result<MigrationReport, MigrationError> {\n194\t    migrate_with_steps(conn, MIGRATIONS)\n195\t}\n196\t\n197\tpub fn migrate_with_steps(\n198\t    conn: &Connection,\n199\t    migrations: &[Migration],\n200\t) -> Result<MigrationReport, MigrationError> {\n201\t    migrate_with_event_sink(conn, migrations, |_| {})\n202\t}\n203\t\n204\tpub fn migrate_with_event_sink(\n205\t    conn: &Connection,\n206\t    migrations: &[Migration],\n207\t    mut emit: impl FnMut(&MigrationStepReport),\n208\t) -> Result<MigrationReport, MigrationError> {\n209\t    let before = user_version(conn)?;\n210\t    if before > SCHEMA_VERSION {\n211\t        return Err(MigrationError::IncompatibleSchemaVersion {\n212\t            seen: before,\n213\t            supported: SCHEMA_VERSION,\n214\t        });\n215\t    }\n216\t\n217\t    let mut current = before;\n218\t    let mut reports = Vec::new();\n219\t\n220\t    for migration in migrations.iter().filter(|migration| migration.step_id > before) {\n221\t        if migration.step_id != current.saturating_add(1) {\n222\t            return Err(MigrationError::Storage {\n223\t                message: \"migration registry is not contiguous\",\n224\t            });\n225\t        }\n226\t\n227\t        let started = Instant::now();\n228\t        if let Err(_err) = apply_one(conn, migration) {\n229\t            reports.push(MigrationStepReport {\n230\t                step_id: migration.step_id,\n231\t                duration_ms: Some(duration_ms(started)),\n232\t                failed: true,\n233\t            });\n234\t            emit(reports.last().expect(\"failed step report was just pushed\"));\n235\t            let schema_version_current = user_version(conn).unwrap_or(current);\n236\t            return Err(MigrationError::MigrationError(MigrationFailureReport {\n237\t                schema_version_before: before,\n238\t                schema_version_current,\n239\t                migration_steps: reports,\n240\t            }));\n241\t        }\n242\t\n243\t        current = migration.step_id;\n244\t        reports.push(MigrationStepReport {\n245\t            step_id: migration.step_id,\n246\t            duration_ms: Some(duration_ms(started)),\n247\t            failed: false,\n248\t        });\n249\t        emit(reports.last().expect(\"successful step report was just pushed\"));\n250\t    }\n251\t\n252\t    Ok(MigrationReport {\n253\t        schema_version_before: before,\n254\t        schema_version_after: user_version(conn)?,\n255\t        migration_steps: reports,\n256\t    })\n257\t}\n258\t\n259\tfn apply_one(conn: &Connection, migration: &Migration) -> rusqlite::Result<()> {\n260\t    conn.execute_batch(\"BEGIN IMMEDIATE\")?;\n261\t    let result = (|| {\n262\t        conn.execute_batch(migration.sql)?;\n263\t        conn.pragma_update(None, PRAGMA_USER_VERSION, migration.step_id)?;\n264\t        Ok(())\n265\t    })();\n266\t\n267\t    match result {\n268\t        Ok(()) => conn.execute_batch(\"COMMIT\"),\n269\t        Err(err) => {\n270\t            let _ = conn.execute_batch(\"ROLLBACK\");\n271\t            Err(err)\n272\t        }\n273\t    }\n274\t}\n275\t\n276\tfn user_version(conn: &Connection) -> Result<u32, MigrationError> {\n277\t    conn.query_row(\"PRAGMA user_version\", [], |row| row.get::<_, u32>(0))\n278\t        .map_err(|_| MigrationError::Storage { message: \"could not read schema version\" })\n279\t}\n280\t\n281\tfn duration_ms(started: Instant) -> u64 {\n282\t    u64::try_from(started.elapsed().as_millis()).unwrap_or(u64::MAX)\n283\t}\n284\t\n285\t#[derive(Clone, Debug, Eq, PartialEq)]\n286\tpub struct MigrationAccretionError {\n287\t    pub offender: String,\n288\t}\n289\t\n290\timpl Display for MigrationAccretionError {\n291\t    fn fmt(&self, f: &mut Formatter<'_>) -> std::fmt::Result {\n292\t        write!(f, \"migration accretion guard rejected {}\", self.offender)\n293\t    }\n294\t}\n295\t\n296\timpl std::error::Error for MigrationAccretionError {}\n297\t\n298\tpub fn check_migration_accretion(name: &str, sql: &str) -> Result<(), MigrationAccretionError> {\n299\t    let upper = sql.to_ascii_uppercase();\n300\t    let adds_schema = upper.contains(\"CREATE TABLE\") || upper.contains(\"ADD COLUMN\");\n301\t    let names_removal = upper.contains(\"DROP TABLE\") || upper.contains(\"DROP COLUMN\");\n302\t    let has_exemption = sql.contains(\"-- MIGRATION-ACCRETION-EXEMPTION: \");\n303\t\n304\t    if adds_schema && !names_removal && !has_exemption {\n305\t        return Err(MigrationAccretionError { offender: name.to_string() });\n306\t    }\n307\t\n308\t    Ok(())\n309\t}\n310\t"}]},"parent_tool_use_id":null,"session_id":"6045b345-74e5-4485-9471-2a1561990851","uuid":"30c89987-89fd-432c-b199-5e97944321b2","timestamp":"2026-05-15T23:42:08.460Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-10b-A-low-risk-seams-20260515T234104Z/src/rust/crates/fathomdb-schema/src/lib.rs","content":"use std::fmt::{Display, Formatter};\nuse std::time::Instant;\n\nuse rusqlite::Connection;\n\npub const SCHEMA_VERSION: u32 = 8;\n\n/// SQLite `PRAGMA` name carrying the on-disk schema-version sentinel.\n///\n/// Public on-disk surface per `dev/interfaces/wire.md` § Schema-version\n/// sentinel; advanced by successful migrations per `dev/design/migrations.md`.\npub const PRAGMA_USER_VERSION: &str = \"user_version\";\n\n/// Suffix of the canonical SQLite database file (`<db-name>.sqlite`).\npub const SQLITE_SUFFIX: &str = \".sqlite\";\n\n/// Suffix of the SQLite write-ahead log file (`<db-name>.sqlite-wal`).\npub const WAL_SUFFIX: &str = \"-wal\";\n\n/// Suffix of the sidecar lock file (`<db-name>.sqlite.lock`).\n///\n/// Per `dev/design/bindings.md` § 7, this sidecar flock is the load-bearing\n/// cross-process exclusion layer; it surfaces lock contention before SQLite\n/// I/O begins.\npub const LOCK_SUFFIX: &str = \".lock\";\n\n/// Suffix of the optional SQLite rollback journal file\n/// (`<db-name>.sqlite-journal`).\npub const JOURNAL_SUFFIX: &str = \"-journal\";\n\n#[must_use]\npub fn bootstrap_steps() -> &'static [&'static str] {\n    &[\"create canonical tables\", \"register projection metadata\", \"seed rewrite-era configuration\"]\n}\n\n#[derive(Clone, Copy, Debug, Eq, PartialEq)]\npub struct Migration {\n    pub step_id: u32,\n    pub sql: &'static str,\n}\n\n#[derive(Clone, Debug, Eq, PartialEq)]\npub struct MigrationStepReport {\n    pub step_id: u32,\n    pub duration_ms: Option<u64>,\n    pub failed: bool,\n}\n\n#[derive(Clone, Debug, Eq, PartialEq)]\npub struct MigrationReport {\n    pub schema_version_before: u32,\n    pub schema_version_after: u32,\n    pub migration_steps: Vec<MigrationStepReport>,\n}\n\n#[derive(Clone, Debug, Eq, PartialEq)]\npub struct MigrationFailureReport {\n    pub schema_version_before: u32,\n    pub schema_version_current: u32,\n    pub migration_steps: Vec<MigrationStepReport>,\n}\n\n#[derive(Clone, Debug, Eq, PartialEq)]\npub enum MigrationError {\n    IncompatibleSchemaVersion { seen: u32, supported: u32 },\n    MigrationError(MigrationFailureReport),\n    Storage { message: &'static str },\n}\n\nimpl Display for MigrationError {\n    fn fmt(&self, f: &mut Formatter<'_>) -> std::fmt::Result {\n        match self {\n            Self::IncompatibleSchemaVersion { seen, supported } => {\n                write!(f, \"database schema version {seen} is incompatible with supported version {supported}\")\n            }\n            Self::MigrationError(report) => write!(\n                f,\n                \"schema migration failed at step {}\",\n                report.migration_steps.last().map_or(0, |step| step.step_id)\n            ),\n            Self::Storage { message } => write!(f, \"schema storage error: {message}\"),\n        }\n    }\n}\n\nimpl std::error::Error for MigrationError {}\n\npub const MIGRATIONS: &[Migration] = &[\n    Migration {\n        step_id: 1,\n        sql: \"CREATE TABLE IF NOT EXISTS _fathomdb_schema_meta(key TEXT PRIMARY KEY, value TEXT NOT NULL)\",\n    },\n    Migration {\n        step_id: 2,\n        sql: \"CREATE TABLE IF NOT EXISTS _fathomdb_migrations(step_id INTEGER PRIMARY KEY, applied_at_ms INTEGER NOT NULL);\n              CREATE TABLE IF NOT EXISTS canonical_nodes(write_cursor INTEGER NOT NULL, kind TEXT NOT NULL, body TEXT NOT NULL);\n              CREATE TABLE IF NOT EXISTS canonical_edges(write_cursor INTEGER NOT NULL, kind TEXT NOT NULL, from_id TEXT NOT NULL, to_id TEXT NOT NULL);\",\n    },\n    Migration {\n        step_id: 3,\n        sql: \"CREATE TABLE IF NOT EXISTS _fathomdb_embedder_profiles(profile TEXT PRIMARY KEY, name TEXT NOT NULL, revision TEXT NOT NULL, dimension INTEGER NOT NULL)\",\n    },\n    Migration {\n        step_id: 4,\n        sql: \"CREATE TABLE IF NOT EXISTS operational_collections(\n                  name TEXT PRIMARY KEY,\n                  kind TEXT NOT NULL CHECK(kind IN ('append_only_log', 'latest_state')),\n                  schema_json TEXT NOT NULL,\n                  retention_json TEXT NOT NULL,\n                  format_version INTEGER NOT NULL,\n                  created_at INTEGER NOT NULL\n              );\n              CREATE TABLE IF NOT EXISTS operational_mutations(\n                  id INTEGER PRIMARY KEY AUTOINCREMENT,\n                  collection_name TEXT NOT NULL,\n                  record_key TEXT NOT NULL,\n                  op_kind TEXT NOT NULL CHECK(op_kind = 'append'),\n                  payload_json TEXT NOT NULL,\n                  schema_id TEXT,\n                  write_cursor INTEGER NOT NULL\n              );\n              CREATE TABLE IF NOT EXISTS operational_state(\n                  collection_name TEXT NOT NULL,\n                  record_key TEXT NOT NULL,\n                  payload_json TEXT NOT NULL,\n                  schema_id TEXT,\n                  write_cursor INTEGER NOT NULL,\n                  PRIMARY KEY(collection_name, record_key)\n              );\n              CREATE TABLE IF NOT EXISTS _fathomdb_open_state(key TEXT PRIMARY KEY, value TEXT NOT NULL);\n              INSERT OR IGNORE INTO operational_collections(\n                  name, kind, schema_json, retention_json, format_version, created_at\n              ) VALUES (\n                  'projection_failures',\n                  'append_only_log',\n                  '{\\\"type\\\":\\\"object\\\"}',\n                  '{}',\n                  1,\n                  0\n              );\",\n    },\n    Migration {\n        step_id: 5,\n        sql: \"CREATE VIRTUAL TABLE IF NOT EXISTS search_index USING fts5(\n                  body,\n                  kind UNINDEXED,\n                  write_cursor UNINDEXED\n              );\",\n    },\n    Migration {\n        step_id: 6,\n        sql: \"CREATE TABLE IF NOT EXISTS _fathomdb_projection_state(\n                  kind TEXT PRIMARY KEY,\n                  last_enqueued_cursor INTEGER NOT NULL DEFAULT 0,\n                  updated_at INTEGER NOT NULL DEFAULT 0\n              );\n              CREATE TABLE IF NOT EXISTS _fathomdb_vector_kinds(\n                  kind TEXT PRIMARY KEY,\n                  profile TEXT NOT NULL,\n                  created_at INTEGER NOT NULL DEFAULT 0\n              );\n              CREATE TABLE IF NOT EXISTS _fathomdb_vector_rows(\n                  rowid INTEGER PRIMARY KEY,\n                  kind TEXT NOT NULL,\n                  write_cursor INTEGER NOT NULL UNIQUE\n              );\",\n    },\n    Migration {\n        step_id: 7,\n        sql: \"CREATE TABLE IF NOT EXISTS _fathomdb_projection_terminal(\n                  write_cursor INTEGER PRIMARY KEY,\n                  state TEXT NOT NULL CHECK(state IN ('failed', 'up_to_date'))\n              );\",\n    },\n    // Phase 9 Pack B — REQ-026 / AC-028a/b/c / AC-042 recovery seam.\n    // `source_id` is nullable; existing canonical rows back-fill to NULL,\n    // so reads from older callers stay schema-stable. REQ-045 accretion\n    // offset is documented in `migrations/008_source_id.sql` as inherently\n    // impossible for this slice (every existing canonical column is\n    // load-bearing for replay / projections / recovery locators); the\n    // next schema-touching pack carries the offset budget for two adds.\n    Migration {\n        step_id: 8,\n        sql: \"ALTER TABLE canonical_nodes ADD COLUMN source_id TEXT;\n              ALTER TABLE canonical_edges ADD COLUMN source_id TEXT;\n              CREATE INDEX IF NOT EXISTS canonical_nodes_source_id_idx\n                  ON canonical_nodes(source_id);\n              CREATE INDEX IF NOT EXISTS canonical_edges_source_id_idx\n                  ON canonical_edges(source_id);\",\n    },\n];\n\npub fn migrate(conn: &Connection) -> Result<MigrationReport, MigrationError> {\n    migrate_with_steps(conn, MIGRATIONS)\n}\n\npub fn migrate_with_steps(\n    conn: &Connection,\n    migrations: &[Migration],\n) -> Result<MigrationReport, MigrationError> {\n    migrate_with_event_sink(conn, migrations, |_| {})\n}\n\npub fn migrate_with_event_sink(\n    conn: &Connection,\n    migrations: &[Migration],\n    mut emit: impl FnMut(&MigrationStepReport),\n) -> Result<MigrationReport, MigrationError> {\n    let before = user_version(conn)?;\n    if before > SCHEMA_VERSION {\n        return Err(MigrationError::IncompatibleSchemaVersion {\n            seen: before,\n            supported: SCHEMA_VERSION,\n        });\n    }\n\n    let mut current = before;\n    let mut reports = Vec::new();\n\n    for migration in migrations.iter().filter(|migration| migration.step_id > before) {\n        if migration.step_id != current.saturating_add(1) {\n            return Err(MigrationError::Storage {\n                message: \"migration registry is not contiguous\",\n            });\n        }\n\n        let started = Instant::now();\n        if let Err(_err) = apply_one(conn, migration) {\n            reports.push(MigrationStepReport {\n                step_id: migration.step_id,\n                duration_ms: Some(duration_ms(started)),\n                failed: true,\n            });\n            emit(reports.last().expect(\"failed step report was just pushed\"));\n            let schema_version_current = user_version(conn).unwrap_or(current);\n            return Err(MigrationError::MigrationError(MigrationFailureReport {\n                schema_version_before: before,\n                schema_version_current,\n                migration_steps: reports,\n            }));\n        }\n\n        current = migration.step_id;\n        reports.push(MigrationStepReport {\n            step_id: migration.step_id,\n            duration_ms: Some(duration_ms(started)),\n            failed: false,\n        });\n        emit(reports.last().expect(\"successful step report was just pushed\"));\n    }\n\n    Ok(MigrationReport {\n        schema_version_before: before,\n        schema_version_after: user_version(conn)?,\n        migration_steps: reports,\n    })\n}\n\nfn apply_one(conn: &Connection, migration: &Migration) -> rusqlite::Result<()> {\n    conn.execute_batch(\"BEGIN IMMEDIATE\")?;\n    let result = (|| {\n        conn.execute_batch(migration.sql)?;\n        conn.pragma_update(None, PRAGMA_USER_VERSION, migration.step_id)?;\n        Ok(())\n    })();\n\n    match result {\n        Ok(()) => conn.execute_batch(\"COMMIT\"),\n        Err(err) => {\n            let _ = conn.execute_batch(\"ROLLBACK\");\n            Err(err)\n        }\n    }\n}\n\nfn user_version(conn: &Connection) -> Result<u32, MigrationError> {\n    conn.query_row(\"PRAGMA user_version\", [], |row| row.get::<_, u32>(0))\n        .map_err(|_| MigrationError::Storage { message: \"could not read schema version\" })\n}\n\nfn duration_ms(started: Instant) -> u64 {\n    u64::try_from(started.elapsed().as_millis()).unwrap_or(u64::MAX)\n}\n\n#[derive(Clone, Debug, Eq, PartialEq)]\npub struct MigrationAccretionError {\n    pub offender: String,\n}\n\nimpl Display for MigrationAccretionError {\n    fn fmt(&self, f: &mut Formatter<'_>) -> std::fmt::Result {\n        write!(f, \"migration accretion guard rejected {}\", self.offender)\n    }\n}\n\nimpl std::error::Error for MigrationAccretionError {}\n\npub fn check_migration_accretion(name: &str, sql: &str) -> Result<(), MigrationAccretionError> {\n    let upper = sql.to_ascii_uppercase();\n    let adds_schema = upper.contains(\"CREATE TABLE\") || upper.contains(\"ADD COLUMN\");\n    let names_removal = upper.contains(\"DROP TABLE\") || upper.contains(\"DROP COLUMN\");\n    let has_exemption = sql.contains(\"-- MIGRATION-ACCRETION-EXEMPTION: \");\n\n    if adds_schema && !names_removal && !has_exemption {\n        return Err(MigrationAccretionError { offender: name.to_string() });\n    }\n\n    Ok(())\n}\n","numLines":310,"startLine":1,"totalLines":310}}}
