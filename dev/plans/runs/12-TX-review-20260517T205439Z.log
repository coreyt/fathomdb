     1	// Native-binding loader. Locates the platform-tagged `.node` artifact
     2	// produced by `napi build` and re-exports it as a typed module.
     3	
     4	import { existsSync } from "node:fs";
     5	import { createRequire } from "node:module";
     6	import { dirname, join } from "node:path";
     7	import { fileURLToPath } from "node:url";
     8	
     9	const require = createRequire(import.meta.url);
    10	const here = dirname(fileURLToPath(import.meta.url));
    11	
    12	// `napi build` writes `<name>.<triple>.node` next to the package.json
    13	// (cwd of the build script). Walk up from this file's compiled location
    14	// to find candidates.
    15	const SEARCH_ROOTS = [
    16	  join(here, ".."), // dist/src/ -> dist/
    17	  join(here, "..", ".."), // dist/src/ -> dist/.. (pkg root)
    18	  here, // co-located fallback
    19	];
    20	
    21	const TRIPLES = [
    22	  "linux-x64-gnu",
    23	  "linux-x64-musl",
    24	  "linux-arm64-gnu",
    25	  "linux-arm64-musl",
    26	  "linux-arm-gnueabihf",
    27	  "darwin-x64",
    28	  "darwin-arm64",
    29	  "darwin-universal",
    30	  "win32-x64-msvc",
    31	  "win32-ia32-msvc",
    32	  "win32-arm64-msvc",
    33	  "freebsd-x64",
    34	  "android-arm64",
    35	  "android-arm-eabi",
    36	];
    37	
    38	function loadNative(): unknown {
    39	  for (const root of SEARCH_ROOTS) {
    40	    for (const triple of TRIPLES) {
    41	      const candidate = join(root, `fathomdb.${triple}.node`);
    42	      if (existsSync(candidate)) {
    43	        return require(candidate);
    44	      }
    45	    }
    46	  }
    47	  throw new Error(
    48	    "fathomdb native binding not found. Run `npm run build` to compile it.",
    49	  );
    50	}
    51	
    52	interface NativeWriteReceipt {
    53	  cursor: number;
    54	}
    55	
    56	interface NativeSoftFallback {
    57	  branch: string;
    58	}
    59	
    60	interface NativeSearchResult {
    61	  projectionCursor: number;
    62	  softFallback: NativeSoftFallback | null;
    63	  results: string[];
    64	}
    65	
    66	interface NativeCounterSnapshot {
    67	  queries: number;
    68	  writes: number;
    69	  writeRows: number;
    70	  adminOps: number;
    71	  cacheHit: number;
    72	  cacheMiss: number;
    73	}
    74	
    75	interface NativeAttachSubscriberOptions {
    76	  heartbeatIntervalMs?: number;
    77	}
    78	
    79	interface NativeEngineConfig {
    80	  embedderPoolSize?: number;
    81	  schedulerRuntimeThreads?: number;
    82	  provenanceRowCap?: number;
    83	  embedderCallTimeoutMs?: number;
    84	  slowThresholdMs?: number;
    85	}
    86	
    87	interface NativeEngineOpenOptions {
    88	  engineConfig?: NativeEngineConfig;
    89	}
    90	
    91	interface NativeAdminConfigureOptions {
    92	  name: string;
    93	  body: string;
    94	}
    95	
    96	export interface NativeEngine {
    97	  write(batch: unknown[]): Promise<NativeWriteReceipt>;
    98	  search(query: string): Promise<NativeSearchResult>;
    99	  close(): Promise<void>;
   100	  drain(timeoutMs: number): Promise<void>;
   101	  counters(): NativeCounterSnapshot;
   102	  setProfiling(enabled: boolean): void;
   103	  setSlowThresholdMs(value: number): void;
   104	  attachSubscriber(callback: unknown, options?: NativeAttachSubscriberOptions): void;
   105	}
   106	
   107	export interface NativeModule {
   108	  Engine: {
   109	    open(path: string, options?: NativeEngineOpenOptions): Promise<NativeEngine>;
   110	  };
   111	  adminConfigure(
   112	    engine: NativeEngine,
   113	    options: NativeAdminConfigureOptions,
   114	  ): Promise<NativeWriteReceipt>;
   115	  forcePanicForTest?: () => void;
   116	  forcePanicInAccessorForTest?: () => void;
   117	}
   118	
   119	export const native = loadNative() as NativeModule;

