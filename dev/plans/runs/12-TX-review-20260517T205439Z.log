    76	
    77	export class EmbedderIdentityMismatchError extends FathomDbError {
    78	  readonly storedName: string;
    79	  readonly storedRevision: string;
    80	  readonly suppliedName: string;
    81	  readonly suppliedRevision: string;
    82	  constructor(payload: EmbedderIdentityMismatchPayload) {
