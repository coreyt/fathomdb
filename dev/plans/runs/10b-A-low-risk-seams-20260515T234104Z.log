{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013WPdyVsJGYRNXoRjnyqGx1","type":"tool_result","content":"1776\t    pub fn check_integrity(\n1777\t        &self,\n1778\t        opts: CheckIntegrityOpts,\n1779\t    ) -> Result<IntegrityReport, EngineError> {\n1780\t        self.ensure_open()?;\n1781\t        let connection = self.connection.lock().map_err(|_| EngineError::Storage)?;\n1782\t        let connection = connection.as_ref().ok_or(EngineError::Closing)?;\n1783\t        Ok(IntegrityReport {\n1784\t            physical: physical_section(connection, opts.full),\n1785\t            logical: logical_section(connection),\n1786\t            semantic: semantic_section(connection),\n1787\t        })\n1788\t    }\n1789\t\n1790\t    /// Doctor bit-preserving export. Runs `VACUUM INTO` to produce a\n1791\t    /// self-contained SQLite file at `out`, computes SHA-256 of the\n1792\t    /// resulting bytes, and writes a JSON manifest at `manifest`. Per\n1793\t    /// AC-039a/b.\n1794\t    pub fn safe_export(\n1795\t        &self,\n1796\t        out: &Path,\n1797\t        manifest: &Path,\n1798\t    ) -> Result<SafeExportArtifact, EngineError> {\n1799\t        self.ensure_open()?;\n1800\t        {\n1801\t            let connection = self.connection.lock().map_err(|_| EngineError::Storage)?;\n1802\t            let connection = connection.as_ref().ok_or(EngineError::Closing)?;\n1803\t            let target = out.to_string_lossy().to_string();\n1804\t            connection\n1805\t                .execute(\"VACUUM INTO ?1\", params![target])\n1806\t                .map_err(|_| EngineError::Storage)?;\n1807\t        }\n1808\t        let bytes = std::fs::read(out).map_err(|_| EngineError::Storage)?;\n1809\t        let digest = sha2::Sha256::digest(&bytes);\n1810\t        let sha256_hex = hex_encode(digest.as_slice());\n1811\t        let export_abs = out.canonicalize().unwrap_or_else(|_| out.to_path_buf());\n1812\t        let manifest_json = serde_json::json!({\n1813\t            \"export_path\": export_abs.to_string_lossy(),\n1814\t            \"sha256\": sha256_hex,\n1815\t            \"byte_count\": bytes.len() as u64,\n1816\t        });\n1817\t        let manifest_bytes =\n1818\t            serde_json::to_vec_pretty(&manifest_json).map_err(|_| EngineError::Storage)?;\n1819\t        std::fs::write(manifest, &manifest_bytes).map_err(|_| EngineError::Storage)?;\n1820\t        Ok(SafeExportArtifact {\n1821\t            export_path: out.to_path_buf(),\n1822\t            manifest_path: manifest.to_path_buf(),\n1823\t            manifest_sha256: sha256_hex,\n1824\t        })\n1825\t    }\n1826\t\n1827\t    /// Operator regenerate workflow per `dev/design/projections.md`\n1828\t    /// § Regenerate workflow. Drains in-flight projection work, then\n1829\t    /// truncates FTS5 + vec0 shadow rows, resets the projection cursor,\n1830\t    /// and lets the scheduler re-enqueue every canonical row. Durable\n1831\t    /// `projection_failures` audit rows are preserved per design. AC-044\n1832\t    /// + AC-063c.\n1833\t    pub fn rebuild_projections(&self) -> Result<RebuildReport, EngineError> {\n1834\t        self.ensure_open()?;\n1835\t        self.run_rebuild(true, RebuildKind::Projections)\n1836\t    }\n1837\t\n1838\t    /// Vec0-only variant of [`Engine::rebuild_projections`]. Leaves\n1839\t    /// FTS5 shadow content untouched; per recovery design,\n1840\t    /// `recover --rebuild-vec0` is the surface for vec0-only repair.\n1841\t    pub fn rebuild_vec0(&self) -> Result<RebuildReport, EngineError> {\n1842\t        self.ensure_open()?;\n1843\t        self.run_rebuild(false, RebuildKind::Vec0)\n1844\t    }\n1845\t\n1846\t    /// Phase 9 Pack B / AC-042 source trace. Returns the canonical-row\n1847\t    /// id set produced by `source_id`, ordered by `write_cursor`. Empty\n1848\t    /// string is not a valid `source_id`; rows with NULL `source_id`\n1849\t    /// are excluded from every result.\n1850\t    pub fn trace_source_ref(&self, source_id: &str) -> Result<TraceReport, EngineError> {\n1851\t        self.ensure_open()?;\n1852\t        if source_id.is_empty() {\n1853\t            return Err(EngineError::WriteValidation);\n1854\t        }\n1855\t        let connection = self.connection.lock().map_err(|_| EngineError::Storage)?;\n1856\t        let connection = connection.as_ref().ok_or(EngineError::Closing)?;\n1857\t\n1858\t        let mut events: Vec<TraceEvent> = Vec::new();\n1859\t        let mut nodes = connection\n1860\t            .prepare(\n1861\t                \"SELECT write_cursor, kind FROM canonical_nodes WHERE source_id = ?1\n1862\t                 ORDER BY write_cursor\",\n1863\t            )\n1864\t            .map_err(|_| EngineError::Storage)?;\n1865\t        let node_rows = nodes\n1866\t            .query_map([source_id], |row| {\n1867\t                Ok(TraceEvent {\n1868\t                    write_cursor: row.get::<_, i64>(0)? as u64,\n1869\t                    kind: row.get::<_, String>(1)?,\n1870\t                    table: \"canonical_nodes\",\n1871\t                })\n1872\t            })\n1873\t            .map_err(|_| EngineError::Storage)?;\n1874\t        for row in node_rows {\n1875\t            events.push(row.map_err(|_| EngineError::Storage)?);\n1876\t        }\n1877\t\n1878\t        let mut edges = connection\n1879\t            .prepare(\n1880\t                \"SELECT write_cursor, kind FROM canonical_edges WHERE source_id = ?1\n1881\t                 ORDER BY write_cursor\",\n1882\t            )\n1883\t            .map_err(|_| EngineError::Storage)?;\n1884\t        let edge_rows = edges\n1885\t            .query_map([source_id], |row| {\n1886\t                Ok(TraceEvent {\n1887\t                    write_cursor: row.get::<_, i64>(0)? as u64,\n1888\t                    kind: row.get::<_, String>(1)?,\n1889\t                    table: \"canonical_edges\",\n1890\t                })\n1891\t            })\n1892\t            .map_err(|_| EngineError::Storage)?;\n1893\t        for row in edge_rows {\n1894\t            events.push(row.map_err(|_| EngineError::Storage)?);\n1895\t        }\n1896\t\n1897\t        events.sort_by_key(|e| e.write_cursor);\n1898\t        Ok(TraceReport { source_ref: source_id.to_string(), events })\n1899\t    }\n1900\t\n1901\t    /// Phase 9 Pack B / AC-028a/b/c source excise. Drains in-flight\n1902\t    /// projection work, then deletes every canonical row attributable\n1903\t    /// to `source_id` plus the FTS5 + vec0 shadow rows that referenced\n1904\t    /// those cursors, and appends an audit row to the\n1905\t    /// `excise_source_audit` operational collection.\n1906\t    ///\n1907\t    /// Non-perturbation: rows from other sources (and rows with NULL\n1908\t    /// `source_id`) are untouched; the projection cursor is NOT reset\n1909\t    /// and no blanket projection rebuild is issued.\n1910\t    pub fn excise_source(&self, source_id: &str) -> Result<ExciseReport, EngineError> {\n1911\t        self.ensure_open()?;\n1912\t        if source_id.is_empty() {\n1913\t            return Err(EngineError::WriteValidation);\n1914\t        }\n1915\t\n1916\t        // Drain MUST succeed before the excise transaction. SQLite-WAL\n1917\t        // would otherwise allow a worker that already dequeued a job\n1918\t        // for an excised cursor to commit its INSERT into vec0 /\n1919\t        // _fathomdb_vector_rows after our DELETE releases the writer\n1920\t        // lock, leaving residue and breaking AC-028b. Surface the\n1921\t        // timeout instead of swallowing it (Pack A pattern).\n1922\t        self.projection_runtime.set_frozen(true);\n1923\t        let drain_result = self.drain(REBUILD_DRAIN_TIMEOUT_MS);\n1924\t        let outcome = drain_result.and_then(|()| self.excise_source_inner(source_id));\n1925\t        self.projection_runtime.set_frozen(false);\n1926\t        outcome\n1927\t    }\n1928\t\n1929\t    fn excise_source_inner(&self, source_id: &str) -> Result<ExciseReport, EngineError> {\n1930\t        let mut connection = self.connection.lock().map_err(|_| EngineError::Storage)?;\n1931\t        let connection = connection.as_mut().ok_or(EngineError::Closing)?;\n1932\t        let tx = connection.transaction().map_err(|_| EngineError::Storage)?;\n1933\t\n1934\t        // Collect the cursor sets up-front so we can targeted-delete\n1935\t        // shadow rows AND emit an accurate audit row in one txn.\n1936\t        let node_cursors: Vec<i64> = {\n1937\t            let mut stmt = tx\n1938\t                .prepare(\"SELECT write_cursor FROM canonical_nodes WHERE source_id = ?1\")\n1939\t                .map_err(|_| EngineError::Storage)?;\n1940\t            let rows = stmt\n1941\t                .query_map([source_id], |row| row.get::<_, i64>(0))\n1942\t                .map_err(|_| EngineError::Storage)?;\n1943\t            rows.collect::<rusqlite::Result<Vec<_>>>().map_err(|_| EngineError::Storage)?\n1944\t        };\n1945\t        let edge_cursors: Vec<i64> = {\n1946\t            let mut stmt = tx\n1947\t                .prepare(\"SELECT write_cursor FROM canonical_edges WHERE source_id = ?1\")\n1948\t                .map_err(|_| EngineError::Storage)?;\n1949\t            let rows = stmt\n1950\t                .query_map([source_id], |row| row.get::<_, i64>(0))\n1951\t                .map_err(|_| EngineError::Storage)?;\n1952\t            rows.collect::<rusqlite::Result<Vec<_>>>().map_err(|_| EngineError::Storage)?\n1953\t        };\n1954\t\n1955\t        let mut shadow_invalidated: u64 = 0;\n1956\t        for cursor in node_cursors.iter().chain(edge_cursors.iter()) {\n1957\t            shadow_invalidated = shadow_invalidated.saturating_add(\n1958\t                tx.execute(\"DELETE FROM search_index WHERE write_cursor = ?1\", [cursor])\n1959\t                    .map_err(|_| EngineError::Storage)? as u64,\n1960\t            );\n1961\t            // vec0 rowid is the canonical row's write_cursor (see\n1962\t            // `_fathomdb_vector_rows.write_cursor UNIQUE`).\n1963\t            shadow_invalidated = shadow_invalidated.saturating_add(\n1964\t                tx.execute(\"DELETE FROM vector_default WHERE rowid = ?1\", [cursor])\n1965\t                    .map_err(|_| EngineError::Storage)? as u64,\n1966\t            );\n1967\t            shadow_invalidated = shadow_invalidated.saturating_add(\n1968\t                tx.execute(\"DELETE FROM _fathomdb_vector_rows WHERE write_cursor = ?1\", [cursor])\n1969\t                    .map_err(|_| EngineError::Storage)? as u64,\n1970\t            );\n1971\t            shadow_invalidated = shadow_invalidated.saturating_add(\n1972\t                tx.execute(\n1973\t                    \"DELETE FROM _fathomdb_projection_terminal WHERE write_cursor = ?1\",\n1974\t                    [cursor],\n1975\t                )\n1976\t                .map_err(|_| EngineError::Storage)? as u64,\n1977\t            );\n1978\t        }\n1979\t\n1980\t        let nodes_excised = tx\n1981\t            .execute(\"DELETE FROM canonical_nodes WHERE source_id = ?1\", [source_id])\n1982\t            .map_err(|_| EngineError::Storage)? as u64;\n1983\t        let edges_excised = tx\n1984\t            .execute(\"DELETE FROM canonical_edges WHERE source_id = ?1\", [source_id])\n1985\t            .map_err(|_| EngineError::Storage)? as u64;\n1986\t\n1987\t        // AC-028a audit row: a single append on the\n1988\t        // `excise_source_audit` collection naming the excised source.\n1989\t        // `next_cursor` after a prior write holds the LAST committed cursor;\n1990\t        // mirror the vec writer pattern (load + 1, then store post-commit)\n1991\t        // so the audit row's `write_cursor` is strictly greater than every\n1992\t        // canonical row that preceded it.\n1993\t        let excised_at = SystemTime::now().duration_since(UNIX_EPOCH).unwrap_or_default().as_secs();\n1994\t        let payload = serde_json::json!({\n1995\t            \"source_id\": source_id,\n1996\t            \"excised_at\": excised_at,\n1997\t            \"nodes_excised\": nodes_excised,\n1998\t            \"edges_excised\": edges_excised,\n1999\t            \"projections_invalidated\": shadow_invalidated,\n2000\t        })\n2001\t        .to_string();\n2002\t        let audit_cursor = self.next_cursor.load(Ordering::SeqCst).saturating_add(1);\n2003\t        tx.execute(\n2004\t            \"INSERT INTO operational_mutations(\n2005\t                collection_name, record_key, op_kind, payload_json, schema_id, write_cursor\n2006\t             ) VALUES('excise_source_audit', ?1, 'append', ?2, NULL, ?3)\",\n2007\t            params![source_id, payload, audit_cursor],\n2008\t        )\n2009\t        .map_err(|_| EngineError::Storage)?;\n2010\t\n2011\t        tx.commit().map_err(|_| EngineError::Storage)?;\n2012\t        self.next_cursor.store(audit_cursor, Ordering::SeqCst);\n2013\t        Ok(ExciseReport {\n2014\t            source_ref: source_id.to_string(),\n2015\t            nodes_excised,\n2016\t            edges_excised,\n2017\t            projections_invalidated: shadow_invalidated,\n2018\t        })\n2019\t    }\n2020\t\n2021\t    fn run_rebuild(\n2022\t        &self,\n2023\t        include_fts: bool,\n2024\t        kind: RebuildKind,\n2025\t    ) -> Result<RebuildReport, EngineError> {\n2026\t        self.projection_runtime.set_frozen(true);\n2027\t        // Drain MUST succeed: rebuild_shadow_state truncates shadow rows,\n2028\t        // and SQLite-WAL allows a worker that already dequeued a job to\n2029\t        // commit its `INSERT OR IGNORE INTO _fathomdb_vector_rows / vec0`\n2030\t        // after our truncate releases the writer lock, leaving stale\n2031\t        // rows. Surfacing the timeout (instead of swallowing it) lets the\n2032\t        // operator retry rather than silently corrupt the rebuild.\n2033\t        let drain_result = self.drain(REBUILD_DRAIN_TIMEOUT_MS);\n2034\t        let result = drain_result.and_then(|()| self.rebuild_shadow_state(include_fts, kind));\n2035\t        self.projection_runtime.set_frozen(false);\n2036\t        result\n2037\t    }\n2038\t\n2039\t    fn rebuild_shadow_state(\n2040\t        &self,\n2041\t        include_fts: bool,\n2042\t        kind: RebuildKind,\n2043\t    ) -> Result<RebuildReport, EngineError> {\n2044\t        let mut connection = self.connection.lock().map_err(|_| EngineError::Storage)?;\n2045\t        let connection = connection.as_mut().ok_or(EngineError::Closing)?;\n2046\t        let tx = connection.transaction().map_err(|_| EngineError::Storage)?;\n2047\t        let mut rows_invalidated: u64 = 0;\n2048\t        if include_fts {\n2049\t            let n = tx.execute(\"DELETE FROM search_index\", []).map_err(|_| EngineError::Storage)?;\n2050\t            rows_invalidated = rows_invalidated.saturating_add(n as u64);\n2051\t        }\n2052\t        let n = tx.execute(\"DELETE FROM vector_default\", []).map_err(|_| EngineError::Storage)?;\n2053\t        rows_invalidated = rows_invalidated.saturating_add(n as u64);\n2054\t        let n = tx\n2055\t            .execute(\"DELETE FROM _fathomdb_vector_rows\", [])\n2056\t            .map_err(|_| EngineError::Storage)?;\n2057\t        rows_invalidated = rows_invalidated.saturating_add(n as u64);\n2058\t        let n = tx\n2059\t            .execute(\"DELETE FROM _fathomdb_projection_terminal\", [])\n2060\t            .map_err(|_| EngineError::Storage)?;\n2061\t        rows_invalidated = rows_invalidated.saturating_add(n as u64);\n2062\t        store_projection_cursor(&tx, 0).map_err(|_| EngineError::Storage)?;\n2063\t        let mut rows_rebuilt: u64 = 0;\n2064\t        if include_fts {\n2065\t            for row in canonical_node_rows(&tx).map_err(|_| EngineError::Storage)? {\n2066\t                tx.execute(\n2067\t                    \"INSERT INTO search_index(body, kind, write_cursor) VALUES(?1, ?2, ?3)\",\n2068\t                    params![row.body, row.kind, row.cursor],\n2069\t                )\n2070\t                .map_err(|_| EngineError::Storage)?;\n2071\t                rows_rebuilt = rows_rebuilt.saturating_add(1);\n2072\t            }\n2073\t        }\n2074\t        let projection_cursor_after =\n2075\t            load_projection_cursor(&tx).map_err(|_| EngineError::Storage)?;"}]},"parent_tool_use_id":null,"session_id":"6045b345-74e5-4485-9471-2a1561990851","uuid":"13184c58-2722-447d-bf80-621f82b97bc5","timestamp":"2026-05-15T23:41:54.205Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-10b-A-low-risk-seams-20260515T234104Z/src/rust/crates/fathomdb-engine/src/lib.rs","content":"    pub fn check_integrity(\n        &self,\n        opts: CheckIntegrityOpts,\n    ) -> Result<IntegrityReport, EngineError> {\n        self.ensure_open()?;\n        let connection = self.connection.lock().map_err(|_| EngineError::Storage)?;\n        let connection = connection.as_ref().ok_or(EngineError::Closing)?;\n        Ok(IntegrityReport {\n            physical: physical_section(connection, opts.full),\n            logical: logical_section(connection),\n            semantic: semantic_section(connection),\n        })\n    }\n\n    /// Doctor bit-preserving export. Runs `VACUUM INTO` to produce a\n    /// self-contained SQLite file at `out`, computes SHA-256 of the\n    /// resulting bytes, and writes a JSON manifest at `manifest`. Per\n    /// AC-039a/b.\n    pub fn safe_export(\n        &self,\n        out: &Path,\n        manifest: &Path,\n    ) -> Result<SafeExportArtifact, EngineError> {\n        self.ensure_open()?;\n        {\n            let connection = self.connection.lock().map_err(|_| EngineError::Storage)?;\n            let connection = connection.as_ref().ok_or(EngineError::Closing)?;\n            let target = out.to_string_lossy().to_string();\n            connection\n                .execute(\"VACUUM INTO ?1\", params![target])\n                .map_err(|_| EngineError::Storage)?;\n        }\n        let bytes = std::fs::read(out).map_err(|_| EngineError::Storage)?;\n        let digest = sha2::Sha256::digest(&bytes);\n        let sha256_hex = hex_encode(digest.as_slice());\n        let export_abs = out.canonicalize().unwrap_or_else(|_| out.to_path_buf());\n        let manifest_json = serde_json::json!({\n            \"export_path\": export_abs.to_string_lossy(),\n            \"sha256\": sha256_hex,\n            \"byte_count\": bytes.len() as u64,\n        });\n        let manifest_bytes =\n            serde_json::to_vec_pretty(&manifest_json).map_err(|_| EngineError::Storage)?;\n        std::fs::write(manifest, &manifest_bytes).map_err(|_| EngineError::Storage)?;\n        Ok(SafeExportArtifact {\n            export_path: out.to_path_buf(),\n            manifest_path: manifest.to_path_buf(),\n            manifest_sha256: sha256_hex,\n        })\n    }\n\n    /// Operator regenerate workflow per `dev/design/projections.md`\n    /// § Regenerate workflow. Drains in-flight projection work, then\n    /// truncates FTS5 + vec0 shadow rows, resets the projection cursor,\n    /// and lets the scheduler re-enqueue every canonical row. Durable\n    /// `projection_failures` audit rows are preserved per design. AC-044\n    /// + AC-063c.\n    pub fn rebuild_projections(&self) -> Result<RebuildReport, EngineError> {\n        self.ensure_open()?;\n        self.run_rebuild(true, RebuildKind::Projections)\n    }\n\n    /// Vec0-only variant of [`Engine::rebuild_projections`]. Leaves\n    /// FTS5 shadow content untouched; per recovery design,\n    /// `recover --rebuild-vec0` is the surface for vec0-only repair.\n    pub fn rebuild_vec0(&self) -> Result<RebuildReport, EngineError> {\n        self.ensure_open()?;\n        self.run_rebuild(false, RebuildKind::Vec0)\n    }\n\n    /// Phase 9 Pack B / AC-042 source trace. Returns the canonical-row\n    /// id set produced by `source_id`, ordered by `write_cursor`. Empty\n    /// string is not a valid `source_id`; rows with NULL `source_id`\n    /// are excluded from every result.\n    pub fn trace_source_ref(&self, source_id: &str) -> Result<TraceReport, EngineError> {\n        self.ensure_open()?;\n        if source_id.is_empty() {\n            return Err(EngineError::WriteValidation);\n        }\n        let connection = self.connection.lock().map_err(|_| EngineError::Storage)?;\n        let connection = connection.as_ref().ok_or(EngineError::Closing)?;\n\n        let mut events: Vec<TraceEvent> = Vec::new();\n        let mut nodes = connection\n            .prepare(\n                \"SELECT write_cursor, kind FROM canonical_nodes WHERE source_id = ?1\n                 ORDER BY write_cursor\",\n            )\n            .map_err(|_| EngineError::Storage)?;\n        let node_rows = nodes\n            .query_map([source_id], |row| {\n                Ok(TraceEvent {\n                    write_cursor: row.get::<_, i64>(0)? as u64,\n                    kind: row.get::<_, String>(1)?,\n                    table: \"canonical_nodes\",\n                })\n            })\n            .map_err(|_| EngineError::Storage)?;\n        for row in node_rows {\n            events.push(row.map_err(|_| EngineError::Storage)?);\n        }\n\n        let mut edges = connection\n            .prepare(\n                \"SELECT write_cursor, kind FROM canonical_edges WHERE source_id = ?1\n                 ORDER BY write_cursor\",\n            )\n            .map_err(|_| EngineError::Storage)?;\n        let edge_rows = edges\n            .query_map([source_id], |row| {\n                Ok(TraceEvent {\n                    write_cursor: row.get::<_, i64>(0)? as u64,\n                    kind: row.get::<_, String>(1)?,\n                    table: \"canonical_edges\",\n                })\n            })\n            .map_err(|_| EngineError::Storage)?;\n        for row in edge_rows {\n            events.push(row.map_err(|_| EngineError::Storage)?);\n        }\n\n        events.sort_by_key(|e| e.write_cursor);\n        Ok(TraceReport { source_ref: source_id.to_string(), events })\n    }\n\n    /// Phase 9 Pack B / AC-028a/b/c source excise. Drains in-flight\n    /// projection work, then deletes every canonical row attributable\n    /// to `source_id` plus the FTS5 + vec0 shadow rows that referenced\n    /// those cursors, and appends an audit row to the\n    /// `excise_source_audit` operational collection.\n    ///\n    /// Non-perturbation: rows from other sources (and rows with NULL\n    /// `source_id`) are untouched; the projection cursor is NOT reset\n    /// and no blanket projection rebuild is issued.\n    pub fn excise_source(&self, source_id: &str) -> Result<ExciseReport, EngineError> {\n        self.ensure_open()?;\n        if source_id.is_empty() {\n            return Err(EngineError::WriteValidation);\n        }\n\n        // Drain MUST succeed before the excise transaction. SQLite-WAL\n        // would otherwise allow a worker that already dequeued a job\n        // for an excised cursor to commit its INSERT into vec0 /\n        // _fathomdb_vector_rows after our DELETE releases the writer\n        // lock, leaving residue and breaking AC-028b. Surface the\n        // timeout instead of swallowing it (Pack A pattern).\n        self.projection_runtime.set_frozen(true);\n        let drain_result = self.drain(REBUILD_DRAIN_TIMEOUT_MS);\n        let outcome = drain_result.and_then(|()| self.excise_source_inner(source_id));\n        self.projection_runtime.set_frozen(false);\n        outcome\n    }\n\n    fn excise_source_inner(&self, source_id: &str) -> Result<ExciseReport, EngineError> {\n        let mut connection = self.connection.lock().map_err(|_| EngineError::Storage)?;\n        let connection = connection.as_mut().ok_or(EngineError::Closing)?;\n        let tx = connection.transaction().map_err(|_| EngineError::Storage)?;\n\n        // Collect the cursor sets up-front so we can targeted-delete\n        // shadow rows AND emit an accurate audit row in one txn.\n        let node_cursors: Vec<i64> = {\n            let mut stmt = tx\n                .prepare(\"SELECT write_cursor FROM canonical_nodes WHERE source_id = ?1\")\n                .map_err(|_| EngineError::Storage)?;\n            let rows = stmt\n                .query_map([source_id], |row| row.get::<_, i64>(0))\n                .map_err(|_| EngineError::Storage)?;\n            rows.collect::<rusqlite::Result<Vec<_>>>().map_err(|_| EngineError::Storage)?\n        };\n        let edge_cursors: Vec<i64> = {\n            let mut stmt = tx\n                .prepare(\"SELECT write_cursor FROM canonical_edges WHERE source_id = ?1\")\n                .map_err(|_| EngineError::Storage)?;\n            let rows = stmt\n                .query_map([source_id], |row| row.get::<_, i64>(0))\n                .map_err(|_| EngineError::Storage)?;\n            rows.collect::<rusqlite::Result<Vec<_>>>().map_err(|_| EngineError::Storage)?\n        };\n\n        let mut shadow_invalidated: u64 = 0;\n        for cursor in node_cursors.iter().chain(edge_cursors.iter()) {\n            shadow_invalidated = shadow_invalidated.saturating_add(\n                tx.execute(\"DELETE FROM search_index WHERE write_cursor = ?1\", [cursor])\n                    .map_err(|_| EngineError::Storage)? as u64,\n            );\n            // vec0 rowid is the canonical row's write_cursor (see\n            // `_fathomdb_vector_rows.write_cursor UNIQUE`).\n            shadow_invalidated = shadow_invalidated.saturating_add(\n                tx.execute(\"DELETE FROM vector_default WHERE rowid = ?1\", [cursor])\n                    .map_err(|_| EngineError::Storage)? as u64,\n            );\n            shadow_invalidated = shadow_invalidated.saturating_add(\n                tx.execute(\"DELETE FROM _fathomdb_vector_rows WHERE write_cursor = ?1\", [cursor])\n                    .map_err(|_| EngineError::Storage)? as u64,\n            );\n            shadow_invalidated = shadow_invalidated.saturating_add(\n                tx.execute(\n                    \"DELETE FROM _fathomdb_projection_terminal WHERE write_cursor = ?1\",\n                    [cursor],\n                )\n                .map_err(|_| EngineError::Storage)? as u64,\n            );\n        }\n\n        let nodes_excised = tx\n            .execute(\"DELETE FROM canonical_nodes WHERE source_id = ?1\", [source_id])\n            .map_err(|_| EngineError::Storage)? as u64;\n        let edges_excised = tx\n            .execute(\"DELETE FROM canonical_edges WHERE source_id = ?1\", [source_id])\n            .map_err(|_| EngineError::Storage)? as u64;\n\n        // AC-028a audit row: a single append on the\n        // `excise_source_audit` collection naming the excised source.\n        // `next_cursor` after a prior write holds the LAST committed cursor;\n        // mirror the vec writer pattern (load + 1, then store post-commit)\n        // so the audit row's `write_cursor` is strictly greater than every\n        // canonical row that preceded it.\n        let excised_at = SystemTime::now().duration_since(UNIX_EPOCH).unwrap_or_default().as_secs();\n        let payload = serde_json::json!({\n            \"source_id\": source_id,\n            \"excised_at\": excised_at,\n            \"nodes_excised\": nodes_excised,\n            \"edges_excised\": edges_excised,\n            \"projections_invalidated\": shadow_invalidated,\n        })\n        .to_string();\n        let audit_cursor = self.next_cursor.load(Ordering::SeqCst).saturating_add(1);\n        tx.execute(\n            \"INSERT INTO operational_mutations(\n                collection_name, record_key, op_kind, payload_json, schema_id, write_cursor\n             ) VALUES('excise_source_audit', ?1, 'append', ?2, NULL, ?3)\",\n            params![source_id, payload, audit_cursor],\n        )\n        .map_err(|_| EngineError::Storage)?;\n\n        tx.commit().map_err(|_| EngineError::Storage)?;\n        self.next_cursor.store(audit_cursor, Ordering::SeqCst);\n        Ok(ExciseReport {\n            source_ref: source_id.to_string(),\n            nodes_excised,\n            edges_excised,\n            projections_invalidated: shadow_invalidated,\n        })\n    }\n\n    fn run_rebuild(\n        &self,\n        include_fts: bool,\n        kind: RebuildKind,\n    ) -> Result<RebuildReport, EngineError> {\n        self.projection_runtime.set_frozen(true);\n        // Drain MUST succeed: rebuild_shadow_state truncates shadow rows,\n        // and SQLite-WAL allows a worker that already dequeued a job to\n        // commit its `INSERT OR IGNORE INTO _fathomdb_vector_rows / vec0`\n        // after our truncate releases the writer lock, leaving stale\n        // rows. Surfacing the timeout (instead of swallowing it) lets the\n        // operator retry rather than silently corrupt the rebuild.\n        let drain_result = self.drain(REBUILD_DRAIN_TIMEOUT_MS);\n        let result = drain_result.and_then(|()| self.rebuild_shadow_state(include_fts, kind));\n        self.projection_runtime.set_frozen(false);\n        result\n    }\n\n    fn rebuild_shadow_state(\n        &self,\n        include_fts: bool,\n        kind: RebuildKind,\n    ) -> Result<RebuildReport, EngineError> {\n        let mut connection = self.connection.lock().map_err(|_| EngineError::Storage)?;\n        let connection = connection.as_mut().ok_or(EngineError::Closing)?;\n        let tx = connection.transaction().map_err(|_| EngineError::Storage)?;\n        let mut rows_invalidated: u64 = 0;\n        if include_fts {\n            let n = tx.execute(\"DELETE FROM search_index\", []).map_err(|_| EngineError::Storage)?;\n            rows_invalidated = rows_invalidated.saturating_add(n as u64);\n        }\n        let n = tx.execute(\"DELETE FROM vector_default\", []).map_err(|_| EngineError::Storage)?;\n        rows_invalidated = rows_invalidated.saturating_add(n as u64);\n        let n = tx\n            .execute(\"DELETE FROM _fathomdb_vector_rows\", [])\n            .map_err(|_| EngineError::Storage)?;\n        rows_invalidated = rows_invalidated.saturating_add(n as u64);\n        let n = tx\n            .execute(\"DELETE FROM _fathomdb_projection_terminal\", [])\n            .map_err(|_| EngineError::Storage)?;\n        rows_invalidated = rows_invalidated.saturating_add(n as u64);\n        store_projection_cursor(&tx, 0).map_err(|_| EngineError::Storage)?;\n        let mut rows_rebuilt: u64 = 0;\n        if include_fts {\n            for row in canonical_node_rows(&tx).map_err(|_| EngineError::Storage)? {\n                tx.execute(\n                    \"INSERT INTO search_index(body, kind, write_cursor) VALUES(?1, ?2, ?3)\",\n                    params![row.body, row.kind, row.cursor],\n                )\n                .map_err(|_| EngineError::Storage)?;\n                rows_rebuilt = rows_rebuilt.saturating_add(1);\n            }\n        }\n        let projection_cursor_after =\n            load_projection_cursor(&tx).map_err(|_| EngineError::Storage)?;","numLines":300,"startLine":1776,"totalLines":3599}}}
