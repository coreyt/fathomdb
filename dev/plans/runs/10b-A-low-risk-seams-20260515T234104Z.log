{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0118QsXKPD7DzC9nHs3LNeVT","type":"tool_result","content":"1\t//! Operator CLI parser + verb runtime for `fathomdb`.\n2\t//!\n3\t//! Surface owned by `dev/interfaces/cli.md`. Phase 10a wires the parser\n4\t//! scaffold to real engine seam calls: `doctor check-integrity`,\n5\t//! `doctor safe-export`, `doctor trace`, `recover --rebuild-projections`,\n6\t//! `recover --rebuild-vec0`, and `recover --excise-source` invoke the\n7\t//! corresponding [`fathomdb::Engine`] methods and serialize the typed\n8\t//! report under the per-verb JSON discriminator.\n9\t\n10\tuse std::path::PathBuf;\n11\t\n12\tuse clap::{Args, Parser, Subcommand};\n13\tuse fathomdb::{\n14\t    CheckIntegrityOpts, CorruptionLocator, Engine, EngineError, EngineOpenError, ExciseReport,\n15\t    Finding, IntegrityReport, RebuildKind, RebuildReport, SafeExportArtifact, Section, TraceReport,\n16\t};\n17\tuse serde_json::{json, Value};\n18\t\n19\t/// Stable exit-code classes for the operator CLI.\n20\t///\n21\t/// Sourced from `dev/interfaces/cli.md` § Exit-code classes; meanings remain\n22\t/// load-bearing across `recover` + `doctor` outcomes.\n23\tpub mod exit_code {\n24\t    /// Successful completion with no findings that require a non-zero exit.\n25\t    pub const OK: i32 = 0;\n26\t\n27\t    /// `recover` completed only because lossy action was explicitly accepted.\n28\t    pub const RECOVERY_ACCEPTED_LOSS: i32 = 64;\n29\t\n30\t    /// Doctor / verification surface found actionable non-clean state.\n31\t    pub const DOCTOR_FOUND_ISSUES: i32 = 65;\n32\t\n33\t    /// Export / materialization failure on an artifact-producing doctor verb.\n34\t    pub const EXPORT_FAILURE: i32 = 66;\n35\t\n36\t    /// Unrecoverable command failure.\n37\t    pub const UNRECOVERABLE: i32 = 70;\n38\t\n39\t    /// Lock-held or equivalent precondition-blocked outcome.\n40\t    pub const LOCK_HELD: i32 = 71;\n41\t}\n42\t\n43\t/// Top-level CLI invocation.\n44\t#[derive(Debug, Parser)]\n45\t#[command(name = \"fathomdb\", version, about = \"FathomDB operator CLI\", long_about = None)]\n46\tpub struct Cli {\n47\t    #[command(subcommand)]\n48\t    pub command: Command,\n49\t}\n50\t\n51\t/// Root command verbs.\n52\t///\n53\t/// 0.6.0 ships exactly two roots per `dev/interfaces/cli.md` § Roots:\n54\t/// `recover` for lossy operator workflows and `doctor` for diagnostics.\n55\t#[derive(Debug, Subcommand)]\n56\tpub enum Command {\n57\t    /// Run a lossy / non-bit-preserving recovery workflow.\n58\t    Recover(RecoverArgs),\n59\t    /// Run an operator diagnostic verb.\n60\t    Doctor(DoctorArgs),\n61\t}\n62\t\n63\t/// Wrapper carrying the doctor verb table beneath the `doctor` root.\n64\t#[derive(Debug, Args)]\n65\tpub struct DoctorArgs {\n66\t    #[command(subcommand)]\n67\t    pub command: DoctorCommand,\n68\t}\n69\t\n70\t/// Argument set for the `recover` root command.\n71\t///\n72\t/// `--accept-data-loss` is declared on this parser only; doctor verbs reject\n73\t/// it as unknown.\n74\t#[derive(Debug, Args)]\n75\tpub struct RecoverArgs {\n76\t    /// Required acknowledgement that the workflow may discard data.\n77\t    #[arg(long)]\n78\t    pub accept_data_loss: bool,\n79\t\n80\t    /// Truncate the SQLite WAL after replay.\n81\t    #[arg(long)]\n82\t    pub truncate_wal: bool,\n83\t\n84\t    /// Rebuild the `vec0` shadow tables from canonical state.\n85\t    #[arg(long)]\n86\t    pub rebuild_vec0: bool,\n87\t\n88\t    /// Rebuild projection materializations.\n89\t    #[arg(long)]\n90\t    pub rebuild_projections: bool,\n91\t\n92\t    /// Excise the named source row from the canonical store.\n93\t    #[arg(long)]\n94\t    pub excise_source: Option<String>,\n95\t\n96\t    /// Purge a logical id and all rows it owns.\n97\t    #[arg(long)]\n98\t    pub purge_logical_id: Option<String>,\n99\t\n100\t    /// Restore a previously purged logical id from operator-supplied source.\n101\t    #[arg(long)]\n102\t    pub restore_logical_id: Option<String>,\n103\t\n104\t    /// Emit machine-readable JSON output.\n105\t    #[arg(long)]\n106\t    pub json: bool,\n107\t\n108\t    /// Path to the database file to recover.\n109\t    pub db_path: PathBuf,\n110\t}\n111\t\n112\t/// Doctor verb table per `dev/interfaces/cli.md` § Doctor verbs.\n113\t#[derive(Debug, Subcommand)]\n114\tpub enum DoctorCommand {\n115\t    /// Run a structural integrity check against the database.\n116\t    CheckIntegrity(CheckIntegrityArgs),\n117\t    /// Materialize a safe export of the database.\n118\t    SafeExport(SafeExportArgs),\n119\t    /// Verify the embedder identity recorded in the database.\n120\t    VerifyEmbedder(SimpleDoctorArgs),\n121\t    /// Trace the resolution chain for a given source reference.\n122\t    Trace(TraceArgs),\n123\t    /// Dump the canonical schema definition.\n124\t    DumpSchema(SimpleDoctorArgs),\n125\t    /// Dump per-table row counts.\n126\t    DumpRowCounts(SimpleDoctorArgs),\n127\t    /// Dump the response-cycle profile recorded by the engine.\n128\t    DumpProfile(SimpleDoctorArgs),\n129\t}\n130\t\n131\t/// Shared args for doctor verbs whose only options are `--json` and a\n132\t/// required `<db_path>` positional. `cli.md` § Output posture: `--json` is\n133\t/// the normative machine-readable contract on every verb.\n134\t#[derive(Debug, Args)]\n135\tpub struct SimpleDoctorArgs {\n136\t    /// Emit machine-readable JSON output.\n137\t    #[arg(long)]\n138\t    pub json: bool,\n139\t\n140\t    /// Path to the database file to inspect.\n141\t    pub db_path: PathBuf,\n142\t}\n143\t\n144\t/// Per-verb argument set for `doctor check-integrity`.\n145\t#[derive(Debug, Args)]\n146\tpub struct CheckIntegrityArgs {\n147\t    /// Run only the fast integrity probes.\n148\t    #[arg(long)]\n149\t    pub quick: bool,\n150\t\n151\t    /// Run the full per-page integrity sweep.\n152\t    #[arg(long)]\n153\t    pub full: bool,\n154\t\n155\t    /// Confirm round-trip equivalence between canonical + projection state.\n156\t    #[arg(long = \"round-trip\")]\n157\t    pub round_trip: bool,\n158\t\n159\t    /// Format human output.\n160\t    #[arg(long)]\n161\t    pub pretty: bool,\n162\t\n163\t    /// Emit machine-readable JSON output.\n164\t    #[arg(long)]\n165\t    pub json: bool,\n166\t\n167\t    /// Path to the database file to inspect.\n168\t    pub db_path: PathBuf,\n169\t}\n170\t\n171\t/// Per-verb argument set for `doctor safe-export`.\n172\t#[derive(Debug, Args)]\n173\tpub struct SafeExportArgs {\n174\t    /// Destination path for the exported artifact.\n175\t    pub out: PathBuf,\n176\t\n177\t    /// Optional manifest sidecar describing the exported artifact.\n178\t    #[arg(long)]\n179\t    pub manifest: Option<PathBuf>,\n180\t\n181\t    /// Emit machine-readable JSON output.\n182\t    #[arg(long)]\n183\t    pub json: bool,\n184\t\n185\t    /// Path to the database file to export.\n186\t    pub db_path: PathBuf,\n187\t}\n188\t\n189\t/// Per-verb argument set for `doctor trace`.\n190\t#[derive(Debug, Args)]\n191\tpub struct TraceArgs {\n192\t    /// Source reference to trace.\n193\t    #[arg(long = \"source-ref\")]\n194\t    pub source_ref: String,\n195\t\n196\t    /// Emit machine-readable JSON output.\n197\t    #[arg(long)]\n198\t    pub json: bool,\n199\t\n200\t    /// Path to the database file to inspect.\n201\t    pub db_path: PathBuf,\n202\t}\n203\t\n204\t/// Outcome classes that map to the stable exit-code matrix in\n205\t/// `dev/interfaces/cli.md` § Exit-code classes.\n206\t#[derive(Debug, Clone, Copy, PartialEq, Eq)]\n207\tpub enum CliOutcome {\n208\t    /// Verb completed successfully with no findings.\n209\t    Clean,\n210\t    /// Doctor / verification surface found actionable non-clean state.\n211\t    Findings,\n212\t    /// Export / materialization failure on an artifact-producing doctor verb.\n213\t    ExportFailure,\n214\t    /// `recover` completed only because lossy action was explicitly accepted.\n215\t    RecoveryAcceptedLoss,\n216\t    /// Lock-held or equivalent precondition-blocked outcome.\n217\t    LockHeld,\n218\t    /// Unrecoverable command failure.\n219\t    Unrecoverable,\n220\t}\n221\t\n222\t/// Map an outcome to the stable exit code defined in `cli.md`.\n223\t#[must_use]\n224\tpub fn outcome_to_exit_code(outcome: CliOutcome) -> i32 {\n225\t    match outcome {\n226\t        CliOutcome::Clean => exit_code::OK,\n227\t        CliOutcome::Findings => exit_code::DOCTOR_FOUND_ISSUES,\n228\t        CliOutcome::ExportFailure => exit_code::EXPORT_FAILURE,\n229\t        CliOutcome::RecoveryAcceptedLoss => exit_code::RECOVERY_ACCEPTED_LOSS,\n230\t        CliOutcome::LockHeld => exit_code::LOCK_HELD,\n231\t        CliOutcome::Unrecoverable => exit_code::UNRECOVERABLE,\n232\t    }\n233\t}\n234\t\n235\t/// Map an [`EngineError`] to the [`CliOutcome`] class per\n236\t/// `dev/interfaces/cli.md` § Error to exit-code mapping.\n237\t#[must_use]\n238\tpub fn engine_error_to_outcome(err: &EngineError) -> CliOutcome {\n239\t    match err {\n240\t        EngineError::Closing => CliOutcome::LockHeld,\n241\t        _ => CliOutcome::Unrecoverable,\n242\t    }\n243\t}\n244\t\n245\t/// Map an [`EngineOpenError`] to the [`CliOutcome`] class per\n246\t/// `dev/interfaces/cli.md` § Error to exit-code mapping.\n247\t#[must_use]\n248\tpub fn engine_open_error_to_outcome(err: &EngineOpenError) -> CliOutcome {\n249\t    match err {\n250\t        EngineOpenError::DatabaseLocked { .. } => CliOutcome::LockHeld,\n251\t        _ => CliOutcome::Unrecoverable,\n252\t    }\n253\t}\n254\t\n255\t/// Run a parsed CLI command.\n256\t///\n257\t/// Phase 10a wires the six landed engine seams. The CLI opens the engine\n258\t/// at the verb's `<db_path>`, calls the seam, serializes the typed report\n259\t/// under a `verb`-discriminated JSON envelope, and maps `EngineError` to\n260\t/// the stable exit-code matrix.\n261\t///\n262\t/// `recover` invoked without `--accept-data-loss` is refused at the CLI\n263\t/// layer (no engine call) per `dev/design/recovery.md`: recovery is the\n264\t/// only lossy root and must not proceed without explicit acknowledgement.\n265\t#[must_use]\n266\tpub fn run(cli: Cli) -> i32 {\n267\t    match cli.command {\n268\t        Command::Recover(args) => run_recover(args),\n269\t        Command::Doctor(d) => run_doctor(d.command),\n270\t    }\n271\t}\n272\t\n273\tfn run_recover(args: RecoverArgs) -> i32 {\n274\t    if !args.accept_data_loss {\n275\t        println!(\n276\t            r#\"{{\"status\":\"refused\",\"verb\":\"recover\",\"code\":\"E_RECOVER_REQUIRES_ACCEPT_DATA_LOSS\"}}\"#\n277\t        );\n278\t        return exit_code::UNRECOVERABLE;\n279\t    }\n280\t\n281\t    // Pick the bound sub-action. Only one is wired in Phase 10a per\n282\t    // call; if multiple are passed, dispatch the first landed seam in\n283\t    // declaration order. Unsupported recover sub-flags (`--truncate-wal`,\n284\t    // `--purge-logical-id`, `--restore-logical-id`) fall through to a\n285\t    // not-implemented refusal until their engine seams land.\n286\t    if args.rebuild_projections {\n287\t        return wire_recover(&args.db_path, \"rebuild-projections\", |e| {\n288\t            e.rebuild_projections().map(|r| rebuild_report_json(\"rebuild-projections\", &r))\n289\t        });\n290\t    }\n291\t    if args.rebuild_vec0 {\n292\t        return wire_recover(&args.db_path, \"rebuild-vec0\", |e| {\n293\t            e.rebuild_vec0().map(|r| rebuild_report_json(\"rebuild-vec0\", &r))\n294\t        });\n295\t    }\n296\t    if let Some(source_id) = args.excise_source.as_deref() {\n297\t        return wire_recover(&args.db_path, \"excise-source\", |e| {\n298\t            e.excise_source(source_id).map(|r| excise_report_json(&r))\n299\t        });\n300\t    }\n301\t\n302\t    // No bound sub-action selected → stub.\n303\t    println!(r#\"{{\"status\":\"not_implemented\",\"verb\":\"recover\"}}\"#);\n304\t    exit_code::UNRECOVERABLE\n305\t}\n306\t\n307\tfn run_doctor(cmd: DoctorCommand) -> i32 {\n308\t    match cmd {\n309\t        DoctorCommand::CheckIntegrity(args) => {\n310\t            let opts = CheckIntegrityOpts {\n311\t                quick: args.quick,\n312\t                full: args.full,\n313\t                round_trip: args.round_trip,\n314\t            };\n315\t            run_doctor_verb(&args.db_path, \"check-integrity\", |e| {\n316\t                e.check_integrity(opts).map(|r| integrity_report_outcome(&r))\n317\t            })\n318\t        }\n319\t        DoctorCommand::SafeExport(args) => {\n320\t            let manifest = args.manifest.clone().unwrap_or_else(|| {\n321\t                let mut p = args.out.clone();\n322\t                let name = p\n323\t                    .file_name()\n324\t                    .map(|s| s.to_string_lossy().into_owned())\n325\t                    .unwrap_or_else(|| \"export\".to_string());\n326\t                p.set_file_name(format!(\"{name}.manifest.json\"));\n327\t                p\n328\t            });\n329\t            run_doctor_verb_with_error_outcome(\n330\t                &args.db_path,\n331\t                \"safe-export\",\n332\t                CliOutcome::ExportFailure,\n333\t                |e| {\n334\t                    e.safe_export(&args.out, &manifest)\n335\t                        .map(|r| (safe_export_json(&r), CliOutcome::Clean))\n336\t                },\n337\t            )\n338\t        }\n339\t        DoctorCommand::Trace(args) => run_doctor_verb(&args.db_path, \"trace\", |e| {\n340\t            e.trace_source_ref(&args.source_ref).map(|r| (trace_report_json(&r), CliOutcome::Clean))\n341\t        }),\n342\t        DoctorCommand::VerifyEmbedder(args) => stub_doctor(&args.db_path, \"verify-embedder\"),\n343\t        DoctorCommand::DumpSchema(args) => stub_doctor(&args.db_path, \"dump-schema\"),\n344\t        DoctorCommand::DumpRowCounts(args) => stub_doctor(&args.db_path, \"dump-row-counts\"),\n345\t        DoctorCommand::DumpProfile(args) => stub_doctor(&args.db_path, \"dump-profile\"),\n346\t    }\n347\t}\n348\t\n349\t/// Stub body for doctor verbs whose engine seam has not landed yet. Opens\n350\t/// the engine (so lock-held / open-error classes still surface) and then\n351\t/// emits a `not_implemented` JSON envelope. Returns `UNRECOVERABLE`\n352\t/// (matches the Phase 9 surface-stub posture).\n353\tfn stub_doctor(db_path: &std::path::Path, verb: &str) -> i32 {\n354\t    match Engine::open(db_path.to_path_buf()) {\n355\t        Ok(_opened) => {\n356\t            println!(r#\"{{\"status\":\"not_implemented\",\"verb\":\"{verb}\"}}\"#);\n357\t            exit_code::UNRECOVERABLE\n358\t        }\n359\t        Err(err) => emit_engine_open_error(verb, &err),\n360\t    }\n361\t}\n362\t\n363\t/// Open the engine, invoke `f`, print the resulting JSON value, and map\n364\t/// the outcome to an exit code. The closure returns `(json, outcome)`.\n365\tfn run_doctor_verb<F>(db_path: &std::path::Path, verb: &str, f: F) -> i32\n366\twhere\n367\t    F: FnOnce(&Engine) -> Result<(Value, CliOutcome), EngineError>,\n368\t{\n369\t    run_doctor_verb_inner(db_path, verb, None, f)\n370\t}\n371\t\n372\t/// Variant that overrides the `EngineError` → outcome mapping for verbs\n373\t/// with a dedicated failure class (per `cli.md § Error → exit-code\n374\t/// mapping`). Example: `doctor safe-export` maps engine errors to\n375\t/// `ExportFailure` (66), not the default `Unrecoverable` (70).\n376\tfn run_doctor_verb_with_error_outcome<F>(\n377\t    db_path: &std::path::Path,\n378\t    verb: &str,\n379\t    error_outcome: CliOutcome,\n380\t    f: F,\n381\t) -> i32\n382\twhere\n383\t    F: FnOnce(&Engine) -> Result<(Value, CliOutcome), EngineError>,\n384\t{\n385\t    run_doctor_verb_inner(db_path, verb, Some(error_outcome), f)\n386\t}\n387\t\n388\tfn run_doctor_verb_inner<F>(\n389\t    db_path: &std::path::Path,\n390\t    verb: &str,\n391\t    error_outcome: Option<CliOutcome>,\n392\t    f: F,\n393\t) -> i32\n394\twhere\n395\t    F: FnOnce(&Engine) -> Result<(Value, CliOutcome), EngineError>,\n396\t{\n397\t    let opened = match Engine::open(db_path.to_path_buf()) {\n398\t        Ok(o) => o,\n399\t        Err(err) => return emit_engine_open_error(verb, &err),\n400\t    };\n401\t    match f(&opened.engine) {\n402\t        Ok((value, outcome)) => {\n403\t            println!(\"{value}\");\n404\t            outcome_to_exit_code(outcome)\n405\t        }\n406\t        Err(err) => match error_outcome {\n407\t            Some(outcome) => emit_engine_error_with_outcome(verb, &err, outcome),\n408\t            None => emit_engine_error(verb, &err),\n409\t        },\n410\t    }\n411\t}\n412\t\n413\t/// Open the engine for `recover`, invoke `f`, print the JSON, and map the\n414\t/// outcome to `RECOVERY_ACCEPTED_LOSS` (64) on success.\n415\tfn wire_recover<F>(db_path: &std::path::Path, sub_verb: &str, f: F) -> i32\n416\twhere\n417\t    F: FnOnce(&Engine) -> Result<Value, EngineError>,\n418\t{\n419\t    let opened = match Engine::open(db_path.to_path_buf()) {\n420\t        Ok(o) => o,\n421\t        Err(err) => return emit_engine_open_error(sub_verb, &err),\n422\t    };\n423\t    match f(&opened.engine) {\n424\t        Ok(value) => {\n425\t            println!(\"{value}\");\n426\t            outcome_to_exit_code(CliOutcome::RecoveryAcceptedLoss)\n427\t        }\n428\t        Err(err) => emit_engine_error(sub_verb, &err),\n429\t    }\n430\t}\n431\t\n432\tfn emit_engine_error(verb: &str, err: &EngineError) -> i32 {\n433\t    emit_engine_error_with_outcome(verb, err, engine_error_to_outcome(err))\n434\t}\n435\t\n436\tfn emit_engine_error_with_outcome(verb: &str, err: &EngineError, outcome: CliOutcome) -> i32 {\n437\t    let payload = json!({\n438\t        \"status\": \"error\",\n439\t        \"verb\": verb,\n440\t        \"code\": engine_error_code(err),\n441\t        \"detail\": err.to_string(),\n442\t    });\n443\t    println!(\"{payload}\");\n444\t    outcome_to_exit_code(outcome)\n445\t}\n446\t\n447\tfn emit_engine_open_error(verb: &str, err: &EngineOpenError) -> i32 {\n448\t    let outcome = engine_open_error_to_outcome(err);\n449\t    let payload = json!({\n450\t        \"status\": \"error\",\n451\t        \"verb\": verb,\n452\t        \"code\": engine_open_error_code(err),\n453\t        \"detail\": err.to_string(),\n454\t    });\n455\t    println!(\"{payload}\");\n456\t    outcome_to_exit_code(outcome)\n457\t}\n458\t\n459\tfn engine_error_code(err: &EngineError) -> &'static str {\n460\t    match err {\n461\t        EngineError::Storage => \"StorageError\",\n462\t        EngineError::Projection => \"ProjectionError\",\n463\t        EngineError::Vector => \"VectorError\",\n464\t        EngineError::Embedder => \"EmbedderError\",\n465\t        EngineError::EmbedderNotConfigured => \"EmbedderNotConfiguredError\",\n466\t        EngineError::KindNotVectorIndexed => \"KindNotVectorIndexedError\",\n467\t        EngineError::EmbedderDimensionMismatch { .. } => \"EmbedderDimensionMismatchError\",\n468\t        EngineError::Scheduler => \"SchedulerError\",\n469\t        EngineError::OpStore => \"OpStoreError\",\n470\t        EngineError::WriteValidation => \"WriteValidationError\",\n471\t        EngineError::SchemaValidation => \"SchemaValidationError\",\n472\t        EngineError::Overloaded => \"OverloadedError\",\n473\t        EngineError::Closing => \"ClosingError\",\n474\t    }\n475\t}\n476\t\n477\tfn engine_open_error_code(err: &EngineOpenError) -> &'static str {\n478\t    match err {\n479\t        EngineOpenError::DatabaseLocked { .. } => \"DatabaseLockedError\",\n480\t        EngineOpenError::Corruption(_) => \"CorruptionError\",\n481\t        EngineOpenError::IncompatibleSchemaVersion { .. } => \"IncompatibleSchemaVersionError\",\n482\t        EngineOpenError::MigrationError { .. } => \"MigrationError\",\n483\t        EngineOpenError::EmbedderIdentityMismatch { .. } => \"EmbedderIdentityMismatchError\",\n484\t        EngineOpenError::EmbedderDimensionMismatch { .. } => \"EmbedderDimensionMismatchError\",\n485\t        EngineOpenError::Io { .. } => \"IoError\",\n486\t    }\n487\t}\n488\t\n489\t// ---- JSON serializers for engine report types ----\n490\t\n491\tfn integrity_report_outcome(report: &IntegrityReport) -> (Value, CliOutcome) {\n492\t    let any_findings = matches!(report.physical, Section::Findings(_))\n493\t        || matches!(report.logical, Section::Findings(_))\n494\t        || matches!(report.semantic, Section::Findings(_));\n495\t    let body = json!({\n496\t        \"verb\": \"check-integrity\",\n497\t        \"physical\": section_json(&report.physical),\n498\t        \"logical\": section_json(&report.logical),\n499\t        \"semantic\": section_json(&report.semantic),\n500\t    });\n501\t    let outcome = if any_findings { CliOutcome::Findings } else { CliOutcome::Clean };\n502\t    (body, outcome)\n503\t}\n504\t\n505\tfn section_json(section: &Section) -> Value {\n506\t    match section {\n507\t        Section::Clean => json!({ \"status\": \"clean\", \"findings\": [] }),\n508\t        Section::Findings(findings) => json!({\n509\t            \"status\": \"findings\",\n510\t            \"findings\": findings.iter().map(finding_json).collect::<Vec<_>>(),\n511\t        }),\n512\t    }\n513\t}\n514\t\n515\tfn finding_json(f: &Finding) -> Value {\n516\t    json!({\n517\t        \"code\": f.code,\n518\t        \"stage\": f.stage,\n519\t        \"locator\": locator_json(&f.locator),\n520\t        \"doc_anchor\": f.doc_anchor,\n521\t        \"detail\": f.detail,\n522\t    })\n523\t}\n524\t\n525\tfn locator_json(loc: &CorruptionLocator) -> Value {\n526\t    match loc {\n527\t        CorruptionLocator::FileOffset { offset } => {\n528\t            json!({ \"kind\": \"file_offset\", \"offset\": offset })\n529\t        }\n530\t        CorruptionLocator::PageId { page } => json!({ \"kind\": \"page_id\", \"page\": page }),\n531\t        CorruptionLocator::TableRow { table, rowid } => {\n532\t            json!({ \"kind\": \"table_row\", \"table\": table, \"rowid\": rowid })\n533\t        }\n534\t        CorruptionLocator::Vec0ShadowRow { partition, rowid } => {\n535\t            json!({ \"kind\": \"vec0_shadow_row\", \"partition\": partition, \"rowid\": rowid })\n536\t        }\n537\t        CorruptionLocator::MigrationStep { from, to } => {\n538\t            json!({ \"kind\": \"migration_step\", \"from\": from, \"to\": to })\n539\t        }\n540\t        CorruptionLocator::OpaqueSqliteError { sqlite_extended_code } => {\n541\t            json!({\n542\t                \"kind\": \"opaque_sqlite_error\",\n543\t                \"sqlite_extended_code\": sqlite_extended_code,\n544\t            })\n545\t        }\n546\t    }\n547\t}\n548\t\n549\tfn safe_export_json(a: &SafeExportArtifact) -> Value {\n550\t    json!({\n551\t        \"verb\": \"safe-export\",\n552\t        \"export_path\": a.export_path.to_string_lossy(),\n553\t        \"manifest_path\": a.manifest_path.to_string_lossy(),\n554\t        \"manifest_sha256\": a.manifest_sha256,\n555\t    })\n556\t}\n557\t\n558\tfn trace_report_json(t: &TraceReport) -> Value {\n559\t    json!({\n560\t        \"verb\": \"trace\",\n561\t        \"source_ref\": t.source_ref,\n562\t        \"events\": t.events.iter().map(|e| json!({\n563\t            \"write_cursor\": e.write_cursor,\n564\t            \"kind\": e.kind,\n565\t            \"table\": e.table,\n566\t        })).collect::<Vec<_>>(),\n567\t    })\n568\t}\n569\t\n570\tfn rebuild_report_json(verb: &'static str, r: &RebuildReport) -> Value {\n571\t    let kind = match r.kind {\n572\t        RebuildKind::Projections => \"projections\",\n573\t        RebuildKind::Vec0 => \"vec0\",\n574\t    };\n575\t    json!({\n576\t        \"verb\": verb,\n577\t        \"kind\": kind,\n578\t        \"rows_invalidated\": r.rows_invalidated,\n579\t        \"rows_rebuilt\": r.rows_rebuilt,\n580\t        \"projection_cursor_after\": r.projection_cursor_after,\n581\t    })\n582\t}\n583\t\n584\tfn excise_report_json(r: &ExciseReport) -> Value {\n585\t    json!({\n586\t        \"verb\": \"excise-source\",\n587\t        \"source_ref\": r.source_ref,\n588\t        \"nodes_excised\": r.nodes_excised,\n589\t        \"edges_excised\": r.edges_excised,\n590\t        \"projections_invalidated\": r.projections_invalidated,\n591\t    })\n592\t}\n593\t\n594\t#[cfg(test)]\n595\tmod tests {\n596\t    use super::*;\n597\t\n598\t    #[test]\n599\t    fn outcome_mapping_covers_cli_md_exit_classes() {\n600\t        assert_eq!(outcome_to_exit_code(CliOutcome::Clean), 0);\n601\t        assert_eq!(outcome_to_exit_code(CliOutcome::RecoveryAcceptedLoss), 64);\n602\t        assert_eq!(outcome_to_exit_code(CliOutcome::Findings), 65);\n603\t        assert_eq!(outcome_to_exit_code(CliOutcome::ExportFailure), 66);\n604\t        assert_eq!(outcome_to_exit_code(CliOutcome::Unrecoverable), 70);\n605\t        assert_eq!(outcome_to_exit_code(CliOutcome::LockHeld), 71);\n606\t    }\n607\t\n608\t    #[test]\n609\t    fn engine_error_storage_maps_to_unrecoverable() {\n610\t        assert_eq!(engine_error_to_outcome(&EngineError::Storage), CliOutcome::Unrecoverable);\n611\t        assert_eq!(engine_error_to_outcome(&EngineError::Closing), CliOutcome::LockHeld);\n612\t    }\n613\t\n614\t    #[test]\n615\t    fn engine_open_database_locked_maps_to_lock_held() {\n616\t        let err = EngineOpenError::DatabaseLocked { holder_pid: Some(1234) };\n617\t        assert_eq!(engine_open_error_to_outcome(&err), CliOutcome::LockHeld);\n618\t    }\n619\t}\n620\t"}]},"parent_tool_use_id":null,"session_id":"6045b345-74e5-4485-9471-2a1561990851","uuid":"fefc924a-11ea-49a4-bf0b-d91c7f999f98","timestamp":"2026-05-15T23:41:30.152Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-10b-A-low-risk-seams-20260515T234104Z/src/rust/crates/fathomdb-cli/src/lib.rs","content":"//! Operator CLI parser + verb runtime for `fathomdb`.\n//!\n//! Surface owned by `dev/interfaces/cli.md`. Phase 10a wires the parser\n//! scaffold to real engine seam calls: `doctor check-integrity`,\n//! `doctor safe-export`, `doctor trace`, `recover --rebuild-projections`,\n//! `recover --rebuild-vec0`, and `recover --excise-source` invoke the\n//! corresponding [`fathomdb::Engine`] methods and serialize the typed\n//! report under the per-verb JSON discriminator.\n\nuse std::path::PathBuf;\n\nuse clap::{Args, Parser, Subcommand};\nuse fathomdb::{\n    CheckIntegrityOpts, CorruptionLocator, Engine, EngineError, EngineOpenError, ExciseReport,\n    Finding, IntegrityReport, RebuildKind, RebuildReport, SafeExportArtifact, Section, TraceReport,\n};\nuse serde_json::{json, Value};\n\n/// Stable exit-code classes for the operator CLI.\n///\n/// Sourced from `dev/interfaces/cli.md` § Exit-code classes; meanings remain\n/// load-bearing across `recover` + `doctor` outcomes.\npub mod exit_code {\n    /// Successful completion with no findings that require a non-zero exit.\n    pub const OK: i32 = 0;\n\n    /// `recover` completed only because lossy action was explicitly accepted.\n    pub const RECOVERY_ACCEPTED_LOSS: i32 = 64;\n\n    /// Doctor / verification surface found actionable non-clean state.\n    pub const DOCTOR_FOUND_ISSUES: i32 = 65;\n\n    /// Export / materialization failure on an artifact-producing doctor verb.\n    pub const EXPORT_FAILURE: i32 = 66;\n\n    /// Unrecoverable command failure.\n    pub const UNRECOVERABLE: i32 = 70;\n\n    /// Lock-held or equivalent precondition-blocked outcome.\n    pub const LOCK_HELD: i32 = 71;\n}\n\n/// Top-level CLI invocation.\n#[derive(Debug, Parser)]\n#[command(name = \"fathomdb\", version, about = \"FathomDB operator CLI\", long_about = None)]\npub struct Cli {\n    #[command(subcommand)]\n    pub command: Command,\n}\n\n/// Root command verbs.\n///\n/// 0.6.0 ships exactly two roots per `dev/interfaces/cli.md` § Roots:\n/// `recover` for lossy operator workflows and `doctor` for diagnostics.\n#[derive(Debug, Subcommand)]\npub enum Command {\n    /// Run a lossy / non-bit-preserving recovery workflow.\n    Recover(RecoverArgs),\n    /// Run an operator diagnostic verb.\n    Doctor(DoctorArgs),\n}\n\n/// Wrapper carrying the doctor verb table beneath the `doctor` root.\n#[derive(Debug, Args)]\npub struct DoctorArgs {\n    #[command(subcommand)]\n    pub command: DoctorCommand,\n}\n\n/// Argument set for the `recover` root command.\n///\n/// `--accept-data-loss` is declared on this parser only; doctor verbs reject\n/// it as unknown.\n#[derive(Debug, Args)]\npub struct RecoverArgs {\n    /// Required acknowledgement that the workflow may discard data.\n    #[arg(long)]\n    pub accept_data_loss: bool,\n\n    /// Truncate the SQLite WAL after replay.\n    #[arg(long)]\n    pub truncate_wal: bool,\n\n    /// Rebuild the `vec0` shadow tables from canonical state.\n    #[arg(long)]\n    pub rebuild_vec0: bool,\n\n    /// Rebuild projection materializations.\n    #[arg(long)]\n    pub rebuild_projections: bool,\n\n    /// Excise the named source row from the canonical store.\n    #[arg(long)]\n    pub excise_source: Option<String>,\n\n    /// Purge a logical id and all rows it owns.\n    #[arg(long)]\n    pub purge_logical_id: Option<String>,\n\n    /// Restore a previously purged logical id from operator-supplied source.\n    #[arg(long)]\n    pub restore_logical_id: Option<String>,\n\n    /// Emit machine-readable JSON output.\n    #[arg(long)]\n    pub json: bool,\n\n    /// Path to the database file to recover.\n    pub db_path: PathBuf,\n}\n\n/// Doctor verb table per `dev/interfaces/cli.md` § Doctor verbs.\n#[derive(Debug, Subcommand)]\npub enum DoctorCommand {\n    /// Run a structural integrity check against the database.\n    CheckIntegrity(CheckIntegrityArgs),\n    /// Materialize a safe export of the database.\n    SafeExport(SafeExportArgs),\n    /// Verify the embedder identity recorded in the database.\n    VerifyEmbedder(SimpleDoctorArgs),\n    /// Trace the resolution chain for a given source reference.\n    Trace(TraceArgs),\n    /// Dump the canonical schema definition.\n    DumpSchema(SimpleDoctorArgs),\n    /// Dump per-table row counts.\n    DumpRowCounts(SimpleDoctorArgs),\n    /// Dump the response-cycle profile recorded by the engine.\n    DumpProfile(SimpleDoctorArgs),\n}\n\n/// Shared args for doctor verbs whose only options are `--json` and a\n/// required `<db_path>` positional. `cli.md` § Output posture: `--json` is\n/// the normative machine-readable contract on every verb.\n#[derive(Debug, Args)]\npub struct SimpleDoctorArgs {\n    /// Emit machine-readable JSON output.\n    #[arg(long)]\n    pub json: bool,\n\n    /// Path to the database file to inspect.\n    pub db_path: PathBuf,\n}\n\n/// Per-verb argument set for `doctor check-integrity`.\n#[derive(Debug, Args)]\npub struct CheckIntegrityArgs {\n    /// Run only the fast integrity probes.\n    #[arg(long)]\n    pub quick: bool,\n\n    /// Run the full per-page integrity sweep.\n    #[arg(long)]\n    pub full: bool,\n\n    /// Confirm round-trip equivalence between canonical + projection state.\n    #[arg(long = \"round-trip\")]\n    pub round_trip: bool,\n\n    /// Format human output.\n    #[arg(long)]\n    pub pretty: bool,\n\n    /// Emit machine-readable JSON output.\n    #[arg(long)]\n    pub json: bool,\n\n    /// Path to the database file to inspect.\n    pub db_path: PathBuf,\n}\n\n/// Per-verb argument set for `doctor safe-export`.\n#[derive(Debug, Args)]\npub struct SafeExportArgs {\n    /// Destination path for the exported artifact.\n    pub out: PathBuf,\n\n    /// Optional manifest sidecar describing the exported artifact.\n    #[arg(long)]\n    pub manifest: Option<PathBuf>,\n\n    /// Emit machine-readable JSON output.\n    #[arg(long)]\n    pub json: bool,\n\n    /// Path to the database file to export.\n    pub db_path: PathBuf,\n}\n\n/// Per-verb argument set for `doctor trace`.\n#[derive(Debug, Args)]\npub struct TraceArgs {\n    /// Source reference to trace.\n    #[arg(long = \"source-ref\")]\n    pub source_ref: String,\n\n    /// Emit machine-readable JSON output.\n    #[arg(long)]\n    pub json: bool,\n\n    /// Path to the database file to inspect.\n    pub db_path: PathBuf,\n}\n\n/// Outcome classes that map to the stable exit-code matrix in\n/// `dev/interfaces/cli.md` § Exit-code classes.\n#[derive(Debug, Clone, Copy, PartialEq, Eq)]\npub enum CliOutcome {\n    /// Verb completed successfully with no findings.\n    Clean,\n    /// Doctor / verification surface found actionable non-clean state.\n    Findings,\n    /// Export / materialization failure on an artifact-producing doctor verb.\n    ExportFailure,\n    /// `recover` completed only because lossy action was explicitly accepted.\n    RecoveryAcceptedLoss,\n    /// Lock-held or equivalent precondition-blocked outcome.\n    LockHeld,\n    /// Unrecoverable command failure.\n    Unrecoverable,\n}\n\n/// Map an outcome to the stable exit code defined in `cli.md`.\n#[must_use]\npub fn outcome_to_exit_code(outcome: CliOutcome) -> i32 {\n    match outcome {\n        CliOutcome::Clean => exit_code::OK,\n        CliOutcome::Findings => exit_code::DOCTOR_FOUND_ISSUES,\n        CliOutcome::ExportFailure => exit_code::EXPORT_FAILURE,\n        CliOutcome::RecoveryAcceptedLoss => exit_code::RECOVERY_ACCEPTED_LOSS,\n        CliOutcome::LockHeld => exit_code::LOCK_HELD,\n        CliOutcome::Unrecoverable => exit_code::UNRECOVERABLE,\n    }\n}\n\n/// Map an [`EngineError`] to the [`CliOutcome`] class per\n/// `dev/interfaces/cli.md` § Error to exit-code mapping.\n#[must_use]\npub fn engine_error_to_outcome(err: &EngineError) -> CliOutcome {\n    match err {\n        EngineError::Closing => CliOutcome::LockHeld,\n        _ => CliOutcome::Unrecoverable,\n    }\n}\n\n/// Map an [`EngineOpenError`] to the [`CliOutcome`] class per\n/// `dev/interfaces/cli.md` § Error to exit-code mapping.\n#[must_use]\npub fn engine_open_error_to_outcome(err: &EngineOpenError) -> CliOutcome {\n    match err {\n        EngineOpenError::DatabaseLocked { .. } => CliOutcome::LockHeld,\n        _ => CliOutcome::Unrecoverable,\n    }\n}\n\n/// Run a parsed CLI command.\n///\n/// Phase 10a wires the six landed engine seams. The CLI opens the engine\n/// at the verb's `<db_path>`, calls the seam, serializes the typed report\n/// under a `verb`-discriminated JSON envelope, and maps `EngineError` to\n/// the stable exit-code matrix.\n///\n/// `recover` invoked without `--accept-data-loss` is refused at the CLI\n/// layer (no engine call) per `dev/design/recovery.md`: recovery is the\n/// only lossy root and must not proceed without explicit acknowledgement.\n#[must_use]\npub fn run(cli: Cli) -> i32 {\n    match cli.command {\n        Command::Recover(args) => run_recover(args),\n        Command::Doctor(d) => run_doctor(d.command),\n    }\n}\n\nfn run_recover(args: RecoverArgs) -> i32 {\n    if !args.accept_data_loss {\n        println!(\n            r#\"{{\"status\":\"refused\",\"verb\":\"recover\",\"code\":\"E_RECOVER_REQUIRES_ACCEPT_DATA_LOSS\"}}\"#\n        );\n        return exit_code::UNRECOVERABLE;\n    }\n\n    // Pick the bound sub-action. Only one is wired in Phase 10a per\n    // call; if multiple are passed, dispatch the first landed seam in\n    // declaration order. Unsupported recover sub-flags (`--truncate-wal`,\n    // `--purge-logical-id`, `--restore-logical-id`) fall through to a\n    // not-implemented refusal until their engine seams land.\n    if args.rebuild_projections {\n        return wire_recover(&args.db_path, \"rebuild-projections\", |e| {\n            e.rebuild_projections().map(|r| rebuild_report_json(\"rebuild-projections\", &r))\n        });\n    }\n    if args.rebuild_vec0 {\n        return wire_recover(&args.db_path, \"rebuild-vec0\", |e| {\n            e.rebuild_vec0().map(|r| rebuild_report_json(\"rebuild-vec0\", &r))\n        });\n    }\n    if let Some(source_id) = args.excise_source.as_deref() {\n        return wire_recover(&args.db_path, \"excise-source\", |e| {\n            e.excise_source(source_id).map(|r| excise_report_json(&r))\n        });\n    }\n\n    // No bound sub-action selected → stub.\n    println!(r#\"{{\"status\":\"not_implemented\",\"verb\":\"recover\"}}\"#);\n    exit_code::UNRECOVERABLE\n}\n\nfn run_doctor(cmd: DoctorCommand) -> i32 {\n    match cmd {\n        DoctorCommand::CheckIntegrity(args) => {\n            let opts = CheckIntegrityOpts {\n                quick: args.quick,\n                full: args.full,\n                round_trip: args.round_trip,\n            };\n            run_doctor_verb(&args.db_path, \"check-integrity\", |e| {\n                e.check_integrity(opts).map(|r| integrity_report_outcome(&r))\n            })\n        }\n        DoctorCommand::SafeExport(args) => {\n            let manifest = args.manifest.clone().unwrap_or_else(|| {\n                let mut p = args.out.clone();\n                let name = p\n                    .file_name()\n                    .map(|s| s.to_string_lossy().into_owned())\n                    .unwrap_or_else(|| \"export\".to_string());\n                p.set_file_name(format!(\"{name}.manifest.json\"));\n                p\n            });\n            run_doctor_verb_with_error_outcome(\n                &args.db_path,\n                \"safe-export\",\n                CliOutcome::ExportFailure,\n                |e| {\n                    e.safe_export(&args.out, &manifest)\n                        .map(|r| (safe_export_json(&r), CliOutcome::Clean))\n                },\n            )\n        }\n        DoctorCommand::Trace(args) => run_doctor_verb(&args.db_path, \"trace\", |e| {\n            e.trace_source_ref(&args.source_ref).map(|r| (trace_report_json(&r), CliOutcome::Clean))\n        }),\n        DoctorCommand::VerifyEmbedder(args) => stub_doctor(&args.db_path, \"verify-embedder\"),\n        DoctorCommand::DumpSchema(args) => stub_doctor(&args.db_path, \"dump-schema\"),\n        DoctorCommand::DumpRowCounts(args) => stub_doctor(&args.db_path, \"dump-row-counts\"),\n        DoctorCommand::DumpProfile(args) => stub_doctor(&args.db_path, \"dump-profile\"),\n    }\n}\n\n/// Stub body for doctor verbs whose engine seam has not landed yet. Opens\n/// the engine (so lock-held / open-error classes still surface) and then\n/// emits a `not_implemented` JSON envelope. Returns `UNRECOVERABLE`\n/// (matches the Phase 9 surface-stub posture).\nfn stub_doctor(db_path: &std::path::Path, verb: &str) -> i32 {\n    match Engine::open(db_path.to_path_buf()) {\n        Ok(_opened) => {\n            println!(r#\"{{\"status\":\"not_implemented\",\"verb\":\"{verb}\"}}\"#);\n            exit_code::UNRECOVERABLE\n        }\n        Err(err) => emit_engine_open_error(verb, &err),\n    }\n}\n\n/// Open the engine, invoke `f`, print the resulting JSON value, and map\n/// the outcome to an exit code. The closure returns `(json, outcome)`.\nfn run_doctor_verb<F>(db_path: &std::path::Path, verb: &str, f: F) -> i32\nwhere\n    F: FnOnce(&Engine) -> Result<(Value, CliOutcome), EngineError>,\n{\n    run_doctor_verb_inner(db_path, verb, None, f)\n}\n\n/// Variant that overrides the `EngineError` → outcome mapping for verbs\n/// with a dedicated failure class (per `cli.md § Error → exit-code\n/// mapping`). Example: `doctor safe-export` maps engine errors to\n/// `ExportFailure` (66), not the default `Unrecoverable` (70).\nfn run_doctor_verb_with_error_outcome<F>(\n    db_path: &std::path::Path,\n    verb: &str,\n    error_outcome: CliOutcome,\n    f: F,\n) -> i32\nwhere\n    F: FnOnce(&Engine) -> Result<(Value, CliOutcome), EngineError>,\n{\n    run_doctor_verb_inner(db_path, verb, Some(error_outcome), f)\n}\n\nfn run_doctor_verb_inner<F>(\n    db_path: &std::path::Path,\n    verb: &str,\n    error_outcome: Option<CliOutcome>,\n    f: F,\n) -> i32\nwhere\n    F: FnOnce(&Engine) -> Result<(Value, CliOutcome), EngineError>,\n{\n    let opened = match Engine::open(db_path.to_path_buf()) {\n        Ok(o) => o,\n        Err(err) => return emit_engine_open_error(verb, &err),\n    };\n    match f(&opened.engine) {\n        Ok((value, outcome)) => {\n            println!(\"{value}\");\n            outcome_to_exit_code(outcome)\n        }\n        Err(err) => match error_outcome {\n            Some(outcome) => emit_engine_error_with_outcome(verb, &err, outcome),\n            None => emit_engine_error(verb, &err),\n        },\n    }\n}\n\n/// Open the engine for `recover`, invoke `f`, print the JSON, and map the\n/// outcome to `RECOVERY_ACCEPTED_LOSS` (64) on success.\nfn wire_recover<F>(db_path: &std::path::Path, sub_verb: &str, f: F) -> i32\nwhere\n    F: FnOnce(&Engine) -> Result<Value, EngineError>,\n{\n    let opened = match Engine::open(db_path.to_path_buf()) {\n        Ok(o) => o,\n        Err(err) => return emit_engine_open_error(sub_verb, &err),\n    };\n    match f(&opened.engine) {\n        Ok(value) => {\n            println!(\"{value}\");\n            outcome_to_exit_code(CliOutcome::RecoveryAcceptedLoss)\n        }\n        Err(err) => emit_engine_error(sub_verb, &err),\n    }\n}\n\nfn emit_engine_error(verb: &str, err: &EngineError) -> i32 {\n    emit_engine_error_with_outcome(verb, err, engine_error_to_outcome(err))\n}\n\nfn emit_engine_error_with_outcome(verb: &str, err: &EngineError, outcome: CliOutcome) -> i32 {\n    let payload = json!({\n        \"status\": \"error\",\n        \"verb\": verb,\n        \"code\": engine_error_code(err),\n        \"detail\": err.to_string(),\n    });\n    println!(\"{payload}\");\n    outcome_to_exit_code(outcome)\n}\n\nfn emit_engine_open_error(verb: &str, err: &EngineOpenError) -> i32 {\n    let outcome = engine_open_error_to_outcome(err);\n    let payload = json!({\n        \"status\": \"error\",\n        \"verb\": verb,\n        \"code\": engine_open_error_code(err),\n        \"detail\": err.to_string(),\n    });\n    println!(\"{payload}\");\n    outcome_to_exit_code(outcome)\n}\n\nfn engine_error_code(err: &EngineError) -> &'static str {\n    match err {\n        EngineError::Storage => \"StorageError\",\n        EngineError::Projection => \"ProjectionError\",\n        EngineError::Vector => \"VectorError\",\n        EngineError::Embedder => \"EmbedderError\",\n        EngineError::EmbedderNotConfigured => \"EmbedderNotConfiguredError\",\n        EngineError::KindNotVectorIndexed => \"KindNotVectorIndexedError\",\n        EngineError::EmbedderDimensionMismatch { .. } => \"EmbedderDimensionMismatchError\",\n        EngineError::Scheduler => \"SchedulerError\",\n        EngineError::OpStore => \"OpStoreError\",\n        EngineError::WriteValidation => \"WriteValidationError\",\n        EngineError::SchemaValidation => \"SchemaValidationError\",\n        EngineError::Overloaded => \"OverloadedError\",\n        EngineError::Closing => \"ClosingError\",\n    }\n}\n\nfn engine_open_error_code(err: &EngineOpenError) -> &'static str {\n    match err {\n        EngineOpenError::DatabaseLocked { .. } => \"DatabaseLockedError\",\n        EngineOpenError::Corruption(_) => \"CorruptionError\",\n        EngineOpenError::IncompatibleSchemaVersion { .. } => \"IncompatibleSchemaVersionError\",\n        EngineOpenError::MigrationError { .. } => \"MigrationError\",\n        EngineOpenError::EmbedderIdentityMismatch { .. } => \"EmbedderIdentityMismatchError\",\n        EngineOpenError::EmbedderDimensionMismatch { .. } => \"EmbedderDimensionMismatchError\",\n        EngineOpenError::Io { .. } => \"IoError\",\n    }\n}\n\n// ---- JSON serializers for engine report types ----\n\nfn integrity_report_outcome(report: &IntegrityReport) -> (Value, CliOutcome) {\n    let any_findings = matches!(report.physical, Section::Findings(_))\n        || matches!(report.logical, Section::Findings(_))\n        || matches!(report.semantic, Section::Findings(_));\n    let body = json!({\n        \"verb\": \"check-integrity\",\n        \"physical\": section_json(&report.physical),\n        \"logical\": section_json(&report.logical),\n        \"semantic\": section_json(&report.semantic),\n    });\n    let outcome = if any_findings { CliOutcome::Findings } else { CliOutcome::Clean };\n    (body, outcome)\n}\n\nfn section_json(section: &Section) -> Value {\n    match section {\n        Section::Clean => json!({ \"status\": \"clean\", \"findings\": [] }),\n        Section::Findings(findings) => json!({\n            \"status\": \"findings\",\n            \"findings\": findings.iter().map(finding_json).collect::<Vec<_>>(),\n        }),\n    }\n}\n\nfn finding_json(f: &Finding) -> Value {\n    json!({\n        \"code\": f.code,\n        \"stage\": f.stage,\n        \"locator\": locator_json(&f.locator),\n        \"doc_anchor\": f.doc_anchor,\n        \"detail\": f.detail,\n    })\n}\n\nfn locator_json(loc: &CorruptionLocator) -> Value {\n    match loc {\n        CorruptionLocator::FileOffset { offset } => {\n            json!({ \"kind\": \"file_offset\", \"offset\": offset })\n        }\n        CorruptionLocator::PageId { page } => json!({ \"kind\": \"page_id\", \"page\": page }),\n        CorruptionLocator::TableRow { table, rowid } => {\n            json!({ \"kind\": \"table_row\", \"table\": table, \"rowid\": rowid })\n        }\n        CorruptionLocator::Vec0ShadowRow { partition, rowid } => {\n            json!({ \"kind\": \"vec0_shadow_row\", \"partition\": partition, \"rowid\": rowid })\n        }\n        CorruptionLocator::MigrationStep { from, to } => {\n            json!({ \"kind\": \"migration_step\", \"from\": from, \"to\": to })\n        }\n        CorruptionLocator::OpaqueSqliteError { sqlite_extended_code } => {\n            json!({\n                \"kind\": \"opaque_sqlite_error\",\n                \"sqlite_extended_code\": sqlite_extended_code,\n            })\n        }\n    }\n}\n\nfn safe_export_json(a: &SafeExportArtifact) -> Value {\n    json!({\n        \"verb\": \"safe-export\",\n        \"export_path\": a.export_path.to_string_lossy(),\n        \"manifest_path\": a.manifest_path.to_string_lossy(),\n        \"manifest_sha256\": a.manifest_sha256,\n    })\n}\n\nfn trace_report_json(t: &TraceReport) -> Value {\n    json!({\n        \"verb\": \"trace\",\n        \"source_ref\": t.source_ref,\n        \"events\": t.events.iter().map(|e| json!({\n            \"write_cursor\": e.write_cursor,\n            \"kind\": e.kind,\n            \"table\": e.table,\n        })).collect::<Vec<_>>(),\n    })\n}\n\nfn rebuild_report_json(verb: &'static str, r: &RebuildReport) -> Value {\n    let kind = match r.kind {\n        RebuildKind::Projections => \"projections\",\n        RebuildKind::Vec0 => \"vec0\",\n    };\n    json!({\n        \"verb\": verb,\n        \"kind\": kind,\n        \"rows_invalidated\": r.rows_invalidated,\n        \"rows_rebuilt\": r.rows_rebuilt,\n        \"projection_cursor_after\": r.projection_cursor_after,\n    })\n}\n\nfn excise_report_json(r: &ExciseReport) -> Value {\n    json!({\n        \"verb\": \"excise-source\",\n        \"source_ref\": r.source_ref,\n        \"nodes_excised\": r.nodes_excised,\n        \"edges_excised\": r.edges_excised,\n        \"projections_invalidated\": r.projections_invalidated,\n    })\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn outcome_mapping_covers_cli_md_exit_classes() {\n        assert_eq!(outcome_to_exit_code(CliOutcome::Clean), 0);\n        assert_eq!(outcome_to_exit_code(CliOutcome::RecoveryAcceptedLoss), 64);\n        assert_eq!(outcome_to_exit_code(CliOutcome::Findings), 65);\n        assert_eq!(outcome_to_exit_code(CliOutcome::ExportFailure), 66);\n        assert_eq!(outcome_to_exit_code(CliOutcome::Unrecoverable), 70);\n        assert_eq!(outcome_to_exit_code(CliOutcome::LockHeld), 71);\n    }\n\n    #[test]\n    fn engine_error_storage_maps_to_unrecoverable() {\n        assert_eq!(engine_error_to_outcome(&EngineError::Storage), CliOutcome::Unrecoverable);\n        assert_eq!(engine_error_to_outcome(&EngineError::Closing), CliOutcome::LockHeld);\n    }\n\n    #[test]\n    fn engine_open_database_locked_maps_to_lock_held() {\n        let err = EngineOpenError::DatabaseLocked { holder_pid: Some(1234) };\n        assert_eq!(engine_open_error_to_outcome(&err), CliOutcome::LockHeld);\n    }\n}\n","numLines":620,"startLine":1,"totalLines":620}}}
