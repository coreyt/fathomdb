{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NPCh3ycHCwBDdtGFsXHJSf","type":"tool_result","content":"1\t//! Parser-shape assertions for the operator CLI surface owned by\n2\t//! `dev/interfaces/cli.md`.\n3\t//!\n4\t//! The 0.6.0 surface-stubs slice pins root commands, doctor verbs, recover\n5\t//! flag set, and the cross-verb invariant that `--accept-data-loss` belongs\n6\t//! to `recover` only (doctor verbs reject it).\n7\t\n8\tuse clap::Parser;\n9\t\n10\tuse fathomdb_cli::{exit_code, Cli, Command, DoctorCommand};\n11\t\n12\tfn parse(args: &[&str]) -> Cli {\n13\t    let mut argv = vec![\"fathomdb\"];\n14\t    argv.extend_from_slice(args);\n15\t    Cli::try_parse_from(argv).expect(\"parse should succeed\")\n16\t}\n17\t\n18\tfn doctor(cli: Cli) -> DoctorCommand {\n19\t    let Command::Doctor(d) = cli.command else { panic!(\"expected doctor variant\") };\n20\t    d.command\n21\t}\n22\t\n23\t#[test]\n24\tfn recover_accepts_all_six_subflags() {\n25\t    let cli = parse(&[\n26\t        \"recover\",\n27\t        \"--accept-data-loss\",\n28\t        \"--truncate-wal\",\n29\t        \"--rebuild-vec0\",\n30\t        \"--rebuild-projections\",\n31\t        \"--excise-source\",\n32\t        \"src-1\",\n33\t        \"--purge-logical-id\",\n34\t        \"lid-1\",\n35\t        \"--restore-logical-id\",\n36\t        \"lid-2\",\n37\t        \"/tmp/db.sqlite\",\n38\t    ]);\n39\t\n40\t    let Command::Recover(args) = cli.command else { panic!(\"expected recover variant\") };\n41\t    assert!(args.accept_data_loss);\n42\t    assert!(args.truncate_wal);\n43\t    assert!(args.rebuild_vec0);\n44\t    assert!(args.rebuild_projections);\n45\t    assert_eq!(args.excise_source.as_deref(), Some(\"src-1\"));\n46\t    assert_eq!(args.purge_logical_id.as_deref(), Some(\"lid-1\"));\n47\t    assert_eq!(args.restore_logical_id.as_deref(), Some(\"lid-2\"));\n48\t}\n49\t\n50\t#[test]\n51\tfn doctor_check_integrity_accepts_full_flag_set() {\n52\t    let cli = parse(&[\n53\t        \"doctor\",\n54\t        \"check-integrity\",\n55\t        \"--quick\",\n56\t        \"--full\",\n57\t        \"--round-trip\",\n58\t        \"--pretty\",\n59\t        \"/tmp/db.sqlite\",\n60\t    ]);\n61\t    let DoctorCommand::CheckIntegrity(args) = doctor(cli) else {\n62\t        panic!(\"expected check-integrity\")\n63\t    };\n64\t    assert!(args.quick);\n65\t    assert!(args.full);\n66\t    assert!(args.round_trip);\n67\t    assert!(args.pretty);\n68\t}\n69\t\n70\t#[test]\n71\tfn doctor_safe_export_accepts_out_and_manifest() {\n72\t    let cli = parse(&[\n73\t        \"doctor\",\n74\t        \"safe-export\",\n75\t        \"/tmp/out\",\n76\t        \"--manifest\",\n77\t        \"/tmp/manifest.json\",\n78\t        \"/tmp/db.sqlite\",\n79\t    ]);\n80\t    let DoctorCommand::SafeExport(args) = doctor(cli) else {\n81\t        panic!(\"expected safe-export\");\n82\t    };\n83\t    assert_eq!(args.out, std::path::PathBuf::from(\"/tmp/out\"));\n84\t    assert_eq!(\n85\t        args.manifest.as_ref().map(|p| p.to_string_lossy().into_owned()).as_deref(),\n86\t        Some(\"/tmp/manifest.json\")\n87\t    );\n88\t}\n89\t\n90\t#[test]\n91\tfn doctor_trace_requires_source_ref() {\n92\t    let cli = parse(&[\"doctor\", \"trace\", \"--source-ref\", \"src-99\", \"/tmp/db.sqlite\"]);\n93\t    let DoctorCommand::Trace(args) = doctor(cli) else {\n94\t        panic!(\"expected trace\");\n95\t    };\n96\t    assert_eq!(args.source_ref, \"src-99\");\n97\t\n98\t    Cli::try_parse_from([\"fathomdb\", \"doctor\", \"trace\"]).expect_err(\"trace requires --source-ref\");\n99\t}\n100\t\n101\t#[test]\n102\tfn doctor_simple_verbs_parse() {\n103\t    for verb in [\"verify-embedder\", \"dump-schema\", \"dump-row-counts\", \"dump-profile\"] {\n104\t        let cli = parse(&[\"doctor\", verb, \"/tmp/db.sqlite\"]);\n105\t        match (verb, doctor(cli)) {\n106\t            (\"verify-embedder\", DoctorCommand::VerifyEmbedder(args))\n107\t            | (\"dump-schema\", DoctorCommand::DumpSchema(args))\n108\t            | (\"dump-row-counts\", DoctorCommand::DumpRowCounts(args))\n109\t            | (\"dump-profile\", DoctorCommand::DumpProfile(args)) => {\n110\t                assert!(!args.json, \"default --json must be false for {verb}\");\n111\t            }\n112\t            (other, parsed) => panic!(\"verb {other} parsed unexpectedly as {parsed:?}\"),\n113\t        }\n114\t    }\n115\t}\n116\t\n117\t#[test]\n118\tfn every_doctor_verb_accepts_json_flag() {\n119\t    // `cli.md` § Output posture: `--json` is the normative machine-readable\n120\t    // contract on every verb.\n121\t    for verb in [\n122\t        \"check-integrity\",\n123\t        \"safe-export\",\n124\t        \"verify-embedder\",\n125\t        \"trace\",\n126\t        \"dump-schema\",\n127\t        \"dump-row-counts\",\n128\t        \"dump-profile\",\n129\t    ] {\n130\t        let mut argv: Vec<&str> = vec![\"fathomdb\", \"doctor\", verb];\n131\t        match verb {\n132\t            \"safe-export\" => argv.push(\"/tmp/out\"),\n133\t            \"trace\" => argv.extend([\"--source-ref\", \"src-1\"]),\n134\t            _ => {}\n135\t        }\n136\t        argv.push(\"--json\");\n137\t        argv.push(\"/tmp/db.sqlite\");\n138\t        Cli::try_parse_from(argv)\n139\t            .unwrap_or_else(|e| panic!(\"doctor {verb} --json must parse; err={e}\"));\n140\t    }\n141\t}\n142\t\n143\t#[test]\n144\tfn doctor_rejects_accept_data_loss() {\n145\t    let res = Cli::try_parse_from([\"fathomdb\", \"doctor\", \"check-integrity\", \"--accept-data-loss\"]);\n146\t    assert!(res.is_err(), \"doctor must reject --accept-data-loss\");\n147\t}\n148\t\n149\t#[test]\n150\tfn unknown_root_command_is_rejected() {\n151\t    let res = Cli::try_parse_from([\"fathomdb\", \"destroy-everything\"]);\n152\t    assert!(res.is_err());\n153\t}\n154\t\n155\t#[test]\n156\tfn json_flag_available_on_doctor_verbs() {\n157\t    let cli = parse(&[\"doctor\", \"check-integrity\", \"--json\", \"/tmp/db.sqlite\"]);\n158\t    let DoctorCommand::CheckIntegrity(args) = doctor(cli) else {\n159\t        panic!(\"expected check-integrity\");\n160\t    };\n161\t    assert!(args.json);\n162\t}\n163\t\n164\t#[test]\n165\tfn exit_code_constants_match_design() {\n166\t    assert_eq!(exit_code::OK, 0);\n167\t    assert_eq!(exit_code::RECOVERY_ACCEPTED_LOSS, 64);\n168\t    assert_eq!(exit_code::DOCTOR_FOUND_ISSUES, 65);\n169\t    assert_eq!(exit_code::EXPORT_FAILURE, 66);\n170\t    assert_eq!(exit_code::UNRECOVERABLE, 70);\n171\t    assert_eq!(exit_code::LOCK_HELD, 71);\n172\t}\n173\t"}]},"parent_tool_use_id":null,"session_id":"6045b345-74e5-4485-9471-2a1561990851","uuid":"cc4fdbe9-c7f4-4405-9eb4-c6a29feb5e61","timestamp":"2026-05-15T23:43:30.156Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-10b-A-low-risk-seams-20260515T234104Z/src/rust/crates/fathomdb-cli/tests/parser.rs","content":"//! Parser-shape assertions for the operator CLI surface owned by\n//! `dev/interfaces/cli.md`.\n//!\n//! The 0.6.0 surface-stubs slice pins root commands, doctor verbs, recover\n//! flag set, and the cross-verb invariant that `--accept-data-loss` belongs\n//! to `recover` only (doctor verbs reject it).\n\nuse clap::Parser;\n\nuse fathomdb_cli::{exit_code, Cli, Command, DoctorCommand};\n\nfn parse(args: &[&str]) -> Cli {\n    let mut argv = vec![\"fathomdb\"];\n    argv.extend_from_slice(args);\n    Cli::try_parse_from(argv).expect(\"parse should succeed\")\n}\n\nfn doctor(cli: Cli) -> DoctorCommand {\n    let Command::Doctor(d) = cli.command else { panic!(\"expected doctor variant\") };\n    d.command\n}\n\n#[test]\nfn recover_accepts_all_six_subflags() {\n    let cli = parse(&[\n        \"recover\",\n        \"--accept-data-loss\",\n        \"--truncate-wal\",\n        \"--rebuild-vec0\",\n        \"--rebuild-projections\",\n        \"--excise-source\",\n        \"src-1\",\n        \"--purge-logical-id\",\n        \"lid-1\",\n        \"--restore-logical-id\",\n        \"lid-2\",\n        \"/tmp/db.sqlite\",\n    ]);\n\n    let Command::Recover(args) = cli.command else { panic!(\"expected recover variant\") };\n    assert!(args.accept_data_loss);\n    assert!(args.truncate_wal);\n    assert!(args.rebuild_vec0);\n    assert!(args.rebuild_projections);\n    assert_eq!(args.excise_source.as_deref(), Some(\"src-1\"));\n    assert_eq!(args.purge_logical_id.as_deref(), Some(\"lid-1\"));\n    assert_eq!(args.restore_logical_id.as_deref(), Some(\"lid-2\"));\n}\n\n#[test]\nfn doctor_check_integrity_accepts_full_flag_set() {\n    let cli = parse(&[\n        \"doctor\",\n        \"check-integrity\",\n        \"--quick\",\n        \"--full\",\n        \"--round-trip\",\n        \"--pretty\",\n        \"/tmp/db.sqlite\",\n    ]);\n    let DoctorCommand::CheckIntegrity(args) = doctor(cli) else {\n        panic!(\"expected check-integrity\")\n    };\n    assert!(args.quick);\n    assert!(args.full);\n    assert!(args.round_trip);\n    assert!(args.pretty);\n}\n\n#[test]\nfn doctor_safe_export_accepts_out_and_manifest() {\n    let cli = parse(&[\n        \"doctor\",\n        \"safe-export\",\n        \"/tmp/out\",\n        \"--manifest\",\n        \"/tmp/manifest.json\",\n        \"/tmp/db.sqlite\",\n    ]);\n    let DoctorCommand::SafeExport(args) = doctor(cli) else {\n        panic!(\"expected safe-export\");\n    };\n    assert_eq!(args.out, std::path::PathBuf::from(\"/tmp/out\"));\n    assert_eq!(\n        args.manifest.as_ref().map(|p| p.to_string_lossy().into_owned()).as_deref(),\n        Some(\"/tmp/manifest.json\")\n    );\n}\n\n#[test]\nfn doctor_trace_requires_source_ref() {\n    let cli = parse(&[\"doctor\", \"trace\", \"--source-ref\", \"src-99\", \"/tmp/db.sqlite\"]);\n    let DoctorCommand::Trace(args) = doctor(cli) else {\n        panic!(\"expected trace\");\n    };\n    assert_eq!(args.source_ref, \"src-99\");\n\n    Cli::try_parse_from([\"fathomdb\", \"doctor\", \"trace\"]).expect_err(\"trace requires --source-ref\");\n}\n\n#[test]\nfn doctor_simple_verbs_parse() {\n    for verb in [\"verify-embedder\", \"dump-schema\", \"dump-row-counts\", \"dump-profile\"] {\n        let cli = parse(&[\"doctor\", verb, \"/tmp/db.sqlite\"]);\n        match (verb, doctor(cli)) {\n            (\"verify-embedder\", DoctorCommand::VerifyEmbedder(args))\n            | (\"dump-schema\", DoctorCommand::DumpSchema(args))\n            | (\"dump-row-counts\", DoctorCommand::DumpRowCounts(args))\n            | (\"dump-profile\", DoctorCommand::DumpProfile(args)) => {\n                assert!(!args.json, \"default --json must be false for {verb}\");\n            }\n            (other, parsed) => panic!(\"verb {other} parsed unexpectedly as {parsed:?}\"),\n        }\n    }\n}\n\n#[test]\nfn every_doctor_verb_accepts_json_flag() {\n    // `cli.md` § Output posture: `--json` is the normative machine-readable\n    // contract on every verb.\n    for verb in [\n        \"check-integrity\",\n        \"safe-export\",\n        \"verify-embedder\",\n        \"trace\",\n        \"dump-schema\",\n        \"dump-row-counts\",\n        \"dump-profile\",\n    ] {\n        let mut argv: Vec<&str> = vec![\"fathomdb\", \"doctor\", verb];\n        match verb {\n            \"safe-export\" => argv.push(\"/tmp/out\"),\n            \"trace\" => argv.extend([\"--source-ref\", \"src-1\"]),\n            _ => {}\n        }\n        argv.push(\"--json\");\n        argv.push(\"/tmp/db.sqlite\");\n        Cli::try_parse_from(argv)\n            .unwrap_or_else(|e| panic!(\"doctor {verb} --json must parse; err={e}\"));\n    }\n}\n\n#[test]\nfn doctor_rejects_accept_data_loss() {\n    let res = Cli::try_parse_from([\"fathomdb\", \"doctor\", \"check-integrity\", \"--accept-data-loss\"]);\n    assert!(res.is_err(), \"doctor must reject --accept-data-loss\");\n}\n\n#[test]\nfn unknown_root_command_is_rejected() {\n    let res = Cli::try_parse_from([\"fathomdb\", \"destroy-everything\"]);\n    assert!(res.is_err());\n}\n\n#[test]\nfn json_flag_available_on_doctor_verbs() {\n    let cli = parse(&[\"doctor\", \"check-integrity\", \"--json\", \"/tmp/db.sqlite\"]);\n    let DoctorCommand::CheckIntegrity(args) = doctor(cli) else {\n        panic!(\"expected check-integrity\");\n    };\n    assert!(args.json);\n}\n\n#[test]\nfn exit_code_constants_match_design() {\n    assert_eq!(exit_code::OK, 0);\n    assert_eq!(exit_code::RECOVERY_ACCEPTED_LOSS, 64);\n    assert_eq!(exit_code::DOCTOR_FOUND_ISSUES, 65);\n    assert_eq!(exit_code::EXPORT_FAILURE, 66);\n    assert_eq!(exit_code::UNRECOVERABLE, 70);\n    assert_eq!(exit_code::LOCK_HELD, 71);\n}\n","numLines":173,"startLine":1,"totalLines":173}}}
