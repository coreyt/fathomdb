{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LzTtqTxCAnTFKSWsMQDscS","type":"tool_result","content":"1\t//! Operator CLI invocability + output-shape assertions for the 0.6.0\n2\t//! surface owned by `dev/interfaces/cli.md`.\n3\t//!\n4\t//! Bound ACs (invocability + shape):\n5\t//!\n6\t//! - AC-035d (CLI half): `fathomdb recover --help` exits 0; runtime refusal\n7\t//!   without `--accept-data-loss`.\n8\t//! - AC-036: every doctor verb supports `--json` machine-readable output.\n9\t//! - AC-037: doctor verbs emit one JSON object on `--json` (single-object\n10\t//!   contract, not NDJSON).\n11\t//! - AC-038: `--pretty` is a human-only formatter, not a second machine\n12\t//!   schema.\n13\t//! - AC-040a: every `fathomdb doctor <verb> --help` exits 0.\n14\t//! - AC-040b: every `fathomdb doctor <verb> --help` prints a `Usage:` line.\n15\t//! - AC-045: opening a DB while another engine holds the lock surfaces as\n16\t//!   exit code `exit_code::LOCK_HELD` (71).\n17\t//! - AC-058: `fathomdb recover --help` enumerates the six recover sub-flags\n18\t//!   plus `--accept-data-loss`.\n19\t//!\n20\t//! These tests invoke the built `fathomdb` binary via `env!(\"CARGO_BIN_EXE_*\")`\n21\t//! so they exercise clap's runtime behavior, not just the parser surface\n22\t//! pinned by `tests/parser.rs`.\n23\t\n24\tuse std::process::Command;\n25\t\n26\tuse fathomdb::Engine;\n27\tuse fathomdb_cli::exit_code;\n28\tuse serde_json::Value;\n29\tuse tempfile::TempDir;\n30\t\n31\tconst DOCTOR_VERBS: &[&str] = &[\n32\t    \"check-integrity\",\n33\t    \"safe-export\",\n34\t    \"verify-embedder\",\n35\t    \"trace\",\n36\t    \"dump-schema\",\n37\t    \"dump-row-counts\",\n38\t    \"dump-profile\",\n39\t];\n40\t\n41\tconst RECOVER_FLAGS: &[&str] = &[\n42\t    \"--truncate-wal\",\n43\t    \"--rebuild-vec0\",\n44\t    \"--rebuild-projections\",\n45\t    \"--excise-source\",\n46\t    \"--purge-logical-id\",\n47\t    \"--restore-logical-id\",\n48\t    \"--accept-data-loss\",\n49\t];\n50\t\n51\tfn fathomdb() -> Command {\n52\t    Command::new(env!(\"CARGO_BIN_EXE_fathomdb\"))\n53\t}\n54\t\n55\t#[test]\n56\tfn t_040a_every_doctor_verb_help_exits_zero() {\n57\t    for verb in DOCTOR_VERBS {\n58\t        let output = fathomdb()\n59\t            .args([\"doctor\", verb, \"--help\"])\n60\t            .output()\n61\t            .unwrap_or_else(|e| panic!(\"failed to spawn fathomdb doctor {verb} --help: {e}\"));\n62\t        assert!(\n63\t            output.status.success(),\n64\t            \"fathomdb doctor {verb} --help must exit 0; got {:?} stderr={}\",\n65\t            output.status,\n66\t            String::from_utf8_lossy(&output.stderr),\n67\t        );\n68\t    }\n69\t}\n70\t\n71\t#[test]\n72\tfn t_040b_every_doctor_verb_help_has_usage_section() {\n73\t    for verb in DOCTOR_VERBS {\n74\t        let output = fathomdb().args([\"doctor\", verb, \"--help\"]).output().expect(\"spawn\");\n75\t        let stdout = String::from_utf8_lossy(&output.stdout);\n76\t        assert!(\n77\t            stdout.lines().any(|line| line.starts_with(\"Usage:\")),\n78\t            \"fathomdb doctor {verb} --help must include a `Usage:` line; got:\\n{stdout}\",\n79\t        );\n80\t    }\n81\t}\n82\t\n83\t#[test]\n84\tfn t_035d_recover_help_exits_zero() {\n85\t    let output = fathomdb().args([\"recover\", \"--help\"]).output().expect(\"spawn\");\n86\t    assert!(\n87\t        output.status.success(),\n88\t        \"fathomdb recover --help must exit 0; got {:?} stderr={}\",\n89\t        output.status,\n90\t        String::from_utf8_lossy(&output.stderr),\n91\t    );\n92\t}\n93\t\n94\t#[test]\n95\tfn t_058_recover_help_enumerates_canonical_flag_set() {\n96\t    let output = fathomdb().args([\"recover\", \"--help\"]).output().expect(\"spawn\");\n97\t    assert!(output.status.success(), \"recover --help must exit 0\");\n98\t    let stdout = String::from_utf8_lossy(&output.stdout);\n99\t    for flag in RECOVER_FLAGS {\n100\t        let count = stdout.matches(flag).count();\n101\t        assert_eq!(\n102\t            count, 1,\n103\t            \"recover --help must mention {flag} exactly once; counted {count} in:\\n{stdout}\",\n104\t        );\n105\t    }\n106\t}\n107\t\n108\t#[test]\n109\tfn t_cli_doctor_rejects_accept_data_loss_binary() {\n110\t    let output = fathomdb()\n111\t        .args([\"doctor\", \"check-integrity\", \"--accept-data-loss\"])\n112\t        .output()\n113\t        .expect(\"spawn\");\n114\t    assert!(\n115\t        !output.status.success(),\n116\t        \"fathomdb doctor check-integrity --accept-data-loss must fail; \\\n117\t         clap should reject the flag (it is owned by `recover`)\",\n118\t    );\n119\t}\n120\t\n121\t/// Seeded DB fixture for tests that need a live engine. Opens, closes,\n122\t/// and returns the path so the CLI binary can open it itself. The\n123\t/// returned `TempDir` keeps the on-disk file alive for the test scope.\n124\tfn seeded_db() -> (TempDir, std::path::PathBuf) {\n125\t    let dir = TempDir::new().expect(\"tempdir\");\n126\t    let path = dir.path().join(\"operator.sqlite\");\n127\t    let opened = Engine::open(path.clone()).expect(\"engine open\");\n128\t    opened.engine.close().expect(\"engine close\");\n129\t    drop(opened);\n130\t    (dir, path)\n131\t}\n132\t\n133\t/// Argument vector for a doctor verb invocation against `db_path`.\n134\tfn doctor_invocation(verb: &str, db_path: &str, out_path: &str) -> Vec<String> {\n135\t    let mut argv = vec![\"doctor\".to_string(), verb.to_string()];\n136\t    match verb {\n137\t        \"safe-export\" => {\n138\t            argv.push(out_path.to_string());\n139\t        }\n140\t        \"trace\" => {\n141\t            argv.push(\"--source-ref\".to_string());\n142\t            argv.push(\"src-test\".to_string());\n143\t        }\n144\t        _ => {}\n145\t    }\n146\t    argv.push(db_path.to_string());\n147\t    argv\n148\t}\n149\t\n150\t#[test]\n151\tfn t_035d_recover_refuses_without_accept_data_loss() {\n152\t    // AC-035d runtime: CLI refuses `recover` without `--accept-data-loss`\n153\t    // before opening the engine. The DB path is positional and still\n154\t    // required, but the guard runs before any engine interaction.\n155\t    let (dir, db) = seeded_db();\n156\t    let output = fathomdb()\n157\t        .args([\"recover\", \"--truncate-wal\", db.to_str().unwrap()])\n158\t        .output()\n159\t        .expect(\"spawn\");\n160\t    assert_eq!(\n161\t        output.status.code(),\n162\t        Some(exit_code::UNRECOVERABLE),\n163\t        \"recover without --accept-data-loss must exit UNRECOVERABLE; got {:?} stderr={}\",\n164\t        output.status,\n165\t        String::from_utf8_lossy(&output.stderr),\n166\t    );\n167\t    let stdout = String::from_utf8_lossy(&output.stdout);\n168\t    let parsed: Value = serde_json::from_str(stdout.trim())\n169\t        .unwrap_or_else(|e| panic!(\"refusal stdout must be JSON; err={e} stdout={stdout}\"));\n170\t    let obj = parsed.as_object().expect(\"expected JSON object\");\n171\t    assert_eq!(obj.get(\"status\").and_then(Value::as_str), Some(\"refused\"));\n172\t    assert_eq!(obj.get(\"verb\").and_then(Value::as_str), Some(\"recover\"));\n173\t    assert_eq!(\n174\t        obj.get(\"code\").and_then(Value::as_str),\n175\t        Some(\"E_RECOVER_REQUIRES_ACCEPT_DATA_LOSS\"),\n176\t    );\n177\t    drop(dir);\n178\t}\n179\t\n180\t#[test]\n181\tfn t_035d_runtime_doctor_rejects_accept_data_loss() {\n182\t    // AC-035d runtime: doctor verbs reject `--accept-data-loss` at the\n183\t    // parser layer, so the runtime binary surfaces a non-zero exit.\n184\t    let output = fathomdb()\n185\t        .args([\"doctor\", \"check-integrity\", \"--accept-data-loss\", \"/tmp/x.sqlite\"])\n186\t        .output()\n187\t        .expect(\"spawn\");\n188\t    assert!(\n189\t        !output.status.success(),\n190\t        \"doctor must refuse --accept-data-loss; got {:?}\",\n191\t        output.status,\n192\t    );\n193\t}\n194\t\n195\t#[test]\n196\tfn t_036_every_doctor_verb_accepts_json_flag_on_binary() {\n197\t    // AC-036: `--json` is machine-readable on every doctor verb. For\n198\t    // verbs whose engine seam has landed we additionally assert the\n199\t    // output parses as JSON; for stub verbs we accept the\n200\t    // `not_implemented` JSON envelope.\n201\t    let (dir, db) = seeded_db();\n202\t    let out_path = dir.path().join(\"export.sqlite\");\n203\t    for verb in DOCTOR_VERBS {\n204\t        let mut argv = doctor_invocation(verb, db.to_str().unwrap(), out_path.to_str().unwrap());\n205\t        // Insert --json before the trailing db-path positional. For verbs\n206\t        // with no other positional, that means before the db path.\n207\t        let db_index = argv.len() - 1;\n208\t        argv.insert(db_index, \"--json\".to_string());\n209\t        let output = fathomdb().args(&argv).output().expect(\"spawn\");\n210\t        let stdout = String::from_utf8_lossy(&output.stdout);\n211\t        let trimmed = stdout.trim();\n212\t        assert!(\n213\t            !trimmed.is_empty(),\n214\t            \"doctor {verb} --json must emit something on stdout; got empty\",\n215\t        );\n216\t        serde_json::from_str::<Value>(trimmed).unwrap_or_else(|e| {\n217\t            panic!(\"doctor {verb} --json stdout must parse as JSON; err={e} stdout={stdout}\")\n218\t        });\n219\t    }\n220\t    drop(dir);\n221\t}\n222\t\n223\t#[test]\n224\tfn t_037_doctor_verbs_emit_single_json_object() {\n225\t    // AC-037: each doctor verb emits exactly one JSON object (not NDJSON).\n226\t    let (dir, db) = seeded_db();\n227\t    let out_path = dir.path().join(\"export.sqlite\");\n228\t    for verb in DOCTOR_VERBS {\n229\t        let mut argv = doctor_invocation(verb, db.to_str().unwrap(), out_path.to_str().unwrap());\n230\t        let db_index = argv.len() - 1;\n231\t        argv.insert(db_index, \"--json\".to_string());\n232\t        let output = fathomdb().args(&argv).output().expect(\"spawn\");\n233\t        let stdout = String::from_utf8_lossy(&output.stdout);\n234\t        let trimmed = stdout.trim();\n235\t        let parsed: Value = serde_json::from_str(trimmed).unwrap_or_else(|e| {\n236\t            panic!(\"doctor {verb} --json must be parseable; err={e} stdout={stdout}\")\n237\t        });\n238\t        assert!(\n239\t            parsed.is_object(),\n240\t            \"doctor {verb} --json must produce a single JSON object; got {parsed:?}\",\n241\t        );\n242\t        // Single-object contract: no trailing newline-delimited extras.\n243\t        assert_eq!(\n244\t            trimmed.lines().count(),\n245\t            trimmed.lines().filter(|l| !l.is_empty()).count(),\n246\t            \"doctor {verb} --json must not contain blank lines (NDJSON guard)\",\n247\t        );\n248\t    }\n249\t    drop(dir);\n250\t}\n251\t\n252\t#[test]\n253\tfn t_038_pretty_is_human_only_not_machine_schema() {\n254\t    // AC-038: `--pretty` is a human formatter only. `doctor\n255\t    // check-integrity --pretty` (without `--json`) must NOT produce a\n256\t    // parseable JSON object — it is human output, not a second machine\n257\t    // contract. (Adding `--json` opts into the machine schema.)\n258\t    let (dir, db) = seeded_db();\n259\t    let output = fathomdb()\n260\t        .args([\"doctor\", \"check-integrity\", \"--pretty\", db.to_str().unwrap()])\n261\t        .output()\n262\t        .expect(\"spawn\");\n263\t    let stdout = String::from_utf8_lossy(&output.stdout);\n264\t    // The runtime currently emits the JSON shape on every invocation\n265\t    // (the binding-facing contract); `--pretty` is allowed to be a\n266\t    // no-op in 0.6.0. The strict-machine guard for AC-038 is that\n267\t    // `--pretty` does NOT introduce a second JSON discriminator or\n268\t    // schema beyond what `--json` already pins. Assert the emitted\n269\t    // object — if any — uses the same `verb` discriminator.\n270\t    if let Ok(parsed) = serde_json::from_str::<Value>(stdout.trim()) {\n271\t        let obj = parsed.as_object().expect(\"object\");\n272\t        assert_eq!(\n273\t            obj.get(\"verb\").and_then(Value::as_str),\n274\t            Some(\"check-integrity\"),\n275\t            \"--pretty must not introduce a second machine schema; verb discriminator must \\\n276\t             match the one fixed by --json\",\n277\t        );\n278\t    }\n279\t    drop(dir);\n280\t}\n281\t\n282\t#[test]\n283\tfn t_045_lock_held_outcome_maps_to_exit_71() {\n284\t    // AC-045: opening a DB while another process holds the engine file\n285\t    // lock surfaces as `LOCK_HELD` (71). We acquire the lock in-process\n286\t    // by keeping an Engine open and invoking the CLI binary against the\n287\t    // same path.\n288\t    let dir = TempDir::new().expect(\"tempdir\");\n289\t    let db = dir.path().join(\"locked.sqlite\");\n290\t    let opened = Engine::open(db.clone()).expect(\"engine open\");\n291\t    let output = fathomdb()\n292\t        .args([\"doctor\", \"check-integrity\", \"--json\", db.to_str().unwrap()])\n293\t        .output()\n294\t        .expect(\"spawn\");\n295\t    assert_eq!(\n296\t        output.status.code(),\n297\t        Some(exit_code::LOCK_HELD),\n298\t        \"lock-held DB must exit LOCK_HELD (71); got {:?} stderr={}\",\n299\t        output.status,\n300\t        String::from_utf8_lossy(&output.stderr),\n301\t    );\n302\t    let stdout = String::from_utf8_lossy(&output.stdout);\n303\t    let parsed: Value = serde_json::from_str(stdout.trim())\n304\t        .unwrap_or_else(|e| panic!(\"lock-held stdout must be JSON; err={e} stdout={stdout}\"));\n305\t    let obj = parsed.as_object().expect(\"object\");\n306\t    assert_eq!(obj.get(\"status\").and_then(Value::as_str), Some(\"error\"));\n307\t    assert_eq!(obj.get(\"code\").and_then(Value::as_str), Some(\"DatabaseLockedError\"));\n308\t    opened.engine.close().expect(\"close\");\n309\t    drop(opened);\n310\t    drop(dir);\n311\t}\n312\t\n313\t#[test]\n314\tfn t_recover_excise_requires_accept_data_loss_runtime() {\n315\t    // Runtime guard pairs with AC-035d: `recover --excise-source` must\n316\t    // refuse without `--accept-data-loss` (and not contact the engine).\n317\t    let (dir, db) = seeded_db();\n318\t    let output = fathomdb()\n319\t        .args([\"recover\", \"--excise-source\", \"src-1\", db.to_str().unwrap()])\n320\t        .output()\n321\t        .expect(\"spawn\");\n322\t    assert_eq!(output.status.code(), Some(exit_code::UNRECOVERABLE));\n323\t    let stdout = String::from_utf8_lossy(&output.stdout);\n324\t    let parsed: Value = serde_json::from_str(stdout.trim()).expect(\"json\");\n325\t    assert_eq!(parsed.get(\"status\").and_then(Value::as_str), Some(\"refused\"));\n326\t    drop(dir);\n327\t}\n328\t\n329\t#[test]\n330\tfn t_recover_excise_source_with_accept_data_loss_succeeds() {\n331\t    // End-to-end happy path for `recover --excise-source` after\n332\t    // --accept-data-loss is supplied. Excising an unknown source id is\n333\t    // a no-op excise (counts == 0) — engine returns Ok and CLI maps to\n334\t    // RECOVERY_ACCEPTED_LOSS (64).\n335\t    let (dir, db) = seeded_db();\n336\t    let output = fathomdb()\n337\t        .args([\"recover\", \"--accept-data-loss\", \"--excise-source\", \"src-1\", db.to_str().unwrap()])\n338\t        .output()\n339\t        .expect(\"spawn\");\n340\t    assert_eq!(\n341\t        output.status.code(),\n342\t        Some(exit_code::RECOVERY_ACCEPTED_LOSS),\n343\t        \"recover --excise-source with --accept-data-loss must exit 64; got {:?} stderr={}\",\n344\t        output.status,\n345\t        String::from_utf8_lossy(&output.stderr),\n346\t    );\n347\t    let stdout = String::from_utf8_lossy(&output.stdout);\n348\t    let parsed: Value = serde_json::from_str(stdout.trim()).expect(\"json\");\n349\t    assert_eq!(parsed.get(\"verb\").and_then(Value::as_str), Some(\"excise-source\"));\n350\t    drop(dir);\n351\t}\n352\t\n353\t#[test]\n354\tfn t_safe_export_engine_error_exits_export_failure_66() {\n355\t    // `cli.md` § Error → exit-code mapping pins `doctor safe-export` failure\n356\t    // to class `artifact-fail` = exit 66. Trigger an engine error by\n357\t    // pointing the export target at a path inside a nonexistent directory\n358\t    // so the underlying `VACUUM INTO` step fails.\n359\t    let (dir, db) = seeded_db();\n360\t    let bad_out = dir.path().join(\"nonexistent\").join(\"export.sqlite\");\n361\t    let output = fathomdb()\n362\t        .args([\"doctor\", \"safe-export\", bad_out.to_str().unwrap(), db.to_str().unwrap(), \"--json\"])\n363\t        .output()\n364\t        .expect(\"spawn\");\n365\t    assert_eq!(\n366\t        output.status.code(),\n367\t        Some(exit_code::EXPORT_FAILURE),\n368\t        \"stdout: {}\\nstderr: {}\",\n369\t        String::from_utf8_lossy(&output.stdout),\n370\t        String::from_utf8_lossy(&output.stderr),\n371\t    );\n372\t    let stdout = String::from_utf8_lossy(&output.stdout);\n373\t    let v: Value = serde_json::from_str(stdout.trim()).expect(\"one json object\");\n374\t    assert_eq!(v.get(\"verb\").and_then(Value::as_str), Some(\"safe-export\"));\n375\t    assert_eq!(v.get(\"status\").and_then(Value::as_str), Some(\"error\"));\n376\t    drop(dir);\n377\t}\n378\t\n379\t#[test]\n380\tfn t_clap_parse_error_on_unknown_root_is_nonzero() {\n381\t    // Parser-level rejection is pinned by tests/parser.rs; this asserts the\n382\t    // built binary surfaces that rejection as a non-zero exit. The exact code\n383\t    // is clap's parse-error code (currently 2) and is intentionally NOT\n384\t    // pinned here — it is not part of `cli.md` § Exit-code classes.\n385\t    let output = fathomdb().args([\"destroy-everything\"]).output().expect(\"spawn\");\n386\t    assert!(\n387\t        !output.status.success(),\n388\t        \"unknown root command must exit non-zero; got {:?}\",\n389\t        output.status,\n390\t    );\n391\t}\n392\t"}]},"parent_tool_use_id":null,"session_id":"6045b345-74e5-4485-9471-2a1561990851","uuid":"7290e425-b5d0-4195-8c79-22b50a642c24","timestamp":"2026-05-15T23:43:22.718Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-10b-A-low-risk-seams-20260515T234104Z/src/rust/crates/fathomdb-cli/tests/operator_cli.rs","content":"//! Operator CLI invocability + output-shape assertions for the 0.6.0\n//! surface owned by `dev/interfaces/cli.md`.\n//!\n//! Bound ACs (invocability + shape):\n//!\n//! - AC-035d (CLI half): `fathomdb recover --help` exits 0; runtime refusal\n//!   without `--accept-data-loss`.\n//! - AC-036: every doctor verb supports `--json` machine-readable output.\n//! - AC-037: doctor verbs emit one JSON object on `--json` (single-object\n//!   contract, not NDJSON).\n//! - AC-038: `--pretty` is a human-only formatter, not a second machine\n//!   schema.\n//! - AC-040a: every `fathomdb doctor <verb> --help` exits 0.\n//! - AC-040b: every `fathomdb doctor <verb> --help` prints a `Usage:` line.\n//! - AC-045: opening a DB while another engine holds the lock surfaces as\n//!   exit code `exit_code::LOCK_HELD` (71).\n//! - AC-058: `fathomdb recover --help` enumerates the six recover sub-flags\n//!   plus `--accept-data-loss`.\n//!\n//! These tests invoke the built `fathomdb` binary via `env!(\"CARGO_BIN_EXE_*\")`\n//! so they exercise clap's runtime behavior, not just the parser surface\n//! pinned by `tests/parser.rs`.\n\nuse std::process::Command;\n\nuse fathomdb::Engine;\nuse fathomdb_cli::exit_code;\nuse serde_json::Value;\nuse tempfile::TempDir;\n\nconst DOCTOR_VERBS: &[&str] = &[\n    \"check-integrity\",\n    \"safe-export\",\n    \"verify-embedder\",\n    \"trace\",\n    \"dump-schema\",\n    \"dump-row-counts\",\n    \"dump-profile\",\n];\n\nconst RECOVER_FLAGS: &[&str] = &[\n    \"--truncate-wal\",\n    \"--rebuild-vec0\",\n    \"--rebuild-projections\",\n    \"--excise-source\",\n    \"--purge-logical-id\",\n    \"--restore-logical-id\",\n    \"--accept-data-loss\",\n];\n\nfn fathomdb() -> Command {\n    Command::new(env!(\"CARGO_BIN_EXE_fathomdb\"))\n}\n\n#[test]\nfn t_040a_every_doctor_verb_help_exits_zero() {\n    for verb in DOCTOR_VERBS {\n        let output = fathomdb()\n            .args([\"doctor\", verb, \"--help\"])\n            .output()\n            .unwrap_or_else(|e| panic!(\"failed to spawn fathomdb doctor {verb} --help: {e}\"));\n        assert!(\n            output.status.success(),\n            \"fathomdb doctor {verb} --help must exit 0; got {:?} stderr={}\",\n            output.status,\n            String::from_utf8_lossy(&output.stderr),\n        );\n    }\n}\n\n#[test]\nfn t_040b_every_doctor_verb_help_has_usage_section() {\n    for verb in DOCTOR_VERBS {\n        let output = fathomdb().args([\"doctor\", verb, \"--help\"]).output().expect(\"spawn\");\n        let stdout = String::from_utf8_lossy(&output.stdout);\n        assert!(\n            stdout.lines().any(|line| line.starts_with(\"Usage:\")),\n            \"fathomdb doctor {verb} --help must include a `Usage:` line; got:\\n{stdout}\",\n        );\n    }\n}\n\n#[test]\nfn t_035d_recover_help_exits_zero() {\n    let output = fathomdb().args([\"recover\", \"--help\"]).output().expect(\"spawn\");\n    assert!(\n        output.status.success(),\n        \"fathomdb recover --help must exit 0; got {:?} stderr={}\",\n        output.status,\n        String::from_utf8_lossy(&output.stderr),\n    );\n}\n\n#[test]\nfn t_058_recover_help_enumerates_canonical_flag_set() {\n    let output = fathomdb().args([\"recover\", \"--help\"]).output().expect(\"spawn\");\n    assert!(output.status.success(), \"recover --help must exit 0\");\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    for flag in RECOVER_FLAGS {\n        let count = stdout.matches(flag).count();\n        assert_eq!(\n            count, 1,\n            \"recover --help must mention {flag} exactly once; counted {count} in:\\n{stdout}\",\n        );\n    }\n}\n\n#[test]\nfn t_cli_doctor_rejects_accept_data_loss_binary() {\n    let output = fathomdb()\n        .args([\"doctor\", \"check-integrity\", \"--accept-data-loss\"])\n        .output()\n        .expect(\"spawn\");\n    assert!(\n        !output.status.success(),\n        \"fathomdb doctor check-integrity --accept-data-loss must fail; \\\n         clap should reject the flag (it is owned by `recover`)\",\n    );\n}\n\n/// Seeded DB fixture for tests that need a live engine. Opens, closes,\n/// and returns the path so the CLI binary can open it itself. The\n/// returned `TempDir` keeps the on-disk file alive for the test scope.\nfn seeded_db() -> (TempDir, std::path::PathBuf) {\n    let dir = TempDir::new().expect(\"tempdir\");\n    let path = dir.path().join(\"operator.sqlite\");\n    let opened = Engine::open(path.clone()).expect(\"engine open\");\n    opened.engine.close().expect(\"engine close\");\n    drop(opened);\n    (dir, path)\n}\n\n/// Argument vector for a doctor verb invocation against `db_path`.\nfn doctor_invocation(verb: &str, db_path: &str, out_path: &str) -> Vec<String> {\n    let mut argv = vec![\"doctor\".to_string(), verb.to_string()];\n    match verb {\n        \"safe-export\" => {\n            argv.push(out_path.to_string());\n        }\n        \"trace\" => {\n            argv.push(\"--source-ref\".to_string());\n            argv.push(\"src-test\".to_string());\n        }\n        _ => {}\n    }\n    argv.push(db_path.to_string());\n    argv\n}\n\n#[test]\nfn t_035d_recover_refuses_without_accept_data_loss() {\n    // AC-035d runtime: CLI refuses `recover` without `--accept-data-loss`\n    // before opening the engine. The DB path is positional and still\n    // required, but the guard runs before any engine interaction.\n    let (dir, db) = seeded_db();\n    let output = fathomdb()\n        .args([\"recover\", \"--truncate-wal\", db.to_str().unwrap()])\n        .output()\n        .expect(\"spawn\");\n    assert_eq!(\n        output.status.code(),\n        Some(exit_code::UNRECOVERABLE),\n        \"recover without --accept-data-loss must exit UNRECOVERABLE; got {:?} stderr={}\",\n        output.status,\n        String::from_utf8_lossy(&output.stderr),\n    );\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    let parsed: Value = serde_json::from_str(stdout.trim())\n        .unwrap_or_else(|e| panic!(\"refusal stdout must be JSON; err={e} stdout={stdout}\"));\n    let obj = parsed.as_object().expect(\"expected JSON object\");\n    assert_eq!(obj.get(\"status\").and_then(Value::as_str), Some(\"refused\"));\n    assert_eq!(obj.get(\"verb\").and_then(Value::as_str), Some(\"recover\"));\n    assert_eq!(\n        obj.get(\"code\").and_then(Value::as_str),\n        Some(\"E_RECOVER_REQUIRES_ACCEPT_DATA_LOSS\"),\n    );\n    drop(dir);\n}\n\n#[test]\nfn t_035d_runtime_doctor_rejects_accept_data_loss() {\n    // AC-035d runtime: doctor verbs reject `--accept-data-loss` at the\n    // parser layer, so the runtime binary surfaces a non-zero exit.\n    let output = fathomdb()\n        .args([\"doctor\", \"check-integrity\", \"--accept-data-loss\", \"/tmp/x.sqlite\"])\n        .output()\n        .expect(\"spawn\");\n    assert!(\n        !output.status.success(),\n        \"doctor must refuse --accept-data-loss; got {:?}\",\n        output.status,\n    );\n}\n\n#[test]\nfn t_036_every_doctor_verb_accepts_json_flag_on_binary() {\n    // AC-036: `--json` is machine-readable on every doctor verb. For\n    // verbs whose engine seam has landed we additionally assert the\n    // output parses as JSON; for stub verbs we accept the\n    // `not_implemented` JSON envelope.\n    let (dir, db) = seeded_db();\n    let out_path = dir.path().join(\"export.sqlite\");\n    for verb in DOCTOR_VERBS {\n        let mut argv = doctor_invocation(verb, db.to_str().unwrap(), out_path.to_str().unwrap());\n        // Insert --json before the trailing db-path positional. For verbs\n        // with no other positional, that means before the db path.\n        let db_index = argv.len() - 1;\n        argv.insert(db_index, \"--json\".to_string());\n        let output = fathomdb().args(&argv).output().expect(\"spawn\");\n        let stdout = String::from_utf8_lossy(&output.stdout);\n        let trimmed = stdout.trim();\n        assert!(\n            !trimmed.is_empty(),\n            \"doctor {verb} --json must emit something on stdout; got empty\",\n        );\n        serde_json::from_str::<Value>(trimmed).unwrap_or_else(|e| {\n            panic!(\"doctor {verb} --json stdout must parse as JSON; err={e} stdout={stdout}\")\n        });\n    }\n    drop(dir);\n}\n\n#[test]\nfn t_037_doctor_verbs_emit_single_json_object() {\n    // AC-037: each doctor verb emits exactly one JSON object (not NDJSON).\n    let (dir, db) = seeded_db();\n    let out_path = dir.path().join(\"export.sqlite\");\n    for verb in DOCTOR_VERBS {\n        let mut argv = doctor_invocation(verb, db.to_str().unwrap(), out_path.to_str().unwrap());\n        let db_index = argv.len() - 1;\n        argv.insert(db_index, \"--json\".to_string());\n        let output = fathomdb().args(&argv).output().expect(\"spawn\");\n        let stdout = String::from_utf8_lossy(&output.stdout);\n        let trimmed = stdout.trim();\n        let parsed: Value = serde_json::from_str(trimmed).unwrap_or_else(|e| {\n            panic!(\"doctor {verb} --json must be parseable; err={e} stdout={stdout}\")\n        });\n        assert!(\n            parsed.is_object(),\n            \"doctor {verb} --json must produce a single JSON object; got {parsed:?}\",\n        );\n        // Single-object contract: no trailing newline-delimited extras.\n        assert_eq!(\n            trimmed.lines().count(),\n            trimmed.lines().filter(|l| !l.is_empty()).count(),\n            \"doctor {verb} --json must not contain blank lines (NDJSON guard)\",\n        );\n    }\n    drop(dir);\n}\n\n#[test]\nfn t_038_pretty_is_human_only_not_machine_schema() {\n    // AC-038: `--pretty` is a human formatter only. `doctor\n    // check-integrity --pretty` (without `--json`) must NOT produce a\n    // parseable JSON object — it is human output, not a second machine\n    // contract. (Adding `--json` opts into the machine schema.)\n    let (dir, db) = seeded_db();\n    let output = fathomdb()\n        .args([\"doctor\", \"check-integrity\", \"--pretty\", db.to_str().unwrap()])\n        .output()\n        .expect(\"spawn\");\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    // The runtime currently emits the JSON shape on every invocation\n    // (the binding-facing contract); `--pretty` is allowed to be a\n    // no-op in 0.6.0. The strict-machine guard for AC-038 is that\n    // `--pretty` does NOT introduce a second JSON discriminator or\n    // schema beyond what `--json` already pins. Assert the emitted\n    // object — if any — uses the same `verb` discriminator.\n    if let Ok(parsed) = serde_json::from_str::<Value>(stdout.trim()) {\n        let obj = parsed.as_object().expect(\"object\");\n        assert_eq!(\n            obj.get(\"verb\").and_then(Value::as_str),\n            Some(\"check-integrity\"),\n            \"--pretty must not introduce a second machine schema; verb discriminator must \\\n             match the one fixed by --json\",\n        );\n    }\n    drop(dir);\n}\n\n#[test]\nfn t_045_lock_held_outcome_maps_to_exit_71() {\n    // AC-045: opening a DB while another process holds the engine file\n    // lock surfaces as `LOCK_HELD` (71). We acquire the lock in-process\n    // by keeping an Engine open and invoking the CLI binary against the\n    // same path.\n    let dir = TempDir::new().expect(\"tempdir\");\n    let db = dir.path().join(\"locked.sqlite\");\n    let opened = Engine::open(db.clone()).expect(\"engine open\");\n    let output = fathomdb()\n        .args([\"doctor\", \"check-integrity\", \"--json\", db.to_str().unwrap()])\n        .output()\n        .expect(\"spawn\");\n    assert_eq!(\n        output.status.code(),\n        Some(exit_code::LOCK_HELD),\n        \"lock-held DB must exit LOCK_HELD (71); got {:?} stderr={}\",\n        output.status,\n        String::from_utf8_lossy(&output.stderr),\n    );\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    let parsed: Value = serde_json::from_str(stdout.trim())\n        .unwrap_or_else(|e| panic!(\"lock-held stdout must be JSON; err={e} stdout={stdout}\"));\n    let obj = parsed.as_object().expect(\"object\");\n    assert_eq!(obj.get(\"status\").and_then(Value::as_str), Some(\"error\"));\n    assert_eq!(obj.get(\"code\").and_then(Value::as_str), Some(\"DatabaseLockedError\"));\n    opened.engine.close().expect(\"close\");\n    drop(opened);\n    drop(dir);\n}\n\n#[test]\nfn t_recover_excise_requires_accept_data_loss_runtime() {\n    // Runtime guard pairs with AC-035d: `recover --excise-source` must\n    // refuse without `--accept-data-loss` (and not contact the engine).\n    let (dir, db) = seeded_db();\n    let output = fathomdb()\n        .args([\"recover\", \"--excise-source\", \"src-1\", db.to_str().unwrap()])\n        .output()\n        .expect(\"spawn\");\n    assert_eq!(output.status.code(), Some(exit_code::UNRECOVERABLE));\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    let parsed: Value = serde_json::from_str(stdout.trim()).expect(\"json\");\n    assert_eq!(parsed.get(\"status\").and_then(Value::as_str), Some(\"refused\"));\n    drop(dir);\n}\n\n#[test]\nfn t_recover_excise_source_with_accept_data_loss_succeeds() {\n    // End-to-end happy path for `recover --excise-source` after\n    // --accept-data-loss is supplied. Excising an unknown source id is\n    // a no-op excise (counts == 0) — engine returns Ok and CLI maps to\n    // RECOVERY_ACCEPTED_LOSS (64).\n    let (dir, db) = seeded_db();\n    let output = fathomdb()\n        .args([\"recover\", \"--accept-data-loss\", \"--excise-source\", \"src-1\", db.to_str().unwrap()])\n        .output()\n        .expect(\"spawn\");\n    assert_eq!(\n        output.status.code(),\n        Some(exit_code::RECOVERY_ACCEPTED_LOSS),\n        \"recover --excise-source with --accept-data-loss must exit 64; got {:?} stderr={}\",\n        output.status,\n        String::from_utf8_lossy(&output.stderr),\n    );\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    let parsed: Value = serde_json::from_str(stdout.trim()).expect(\"json\");\n    assert_eq!(parsed.get(\"verb\").and_then(Value::as_str), Some(\"excise-source\"));\n    drop(dir);\n}\n\n#[test]\nfn t_safe_export_engine_error_exits_export_failure_66() {\n    // `cli.md` § Error → exit-code mapping pins `doctor safe-export` failure\n    // to class `artifact-fail` = exit 66. Trigger an engine error by\n    // pointing the export target at a path inside a nonexistent directory\n    // so the underlying `VACUUM INTO` step fails.\n    let (dir, db) = seeded_db();\n    let bad_out = dir.path().join(\"nonexistent\").join(\"export.sqlite\");\n    let output = fathomdb()\n        .args([\"doctor\", \"safe-export\", bad_out.to_str().unwrap(), db.to_str().unwrap(), \"--json\"])\n        .output()\n        .expect(\"spawn\");\n    assert_eq!(\n        output.status.code(),\n        Some(exit_code::EXPORT_FAILURE),\n        \"stdout: {}\\nstderr: {}\",\n        String::from_utf8_lossy(&output.stdout),\n        String::from_utf8_lossy(&output.stderr),\n    );\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    let v: Value = serde_json::from_str(stdout.trim()).expect(\"one json object\");\n    assert_eq!(v.get(\"verb\").and_then(Value::as_str), Some(\"safe-export\"));\n    assert_eq!(v.get(\"status\").and_then(Value::as_str), Some(\"error\"));\n    drop(dir);\n}\n\n#[test]\nfn t_clap_parse_error_on_unknown_root_is_nonzero() {\n    // Parser-level rejection is pinned by tests/parser.rs; this asserts the\n    // built binary surfaces that rejection as a non-zero exit. The exact code\n    // is clap's parse-error code (currently 2) and is intentionally NOT\n    // pinned here — it is not part of `cli.md` § Exit-code classes.\n    let output = fathomdb().args([\"destroy-everything\"]).output().expect(\"spawn\");\n    assert!(\n        !output.status.success(),\n        \"unknown root command must exit non-zero; got {:?}\",\n        output.status,\n    );\n}\n","numLines":392,"startLine":1,"totalLines":392}}}
