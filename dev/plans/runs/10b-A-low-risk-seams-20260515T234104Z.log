{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QZscwnVxGxR5NsErgR5sJg","type":"tool_result","content":"1\tuse fathomdb_engine::{Engine, PreparedWrite};\n2\tuse fathomdb_schema::SQLITE_SUFFIX;\n3\tuse sha2::{Digest, Sha256};\n4\tuse tempfile::TempDir;\n5\t\n6\tfn db_path(dir: &TempDir, name: &str) -> std::path::PathBuf {\n7\t    dir.path().join(format!(\"{name}{SQLITE_SUFFIX}\"))\n8\t}\n9\t\n10\t#[test]\n11\tfn ac_039a_manifest_digest_matches_export_bytes() {\n12\t    let dir = TempDir::new().unwrap();\n13\t    let path = db_path(&dir, \"export_match\");\n14\t    let opened = Engine::open(&path).expect(\"open\");\n15\t    opened\n16\t        .engine\n17\t        .write(&[PreparedWrite::Node {\n18\t            kind: \"doc\".to_string(),\n19\t            body: \"hello world\".to_string(),\n20\t            source_id: None,\n21\t        }])\n22\t        .expect(\"write\");\n23\t\n24\t    let out_dir = TempDir::new().unwrap();\n25\t    let out_path = out_dir.path().join(\"export.sqlite\");\n26\t    let manifest_path = out_dir.path().join(\"export.sha256.json\");\n27\t\n28\t    let artifact = opened.engine.safe_export(&out_path, &manifest_path).expect(\"safe_export\");\n29\t\n30\t    assert!(out_path.exists(), \"export file missing\");\n31\t    assert!(manifest_path.exists(), \"manifest missing\");\n32\t\n33\t    let bytes = std::fs::read(&out_path).expect(\"read export\");\n34\t    let expected = format!(\"{:x}\", Sha256::digest(&bytes));\n35\t    assert_eq!(artifact.manifest_sha256, expected);\n36\t\n37\t    let manifest: serde_json::Value =\n38\t        serde_json::from_slice(&std::fs::read(&manifest_path).unwrap()).unwrap();\n39\t    assert_eq!(manifest[\"sha256\"].as_str().unwrap(), expected);\n40\t    assert_eq!(manifest[\"byte_count\"].as_u64().unwrap(), bytes.len() as u64);\n41\t    assert!(manifest[\"export_path\"].as_str().is_some());\n42\t}\n43\t\n44\t#[test]\n45\tfn ac_039b_one_byte_tamper_detected_by_recompute() {\n46\t    let dir = TempDir::new().unwrap();\n47\t    let path = db_path(&dir, \"export_tamper\");\n48\t    let opened = Engine::open(&path).expect(\"open\");\n49\t    opened\n50\t        .engine\n51\t        .write(&[PreparedWrite::Node {\n52\t            kind: \"doc\".to_string(),\n53\t            body: \"hello tamper\".to_string(),\n54\t            source_id: None,\n55\t        }])\n56\t        .expect(\"write\");\n57\t\n58\t    let out_dir = TempDir::new().unwrap();\n59\t    let out_path = out_dir.path().join(\"export.sqlite\");\n60\t    let manifest_path = out_dir.path().join(\"export.sha256.json\");\n61\t    let artifact = opened.engine.safe_export(&out_path, &manifest_path).expect(\"safe_export\");\n62\t\n63\t    let mut bytes = std::fs::read(&out_path).expect(\"read\");\n64\t    let last = bytes.len() - 1;\n65\t    bytes[last] ^= 0x01;\n66\t    std::fs::write(&out_path, &bytes).expect(\"rewrite\");\n67\t\n68\t    let recomputed = format!(\"{:x}\", Sha256::digest(&bytes));\n69\t    assert_ne!(recomputed, artifact.manifest_sha256, \"tamper not detected\");\n70\t}\n71\t"}]},"parent_tool_use_id":null,"session_id":"6045b345-74e5-4485-9471-2a1561990851","uuid":"8ed05ed4-dd45-4ec3-bff8-eaf1f5b84479","timestamp":"2026-05-15T23:43:19.982Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-10b-A-low-risk-seams-20260515T234104Z/src/rust/crates/fathomdb-engine/tests/safe_export.rs","content":"use fathomdb_engine::{Engine, PreparedWrite};\nuse fathomdb_schema::SQLITE_SUFFIX;\nuse sha2::{Digest, Sha256};\nuse tempfile::TempDir;\n\nfn db_path(dir: &TempDir, name: &str) -> std::path::PathBuf {\n    dir.path().join(format!(\"{name}{SQLITE_SUFFIX}\"))\n}\n\n#[test]\nfn ac_039a_manifest_digest_matches_export_bytes() {\n    let dir = TempDir::new().unwrap();\n    let path = db_path(&dir, \"export_match\");\n    let opened = Engine::open(&path).expect(\"open\");\n    opened\n        .engine\n        .write(&[PreparedWrite::Node {\n            kind: \"doc\".to_string(),\n            body: \"hello world\".to_string(),\n            source_id: None,\n        }])\n        .expect(\"write\");\n\n    let out_dir = TempDir::new().unwrap();\n    let out_path = out_dir.path().join(\"export.sqlite\");\n    let manifest_path = out_dir.path().join(\"export.sha256.json\");\n\n    let artifact = opened.engine.safe_export(&out_path, &manifest_path).expect(\"safe_export\");\n\n    assert!(out_path.exists(), \"export file missing\");\n    assert!(manifest_path.exists(), \"manifest missing\");\n\n    let bytes = std::fs::read(&out_path).expect(\"read export\");\n    let expected = format!(\"{:x}\", Sha256::digest(&bytes));\n    assert_eq!(artifact.manifest_sha256, expected);\n\n    let manifest: serde_json::Value =\n        serde_json::from_slice(&std::fs::read(&manifest_path).unwrap()).unwrap();\n    assert_eq!(manifest[\"sha256\"].as_str().unwrap(), expected);\n    assert_eq!(manifest[\"byte_count\"].as_u64().unwrap(), bytes.len() as u64);\n    assert!(manifest[\"export_path\"].as_str().is_some());\n}\n\n#[test]\nfn ac_039b_one_byte_tamper_detected_by_recompute() {\n    let dir = TempDir::new().unwrap();\n    let path = db_path(&dir, \"export_tamper\");\n    let opened = Engine::open(&path).expect(\"open\");\n    opened\n        .engine\n        .write(&[PreparedWrite::Node {\n            kind: \"doc\".to_string(),\n            body: \"hello tamper\".to_string(),\n            source_id: None,\n        }])\n        .expect(\"write\");\n\n    let out_dir = TempDir::new().unwrap();\n    let out_path = out_dir.path().join(\"export.sqlite\");\n    let manifest_path = out_dir.path().join(\"export.sha256.json\");\n    let artifact = opened.engine.safe_export(&out_path, &manifest_path).expect(\"safe_export\");\n\n    let mut bytes = std::fs::read(&out_path).expect(\"read\");\n    let last = bytes.len() - 1;\n    bytes[last] ^= 0x01;\n    std::fs::write(&out_path, &bytes).expect(\"rewrite\");\n\n    let recomputed = format!(\"{:x}\", Sha256::digest(&bytes));\n    assert_ne!(recomputed, artifact.manifest_sha256, \"tamper not detected\");\n}\n","numLines":71,"startLine":1,"totalLines":71}}}
