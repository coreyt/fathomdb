{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GdDrve1N84cnhi1SseS1XA","type":"tool_result","content":"1\t//! End-to-end CLI binary assertions for Phase 10a recovery + doctor verbs.\n2\t//!\n3\t//! These tests invoke the built `fathomdb` binary against a seeded engine,\n4\t//! parse the emitted JSON, and confirm the per-verb output contract owned\n5\t//! by `dev/interfaces/cli.md` § JSON output wrapping and the AC matrix in\n6\t//! `dev/design/recovery.md` § JSON shapes for other doctor verbs.\n7\t//!\n8\t//! ACs bound live in Phase 10a (CLI binary half):\n9\t//!\n10\t//! - AC-028a/b/c: `recover --excise-source` end-to-end CLI surface.\n11\t//! - AC-039a: `doctor safe-export` emits SHA-256 manifest path.\n12\t//! - AC-042: `doctor trace --source-ref` enumerates canonical rows.\n13\t//! - AC-043a/b: `doctor check-integrity` reports three sections, each\n14\t//!   `clean` or `findings`.\n15\t//! - AC-044, AC-063c: `recover --rebuild-projections` runs end-to-end.\n16\t//!\n17\t//! ACs still ignored with Phase-10a-specific dependencies:\n18\t//!\n19\t//! - AC-026: WAL-only-commit fixture not yet shared with CLI tests.\n20\t//! - AC-027a/b/c/d: pre/post vec0-rebuild canonical+FTS+vector parity\n21\t//!   harness lives in engine-side tests; not yet replayed through CLI.\n22\t//! - AC-039b: tampered-artifact verifier seam not yet landed.\n23\t//! - AC-043c: full-mode page-corruption fixture not exposed to CLI tests.\n24\t\n25\tuse std::path::PathBuf;\n26\tuse std::process::Command;\n27\t\n28\tuse fathomdb::{Engine, PreparedWrite};\n29\tuse fathomdb_cli::exit_code;\n30\tuse serde_json::Value;\n31\tuse tempfile::TempDir;\n32\t\n33\tfn fathomdb() -> Command {\n34\t    Command::new(env!(\"CARGO_BIN_EXE_fathomdb\"))\n35\t}\n36\t\n37\tfn seeded_db() -> (TempDir, PathBuf) {\n38\t    let dir = TempDir::new().expect(\"tempdir\");\n39\t    let path = dir.path().join(\"recovery.sqlite\");\n40\t    let opened = Engine::open(path.clone()).expect(\"open\");\n41\t    opened.engine.close().expect(\"close\");\n42\t    drop(opened);\n43\t    (dir, path)\n44\t}\n45\t\n46\tfn db_with_sources() -> (TempDir, PathBuf) {\n47\t    let dir = TempDir::new().expect(\"tempdir\");\n48\t    let path = dir.path().join(\"recovery.sqlite\");\n49\t    let opened = Engine::open(path.clone()).expect(\"open\");\n50\t    opened\n51\t        .engine\n52\t        .write(&[PreparedWrite::Node {\n53\t            kind: \"doc\".to_string(),\n54\t            body: \"alpha\".to_string(),\n55\t            source_id: Some(\"src-a\".to_string()),\n56\t        }])\n57\t        .expect(\"write a\");\n58\t    opened\n59\t        .engine\n60\t        .write(&[PreparedWrite::Node {\n61\t            kind: \"doc\".to_string(),\n62\t            body: \"beta\".to_string(),\n63\t            source_id: Some(\"src-a\".to_string()),\n64\t        }])\n65\t        .expect(\"write a2\");\n66\t    opened\n67\t        .engine\n68\t        .write(&[PreparedWrite::Node {\n69\t            kind: \"doc\".to_string(),\n70\t            body: \"gamma\".to_string(),\n71\t            source_id: Some(\"src-b\".to_string()),\n72\t        }])\n73\t        .expect(\"write b\");\n74\t    opened.engine.close().expect(\"close\");\n75\t    drop(opened);\n76\t    (dir, path)\n77\t}\n78\t\n79\tfn run_json(args: &[&str]) -> (Option<i32>, Value) {\n80\t    let output = fathomdb().args(args).output().expect(\"spawn\");\n81\t    let stdout = String::from_utf8_lossy(&output.stdout);\n82\t    let parsed: Value = serde_json::from_str(stdout.trim())\n83\t        .unwrap_or_else(|e| panic!(\"stdout must be JSON; err={e} stdout={stdout}\"));\n84\t    (output.status.code(), parsed)\n85\t}\n86\t\n87\t#[test]\n88\tfn t_028a_excise_source_cli_returns_excise_report() {\n89\t    // AC-028a CLI half: `recover --accept-data-loss --excise-source <id>`\n90\t    // exits 64 (RECOVERY_ACCEPTED_LOSS) and emits a JSON envelope keyed\n91\t    // by `verb: \"excise-source\"` with the canonical excise report\n92\t    // counts. Engine-side audit-row contract is bound by\n93\t    // `tests/excise_source.rs::ac_028a_*`.\n94\t    let (dir, db) = db_with_sources();\n95\t    let (code, parsed) = run_json(&[\n96\t        \"recover\",\n97\t        \"--accept-data-loss\",\n98\t        \"--excise-source\",\n99\t        \"src-a\",\n100\t        db.to_str().unwrap(),\n101\t    ]);\n102\t    assert_eq!(code, Some(exit_code::RECOVERY_ACCEPTED_LOSS));\n103\t    assert_eq!(parsed.get(\"verb\").and_then(Value::as_str), Some(\"excise-source\"));\n104\t    assert_eq!(parsed.get(\"source_ref\").and_then(Value::as_str), Some(\"src-a\"));\n105\t    assert_eq!(parsed.get(\"nodes_excised\").and_then(Value::as_u64), Some(2));\n106\t    drop(dir);\n107\t}\n108\t\n109\t#[test]\n110\tfn t_028b_excise_source_cli_reports_projections_invalidated_field() {\n111\t    // AC-028b CLI half: the emitted report includes the\n112\t    // `projections_invalidated` field so binding consumers can detect\n113\t    // shadow-state removal. Engine-side residue assertion is bound by\n114\t    // `tests/excise_source.rs::ac_028b_*`.\n115\t    let (dir, db) = db_with_sources();\n116\t    let (_code, parsed) = run_json(&[\n117\t        \"recover\",\n118\t        \"--accept-data-loss\",\n119\t        \"--excise-source\",\n120\t        \"src-a\",\n121\t        db.to_str().unwrap(),\n122\t    ]);\n123\t    assert!(\n124\t        parsed.get(\"projections_invalidated\").is_some(),\n125\t        \"CLI report must include projections_invalidated; got {parsed:?}\",\n126\t    );\n127\t    drop(dir);\n128\t}\n129\t\n130\t#[test]\n131\tfn t_028c_excise_source_cli_isolates_non_excised_sources() {\n132\t    // AC-028c CLI half: excising one source leaves the other source's\n133\t    // rows queryable. After excise, run trace on the un-excised source\n134\t    // and confirm its canonical-row events survive.\n135\t    let (dir, db) = db_with_sources();\n136\t    let (_code, _excise) = run_json(&[\n137\t        \"recover\",\n138\t        \"--accept-data-loss\",\n139\t        \"--excise-source\",\n140\t        \"src-a\",\n141\t        db.to_str().unwrap(),\n142\t    ]);\n143\t    let (code, parsed) =\n144\t        run_json(&[\"doctor\", \"trace\", \"--source-ref\", \"src-b\", db.to_str().unwrap()]);\n145\t    assert_eq!(code, Some(exit_code::OK));\n146\t    let events = parsed.get(\"events\").and_then(Value::as_array).expect(\"events array\");\n147\t    assert_eq!(events.len(), 1, \"src-b must still have its one event after src-a excise\");\n148\t    drop(dir);\n149\t}\n150\t\n151\t#[test]\n152\tfn t_039a_safe_export_cli_emits_manifest_sha256_field() {\n153\t    // AC-039a CLI half: doctor safe-export emits JSON with\n154\t    // `export_path`, `manifest_path`, `manifest_sha256`. Engine-side\n155\t    // file-bytes equality with the manifest is bound by\n156\t    // `tests/safe_export.rs`.\n157\t    let (dir, db) = seeded_db();\n158\t    let out = dir.path().join(\"export.sqlite\");\n159\t    let manifest = dir.path().join(\"export.manifest.json\");\n160\t    let (code, parsed) = run_json(&[\n161\t        \"doctor\",\n162\t        \"safe-export\",\n163\t        out.to_str().unwrap(),\n164\t        \"--manifest\",\n165\t        manifest.to_str().unwrap(),\n166\t        db.to_str().unwrap(),\n167\t    ]);\n168\t    assert_eq!(code, Some(exit_code::OK));\n169\t    assert_eq!(parsed.get(\"verb\").and_then(Value::as_str), Some(\"safe-export\"));\n170\t    let sha = parsed.get(\"manifest_sha256\").and_then(Value::as_str).expect(\"sha256 field\");\n171\t    assert_eq!(sha.len(), 64, \"sha256 hex must be 64 chars; got {sha}\");\n172\t    assert!(out.exists(), \"exported DB file must exist\");\n173\t    assert!(manifest.exists(), \"manifest sidecar must exist\");\n174\t    drop(dir);\n175\t}\n176\t\n177\t#[test]\n178\tfn t_042_trace_cli_enumerates_canonical_rows_for_source() {\n179\t    // AC-042 CLI half: `doctor trace --source-ref <id>` returns one\n180\t    // event per canonical row attributable to the source, ordered by\n181\t    // `write_cursor`. Engine-side ordering invariant is bound by\n182\t    // `tests/*` engine tests; this asserts the CLI JSON envelope.\n183\t    let (dir, db) = db_with_sources();\n184\t    let (code, parsed) =\n185\t        run_json(&[\"doctor\", \"trace\", \"--source-ref\", \"src-a\", db.to_str().unwrap()]);\n186\t    assert_eq!(code, Some(exit_code::OK));\n187\t    assert_eq!(parsed.get(\"verb\").and_then(Value::as_str), Some(\"trace\"));\n188\t    assert_eq!(parsed.get(\"source_ref\").and_then(Value::as_str), Some(\"src-a\"));\n189\t    let events = parsed.get(\"events\").and_then(Value::as_array).expect(\"events array\");\n190\t    assert_eq!(events.len(), 2);\n191\t    let cursors: Vec<u64> =\n192\t        events.iter().filter_map(|e| e.get(\"write_cursor\").and_then(Value::as_u64)).collect();\n193\t    assert!(cursors.windows(2).all(|w| w[0] <= w[1]), \"events must be cursor-ordered: {cursors:?}\");\n194\t    drop(dir);\n195\t}\n196\t\n197\t#[test]\n198\tfn t_043a_check_integrity_cli_emits_three_sections() {\n199\t    // AC-043a CLI half: integrity report has top-level keys\n200\t    // `physical`, `logical`, `semantic`. Engine-side three-section\n201\t    // contract is bound by `tests/check_integrity.rs`.\n202\t    let (dir, db) = seeded_db();\n203\t    let (_code, parsed) = run_json(&[\"doctor\", \"check-integrity\", db.to_str().unwrap()]);\n204\t    assert_eq!(parsed.get(\"verb\").and_then(Value::as_str), Some(\"check-integrity\"));\n205\t    assert!(parsed.get(\"physical\").is_some(), \"physical key missing: {parsed:?}\");\n206\t    assert!(parsed.get(\"logical\").is_some(), \"logical key missing: {parsed:?}\");\n207\t    assert!(parsed.get(\"semantic\").is_some(), \"semantic key missing: {parsed:?}\");\n208\t    drop(dir);\n209\t}\n210\t\n211\t#[test]\n212\tfn t_043b_check_integrity_cli_each_section_clean_or_findings() {\n213\t    // AC-043b CLI half: every section's machine shape is either\n214\t    // {status:\"clean\", findings:[]} or {status:\"findings\", findings:[...]}.\n215\t    // On a clean seeded DB every section is `clean`.\n216\t    let (dir, db) = seeded_db();\n217\t    let (code, parsed) = run_json(&[\"doctor\", \"check-integrity\", db.to_str().unwrap()]);\n218\t    assert_eq!(code, Some(exit_code::OK), \"clean DB must exit 0; got {code:?}\");\n219\t    for key in [\"physical\", \"logical\", \"semantic\"] {\n220\t        let section = parsed.get(key).expect(\"section\");\n221\t        let status = section.get(\"status\").and_then(Value::as_str).expect(\"status\");\n222\t        assert!(\n223\t            status == \"clean\" || status == \"findings\",\n224\t            \"section {key} status must be clean|findings; got {status}\",\n225\t        );\n226\t        let findings = section.get(\"findings\").and_then(Value::as_array).expect(\"findings array\");\n227\t        if status == \"clean\" {\n228\t            assert!(findings.is_empty(), \"clean section must have empty findings\");\n229\t        }\n230\t    }\n231\t    drop(dir);\n232\t}\n233\t\n234\t#[test]\n235\tfn t_044_recover_rebuild_projections_cli_runs_end_to_end() {\n236\t    // AC-044 CLI half: `recover --accept-data-loss --rebuild-projections`\n237\t    // exits 64 and emits a rebuild report with the\n238\t    // `projection_cursor_after` field. Engine-side projection-rebuild\n239\t    // semantics are bound by `tests/rebuild_projections.rs`.\n240\t    let (dir, db) = seeded_db();\n241\t    let (code, parsed) =\n242\t        run_json(&[\"recover\", \"--accept-data-loss\", \"--rebuild-projections\", db.to_str().unwrap()]);\n243\t    assert_eq!(code, Some(exit_code::RECOVERY_ACCEPTED_LOSS));\n244\t    assert_eq!(parsed.get(\"verb\").and_then(Value::as_str), Some(\"rebuild-projections\"));\n245\t    assert!(\n246\t        parsed.get(\"projection_cursor_after\").is_some(),\n247\t        \"rebuild report must carry projection_cursor_after\",\n248\t    );\n249\t    drop(dir);\n250\t}\n251\t\n252\t#[test]\n253\tfn t_063c_recover_rebuild_projections_cli_regenerate_workflow() {\n254\t    // AC-063c CLI half: `recover --rebuild-projections` is the\n255\t    // canonical regenerate workflow. Confirm the CLI binds it as the\n256\t    // landed engine seam, with `kind: \"projections\"` discriminator.\n257\t    let (dir, db) = seeded_db();\n258\t    let (_code, parsed) =\n259\t        run_json(&[\"recover\", \"--accept-data-loss\", \"--rebuild-projections\", db.to_str().unwrap()]);\n260\t    assert_eq!(parsed.get(\"kind\").and_then(Value::as_str), Some(\"projections\"));\n261\t    drop(dir);\n262\t}\n263\t\n264\t// ---- Still ignored: fixture / engine-seam gaps remain ----\n265\t\n266\t#[test]\n267\t#[ignore = \"AC-026: dep-Phase-10a-wal-only-fixture; safe-export seam landed, but the WAL-only-commit setup harness is not yet shared with CLI tests\"]\n268\tfn t_026_safe_export_covers_wal_only_commits() {\n269\t    let _bin = env!(\"CARGO_BIN_EXE_fathomdb\");\n270\t    unimplemented!(\"AC-026 awaits a CLI-side WAL-only-commit fixture\");\n271\t}\n272\t\n273\t#[test]\n274\t#[ignore = \"AC-027a: dep-Phase-10a-vec0-rebuild-pre-post-canonical-compare; engine-side fixture not shared with CLI\"]\n275\tfn t_027a_recovery_preserves_canonical_rows() {\n276\t    let _bin = env!(\"CARGO_BIN_EXE_fathomdb\");\n277\t    unimplemented!(\"AC-027a awaits CLI-side pre/post canonical-row compare fixture\");\n278\t}\n279\t\n280\t#[test]\n281\t#[ignore = \"AC-027b: dep-Phase-10a-fts-result-equality; CLI-side FTS query parity harness not yet wired\"]\n282\tfn t_027b_recovery_preserves_fts_query_result_equality() {\n283\t    let _bin = env!(\"CARGO_BIN_EXE_fathomdb\");\n284\t    unimplemented!(\"AC-027b awaits CLI-side FTS pre/post compare fixture\");\n285\t}\n286\t\n287\t#[test]\n288\t#[ignore = \"AC-027c: dep-Phase-10a-vector-profile-bit-equal; CLI-side vector-profile metadata compare not yet wired\"]\n289\tfn t_027c_recovery_preserves_vector_profile_metadata_bit_equal() {\n290\t    let _bin = env!(\"CARGO_BIN_EXE_fathomdb\");\n291\t    unimplemented!(\"AC-027c awaits CLI-side vector-profile metadata compare fixture\");\n292\t}\n293\t\n294\t#[test]\n295\t#[ignore = \"AC-027d: dep-Phase-10a-vector-top-k-rank-correlation; rank-correlation harness lives in engine tests\"]\n296\tfn t_027d_recovery_preserves_vector_top_k_rank_correlation() {\n297\t    let _bin = env!(\"CARGO_BIN_EXE_fathomdb\");\n298\t    unimplemented!(\"AC-027d awaits CLI-side rank-correlation harness\");\n299\t}\n300\t\n301\t#[test]\n302\t#[ignore = \"AC-039b: dep-Phase-10a-safe-export-tamper-verifier; engine has no verify-manifest seam yet\"]\n303\tfn t_039b_safe_export_tampered_artifact_detected() {\n304\t    let _bin = env!(\"CARGO_BIN_EXE_fathomdb\");\n305\t    unimplemented!(\"AC-039b awaits a safe-export verifier seam\");\n306\t}\n307\t\n308\t#[test]\n309\t#[ignore = \"AC-043c: dep-Phase-10a-page-corruption-fixture; CLI-side page-corruption helper not yet exposed\"]\n310\tfn t_043c_check_integrity_full_findings_carry_stable_report_fields() {\n311\t    let _bin = env!(\"CARGO_BIN_EXE_fathomdb\");\n312\t    unimplemented!(\n313\t        \"AC-043c awaits a CLI-side page-corruption helper to surface --full integrity findings\"\n314\t    );\n315\t}\n316\t"}]},"parent_tool_use_id":null,"session_id":"6045b345-74e5-4485-9471-2a1561990851","uuid":"d3751cf9-0db5-4767-8c89-87071fbd4972","timestamp":"2026-05-15T23:43:26.369Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-10b-A-low-risk-seams-20260515T234104Z/src/rust/crates/fathomdb-cli/tests/recovery_cli.rs","content":"//! End-to-end CLI binary assertions for Phase 10a recovery + doctor verbs.\n//!\n//! These tests invoke the built `fathomdb` binary against a seeded engine,\n//! parse the emitted JSON, and confirm the per-verb output contract owned\n//! by `dev/interfaces/cli.md` § JSON output wrapping and the AC matrix in\n//! `dev/design/recovery.md` § JSON shapes for other doctor verbs.\n//!\n//! ACs bound live in Phase 10a (CLI binary half):\n//!\n//! - AC-028a/b/c: `recover --excise-source` end-to-end CLI surface.\n//! - AC-039a: `doctor safe-export` emits SHA-256 manifest path.\n//! - AC-042: `doctor trace --source-ref` enumerates canonical rows.\n//! - AC-043a/b: `doctor check-integrity` reports three sections, each\n//!   `clean` or `findings`.\n//! - AC-044, AC-063c: `recover --rebuild-projections` runs end-to-end.\n//!\n//! ACs still ignored with Phase-10a-specific dependencies:\n//!\n//! - AC-026: WAL-only-commit fixture not yet shared with CLI tests.\n//! - AC-027a/b/c/d: pre/post vec0-rebuild canonical+FTS+vector parity\n//!   harness lives in engine-side tests; not yet replayed through CLI.\n//! - AC-039b: tampered-artifact verifier seam not yet landed.\n//! - AC-043c: full-mode page-corruption fixture not exposed to CLI tests.\n\nuse std::path::PathBuf;\nuse std::process::Command;\n\nuse fathomdb::{Engine, PreparedWrite};\nuse fathomdb_cli::exit_code;\nuse serde_json::Value;\nuse tempfile::TempDir;\n\nfn fathomdb() -> Command {\n    Command::new(env!(\"CARGO_BIN_EXE_fathomdb\"))\n}\n\nfn seeded_db() -> (TempDir, PathBuf) {\n    let dir = TempDir::new().expect(\"tempdir\");\n    let path = dir.path().join(\"recovery.sqlite\");\n    let opened = Engine::open(path.clone()).expect(\"open\");\n    opened.engine.close().expect(\"close\");\n    drop(opened);\n    (dir, path)\n}\n\nfn db_with_sources() -> (TempDir, PathBuf) {\n    let dir = TempDir::new().expect(\"tempdir\");\n    let path = dir.path().join(\"recovery.sqlite\");\n    let opened = Engine::open(path.clone()).expect(\"open\");\n    opened\n        .engine\n        .write(&[PreparedWrite::Node {\n            kind: \"doc\".to_string(),\n            body: \"alpha\".to_string(),\n            source_id: Some(\"src-a\".to_string()),\n        }])\n        .expect(\"write a\");\n    opened\n        .engine\n        .write(&[PreparedWrite::Node {\n            kind: \"doc\".to_string(),\n            body: \"beta\".to_string(),\n            source_id: Some(\"src-a\".to_string()),\n        }])\n        .expect(\"write a2\");\n    opened\n        .engine\n        .write(&[PreparedWrite::Node {\n            kind: \"doc\".to_string(),\n            body: \"gamma\".to_string(),\n            source_id: Some(\"src-b\".to_string()),\n        }])\n        .expect(\"write b\");\n    opened.engine.close().expect(\"close\");\n    drop(opened);\n    (dir, path)\n}\n\nfn run_json(args: &[&str]) -> (Option<i32>, Value) {\n    let output = fathomdb().args(args).output().expect(\"spawn\");\n    let stdout = String::from_utf8_lossy(&output.stdout);\n    let parsed: Value = serde_json::from_str(stdout.trim())\n        .unwrap_or_else(|e| panic!(\"stdout must be JSON; err={e} stdout={stdout}\"));\n    (output.status.code(), parsed)\n}\n\n#[test]\nfn t_028a_excise_source_cli_returns_excise_report() {\n    // AC-028a CLI half: `recover --accept-data-loss --excise-source <id>`\n    // exits 64 (RECOVERY_ACCEPTED_LOSS) and emits a JSON envelope keyed\n    // by `verb: \"excise-source\"` with the canonical excise report\n    // counts. Engine-side audit-row contract is bound by\n    // `tests/excise_source.rs::ac_028a_*`.\n    let (dir, db) = db_with_sources();\n    let (code, parsed) = run_json(&[\n        \"recover\",\n        \"--accept-data-loss\",\n        \"--excise-source\",\n        \"src-a\",\n        db.to_str().unwrap(),\n    ]);\n    assert_eq!(code, Some(exit_code::RECOVERY_ACCEPTED_LOSS));\n    assert_eq!(parsed.get(\"verb\").and_then(Value::as_str), Some(\"excise-source\"));\n    assert_eq!(parsed.get(\"source_ref\").and_then(Value::as_str), Some(\"src-a\"));\n    assert_eq!(parsed.get(\"nodes_excised\").and_then(Value::as_u64), Some(2));\n    drop(dir);\n}\n\n#[test]\nfn t_028b_excise_source_cli_reports_projections_invalidated_field() {\n    // AC-028b CLI half: the emitted report includes the\n    // `projections_invalidated` field so binding consumers can detect\n    // shadow-state removal. Engine-side residue assertion is bound by\n    // `tests/excise_source.rs::ac_028b_*`.\n    let (dir, db) = db_with_sources();\n    let (_code, parsed) = run_json(&[\n        \"recover\",\n        \"--accept-data-loss\",\n        \"--excise-source\",\n        \"src-a\",\n        db.to_str().unwrap(),\n    ]);\n    assert!(\n        parsed.get(\"projections_invalidated\").is_some(),\n        \"CLI report must include projections_invalidated; got {parsed:?}\",\n    );\n    drop(dir);\n}\n\n#[test]\nfn t_028c_excise_source_cli_isolates_non_excised_sources() {\n    // AC-028c CLI half: excising one source leaves the other source's\n    // rows queryable. After excise, run trace on the un-excised source\n    // and confirm its canonical-row events survive.\n    let (dir, db) = db_with_sources();\n    let (_code, _excise) = run_json(&[\n        \"recover\",\n        \"--accept-data-loss\",\n        \"--excise-source\",\n        \"src-a\",\n        db.to_str().unwrap(),\n    ]);\n    let (code, parsed) =\n        run_json(&[\"doctor\", \"trace\", \"--source-ref\", \"src-b\", db.to_str().unwrap()]);\n    assert_eq!(code, Some(exit_code::OK));\n    let events = parsed.get(\"events\").and_then(Value::as_array).expect(\"events array\");\n    assert_eq!(events.len(), 1, \"src-b must still have its one event after src-a excise\");\n    drop(dir);\n}\n\n#[test]\nfn t_039a_safe_export_cli_emits_manifest_sha256_field() {\n    // AC-039a CLI half: doctor safe-export emits JSON with\n    // `export_path`, `manifest_path`, `manifest_sha256`. Engine-side\n    // file-bytes equality with the manifest is bound by\n    // `tests/safe_export.rs`.\n    let (dir, db) = seeded_db();\n    let out = dir.path().join(\"export.sqlite\");\n    let manifest = dir.path().join(\"export.manifest.json\");\n    let (code, parsed) = run_json(&[\n        \"doctor\",\n        \"safe-export\",\n        out.to_str().unwrap(),\n        \"--manifest\",\n        manifest.to_str().unwrap(),\n        db.to_str().unwrap(),\n    ]);\n    assert_eq!(code, Some(exit_code::OK));\n    assert_eq!(parsed.get(\"verb\").and_then(Value::as_str), Some(\"safe-export\"));\n    let sha = parsed.get(\"manifest_sha256\").and_then(Value::as_str).expect(\"sha256 field\");\n    assert_eq!(sha.len(), 64, \"sha256 hex must be 64 chars; got {sha}\");\n    assert!(out.exists(), \"exported DB file must exist\");\n    assert!(manifest.exists(), \"manifest sidecar must exist\");\n    drop(dir);\n}\n\n#[test]\nfn t_042_trace_cli_enumerates_canonical_rows_for_source() {\n    // AC-042 CLI half: `doctor trace --source-ref <id>` returns one\n    // event per canonical row attributable to the source, ordered by\n    // `write_cursor`. Engine-side ordering invariant is bound by\n    // `tests/*` engine tests; this asserts the CLI JSON envelope.\n    let (dir, db) = db_with_sources();\n    let (code, parsed) =\n        run_json(&[\"doctor\", \"trace\", \"--source-ref\", \"src-a\", db.to_str().unwrap()]);\n    assert_eq!(code, Some(exit_code::OK));\n    assert_eq!(parsed.get(\"verb\").and_then(Value::as_str), Some(\"trace\"));\n    assert_eq!(parsed.get(\"source_ref\").and_then(Value::as_str), Some(\"src-a\"));\n    let events = parsed.get(\"events\").and_then(Value::as_array).expect(\"events array\");\n    assert_eq!(events.len(), 2);\n    let cursors: Vec<u64> =\n        events.iter().filter_map(|e| e.get(\"write_cursor\").and_then(Value::as_u64)).collect();\n    assert!(cursors.windows(2).all(|w| w[0] <= w[1]), \"events must be cursor-ordered: {cursors:?}\");\n    drop(dir);\n}\n\n#[test]\nfn t_043a_check_integrity_cli_emits_three_sections() {\n    // AC-043a CLI half: integrity report has top-level keys\n    // `physical`, `logical`, `semantic`. Engine-side three-section\n    // contract is bound by `tests/check_integrity.rs`.\n    let (dir, db) = seeded_db();\n    let (_code, parsed) = run_json(&[\"doctor\", \"check-integrity\", db.to_str().unwrap()]);\n    assert_eq!(parsed.get(\"verb\").and_then(Value::as_str), Some(\"check-integrity\"));\n    assert!(parsed.get(\"physical\").is_some(), \"physical key missing: {parsed:?}\");\n    assert!(parsed.get(\"logical\").is_some(), \"logical key missing: {parsed:?}\");\n    assert!(parsed.get(\"semantic\").is_some(), \"semantic key missing: {parsed:?}\");\n    drop(dir);\n}\n\n#[test]\nfn t_043b_check_integrity_cli_each_section_clean_or_findings() {\n    // AC-043b CLI half: every section's machine shape is either\n    // {status:\"clean\", findings:[]} or {status:\"findings\", findings:[...]}.\n    // On a clean seeded DB every section is `clean`.\n    let (dir, db) = seeded_db();\n    let (code, parsed) = run_json(&[\"doctor\", \"check-integrity\", db.to_str().unwrap()]);\n    assert_eq!(code, Some(exit_code::OK), \"clean DB must exit 0; got {code:?}\");\n    for key in [\"physical\", \"logical\", \"semantic\"] {\n        let section = parsed.get(key).expect(\"section\");\n        let status = section.get(\"status\").and_then(Value::as_str).expect(\"status\");\n        assert!(\n            status == \"clean\" || status == \"findings\",\n            \"section {key} status must be clean|findings; got {status}\",\n        );\n        let findings = section.get(\"findings\").and_then(Value::as_array).expect(\"findings array\");\n        if status == \"clean\" {\n            assert!(findings.is_empty(), \"clean section must have empty findings\");\n        }\n    }\n    drop(dir);\n}\n\n#[test]\nfn t_044_recover_rebuild_projections_cli_runs_end_to_end() {\n    // AC-044 CLI half: `recover --accept-data-loss --rebuild-projections`\n    // exits 64 and emits a rebuild report with the\n    // `projection_cursor_after` field. Engine-side projection-rebuild\n    // semantics are bound by `tests/rebuild_projections.rs`.\n    let (dir, db) = seeded_db();\n    let (code, parsed) =\n        run_json(&[\"recover\", \"--accept-data-loss\", \"--rebuild-projections\", db.to_str().unwrap()]);\n    assert_eq!(code, Some(exit_code::RECOVERY_ACCEPTED_LOSS));\n    assert_eq!(parsed.get(\"verb\").and_then(Value::as_str), Some(\"rebuild-projections\"));\n    assert!(\n        parsed.get(\"projection_cursor_after\").is_some(),\n        \"rebuild report must carry projection_cursor_after\",\n    );\n    drop(dir);\n}\n\n#[test]\nfn t_063c_recover_rebuild_projections_cli_regenerate_workflow() {\n    // AC-063c CLI half: `recover --rebuild-projections` is the\n    // canonical regenerate workflow. Confirm the CLI binds it as the\n    // landed engine seam, with `kind: \"projections\"` discriminator.\n    let (dir, db) = seeded_db();\n    let (_code, parsed) =\n        run_json(&[\"recover\", \"--accept-data-loss\", \"--rebuild-projections\", db.to_str().unwrap()]);\n    assert_eq!(parsed.get(\"kind\").and_then(Value::as_str), Some(\"projections\"));\n    drop(dir);\n}\n\n// ---- Still ignored: fixture / engine-seam gaps remain ----\n\n#[test]\n#[ignore = \"AC-026: dep-Phase-10a-wal-only-fixture; safe-export seam landed, but the WAL-only-commit setup harness is not yet shared with CLI tests\"]\nfn t_026_safe_export_covers_wal_only_commits() {\n    let _bin = env!(\"CARGO_BIN_EXE_fathomdb\");\n    unimplemented!(\"AC-026 awaits a CLI-side WAL-only-commit fixture\");\n}\n\n#[test]\n#[ignore = \"AC-027a: dep-Phase-10a-vec0-rebuild-pre-post-canonical-compare; engine-side fixture not shared with CLI\"]\nfn t_027a_recovery_preserves_canonical_rows() {\n    let _bin = env!(\"CARGO_BIN_EXE_fathomdb\");\n    unimplemented!(\"AC-027a awaits CLI-side pre/post canonical-row compare fixture\");\n}\n\n#[test]\n#[ignore = \"AC-027b: dep-Phase-10a-fts-result-equality; CLI-side FTS query parity harness not yet wired\"]\nfn t_027b_recovery_preserves_fts_query_result_equality() {\n    let _bin = env!(\"CARGO_BIN_EXE_fathomdb\");\n    unimplemented!(\"AC-027b awaits CLI-side FTS pre/post compare fixture\");\n}\n\n#[test]\n#[ignore = \"AC-027c: dep-Phase-10a-vector-profile-bit-equal; CLI-side vector-profile metadata compare not yet wired\"]\nfn t_027c_recovery_preserves_vector_profile_metadata_bit_equal() {\n    let _bin = env!(\"CARGO_BIN_EXE_fathomdb\");\n    unimplemented!(\"AC-027c awaits CLI-side vector-profile metadata compare fixture\");\n}\n\n#[test]\n#[ignore = \"AC-027d: dep-Phase-10a-vector-top-k-rank-correlation; rank-correlation harness lives in engine tests\"]\nfn t_027d_recovery_preserves_vector_top_k_rank_correlation() {\n    let _bin = env!(\"CARGO_BIN_EXE_fathomdb\");\n    unimplemented!(\"AC-027d awaits CLI-side rank-correlation harness\");\n}\n\n#[test]\n#[ignore = \"AC-039b: dep-Phase-10a-safe-export-tamper-verifier; engine has no verify-manifest seam yet\"]\nfn t_039b_safe_export_tampered_artifact_detected() {\n    let _bin = env!(\"CARGO_BIN_EXE_fathomdb\");\n    unimplemented!(\"AC-039b awaits a safe-export verifier seam\");\n}\n\n#[test]\n#[ignore = \"AC-043c: dep-Phase-10a-page-corruption-fixture; CLI-side page-corruption helper not yet exposed\"]\nfn t_043c_check_integrity_full_findings_carry_stable_report_fields() {\n    let _bin = env!(\"CARGO_BIN_EXE_fathomdb\");\n    unimplemented!(\n        \"AC-043c awaits a CLI-side page-corruption helper to surface --full integrity findings\"\n    );\n}\n","numLines":316,"startLine":1,"totalLines":316}}}
