{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WjUJk3i9i6pAVn6cJKdZGF","type":"tool_result","content":"1\t//! Open-path corruption matrix (AC-035a / AC-035b / AC-035c).\n2\t//!\n3\t//! Four fixtures, one per `CorruptionKind` variant. Each fixture seeds a\n4\t//! clean database, closes it, applies a deterministic corruption via\n5\t//! `tests/support/corruption.rs`, and asserts that `Engine::open`:\n6\t//!\n7\t//!   - returns `Err(EngineOpenError::Corruption(_))` (AC-035a)\n8\t//!   - carries the documented `(kind, stage, recovery_hint.code)` tuple\n9\t//!     from `dev/design/errors.md` § OpenStage matrix (AC-035b)\n10\t//!   - releases the writer lock and retains no SQLite fd / writer thread\n11\t//!     in the calling process (AC-035c)\n12\t//!\n13\t//! Substrate notes:\n14\t//!   - `corrupt_database_header` / `corrupt_interior_page_byte` already\n15\t//!     existed for AC-006 page-corruption coverage; reused here.\n16\t//!   - `corrupt_wal_invalid_page_size` / `corrupt_embedder_profile_row`\n17\t//!     are new helpers added for the WAL-replay and embedder-identity\n18\t//!     drift fixtures.\n19\t//!   - Process introspection (AC-035c) is linux-only. The test gates on\n20\t//!     `cfg(target_os = \"linux\")` rather than skipping silently.\n21\t\n22\tuse std::fs::{self, File};\n23\tuse std::path::{Path, PathBuf};\n24\tuse std::sync::{Mutex, MutexGuard, OnceLock};\n25\t\n26\tuse fathomdb_engine::{\n27\t    CorruptionDetail, CorruptionKind, CorruptionLocator, Engine, EngineOpenError, OpenStage,\n28\t};\n29\tuse tempfile::TempDir;\n30\t\n31\t#[path = \"support/corruption.rs\"]\n32\tmod corruption;\n33\t\n34\t/// Serialize every test in this binary. AC-035c inspects process-wide\n35\t/// thread names and open fds; parallel sibling tests that hold an\n36\t/// `Engine` alive would otherwise show up as `fathomdb-reader-*` threads\n37\t/// and false-fail the assertion. Even tests that do not check thread\n38\t/// names take the guard so an AC-035c test never races a sibling that\n39\t/// has just spawned reader threads.\n40\tfn serial_guard() -> MutexGuard<'static, ()> {\n41\t    static LOCK: OnceLock<Mutex<()>> = OnceLock::new();\n42\t    LOCK.get_or_init(|| Mutex::new(())).lock().unwrap_or_else(|p| p.into_inner())\n43\t}\n44\t\n45\t#[derive(Clone, Copy, Debug)]\n46\tstruct Expected {\n47\t    kind: CorruptionKind,\n48\t    stage: OpenStage,\n49\t    code: &'static str,\n50\t    doc_anchor: &'static str,\n51\t}\n52\t\n53\tconst EXPECTED_WAL: Expected = Expected {\n54\t    kind: CorruptionKind::WalReplayFailure,\n55\t    stage: OpenStage::WalReplay,\n56\t    code: \"E_CORRUPT_WAL_REPLAY\",\n57\t    doc_anchor: \"design/recovery.md#wal-replay-failures\",\n58\t};\n59\tconst EXPECTED_HEADER: Expected = Expected {\n60\t    kind: CorruptionKind::HeaderMalformed,\n61\t    stage: OpenStage::HeaderProbe,\n62\t    code: \"E_CORRUPT_HEADER\",\n63\t    doc_anchor: \"design/recovery.md#header-malformed\",\n64\t};\n65\tconst EXPECTED_SCHEMA: Expected = Expected {\n66\t    kind: CorruptionKind::SchemaInconsistent,\n67\t    stage: OpenStage::SchemaProbe,\n68\t    code: \"E_CORRUPT_SCHEMA\",\n69\t    doc_anchor: \"design/recovery.md#schema-inconsistent\",\n70\t};\n71\tconst EXPECTED_EMBEDDER: Expected = Expected {\n72\t    kind: CorruptionKind::EmbedderIdentityDrift,\n73\t    stage: OpenStage::EmbedderIdentity,\n74\t    code: \"E_CORRUPT_EMBEDDER_IDENTITY\",\n75\t    doc_anchor: \"design/recovery.md#embedder-identity-drift\",\n76\t};\n77\t\n78\tfn fixture_for(kind: CorruptionKind) -> (TempDir, PathBuf) {\n79\t    let dir = TempDir::new().expect(\"tempdir\");\n80\t    let path = dir.path().join(\"corrupt.sqlite\");\n81\t    // Seed a clean database via the engine so schema + embedder profile\n82\t    // are populated before corruption is applied.\n83\t    let opened = Engine::open(&path).expect(\"seed open\");\n84\t    opened.engine.close().expect(\"seed close\");\n85\t    drop(opened);\n86\t    apply_corruption(kind, &path);\n87\t    (dir, path)\n88\t}\n89\t\n90\tfn apply_corruption(kind: CorruptionKind, path: &Path) {\n91\t    match kind {\n92\t        CorruptionKind::WalReplayFailure => {\n93\t            corruption::corrupt_wal_invalid_page_size(path);\n94\t        }\n95\t        CorruptionKind::HeaderMalformed => {\n96\t            corruption::corrupt_database_header(path);\n97\t        }\n98\t        CorruptionKind::SchemaInconsistent => {\n99\t            // Magic intact; XOR a byte in the b-tree header so the\n100\t            // schema probe trips during page decode.\n101\t            corruption::corrupt_interior_page_byte(path, 0, 100, 0xFF);\n102\t        }\n103\t        CorruptionKind::EmbedderIdentityDrift => {\n104\t            corruption::corrupt_embedder_profile_row(path);\n105\t        }\n106\t    }\n107\t}\n108\t\n109\tfn open_and_expect_corruption(path: &Path) -> CorruptionDetail {\n110\t    let err = Engine::open(path).expect_err(\"Engine::open must fail on corruption fixture\");\n111\t    match err {\n112\t        EngineOpenError::Corruption(detail) => detail,\n113\t        other => panic!(\"expected Corruption, got {other:?}\"),\n114\t    }\n115\t}\n116\t\n117\t// ── AC-035a: refusal + no handle + no side effect ───────────────────────────\n118\t\n119\t#[test]\n120\tfn ac_035a_wal_replay_corruption_refuses_open() {\n121\t    assert_refuses_with_no_side_effect(CorruptionKind::WalReplayFailure);\n122\t}\n123\t\n124\t#[test]\n125\tfn ac_035a_header_corruption_refuses_open() {\n126\t    assert_refuses_with_no_side_effect(CorruptionKind::HeaderMalformed);\n127\t}\n128\t\n129\t#[test]\n130\tfn ac_035a_schema_corruption_refuses_open() {\n131\t    assert_refuses_with_no_side_effect(CorruptionKind::SchemaInconsistent);\n132\t}\n133\t\n134\t#[test]\n135\tfn ac_035a_embedder_identity_corruption_refuses_open() {\n136\t    assert_refuses_with_no_side_effect(CorruptionKind::EmbedderIdentityDrift);\n137\t}\n138\t\n139\tfn assert_refuses_with_no_side_effect(kind: CorruptionKind) {\n140\t    let _guard = serial_guard();\n141\t    let (_dir, path) = fixture_for(kind);\n142\t    let mtime_before = fs::metadata(&path).expect(\"stat before\").modified().expect(\"mtime before\");\n143\t    let len_before = fs::metadata(&path).expect(\"stat before len\").len();\n144\t\n145\t    let result = Engine::open(&path);\n146\t    assert!(\n147\t        matches!(result, Err(EngineOpenError::Corruption(_))),\n148\t        \"expected Err(Corruption) for {kind:?}, got {result:?}\"\n149\t    );\n150\t\n151\t    let mtime_after = fs::metadata(&path).expect(\"stat after\").modified().expect(\"mtime after\");\n152\t    let len_after = fs::metadata(&path).expect(\"stat after len\").len();\n153\t    assert_eq!(\n154\t        mtime_before, mtime_after,\n155\t        \"{kind:?}: failed open must not modify the DB file (mtime drift)\"\n156\t    );\n157\t    assert_eq!(\n158\t        len_before, len_after,\n159\t        \"{kind:?}: failed open must not modify the DB file (len drift)\"\n160\t    );\n161\t}\n162\t\n163\t// ── AC-035b: CorruptionDetail shape per kind ────────────────────────────────\n164\t\n165\t#[test]\n166\tfn ac_035b_wal_replay_shape() {\n167\t    let _guard = serial_guard();\n168\t    let (_dir, path) = fixture_for(CorruptionKind::WalReplayFailure);\n169\t    let detail = open_and_expect_corruption(&path);\n170\t    assert_shape(&detail, &EXPECTED_WAL);\n171\t}\n172\t\n173\t#[test]\n174\tfn ac_035b_header_shape() {\n175\t    let _guard = serial_guard();\n176\t    let (_dir, path) = fixture_for(CorruptionKind::HeaderMalformed);\n177\t    let detail = open_and_expect_corruption(&path);\n178\t    assert_shape(&detail, &EXPECTED_HEADER);\n179\t}\n180\t\n181\t#[test]\n182\tfn ac_035b_schema_shape() {\n183\t    let _guard = serial_guard();\n184\t    let (_dir, path) = fixture_for(CorruptionKind::SchemaInconsistent);\n185\t    let detail = open_and_expect_corruption(&path);\n186\t    assert_shape(&detail, &EXPECTED_SCHEMA);\n187\t}\n188\t\n189\t#[test]\n190\tfn ac_035b_embedder_identity_shape() {\n191\t    let _guard = serial_guard();\n192\t    let (_dir, path) = fixture_for(CorruptionKind::EmbedderIdentityDrift);\n193\t    let detail = open_and_expect_corruption(&path);\n194\t    assert_shape(&detail, &EXPECTED_EMBEDDER);\n195\t}\n196\t\n197\tfn assert_shape(detail: &CorruptionDetail, expected: &Expected) {\n198\t    assert_eq!(detail.kind, expected.kind, \"kind mismatch\");\n199\t    assert_eq!(detail.stage, expected.stage, \"stage mismatch\");\n200\t    // AC-035b: `OpenStage` must remain in `{WalReplay, HeaderProbe,\n201\t    // SchemaProbe, EmbedderIdentity}`. Compile-time enforced by\n202\t    // exhaustive match below; any future LockAcquisition-style variant\n203\t    // would cause this match to non-exhaustively fail to compile.\n204\t    match detail.stage {\n205\t        OpenStage::WalReplay\n206\t        | OpenStage::HeaderProbe\n207\t        | OpenStage::SchemaProbe\n208\t        | OpenStage::EmbedderIdentity => {}\n209\t    }\n210\t    // AC-035b: opaque SQLite paths must surface as OpaqueSqliteError with\n211\t    // a typed extended_code; CorruptionLocator must never expose a\n212\t    // free-form Unspecified variant.\n213\t    match detail.locator {\n214\t        CorruptionLocator::OpaqueSqliteError { sqlite_extended_code: _ }\n215\t        | CorruptionLocator::FileOffset { .. }\n216\t        | CorruptionLocator::PageId { .. }\n217\t        | CorruptionLocator::TableRow { .. }\n218\t        | CorruptionLocator::Vec0ShadowRow { .. }\n219\t        | CorruptionLocator::MigrationStep { .. } => {}\n220\t    }\n221\t    assert_eq!(\n222\t        detail.recovery_hint.code, expected.code,\n223\t        \"recovery_hint.code mismatch for {:?}\",\n224\t        expected.kind\n225\t    );\n226\t    assert_eq!(\n227\t        detail.recovery_hint.doc_anchor, expected.doc_anchor,\n228\t        \"recovery_hint.doc_anchor mismatch for {:?}\",\n229\t        expected.kind\n230\t    );\n231\t}\n232\t\n233\t// AC-035b: `code` is a `&'static str`; re-running the fixture twice must\n234\t// yield bit-equal pointers (and obviously bit-equal contents).\n235\t#[test]\n236\tfn ac_035b_code_is_bit_stable_across_runs() {\n237\t    let _guard = serial_guard();\n238\t    for expected in [&EXPECTED_WAL, &EXPECTED_HEADER, &EXPECTED_SCHEMA, &EXPECTED_EMBEDDER] {\n239\t        let (_dir1, path1) = fixture_for(expected.kind);\n240\t        let (_dir2, path2) = fixture_for(expected.kind);\n241\t        let detail1 = open_and_expect_corruption(&path1);\n242\t        let detail2 = open_and_expect_corruption(&path2);\n243\t        assert_eq!(detail1.recovery_hint.code, detail2.recovery_hint.code);\n244\t        assert_eq!(detail1.recovery_hint.code, expected.code);\n245\t        // The `&'static str` from two separate calls within the same\n246\t        // process must point at the same backing storage — string-\n247\t        // literal interning gives bit-equal pointer comparison and\n248\t        // proves the engine isn't allocating a fresh `String` per\n249\t        // failure.\n250\t        assert!(\n251\t            std::ptr::eq(detail1.recovery_hint.code, detail2.recovery_hint.code),\n252\t            \"recovery_hint.code must be a static literal, not an allocated string\"\n253\t        );\n254\t    }\n255\t}\n256\t\n257\t// ── AC-035c: lock released, fd not retained, no writer/scheduler thread ─────\n258\t\n259\t#[cfg(target_os = \"linux\")]\n260\t#[test]\n261\tfn ac_035c_lock_released_after_corruption_header() {\n262\t    assert_lock_released_and_no_engine_residue(CorruptionKind::HeaderMalformed);\n263\t}\n264\t\n265\t#[cfg(target_os = \"linux\")]\n266\t#[test]\n267\tfn ac_035c_lock_released_after_corruption_schema() {\n268\t    assert_lock_released_and_no_engine_residue(CorruptionKind::SchemaInconsistent);\n269\t}\n270\t\n271\t#[cfg(target_os = \"linux\")]\n272\tfn assert_lock_released_and_no_engine_residue(kind: CorruptionKind) {\n273\t    let _guard = serial_guard();\n274\t    let (_dir, path) = fixture_for(kind);\n275\t    // Trigger the failed open; the lock must be released by the time\n276\t    // the call returns.\n277\t    let err = Engine::open(&path).expect_err(\"must fail\");\n278\t    assert!(matches!(err, EngineOpenError::Corruption(_)));\n279\t\n280\t    let lock_path = lock_path_for(&path);\n281\t    assert!(lock_path.exists(), \"engine should have created the lockfile before releasing it\");\n282\t\n283\t    // Re-acquire the advisory lock that the engine took on `.lock`. If\n284\t    // the failed open leaked the file lock, this `flock(LOCK_EX|NB)`\n285\t    // would return EWOULDBLOCK.\n286\t    let probe = File::options().read(true).write(true).open(&lock_path).expect(\"open lock file\");\n287\t    let probe_fd: i32 = std::os::unix::io::AsRawFd::as_raw_fd(&probe);\n288\t    let rc = unsafe { libc::flock(probe_fd, libc::LOCK_EX | libc::LOCK_NB) };\n289\t    assert_eq!(\n290\t        rc,\n291\t        0,\n292\t        \"AC-035c: lock must be releasable after failed open ({}): errno = {}\",\n293\t        lock_path.display(),\n294\t        std::io::Error::last_os_error()\n295\t    );\n296\t    let _ = unsafe { libc::flock(probe_fd, libc::LOCK_UN) };\n297\t\n298\t    // /proc/self/fd: assert no fd points at the database file. The\n299\t    // canonical absolute path of `path` must not appear as the\n300\t    // destination of any open fd in this process.\n301\t    let canonical = path.canonicalize().expect(\"canonicalize db path\");\n302\t    let fd_dir = PathBuf::from(\"/proc/self/fd\");\n303\t    for entry in fs::read_dir(&fd_dir).expect(\"read /proc/self/fd\") {\n304\t        let entry = entry.expect(\"dirent\");\n305\t        let link = match fs::read_link(entry.path()) {\n306\t            Ok(target) => target,\n307\t            // The fd may have been closed between readdir and readlink;\n308\t            // race is fine for this assertion.\n309\t            Err(_) => continue,\n310\t        };\n311\t        assert_ne!(\n312\t            link,\n313\t            canonical,\n314\t            \"AC-035c: /proc/self/fd/{} still points at the database \\\n315\t             file after a failed open\",\n316\t            entry.file_name().to_string_lossy()\n317\t        );\n318\t    }\n319\t\n320\t    // /proc/self/task: no thread named per fathomdb conventions\n321\t    // (`fathomdb-reader-N`, etc.) must be live in this process.\n322\t    let task_dir = PathBuf::from(\"/proc/self/task\");\n323\t    for entry in fs::read_dir(&task_dir).expect(\"read /proc/self/task\") {\n324\t        let entry = entry.expect(\"task dirent\");\n325\t        let comm_path = entry.path().join(\"comm\");\n326\t        let Ok(comm_bytes) = fs::read(&comm_path) else { continue };\n327\t        let comm = String::from_utf8_lossy(&comm_bytes).trim().to_string();\n328\t        assert!(\n329\t            !comm.starts_with(\"fathomdb-\"),\n330\t            \"AC-035c: thread named '{comm}' is still live after a failed open\"\n331\t        );\n332\t    }\n333\t}\n334\t\n335\t#[cfg(target_os = \"linux\")]\n336\tfn lock_path_for(db_path: &Path) -> PathBuf {\n337\t    let mut lock = db_path.as_os_str().to_owned();\n338\t    lock.push(\".lock\");\n339\t    PathBuf::from(lock)\n340\t}\n341\t"}]},"parent_tool_use_id":null,"session_id":"3dcf3508-c16d-46fb-9860-076600a60569","uuid":"2bcdfecd-b919-4e13-b8dc-2196210ce3e5","timestamp":"2026-05-17T19:25:12.855Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-D-durability-harnesses-20260517T185755Z/src/rust/crates/fathomdb-engine/tests/durability_open_path.rs","content":"//! Open-path corruption matrix (AC-035a / AC-035b / AC-035c).\n//!\n//! Four fixtures, one per `CorruptionKind` variant. Each fixture seeds a\n//! clean database, closes it, applies a deterministic corruption via\n//! `tests/support/corruption.rs`, and asserts that `Engine::open`:\n//!\n//!   - returns `Err(EngineOpenError::Corruption(_))` (AC-035a)\n//!   - carries the documented `(kind, stage, recovery_hint.code)` tuple\n//!     from `dev/design/errors.md` § OpenStage matrix (AC-035b)\n//!   - releases the writer lock and retains no SQLite fd / writer thread\n//!     in the calling process (AC-035c)\n//!\n//! Substrate notes:\n//!   - `corrupt_database_header` / `corrupt_interior_page_byte` already\n//!     existed for AC-006 page-corruption coverage; reused here.\n//!   - `corrupt_wal_invalid_page_size` / `corrupt_embedder_profile_row`\n//!     are new helpers added for the WAL-replay and embedder-identity\n//!     drift fixtures.\n//!   - Process introspection (AC-035c) is linux-only. The test gates on\n//!     `cfg(target_os = \"linux\")` rather than skipping silently.\n\nuse std::fs::{self, File};\nuse std::path::{Path, PathBuf};\nuse std::sync::{Mutex, MutexGuard, OnceLock};\n\nuse fathomdb_engine::{\n    CorruptionDetail, CorruptionKind, CorruptionLocator, Engine, EngineOpenError, OpenStage,\n};\nuse tempfile::TempDir;\n\n#[path = \"support/corruption.rs\"]\nmod corruption;\n\n/// Serialize every test in this binary. AC-035c inspects process-wide\n/// thread names and open fds; parallel sibling tests that hold an\n/// `Engine` alive would otherwise show up as `fathomdb-reader-*` threads\n/// and false-fail the assertion. Even tests that do not check thread\n/// names take the guard so an AC-035c test never races a sibling that\n/// has just spawned reader threads.\nfn serial_guard() -> MutexGuard<'static, ()> {\n    static LOCK: OnceLock<Mutex<()>> = OnceLock::new();\n    LOCK.get_or_init(|| Mutex::new(())).lock().unwrap_or_else(|p| p.into_inner())\n}\n\n#[derive(Clone, Copy, Debug)]\nstruct Expected {\n    kind: CorruptionKind,\n    stage: OpenStage,\n    code: &'static str,\n    doc_anchor: &'static str,\n}\n\nconst EXPECTED_WAL: Expected = Expected {\n    kind: CorruptionKind::WalReplayFailure,\n    stage: OpenStage::WalReplay,\n    code: \"E_CORRUPT_WAL_REPLAY\",\n    doc_anchor: \"design/recovery.md#wal-replay-failures\",\n};\nconst EXPECTED_HEADER: Expected = Expected {\n    kind: CorruptionKind::HeaderMalformed,\n    stage: OpenStage::HeaderProbe,\n    code: \"E_CORRUPT_HEADER\",\n    doc_anchor: \"design/recovery.md#header-malformed\",\n};\nconst EXPECTED_SCHEMA: Expected = Expected {\n    kind: CorruptionKind::SchemaInconsistent,\n    stage: OpenStage::SchemaProbe,\n    code: \"E_CORRUPT_SCHEMA\",\n    doc_anchor: \"design/recovery.md#schema-inconsistent\",\n};\nconst EXPECTED_EMBEDDER: Expected = Expected {\n    kind: CorruptionKind::EmbedderIdentityDrift,\n    stage: OpenStage::EmbedderIdentity,\n    code: \"E_CORRUPT_EMBEDDER_IDENTITY\",\n    doc_anchor: \"design/recovery.md#embedder-identity-drift\",\n};\n\nfn fixture_for(kind: CorruptionKind) -> (TempDir, PathBuf) {\n    let dir = TempDir::new().expect(\"tempdir\");\n    let path = dir.path().join(\"corrupt.sqlite\");\n    // Seed a clean database via the engine so schema + embedder profile\n    // are populated before corruption is applied.\n    let opened = Engine::open(&path).expect(\"seed open\");\n    opened.engine.close().expect(\"seed close\");\n    drop(opened);\n    apply_corruption(kind, &path);\n    (dir, path)\n}\n\nfn apply_corruption(kind: CorruptionKind, path: &Path) {\n    match kind {\n        CorruptionKind::WalReplayFailure => {\n            corruption::corrupt_wal_invalid_page_size(path);\n        }\n        CorruptionKind::HeaderMalformed => {\n            corruption::corrupt_database_header(path);\n        }\n        CorruptionKind::SchemaInconsistent => {\n            // Magic intact; XOR a byte in the b-tree header so the\n            // schema probe trips during page decode.\n            corruption::corrupt_interior_page_byte(path, 0, 100, 0xFF);\n        }\n        CorruptionKind::EmbedderIdentityDrift => {\n            corruption::corrupt_embedder_profile_row(path);\n        }\n    }\n}\n\nfn open_and_expect_corruption(path: &Path) -> CorruptionDetail {\n    let err = Engine::open(path).expect_err(\"Engine::open must fail on corruption fixture\");\n    match err {\n        EngineOpenError::Corruption(detail) => detail,\n        other => panic!(\"expected Corruption, got {other:?}\"),\n    }\n}\n\n// ── AC-035a: refusal + no handle + no side effect ───────────────────────────\n\n#[test]\nfn ac_035a_wal_replay_corruption_refuses_open() {\n    assert_refuses_with_no_side_effect(CorruptionKind::WalReplayFailure);\n}\n\n#[test]\nfn ac_035a_header_corruption_refuses_open() {\n    assert_refuses_with_no_side_effect(CorruptionKind::HeaderMalformed);\n}\n\n#[test]\nfn ac_035a_schema_corruption_refuses_open() {\n    assert_refuses_with_no_side_effect(CorruptionKind::SchemaInconsistent);\n}\n\n#[test]\nfn ac_035a_embedder_identity_corruption_refuses_open() {\n    assert_refuses_with_no_side_effect(CorruptionKind::EmbedderIdentityDrift);\n}\n\nfn assert_refuses_with_no_side_effect(kind: CorruptionKind) {\n    let _guard = serial_guard();\n    let (_dir, path) = fixture_for(kind);\n    let mtime_before = fs::metadata(&path).expect(\"stat before\").modified().expect(\"mtime before\");\n    let len_before = fs::metadata(&path).expect(\"stat before len\").len();\n\n    let result = Engine::open(&path);\n    assert!(\n        matches!(result, Err(EngineOpenError::Corruption(_))),\n        \"expected Err(Corruption) for {kind:?}, got {result:?}\"\n    );\n\n    let mtime_after = fs::metadata(&path).expect(\"stat after\").modified().expect(\"mtime after\");\n    let len_after = fs::metadata(&path).expect(\"stat after len\").len();\n    assert_eq!(\n        mtime_before, mtime_after,\n        \"{kind:?}: failed open must not modify the DB file (mtime drift)\"\n    );\n    assert_eq!(\n        len_before, len_after,\n        \"{kind:?}: failed open must not modify the DB file (len drift)\"\n    );\n}\n\n// ── AC-035b: CorruptionDetail shape per kind ────────────────────────────────\n\n#[test]\nfn ac_035b_wal_replay_shape() {\n    let _guard = serial_guard();\n    let (_dir, path) = fixture_for(CorruptionKind::WalReplayFailure);\n    let detail = open_and_expect_corruption(&path);\n    assert_shape(&detail, &EXPECTED_WAL);\n}\n\n#[test]\nfn ac_035b_header_shape() {\n    let _guard = serial_guard();\n    let (_dir, path) = fixture_for(CorruptionKind::HeaderMalformed);\n    let detail = open_and_expect_corruption(&path);\n    assert_shape(&detail, &EXPECTED_HEADER);\n}\n\n#[test]\nfn ac_035b_schema_shape() {\n    let _guard = serial_guard();\n    let (_dir, path) = fixture_for(CorruptionKind::SchemaInconsistent);\n    let detail = open_and_expect_corruption(&path);\n    assert_shape(&detail, &EXPECTED_SCHEMA);\n}\n\n#[test]\nfn ac_035b_embedder_identity_shape() {\n    let _guard = serial_guard();\n    let (_dir, path) = fixture_for(CorruptionKind::EmbedderIdentityDrift);\n    let detail = open_and_expect_corruption(&path);\n    assert_shape(&detail, &EXPECTED_EMBEDDER);\n}\n\nfn assert_shape(detail: &CorruptionDetail, expected: &Expected) {\n    assert_eq!(detail.kind, expected.kind, \"kind mismatch\");\n    assert_eq!(detail.stage, expected.stage, \"stage mismatch\");\n    // AC-035b: `OpenStage` must remain in `{WalReplay, HeaderProbe,\n    // SchemaProbe, EmbedderIdentity}`. Compile-time enforced by\n    // exhaustive match below; any future LockAcquisition-style variant\n    // would cause this match to non-exhaustively fail to compile.\n    match detail.stage {\n        OpenStage::WalReplay\n        | OpenStage::HeaderProbe\n        | OpenStage::SchemaProbe\n        | OpenStage::EmbedderIdentity => {}\n    }\n    // AC-035b: opaque SQLite paths must surface as OpaqueSqliteError with\n    // a typed extended_code; CorruptionLocator must never expose a\n    // free-form Unspecified variant.\n    match detail.locator {\n        CorruptionLocator::OpaqueSqliteError { sqlite_extended_code: _ }\n        | CorruptionLocator::FileOffset { .. }\n        | CorruptionLocator::PageId { .. }\n        | CorruptionLocator::TableRow { .. }\n        | CorruptionLocator::Vec0ShadowRow { .. }\n        | CorruptionLocator::MigrationStep { .. } => {}\n    }\n    assert_eq!(\n        detail.recovery_hint.code, expected.code,\n        \"recovery_hint.code mismatch for {:?}\",\n        expected.kind\n    );\n    assert_eq!(\n        detail.recovery_hint.doc_anchor, expected.doc_anchor,\n        \"recovery_hint.doc_anchor mismatch for {:?}\",\n        expected.kind\n    );\n}\n\n// AC-035b: `code` is a `&'static str`; re-running the fixture twice must\n// yield bit-equal pointers (and obviously bit-equal contents).\n#[test]\nfn ac_035b_code_is_bit_stable_across_runs() {\n    let _guard = serial_guard();\n    for expected in [&EXPECTED_WAL, &EXPECTED_HEADER, &EXPECTED_SCHEMA, &EXPECTED_EMBEDDER] {\n        let (_dir1, path1) = fixture_for(expected.kind);\n        let (_dir2, path2) = fixture_for(expected.kind);\n        let detail1 = open_and_expect_corruption(&path1);\n        let detail2 = open_and_expect_corruption(&path2);\n        assert_eq!(detail1.recovery_hint.code, detail2.recovery_hint.code);\n        assert_eq!(detail1.recovery_hint.code, expected.code);\n        // The `&'static str` from two separate calls within the same\n        // process must point at the same backing storage — string-\n        // literal interning gives bit-equal pointer comparison and\n        // proves the engine isn't allocating a fresh `String` per\n        // failure.\n        assert!(\n            std::ptr::eq(detail1.recovery_hint.code, detail2.recovery_hint.code),\n            \"recovery_hint.code must be a static literal, not an allocated string\"\n        );\n    }\n}\n\n// ── AC-035c: lock released, fd not retained, no writer/scheduler thread ─────\n\n#[cfg(target_os = \"linux\")]\n#[test]\nfn ac_035c_lock_released_after_corruption_header() {\n    assert_lock_released_and_no_engine_residue(CorruptionKind::HeaderMalformed);\n}\n\n#[cfg(target_os = \"linux\")]\n#[test]\nfn ac_035c_lock_released_after_corruption_schema() {\n    assert_lock_released_and_no_engine_residue(CorruptionKind::SchemaInconsistent);\n}\n\n#[cfg(target_os = \"linux\")]\nfn assert_lock_released_and_no_engine_residue(kind: CorruptionKind) {\n    let _guard = serial_guard();\n    let (_dir, path) = fixture_for(kind);\n    // Trigger the failed open; the lock must be released by the time\n    // the call returns.\n    let err = Engine::open(&path).expect_err(\"must fail\");\n    assert!(matches!(err, EngineOpenError::Corruption(_)));\n\n    let lock_path = lock_path_for(&path);\n    assert!(lock_path.exists(), \"engine should have created the lockfile before releasing it\");\n\n    // Re-acquire the advisory lock that the engine took on `.lock`. If\n    // the failed open leaked the file lock, this `flock(LOCK_EX|NB)`\n    // would return EWOULDBLOCK.\n    let probe = File::options().read(true).write(true).open(&lock_path).expect(\"open lock file\");\n    let probe_fd: i32 = std::os::unix::io::AsRawFd::as_raw_fd(&probe);\n    let rc = unsafe { libc::flock(probe_fd, libc::LOCK_EX | libc::LOCK_NB) };\n    assert_eq!(\n        rc,\n        0,\n        \"AC-035c: lock must be releasable after failed open ({}): errno = {}\",\n        lock_path.display(),\n        std::io::Error::last_os_error()\n    );\n    let _ = unsafe { libc::flock(probe_fd, libc::LOCK_UN) };\n\n    // /proc/self/fd: assert no fd points at the database file. The\n    // canonical absolute path of `path` must not appear as the\n    // destination of any open fd in this process.\n    let canonical = path.canonicalize().expect(\"canonicalize db path\");\n    let fd_dir = PathBuf::from(\"/proc/self/fd\");\n    for entry in fs::read_dir(&fd_dir).expect(\"read /proc/self/fd\") {\n        let entry = entry.expect(\"dirent\");\n        let link = match fs::read_link(entry.path()) {\n            Ok(target) => target,\n            // The fd may have been closed between readdir and readlink;\n            // race is fine for this assertion.\n            Err(_) => continue,\n        };\n        assert_ne!(\n            link,\n            canonical,\n            \"AC-035c: /proc/self/fd/{} still points at the database \\\n             file after a failed open\",\n            entry.file_name().to_string_lossy()\n        );\n    }\n\n    // /proc/self/task: no thread named per fathomdb conventions\n    // (`fathomdb-reader-N`, etc.) must be live in this process.\n    let task_dir = PathBuf::from(\"/proc/self/task\");\n    for entry in fs::read_dir(&task_dir).expect(\"read /proc/self/task\") {\n        let entry = entry.expect(\"task dirent\");\n        let comm_path = entry.path().join(\"comm\");\n        let Ok(comm_bytes) = fs::read(&comm_path) else { continue };\n        let comm = String::from_utf8_lossy(&comm_bytes).trim().to_string();\n        assert!(\n            !comm.starts_with(\"fathomdb-\"),\n            \"AC-035c: thread named '{comm}' is still live after a failed open\"\n        );\n    }\n}\n\n#[cfg(target_os = \"linux\")]\nfn lock_path_for(db_path: &Path) -> PathBuf {\n    let mut lock = db_path.as_os_str().to_owned();\n    lock.push(\".lock\");\n    PathBuf::from(lock)\n}\n","numLines":341,"startLine":1,"totalLines":341}}}
