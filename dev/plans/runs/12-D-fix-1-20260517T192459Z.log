{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RqnF1tms98jUSKGZ55LkN3","type":"tool_result","content":"1\t//! Documented page-corruption tool for AC-006 fixture binding.\n2\t//!\n3\t//! AC-006 requires a deterministic page-corruption harness whose flavors\n4\t//! map onto the two `code` values the engine surfaces from\n5\t//! `(EventSource::SqliteInternal, EventCategory::Corruption)`:\n6\t//!\n7\t//! - [`corrupt_database_header`] — overwrites the SQLite magic-header\n8\t//!   string at the start of the page at index 0 (the header-bearing\n9\t//!   page). On reopen this surfaces `SQLITE_NOTADB`.\n10\t//! - [`corrupt_interior_page_byte`] — XORs a single byte at a caller\n11\t//!   chosen `(page_index, byte_offset)` outside the magic header. With\n12\t//!   `byte_offset >= 100` on the page at index 0 (or any byte on a\n13\t//!   page at index >= 1) this hits the SQLite B-tree decoder during\n14\t//!   the `Engine::open` schema probe and surfaces `SQLITE_CORRUPT`.\n15\t//!\n16\t//! Both helpers operate on a CLOSED database file. They MUST NOT be\n17\t//! called against an open SQLite handle: the harness writes raw bytes via\n18\t//! `std::fs`, bypassing the page cache.\n19\t//!\n20\t//! The helpers `fsync` after every write so the corruption is durable\n21\t//! before reopen — otherwise the kernel page cache can mask the flip and\n22\t//! reproduce a clean page on the next open.\n23\t\n24\tuse std::fs::{File, OpenOptions};\n25\tuse std::io::{Read, Seek, SeekFrom, Write};\n26\tuse std::path::{Path, PathBuf};\n27\t\n28\t/// SQLite default page size used by the engine. Page 0 is the\n29\t/// header-bearing page; pages 1..N are interior / leaf pages of the\n30\t/// canonical b-trees.\n31\tpub const DEFAULT_PAGE_SIZE: u64 = 4096;\n32\t\n33\t/// Overwrite the SQLite magic-header string at the start of the page\n34\t/// at index 0 (the header-bearing page).\n35\t///\n36\t/// Effect on reopen: `Connection::open` (or the first `PRAGMA` call)\n37\t/// fails with extended code `SQLITE_NOTADB`, which the engine maps to\n38\t/// `EngineOpenError::Corruption(CorruptionDetail { kind:\n39\t/// HeaderMalformed, .. })` and emits `(SqliteInternal, Corruption,\n40\t/// code = \"SQLITE_NOTADB\")`.\n41\tpub fn corrupt_database_header(path: &Path) {\n42\t    let mut file =\n43\t        OpenOptions::new().read(true).write(true).open(path).expect(\"open db file for corruption\");\n44\t    file.seek(SeekFrom::Start(0)).expect(\"seek to header\");\n45\t    // Replace the SQLite magic (\"SQLite format 3\\0\", 16 bytes) with a\n46\t    // pattern guaranteed not to be a valid SQLite header.\n47\t    file.write_all(b\"not-a-sqlite-db!\").expect(\"overwrite header magic\");\n48\t    file.flush().expect(\"flush header overwrite\");\n49\t    file.sync_all().expect(\"fsync after header corruption\");\n50\t}\n51\t\n52\t/// XOR a single byte at `(page_index, byte_offset)` with `xor_mask`.\n53\t///\n54\t/// Use `page_index = 0, byte_offset >= 100` to corrupt the B-tree\n55\t/// header / cell-pointer region of the page at index 0 while\n56\t/// preserving the SQLite magic string (the magic occupies the first\n57\t/// 16 bytes; the database header occupies bytes 0..100). On reopen\n58\t/// the engine's schema probe (`PRAGMA schema_version`) then forces\n59\t/// SQLite to decode the corrupt b-tree page and fails with extended\n60\t/// code `SQLITE_CORRUPT`, which the engine maps to\n61\t/// `EngineOpenError::Corruption(CorruptionDetail { kind:\n62\t/// SchemaInconsistent, .. })` and emits `(SqliteInternal, Corruption,\n63\t/// code = \"SQLITE_CORRUPT\")`.\n64\t///\n65\t/// `xor_mask` must be non-zero — XORing with 0 is a no-op and produces\n66\t/// a misleading \"corruption that wasn't\" assertion failure.\n67\tpub fn corrupt_interior_page_byte(path: &Path, page_index: u32, byte_offset: u16, xor_mask: u8) {\n68\t    assert_ne!(xor_mask, 0, \"corrupt_interior_page_byte: xor_mask must be non-zero\");\n69\t    let absolute = u64::from(page_index) * DEFAULT_PAGE_SIZE + u64::from(byte_offset);\n70\t    let mut file =\n71\t        OpenOptions::new().read(true).write(true).open(path).expect(\"open db file for corruption\");\n72\t    file.seek(SeekFrom::Start(absolute)).expect(\"seek to interior byte\");\n73\t    let mut buf = [0u8; 1];\n74\t    file.read_exact(&mut buf).expect(\"read byte to corrupt\");\n75\t    buf[0] ^= xor_mask;\n76\t    file.seek(SeekFrom::Start(absolute)).expect(\"seek back\");\n77\t    file.write_all(&buf).expect(\"write corrupted byte\");\n78\t    file.flush().expect(\"flush corruption\");\n79\t    file.sync_all().expect(\"fsync after interior corruption\");\n80\t}\n81\t\n82\t/// Path of the SQLite write-ahead-log sidecar file for `db_path`.\n83\t///\n84\t/// SQLite appends the literal suffix `-wal` to the database file name;\n85\t/// it does NOT swap a file extension. `foo.sqlite` → `foo.sqlite-wal`.\n86\t#[allow(dead_code)]\n87\tpub fn wal_sidecar_path(db_path: &Path) -> PathBuf {\n88\t    let mut wal = db_path.as_os_str().to_owned();\n89\t    wal.push(\"-wal\");\n90\t    PathBuf::from(wal)\n91\t}\n92\t\n93\t/// Replace `db_path`'s WAL sidecar with a header that advertises a page\n94\t/// size larger than `SQLITE_MAX_PAGE_SIZE` (65536). On reopen the engine's\n95\t/// WAL-replay step (`PRAGMA journal_mode = WAL`) refuses to apply the\n96\t/// log and surfaces `SQLITE_CORRUPT`, which the engine maps to\n97\t/// `EngineOpenError::Corruption(CorruptionDetail { kind:\n98\t/// WalReplayFailure, stage: WalReplay, .. })`.\n99\t///\n100\t/// MUST be called against a CLOSED database. The previous WAL sidecar\n101\t/// (if any) is truncated and rewritten.\n102\t#[allow(dead_code)]\n103\tpub fn corrupt_wal_invalid_page_size(db_path: &Path) {\n104\t    let wal_path = wal_sidecar_path(db_path);\n105\t    let mut file = File::create(&wal_path).expect(\"create -wal sidecar\");\n106\t    // WAL header layout (`sqlite3WalOpen` / `walIndexRecover` in SQLite):\n107\t    //   off  0 .. 3  magic (big-endian 0x377f0682 or 0x377f0683)\n108\t    //   off  4 .. 7  file format version (big-endian, expected 3007000)\n109\t    //   off  8 .. 11 page size (big-endian; rejected if > SQLITE_MAX_PAGE_SIZE)\n110\t    //   off 12 .. 15 checkpoint sequence\n111\t    //   off 16 .. 19 salt-1\n112\t    //   off 20 .. 23 salt-2\n113\t    //   off 24 .. 27 checksum-1\n114\t    //   off 28 .. 31 checksum-2\n115\t    let mut header = [0u8; 32];\n116\t    header[0..4].copy_from_slice(&0x377f_0683_u32.to_be_bytes());\n117\t    header[4..8].copy_from_slice(&3_007_000_u32.to_be_bytes());\n118\t    // 0x0080_0000 (8 MiB) exceeds SQLITE_MAX_PAGE_SIZE (65 536).\n119\t    header[8..12].copy_from_slice(&0x0080_0000_u32.to_be_bytes());\n120\t    file.write_all(&header).expect(\"write wal header\");\n121\t    file.flush().expect(\"flush wal header\");\n122\t    file.sync_all().expect(\"fsync after wal header corruption\");\n123\t}\n124\t\n125\t/// Null out the `dimension` column of the default embedder profile row\n126\t/// so that on reopen `check_embedder_profile` cannot decode the stored\n127\t/// identity. The engine maps this to\n128\t/// `EngineOpenError::Corruption(CorruptionDetail { kind:\n129\t/// EmbedderIdentityDrift, stage: EmbedderIdentity, .. })`.\n130\t///\n131\t/// MUST be called against a CLOSED database. Uses a raw rusqlite\n132\t/// connection to bypass the engine's open path so the corruption is\n133\t/// committed before the test re-opens.\n134\t#[allow(dead_code)]\n135\tpub fn corrupt_embedder_profile_row(db_path: &Path) {\n136\t    let conn = rusqlite::Connection::open(db_path).expect(\"open db for profile corruption\");\n137\t    // NEGATIVE dimension passes the `NOT NULL` constraint but fails\n138\t    // `row.get::<_, u32>(2)` with `IntegralValueOutOfRange`, which the\n139\t    // engine maps to `Corruption(EmbedderIdentityDrift)`. NULL would\n140\t    // hit the `NOT NULL` schema constraint and never commit.\n141\t    conn.execute(\n142\t        \"UPDATE _fathomdb_embedder_profiles SET dimension = -1 WHERE profile = 'default'\",\n143\t        [],\n144\t    )\n145\t    .expect(\"set embedder profile dimension to -1\");\n146\t    // Force a checkpoint so the corruption lands in the main DB file\n147\t    // rather than sitting in the -wal sidecar (the open path examines\n148\t    // both, but we want the corruption to survive a -wal teardown).\n149\t    conn.execute_batch(\"PRAGMA wal_checkpoint(TRUNCATE)\").ok();\n150\t    drop(conn);\n151\t}\n152\t"}]},"parent_tool_use_id":null,"session_id":"3dcf3508-c16d-46fb-9860-076600a60569","uuid":"90b34d27-488c-4189-b5df-ce4a5e6fd1d8","timestamp":"2026-05-17T19:25:14.678Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-D-durability-harnesses-20260517T185755Z/src/rust/crates/fathomdb-engine/tests/support/corruption.rs","content":"//! Documented page-corruption tool for AC-006 fixture binding.\n//!\n//! AC-006 requires a deterministic page-corruption harness whose flavors\n//! map onto the two `code` values the engine surfaces from\n//! `(EventSource::SqliteInternal, EventCategory::Corruption)`:\n//!\n//! - [`corrupt_database_header`] — overwrites the SQLite magic-header\n//!   string at the start of the page at index 0 (the header-bearing\n//!   page). On reopen this surfaces `SQLITE_NOTADB`.\n//! - [`corrupt_interior_page_byte`] — XORs a single byte at a caller\n//!   chosen `(page_index, byte_offset)` outside the magic header. With\n//!   `byte_offset >= 100` on the page at index 0 (or any byte on a\n//!   page at index >= 1) this hits the SQLite B-tree decoder during\n//!   the `Engine::open` schema probe and surfaces `SQLITE_CORRUPT`.\n//!\n//! Both helpers operate on a CLOSED database file. They MUST NOT be\n//! called against an open SQLite handle: the harness writes raw bytes via\n//! `std::fs`, bypassing the page cache.\n//!\n//! The helpers `fsync` after every write so the corruption is durable\n//! before reopen — otherwise the kernel page cache can mask the flip and\n//! reproduce a clean page on the next open.\n\nuse std::fs::{File, OpenOptions};\nuse std::io::{Read, Seek, SeekFrom, Write};\nuse std::path::{Path, PathBuf};\n\n/// SQLite default page size used by the engine. Page 0 is the\n/// header-bearing page; pages 1..N are interior / leaf pages of the\n/// canonical b-trees.\npub const DEFAULT_PAGE_SIZE: u64 = 4096;\n\n/// Overwrite the SQLite magic-header string at the start of the page\n/// at index 0 (the header-bearing page).\n///\n/// Effect on reopen: `Connection::open` (or the first `PRAGMA` call)\n/// fails with extended code `SQLITE_NOTADB`, which the engine maps to\n/// `EngineOpenError::Corruption(CorruptionDetail { kind:\n/// HeaderMalformed, .. })` and emits `(SqliteInternal, Corruption,\n/// code = \"SQLITE_NOTADB\")`.\npub fn corrupt_database_header(path: &Path) {\n    let mut file =\n        OpenOptions::new().read(true).write(true).open(path).expect(\"open db file for corruption\");\n    file.seek(SeekFrom::Start(0)).expect(\"seek to header\");\n    // Replace the SQLite magic (\"SQLite format 3\\0\", 16 bytes) with a\n    // pattern guaranteed not to be a valid SQLite header.\n    file.write_all(b\"not-a-sqlite-db!\").expect(\"overwrite header magic\");\n    file.flush().expect(\"flush header overwrite\");\n    file.sync_all().expect(\"fsync after header corruption\");\n}\n\n/// XOR a single byte at `(page_index, byte_offset)` with `xor_mask`.\n///\n/// Use `page_index = 0, byte_offset >= 100` to corrupt the B-tree\n/// header / cell-pointer region of the page at index 0 while\n/// preserving the SQLite magic string (the magic occupies the first\n/// 16 bytes; the database header occupies bytes 0..100). On reopen\n/// the engine's schema probe (`PRAGMA schema_version`) then forces\n/// SQLite to decode the corrupt b-tree page and fails with extended\n/// code `SQLITE_CORRUPT`, which the engine maps to\n/// `EngineOpenError::Corruption(CorruptionDetail { kind:\n/// SchemaInconsistent, .. })` and emits `(SqliteInternal, Corruption,\n/// code = \"SQLITE_CORRUPT\")`.\n///\n/// `xor_mask` must be non-zero — XORing with 0 is a no-op and produces\n/// a misleading \"corruption that wasn't\" assertion failure.\npub fn corrupt_interior_page_byte(path: &Path, page_index: u32, byte_offset: u16, xor_mask: u8) {\n    assert_ne!(xor_mask, 0, \"corrupt_interior_page_byte: xor_mask must be non-zero\");\n    let absolute = u64::from(page_index) * DEFAULT_PAGE_SIZE + u64::from(byte_offset);\n    let mut file =\n        OpenOptions::new().read(true).write(true).open(path).expect(\"open db file for corruption\");\n    file.seek(SeekFrom::Start(absolute)).expect(\"seek to interior byte\");\n    let mut buf = [0u8; 1];\n    file.read_exact(&mut buf).expect(\"read byte to corrupt\");\n    buf[0] ^= xor_mask;\n    file.seek(SeekFrom::Start(absolute)).expect(\"seek back\");\n    file.write_all(&buf).expect(\"write corrupted byte\");\n    file.flush().expect(\"flush corruption\");\n    file.sync_all().expect(\"fsync after interior corruption\");\n}\n\n/// Path of the SQLite write-ahead-log sidecar file for `db_path`.\n///\n/// SQLite appends the literal suffix `-wal` to the database file name;\n/// it does NOT swap a file extension. `foo.sqlite` → `foo.sqlite-wal`.\n#[allow(dead_code)]\npub fn wal_sidecar_path(db_path: &Path) -> PathBuf {\n    let mut wal = db_path.as_os_str().to_owned();\n    wal.push(\"-wal\");\n    PathBuf::from(wal)\n}\n\n/// Replace `db_path`'s WAL sidecar with a header that advertises a page\n/// size larger than `SQLITE_MAX_PAGE_SIZE` (65536). On reopen the engine's\n/// WAL-replay step (`PRAGMA journal_mode = WAL`) refuses to apply the\n/// log and surfaces `SQLITE_CORRUPT`, which the engine maps to\n/// `EngineOpenError::Corruption(CorruptionDetail { kind:\n/// WalReplayFailure, stage: WalReplay, .. })`.\n///\n/// MUST be called against a CLOSED database. The previous WAL sidecar\n/// (if any) is truncated and rewritten.\n#[allow(dead_code)]\npub fn corrupt_wal_invalid_page_size(db_path: &Path) {\n    let wal_path = wal_sidecar_path(db_path);\n    let mut file = File::create(&wal_path).expect(\"create -wal sidecar\");\n    // WAL header layout (`sqlite3WalOpen` / `walIndexRecover` in SQLite):\n    //   off  0 .. 3  magic (big-endian 0x377f0682 or 0x377f0683)\n    //   off  4 .. 7  file format version (big-endian, expected 3007000)\n    //   off  8 .. 11 page size (big-endian; rejected if > SQLITE_MAX_PAGE_SIZE)\n    //   off 12 .. 15 checkpoint sequence\n    //   off 16 .. 19 salt-1\n    //   off 20 .. 23 salt-2\n    //   off 24 .. 27 checksum-1\n    //   off 28 .. 31 checksum-2\n    let mut header = [0u8; 32];\n    header[0..4].copy_from_slice(&0x377f_0683_u32.to_be_bytes());\n    header[4..8].copy_from_slice(&3_007_000_u32.to_be_bytes());\n    // 0x0080_0000 (8 MiB) exceeds SQLITE_MAX_PAGE_SIZE (65 536).\n    header[8..12].copy_from_slice(&0x0080_0000_u32.to_be_bytes());\n    file.write_all(&header).expect(\"write wal header\");\n    file.flush().expect(\"flush wal header\");\n    file.sync_all().expect(\"fsync after wal header corruption\");\n}\n\n/// Null out the `dimension` column of the default embedder profile row\n/// so that on reopen `check_embedder_profile` cannot decode the stored\n/// identity. The engine maps this to\n/// `EngineOpenError::Corruption(CorruptionDetail { kind:\n/// EmbedderIdentityDrift, stage: EmbedderIdentity, .. })`.\n///\n/// MUST be called against a CLOSED database. Uses a raw rusqlite\n/// connection to bypass the engine's open path so the corruption is\n/// committed before the test re-opens.\n#[allow(dead_code)]\npub fn corrupt_embedder_profile_row(db_path: &Path) {\n    let conn = rusqlite::Connection::open(db_path).expect(\"open db for profile corruption\");\n    // NEGATIVE dimension passes the `NOT NULL` constraint but fails\n    // `row.get::<_, u32>(2)` with `IntegralValueOutOfRange`, which the\n    // engine maps to `Corruption(EmbedderIdentityDrift)`. NULL would\n    // hit the `NOT NULL` schema constraint and never commit.\n    conn.execute(\n        \"UPDATE _fathomdb_embedder_profiles SET dimension = -1 WHERE profile = 'default'\",\n        [],\n    )\n    .expect(\"set embedder profile dimension to -1\");\n    // Force a checkpoint so the corruption lands in the main DB file\n    // rather than sitting in the -wal sidecar (the open path examines\n    // both, but we want the corruption to survive a -wal teardown).\n    conn.execute_batch(\"PRAGMA wal_checkpoint(TRUNCATE)\").ok();\n    drop(conn);\n}\n","numLines":152,"startLine":1,"totalLines":152}}}
