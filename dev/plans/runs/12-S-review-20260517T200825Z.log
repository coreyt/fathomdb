   137	    text = changelog.read_text(encoding="utf-8")
   138	    # Split CHANGELOG into sections per `##` heading and only consider
   139	    # text under a heading containing "Removed" (case-insensitive). This
   140	    # bounds the match to the announcement region.
   141	    sections = re.split(r"^(#{1,6}\s+.*)$", text, flags=re.MULTILINE)
   142	    removed_text_parts: list[str] = []
   143	    # `sections` is [pre, heading1, body1, heading2, body2, ...]
   144	    for i in range(1, len(sections), 2):
   145	        heading = sections[i]
   146	        body = sections[i + 1] if i + 1 < len(sections) else ""
   147	        if re.search(r"removed", heading, flags=re.IGNORECASE):
   148	            removed_text_parts.append(body)
   149	    haystack = "\n".join(removed_text_parts)
   150	    undocumented = []
   151	    for r in removed:
   152	        if not re.search(r"\b" + re.escape(r.name) + r"\b", haystack):
   153	            undocumented.append(r)
   154	    return undocumented
   155	
   156	
   157	def load_diff(args: argparse.Namespace) -> str:
   158	    if args.diff_file:
   159	        return Path(args.diff_file).read_text(encoding="utf-8")
   160	    cmd = ["git", "-C", str(args.repo_root), "diff", f"{args.base}..{args.head}", "--"]
   161	    for prefix in SCAN_PREFIXES:
   162	        cmd.append(f"{prefix}**")
   163	    completed = subprocess.run(cmd, check=False, capture_output=True, text=True)
   164	    if completed.returncode != 0:
   165	        sys.stderr.write(completed.stderr)
   166	        sys.exit(2)
   167	    return completed.stdout
   168	
   169	
   170	def main(argv: list[str]) -> int:
   171	    p = argparse.ArgumentParser(description=__doc__)
   172	    p.add_argument("--base", default="0.6.0-rewrite", help="base git ref")
   173	    p.add_argument("--head", default="HEAD", help="head git ref")
   174	    p.add_argument("--diff-file", default=None, help="read diff from a file instead of git")
   175	    p.add_argument("--changelog", default=None, help="CHANGELOG.md path (default: <repo>/CHANGELOG.md)")
   176	    p.add_argument("--repo-root", default=None, help="repository root (default: git rev-parse)")
   177	    args = p.parse_args(argv)
   178	
   179	    if args.repo_root is None:
   180	        try:
   181	            args.repo_root = subprocess.check_output(
   182	                ["git", "rev-parse", "--show-toplevel"], text=True
   183	            ).strip()
   184	        except subprocess.CalledProcessError:
   185	            sys.stderr.write("not inside a git repo; pass --repo-root\n")
   186	            return 2
   187	
   188	    changelog_path = Path(args.changelog) if args.changelog else Path(args.repo_root) / "CHANGELOG.md"
   189	    if not changelog_path.exists():
   190	        sys.stderr.write(f"CHANGELOG.md missing at {changelog_path}\n")
   191	        return 2
   192	
   193	    diff_text = load_diff(args)
   194	    removals, additions = parse_diff(diff_text)
   195	    truly_removed = real_removals(removals, additions)
   196	    undocumented = changelog_documents(changelog_path, truly_removed)
   197	
   198	    if undocumented:
   199	        sys.stderr.write("AC-050c: removed public symbols missing from CHANGELOG Removed section:\n")
   200	        for r in undocumented:
   201	            sys.stderr.write(f"  {r.path}: {r.symbol_kind} {r.name}\n")
   202	        return 1
   203	
   204	    if truly_removed:
   205	        sys.stdout.write(f"AC-050c OK: {len(truly_removed)} removals all documented.\n")
   206	    return 0
   207	
   208	
   209	if __name__ == "__main__":
   210	    sys.exit(main(sys.argv[1:]))

