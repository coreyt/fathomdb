   252	# Emit a structured drift diagnostic: `<file>:<line>: version drift —
   253	# observed "X", expected "Y"`. Centralized so every drift site has the
   254	# same shape (parseable by tooling, asserted in test_set_version.sh).
   255	_drift() {
   256	  local file="$1" line="$2" observed="$3" expected="$4"
   257	  printf '%s:%s: version drift — observed "%s", expected "%s"\n' \
   258	    "$file" "${line:-?}" "$observed" "$expected" >&2
   259	}
   260	
   261	check_files() {
   262	  local ws py npm emb
