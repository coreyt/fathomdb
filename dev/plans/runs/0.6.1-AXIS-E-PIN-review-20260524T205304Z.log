     1	#!/usr/bin/env bash
     2	# Shared output discipline for scripts/agent-*.sh.
     3	#
     4	# Output contract:
     5	#   - Pass: silent on stdout (or "ok <verb> NNNms" if AGENT_VERBOSE=1).
     6	#   - Fail: first 200 lines of captured output to stdout, then a footer
     7	#           with the spill path and exit code. Spill file always written.
     8	#
     9	# Rationale: keep agent context clean on the happy path; on failure give
    10	# the agent the *start* of the diagnostic (where the actionable error
    11	# lives) and a path to the rest. Cap is on output, not capture — the
    12	# spill file always has the full log.
    13	
    14	set -u
    15	
    16	# Usage: run_capped <verb> <command...>
    17	# Returns the underlying command's exit code.
    18	run_capped() {
    19	  local verb="$1"
    20	  shift
    21	
    22	  local spill="/tmp/fathomdb-agent-${verb}-$$.log"
    23	  local start_ms end_ms duration_ms
    24	  local rc=0
    25	
    26	  start_ms=$(date +%s%3N 2>/dev/null || python3 -c 'import time; print(int(time.time()*1000))')
    27	
    28	  # Capture combined stdout+stderr.
    29	  set +e
    30	  "$@" >"$spill" 2>&1
    31	  rc=$?
    32	  set -e
    33	  set -u
    34	
    35	  end_ms=$(date +%s%3N 2>/dev/null || python3 -c 'import time; print(int(time.time()*1000))')
    36	  duration_ms=$((end_ms - start_ms))
    37	
    38	  if [ "$rc" -eq 0 ]; then
    39	    if [ "${AGENT_VERBOSE:-0}" = "1" ]; then
    40	      printf 'ok %s %sms\n' "$verb" "$duration_ms"
    41	    fi
    42	    rm -f "$spill"
    43	    return 0
    44	  fi
    45	
    46	  local total_lines
    47	  total_lines=$(wc -l <"$spill" | tr -d ' ')
    48	
    49	  printf 'FAIL %s (exit=%d, %sms)\n' "$verb" "$rc" "$duration_ms"
    50	  printf -- '----\n'
    51	  head -n 200 "$spill"
    52	  if [ "$total_lines" -gt 200 ]; then
    53	    printf -- '----\n'
    54	    printf 'output truncated (%s lines total); full log: %s\n' "$total_lines" "$spill"
    55	  else
    56	    printf -- '----\n'
    57	    printf 'full log: %s\n' "$spill"
    58	  fi
    59	  return "$rc"
    60	}
