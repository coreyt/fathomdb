   227	    """Deterministic, hop-stratified sample. The pooled ≥3-hop answerable cell is
   228	    sized to ``n_ge3_answerable`` (split 3/4-hop ~ the corpus ratio) — that cell
   229	    is the power-sim variance source; the 2-hop + unanswerable sets are context."""
   230	    rng = random.Random(seed)
   231	
   232	    def pick(pred: Any, n: int) -> list[Question]:
   233	        pool = sorted([q for q in questions if pred(q)], key=lambda q: q.id)
   234	        return pool if len(pool) <= n else rng.sample(pool, n)
   235	
   236	    n3 = round(n_ge3_answerable * 0.65)
   237	    n4 = n_ge3_answerable - n3
   238	    sample: list[Question] = []
   239	    sample += pick(lambda q: q.answerable and q.hop_count == 3, n3)
   240	    sample += pick(lambda q: q.answerable and q.hop_count == 4, n4)
   241	    sample += pick(lambda q: q.answerable and q.hop_count == 2, n_2hop_answerable)
   242	    sample += pick(lambda q: (not q.answerable) and q.hop_count >= 3, n_unanswerable_ge3)
   243	    sample.sort(key=lambda q: q.id)
   244	    return sample
