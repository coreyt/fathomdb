   296	        "shape": shape,
   297	        "target_p_go": target,
   298	        "required_n": chosen,
   299	        "power_ok": chosen is not None,
   300	        "curve": curve,
   301	        "rho": rho,
   302	        "lift": lift,
   303	        "material_threshold": MATERIAL_F1_LIFT,
   304	        "note": (
   305	            "required_n is the pooled >=3-hop cell size; power sized via the whole "
   306	            "decide() rule (imported, not redefined). MATERIAL_F1_LIFT (0.02) sits "
   307	            "at/above the implied pooled >=3-hop MDE at this N."
   308	        ),
   309	    }

