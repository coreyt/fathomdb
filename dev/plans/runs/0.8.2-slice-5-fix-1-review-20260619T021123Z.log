   184	
   185	def simulate_p_go(
   186	    base_f1: Sequence[float],
   187	    base_em: Sequence[float],
   188	    hop_counts: Sequence[int],
   189	    *,
   190	    shape: str,
   191	    n: int,
   192	    rho: float = DEFAULT_RHO,
   193	    lift: float = FLAT_POSITIVE_LIFT,
   194	    n_trials: int = 300,
   195	    n_boot: int = 400,
   196	    seed: int = 0,
   197	) -> dict[str, Any]:
   198	    """Estimate P(GO) for a pooled ≥3-hop cell of size ``n`` under ``shape``.
   199	
   200	    Draws ``n_trials`` paired-bootstrap resamples from the measured baseline
   201	    F1/EM distribution, applies the shape's per-question ΔF1, computes the
   202	    summary statistics the harness would hand ``decide()``, and reports the
   203	    fraction that ``decide()`` calls **GO**. ``decide()`` is the real frozen rule.
   204	    """
   205	    if shape not in EFFECT_SHAPES:
   206	        raise ValueError(f"unknown shape {shape!r}")
   207	    bf = np.asarray(base_f1, dtype=float)
   208	    be = np.asarray(base_em, dtype=float)
   209	    bh = np.asarray(hop_counts, dtype=float)
   210	    if bf.size == 0:
   211	        raise ValueError("base_f1 is empty — need measured baseline F1")
   212	    sd_f1 = float(bf.std(ddof=1)) if bf.size > 1 else 0.0
   213	    sd_em = float(be.std(ddof=1)) if be.size > 1 else 0.0
   214	    sd_pair_f1 = sd_f1 * math.sqrt(2 * (1 - rho))
   215	    sd_pair_em = sd_em * math.sqrt(2 * (1 - rho))
   216	
   217	    rng = np.random.default_rng(seed)
   218	    go = 0
   219	    for _ in range(n_trials):
   220	        # Resample a size-n pooled ≥3-hop cell from the measured baseline (its hop
   221	        # mix carries the trend structure).
   222	        sel = rng.integers(0, bf.size, size=n)
   223	        hops = bh[sel]
   224	        true_d = effect_delta(shape, hops, lift=lift)
   225	        # Model the per-question PAIRED DIFFERENCE directly (ppr − comparator):
   226	        # mean = the shape's true ΔF1, SD = the paired-difference SD derived from
   227	        # the measured baseline variance. Per-question F1 ∈ [0,1] ⇒ ΔF1 ∈ [-1,1];
   228	        # clip the *difference*, NOT ppr=base+noise — the latter biases the mean
   229	        # delta negative at large N when the baseline F1 is bimodal (a power
   230	        # artifact that made P(GO) spuriously fall toward 0 as N grew).
   231	        delta_f1 = np.clip(true_d + rng.normal(0, sd_pair_f1, size=n), -1.0, 1.0)
   232	        # EM: no modelled lift (F1 is the primary signal; EM is a CI-banded guard).
   233	        delta_em = np.clip(rng.normal(0, sd_pair_em, size=n), -1.0, 1.0)
   234	
   235	        f1_delta = float(delta_f1.mean())
   236	        f1_ci_low = _percentile_ci_low(delta_f1, rng, n_boot=n_boot)
   237	        em_ci_high = _percentile_ci_high(delta_em, rng, n_boot=n_boot)
   238	        neg_sig = _slope_neg_significant(hops, delta_f1, rng, n_boot=n_boot)
   239	
   240	        verdict = decide(
   241	            material={"f1_delta": f1_delta, "f1_ci_low": f1_ci_low},
   242	            em={"ci_high": em_ci_high},
   243	            trend={"neg_significant": neg_sig},
   244	            confident_wrong={"increase_significant": False},
   245	            power_ok=True,
   246	        )
