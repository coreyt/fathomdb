   117	
   118	def effect_delta(shape: str, hop_counts: np.ndarray, *, lift: float = FLAT_POSITIVE_LIFT) -> np.ndarray:
   119	    """Per-question TRUE ΔF1 (ppr − comparator) for an effect ``shape``.
   120	
   121	    Each shape is centred so the *pooled* mean lift ≈ ``lift`` (so the shapes are
   122	    comparable at the primary endpoint and only their hop-profile differs):
   123	      * ``flat_positive`` — equal ``lift`` at every hop (not strictly increasing).
   124	      * ``monotonic``     — increasing with hop (2<3<4), pooled mean ≈ ``lift``.
   125	      * ``inverted_u``    — peaks at 3-hop, dips at 2 and 4 (HippoRAG shape).
   126	    """
   127	    hops = np.asarray(hop_counts, dtype=float)
   128	    if shape == "flat_positive":
   129	        d = np.full_like(hops, lift)
   130	    elif shape == "monotonic":
   131	        # linear in hop, centred to mean ~lift over the present hops
   132	        base = (hops - hops.mean()) * lift
   133	        d = lift + base
   134	    elif shape == "inverted_u":
   135	        # peak at hop 3: penalise distance from 3, then CENTER so the pooled mean
   136	        # over the present hops == lift (subtract the mean bump). Without centering
   137	        # the bump rode ON TOP of lift ⇒ pooled mean ≈ lift·(1+0.8·frac_3hop) > lift,
   138	        # inflating P(GO) for this shape relative to flat/monotonic ([P2]).
   139	        bump = (lift * 0.8) * (1.0 - np.abs(hops - 3.0))
   140	        d = lift + bump - bump.mean()
   141	    else:
   142	        raise ValueError(f"unknown effect shape: {shape!r} (expected one of {EFFECT_SHAPES})")
   143	    return d
   144	
   145	
   146	def _percentile_ci_low(deltas: np.ndarray, rng: np.random.Generator, *, n_boot: int, alpha: float = 0.05) -> float:
   147	    """Lower bound of a percentile paired-bootstrap CI for the mean of ``deltas``."""
   148	    n = len(deltas)
   149	    idx = rng.integers(0, n, size=(n_boot, n))
   150	    boot_means = deltas[idx].mean(axis=1)
   151	    return float(np.quantile(boot_means, alpha / 2))
   152	
   153	
   154	def _percentile_ci_high(deltas: np.ndarray, rng: np.random.Generator, *, n_boot: int, alpha: float = 0.05) -> float:
   155	    n = len(deltas)
   156	    idx = rng.integers(0, n, size=(n_boot, n))
   157	    boot_means = deltas[idx].mean(axis=1)
   158	    return float(np.quantile(boot_means, 1 - alpha / 2))
   159	
   160	
   161	def _slope_neg_significant(
   162	    hops: np.ndarray, deltas: np.ndarray, rng: np.random.Generator, *, n_boot: int, alpha: float = 0.05
   163	) -> bool:
   164	    """True iff the OLS slope of ΔF1 on hop is significantly negative (its
   165	    paired-bootstrap CI lies entirely below 0). Needs ≥2 distinct hop values."""
   166	    if len(np.unique(hops)) < 2:
   167	        return False
   168	    n = len(deltas)
   169	    idx = rng.integers(0, n, size=(n_boot, n))
   170	    hb = hops[idx]
   171	    db = deltas[idx]
   172	    hbar = hb.mean(axis=1, keepdims=True)
   173	    dbar = db.mean(axis=1, keepdims=True)
   174	    cov = ((hb - hbar) * (db - dbar)).sum(axis=1)
   175	    var = ((hb - hbar) ** 2).sum(axis=1)
   176	    var = np.where(var == 0, np.nan, var)
   177	    slopes = cov / var
   178	    slopes = slopes[np.isfinite(slopes)]
   179	    if slopes.size == 0:
   180	        return False
   181	    ci_high = float(np.quantile(slopes, 1 - alpha / 2))
   182	    return ci_high < 0.0
