   250	    return {
   251	        "shape": shape,
   252	        "n": n,
   253	        "p_go": round(go / n_trials, 4),
   254	        "rho": rho,
   255	        "lift": lift,
   256	        "sd_baseline_f1": round(sd_f1, 6),
   257	        "sd_pair_f1": round(sd_pair_f1, 6),
   258	        "n_trials": n_trials,
   259	        "n_boot": n_boot,
   260	        "material_threshold": MATERIAL_F1_LIFT,
   261	        "seed": seed,
   262	    }
