   265	def required_n(
   266	    base_f1: Sequence[float],
   267	    base_em: Sequence[float],
   268	    hop_counts: Sequence[int],
   269	    *,
   270	    shape: str = "flat_positive",
   271	    target: float = TARGET_P_GO,
   272	    grid: Sequence[int] = (50, 100, 150, 200, 300, 400, 600, 800, 1200, 1600, 2000),
   273	    rho: float = DEFAULT_RHO,
   274	    lift: float = FLAT_POSITIVE_LIFT,
   275	    n_trials: int = 300,
   276	    n_boot: int = 400,
   277	    seed: int = 0,
   278	) -> dict[str, Any]:
   279	    """Smallest pooled ≥3-hop cell N on ``grid`` with P(GO) ≥ ``target``.
   280	
   281	    Returns the required N (``None`` if the grid never clears ``target``) plus the
   282	    full P(GO) curve, so the projection is auditable.
   283	    """
   284	    curve: list[dict[str, Any]] = []
   285	    chosen: int | None = None
