name: Release

on:
  push:
    tags:
      - "v*"
  workflow_dispatch:
    inputs:
      dry_run:
        description: "Rehearse cargo publish --dry-run + npm --dry-run; PyPI publish + post-publish smoke skipped entirely (no test.pypi slot burn)."
        type: boolean
        default: true

permissions:
  actions: read
  contents: write
  id-token: write

env:
  DRY_RUN: ${{ inputs.dry_run || 'false' }}

jobs:
  # Single ubuntu preflight. Combines:
  #   - scripts/verify-release-gates.sh (tag↔Cargo.toml lockstep, set-version
  #     --check-files lockstep, HEAD-on-main, CHANGELOG section, crate
  #     publish metadata).
  #   - actionlint on all workflow files (per feedback_workflow_validation —
  #     yaml.safe_load passes schema-invalid syntax GitHub silently rejects).
  verify-release:
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
        with:
          fetch-depth: 0  # need refs/heads/main for HEAD-reach check
      - name: Install actionlint
        run: |
          curl -fsSL https://raw.githubusercontent.com/rhysd/actionlint/v1.7.7/scripts/download-actionlint.bash \
            | bash -s -- 1.7.7
          sudo mv actionlint /usr/local/bin/actionlint
      - name: Validate workflow YAML
        run: actionlint .github/workflows/*.yml
      - name: Run release gates
        # Runs on push (tag-format + version-axis enforced) and
        # workflow_dispatch (tag check skipped, all other gates enforced;
        # dispatch with dry_run=false emits an emergency-republish warning).
        #
        # RELEASE_GATES_HEAD_REF: actions/checkout fetches all refs under
        # refs/remotes/origin/* but does NOT create a local refs/heads/main
        # when checking out a tag, so the gate's default lookup of
        # refs/heads/main fails on CI. Point the gate at the remote-tracking
        # ref. Local dev environments leave this unset and use the local
        # main branch as before.
        run: bash scripts/verify-release-gates.sh
        env:
          GH_TOKEN: ${{ github.token }}
          RELEASE_GATES_HEAD_REF: refs/remotes/origin/main

  # Multi-platform Python wheels via PyO3/maturin-action. Produces manylinux,
  # macOS (x86_64 + arm64), and Windows wheels for Python 3.10-3.12. The
  # working-directory must be `src/python` so maturin reads our pyproject.toml
  # there (manifest-path = ../rust/crates/fathomdb-py/Cargo.toml).
  build-python:
    needs: verify-release
    strategy:
      fail-fast: false
      matrix:
        include:
          - runner: ubuntu-latest
            target: x86_64-unknown-linux-gnu
            manylinux: "2_28"
          - runner: ubuntu-latest
            target: aarch64-unknown-linux-gnu
            manylinux: "2_28"
          - runner: macos-latest
            target: x86_64-apple-darwin
          - runner: macos-latest
            target: aarch64-apple-darwin
          - runner: windows-latest
            target: x86_64-pc-windows-msvc
    runs-on: ${{ matrix.runner }}
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
      - uses: actions/setup-python@a309ff8b426b58ec0e2a45f0f869d46889d02405 # v6.2.0
        with:
          python-version: "3.11"
      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
        with:
          toolchain: stable
          targets: ${{ matrix.target }}
      - uses: PyO3/maturin-action@e83996d129638aa358a18fbd1dfb82f0b0fb5d3b # v1.51.0
        with:
          target: ${{ matrix.target }}
          # Explicit -i: cross-compile Docker containers can pick up
          # python3.14 which pyo3 0.23 does not support. Bump alongside the
          # pyo3 upgrade landing in dev/notes/pyo3-0.28-upgrade-plan.md.
          args: --release --out dist -i python3.10 python3.11 python3.12
          manylinux: ${{ matrix.manylinux || 'auto' }}
          working-directory: src/python
      - uses: actions/upload-artifact@bbbca2ddaa5d8feaa63e36b76fdaad77386f024f # v7.0.0
        with:
          name: python-dist-${{ matrix.target }}
          path: src/python/dist/*

  # Native binding prebuilds for npm. The napi-rs CLI handles the rename to
  # fathomdb.<platform-label>.node per the `napi.triples` block in
  # src/ts/package.json — prefer this over a raw `cargo build` + manual cp
  # because the platform-label convention lives in the napi-rs CLI, not in
  # us. Binary lands flat at src/ts/fathomdb.<label>.node (NO prebuilds/
  # subdir; that was the pre-0.6.0 layout).
  build-napi:
    needs: verify-release
    strategy:
      fail-fast: false
      matrix:
        include:
          - runner: ubuntu-latest
            target: x86_64-unknown-linux-gnu
            label: linux-x64-gnu
          - runner: macos-latest
            target: x86_64-apple-darwin
            label: darwin-x64
          - runner: macos-latest
            target: aarch64-apple-darwin
            label: darwin-arm64
          - runner: windows-latest
            target: x86_64-pc-windows-msvc
            label: win32-x64-msvc
    runs-on: ${{ matrix.runner }}
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
      - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0
        with:
          node-version: "22"
      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
        with:
          toolchain: stable
          targets: ${{ matrix.target }}
      - uses: Swatinem/rust-cache@c19371144df3bb44fab255c43d04cbc2ab54d1c4 # v2.9.1
      - name: Install ts deps
        working-directory: src/ts
        run: npm ci
      - name: Build napi binding
        working-directory: src/ts
        env:
          CARGO_BUILD_TARGET: ${{ matrix.target }}
        run: npm run build:native
      - uses: actions/upload-artifact@bbbca2ddaa5d8feaa63e36b76fdaad77386f024f # v7.0.0
        with:
          name: napi-${{ matrix.label }}
          path: src/ts/fathomdb.${{ matrix.label }}.node

  # Pre-publish packaging verification for Rust crates:
  #   1. cargo build --release --workspace — compile check of every crate
  #      we are about to publish.
  #   2. cargo package --no-verify for the three leaf crates with no
  #      in-workspace dependencies (fathomdb-embedder-api, fathomdb-schema,
  #      fathomdb-query). Validates manifest/readme/license metadata
  #      without invoking the registry.
  #
  # The dependent crates (fathomdb-engine, fathomdb-embedder, fathomdb,
  # fathomdb-cli) are NOT packaged here: cargo package rewrites path deps
  # to versioned deps and then does a registry resolve on the rewritten
  # manifest. For a fresh release the leaf crates are not published yet,
  # so the resolve cannot find e.g. fathomdb-schema@0.6.0 and fails.
  # Manifest correctness of the dependent crates is enforced at actual
  # publish time inside `cargo publish`, which we do not want to duplicate
  # at CI cost.
  build-rust:
    runs-on: ubuntu-latest
    needs: verify-release
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
        with:
          toolchain: stable
      - uses: Swatinem/rust-cache@c19371144df3bb44fab255c43d04cbc2ab54d1c4 # v2.9.1
      - name: Verify workspace builds in release mode
        run: cargo build --release --workspace
      - name: Package fathomdb-embedder-api (leaf, Axis E)
        run: cargo package --no-verify -p fathomdb-embedder-api
      - name: Package fathomdb-schema (leaf, no in-workspace deps)
        run: cargo package --no-verify -p fathomdb-schema
      - name: Package fathomdb-query (leaf, no in-workspace deps)
        run: cargo package --no-verify -p fathomdb-query

  # Cross-ecosystem gate: every build must succeed before ANY publish runs.
  # Without this, a partial release (e.g. crates.io 0.6.0 published but
  # pypi 0.6.0 blocked on a build failure) leaves downstream versioning
  # unrecoverable — 0.6.1 would then have mismatched ecosystem coverage.
  all-builds-passed:
    runs-on: ubuntu-latest
    needs:
      - verify-release
      - build-python
      - build-napi
      - build-rust
    steps:
      - run: echo "all release build gates passed"

  # --- Tiered cargo publish (T1..T7) -----------------------------------------
  # Each tier publishes one crate, then sleeps 60s to let the crates.io
  # index propagate before the next tier resolves the dep against it.
  # --locked is omitted: the lock file is generated against local path
  # dependencies, which do not match the crates.io index state during
  # tiered publishing.
  # Order rationale: see dev/design/release.md § Tiered publish order.
  #
  # Idempotency: every tier delegates to scripts/release/cargo-publish-if-new.sh,
  # which checks crates.io for the target version and skips the publish
  # (exit 0) if it already exists. This covers axis-W-only patch releases
  # (axis-E held at a prior version) and partial-republish retries.

  publish-rust-t1-embedder-api:
    runs-on: ubuntu-latest
    needs: all-builds-passed
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
        with:
          toolchain: stable
      - name: cargo publish fathomdb-embedder-api
        run: |
          if [ "${DRY_RUN}" = "true" ]; then
            bash scripts/release/cargo-publish-if-new.sh --dry-run fathomdb-embedder-api
          else
            bash scripts/release/cargo-publish-if-new.sh fathomdb-embedder-api
          fi
        env:
          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}
      - name: Wait for crates.io index propagation
        if: ${{ inputs.dry_run != true }}
        run: sleep 60

  publish-rust-t2-schema:
    runs-on: ubuntu-latest
    needs: publish-rust-t1-embedder-api
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
        with:
          toolchain: stable
      - name: cargo publish fathomdb-schema
        run: |
          if [ "${DRY_RUN}" = "true" ]; then
            bash scripts/release/cargo-publish-if-new.sh --dry-run fathomdb-schema
          else
            bash scripts/release/cargo-publish-if-new.sh fathomdb-schema
          fi
        env:
          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}
      - name: Wait for crates.io index propagation
        if: ${{ inputs.dry_run != true }}
        run: sleep 60

  publish-rust-t3-query:
    runs-on: ubuntu-latest
    needs: publish-rust-t2-schema
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2

