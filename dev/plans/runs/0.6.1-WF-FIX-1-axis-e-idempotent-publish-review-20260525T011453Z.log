--- a/.github/workflows/release.yml
+++ b/.github/workflows/release.yml
@@ -128,305 +128,310 @@ jobs:
             label: win32-x64-msvc
     runs-on: ${{ matrix.runner }}
     steps:
       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
       - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0
         with:
           node-version: "22"
       - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
         with:
           toolchain: stable
           targets: ${{ matrix.target }}
       - uses: Swatinem/rust-cache@c19371144df3bb44fab255c43d04cbc2ab54d1c4 # v2.9.1
       - name: Install ts deps
         working-directory: src/ts
         run: npm ci
       - name: Build napi binding
         working-directory: src/ts
         env:
           CARGO_BUILD_TARGET: ${{ matrix.target }}
         run: npm run build:native
       - uses: actions/upload-artifact@bbbca2ddaa5d8feaa63e36b76fdaad77386f024f # v7.0.0
         with:
           name: napi-${{ matrix.label }}
           path: src/ts/fathomdb.${{ matrix.label }}.node
 
   # Pre-publish packaging verification for Rust crates:
   #   1. cargo build --release --workspace — compile check of every crate
   #      we are about to publish.
   #   2. cargo package --no-verify for the three leaf crates with no
   #      in-workspace dependencies (fathomdb-embedder-api, fathomdb-schema,
   #      fathomdb-query). Validates manifest/readme/license metadata
   #      without invoking the registry.
   #
   # The dependent crates (fathomdb-engine, fathomdb-embedder, fathomdb,
   # fathomdb-cli) are NOT packaged here: cargo package rewrites path deps
   # to versioned deps and then does a registry resolve on the rewritten
   # manifest. For a fresh release the leaf crates are not published yet,
   # so the resolve cannot find e.g. fathomdb-schema@0.6.0 and fails.
   # Manifest correctness of the dependent crates is enforced at actual
   # publish time inside `cargo publish`, which we do not want to duplicate
   # at CI cost.
   build-rust:
     runs-on: ubuntu-latest
     needs: verify-release
     steps:
       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
       - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
         with:
           toolchain: stable
       - uses: Swatinem/rust-cache@c19371144df3bb44fab255c43d04cbc2ab54d1c4 # v2.9.1
       - name: Verify workspace builds in release mode
         run: cargo build --release --workspace
       - name: Package fathomdb-embedder-api (leaf, Axis E)
         run: cargo package --no-verify -p fathomdb-embedder-api
       - name: Package fathomdb-schema (leaf, no in-workspace deps)
         run: cargo package --no-verify -p fathomdb-schema
       - name: Package fathomdb-query (leaf, no in-workspace deps)
         run: cargo package --no-verify -p fathomdb-query
 
   # Cross-ecosystem gate: every build must succeed before ANY publish runs.
   # Without this, a partial release (e.g. crates.io 0.6.0 published but
   # pypi 0.6.0 blocked on a build failure) leaves downstream versioning
   # unrecoverable — 0.6.1 would then have mismatched ecosystem coverage.
   all-builds-passed:
     runs-on: ubuntu-latest
     needs:
       - verify-release
       - build-python
       - build-napi
       - build-rust
     steps:
       - run: echo "all release build gates passed"
 
   # --- Tiered cargo publish (T1..T7) -----------------------------------------
   # Each tier publishes one crate, then sleeps 60s to let the crates.io
   # index propagate before the next tier resolves the dep against it.
   # --locked is omitted: the lock file is generated against local path
   # dependencies, which do not match the crates.io index state during
   # tiered publishing.
   # Order rationale: see dev/design/release.md § Tiered publish order.
+  #
+  # Idempotency: every tier delegates to scripts/release/cargo-publish-if-new.sh,
+  # which checks crates.io for the target version and skips the publish
+  # (exit 0) if it already exists. This covers axis-W-only patch releases
+  # (axis-E held at a prior version) and partial-republish retries.
 
   publish-rust-t1-embedder-api:
     runs-on: ubuntu-latest
     needs: all-builds-passed
     steps:
       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
       - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
         with:
           toolchain: stable
       - name: cargo publish fathomdb-embedder-api
         run: |
           if [ "${DRY_RUN}" = "true" ]; then
-            cargo publish --dry-run -p fathomdb-embedder-api
+            bash scripts/release/cargo-publish-if-new.sh --dry-run fathomdb-embedder-api
           else
-            cargo publish -p fathomdb-embedder-api --token "${CARGO_REGISTRY_TOKEN}"
+            bash scripts/release/cargo-publish-if-new.sh fathomdb-embedder-api
           fi
         env:
           CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}
       - name: Wait for crates.io index propagation
         if: ${{ inputs.dry_run != true }}
         run: sleep 60
 
   publish-rust-t2-schema:
     runs-on: ubuntu-latest
     needs: publish-rust-t1-embedder-api
     steps:
       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
       - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
         with:
           toolchain: stable
       - name: cargo publish fathomdb-schema
         run: |
           if [ "${DRY_RUN}" = "true" ]; then
-            cargo publish --dry-run -p fathomdb-schema
+            bash scripts/release/cargo-publish-if-new.sh --dry-run fathomdb-schema
           else
-            cargo publish -p fathomdb-schema --token "${CARGO_REGISTRY_TOKEN}"
+            bash scripts/release/cargo-publish-if-new.sh fathomdb-schema
           fi
         env:
           CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}
       - name: Wait for crates.io index propagation
         if: ${{ inputs.dry_run != true }}
         run: sleep 60
 
   publish-rust-t3-query:
     runs-on: ubuntu-latest
     needs: publish-rust-t2-schema
     steps:
       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
       - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
         with:
           toolchain: stable
       - name: cargo publish fathomdb-query
         run: |
           if [ "${DRY_RUN}" = "true" ]; then
-            cargo publish --dry-run -p fathomdb-query
+            bash scripts/release/cargo-publish-if-new.sh --dry-run fathomdb-query
           else
-            cargo publish -p fathomdb-query --token "${CARGO_REGISTRY_TOKEN}"
+            bash scripts/release/cargo-publish-if-new.sh fathomdb-query
           fi
         env:
           CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}
       - name: Wait for crates.io index propagation
         if: ${{ inputs.dry_run != true }}
         run: sleep 60
 
   publish-rust-t4-engine:
     runs-on: ubuntu-latest
     needs: publish-rust-t3-query
     steps:
       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
       - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
         with:
           toolchain: stable
       - name: cargo publish fathomdb-engine
         run: |
           if [ "${DRY_RUN}" = "true" ]; then
-            cargo publish --dry-run -p fathomdb-engine
+            bash scripts/release/cargo-publish-if-new.sh --dry-run fathomdb-engine
           else
-            cargo publish -p fathomdb-engine --token "${CARGO_REGISTRY_TOKEN}"
+            bash scripts/release/cargo-publish-if-new.sh fathomdb-engine
           fi
         env:
           CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}
       - name: Wait for crates.io index propagation
         if: ${{ inputs.dry_run != true }}
         run: sleep 60
 
   publish-rust-t5-embedder:
     runs-on: ubuntu-latest
     # T5 depends on Axis E (T1) in graph terms but waits for T4 here so the
     # 60s index-propagation cadence stays linear; parallelizing T5 with T4
     # would race the crates.io index from two directions for no real wall-
     # clock win.
     needs: publish-rust-t4-engine
     steps:
       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
       - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
         with:
           toolchain: stable
       - name: cargo publish fathomdb-embedder
         run: |
           if [ "${DRY_RUN}" = "true" ]; then
-            cargo publish --dry-run -p fathomdb-embedder
+            bash scripts/release/cargo-publish-if-new.sh --dry-run fathomdb-embedder
           else
-            cargo publish -p fathomdb-embedder --token "${CARGO_REGISTRY_TOKEN}"
+            bash scripts/release/cargo-publish-if-new.sh fathomdb-embedder
           fi
         env:
           CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}
       - name: Wait for crates.io index propagation
         if: ${{ inputs.dry_run != true }}
         run: sleep 60
 
   publish-rust-t6-facade:
     runs-on: ubuntu-latest
     needs: publish-rust-t5-embedder
     steps:
       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
       - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
         with:
           toolchain: stable
       - name: cargo publish fathomdb (facade)
         run: |
           if [ "${DRY_RUN}" = "true" ]; then
-            cargo publish --dry-run -p fathomdb
+            bash scripts/release/cargo-publish-if-new.sh --dry-run fathomdb
           else
-            cargo publish -p fathomdb --token "${CARGO_REGISTRY_TOKEN}"
+            bash scripts/release/cargo-publish-if-new.sh fathomdb
           fi
         env:
           CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}
       - name: Wait for crates.io index propagation
         if: ${{ inputs.dry_run != true }}
         run: sleep 60
 
   publish-rust-t7-cli:
     runs-on: ubuntu-latest
     needs: publish-rust-t6-facade
     steps:
       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
       - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
         with:
           toolchain: stable
       - name: cargo publish fathomdb-cli
         run: |
           if [ "${DRY_RUN}" = "true" ]; then
-            cargo publish --dry-run -p fathomdb-cli
+            bash scripts/release/cargo-publish-if-new.sh --dry-run fathomdb-cli
           else
-            cargo publish -p fathomdb-cli --token "${CARGO_REGISTRY_TOKEN}"
+            bash scripts/release/cargo-publish-if-new.sh fathomdb-cli
           fi
         env:
           CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}
       - name: Wait for crates.io index propagation
         if: ${{ inputs.dry_run != true }}
         run: sleep 60
 
   # --- Tier 8: binding-package parallel publishes ----------------------------
   # PyPI + npm wrap fathomdb-engine directly (PyO3 / napi-rs). They publish
   # in parallel after T4 resolves on crates.io — independent of T5..T7.
 
   publish-pypi:
     runs-on: ubuntu-latest
     # TestPyPI also rejects same-version re-uploads — dry-run rehearsals would
     # consume the next-release version slot. Skip the publish step entirely
     # on dispatch; the build-python matrix still runs on dry-run so wheel
     # buildability stays exercised across platforms.
     if: ${{ inputs.dry_run != true }}
     needs: publish-rust-t4-engine
     environment:
       name: pypi
     steps:
       - uses: actions/download-artifact@3e5f45b2cfb9172054b4087a40e8e0b5a5461e7c # v8.0.1
         with:
           pattern: python-dist-*
           merge-multiple: true
           path: dist
       - name: Publish to PyPI
         uses: pypa/gh-action-pypi-publish@cef221092ed1bacb1cc03d23a2d87d1d172e277b # v1.14.0
         with:
           packages-dir: dist
 
   publish-npm:
     runs-on: ubuntu-latest
     needs: publish-rust-t4-engine
     permissions:
       contents: read
       id-token: write
     defaults:
       run:
         working-directory: src/ts
     steps:
       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
       - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0
         with:
           node-version: "22"
           registry-url: "https://registry.npmjs.org"
       # Pull every platform binary into src/ts/ as siblings of dist/ — the
       # napi loader expects fathomdb.<platform>-<arch>.node relative to
       # the compiled JS, and the package.json `files` list ships them.
       - uses: actions/download-artifact@3e5f45b2cfb9172054b4087a40e8e0b5a5461e7c # v8.0.1
         with:
           pattern: napi-*
           merge-multiple: true
           path: src/ts
       - name: List staged artifacts
         run: ls -la
       - name: Install + build TypeScript
         run: |
           npm ci
           # The native binaries are already downloaded from build-napi;
           # only the tsc step is needed here.
           npx tsc -p tsconfig.build.json
       # npm OIDC trusted publishing requires npm >= 11.5.1 but Node 22
       # ships with npm 10.x. Using npx to invoke the latest npm avoids
       # the MODULE_NOT_FOUND bug from `npm install -g npm@latest` while
       # still getting a version that supports OIDC. --access public makes
       # the bare (unscoped) package publishable; --provenance attests
       # the build came from this workflow run.
       # npm refuses to publish a prerelease version (anything with a
       # `-` per semver: `0.6.0-rc.1`) without an explicit `--tag`,
       # since otherwise it would be auto-tagged `latest` and served as
       # the default install. Map prereleases to `next`; GA to `latest`.
       - name: Resolve npm dist-tag
         id: npm_tag
         run: |
           v=$(node -e "console.log(require('./package.json').version)")
           case "$v" in
             *-*) tag=next ;;
             *)   tag=latest ;;
