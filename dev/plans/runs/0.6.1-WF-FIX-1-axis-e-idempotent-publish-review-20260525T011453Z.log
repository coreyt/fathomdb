     1	#!/usr/bin/env bash
     2	# scripts/set-version.sh — two-axis version single source of truth.
     3	#
     4	# Axis W (workspace lockstep): Cargo.toml [workspace.package].version,
     5	# src/python/pyproject.toml [project].version, src/ts/package.json
     6	# top-level "version". Inherited by every workspace crate via
     7	# `version.workspace = true`.
     8	#
     9	# Axis E (embedder-api independent semver):
    10	# src/rust/crates/fathomdb-embedder-api/Cargo.toml [package].version.
    11	#
    12	# Owner: dev/design/release.md § Version axes.
    13	set -euo pipefail
    14	
    15	usage() {
    16	  cat <<'USAGE' >&2
    17	Usage: scripts/set-version.sh <mode> [args]
    18	
    19	Modes:
    20	  --workspace <new-w-version>     Set Axis W (Cargo workspace + python + ts).
    21	  --embedder-api <new-e-version>  Set Axis E (fathomdb-embedder-api only).
    22	  --check-files                   Verify both axes are internally consistent.
    23	
    24	Examples:
    25	  scripts/set-version.sh --workspace 0.6.1
    26	  scripts/set-version.sh --embedder-api 0.7.0
    27	  scripts/set-version.sh --check-files
    28	USAGE
    29	}
    30	
    31	die_usage() {
    32	  if [ -n "${1:-}" ]; then
    33	    printf 'error: %s\n' "$1" >&2
    34	  fi
    35	  usage
    36	  exit 2
    37	}
    38	
    39	REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
    40	CARGO="$REPO_ROOT/Cargo.toml"
    41	PYPROJ="$REPO_ROOT/src/python/pyproject.toml"
    42	NPMPKG="$REPO_ROOT/src/ts/package.json"
    43	EMB_API_DIR="$REPO_ROOT/src/rust/crates/fathomdb-embedder-api"
    44	EMB_API="$EMB_API_DIR/Cargo.toml"
    45	CRATES_DIR="$REPO_ROOT/src/rust/crates"
    46	
    47	# Atomic write: edits "$1" with awk program "$2" via a tmpfile mv.
    48	awk_inplace() {
    49	  local target="$1"
    50	  local prog="$2"
    51	  local tmp
    52	  tmp="$(mktemp "${target}.XXXXXX")"
    53	  awk "$prog" "$target" >"$tmp"
    54	  mv "$tmp" "$target"
    55	}
    56	
    57	# Set [workspace.package].version in Cargo.toml.
    58	set_workspace_version() {
    59	  local new="$1"
    60	  awk_inplace "$CARGO" '
    61	    BEGIN { in_block = 0 }
    62	    /^\[workspace\.package\]/ { in_block = 1; print; next }
    63	    /^\[/ { in_block = 0; print; next }
    64	    {
    65	      if (in_block && $0 ~ /^version[[:space:]]*=/) {
    66	        print "version = \"'"$new"'\""
    67	      } else {
    68	        print
    69	      }
    70	    }
    71	  '
    72	}
    73	
    74	# Update every Axis-W entry in [workspace.dependencies]. fathomdb-embedder-api
    75	# is Axis E and is skipped here — its version is set separately via
    76	# set_workspace_dep_embedder_api_version().
    77	#
    78	# Each line we touch is of the shape:
    79	#   fathomdb-<name> = { path = "...", version = "X.Y.Z" }
    80	# We rewrite only the version="X.Y.Z" segment; path is preserved.
    81	set_workspace_dep_axis_w_versions() {
    82	  local new="$1"
    83	  awk_inplace "$CARGO" '
    84	    BEGIN { in_block = 0 }
    85	    /^\[workspace\.dependencies\]/ { in_block = 1; print; next }
    86	    /^\[/ { in_block = 0; print; next }
    87	    {
    88	      if (in_block && $0 ~ /^fathomdb(-[a-z]+)*[[:space:]]*=/) {
    89	        # Skip Axis E (fathomdb-embedder-api).
    90	        if ($0 ~ /^fathomdb-embedder-api[[:space:]]*=/) {
    91	          print; next
    92	        }
    93	        # Rewrite version="..." in-place, preserve everything else.
    94	        if (sub(/version[[:space:]]*=[[:space:]]*"[^"]*"/,
    95	                "version = \"'"$new"'\"")) {
    96	          print; next
    97	        }
    98	      }
    99	      print
   100	    }
   101	  '
   102	}
   103	
   104	# Update the Axis-E entry in [workspace.dependencies] (fathomdb-embedder-api).
   105	set_workspace_dep_embedder_api_version() {
   106	  local new="$1"
   107	  awk_inplace "$CARGO" '
   108	    BEGIN { in_block = 0 }
   109	    /^\[workspace\.dependencies\]/ { in_block = 1; print; next }
   110	    /^\[/ { in_block = 0; print; next }
   111	    {
   112	      if (in_block && $0 ~ /^fathomdb-embedder-api[[:space:]]*=/) {
   113	        if (sub(/version[[:space:]]*=[[:space:]]*"[^"]*"/,
   114	                "version = \"'"$new"'\"")) {
   115	          print; next
   116	        }
   117	      }
   118	      print
   119	    }
   120	  '
   121	}
   122	
   123	# Set [project].version in pyproject.toml.
   124	set_pyproject_version() {
   125	  local new="$1"
   126	  awk_inplace "$PYPROJ" '
   127	    BEGIN { in_block = 0 }
   128	    /^\[project\]/ { in_block = 1; print; next }
   129	    /^\[/ { in_block = 0; print; next }
   130	    {
   131	      if (in_block && $0 ~ /^version[[:space:]]*=/) {
   132	        print "version = \"'"$new"'\""
   133	      } else {
   134	        print
   135	      }
   136	    }
   137	  '
   138	}
   139	
   140	# Set the top-level "version" field in package.json.
   141	# Constraint: only rewrite the first occurrence so a nested "version" inside
   142	# devDependencies cannot be touched.
   143	set_npm_version() {
   144	  local new="$1"
   145	  local tmp
   146	  tmp="$(mktemp "${NPMPKG}.XXXXXX")"
   147	  awk -v new="$new" '
   148	    BEGIN { done = 0 }
   149	    {
   150	      if (!done && match($0, /"version"[[:space:]]*:[[:space:]]*"[^"]*"/)) {
   151	        sub(/"version"[[:space:]]*:[[:space:]]*"[^"]*"/, "\"version\": \"" new "\"")
   152	        done = 1
   153	      }
   154	      print
   155	    }
   156	  ' "$NPMPKG" >"$tmp"
   157	  mv "$tmp" "$NPMPKG"
   158	}
   159	
   160	# Set [package].version in fathomdb-embedder-api/Cargo.toml. Preserves any
   161	# leading comment lines inside the [package] block (so the Axis-E why-comment
   162	# survives re-runs).
   163	set_embedder_api_version() {
   164	  local new="$1"
