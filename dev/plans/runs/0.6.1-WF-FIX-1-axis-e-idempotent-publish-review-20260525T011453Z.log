dev/plans/runs/12-TX-ts-python-parity-20260517T204414Z.log:1111:{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01F52gFQWjw5TAjzWqsMuRCT","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Y8wJqT6Mxhws3Nopy6DuEY","name":"TodoWrite","input":{"todos":[{"content":"Build parity matrix (Python vs TS surface)","activeForm":"Building parity matrix","status":"completed"},{"content":"Close error-class taxonomy gaps","activeForm":"Closing error-class taxonomy gaps","status":"completed"},{"content":"Close data-shape gaps","activeForm":"Closing data-shape gaps","status":"completed"},{"content":"Close test-counterpart gaps","activeForm":"Closing test-counterpart gaps","status":"in_progress"},{"content":"Verify type-stub completeness","activeForm":"Verifying type-stub completeness","status":"pending"},{"content":"Run both suites green -----------------------\n  # AC-056: a published artifact is not \"done\" until it installs cleanly from\n  # the registry on a fresh machine and the SDK opens + closes + process-exits.\n  # Skipped on dry-run — install-from-test.pypi does not mirror prod closely\n  # enough to make the smoke meaningful, and npm has no comparable staging.\n  post-publish-smoke:\n    runs-on: ubuntu-latest\n    if: ${{ inputs.dry_run != true }}\n    needs:\n      - publish-rust-t7-cli\n      - publish-pypi\n      - publish-npm\n    strategy:\n      fail-fast: false\n      matrix:\n        smoke:\n          - crates-cli\n          - pypi-wheel\n          - npm-package\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: actions/setup-python@a309ff8b426b58ec0e2a45f0f869d46889d02405 # v6.2.0\n        if: matrix.smoke == 'pypi-wheel'\n        with:\n          python-version: \"3.12\"\n      - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0\n        if: matrix.smoke == 'npm-package'\n        with:\n          node-version: \"22\"\n      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n        if: matrix.smoke == 'crates-cli'\n        with:\n          toolchain: stable\n      - name: Resolve tag version\n        id: ver\n        run: |\n          v=\"${GITHUB_REF_NAME#v}\"\n          echo \"version=${v}\" >> \"$GITHUB_OUTPUT\"\n      - name: Run smoke\n        run: bash \"scripts/release/smoke/smoke-${{ matrix.smoke }}.sh\" \"${{ steps.ver.outputs.version }}\"\n\n  # AC-052: sibling triple (fathomdb + fathomdb-embedder + fathomdb-embedder-\n  # api) must all exist in the registry at the expected versions after the\n  # tier 1..7 publishes complete. Skipped on dry-run since no real publish\n  # happened.\n  co-tagging-assert:\n    runs-on: ubuntu-latest\n    if: ${{ inputs.dry_run != true }}\n    needs:\n      - publish-rust-t7-cli\n      - publish-pypi\n      - publish-npm\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - name: Resolve tag version\n        id: ver\n        run: |\n          v=\"${GITHUB_REF_NAME#v}\"\n          echo \"version=${v}\" >> \"$GITHUB_OUTPUT\"\n      - name: Assert sibling-package co-tagging\n        run: bash scripts/release/assert-co-tagging.sh \"${{ steps.ver.outputs.version }}\"\n\n  # AC-054 partial: only this job marks the release complete by creating the\n  # GitHub Release. If any smoke or co-tagging job is red, this job does not\n  # run, so the release is never marked done. Skipped on dry-run.\n  github-release:\n    runs-on: ubuntu-latest\n    if: ${{ inputs.dry_run != true }}\n    needs:\n      - post-publish-smoke\n      - co-tagging-assert\n    steps:\n      - uses: actions/download-artifact@3e5f45b2cfb9172054b4087a40e8e0b5a5461e7c # v8.0.1\n        with:\n          pattern: python-dist-*\n          merge-multiple: true\n          path: dist\n      - uses: softprops/action-gh-release@153bb8e04406b158c6c84fc1615b65b24149a1fe # v2.6.1\n        with:\n          files: dist/*\n","structuredPatch":[{"oldStart":355,"oldLines":6,"newStart":355,"newLines":11,"lines":[" ","   publish-pypi:","     runs-on: ubuntu-latest","+    # TestPyPI also rejects same-version re-uploads — dry-run rehearsals would","+    # consume the next-release version slot. Skip the publish step entirely","+    # on dispatch; the build-python matrix still runs on dry-run so wheel","+    # buildability stays exercised across platforms.","+    if: ${{ inputs.dry_run != true }}","     needs: publish-rust-t4-engine","     environment:","       name: pypi"]},{"oldStart":364,"oldLines":11,"newStart":369,"newLines":10,"lines":["           pattern: python-dist-*","           merge-multiple: true","           path: dist","-      - name: Publish to PyPI (or test.pypi on dry-run)","+      - name: Publish to PyPI","         uses: pypa/gh-action-pypi-publish@cef221092ed1bacb1cc03d23a2d87d1d172e277b # v1.14.0","         with:","           packages-dir: dist","-          repository-url: ${{ env.DRY_RUN == 'true' && 'https://test.pypi.org/legacy/' || '' }}"," ","   publish-npm:","     runs-on: ubuntu-latest"]}],"userModified":false,"replaceAll":false}}
