dev/plans/runs/12-DX-external-user-docs-20260517T210205Z.log:292:{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015k5RjQzWansPM2ZPqDs91V","type":"tool_result","content":"1\t\"\"\"Python wrapper around the native PyO3 engine handle.\n2\t\n3\t`Engine` mirrors the public five-verb surface owned by\n4\t`dev/interfaces/python.md`. The native PyO3 class\n5\t(`fathomdb._fathomdb.Engine`) holds the `Arc<fathomdb_engine::Engine>`\n6\tand runs every blocking call under `py.allow_threads`; this Python\n7\twrapper converts native return values into the dataclasses in\n8\t`fathomdb.types` and rejects unknown `open()` kwargs.\n9\t\"\"\"\n10\t\n11\tfrom __future__ import annotations\n12\t\n13\timport logging\n14\tfrom typing import Any, cast\n15\t\n16\tfrom fathomdb._fathomdb import Engine as _NativeEngine\n17\tfrom fathomdb.config import EngineConfig\n18\tfrom fathomdb.types import (\n19\t    CounterSnapshot,\n20\t    SearchResult,\n21\t    SoftFallback,\n22\t    SoftFallbackBranch,\n23\t    WriteReceipt,\n24\t)\n25\t\n26\t_KWARG_FIELDS = {\n27\t    \"embedder_pool_size\",\n28\t    \"scheduler_runtime_threads\",\n29\t    \"provenance_row_cap\",\n30\t    \"embedder_call_timeout_ms\",\n31\t    \"slow_threshold_ms\",\n32\t}\n33\t\n34\t\n35\tclass Engine:\n36\t    \"\"\"Python handle that wraps the native PyO3 engine.\"\"\"\n37\t\n38\t    __slots__ = (\"_native\", \"_path\", \"_config\")\n39\t\n40\t    def __init__(\n41\t        self,\n42\t        native: _NativeEngine,\n43\t        *,\n44\t        path: str,\n45\t        config: EngineConfig,\n46\t    ) -> None:\n47\t        self._native = native\n48\t        self._path = path\n49\t        self._config = config\n50\t\n51\t    @classmethod\n52\t    def open(\n53\t        cls,\n54\t        path: str,\n55\t        *,\n56\t        config: EngineConfig | None = None,\n57\t        **engine_config: Any,\n58\t    ) -> \"Engine\":\n59\t        \"\"\"Open the database at `path`.\n60\t\n61\t        Either `config` or per-knob keyword arguments may be supplied,\n62\t        but not both. Unknown keyword arguments are rejected.\n63\t        \"\"\"\n64\t\n65\t        if config is not None and engine_config:\n66\t            raise ValueError(\n67\t                \"Engine.open accepts either config= or per-knob keyword arguments, not both\",\n68\t            )\n69\t\n70\t        unknown = set(engine_config) - _KWARG_FIELDS\n71\t        if unknown:\n72\t            raise TypeError(\n73\t                f\"Engine.open got unexpected keyword arguments: {sorted(unknown)!r}\",\n74\t            )\n75\t\n76\t        resolved = config if config is not None else EngineConfig(**engine_config)\n77\t        native = _NativeEngine.open(path)\n78\t        return cls(native, path=path, config=resolved)\n79\t\n80\t    @property\n81\t    def path(self) -> str:\n82\t        return self._path\n83\t\n84\t    @property\n85\t    def config(self) -> EngineConfig:\n86\t        return self._config\n87\t\n88\t    def write(self, batch: list[Any] | None = None) -> WriteReceipt:\n89\t        receipt = self._native.write(batch or [])\n90\t        return WriteReceipt(cursor=receipt.cursor)\n91\t\n92\t    def search(self, query: str) -> SearchResult:\n93\t        result = self._native.search(query)\n94\t        fallback = result.soft_fallback\n95\t        soft = (\n96\t            SoftFallback(branch=cast(SoftFallbackBranch, fallback.branch))\n97\t            if fallback is not None\n98\t            else None\n99\t        )\n100\t        return SearchResult(\n101\t            projection_cursor=result.projection_cursor,\n102\t            soft_fallback=soft,\n103\t            results=list(result.results),\n104\t        )\n105\t\n106\t    def close(self) -> None:\n107\t        self._native.close()\n108\t\n109\t    def drain(self, *, timeout_s: float | int = 0) -> None:\n110\t        \"\"\"Block until in-flight writes drain or `timeout_s` elapses.\"\"\"\n111\t\n112\t        self._native.drain(timeout_s=float(timeout_s))\n113\t\n114\t    def counters(self) -> CounterSnapshot:\n115\t        snap = self._native.counters()\n116\t        return CounterSnapshot(\n117\t            queries=snap.queries,\n118\t            writes=snap.writes,\n119\t            write_rows=snap.write_rows,\n120\t            admin_ops=snap.admin_ops,\n121\t            cache_hit=snap.cache_hit,\n122\t            cache_miss=snap.cache_miss,\n123\t        )\n124\t\n125\t    def set_profiling(self, *, enabled: bool) -> None:\n126\t        self._native.set_profiling(enabled)\n127\t\n128\t    def set_slow_threshold_ms(self, *, value: int) -> None:\n129\t        self._native.set_slow_threshold_ms(value)\n130\t\n131\t    def attach_logging_subscriber(\n132\t        self,\n133\t        logger: logging.Logger,\n134\t        *,\n135\t        heartbeat_interval_ms: int | None = None,\n136\t    ) -> None:\n137\t        \"\"\"Bind engine events into the supplied `logging.Logger`.\n138\t\n139\t        Subscriber wiring lands in a later 0.6.x slice; the native call\n140\t        accepts the parameters so callers can wire a logger against the\n141\t        public surface.\n142\t        \"\"\"\n143\t\n144\t        self._native.attach_logging_subscriber(\n145\t            logger,\n146\t            heartbeat_interval_ms=heartbeat_interval_ms,\n147\t        )\n148\t\n149\t\n150\t__all__ = [\"Engine\"]\n151\t"}]},"parent_tool_use_id":null,"session_id":"c409cac9-fa4a-4d9f-9db5-55aae00050c6","uuid":"544acdbd-0551-4037-b709-52f3c70508aa","timestamp":"2026-05-17T21:02:41.938Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-DX-external-user-docs-20260517T210205Z/src/python/fathomdb/engine.py","content":"\"\"\"Python wrapper around the native PyO3 engine handle.\n\n`Engine` mirrors the public five-verb surface owned by\n`dev/interfaces/python.md`. The native PyO3 class\n(`fathomdb._fathomdb.Engine`) holds the `Arc<fathomdb_engine::Engine>`\nand runs every blocking call under `py.allow_threads`; this Python\nwrapper converts native return values into the dataclasses in\n`fathomdb.types` and rejects unknown `open()` kwargs.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom typing import Any, cast\n\nfrom fathomdb._fathomdb import Engine as _NativeEngine\nfrom fathomdb.config import EngineConfig\nfrom fathomdb.types import (\n    CounterSnapshot,\n    SearchResult,\n    SoftFallback,\n    SoftFallbackBranch,\n    WriteReceipt,\n)\n\n_KWARG_FIELDS = {\n    \"embedder_pool_size\",\n    \"scheduler_runtime_threads\",\n    \"provenance_row_cap\",\n    \"embedder_call_timeout_ms\",\n    \"slow_threshold_ms\",\n}\n\n\nclass Engine:\n    \"\"\"Python handle that wraps the native PyO3 engine.\"\"\"\n\n    __slots__ = (\"_native\", \"_path\", \"_config\")\n\n    def __init__(\n        self,\n        native: _NativeEngine,\n        *,\n        path: str,\n        config: EngineConfig,\n    ) -> None:\n        self._native = native\n        self._path = path\n        self._config = config\n\n    @classmethod\n    def open(\n        cls,\n        path: str,\n        *,\n        config: EngineConfig | None = None,\n        **engine_config: Any,\n    ) -> \"Engine\":\n        \"\"\"Open the database at `path`.\n\n        Either `config` or per-knob keyword arguments may be supplied,\n        but not both. Unknown keyword arguments are rejected.\n        \"\"\"\n\n        if config is not None and engine_config:\n            raise ValueError(\n                \"Engine.open accepts either config= or per-knob keyword arguments, not both\",\n            )\n\n        unknown = set(engine_config) - _KWARG_FIELDS\n        if unknown:\n            raise TypeError(\n                f\"Engine.open got unexpected keyword arguments: {sorted(unknown)!r}\",\n            )\n\n        resolved = config if config is not None else EngineConfig(**engine_config)\n        native = _NativeEngine.open(path)\n        return cls(native, path=path, config=resolved)\n\n    @property\n    def path(self) -> str:\n        return self._path\n\n    @property\n    def config(self) -> EngineConfig:\n        return self._config\n\n    def write(self, batch: list[Any] | None = None) -> WriteReceipt:\n        receipt = self._native.write(batch or [])\n        return WriteReceipt(cursor=receipt.cursor)\n\n    def search(self, query: str) -> SearchResult:\n        result = self._native.search(query)\n        fallback = result.soft_fallback\n        soft = (\n            SoftFallback(branch=cast(SoftFallbackBranch, fallback.branch))\n            if fallback is not None\n            else None\n        )\n        return SearchResult(\n            projection_cursor=result.projection_cursor,\n            soft_fallback=soft,\n            results=list(result.results),\n        )\n\n    def close(self) -> None:\n        self._native.close()\n\n    def drain(self, *, timeout_s: float | int = 0) -> None:\n        \"\"\"Block until in-flight writes drain or `timeout_s` elapses.\"\"\"\n\n        self._native.drain(timeout_s=float(timeout_s))\n\n    def counters(self) -> CounterSnapshot:\n        snap = self._native.counters()\n        return CounterSnapshot(\n            queries=snap.queries,\n            writes=snap.writes,\n            write_rows=snap.write_rows,\n            admin_ops=snap.admin_ops,\n            cache_hit=snap.cache_hit,\n            cache_miss=snap.cache_miss,\n        )\n\n    def set_profiling(self, *, enabled: bool) -> None:\n        self._native.set_profiling(enabled)\n\n    def set_slow_threshold_ms(self, *, value: int) -> None:\n        self._native.set_slow_threshold_ms(value)\n\n    def attach_logging_subscriber(\n        self,\n        logger: logging.Logger,\n        *,\n        heartbeat_interval_ms: int | None = None,\n    ) -> None:\n        \"\"\"Bind engine events into the supplied `logging.Logger`.\n\n        Subscriber wiring lands in a later 0.6.x slice; the native call\n        accepts the parameters so callers can wire a logger against the\n        public surface.\n        \"\"\"\n\n        self._native.attach_logging_subscriber(\n            logger,\n            heartbeat_interval_ms=heartbeat_interval_ms,\n        )\n\n\n__all__ = [\"Engine\"]\n","numLines":151,"startLine":1,"totalLines":151}}}
