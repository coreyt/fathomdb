  publish-pypi:
    runs-on: ubuntu-latest
    # TestPyPI also rejects same-version re-uploads — dry-run rehearsals would
    # consume the next-release version slot. Skip the publish step entirely
    # on dispatch; the build-python matrix still runs on dry-run so wheel
    # buildability stays exercised across platforms.
    if: ${{ inputs.dry_run != true }}
    needs: publish-rust-t4-engine
    environment:
      name: pypi
    steps:
      - uses: actions/download-artifact@3e5f45b2cfb9172054b4087a40e8e0b5a5461e7c # v8.0.1
        with:
          pattern: python-dist-*
          merge-multiple: true
          path: dist
      - name: Publish to PyPI
        uses: pypa/gh-action-pypi-publish@cef221092ed1bacb1cc03d23a2d87d1d172e277b # v1.14.0
        with:
          packages-dir: dist

  publish-npm:
    runs-on: ubuntu-latest
    needs: publish-rust-t4-engine
    permissions:
      contents: read
      id-token: write
    defaults:
      run:
        working-directory: src/ts
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
      - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0
        with:
