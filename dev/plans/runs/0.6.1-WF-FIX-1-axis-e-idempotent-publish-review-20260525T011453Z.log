4\tclass EmbedderNotConfiguredError(EmbedderError): ...\n55\tclass SchedulerError(EngineError): ...\n56\tclass OpStoreError(EngineError): ...\n57\tclass WriteValidationError(EngineError): ...\n58\tclass SchemaValidationError(EngineError): ...\n59\tclass OverloadedError(EngineError): ...\n60\tclass ClosingError(EngineError): ...\n61\t\n62\tclass DatabaseLockedError(EngineError):\n63\t    holder_pid: int | None\n64\t    def __init__(self, *args: Any, holder_pid: int | None = ...) -> None: ...\n65\t\n66\tclass CorruptionError(EngineError):\n67\t    kind: str\n68\t    stage: str\n69\t    recovery_hint_code: str\n70\t    doc_anchor: str\n71\t    def __init__(\n72\t        self,\n73\t        *args: Any,\n74\t        kind: str = ...,\n75\t        stage: str = ...,\n76\t        recovery_hint_code: str = ...,\n77\t        doc_anchor: str = ...,\n78\t    ) -> None: ...\n79\t\n80\tclass IncompatibleSchemaVersionError(EngineError): ...\n81\tclass MigrationError(EngineError): ...\n82\t\n83\tclass EmbedderIdentityMismatchError(EngineError):\n84\t    stored_name: str\n85\t    stored_revision: str\n86\t    supplied_name: str\n87\t    supplied_revision: str\n88\t    def __init__(\n89\t        self,\n90\t        *args: Any,\n91\t        stored_name: str = ...,\n92\t        stored_revision: str = ...,\n93\t        supplied_name: str = ...,\n94\t        supplied_revision: str = ...,\n95\t    ) -> None: ...\n96\t\n97\tclass EmbedderDimensionMismatchError(EngineError):\n98\t    stored: int\n99\t    supplied: int\n100\t    def __init__(self, *args: Any, stored: int = ..., supplied: int = ...) -> None: ...\n101\t"}]},"parent_tool_use_id":null,"session_id":"e03e003f-16a4-48ce-9857-522e8e7e136e","uuid":"e8402cf2-7415-45ff-921b-87b88c7b00ec","timestamp":"2026-05-17T20:44:57.776Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-TX-ts-python-parity-20260517T204414Z/src/python/fathomdb/_fathomdb.pyi","content":"\"\"\"Type stubs for the PyO3 extension `fathomdb._fathomdb`.\n\nMirrors the surface emitted by `src/rust/crates/fathomdb-py/src/lib.rs`.\nHand-maintained — keep in sync with the binding's `#[pyclass]` /\n`create_exception!` / `#[pyfunction]` exports.\n\"\"\"\n\nfrom typing import Any, Iterable\n\nclass WriteReceipt:\n    cursor: int\n\nclass SoftFallback:\n    branch: str\n\nclass SearchResult:\n    projection_cursor: int\n    soft_fallback: SoftFallback | None\n    results: list[str]\n\nclass CounterSnapshot:\n    queries: int\n    writes: int\n    write_rows: int\n    admin_ops: int\n    cache_hit: int\n    cache_miss: int\n\nclass Engine:\n    @staticmethod\n    def open(path: str) -> \"Engine\": ...\n    def write(self, batch: Iterable[Any]) -> WriteReceipt: ...\n    def search(self, query: str) -> SearchResult: ...\n    def close(self) -> None: ...\n    def drain(self, timeout_s: float = ...) -> None: ...\n    def counters(self) -> CounterSnapshot: ...\n    def set_profiling(self, enabled: bool) -> None: ...\n    def set_slow_threshold_ms(self, value: int) -> None: ...\n    def attach_logging_subscriber(\n        self,\n        logger: Any,\n        heartbeat_interval_ms: int | None = ...,\n    ) -> None: ...\n\ndef admin_configure(engine: Engine, name: str, body: str) -> WriteReceipt: ...\ndef force_panic_for_test() -> None: ...\n\nclass EngineError(Exception): ...\nclass StorageError(EngineError): ...\nclass ProjectionError(EngineError): ...\nclass VectorError(EngineError): ...\nclass KindNotVectorIndexedError(VectorError): ...\nclass EmbedderError(EngineError): ...\nclass EmbedderNotConfiguredError(EmbedderError): ...\nclass SchedulerError(EngineError): ...\nclass OpStoreError(EngineError): ...\nclass WriteValidationError(EngineError): ...\nclass SchemaValidationError(EngineError): ...\nclass OverloadedError(EngineError): ...\nclass ClosingError(EngineError): ...\n\nclass DatabaseLockedError(EngineError):\n    holder_pid: int | None\n    def __init__(self, *args: Any, holder_pid: int | None = ...) -> None: ...\n\nclass CorruptionError(EngineError):\n    kind: str\n    stage: str\n    recovery_hint_code: str\n    doc_anchor: str\n    def __init__(\n        self,\n        *args: Any,\n        kind: str = ...,\n        stage: str = ...,\n        recovery_hint_code: str = ...,\n        doc_anchor: str = ...,\n    ) -> None: ...\n\nclass IncompatibleSchemaVersionError(EngineError): ...\nclass MigrationError(EngineError): ...\n\nclass EmbedderIdentityMismatchError(EngineError):\n    stored_name: str\n    stored_revision: str\n    supplied_name: str\n    supplied_revision: str\n    def __init__(\n        self,\n        *args: Any,\n        stored_name: str = ...,\n        stored_revision: str = ...,\n        supplied_name: str = ...,\n        supplied_revision: str = ...,\n    ) -> None: ...\n\nclass EmbedderDimensionMismatchError(EngineError):\n    stored: int\n    supplied: int\n    def __init__(self, *args: Any, stored: int = ..., supplied: int = ...) -> None: ...\n","numLines":101,"startLine":1,"totalLines":101}}}
