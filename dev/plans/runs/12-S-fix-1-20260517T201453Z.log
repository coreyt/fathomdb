 STRICT=1 promotes toolchain blockers to","+# hard failures so the gate is real (rc=2 → exit). Local dev hosts","+# without strace must run scripts/bootstrap.sh first.","+STRICT=1 bash \"$SCRIPT_DIR/agent-security.sh\" || exit 1"," run_step test || exit 1"," "," end=$(date +%s)"]}],"userModified":false,"replaceAll":false}}
