{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01SweNUjYeTvKvt9WB2FpybZ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01GavbHzF5xSbxt3Ef49y9mK","name":"Write","input":{"file_path":"/tmp/fdb-12-S-security-fixtures-20260517T195735Z/scripts/tests/test_ast_scan.sh","content":"#!/usr/bin/env bash\n# Self-test for AC-050a AST no-shim scanner (scripts/security/ast_scan.py).\n# Drives clean + dirty fixtures per language, plus targeted sub-fixtures\n# for the verb-reroute, crate-root, and block-comment rules.\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nREPO_ROOT=\"$(cd \"$SCRIPT_DIR/../..\" && pwd)\"\nSCAN=\"$REPO_ROOT/scripts/security/ast_scan.py\"\nFIX=\"$SCRIPT_DIR/fixtures/ast-shim\"\n\nfail() { echo \"FAIL: $*\" >&2; exit 1; }\n\nrun_clean() {\n    local lang=\"$1\" path=\"$2\"\n    if ! python3 \"$SCAN\" --language \"$lang\" --path \"$path\" --repo-root \"$REPO_ROOT\" >/dev/null 2>&1; then\n        fail \"$lang clean fixture ($path) must exit 0\"\n    fi\n}\n\nrun_dirty() {\n    local lang=\"$1\" path=\"$2\" expect_pattern=\"$3\"\n    local errf\n    errf=$(mktemp)\n    set +e\n    python3 \"$SCAN\" --language \"$lang\" --path \"$path\" --repo-root \"$REPO_ROOT\" >/dev/null 2>\"$errf\"\n    local rc=$?\n    set -e\n    if [ \"$rc\" -ne 1 ]; then\n        cat \"$errf\" >&2\n        rm -f \"$errf\"\n        fail \"$lang dirty fixture ($path) must exit 1, got $rc\"\n    fi\n    if ! grep -qE \"$expect_pattern\" \"$errf\"; then\n        cat \"$errf\" >&2\n        rm -f \"$errf\"\n        fail \"$lang dirty fixture ($path): expected pattern '$expect_pattern' missing\"\n    fi\n    rm -f \"$errf\"\n}\n\n# V05_VERBS must be non-empty — sentinel that the rule is enforced.\nverb_count=$(python3 -c 'import sys; sys.path.insert(0, \"'\"$REPO_ROOT\"'/scripts/security\"); import ast_scan; print(len(ast_scan.V05_VERBS))')\nif [ \"$verb_count\" -lt 1 ]; then\n    fail \"V05_VERBS is empty — verb-reroute rule is unenforced\"\nfi\necho \"OK V05_VERBS populated ($verb_count entries)\"\n\nfor lang in rust python ts; do\n    run_clean \"$lang\" \"$FIX/$lang/clean\"\n    echo \"OK $lang clean\"\n    run_dirty \"$lang\" \"$FIX/$lang/dirty\" \"(legacy_|compat_v0_5|allow\\\\(deprecated\\\\)|verb re-route)\"\n    echo \"OK $lang dirty\"\ndone\n\n# Targeted sub-rules: each fixture isolates one detection path.\nrun_dirty rust \"$FIX/rust/dirty/lib.rs\" \"rust-crate-root-allow-deprecated\"\necho \"OK rust crate-root rule (lib.rs isolated)\"\n\nrun_dirty rust \"$FIX/rust/dirty/v05_verb_reroute.rs\" \"rust-05x-verb-reroute\"\necho \"OK rust v05 verb-reroute\"\n\nrun_dirty python \"$FIX/python/dirty/v05_verb_reroute.py\" \"python-05x-verb-reroute\"\necho \"OK python v05 verb-reroute\"\n\nrun_dirty ts \"$FIX/ts/dirty/v05_verb_reroute.ts\" \"ts-05x-verb-reroute\"\necho \"OK ts v05 verb-reroute\"\n\n# Block-comment stripping: banned names inside /* */ must NOT flag.\nrun_clean rust \"$FIX/rust/clean\"\necho \"OK rust clean (block-comment safe variant)\"\n\n# But real code OUTSIDE a block comment in a file that also contains a\n# block comment must still flag.\nrun_dirty rust \"$FIX/rust/dirty/block_comment_real.rs\" \"(legacy_|rust-public-symbol)\"\necho \"OK rust block-comment does not swallow real code\"\n\necho \"test_ast_scan.sh: all language fixtures pass\"\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":309,"cache_read_input_tokens":67200,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":309},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"763b881e-23a9-40f3-bcb2-77cbd569c95f","uuid":"682d6125-7fc5-4761-b123-2237622fdbdf"}
