\"$errf\"\n}\n\n# V05_VERBS must be non-empty — sentinel that the rule is enforced.\nverb_count=$(python3 -c 'import sys; sys.path.insert(0, \"'\"$REPO_ROOT\"'/scripts/security\"); import ast_scan; print(len(ast_scan.V05_VERBS))')\nif [ \"$verb_count\" -lt 1 ]; then\n    fail \"V05_VERBS is empty — verb-reroute rule is unenforced\"\nfi\necho \"OK V05_VERBS populated ($verb_count entries)\"\n\nfor lang in rust python ts; do\n    run_clean \"$lang\" \"$FIX/$lang/clean\"\n    echo \"OK $lang clean\"\n    run_dirty \"$lang\" \"$FIX/$lang/dirty\" \"(legacy_|compat_v0_5|allow\\\\(deprecated\\\\)|verb re-route)\"\n    echo \"OK $lang dirty\"\ndone\n\n# Targeted sub-rules: each fixture isolates one detection path.\nrun_dirty rust \"$FIX/rust/dirty/lib.rs\" \"rust-crate-root-allow-deprecated\"\necho \"OK rust crate-root rule (lib.rs isolated)\"\n\nrun_dirty rust \"$FIX/rust/dirty/v05_verb_reroute.rs\" \"rust-05x-verb-reroute\"\necho \"OK rust v05 verb-reroute\"\n\nrun_dirty python \"$FIX/python/dirty/v05_verb_reroute.py\" \"python-05x-verb-reroute\"\necho \"OK python v05 verb-reroute\"\n\nrun_dirty ts \"$FIX/ts/dirty/v05_verb_reroute.ts\" \"ts-05x-verb-reroute\"\necho \"OK ts v05 verb-reroute\"\n\n# Block-comment stripping: banned names inside /* */ must NOT flag.\nrun_clean rust \"$FIX/rust/clean\"\necho \"OK rust clean (block-comment safe variant)\"\n\n# But real code OUTSIDE a block comment in a file that also contains a\n# block comment must still flag.\nrun_dirty rust \"$FIX/rust/dirty/block_comment_real.rs\" \"(legacy_|rust-public-symbol)\"\necho \"OK rust block-comment does not swallow real code\"\n\necho \"test_ast_scan.sh: all language fixtures pass\"\n","structuredPatch":[{"oldStart":1,"oldLines":6,"newStart":1,"newLines":7,"lines":[" #!/usr/bin/env bash"," # Self-test for AC-050a AST no-shim scanner (scripts/security/ast_scan.py).","-# Drives clean + dirty fixtures per language.","+# Drives clean + dirty fixtures per language, plus targeted sub-fixtures","+# for t