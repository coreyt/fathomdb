{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AoZnw5BU9izkTbSsr2BNiw","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t# Self-test for AC-050a AST no-shim scanner (scripts/security/ast_scan.py).\n3\t# Drives clean + dirty fixtures per language.\n4\tset -euo pipefail\n5\t\n6\tSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n7\tREPO_ROOT=\"$(cd \"$SCRIPT_DIR/../..\" && pwd)\"\n8\tSCAN=\"$REPO_ROOT/scripts/security/ast_scan.py\"\n9\tFIX=\"$SCRIPT_DIR/fixtures/ast-shim\"\n10\t\n11\tfail() { echo \"FAIL: $*\" >&2; exit 1; }\n12\t\n13\tfor lang in rust python ts; do\n14\t    # Clean fixture must pass.\n15\t    if ! python3 \"$SCAN\" --language \"$lang\" --path \"$FIX/$lang/clean\" --repo-root \"$REPO_ROOT\" >/dev/null; then\n16\t        fail \"$lang clean fixture must exit 0\"\n17\t    fi\n18\t    echo \"OK $lang clean\"\n19\t\n20\t    # Dirty fixture must fail with non-zero exit and a recognizable diagnostic.\n21\t    set +e\n22\t    python3 \"$SCAN\" --language \"$lang\" --path \"$FIX/$lang/dirty\" --repo-root \"$REPO_ROOT\" \\\n23\t        >/dev/null 2>/tmp/ast_scan_dirty_$lang.err\n24\t    rc=$?\n25\t    set -e\n26\t    if [ \"$rc\" -ne 1 ]; then\n27\t        fail \"$lang dirty fixture must exit 1, got $rc\"\n28\t    fi\n29\t    if ! grep -qE \"(legacy_|compat_v0_5|allow\\(deprecated\\))\" /tmp/ast_scan_dirty_$lang.err; then\n30\t        fail \"$lang dirty fixture: diagnostic must name a banned pattern\"\n31\t    fi\n32\t    echo \"OK $lang dirty\"\n33\tdone\n34\t\n35\techo \"test_ast_scan.sh: all language fixtures pass\"\n36\t"}]},"parent_tool_use_id":null,"session_id":"763b881e-23a9-40f3-bcb2-77cbd569c95f","uuid":"797d5331-ed6c-422d-8d7c-3ef058baa16f","timestamp":"2026-05-17T20:14:59.550Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-S-security-fixtures-20260517T195735Z/scripts/tests/test_ast_scan.sh","content":"#!/usr/bin/env bash\n# Self-test for AC-050a AST no-shim scanner (scripts/security/ast_scan.py).\n# Drives clean + dirty fixtures per language.\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nREPO_ROOT=\"$(cd \"$SCRIPT_DIR/../..\" && pwd)\"\nSCAN=\"$REPO_ROOT/scripts/security/ast_scan.py\"\nFIX=\"$SCRIPT_DIR/fixtures/ast-shim\"\n\nfail() { echo \"FAIL: $*\" >&2; exit 1; }\n\nfor lang in rust python ts; do\n    # Clean fixture must pass.\n    if ! python3 \"$SCAN\" --language \"$lang\" --path \"$FIX/$lang/clean\" --repo-root \"$REPO_ROOT\" >/dev/null; then\n        fail \"$lang clean fixture must exit 0\"\n    fi\n    echo \"OK $lang clean\"\n\n    # Dirty fixture must fail with non-zero exit and a recognizable diagnostic.\n    set +e\n    python3 \"$SCAN\" --language \"$lang\" --path \"$FIX/$lang/dirty\" --repo-root \"$REPO_ROOT\" \\\n        >/dev/null 2>/tmp/ast_scan_dirty_$lang.err\n    rc=$?\n    set -e\n    if [ \"$rc\" -ne 1 ]; then\n        fail \"$lang dirty fixture must exit 1, got $rc\"\n    fi\n    if ! grep -qE \"(legacy_|compat_v0_5|allow\\(deprecated\\))\" /tmp/ast_scan_dirty_$lang.err; then\n        fail \"$lang dirty fixture: diagnostic must name a banned pattern\"\n    fi\n    echo \"OK $lang dirty\"\ndone\n\necho \"test_ast_scan.sh: all language fixtures pass\"\n","numLines":36,"startLine":1,"totalLines":36}}}
