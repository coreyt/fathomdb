     1	//! napi-rs binding from the TypeScript SDK to `fathomdb-engine`.
     2	//!
     3	//! FFI safety contract (mirrors the PyO3 binding in `fathomdb-py`):
     4	//!
     5	//! 1. Every method that may block inside the engine runs its blocking
     6	//!    body inside `tokio::task::spawn_blocking`, so the libuv main
     7	//!    thread is never tied up. napi-rs's `#[napi] async fn` wraps
     8	//!    return values as JS `Promise<T>`.
     9	//! 2. Engine entry points return typed errors via [`engine_error_to_napi`] /
    10	//!    [`engine_open_error_to_napi`] — single-switch mapping with no
    11	//!    catch-all arm; the binding fails to compile when the Rust variant
    12	//!    set drifts from the TS leaf-class set (AC-060a).
    13	//! 3. Every string crossing the FFI is checked by [`validate_ffi_string`]
    14	//!    for embedded NUL or unpaired UTF-16 surrogates BEFORE the writer
    15	//!    transaction opens (AC-068a / AC-068b).
    16	//! 4. Engine panics are caught via `catch_unwind` inside the spawn-blocking
    17	//!    body and rethrown as a distinct `FathomDbPanicError` (code
    18	//!    `FDB_PANIC`); the host process is not aborted (AC-067).
    19	//
    20	// why: napi-rs catches panics by default but throws a generic JS
    21	// `Error` with `Status::GenericFailure` and a Rust-formatted message,
    22	// which is hard to assert on. Explicit `catch_unwind` + a stable
    23	// `FDB_PANIC` code lets the TS-side `rethrowTyped` map panics to a
    24	// distinct `FathomDbPanicError` class that is intentionally NOT a
    25	// `FathomDbError` subclass: panic is a contract bug, not a typed
    26	// engine outcome.
    27	
    28	use std::panic::{catch_unwind, AssertUnwindSafe};
    29	use std::sync::Arc;
    30	
    31	use fathomdb_engine::{
    32	    CorruptionDetail, CorruptionKind, Engine as RustEngine, EngineError as RustEngineError,
    33	    EngineOpenError, OpenStage, PreparedWrite, SearchResult as RustSearchResult,
    34	    SoftFallbackBranch, WriteReceipt as RustWriteReceipt,
    35	};
    36	use napi::{Error, JsUnknown, Result, Status};
    37	use napi_derive::napi;
    38	use serde::Serialize;
    39	use serde_json::{json, Value as JsonValue};
    40	
    41	// ===== Error-code constants ===========================================
    42	//
    43	// One per typed leaf class on the TS side. The single-switch translator
    44	// below maps every engine variant to exactly one of these codes; the TS
    45	// `rethrowTyped` table maps each code to exactly one leaf class. Drift
    46	// fails to compile (Rust side) or fails an exhaustiveness check (TS).
    47	
    48	const CODE_STORAGE: &str = "FDB_STORAGE";
