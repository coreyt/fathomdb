   118	// ===== Error mapping ==================================================
   119	
   120	/// Translate every `EngineError` variant to its typed JS counterpart.
   121	///
   122	/// No catch-all arm: drift between the Rust enum and the TS class set
   123	/// is a compile error.
   124	fn engine_error_to_napi(err: RustEngineError) -> Error {
   125	    match err {
   126	        RustEngineError::Storage => typed_error(CODE_STORAGE, "storage error", JsonValue::Null),
   127	        RustEngineError::Projection => {
   128	            typed_error(CODE_PROJECTION, "projection error", JsonValue::Null)
   129	        }
   130	        RustEngineError::Vector => typed_error(CODE_VECTOR, "vector error", JsonValue::Null),
   131	        RustEngineError::Embedder => typed_error(CODE_EMBEDDER, "embedder error", JsonValue::Null),
   132	        RustEngineError::EmbedderNotConfigured => {
   133	            typed_error(CODE_EMBEDDER_NOT_CONFIGURED, "embedder is not configured", JsonValue::Null)
   134	        }
   135	        RustEngineError::KindNotVectorIndexed => typed_error(
   136	            CODE_KIND_NOT_VECTOR_INDEXED,
   137	            "kind is not configured for vector indexing",
   138	            JsonValue::Null,
   139	        ),
   140	        RustEngineError::EmbedderDimensionMismatch { expected, actual } => typed_error(
   141	            CODE_EMBEDDER_DIMENSION_MISMATCH,
   142	            format!("embedder vector dimension mismatch: stored {expected}, supplied {actual}"),
   143	            json!({ "stored": expected, "supplied": actual }),
   144	        ),
   145	        RustEngineError::Scheduler => {
   146	            typed_error(CODE_SCHEDULER, "scheduler error", JsonValue::Null)
   147	        }
   148	        RustEngineError::OpStore => typed_error(CODE_OP_STORE, "op-store error", JsonValue::Null),
   149	        RustEngineError::WriteValidation => {
   150	            typed_error(CODE_WRITE_VALIDATION, "write validation error", JsonValue::Null)
   151	        }
   152	        RustEngineError::SchemaValidation => {
   153	            typed_error(CODE_SCHEMA_VALIDATION, "schema validation error", JsonValue::Null)
   154	        }
   155	        RustEngineError::Overloaded => {
   156	            typed_error(CODE_OVERLOADED, "engine overloaded", JsonValue::Null)
   157	        }
   158	        RustEngineError::Closing => typed_error(CODE_CLOSING, "engine is closing", JsonValue::Null),
   159	    }
   160	}
