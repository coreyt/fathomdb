    68	// ===== Typed-error encoder ============================================
    69	
    70	/// Encode a typed-error envelope as JSON in `err.message` so the
    71	/// TS-side `rethrowTyped` can reconstitute the right leaf class with
    72	/// the right payload. napi-rs 2.x has no public API for throwing a
    73	/// Rust-defined JS class directly; the envelope-in-message pattern is
    74	/// the canonical workaround.
    75	#[derive(Serialize)]
    76	struct TypedEnvelope<'a> {
    77	    code: &'a str,
    78	    message: String,
    79	    payload: JsonValue,
    80	}
    81	
    82	fn typed_error(code: &'static str, message: impl Into<String>, payload: JsonValue) -> Error {
    83	    let envelope = TypedEnvelope { code, message: message.into(), payload };
    84	    // serde_json serialization is infallible for our envelope shape;
    85	    // unwrap is safe.
    86	    let reason = serde_json::to_string(&envelope).unwrap();
    87	    Error::new(Status::GenericFailure, reason)
    88	}
    89	
    90	// ===== String validation (AC-068a / AC-068b) =========================
    91	
    92	/// Reject strings carrying an embedded NUL or an unpaired UTF-16
    93	/// surrogate codepoint (`U+D800..=U+DFFF`).
    94	///
    95	/// JavaScript strings are UTF-16 by spec, so lone surrogates are
    96	/// representable on the JS side (`String.fromCharCode(0xD800)`). The
    97	/// napi-rs string conversion translates UTF-16 → UTF-8 and accepts
    98	/// some malformed inputs; this helper rejects them BEFORE the writer
    99	/// transaction opens (no-row-written invariant).
   100	pub fn validate_ffi_string(value: &str) -> std::result::Result<(), String> {
   101	    if value.as_bytes().contains(&0) {
   102	        return Err("embedded NUL byte in FFI string".to_string());
   103	    }
   104	    for ch in value.chars() {
   105	        let cp = ch as u32;
   106	        if (0xD800..=0xDFFF).contains(&cp) {
   107	            return Err(format!("unpaired UTF-16 surrogate U+{cp:04X} in FFI string"));
   108	        }
   109	    }
   110	    Ok(())
   111	}
   112	
   113	fn validate_ffi_string_napi(value: &str) -> Result<()> {
   114	    validate_ffi_string(value)
   115	        .map_err(|msg| typed_error(CODE_WRITE_VALIDATION, msg, JsonValue::Null))
   116	}
