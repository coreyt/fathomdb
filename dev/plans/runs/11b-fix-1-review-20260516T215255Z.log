   262	/// Run a blocking engine call inside `tokio::task::spawn_blocking` so
   263	/// the libuv event loop stays free, wrapping it in `catch_unwind` so
   264	/// panics surface as the typed [`panic_error`] rather than aborting the
   265	/// host process. `AssertUnwindSafe` lets us thread the closure through
   266	/// without requiring `UnwindSafe` from the engine's `Arc<dyn Embedder>`
   267	/// substrate.
   268	async fn call_engine<R, F>(f: F) -> Result<R>
   269	where
   270	    R: Send + 'static,
   271	    F: FnOnce() -> std::result::Result<R, RustEngineError> + Send + 'static,
   272	{
   273	    let join_result = tokio::task::spawn_blocking(move || catch_unwind(AssertUnwindSafe(f))).await;
   274	    match join_result {
   275	        Ok(Ok(Ok(value))) => Ok(value),
   276	        Ok(Ok(Err(err))) => Err(engine_error_to_napi(err)),
   277	        Ok(Err(_panic)) => Err(panic_error()),
   278	        Err(join_err) => Err(typed_error(
   279	            CODE_PANIC,
   280	            format!("spawn_blocking join error: {join_err}"),
   281	            JsonValue::Null,
   282	        )),
   283	    }
   284	}
   285	
   286	/// Sync sibling of [`call_engine`]: wrap a non-blocking accessor in
   287	/// `catch_unwind` so a panic on the JS thread surfaces as [`panic_error`]
   288	/// instead of unwinding into napi-rs's default `GenericFailure` path.
   289	fn call_engine_sync<R, F>(f: F) -> Result<R>
   290	where
   291	    F: FnOnce() -> Result<R>,
   292	{
   293	    match catch_unwind(AssertUnwindSafe(f)) {
   294	        Ok(result) => result,
   295	        Err(_panic) => Err(panic_error()),
   296	    }
   297	}
