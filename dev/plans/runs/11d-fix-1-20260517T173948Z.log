{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Wtzm4weLbe1CbTJJxL7zkT","type":"tool_result","content":"1\tname: Release\n2\t\n3\ton:\n4\t  push:\n5\t    tags:\n6\t      - \"v*\"\n7\t  workflow_dispatch:\n8\t    inputs:\n9\t      dry_run:\n10\t        description: \"Rehearse against test.pypi + cargo --dry-run + npm --dry-run (no real publish).\"\n11\t        type: boolean\n12\t        default: true\n13\t\n14\tpermissions:\n15\t  actions: read\n16\t  contents: write\n17\t  id-token: write\n18\t\n19\tenv:\n20\t  DRY_RUN: ${{ inputs.dry_run || 'false' }}\n21\t\n22\tjobs:\n23\t  # Single ubuntu preflight. Combines:\n24\t  #   - scripts/verify-release-gates.sh (tag↔Cargo.toml lockstep, set-version\n25\t  #     --check-files lockstep, HEAD-on-main, CHANGELOG section, crate\n26\t  #     publish metadata).\n27\t  #   - actionlint on all workflow files (per feedback_workflow_validation —\n28\t  #     yaml.safe_load passes schema-invalid syntax GitHub silently rejects).\n29\t  verify-release:\n30\t    runs-on: ubuntu-latest\n31\t    timeout-minutes: 10\n32\t    steps:\n33\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n34\t        with:\n35\t          fetch-depth: 0  # need refs/heads/main for HEAD-reach check\n36\t      - name: Install actionlint\n37\t        run: |\n38\t          curl -fsSL https://raw.githubusercontent.com/rhysd/actionlint/v1.7.7/scripts/download-actionlint.bash \\\n39\t            | bash -s -- 1.7.7\n40\t          sudo mv actionlint /usr/local/bin/actionlint\n41\t      - name: Validate workflow YAML\n42\t        run: actionlint .github/workflows/*.yml\n43\t      - name: Run release gates\n44\t        # Only runs on real tag pushes. workflow_dispatch rehearsals have\n45\t        # no v* tag context, so the tag/Cargo.toml-lockstep check would\n46\t        # always fail; dry-run is for exercising the publish path, not\n47\t        # the gate.\n48\t        if: github.event_name == 'push'\n49\t        run: bash scripts/verify-release-gates.sh\n50\t        env:\n51\t          GH_TOKEN: ${{ github.token }}\n52\t\n53\t  # Multi-platform Python wheels via PyO3/maturin-action. Produces manylinux,\n54\t  # macOS (x86_64 + arm64), and Windows wheels for Python 3.10-3.12. The\n55\t  # working-directory must be `src/python` so maturin reads our pyproject.toml\n56\t  # there (manifest-path = ../rust/crates/fathomdb-py/Cargo.toml).\n57\t  build-python:\n58\t    needs: verify-release\n59\t    strategy:\n60\t      fail-fast: false\n61\t      matrix:\n62\t        include:\n63\t          - runner: ubuntu-latest\n64\t            target: x86_64-unknown-linux-gnu\n65\t            manylinux: \"2_28\"\n66\t          - runner: ubuntu-latest\n67\t            target: aarch64-unknown-linux-gnu\n68\t            manylinux: \"2_28\"\n69\t          - runner: macos-latest\n70\t            target: x86_64-apple-darwin\n71\t          - runner: macos-latest\n72\t            target: aarch64-apple-darwin\n73\t          - runner: windows-latest\n74\t            target: x86_64-pc-windows-msvc\n75\t    runs-on: ${{ matrix.runner }}\n76\t    steps:\n77\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n78\t      - uses: actions/setup-python@a309ff8b426b58ec0e2a45f0f869d46889d02405 # v6.2.0\n79\t        with:\n80\t          python-version: \"3.11\"\n81\t      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n82\t        with:\n83\t          toolchain: stable\n84\t          targets: ${{ matrix.target }}\n85\t      - uses: PyO3/maturin-action@e83996d129638aa358a18fbd1dfb82f0b0fb5d3b # v1.51.0\n86\t        with:\n87\t          target: ${{ matrix.target }}\n88\t          # Explicit -i: cross-compile Docker containers can pick up\n89\t          # python3.14 which pyo3 0.23 does not support. Bump alongside the\n90\t          # pyo3 upgrade landing in dev/notes/pyo3-0.28-upgrade-plan.md.\n91\t          args: --release --out dist -i python3.10 python3.11 python3.12\n92\t          manylinux: ${{ matrix.manylinux || 'auto' }}\n93\t          working-directory: src/python\n94\t      - uses: actions/upload-artifact@bbbca2ddaa5d8feaa63e36b76fdaad77386f024f # v7.0.0\n95\t        with:\n96\t          name: python-dist-${{ matrix.target }}\n97\t          path: src/python/dist/*\n98\t\n99\t  # Native binding prebuilds for npm. The napi-rs CLI handles the rename to\n100\t  # fathomdb.<platform-label>.node per the `napi.triples` block in\n101\t  # src/ts/package.json — prefer this over a raw `cargo build` + manual cp\n102\t  # because the platform-label convention lives in the napi-rs CLI, not in\n103\t  # us. Binary lands flat at src/ts/fathomdb.<label>.node (NO prebuilds/\n104\t  # subdir; that was the pre-0.6.0 layout).\n105\t  build-napi:\n106\t    needs: verify-release\n107\t    strategy:\n108\t      fail-fast: false\n109\t      matrix:\n110\t        include:\n111\t          - runner: ubuntu-latest\n112\t            target: x86_64-unknown-linux-gnu\n113\t            label: linux-x64-gnu\n114\t          - runner: macos-latest\n115\t            target: x86_64-apple-darwin\n116\t            label: darwin-x64\n117\t          - runner: macos-latest\n118\t            target: aarch64-apple-darwin\n119\t            label: darwin-arm64\n120\t          - runner: windows-latest\n121\t            target: x86_64-pc-windows-msvc\n122\t            label: win32-x64\n123\t    runs-on: ${{ matrix.runner }}\n124\t    steps:\n125\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n126\t      - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0\n127\t        with:\n128\t          node-version: \"22\"\n129\t      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n130\t        with:\n131\t          toolchain: stable\n132\t          targets: ${{ matrix.target }}\n133\t      - uses: Swatinem/rust-cache@c19371144df3bb44fab255c43d04cbc2ab54d1c4 # v2.9.1\n134\t      - name: Install ts deps\n135\t        working-directory: src/ts\n136\t        run: npm ci\n137\t      - name: Build napi binding\n138\t        working-directory: src/ts\n139\t        env:\n140\t          CARGO_BUILD_TARGET: ${{ matrix.target }}\n141\t        run: npm run build:native\n142\t      - uses: actions/upload-artifact@bbbca2ddaa5d8feaa63e36b76fdaad77386f024f # v7.0.0\n143\t        with:\n144\t          name: napi-${{ matrix.label }}\n145\t          path: src/ts/fathomdb.${{ matrix.label }}.node\n146\t\n147\t  # Pre-publish packaging verification for Rust crates:\n148\t  #   1. cargo build --release --workspace — compile check of every crate\n149\t  #      we are about to publish.\n150\t  #   2. cargo package --no-verify for the three leaf crates with no\n151\t  #      in-workspace dependencies (fathomdb-embedder-api, fathomdb-schema,\n152\t  #      fathomdb-query). Validates manifest/readme/license metadata\n153\t  #      without invoking the registry.\n154\t  #\n155\t  # The dependent crates (fathomdb-engine, fathomdb-embedder, fathomdb,\n156\t  # fathomdb-cli) are NOT packaged here: cargo package rewrites path deps\n157\t  # to versioned deps and then does a registry resolve on the rewritten\n158\t  # manifest. For a fresh release the leaf crates are not published yet,\n159\t  # so the resolve cannot find e.g. fathomdb-schema@0.6.0 and fails.\n160\t  # Manifest correctness of the dependent crates is enforced at actual\n161\t  # publish time inside `cargo publish`, which we do not want to duplicate\n162\t  # at CI cost.\n163\t  build-rust:\n164\t    runs-on: ubuntu-latest\n165\t    needs: verify-release\n166\t    steps:\n167\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n168\t      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n169\t        with:\n170\t          toolchain: stable\n171\t      - uses: Swatinem/rust-cache@c19371144df3bb44fab255c43d04cbc2ab54d1c4 # v2.9.1\n172\t      - name: Verify workspace builds in release mode\n173\t        run: cargo build --release --workspace\n174\t      - name: Package fathomdb-embedder-api (leaf, Axis E)\n175\t        run: cargo package --no-verify -p fathomdb-embedder-api\n176\t      - name: Package fathomdb-schema (leaf, no in-workspace deps)\n177\t        run: cargo package --no-verify -p fathomdb-schema\n178\t      - name: Package fathomdb-query (leaf, no in-workspace deps)\n179\t        run: cargo package --no-verify -p fathomdb-query\n180\t\n181\t  # Cross-ecosystem gate: every build must succeed before ANY publish runs.\n182\t  # Without this, a partial release (e.g. crates.io 0.6.0 published but\n183\t  # pypi 0.6.0 blocked on a build failure) leaves downstream versioning\n184\t  # unrecoverable — 0.6.1 would then have mismatched ecosystem coverage.\n185\t  all-builds-passed:\n186\t    runs-on: ubuntu-latest\n187\t    needs:\n188\t      - verify-release\n189\t      - build-python\n190\t      - build-napi\n191\t      - build-rust\n192\t    steps:\n193\t      - run: echo \"all release build gates passed\"\n194\t\n195\t  # --- Tiered cargo publish (T1..T7) -----------------------------------------\n196\t  # Each tier publishes one crate, then sleeps 60s to let the crates.io\n197\t  # index propagate before the next tier resolves the dep against it.\n198\t  # --locked is omitted: the lock file is generated against local path\n199\t  # dependencies, which do not match the crates.io index state during\n200\t  # tiered publishing.\n201\t  # Order rationale: see dev/design/release.md § Tiered publish order.\n202\t\n203\t  publish-rust-t1-embedder-api:\n204\t    runs-on: ubuntu-latest\n205\t    needs: all-builds-passed\n206\t    steps:\n207\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n208\t      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n209\t        with:\n210\t          toolchain: stable\n211\t      - name: cargo publish fathomdb-embedder-api\n212\t        run: |\n213\t          if [ \"${DRY_RUN}\" = \"true\" ]; then\n214\t            cargo publish --dry-run -p fathomdb-embedder-api\n215\t          else\n216\t            cargo publish -p fathomdb-embedder-api --token \"${CARGO_REGISTRY_TOKEN}\"\n217\t          fi\n218\t        env:\n219\t          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n220\t      - name: Wait for crates.io index propagation\n221\t        if: ${{ inputs.dry_run != true }}\n222\t        run: sleep 60\n223\t\n224\t  publish-rust-t2-schema:\n225\t    runs-on: ubuntu-latest\n226\t    needs: publish-rust-t1-embedder-api\n227\t    steps:\n228\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n229\t      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n230\t        with:\n231\t          toolchain: stable\n232\t      - name: cargo publish fathomdb-schema\n233\t        run: |\n234\t          if [ \"${DRY_RUN}\" = \"true\" ]; then\n235\t            cargo publish --dry-run -p fathomdb-schema\n236\t          else\n237\t            cargo publish -p fathomdb-schema --token \"${CARGO_REGISTRY_TOKEN}\"\n238\t          fi\n239\t        env:\n240\t          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n241\t      - name: Wait for crates.io index propagation\n242\t        if: ${{ inputs.dry_run != true }}\n243\t        run: sleep 60\n244\t\n245\t  publish-rust-t3-query:\n246\t    runs-on: ubuntu-latest\n247\t    needs: publish-rust-t2-schema\n248\t    steps:\n249\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n250\t      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n251\t        with:\n252\t          toolchain: stable\n253\t      - name: cargo publish fathomdb-query\n254\t        run: |\n255\t          if [ \"${DRY_RUN}\" = \"true\" ]; then\n256\t            cargo publish --dry-run -p fathomdb-query\n257\t          else\n258\t            cargo publish -p fathomdb-query --token \"${CARGO_REGISTRY_TOKEN}\"\n259\t          fi\n260\t        env:\n261\t          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n262\t      - name: Wait for crates.io index propagation\n263\t        if: ${{ inputs.dry_run != true }}\n264\t        run: sleep 60\n265\t\n266\t  publish-rust-t4-engine:\n267\t    runs-on: ubuntu-latest\n268\t    needs: publish-rust-t3-query\n269\t    steps:\n270\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n271\t      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n272\t        with:\n273\t          toolchain: stable\n274\t      - name: cargo publish fathomdb-engine\n275\t        run: |\n276\t          if [ \"${DRY_RUN}\" = \"true\" ]; then\n277\t            cargo publish --dry-run -p fathomdb-engine\n278\t          else\n279\t            cargo publish -p fathomdb-engine --token \"${CARGO_REGISTRY_TOKEN}\"\n280\t          fi\n281\t        env:\n282\t          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n283\t      - name: Wait for crates.io index propagation\n284\t        if: ${{ inputs.dry_run != true }}\n285\t        run: sleep 60\n286\t\n287\t  publish-rust-t5-embedder:\n288\t    runs-on: ubuntu-latest\n289\t    # T5 depends on Axis E (T1) in graph terms but waits for T4 here so the\n290\t    # 60s index-propagation cadence stays linear; parallelizing T5 with T4\n291\t    # would race the crates.io index from two directions for no real wall-\n292\t    # clock win.\n293\t    needs: publish-rust-t4-engine\n294\t    steps:\n295\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n296\t      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n297\t        with:\n298\t          toolchain: stable\n299\t      - name: cargo publish fathomdb-embedder\n300\t        run: |\n301\t          if [ \"${DRY_RUN}\" = \"true\" ]; then\n302\t            cargo publish --dry-run -p fathomdb-embedder\n303\t          else\n304\t            cargo publish -p fathomdb-embedder --token \"${CARGO_REGISTRY_TOKEN}\"\n305\t          fi\n306\t        env:\n307\t          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n308\t      - name: Wait for crates.io index propagation\n309\t        if: ${{ inputs.dry_run != true }}\n310\t        run: sleep 60\n311\t\n312\t  publish-rust-t6-facade:\n313\t    runs-on: ubuntu-latest\n314\t    needs: publish-rust-t5-embedder\n315\t    steps:\n316\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n317\t      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n318\t        with:\n319\t          toolchain: stable\n320\t      - name: cargo publish fathomdb (facade)\n321\t        run: |\n322\t          if [ \"${DRY_RUN}\" = \"true\" ]; then\n323\t            cargo publish --dry-run -p fathomdb\n324\t          else\n325\t            cargo publish -p fathomdb --token \"${CARGO_REGISTRY_TOKEN}\"\n326\t          fi\n327\t        env:\n328\t          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n329\t      - name: Wait for crates.io index propagation\n330\t        if: ${{ inputs.dry_run != true }}\n331\t        run: sleep 60\n332\t\n333\t  publish-rust-t7-cli:\n334\t    runs-on: ubuntu-latest\n335\t    needs: publish-rust-t6-facade\n336\t    steps:\n337\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n338\t      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n339\t        with:\n340\t          toolchain: stable\n341\t      - name: cargo publish fathomdb-cli\n342\t        run: |\n343\t          if [ \"${DRY_RUN}\" = \"true\" ]; then\n344\t            cargo publish --dry-run -p fathomdb-cli\n345\t          else\n346\t            cargo publish -p fathomdb-cli --token \"${CARGO_REGISTRY_TOKEN}\"\n347\t          fi\n348\t        env:\n349\t          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n350\t      - name: Wait for crates.io index propagation\n351\t        if: ${{ inputs.dry_run != true }}\n352\t        run: sleep 60\n353\t\n354\t  # --- Tier 8: binding-package parallel publishes ----------------------------\n355\t  # PyPI + npm wrap fathomdb-engine directly (PyO3 / napi-rs). They publish\n356\t  # in parallel after T4 resolves on crates.io — independent of T5..T7.\n357\t\n358\t  publish-pypi:\n359\t    runs-on: ubuntu-latest\n360\t    needs: publish-rust-t4-engine\n361\t    environment:\n362\t      name: pypi\n363\t    steps:\n364\t      - uses: actions/download-artifact@3e5f45b2cfb9172054b4087a40e8e0b5a5461e7c # v8.0.1\n365\t        with:\n366\t          pattern: python-dist-*\n367\t          merge-multiple: true\n368\t          path: dist\n369\t      - name: Publish to PyPI (or test.pypi on dry-run)\n370\t        uses: pypa/gh-action-pypi-publish@cef221092ed1bacb1cc03d23a2d87d1d172e277b # v1.14.0\n371\t        with:\n372\t          packages-dir: dist\n373\t          repository-url: ${{ env.DRY_RUN == 'true' && 'https://test.pypi.org/legacy/' || '' }}\n374\t\n375\t  publish-npm:\n376\t    runs-on: ubuntu-latest\n377\t    needs: publish-rust-t4-engine\n378\t    permissions:\n379\t      contents: read\n380\t      id-token: write\n381\t    defaults:\n382\t      run:\n383\t        working-directory: src/ts\n384\t    steps:\n385\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n386\t      - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0\n387\t        with:\n388\t          node-version: \"22\"\n389\t          registry-url: \"https://registry.npmjs.org\"\n390\t      # Pull every platform binary into src/ts/ as siblings of dist/ — the\n391\t      # napi loader expects fathomdb.<platform>-<arch>.node relative to\n392\t      # the compiled JS, and the package.json `files` list ships them.\n393\t      - uses: actions/download-artifact@3e5f45b2cfb9172054b4087a40e8e0b5a5461e7c # v8.0.1\n394\t        with:\n395\t          pattern: napi-*\n396\t          merge-multiple: true\n397\t          path: src/ts\n398\t      - name: List staged artifacts\n399\t        run: ls -la\n400\t      - name: Install + build TypeScript\n401\t        run: |\n402\t          npm ci\n403\t          # The native binaries are already downloaded from build-napi;\n404\t          # only the tsc step is needed here.\n405\t          npx tsc -p tsconfig.json\n406\t      # npm OIDC trusted publishing requires npm >= 11.5.1 but Node 22\n407\t      # ships with npm 10.x. Using npx to invoke the latest npm avoids\n408\t      # the MODULE_NOT_FOUND bug from `npm install -g npm@latest` while\n409\t      # still getting a version that supports OIDC. --access public makes\n410\t      # the bare (unscoped) package publishable; --provenance attests\n411\t      # the build came from this workflow run.\n412\t      - name: Publish to npm (or dry-run rehearsal)\n413\t        run: |\n414\t          if [ \"${DRY_RUN}\" = \"true\" ]; then\n415\t            npx npm@latest publish --dry-run --access public --provenance\n416\t          else\n417\t            npx npm@latest publish --provenance --access public\n418\t          fi\n419\t\n420\t  # --- Post-publish verification --------------------------------------------\n421\t  # AC-056: a published artifact is not \"done\" until it installs cleanly from\n422\t  # the registry on a fresh machine and the SDK opens + closes + process-exits.\n423\t  # Skipped on dry-run — install-from-test.pypi does not mirror prod closely\n424\t  # enough to make the smoke meaningful, and npm has no comparable staging.\n425\t  post-publish-smoke:\n426\t    runs-on: ubuntu-latest\n427\t    if: ${{ inputs.dry_run != true }}\n428\t    needs:\n429\t      - publish-rust-t7-cli\n430\t      - publish-pypi\n431\t      - publish-npm\n432\t    strategy:\n433\t      fail-fast: false\n434\t      matrix:\n435\t        smoke:\n436\t          - crates-cli\n437\t          - pypi-wheel\n438\t          - npm-package\n439\t    steps:\n440\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n441\t      - uses: actions/setup-python@a309ff8b426b58ec0e2a45f0f869d46889d02405 # v6.2.0\n442\t        if: matrix.smoke == 'pypi-wheel'\n443\t        with:\n444\t          python-version: \"3.12\"\n445\t      - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0\n446\t        if: matrix.smoke == 'npm-package'\n447\t        with:\n448\t          node-version: \"22\"\n449\t      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n450\t        if: matrix.smoke == 'crates-cli'\n451\t        with:\n452\t          toolchain: stable\n453\t      - name: Resolve tag version\n454\t        id: ver\n455\t        run: |\n456\t          v=\"${GITHUB_REF_NAME#v}\"\n457\t          echo \"version=${v}\" >> \"$GITHUB_OUTPUT\"\n458\t      - name: Run smoke\n459\t        run: bash \"scripts/release/smoke/smoke-${{ matrix.smoke }}.sh\" \"${{ steps.ver.outputs.version }}\"\n460\t\n461\t  # AC-052: sibling triple (fathomdb + fathomdb-embedder + fathomdb-embedder-\n462\t  # api) must all exist in the registry at the expected versions after the\n463\t  # tier 1..7 publishes complete. Skipped on dry-run since no real publish\n464\t  # happened.\n465\t  co-tagging-assert:\n466\t    runs-on: ubuntu-latest\n467\t    if: ${{ inputs.dry_run != true }}\n468\t    needs:\n469\t      - publish-rust-t7-cli\n470\t      - publish-pypi\n471\t      - publish-npm\n472\t    steps:\n473\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n474\t      - name: Resolve tag version\n475\t        id: ver\n476\t        run: |\n477\t          v=\"${GITHUB_REF_NAME#v}\"\n478\t          echo \"version=${v}\" >> \"$GITHUB_OUTPUT\"\n479\t      - name: Assert sibling-package co-tagging\n480\t        run: bash scripts/release/assert-co-tagging.sh \"${{ steps.ver.outputs.version }}\"\n481\t\n482\t  # AC-054 partial: only this job marks the release complete by creating the\n483\t  # GitHub Release. If any smoke or co-tagging job is red, this job does not\n484\t  # run, so the release is never marked done. Skipped on dry-run.\n485\t  github-release:\n486\t    runs-on: ubuntu-latest\n487\t    if: ${{ inputs.dry_run != true }}\n488\t    needs:\n489\t      - post-publish-smoke\n490\t      - co-tagging-assert\n491\t    steps:\n492\t      - uses: actions/download-artifact@3e5f45b2cfb9172054b4087a40e8e0b5a5461e7c # v8.0.1\n493\t        with:\n494\t          pattern: python-dist-*\n495\t          merge-multiple: true\n496\t          path: dist\n497\t      - uses: softprops/action-gh-release@153bb8e04406b158c6c84fc1615b65b24149a1fe # v2.6.1\n498\t        with:\n499\t          files: dist/*\n500\t"}]},"parent_tool_use_id":null,"session_id":"461792b1-c5f8-4800-9416-9dfcbd8f629a","uuid":"3649e402-a7fd-4fc4-83ee-7532fa3be3df","timestamp":"2026-05-17T17:39:54.827Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-11d-release-workflow-20260517T145932Z/.github/workflows/release.yml","content":"name: Release\n\non:\n  push:\n    tags:\n      - \"v*\"\n  workflow_dispatch:\n    inputs:\n      dry_run:\n        description: \"Rehearse against test.pypi + cargo --dry-run + npm --dry-run (no real publish).\"\n        type: boolean\n        default: true\n\npermissions:\n  actions: read\n  contents: write\n  id-token: write\n\nenv:\n  DRY_RUN: ${{ inputs.dry_run || 'false' }}\n\njobs:\n  # Single ubuntu preflight. Combines:\n  #   - scripts/verify-release-gates.sh (tag↔Cargo.toml lockstep, set-version\n  #     --check-files lockstep, HEAD-on-main, CHANGELOG section, crate\n  #     publish metadata).\n  #   - actionlint on all workflow files (per feedback_workflow_validation —\n  #     yaml.safe_load passes schema-invalid syntax GitHub silently rejects).\n  verify-release:\n    runs-on: ubuntu-latest\n    timeout-minutes: 10\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n        with:\n          fetch-depth: 0  # need refs/heads/main for HEAD-reach check\n      - name: Install actionlint\n        run: |\n          curl -fsSL https://raw.githubusercontent.com/rhysd/actionlint/v1.7.7/scripts/download-actionlint.bash \\\n            | bash -s -- 1.7.7\n          sudo mv actionlint /usr/local/bin/actionlint\n      - name: Validate workflow YAML\n        run: actionlint .github/workflows/*.yml\n      - name: Run release gates\n        # Only runs on real tag pushes. workflow_dispatch rehearsals have\n        # no v* tag context, so the tag/Cargo.toml-lockstep check would\n        # always fail; dry-run is for exercising the publish path, not\n        # the gate.\n        if: github.event_name == 'push'\n        run: bash scripts/verify-release-gates.sh\n        env:\n          GH_TOKEN: ${{ github.token }}\n\n  # Multi-platform Python wheels via PyO3/maturin-action. Produces manylinux,\n  # macOS (x86_64 + arm64), and Windows wheels for Python 3.10-3.12. The\n  # working-directory must be `src/python` so maturin reads our pyproject.toml\n  # there (manifest-path = ../rust/crates/fathomdb-py/Cargo.toml).\n  build-python:\n    needs: verify-release\n    strategy:\n      fail-fast: false\n      matrix:\n        include:\n          - runner: ubuntu-latest\n            target: x86_64-unknown-linux-gnu\n            manylinux: \"2_28\"\n          - runner: ubuntu-latest\n            target: aarch64-unknown-linux-gnu\n            manylinux: \"2_28\"\n          - runner: macos-latest\n            target: x86_64-apple-darwin\n          - runner: macos-latest\n            target: aarch64-apple-darwin\n          - runner: windows-latest\n            target: x86_64-pc-windows-msvc\n    runs-on: ${{ matrix.runner }}\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: actions/setup-python@a309ff8b426b58ec0e2a45f0f869d46889d02405 # v6.2.0\n        with:\n          python-version: \"3.11\"\n      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n        with:\n          toolchain: stable\n          targets: ${{ matrix.target }}\n      - uses: PyO3/maturin-action@e83996d129638aa358a18fbd1dfb82f0b0fb5d3b # v1.51.0\n        with:\n          target: ${{ matrix.target }}\n          # Explicit -i: cross-compile Docker containers can pick up\n          # python3.14 which pyo3 0.23 does not support. Bump alongside the\n          # pyo3 upgrade landing in dev/notes/pyo3-0.28-upgrade-plan.md.\n          args: --release --out dist -i python3.10 python3.11 python3.12\n          manylinux: ${{ matrix.manylinux || 'auto' }}\n          working-directory: src/python\n      - uses: actions/upload-artifact@bbbca2ddaa5d8feaa63e36b76fdaad77386f024f # v7.0.0\n        with:\n          name: python-dist-${{ matrix.target }}\n          path: src/python/dist/*\n\n  # Native binding prebuilds for npm. The napi-rs CLI handles the rename to\n  # fathomdb.<platform-label>.node per the `napi.triples` block in\n  # src/ts/package.json — prefer this over a raw `cargo build` + manual cp\n  # because the platform-label convention lives in the napi-rs CLI, not in\n  # us. Binary lands flat at src/ts/fathomdb.<label>.node (NO prebuilds/\n  # subdir; that was the pre-0.6.0 layout).\n  build-napi:\n    needs: verify-release\n    strategy:\n      fail-fast: false\n      matrix:\n        include:\n          - runner: ubuntu-latest\n            target: x86_64-unknown-linux-gnu\n            label: linux-x64-gnu\n          - runner: macos-latest\n            target: x86_64-apple-darwin\n            label: darwin-x64\n          - runner: macos-latest\n            target: aarch64-apple-darwin\n            label: darwin-arm64\n          - runner: windows-latest\n            target: x86_64-pc-windows-msvc\n            label: win32-x64\n    runs-on: ${{ matrix.runner }}\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0\n        with:\n          node-version: \"22\"\n      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n        with:\n          toolchain: stable\n          targets: ${{ matrix.target }}\n      - uses: Swatinem/rust-cache@c19371144df3bb44fab255c43d04cbc2ab54d1c4 # v2.9.1\n      - name: Install ts deps\n        working-directory: src/ts\n        run: npm ci\n      - name: Build napi binding\n        working-directory: src/ts\n        env:\n          CARGO_BUILD_TARGET: ${{ matrix.target }}\n        run: npm run build:native\n      - uses: actions/upload-artifact@bbbca2ddaa5d8feaa63e36b76fdaad77386f024f # v7.0.0\n        with:\n          name: napi-${{ matrix.label }}\n          path: src/ts/fathomdb.${{ matrix.label }}.node\n\n  # Pre-publish packaging verification for Rust crates:\n  #   1. cargo build --release --workspace — compile check of every crate\n  #      we are about to publish.\n  #   2. cargo package --no-verify for the three leaf crates with no\n  #      in-workspace dependencies (fathomdb-embedder-api, fathomdb-schema,\n  #      fathomdb-query). Validates manifest/readme/license metadata\n  #      without invoking the registry.\n  #\n  # The dependent crates (fathomdb-engine, fathomdb-embedder, fathomdb,\n  # fathomdb-cli) are NOT packaged here: cargo package rewrites path deps\n  # to versioned deps and then does a registry resolve on the rewritten\n  # manifest. For a fresh release the leaf crates are not published yet,\n  # so the resolve cannot find e.g. fathomdb-schema@0.6.0 and fails.\n  # Manifest correctness of the dependent crates is enforced at actual\n  # publish time inside `cargo publish`, which we do not want to duplicate\n  # at CI cost.\n  build-rust:\n    runs-on: ubuntu-latest\n    needs: verify-release\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n        with:\n          toolchain: stable\n      - uses: Swatinem/rust-cache@c19371144df3bb44fab255c43d04cbc2ab54d1c4 # v2.9.1\n      - name: Verify workspace builds in release mode\n        run: cargo build --release --workspace\n      - name: Package fathomdb-embedder-api (leaf, Axis E)\n        run: cargo package --no-verify -p fathomdb-embedder-api\n      - name: Package fathomdb-schema (leaf, no in-workspace deps)\n        run: cargo package --no-verify -p fathomdb-schema\n      - name: Package fathomdb-query (leaf, no in-workspace deps)\n        run: cargo package --no-verify -p fathomdb-query\n\n  # Cross-ecosystem gate: every build must succeed before ANY publish runs.\n  # Without this, a partial release (e.g. crates.io 0.6.0 published but\n  # pypi 0.6.0 blocked on a build failure) leaves downstream versioning\n  # unrecoverable — 0.6.1 would then have mismatched ecosystem coverage.\n  all-builds-passed:\n    runs-on: ubuntu-latest\n    needs:\n      - verify-release\n      - build-python\n      - build-napi\n      - build-rust\n    steps:\n      - run: echo \"all release build gates passed\"\n\n  # --- Tiered cargo publish (T1..T7) -----------------------------------------\n  # Each tier publishes one crate, then sleeps 60s to let the crates.io\n  # index propagate before the next tier resolves the dep against it.\n  # --locked is omitted: the lock file is generated against local path\n  # dependencies, which do not match the crates.io index state during\n  # tiered publishing.\n  # Order rationale: see dev/design/release.md § Tiered publish order.\n\n  publish-rust-t1-embedder-api:\n    runs-on: ubuntu-latest\n    needs: all-builds-passed\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n        with:\n          toolchain: stable\n      - name: cargo publish fathomdb-embedder-api\n        run: |\n          if [ \"${DRY_RUN}\" = \"true\" ]; then\n            cargo publish --dry-run -p fathomdb-embedder-api\n          else\n            cargo publish -p fathomdb-embedder-api --token \"${CARGO_REGISTRY_TOKEN}\"\n          fi\n        env:\n          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n      - name: Wait for crates.io index propagation\n        if: ${{ inputs.dry_run != true }}\n        run: sleep 60\n\n  publish-rust-t2-schema:\n    runs-on: ubuntu-latest\n    needs: publish-rust-t1-embedder-api\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n        with:\n          toolchain: stable\n      - name: cargo publish fathomdb-schema\n        run: |\n          if [ \"${DRY_RUN}\" = \"true\" ]; then\n            cargo publish --dry-run -p fathomdb-schema\n          else\n            cargo publish -p fathomdb-schema --token \"${CARGO_REGISTRY_TOKEN}\"\n          fi\n        env:\n          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n      - name: Wait for crates.io index propagation\n        if: ${{ inputs.dry_run != true }}\n        run: sleep 60\n\n  publish-rust-t3-query:\n    runs-on: ubuntu-latest\n    needs: publish-rust-t2-schema\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n        with:\n          toolchain: stable\n      - name: cargo publish fathomdb-query\n        run: |\n          if [ \"${DRY_RUN}\" = \"true\" ]; then\n            cargo publish --dry-run -p fathomdb-query\n          else\n            cargo publish -p fathomdb-query --token \"${CARGO_REGISTRY_TOKEN}\"\n          fi\n        env:\n          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n      - name: Wait for crates.io index propagation\n        if: ${{ inputs.dry_run != true }}\n        run: sleep 60\n\n  publish-rust-t4-engine:\n    runs-on: ubuntu-latest\n    needs: publish-rust-t3-query\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n        with:\n          toolchain: stable\n      - name: cargo publish fathomdb-engine\n        run: |\n          if [ \"${DRY_RUN}\" = \"true\" ]; then\n            cargo publish --dry-run -p fathomdb-engine\n          else\n            cargo publish -p fathomdb-engine --token \"${CARGO_REGISTRY_TOKEN}\"\n          fi\n        env:\n          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n      - name: Wait for crates.io index propagation\n        if: ${{ inputs.dry_run != true }}\n        run: sleep 60\n\n  publish-rust-t5-embedder:\n    runs-on: ubuntu-latest\n    # T5 depends on Axis E (T1) in graph terms but waits for T4 here so the\n    # 60s index-propagation cadence stays linear; parallelizing T5 with T4\n    # would race the crates.io index from two directions for no real wall-\n    # clock win.\n    needs: publish-rust-t4-engine\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n        with:\n          toolchain: stable\n      - name: cargo publish fathomdb-embedder\n        run: |\n          if [ \"${DRY_RUN}\" = \"true\" ]; then\n            cargo publish --dry-run -p fathomdb-embedder\n          else\n            cargo publish -p fathomdb-embedder --token \"${CARGO_REGISTRY_TOKEN}\"\n          fi\n        env:\n          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n      - name: Wait for crates.io index propagation\n        if: ${{ inputs.dry_run != true }}\n        run: sleep 60\n\n  publish-rust-t6-facade:\n    runs-on: ubuntu-latest\n    needs: publish-rust-t5-embedder\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n        with:\n          toolchain: stable\n      - name: cargo publish fathomdb (facade)\n        run: |\n          if [ \"${DRY_RUN}\" = \"true\" ]; then\n            cargo publish --dry-run -p fathomdb\n          else\n            cargo publish -p fathomdb --token \"${CARGO_REGISTRY_TOKEN}\"\n          fi\n        env:\n          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n      - name: Wait for crates.io index propagation\n        if: ${{ inputs.dry_run != true }}\n        run: sleep 60\n\n  publish-rust-t7-cli:\n    runs-on: ubuntu-latest\n    needs: publish-rust-t6-facade\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n        with:\n          toolchain: stable\n      - name: cargo publish fathomdb-cli\n        run: |\n          if [ \"${DRY_RUN}\" = \"true\" ]; then\n            cargo publish --dry-run -p fathomdb-cli\n          else\n            cargo publish -p fathomdb-cli --token \"${CARGO_REGISTRY_TOKEN}\"\n          fi\n        env:\n          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n      - name: Wait for crates.io index propagation\n        if: ${{ inputs.dry_run != true }}\n        run: sleep 60\n\n  # --- Tier 8: binding-package parallel publishes ----------------------------\n  # PyPI + npm wrap fathomdb-engine directly (PyO3 / napi-rs). They publish\n  # in parallel after T4 resolves on crates.io — independent of T5..T7.\n\n  publish-pypi:\n    runs-on: ubuntu-latest\n    needs: publish-rust-t4-engine\n    environment:\n      name: pypi\n    steps:\n      - uses: actions/download-artifact@3e5f45b2cfb9172054b4087a40e8e0b5a5461e7c # v8.0.1\n        with:\n          pattern: python-dist-*\n          merge-multiple: true\n          path: dist\n      - name: Publish to PyPI (or test.pypi on dry-run)\n        uses: pypa/gh-action-pypi-publish@cef221092ed1bacb1cc03d23a2d87d1d172e277b # v1.14.0\n        with:\n          packages-dir: dist\n          repository-url: ${{ env.DRY_RUN == 'true' && 'https://test.pypi.org/legacy/' || '' }}\n\n  publish-npm:\n    runs-on: ubuntu-latest\n    needs: publish-rust-t4-engine\n    permissions:\n      contents: read\n      id-token: write\n    defaults:\n      run:\n        working-directory: src/ts\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0\n        with:\n          node-version: \"22\"\n          registry-url: \"https://registry.npmjs.org\"\n      # Pull every platform binary into src/ts/ as siblings of dist/ — the\n      # napi loader expects fathomdb.<platform>-<arch>.node relative to\n      # the compiled JS, and the package.json `files` list ships them.\n      - uses: actions/download-artifact@3e5f45b2cfb9172054b4087a40e8e0b5a5461e7c # v8.0.1\n        with:\n          pattern: napi-*\n          merge-multiple: true\n          path: src/ts\n      - name: List staged artifacts\n        run: ls -la\n      - name: Install + build TypeScript\n        run: |\n          npm ci\n          # The native binaries are already downloaded from build-napi;\n          # only the tsc step is needed here.\n          npx tsc -p tsconfig.json\n      # npm OIDC trusted publishing requires npm >= 11.5.1 but Node 22\n      # ships with npm 10.x. Using npx to invoke the latest npm avoids\n      # the MODULE_NOT_FOUND bug from `npm install -g npm@latest` while\n      # still getting a version that supports OIDC. --access public makes\n      # the bare (unscoped) package publishable; --provenance attests\n      # the build came from this workflow run.\n      - name: Publish to npm (or dry-run rehearsal)\n        run: |\n          if [ \"${DRY_RUN}\" = \"true\" ]; then\n            npx npm@latest publish --dry-run --access public --provenance\n          else\n            npx npm@latest publish --provenance --access public\n          fi\n\n  # --- Post-publish verification --------------------------------------------\n  # AC-056: a published artifact is not \"done\" until it installs cleanly from\n  # the registry on a fresh machine and the SDK opens + closes + process-exits.\n  # Skipped on dry-run — install-from-test.pypi does not mirror prod closely\n  # enough to make the smoke meaningful, and npm has no comparable staging.\n  post-publish-smoke:\n    runs-on: ubuntu-latest\n    if: ${{ inputs.dry_run != true }}\n    needs:\n      - publish-rust-t7-cli\n      - publish-pypi\n      - publish-npm\n    strategy:\n      fail-fast: false\n      matrix:\n        smoke:\n          - crates-cli\n          - pypi-wheel\n          - npm-package\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: actions/setup-python@a309ff8b426b58ec0e2a45f0f869d46889d02405 # v6.2.0\n        if: matrix.smoke == 'pypi-wheel'\n        with:\n          python-version: \"3.12\"\n      - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0\n        if: matrix.smoke == 'npm-package'\n        with:\n          node-version: \"22\"\n      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n        if: matrix.smoke == 'crates-cli'\n        with:\n          toolchain: stable\n      - name: Resolve tag version\n        id: ver\n        run: |\n          v=\"${GITHUB_REF_NAME#v}\"\n          echo \"version=${v}\" >> \"$GITHUB_OUTPUT\"\n      - name: Run smoke\n        run: bash \"scripts/release/smoke/smoke-${{ matrix.smoke }}.sh\" \"${{ steps.ver.outputs.version }}\"\n\n  # AC-052: sibling triple (fathomdb + fathomdb-embedder + fathomdb-embedder-\n  # api) must all exist in the registry at the expected versions after the\n  # tier 1..7 publishes complete. Skipped on dry-run since no real publish\n  # happened.\n  co-tagging-assert:\n    runs-on: ubuntu-latest\n    if: ${{ inputs.dry_run != true }}\n    needs:\n      - publish-rust-t7-cli\n      - publish-pypi\n      - publish-npm\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - name: Resolve tag version\n        id: ver\n        run: |\n          v=\"${GITHUB_REF_NAME#v}\"\n          echo \"version=${v}\" >> \"$GITHUB_OUTPUT\"\n      - name: Assert sibling-package co-tagging\n        run: bash scripts/release/assert-co-tagging.sh \"${{ steps.ver.outputs.version }}\"\n\n  # AC-054 partial: only this job marks the release complete by creating the\n  # GitHub Release. If any smoke or co-tagging job is red, this job does not\n  # run, so the release is never marked done. Skipped on dry-run.\n  github-release:\n    runs-on: ubuntu-latest\n    if: ${{ inputs.dry_run != true }}\n    needs:\n      - post-publish-smoke\n      - co-tagging-assert\n    steps:\n      - uses: actions/download-artifact@3e5f45b2cfb9172054b4087a40e8e0b5a5461e7c # v8.0.1\n        with:\n          pattern: python-dist-*\n          merge-multiple: true\n          path: dist\n      - uses: softprops/action-gh-release@153bb8e04406b158c6c84fc1615b65b24149a1fe # v2.6.1\n        with:\n          files: dist/*\n","numLines":500,"startLine":1,"totalLines":500}}}
