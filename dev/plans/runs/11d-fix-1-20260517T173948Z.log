{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CPNqhLLi7PFdwAu9kCatGv","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t# scripts/tests/test_verify_release_gates.sh — coverage for the release-gate\n3\t# preflight script. Owner contract: dev/design/release.md § Tiered publish\n4\t# order — every check that gates entry into T1 is exercised here at least\n5\t# once positive + once negative.\n6\t#\n7\t# Tag/branch context for the script is injected via GITHUB_REF_NAME +\n8\t# RELEASE_GATES_HEAD_REF env so the test does not depend on git state.\n9\tset -euo pipefail\n10\t\n11\tSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n12\tREPO_ROOT=\"$(cd \"$SCRIPT_DIR/../..\" && pwd)\"\n13\tVRG=\"$REPO_ROOT/scripts/verify-release-gates.sh\"\n14\t\n15\tCARGO=\"$REPO_ROOT/Cargo.toml\"\n16\tEMBAPI=\"$REPO_ROOT/src/rust/crates/fathomdb-embedder-api/Cargo.toml\"\n17\tPYPROJ=\"$REPO_ROOT/src/python/pyproject.toml\"\n18\tNPMPKG=\"$REPO_ROOT/src/ts/package.json\"\n19\t\n20\tFAILED=0\n21\tTMPDIR_ROOT=\"$(mktemp -d)\"\n22\tSNAP=\"$TMPDIR_ROOT/snap\"\n23\tmkdir -p \"$SNAP\"\n24\ttrap 'restore; rm -rf \"$TMPDIR_ROOT\"' EXIT\n25\t\n26\tcp \"$CARGO\" \"$SNAP/Cargo.toml\"\n27\tcp \"$EMBAPI\" \"$SNAP/embedder-api.toml\"\n28\tcp \"$PYPROJ\" \"$SNAP/pyproject.toml\"\n29\tcp \"$NPMPKG\" \"$SNAP/package.json\"\n30\tSNAP_CRATES=\"$SNAP/crates\"\n31\tmkdir -p \"$SNAP_CRATES\"\n32\tfor c in \"$REPO_ROOT\"/src/rust/crates/*/Cargo.toml; do\n33\t  rel=\"$(basename \"$(dirname \"$c\")\")\"\n34\t  cp \"$c\" \"$SNAP_CRATES/$rel.toml\"\n35\tdone\n36\t\n37\trestore() {\n38\t  cp \"$SNAP/Cargo.toml\" \"$CARGO\" 2>/dev/null || true\n39\t  cp \"$SNAP/embedder-api.toml\" \"$EMBAPI\" 2>/dev/null || true\n40\t  cp \"$SNAP/pyproject.toml\" \"$PYPROJ\" 2>/dev/null || true\n41\t  cp \"$SNAP/package.json\" \"$NPMPKG\" 2>/dev/null || true\n42\t  for f in \"$SNAP_CRATES\"/*.toml; do\n43\t    base=\"$(basename \"$f\" .toml)\"\n44\t    cp \"$f\" \"$REPO_ROOT/src/rust/crates/$base/Cargo.toml\" 2>/dev/null || true\n45\t  done\n46\t}\n47\t\n48\tpass() { printf 'PASS  %s\\n' \"$1\"; }\n49\tfail() { printf 'FAIL  %s\\n' \"$1\" >&2; FAILED=$((FAILED + 1)); }\n50\t\n51\tws_version() {\n52\t  awk '\n53\t    /^\\[workspace\\.package\\]/ { in_block = 1; next }\n54\t    /^\\[/                     { in_block = 0 }\n55\t    in_block && /^version[[:space:]]*=/ {\n56\t      n = split($0, parts, \"\\\"\")\n57\t      if (n >= 3) { print parts[2] }\n58\t      exit\n59\t    }\n60\t  ' \"$CARGO\"\n61\t}\n62\t\n63\t# Stub HEAD-on-main check by exporting RELEASE_GATES_SKIP_GIT_REACH=1; the\n64\t# script honors the override for tests so the suite does not rely on the\n65\t# actual git topology of the worktree under test.\n66\texport RELEASE_GATES_SKIP_GIT_REACH=1\n67\t# Provide a CHANGELOG override path the test controls.\n68\tCL_PATH=\"$TMPDIR_ROOT/CHANGELOG.md\"\n69\texport RELEASE_GATES_CHANGELOG=\"$CL_PATH\"\n70\t\n71\tWS=\"$(ws_version)\"\n72\t\n73\t# 1. Happy path: tag matches workspace version, CHANGELOG has matching\n74\t#    heading, --check-files passes, every crate has description.\n75\trestore\n76\tprintf '# Changelog\\n\\n## %s\\n' \"$WS\" > \"$CL_PATH\"\n77\tGITHUB_REF_NAME=\"v${WS}\" \"$VRG\" >/dev/null 2>&1 \\\n78\t  && pass \"happy path passes\" \\\n79\t  || fail \"happy path should pass\"\n80\t\n81\t# 2. Tag prefix wrong (no leading v) → fail with structured tag-mismatch line.\n82\trestore\n83\tprintf '# Changelog\\n\\n## %s\\n' \"$WS\" > \"$CL_PATH\"\n84\tif out=\"$(GITHUB_REF_NAME=\"${WS}\" \"$VRG\" 2>&1)\"; then\n85\t  fail \"tag without v prefix should fail\"\n86\telse\n87\t  printf '%s' \"$out\" | grep -qi 'tag' \\\n88\t    && pass \"tag-without-v prefix rejected with tag-related diagnostic\" \\\n89\t    || fail \"wrong diagnostic for missing v prefix; got: $out\"\n90\tfi\n91\t\n92\t# 3. Tag version drifts from workspace → fail with structured tag-mismatch.\n93\trestore\n94\tprintf '# Changelog\\n\\n## 9.9.9\\n' > \"$CL_PATH\"\n95\tif out=\"$(GITHUB_REF_NAME=\"v9.9.9\" \"$VRG\" 2>&1)\"; then\n96\t  fail \"tag drift should fail\"\n97\telse\n98\t  printf '%s' \"$out\" | grep -qiE 'tag.*(drift|mismatch|does not match)' \\\n99\t    && pass \"tag/workspace drift rejected\" \\\n100\t    || fail \"wrong diagnostic for tag drift; got: $out\"\n101\tfi\n102\t\n103\t# 4. set-version.sh --check-files failure surfaces via this gate.\n104\trestore\n105\tsed -i 's/^version = \"[^\"]*\"/version = \"7.7.7\"/' \"$REPO_ROOT/src/python/pyproject.toml\"\n106\tprintf '# Changelog\\n\\n## %s\\n' \"$WS\" > \"$CL_PATH\"\n107\tif out=\"$(GITHUB_REF_NAME=\"v${WS}\" \"$VRG\" 2>&1)\"; then\n108\t  cp \"$SNAP/Cargo.toml\" \"$CARGO\"\n109\t  fail \"drift in --check-files should fail the gate\"\n110\telse\n111\t  printf '%s' \"$out\" | grep -qi 'check-files\\|version drift' \\\n112\t    && pass \"set-version --check-files drift surfaces in gate\" \\\n113\t    || fail \"wrong diagnostic for --check-files drift; got: $out\"\n114\tfi\n115\t\n116\t# 5. CHANGELOG missing the tag section → fail.\n117\trestore\n118\tprintf '# Changelog\\n\\n## 0.0.1\\n' > \"$CL_PATH\"\n119\tif out=\"$(GITHUB_REF_NAME=\"v${WS}\" \"$VRG\" 2>&1)\"; then\n120\t  fail \"missing CHANGELOG section should fail\"\n121\telse\n122\t  printf '%s' \"$out\" | grep -qi 'changelog' \\\n123\t    && pass \"missing CHANGELOG section rejected\" \\\n124\t    || fail \"wrong diagnostic for missing CHANGELOG section; got: $out\"\n125\tfi\n126\t\n127\t# 6. Crate metadata: drop description on fathomdb-engine → fail with\n128\t#    a diagnostic naming the crate manifest.\n129\trestore\n130\tprintf '# Changelog\\n\\n## %s\\n' \"$WS\" > \"$CL_PATH\"\n131\tENG=\"$REPO_ROOT/src/rust/crates/fathomdb-engine/Cargo.toml\"\n132\tsed -i '/^description[[:space:]]*=/d' \"$ENG\"\n133\tif out=\"$(GITHUB_REF_NAME=\"v${WS}\" \"$VRG\" 2>&1)\"; then\n134\t  cp \"$SNAP_CRATES/fathomdb-engine.toml\" \"$ENG\"\n135\t  fail \"missing description should fail crate-metadata check\"\n136\telse\n137\t  cp \"$SNAP_CRATES/fathomdb-engine.toml\" \"$ENG\"\n138\t  printf '%s' \"$out\" | grep -qi 'description' \\\n139\t    && printf '%s' \"$out\" | grep -q 'fathomdb-engine' \\\n140\t    && pass \"missing description on fathomdb-engine flagged\" \\\n141\t    || fail \"wrong diagnostic for missing description; got: $out\"\n142\tfi\n143\t\n144\t# 7. Missing GITHUB_REF_NAME (no tag context) → fail with usage-ish diagnostic.\n145\trestore\n146\tprintf '# Changelog\\n\\n## %s\\n' \"$WS\" > \"$CL_PATH\"\n147\tif out=\"$(unset GITHUB_REF_NAME; \"$VRG\" 2>&1)\"; then\n148\t  fail \"missing GITHUB_REF_NAME should fail\"\n149\telse\n150\t  printf '%s' \"$out\" | grep -qi 'ref_name\\|tag' \\\n151\t    && pass \"missing GITHUB_REF_NAME rejected\" \\\n152\t    || fail \"wrong diagnostic for missing tag context; got: $out\"\n153\tfi\n154\t\n155\t# 8. RELEASE_GATES_SKIP_GIT_REACH=0 + bogus ref → fail (head-on-main check\n156\t#    enforced when not skipped, exercised via a non-existent ref).\n157\trestore\n158\tprintf '# Changelog\\n\\n## %s\\n' \"$WS\" > \"$CL_PATH\"\n159\tif out=\"$(RELEASE_GATES_SKIP_GIT_REACH=0 RELEASE_GATES_HEAD_REF=\"refs/heads/__nonexistent__\" \\\n160\t    GITHUB_REF_NAME=\"v${WS}\" \"$VRG\" 2>&1)\"; then\n161\t  fail \"head-not-on-main should fail when reach check enabled\"\n162\telse\n163\t  printf '%s' \"$out\" | grep -qiE 'main|reach' \\\n164\t    && pass \"head-not-reachable-from-main rejected\" \\\n165\t    || fail \"wrong diagnostic for unreachable HEAD; got: $out\"\n166\tfi\n167\t\n168\trestore\n169\t\n170\tif [ \"$FAILED\" -gt 0 ]; then\n171\t  printf '\\n%d test(s) failed\\n' \"$FAILED\" >&2\n172\t  exit 1\n173\tfi\n174\tprintf '\\nAll verify-release-gates tests passed\\n'\n175\t"}]},"parent_tool_use_id":null,"session_id":"461792b1-c5f8-4800-9416-9dfcbd8f629a","uuid":"cafdd9f0-8296-4f09-ba4d-98d50d896a07","timestamp":"2026-05-17T17:39:54.674Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-11d-release-workflow-20260517T145932Z/scripts/tests/test_verify_release_gates.sh","content":"#!/usr/bin/env bash\n# scripts/tests/test_verify_release_gates.sh — coverage for the release-gate\n# preflight script. Owner contract: dev/design/release.md § Tiered publish\n# order — every check that gates entry into T1 is exercised here at least\n# once positive + once negative.\n#\n# Tag/branch context for the script is injected via GITHUB_REF_NAME +\n# RELEASE_GATES_HEAD_REF env so the test does not depend on git state.\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nREPO_ROOT=\"$(cd \"$SCRIPT_DIR/../..\" && pwd)\"\nVRG=\"$REPO_ROOT/scripts/verify-release-gates.sh\"\n\nCARGO=\"$REPO_ROOT/Cargo.toml\"\nEMBAPI=\"$REPO_ROOT/src/rust/crates/fathomdb-embedder-api/Cargo.toml\"\nPYPROJ=\"$REPO_ROOT/src/python/pyproject.toml\"\nNPMPKG=\"$REPO_ROOT/src/ts/package.json\"\n\nFAILED=0\nTMPDIR_ROOT=\"$(mktemp -d)\"\nSNAP=\"$TMPDIR_ROOT/snap\"\nmkdir -p \"$SNAP\"\ntrap 'restore; rm -rf \"$TMPDIR_ROOT\"' EXIT\n\ncp \"$CARGO\" \"$SNAP/Cargo.toml\"\ncp \"$EMBAPI\" \"$SNAP/embedder-api.toml\"\ncp \"$PYPROJ\" \"$SNAP/pyproject.toml\"\ncp \"$NPMPKG\" \"$SNAP/package.json\"\nSNAP_CRATES=\"$SNAP/crates\"\nmkdir -p \"$SNAP_CRATES\"\nfor c in \"$REPO_ROOT\"/src/rust/crates/*/Cargo.toml; do\n  rel=\"$(basename \"$(dirname \"$c\")\")\"\n  cp \"$c\" \"$SNAP_CRATES/$rel.toml\"\ndone\n\nrestore() {\n  cp \"$SNAP/Cargo.toml\" \"$CARGO\" 2>/dev/null || true\n  cp \"$SNAP/embedder-api.toml\" \"$EMBAPI\" 2>/dev/null || true\n  cp \"$SNAP/pyproject.toml\" \"$PYPROJ\" 2>/dev/null || true\n  cp \"$SNAP/package.json\" \"$NPMPKG\" 2>/dev/null || true\n  for f in \"$SNAP_CRATES\"/*.toml; do\n    base=\"$(basename \"$f\" .toml)\"\n    cp \"$f\" \"$REPO_ROOT/src/rust/crates/$base/Cargo.toml\" 2>/dev/null || true\n  done\n}\n\npass() { printf 'PASS  %s\\n' \"$1\"; }\nfail() { printf 'FAIL  %s\\n' \"$1\" >&2; FAILED=$((FAILED + 1)); }\n\nws_version() {\n  awk '\n    /^\\[workspace\\.package\\]/ { in_block = 1; next }\n    /^\\[/                     { in_block = 0 }\n    in_block && /^version[[:space:]]*=/ {\n      n = split($0, parts, \"\\\"\")\n      if (n >= 3) { print parts[2] }\n      exit\n    }\n  ' \"$CARGO\"\n}\n\n# Stub HEAD-on-main check by exporting RELEASE_GATES_SKIP_GIT_REACH=1; the\n# script honors the override for tests so the suite does not rely on the\n# actual git topology of the worktree under test.\nexport RELEASE_GATES_SKIP_GIT_REACH=1\n# Provide a CHANGELOG override path the test controls.\nCL_PATH=\"$TMPDIR_ROOT/CHANGELOG.md\"\nexport RELEASE_GATES_CHANGELOG=\"$CL_PATH\"\n\nWS=\"$(ws_version)\"\n\n# 1. Happy path: tag matches workspace version, CHANGELOG has matching\n#    heading, --check-files passes, every crate has description.\nrestore\nprintf '# Changelog\\n\\n## %s\\n' \"$WS\" > \"$CL_PATH\"\nGITHUB_REF_NAME=\"v${WS}\" \"$VRG\" >/dev/null 2>&1 \\\n  && pass \"happy path passes\" \\\n  || fail \"happy path should pass\"\n\n# 2. Tag prefix wrong (no leading v) → fail with structured tag-mismatch line.\nrestore\nprintf '# Changelog\\n\\n## %s\\n' \"$WS\" > \"$CL_PATH\"\nif out=\"$(GITHUB_REF_NAME=\"${WS}\" \"$VRG\" 2>&1)\"; then\n  fail \"tag without v prefix should fail\"\nelse\n  printf '%s' \"$out\" | grep -qi 'tag' \\\n    && pass \"tag-without-v prefix rejected with tag-related diagnostic\" \\\n    || fail \"wrong diagnostic for missing v prefix; got: $out\"\nfi\n\n# 3. Tag version drifts from workspace → fail with structured tag-mismatch.\nrestore\nprintf '# Changelog\\n\\n## 9.9.9\\n' > \"$CL_PATH\"\nif out=\"$(GITHUB_REF_NAME=\"v9.9.9\" \"$VRG\" 2>&1)\"; then\n  fail \"tag drift should fail\"\nelse\n  printf '%s' \"$out\" | grep -qiE 'tag.*(drift|mismatch|does not match)' \\\n    && pass \"tag/workspace drift rejected\" \\\n    || fail \"wrong diagnostic for tag drift; got: $out\"\nfi\n\n# 4. set-version.sh --check-files failure surfaces via this gate.\nrestore\nsed -i 's/^version = \"[^\"]*\"/version = \"7.7.7\"/' \"$REPO_ROOT/src/python/pyproject.toml\"\nprintf '# Changelog\\n\\n## %s\\n' \"$WS\" > \"$CL_PATH\"\nif out=\"$(GITHUB_REF_NAME=\"v${WS}\" \"$VRG\" 2>&1)\"; then\n  cp \"$SNAP/Cargo.toml\" \"$CARGO\"\n  fail \"drift in --check-files should fail the gate\"\nelse\n  printf '%s' \"$out\" | grep -qi 'check-files\\|version drift' \\\n    && pass \"set-version --check-files drift surfaces in gate\" \\\n    || fail \"wrong diagnostic for --check-files drift; got: $out\"\nfi\n\n# 5. CHANGELOG missing the tag section → fail.\nrestore\nprintf '# Changelog\\n\\n## 0.0.1\\n' > \"$CL_PATH\"\nif out=\"$(GITHUB_REF_NAME=\"v${WS}\" \"$VRG\" 2>&1)\"; then\n  fail \"missing CHANGELOG section should fail\"\nelse\n  printf '%s' \"$out\" | grep -qi 'changelog' \\\n    && pass \"missing CHANGELOG section rejected\" \\\n    || fail \"wrong diagnostic for missing CHANGELOG section; got: $out\"\nfi\n\n# 6. Crate metadata: drop description on fathomdb-engine → fail with\n#    a diagnostic naming the crate manifest.\nrestore\nprintf '# Changelog\\n\\n## %s\\n' \"$WS\" > \"$CL_PATH\"\nENG=\"$REPO_ROOT/src/rust/crates/fathomdb-engine/Cargo.toml\"\nsed -i '/^description[[:space:]]*=/d' \"$ENG\"\nif out=\"$(GITHUB_REF_NAME=\"v${WS}\" \"$VRG\" 2>&1)\"; then\n  cp \"$SNAP_CRATES/fathomdb-engine.toml\" \"$ENG\"\n  fail \"missing description should fail crate-metadata check\"\nelse\n  cp \"$SNAP_CRATES/fathomdb-engine.toml\" \"$ENG\"\n  printf '%s' \"$out\" | grep -qi 'description' \\\n    && printf '%s' \"$out\" | grep -q 'fathomdb-engine' \\\n    && pass \"missing description on fathomdb-engine flagged\" \\\n    || fail \"wrong diagnostic for missing description; got: $out\"\nfi\n\n# 7. Missing GITHUB_REF_NAME (no tag context) → fail with usage-ish diagnostic.\nrestore\nprintf '# Changelog\\n\\n## %s\\n' \"$WS\" > \"$CL_PATH\"\nif out=\"$(unset GITHUB_REF_NAME; \"$VRG\" 2>&1)\"; then\n  fail \"missing GITHUB_REF_NAME should fail\"\nelse\n  printf '%s' \"$out\" | grep -qi 'ref_name\\|tag' \\\n    && pass \"missing GITHUB_REF_NAME rejected\" \\\n    || fail \"wrong diagnostic for missing tag context; got: $out\"\nfi\n\n# 8. RELEASE_GATES_SKIP_GIT_REACH=0 + bogus ref → fail (head-on-main check\n#    enforced when not skipped, exercised via a non-existent ref).\nrestore\nprintf '# Changelog\\n\\n## %s\\n' \"$WS\" > \"$CL_PATH\"\nif out=\"$(RELEASE_GATES_SKIP_GIT_REACH=0 RELEASE_GATES_HEAD_REF=\"refs/heads/__nonexistent__\" \\\n    GITHUB_REF_NAME=\"v${WS}\" \"$VRG\" 2>&1)\"; then\n  fail \"head-not-on-main should fail when reach check enabled\"\nelse\n  printf '%s' \"$out\" | grep -qiE 'main|reach' \\\n    && pass \"head-not-reachable-from-main rejected\" \\\n    || fail \"wrong diagnostic for unreachable HEAD; got: $out\"\nfi\n\nrestore\n\nif [ \"$FAILED\" -gt 0 ]; then\n  printf '\\n%d test(s) failed\\n' \"$FAILED\" >&2\n  exit 1\nfi\nprintf '\\nAll verify-release-gates tests passed\\n'\n","numLines":175,"startLine":1,"totalLines":175}}}
