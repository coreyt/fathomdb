{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JJkJeFeLHMRAKpqQvZA5Ew","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t# scripts/verify-release-gates.sh — release-time preflight.\n3\t#\n4\t# Asserts (in order, fail-fast):\n5\t#   1. GITHUB_REF_NAME is set and looks like `v<axis-W-version>`, and the\n6\t#      bare version matches Axis W (Cargo.toml [workspace.package].version).\n7\t#   2. set-version.sh --check-files passes (two-axis lockstep + inheritance).\n8\t#   3. HEAD commit is reachable from `main` (overridable via env for tests).\n9\t#   4. CHANGELOG.md has a section heading matching the tag's Axis-W version.\n10\t#   5. Every publishable workspace crate has `description`, `license`, and\n11\t#      `repository` fields populated (cargo publish requires these; failing\n12\t#      early beats failing at T4 after T1+T2+T3 succeed).\n13\t#\n14\t# Test seams (env overrides; do not use in CI):\n15\t#   RELEASE_GATES_SKIP_GIT_REACH=1  Skip check 3 entirely.\n16\t#   RELEASE_GATES_HEAD_REF=<ref>    Compare against this ref instead of main.\n17\t#   RELEASE_GATES_CHANGELOG=<path>  Use this CHANGELOG file instead of repo root.\n18\t#\n19\t# Owner: dev/design/release.md § Tiered publish order (entry gate to T1).\n20\tset -euo pipefail\n21\t\n22\tREPO_ROOT=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\"\n23\tCARGO=\"$REPO_ROOT/Cargo.toml\"\n24\tCRATES_DIR=\"$REPO_ROOT/src/rust/crates\"\n25\tSET_VERSION=\"$REPO_ROOT/scripts/set-version.sh\"\n26\t\n27\tdie() {\n28\t  printf 'release-gate: %s\\n' \"$*\" >&2\n29\t  exit 1\n30\t}\n31\t\n32\t# Mirror of set-version.sh's reader; duplicated here to avoid sourcing a\n33\t# script that has top-level dispatch logic.\n34\tread_workspace_version() {\n35\t  awk '\n36\t    /^\\[workspace\\.package\\]/ { in_block = 1; next }\n37\t    /^\\[/                     { in_block = 0 }\n38\t    in_block && /^version[[:space:]]*=/ {\n39\t      n = split($0, parts, \"\\\"\")\n40\t      if (n >= 3) { print parts[2] }\n41\t      exit\n42\t    }\n43\t  ' \"$CARGO\"\n44\t}\n45\t\n46\t# --- Check 1: tag presence + Axis W match -----------------------------------\n47\t\n48\tif [ -z \"${GITHUB_REF_NAME:-}\" ]; then\n49\t  die \"GITHUB_REF_NAME is not set; this script must run under a tag push (refs/tags/v*)\"\n50\tfi\n51\t\n52\tTAG=\"$GITHUB_REF_NAME\"\n53\tcase \"$TAG\" in\n54\t  v*) ;;\n55\t  *) die \"tag '$TAG' does not start with 'v'; release tags must look like v<axis-W-version>\" ;;\n56\tesac\n57\t\n58\tTAG_VERSION=\"${TAG#v}\"\n59\tWS_VERSION=\"$(read_workspace_version)\"\n60\tif [ -z \"$WS_VERSION\" ]; then\n61\t  die \"Cargo.toml: no [workspace.package] version found\"\n62\tfi\n63\tif [ \"$TAG_VERSION\" != \"$WS_VERSION\" ]; then\n64\t  die \"tag/workspace version mismatch — tag is '$TAG_VERSION', Cargo.toml [workspace.package].version is '$WS_VERSION'\"\n65\tfi\n66\t\n67\t# --- Check 2: --check-files lockstep ----------------------------------------\n68\t\n69\tif ! cf_out=\"$(bash \"$SET_VERSION\" --check-files 2>&1)\"; then\n70\t  printf '%s\\n' \"$cf_out\" >&2\n71\t  die \"set-version.sh --check-files failed; resolve the version drift above before tagging\"\n72\tfi\n73\t\n74\t# --- Check 3: HEAD reachable from main --------------------------------------\n75\t\n76\tif [ \"${RELEASE_GATES_SKIP_GIT_REACH:-0}\" != \"1\" ]; then\n77\t  main_ref=\"${RELEASE_GATES_HEAD_REF:-refs/heads/main}\"\n78\t  if ! git -C \"$REPO_ROOT\" rev-parse --verify \"$main_ref\" >/dev/null 2>&1; then\n79\t    die \"cannot resolve $main_ref; release tags must be cut from a commit on main\"\n80\t  fi\n81\t  head_sha=\"$(git -C \"$REPO_ROOT\" rev-parse HEAD)\"\n82\t  if ! git -C \"$REPO_ROOT\" merge-base --is-ancestor \"$head_sha\" \"$main_ref\" 2>/dev/null; then\n83\t    die \"HEAD ($head_sha) is not reachable from $main_ref; release tags must be cut from main\"\n84\t  fi\n85\tfi\n86\t\n87\t# --- Check 4: CHANGELOG heading for this version ----------------------------\n88\t\n89\tCHANGELOG=\"${RELEASE_GATES_CHANGELOG:-$REPO_ROOT/CHANGELOG.md}\"\n90\tif [ ! -f \"$CHANGELOG\" ]; then\n91\t  die \"CHANGELOG.md not found at $CHANGELOG; create one with a '## $WS_VERSION' section before tagging\"\n92\tfi\n93\tif ! grep -qE \"^##[[:space:]]+v?${WS_VERSION//./\\\\.}([[:space:]].*)?\\$\" \"$CHANGELOG\"; then\n94\t  die \"CHANGELOG.md has no '## $WS_VERSION' (or '## v$WS_VERSION') section heading\"\n95\tfi\n96\t\n97\t# --- Check 5: cargo publish required fields ---------------------------------\n98\t# `license.workspace = true` + `repository.workspace = true` are inherited\n99\t# from [workspace.package]; we only need to check `description` is present\n100\t# per-crate (cargo emits a warning but accepts publish without it — we\n101\t# treat it as required for first-class packages).\n102\t\n103\tPUBLISHABLE_CRATES=(\n104\t  fathomdb\n105\t  fathomdb-cli\n106\t  fathomdb-embedder\n107\t  fathomdb-embedder-api\n108\t  fathomdb-engine\n109\t  fathomdb-query\n110\t  fathomdb-schema\n111\t)\n112\t\n113\t# Read the [package] block until next [section] and check field presence.\n114\thas_package_field() {\n115\t  local manifest=\"$1\" field=\"$2\"\n116\t  awk -v field=\"$field\" '\n117\t    /^\\[package\\]/ { in_block = 1; next }\n118\t    /^\\[/ && in_block { exit }\n119\t    in_block && $0 ~ (\"^\" field \"[[:space:]]*[=.]\") { found = 1; exit }\n120\t    END { exit (found ? 0 : 1) }\n121\t  ' \"$manifest\"\n122\t}\n123\t\n124\tmissing=0\n125\tfor crate in \"${PUBLISHABLE_CRATES[@]}\"; do\n126\t  manifest=\"$CRATES_DIR/$crate/Cargo.toml\"\n127\t  if [ ! -f \"$manifest\" ]; then\n128\t    printf 'release-gate: %s: manifest missing\\n' \"$manifest\" >&2\n129\t    missing=1\n130\t    continue\n131\t  fi\n132\t  for field in description license repository; do\n133\t    if ! has_package_field \"$manifest\" \"$field\"; then\n134\t      printf 'release-gate: %s: missing required field \"%s\" in [package]\\n' \\\n135\t        \"$manifest\" \"$field\" >&2\n136\t      missing=1\n137\t    fi\n138\t  done\n139\tdone\n140\tif [ \"$missing\" -ne 0 ]; then\n141\t  die \"one or more crates are missing cargo publish metadata; fix and retag\"\n142\tfi\n143\t\n144\tprintf 'release-gate: ok — tag=%s, axis-W=%s\\n' \"$TAG\" \"$WS_VERSION\"\n145\t"}]},"parent_tool_use_id":null,"session_id":"461792b1-c5f8-4800-9416-9dfcbd8f629a","uuid":"a5e53233-0b20-42db-95fa-6802e2437fed","timestamp":"2026-05-17T17:39:54.618Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-11d-release-workflow-20260517T145932Z/scripts/verify-release-gates.sh","content":"#!/usr/bin/env bash\n# scripts/verify-release-gates.sh — release-time preflight.\n#\n# Asserts (in order, fail-fast):\n#   1. GITHUB_REF_NAME is set and looks like `v<axis-W-version>`, and the\n#      bare version matches Axis W (Cargo.toml [workspace.package].version).\n#   2. set-version.sh --check-files passes (two-axis lockstep + inheritance).\n#   3. HEAD commit is reachable from `main` (overridable via env for tests).\n#   4. CHANGELOG.md has a section heading matching the tag's Axis-W version.\n#   5. Every publishable workspace crate has `description`, `license`, and\n#      `repository` fields populated (cargo publish requires these; failing\n#      early beats failing at T4 after T1+T2+T3 succeed).\n#\n# Test seams (env overrides; do not use in CI):\n#   RELEASE_GATES_SKIP_GIT_REACH=1  Skip check 3 entirely.\n#   RELEASE_GATES_HEAD_REF=<ref>    Compare against this ref instead of main.\n#   RELEASE_GATES_CHANGELOG=<path>  Use this CHANGELOG file instead of repo root.\n#\n# Owner: dev/design/release.md § Tiered publish order (entry gate to T1).\nset -euo pipefail\n\nREPO_ROOT=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)\"\nCARGO=\"$REPO_ROOT/Cargo.toml\"\nCRATES_DIR=\"$REPO_ROOT/src/rust/crates\"\nSET_VERSION=\"$REPO_ROOT/scripts/set-version.sh\"\n\ndie() {\n  printf 'release-gate: %s\\n' \"$*\" >&2\n  exit 1\n}\n\n# Mirror of set-version.sh's reader; duplicated here to avoid sourcing a\n# script that has top-level dispatch logic.\nread_workspace_version() {\n  awk '\n    /^\\[workspace\\.package\\]/ { in_block = 1; next }\n    /^\\[/                     { in_block = 0 }\n    in_block && /^version[[:space:]]*=/ {\n      n = split($0, parts, \"\\\"\")\n      if (n >= 3) { print parts[2] }\n      exit\n    }\n  ' \"$CARGO\"\n}\n\n# --- Check 1: tag presence + Axis W match -----------------------------------\n\nif [ -z \"${GITHUB_REF_NAME:-}\" ]; then\n  die \"GITHUB_REF_NAME is not set; this script must run under a tag push (refs/tags/v*)\"\nfi\n\nTAG=\"$GITHUB_REF_NAME\"\ncase \"$TAG\" in\n  v*) ;;\n  *) die \"tag '$TAG' does not start with 'v'; release tags must look like v<axis-W-version>\" ;;\nesac\n\nTAG_VERSION=\"${TAG#v}\"\nWS_VERSION=\"$(read_workspace_version)\"\nif [ -z \"$WS_VERSION\" ]; then\n  die \"Cargo.toml: no [workspace.package] version found\"\nfi\nif [ \"$TAG_VERSION\" != \"$WS_VERSION\" ]; then\n  die \"tag/workspace version mismatch — tag is '$TAG_VERSION', Cargo.toml [workspace.package].version is '$WS_VERSION'\"\nfi\n\n# --- Check 2: --check-files lockstep ----------------------------------------\n\nif ! cf_out=\"$(bash \"$SET_VERSION\" --check-files 2>&1)\"; then\n  printf '%s\\n' \"$cf_out\" >&2\n  die \"set-version.sh --check-files failed; resolve the version drift above before tagging\"\nfi\n\n# --- Check 3: HEAD reachable from main --------------------------------------\n\nif [ \"${RELEASE_GATES_SKIP_GIT_REACH:-0}\" != \"1\" ]; then\n  main_ref=\"${RELEASE_GATES_HEAD_REF:-refs/heads/main}\"\n  if ! git -C \"$REPO_ROOT\" rev-parse --verify \"$main_ref\" >/dev/null 2>&1; then\n    die \"cannot resolve $main_ref; release tags must be cut from a commit on main\"\n  fi\n  head_sha=\"$(git -C \"$REPO_ROOT\" rev-parse HEAD)\"\n  if ! git -C \"$REPO_ROOT\" merge-base --is-ancestor \"$head_sha\" \"$main_ref\" 2>/dev/null; then\n    die \"HEAD ($head_sha) is not reachable from $main_ref; release tags must be cut from main\"\n  fi\nfi\n\n# --- Check 4: CHANGELOG heading for this version ----------------------------\n\nCHANGELOG=\"${RELEASE_GATES_CHANGELOG:-$REPO_ROOT/CHANGELOG.md}\"\nif [ ! -f \"$CHANGELOG\" ]; then\n  die \"CHANGELOG.md not found at $CHANGELOG; create one with a '## $WS_VERSION' section before tagging\"\nfi\nif ! grep -qE \"^##[[:space:]]+v?${WS_VERSION//./\\\\.}([[:space:]].*)?\\$\" \"$CHANGELOG\"; then\n  die \"CHANGELOG.md has no '## $WS_VERSION' (or '## v$WS_VERSION') section heading\"\nfi\n\n# --- Check 5: cargo publish required fields ---------------------------------\n# `license.workspace = true` + `repository.workspace = true` are inherited\n# from [workspace.package]; we only need to check `description` is present\n# per-crate (cargo emits a warning but accepts publish without it — we\n# treat it as required for first-class packages).\n\nPUBLISHABLE_CRATES=(\n  fathomdb\n  fathomdb-cli\n  fathomdb-embedder\n  fathomdb-embedder-api\n  fathomdb-engine\n  fathomdb-query\n  fathomdb-schema\n)\n\n# Read the [package] block until next [section] and check field presence.\nhas_package_field() {\n  local manifest=\"$1\" field=\"$2\"\n  awk -v field=\"$field\" '\n    /^\\[package\\]/ { in_block = 1; next }\n    /^\\[/ && in_block { exit }\n    in_block && $0 ~ (\"^\" field \"[[:space:]]*[=.]\") { found = 1; exit }\n    END { exit (found ? 0 : 1) }\n  ' \"$manifest\"\n}\n\nmissing=0\nfor crate in \"${PUBLISHABLE_CRATES[@]}\"; do\n  manifest=\"$CRATES_DIR/$crate/Cargo.toml\"\n  if [ ! -f \"$manifest\" ]; then\n    printf 'release-gate: %s: manifest missing\\n' \"$manifest\" >&2\n    missing=1\n    continue\n  fi\n  for field in description license repository; do\n    if ! has_package_field \"$manifest\" \"$field\"; then\n      printf 'release-gate: %s: missing required field \"%s\" in [package]\\n' \\\n        \"$manifest\" \"$field\" >&2\n      missing=1\n    fi\n  done\ndone\nif [ \"$missing\" -ne 0 ]; then\n  die \"one or more crates are missing cargo publish metadata; fix and retag\"\nfi\n\nprintf 'release-gate: ok — tag=%s, axis-W=%s\\n' \"$TAG\" \"$WS_VERSION\"\n","numLines":145,"startLine":1,"totalLines":145}}}
