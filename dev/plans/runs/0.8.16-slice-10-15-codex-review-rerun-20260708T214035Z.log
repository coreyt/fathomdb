+pub use ort_bge::{OrtBgeEmbedder, OrtPooling, ORT_BGE_EMBEDDER_DIM, ORT_BGE_EMBEDDER_NAME};
+
 #[cfg(all(feature = "default-reranker", any(test, feature = "loader-test-hooks")))]
