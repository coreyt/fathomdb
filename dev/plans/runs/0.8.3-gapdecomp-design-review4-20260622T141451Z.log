   194	            # fathomdb retrieves gold (recall 1) + a body that yields the right answer
   195	            hits["fathomdb"][q.question] = [Hit(doc_id=gid, body=f"body-fdb-{qid}", score=1.0)]
   196	            script[f"body-fdb-{qid}"] = f"ans-{qid}"  # correct
   197	            # mem0 retrieves a wrong doc (recall 0) + a body that yields a wrong answer
   198	            hits["mem0_oss"][q.question] = [Hit(doc_id=f"wrong-{qid}", body=f"body-mem0-{qid}", score=0.5)]
   199	            script[f"body-mem0-{qid}"] = "nope"
   200	            # graphiti retrieves gold (recall 1), correct answer
   201	            hits["graphiti_zep"][q.question] = [Hit(doc_id=gid, body=f"body-gz-{qid}", score=0.9)]
   202	            script[f"body-gz-{qid}"] = f"ans-{qid}"
   203	            # naive retrieves gold half the time
