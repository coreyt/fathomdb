    49	class _FakeAnswerer(BaseAnswerer):
    50	    """Deterministic answerer: returns a per-question scripted answer keyed by the
    51	    FIRST context body (so different arms' contexts yield different answers)."""
    52	
    53	    model_id = "fake-answerer-v1"
    54	
    55	    def __init__(self, script: dict[str, Optional[str]]) -> None:
    56	        self.script = script
    57	        self.n_calls = 0
    58	
    59	    @property
    60	    def available(self) -> bool:
    61	        return True
    62	
    63	    def answer(self, question: str, context: list[str]) -> Optional[str]:
    64	        self.n_calls += 1
    65	        key = context[0] if context else ""
    66	        return self.script.get(key)
