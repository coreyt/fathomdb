    61	def _is_retryable(exc: BaseException) -> bool:
    62	    """A transient airlock failure worth retrying: an HTTP **429** (rate-limit) or
    63	    **5xx** (proxy/upstream hiccup), or a connection-level :class:`URLError`. A 4xx
    64	    other than 429 (e.g. 400/401) is a hard error — never retried."""
