   366	class NaiveRAGAdapter:
   367	    """Floor baseline: flat BM25 over the same documents, no memory graph / update
   368	    logic (ADR §3.3). Pure-Python (no extra dependency); deterministic given the
   369	    corpus."""
   370	
   371	    name = "naive_rag"
   372	
   373	    def __init__(self, documents: dict[str, str], *, k1: float = 1.5, b: float = 0.75) -> None:
   374	        self._k1 = k1
   375	        self._b = b
   376	        n_docs = max(len(documents), 1)
   377	        self._doc_len: dict[str, int] = {}
   378	        self._bodies: dict[str, str] = {}
   379	        # Inverted index: term -> [(doc_id, term_freq)]. Scoring touches only docs
   380	        # that contain a query term (standard BM25 structure) — identical scores
   381	        # to a dense per-doc scan, but O(matching postings) not O(corpus) per query.
   382	        self._postings: dict[str, list[tuple[str, int]]] = defaultdict(list)
   383	        df: dict[str, int] = defaultdict(int)
   384	        for doc_id, body in documents.items():
   385	            self._bodies[doc_id] = body
   386	            toks = _tokenize(body)
   387	            self._doc_len[doc_id] = len(toks)
   388	            counts: dict[str, int] = defaultdict(int)
   389	            for t in toks:
   390	                counts[t] += 1
   391	            for t, f in counts.items():
   392	                self._postings[t].append((doc_id, f))
   393	                df[t] += 1
   394	        self._avgdl = max(sum(self._doc_len.values()) / n_docs, 1e-9)
   395	        self._idf = {t: math.log(1 + (n_docs - n + 0.5) / (n + 0.5)) for t, n in df.items()}
   396	
   397	    def retrieve(self, question: str, k: int) -> list[Hit]:
   398	        q_terms = set(_tokenize(question))
   399	        scores: dict[str, float] = defaultdict(float)
   400	        for t in q_terms:
   401	            idf = self._idf.get(t)
   402	            if not idf:
   403	                continue
   404	            coeff = self._k1 + 1
   405	            for doc_id, f in self._postings.get(t, ()):
   406	                dl = self._doc_len[doc_id]
   407	                denom = f + self._k1 * (1 - self._b + self._b * dl / self._avgdl)
   408	                scores[doc_id] += idf * (f * coeff) / denom
   409	        ranked = sorted(scores.items(), key=lambda kv: kv[1], reverse=True)[:k]
   410	        return [Hit(doc_id=doc_id, body=self._bodies.get(doc_id, ""), score=score) for doc_id, score in ranked]
   411	
   412	
   413	class Mem0OSSAdapter:
   414	    """Local Mem0-OSS baseline (``pip install mem0ai`` — NOT the cloud API; cloud
   415	    is a footprint violation, ADR §3.6). ``mem0`` is imported lazily so the harness
   416	    and its unit tests do not require it; ``available`` is False until both the
   417	    library and a configured backend (LLM + embedder) exist.
   418	
   419	    Mem0's ``add()`` extraction and ``search()`` embedding both require an LLM /
   420	    embedding backend; with no local model available the adapter is inert and the
   421	    live comparison runs FathomDB vs naive-RAG only (recorded as a blocker)."""
   422	
   423	    name = "mem0_oss"
   424	
   425	    def __init__(
   426	        self,
   427	        memory: Optional[Any] = None,
   428	        *,
   429	        user_id: str = "r2-eval",
   430	        chroma_path: Optional[str] = None,
   431	        persist: bool = False,
   432	    ) -> None:
   433	        self._memory = memory
   434	        self._user_id = user_id
   435	        # Persistent mode (Slice 10 / Phase-B): the on-disk Chroma path is the
   436	        # anchor for the doc-id resume sidecar `<chroma_path>.ingested.json`.
   437	        self._chroma_path = chroma_path
   438	        self._persist = persist
   439	
   440	    @property
   441	    def available(self) -> bool:
   442	        return self._memory is not None
   443	
   444	    @staticmethod
   445	    def try_build_persistent(corpus_hash: str) -> Optional["Mem0OSSAdapter"]:
   446	        """Build a **persistent, corpus-keyed** adapter (Slice 10 / Phase-B) that
   447	        REUSES a prior ingest for the same ``corpus_hash`` instead of re-ingesting.
   448	
   449	        Same footprint-safe local backend as :meth:`try_build` (airlock-local LLM +
   450	        local ``bge-small`` embedder + on-disk chroma — never Mem0 cloud, ADR §3.6),
   451	        but the Chroma path/collection AND ``user_id`` are keyed by ``corpus_hash``
   452	        ALONE (no per-run id), so a relaunch reopens the same store and
   453	        :meth:`ingest` skips already-ingested docs via the sidecar. Returns None (not
   454	        raising) when ``mem0ai``/its backend is unavailable, mirroring
   455	        :meth:`try_build`."""
   456	        try:
   457	            from mem0 import Memory  # type: ignore[import-not-found]
   458	
   459	            from eval.mem0_local import build_local_mem0_config
   460	        except Exception:
   461	            return None
   462	        api_key = os.environ.get("R2_MEM0_API_KEY") or os.environ.get("R2_ANSWERER_API_KEY", "")
   463	        kwargs: dict[str, Any] = {"api_key": api_key}
   464	        if os.environ.get("R2_MEM0_MODEL"):
   465	            kwargs["llm_model"] = os.environ["R2_MEM0_MODEL"]
   466	        if os.environ.get("R2_MEM0_BASE_URL"):
   467	            kwargs["base_url"] = os.environ["R2_MEM0_BASE_URL"]
   468	        cfg = build_local_mem0_config(corpus_hash=corpus_hash, persist=True, **kwargs)
   469	        try:
   470	            memory = Memory.from_config(cfg)
   471	        except Exception:
   472	            return None
   473	        # The adapter user_id MUST match the config namespace so a reopen searches the
   474	        # SAME memories the prior ingest wrote (the whole point of persistence).
   475	        return Mem0OSSAdapter(
   476	            memory=memory,
   477	            user_id=str(cfg["_user_id"]),
   478	            chroma_path=str(cfg["_chroma_path"]),
   479	            persist=True,
   480	        )
   481	
   482	    @staticmethod
   483	    def try_build() -> Optional["Mem0OSSAdapter"]:
   484	        """Best-effort LOCAL construction (0.8.3 Slice-5 stand-up). Returns None (not
   485	        raising) when ``mem0ai`` or its backend is unavailable, so the runner records
   486	        a clean blocker.
   487	
   488	        Uses the pinned footprint-safe local config
   489	        (:func:`eval.mem0_local.build_local_mem0_config`): airlock-local LLM + local
   490	        ``bge-small`` embedder + on-disk chroma — **never Mem0 cloud** (ADR §3.6). The
   491	        airlock key is read from ``R2_MEM0_API_KEY`` (falling back to
   492	        ``R2_ANSWERER_API_KEY``); the LLM model/base-url from ``R2_MEM0_MODEL`` /
   493	        ``R2_MEM0_BASE_URL`` when overriding the defaults."""
   494	        try:
   495	            from mem0 import Memory  # type: ignore[import-not-found]
   496	
   497	            from eval.mem0_local import build_local_mem0_config
   498	        except Exception:
   499	            return None
   500	        api_key = os.environ.get("R2_MEM0_API_KEY") or os.environ.get("R2_ANSWERER_API_KEY", "")
   501	        kwargs: dict[str, Any] = {"api_key": api_key}
   502	        if os.environ.get("R2_MEM0_MODEL"):
   503	            kwargs["llm_model"] = os.environ["R2_MEM0_MODEL"]
   504	        if os.environ.get("R2_MEM0_BASE_URL"):
   505	            kwargs["base_url"] = os.environ["R2_MEM0_BASE_URL"]
   506	        try:
   507	            memory = Memory.from_config(build_local_mem0_config(**kwargs))
   508	        except Exception:
   509	            return None
   510	        return Mem0OSSAdapter(memory=memory)
   511	
   512	    def ingest(self, documents: dict[str, str]) -> None:
   513	        if self._memory is None:
   514	            raise RuntimeError("Mem0OSSAdapter not available (mem0ai/backend missing)")
   515	        if not self._persist or self._chroma_path is None:
   516	            # Non-persistent (codex Slice-5 [P1#2] default): ingest every doc, no
   517	            # sidecar — a fresh per-run store starts empty so re-ingest is correct.
   518	            for doc_id, body in documents.items():
   519	                self._memory.add(body, user_id=self._user_id, metadata={"doc_id": doc_id})
   520	            return
   521	        # Persistent + resumable (Slice 10 / Phase-B): the sidecar records every
   522	        # doc_id already written to this corpus-keyed store. SKIP docs already
   523	        # present; ADD only the new ones; flush the sidecar AFTER each add so a kill
   524	        # mid-ingest resumes from exactly where it stopped (incremental + idempotent).
   525	        sidecar = Path(str(self._chroma_path) + ".ingested.json")
   526	        done = self._load_ingested(sidecar)
   527	        for doc_id, body in documents.items():
   528	            if doc_id in done:
   529	                continue
   530	            self._memory.add(body, user_id=self._user_id, metadata={"doc_id": doc_id})
   531	            done.add(doc_id)
   532	            self._write_ingested(sidecar, done)
   533	
   534	    @staticmethod
   535	    def _load_ingested(sidecar: Path) -> set[str]:
   536	        """Load the set of already-ingested doc_ids; tolerate a missing/corrupt
   537	        sidecar (treat as empty → a clean from-scratch ingest)."""
   538	        try:
   539	            data = json.loads(sidecar.read_text(encoding="utf-8"))
   540	        except (OSError, ValueError):
   541	            return set()
   542	        return {str(d) for d in data} if isinstance(data, list) else set()
   543	
   544	    @staticmethod
   545	    def _write_ingested(sidecar: Path, done: set[str]) -> None:
   546	        """Atomically persist the ingested-doc_id set (temp-file + ``os.replace``)
   547	        so a kill mid-write cannot corrupt the resume sidecar."""
   548	        sidecar.parent.mkdir(parents=True, exist_ok=True)
   549	        tmp = sidecar.with_suffix(sidecar.suffix + ".tmp")
   550	        tmp.write_text(json.dumps(sorted(done)), encoding="utf-8")
   551	        os.replace(tmp, sidecar)
   552	
   553	    def retrieve(self, question: str, k: int) -> list[Hit]:
   554	        if self._memory is None:
   555	            raise RuntimeError("Mem0OSSAdapter not available (mem0ai/backend missing)")
   556	        # mem0's search() API drifted across versions: ≤1.x took ``user_id=`` +
   557	        # ``limit=``; 2.x rejects a top-level ``user_id`` (raises ValueError) and
   558	        # renamed ``limit`` → ``top_k``, scoping the user via ``filters={'user_id':…}``
   559	        # + a ``threshold`` cutoff. Introspect the bound method's signature and build
   560	        # the right kwargs so the adapter is version-robust (and the fake-backend
   561	        # conformance test, which keeps the ≤1.x shape, still passes).
   562	        import inspect
   563	
   564	        try:
   565	            params = inspect.signature(self._memory.search).parameters
   566	        except (TypeError, ValueError):
   567	            params = {}
   568	        kwargs: dict[str, Any] = {"query": question}
   569	        if "filters" in params:
   570	            kwargs["filters"] = {"user_id": self._user_id}
   571	        else:
   572	            kwargs["user_id"] = self._user_id
   573	        kwargs["top_k" if "top_k" in params else "limit"] = k
   574	        if "threshold" in params:
   575	            kwargs["threshold"] = 0.0  # return the top-k regardless of similarity floor
   576	        res = self._memory.search(**kwargs)
   577	        items = res.get("results", res) if isinstance(res, dict) else res
   578	        hits: list[Hit] = []
   579	        for item in items:
   580	            doc_id = str(item.get("metadata", {}).get("doc_id", item.get("id", "")))
   581	            hits.append(Hit(doc_id=doc_id, body=str(item.get("memory", "")), score=float(item.get("score", 0.0))))
   582	        return hits
   583	
   584	
   585	# --------------------------------------------------------------------------- #
   586	# Scoring
   587	# --------------------------------------------------------------------------- #
   588	
   589	
   590	def _normalize(text: str) -> str:
   591	    return re.sub(r"[^a-z0-9 ]+", " ", text.lower()).strip()
   592	
   593	
   594	# Abstention strings treated as "no answer", computed THROUGH `_normalize` so the
   595	# comparison is self-consistent: `_normalize` turns "I don't know" into
   596	# "i don t know" (apostrophe -> space). A raw literal set like {"i dont know"}
   597	# silently misses the exact phrase the answerer prompt instructs the model to emit.
   598	_ABSTAIN: frozenset[str] = frozenset(
   599	    _normalize(s) for s in ("I don't know", "I dont know", "idk")
   600	) | {""}
   601	
   602	
   603	def normalize_answer(text: Optional[str]) -> Optional[str]:
   604	    """Raw reader answer -> ``None`` when empty or an abstention (apostrophe-safe).
   605	
   606	    The single normalizer both the sync answerers (``*Answerer._complete``) and the
   607	    batch path (``p0a_batch_e2e.parse_batch_output``) call, so abstention detection
   608	    cannot drift between them."""
   609	    t = (text or "").strip()
   610	    if not t or _normalize(t) in _ABSTAIN:
   611	        return None
   612	    return t
   613	
   614	
   615	def _match(ground_truth: list[str], system_answer: str) -> bool:
   616	    sa = _normalize(system_answer)
   617	    if not sa:
   618	        return False
   619	    for gt in ground_truth:
   620	        g = _normalize(gt)
   621	        if not g:
   622	            continue
   623	        if g in sa or (len(g) <= 40 and sa in g):
   624	            return True
   625	    return False
   626	
   627	
   628	def _tokenize(text: str) -> list[str]:
   629	    return [t for t in re.findall(r"[a-z0-9]+", text.lower()) if len(t) >= 2]
   630	
   631	
   632	class PerClassScorer:
   633	    """Scores ``(ground_truth, system_answer)`` with abstention, stratified by
   634	    class. Abstention against a positive query is a miss (0.0); answering a
   635	    negative query is a false positive (0.0). Correct abstention on a negative
   636	    query scores 1.0."""
   637	
   638	    def __init__(self, extra_classes: tuple[str, ...] = ("exploratory", "negative")) -> None:
   639	        self.classes: set[str] = set(R2_CLASSES) | set(extra_classes)
   640	
   641	    def score_answer(
   642	        self, ground_truth: list[str] | tuple[str, ...] | None, system_answer: Optional[str]
   643	    ) -> float:
   644	        gt = list(ground_truth or [])
   645	        if gt:  # an answer exists
   646	            if system_answer is None:
   647	                return 0.0  # abstention miss — counted, never skipped
   648	            return 1.0 if _match(gt, system_answer) else 0.0
   649	        # negative class: no answer exists
   650	        return 0.0 if system_answer is not None else 1.0
   651	
   652	
   653	# --------------------------------------------------------------------------- #
   654	# Harness
   655	# --------------------------------------------------------------------------- #
   656	
   657	
   658	def _parse_gold(raw: dict[str, Any]) -> list[GoldQuery]:
   659	    out: list[GoldQuery] = []
   660	    for q in raw.get("queries", []):
   661	        gold_class = str(q.get("query_class", "")).strip()
   662	        reporting = GOLD_CLASS_MAP.get(gold_class, gold_class or "unknown")
   663	        answers = tuple(str(a) for a in (q.get("answers") or []))
   664	        doc_ids: list[str] = []
   665	        for ev in q.get("required_evidence") or []:
   666	            did = ev.get("doc_id")
   667	            if did:
   668	                doc_ids.append(str(did))
   669	        if not doc_ids:
   670	            doc_ids = [str(d) for d in (q.get("expected_top_k_doc_ids") or [])]
   671	        out.append(
   672	            GoldQuery(
   673	                query_id=str(q.get("query_id", "")),
   674	                question=str(q.get("query", "")),
   675	                reporting_class=reporting,
   676	                answers=answers,
   677	                gold_doc_ids=tuple(doc_ids),
   678	            )
   679	        )
   680	    return out
   681	
   682	
   683	def load_repin_gold(gold_path: str | Path) -> tuple[str, str, list[GoldQuery]]:
   684	    """Load a 0.8.3 D0a re-pinned gold file → ``(corpus_hash, qrels_version, queries)``.
   685	
   686	    Used by :meth:`R2Harness.from_repin_gold` and the Slice-10 parity runner to
   687	    consume the power-sized memory-class gold. Does NOT enforce the COR-2 pin (the
   688	    re-pin is the LongMemEval corpus, design §3); it requires only that the file
   689	    declares a non-empty ``corpus_hash`` and at least one query.
   690	
   691	    Runtime corpus-validity guard (codex §9 [P2]): runs :func:`validate_repin`
   692	    over the gold itself (per-class counts derived from the file, ``n_min`` from
   693	    the file) and **RAISES** on any problem — an underfilled / N=0 / missing /
   694	    single-session-mislabeled class can never silently run to emit null (the
   695	    Slice-25 N=0 mode)."""
   696	    raw = json.loads(Path(gold_path).read_text(encoding="utf-8"))
   697	    corpus_hash = str(raw.get("corpus_hash", "")).strip()
   698	    if not corpus_hash:
   699	        raise ValueError(f"re-pin gold {gold_path!s} has no corpus_hash")
   700	    raw_queries = list(raw.get("queries", []))
   701	
   702	    from eval.corpus_validity import _observed_counts, validate_repin
   703	
   704	    synth_manifest = {
   705	        "n_min": raw.get("n_min"),
   706	        "per_class_gold_counts": _observed_counts(raw_queries),
   707	    }
   708	    problems = validate_repin(synth_manifest, raw_queries)
   709	    if problems:
   710	        raise ValueError(
   711	            f"re-pin gold {gold_path!s} failed corpus-validity guard: {problems}"
   712	        )
   713	
   714	    queries = _parse_gold(raw)
   715	    if not queries:
   716	        raise ValueError(f"re-pin gold {gold_path!s} has no queries")
   717	
   718	    # The gold's identity is its repin_hash (corpus_hash is the intentionally
   719	    # STABLE LME corpus hash and cannot distinguish gold revisions). Derive the
   720	    # qrels_version from repin_hash so distinct gold revisions stay distinct in
   721	    # results/audit logs (codex §9 fix-2 [P2]). Key off repin_hash first; else
   722	    # the gold's declared qrels_version; only fall back to corpus_hash if a
   723	    # (malformed) gold lacks both — which should not happen for the pinned file.
   724	    repin_hash = str(raw.get("repin_hash", "")).strip()
   725	    declared_version = str(raw.get("qrels_version", "")).strip()
   726	    if repin_hash:
   727	        qrels_version = f"repin-{repin_hash[:8]}"
   728	    elif declared_version:
   729	        qrels_version = declared_version
   730	    else:
   731	        qrels_version = f"repin-{corpus_hash[:8]}"
   732	    return corpus_hash, qrels_version, queries
   733	
   734	
   735	def _mean(values: list[float]) -> Optional[float]:
   736	    return round(sum(values) / len(values), 4) if values else None
   737	
   738	
   739	def _delta(a: Optional[float], b: Optional[float]) -> Optional[float]:
   740	    if a is None or b is None:
   741	        return None
   742	    return round(a - b, 4)
   743	
   744	
   745	class R2Harness:
   746	    """Runs the identical-answerer eval over a set of retrieval adapters.
   747	
   748	    The COR-2 corpus-hash pin is asserted in ``__init__`` — *before* any number is
   749	    produced — so a wrong/unpinned corpus cannot yield a citable result."""
   750	
   751	    def __init__(self, gold_path: str | Path, answerer: BaseAnswerer) -> None:
   752	        path = Path(gold_path)
   753	        raw = json.loads(path.read_text(encoding="utf-8"))
   754	        corpus_hash = str(raw.get("corpus_hash", ""))
   755	        if not corpus_hash.startswith(CORPUS_HASH_PREFIX):
   756	            raise ValueError(
   757	                f"corpus_hash {corpus_hash!r} does not start with {CORPUS_HASH_PREFIX!r} "
   758	                "(COR-2): refusing to produce eval numbers on an unpinned corpus"
   759	            )
   760	        self.corpus_hash = corpus_hash
   761	        self.qrels_version = str(raw.get("qrels_version", ""))
   762	        self.queries = _parse_gold(raw)
   763	        self.answerer = answerer
   764	
   765	    @classmethod
   766	    def from_repin_gold(cls, gold_path: str | Path, answerer: BaseAnswerer) -> "R2Harness":
   767	        """Construct an R2Harness from a 0.8.3 D0a **re-pinned** gold file.
   768	
   769	        The re-pinned memory-class gold is LongMemEval-derived (design §3): its
   770	        ``corpus_hash`` is the LME corpus hash, **not** the COR-2 ``fe973fcd`` IR
   771	        corpus, so it deliberately bypasses the COR-2 ``__init__`` pin via
   772	        :meth:`from_queries` (the same path LME mode uses). The file must still
   773	        declare a non-empty ``corpus_hash`` and ``queries`` (validated here)."""
   774	        corpus_hash, qrels_version, queries = load_repin_gold(gold_path)
   775	        return cls.from_queries(
   776	            queries,
   777	            answerer,
   778	            corpus_hash=corpus_hash,
   779	            qrels_version=qrels_version,
   780	        )
   781	
   782	    @classmethod
   783	    def from_queries(
   784	        cls,
   785	        queries: list[GoldQuery],
   786	        answerer: BaseAnswerer,
   787	        *,
   788	        corpus_hash: str = "lme-eval-v1",
   789	        qrels_version: str = "lme-loaded-v1",
   790	    ) -> "R2Harness":
   791	        """Construct an R2Harness from in-memory queries (no gold file, no COR-2 pin).
   792	
   793	        Used for LME mode where the corpus is different from the frozen FathomDB corpus.
   794	        """
   795	        obj = object.__new__(cls)
   796	        obj.corpus_hash = corpus_hash
   797	        obj.qrels_version = qrels_version
   798	        obj.queries = queries
   799	        obj.answerer = answerer
   800	        return obj
   801	
   802	    def run(
   803	        self,
   804	        systems: Mapping[str, RetrievalAdapter],
   805	        *,
   806	        k: int = 10,
   807	        limit: Optional[int] = None,
   808	    ) -> dict[str, Any]:
   809	        queries = self.queries[:limit] if limit is not None else self.queries
   810	        answerer_available = self.answerer.available
   811	        scorer = PerClassScorer()
   812	
   813	        report_classes = sorted(scorer.classes | {q.reporting_class for q in queries})
   814	
   815	        # accumulators[system][class] -> {"recall": [...], "acc": [...], "abst": [...]}
   816	        acc: dict[str, dict[str, dict[str, list[float]]]] = {
   817	            sys_name: {cls: {"recall": [], "acc": [], "abst": []} for cls in report_classes}
   818	            for sys_name in systems
   819	        }
   820	        n_per_class: dict[str, int] = {cls: 0 for cls in report_classes}
   821	
   822	        for q in queries:
   823	            n_per_class[q.reporting_class] += 1
   824	            for sys_name, adapter in systems.items():
   825	                hits = adapter.retrieve(q.question, k)
   826	                bucket = acc[sys_name][q.reporting_class]
   827	                if q.gold_doc_ids:
   828	                    retrieved = {h.doc_id for h in hits}
   829	                    bucket["recall"].append(
   830	                        1.0 if all(g in retrieved for g in q.gold_doc_ids) else 0.0
   831	                    )
   832	                if answerer_available:
   833	                    answer = self.answerer.answer(q.question, [h.body for h in hits if h.body])
   834	                    bucket["abst"].append(1.0 if answer is None else 0.0)
   835	                    if q.answers:  # only score accuracy when answer strings exist
   836	                        bucket["acc"].append(scorer.score_answer(list(q.answers), answer))
   837	
   838	        results: dict[str, dict[str, dict[str, Optional[float]]]] = {}
   839	        for sys_name in systems:
   840	            results[sys_name] = {}
   841	            for cls in report_classes:
   842	                b = acc[sys_name][cls]
   843	                results[sys_name][cls] = {
   844	                    "recall_at_k": _mean(b["recall"]),
   845	                    "answerer_accuracy": _mean(b["acc"]) if answerer_available else None,
   846	                    "abstention_rate": _mean(b["abst"]) if answerer_available else None,
   847	                }
   848	
   849	        deltas = self._delta_table(results, report_classes)
   850	
   851	        return {
   852	            "corpus_hash": self.corpus_hash,
   853	            "qrels_version": self.qrels_version,
   854	            "answerer_model": self.answerer.model_id,
   855	            "answerer_available": answerer_available,
   856	            "k": k,
   857	            "n_queries_per_class": {cls: n_per_class.get(cls, 0) for cls in report_classes},
   858	            "r2_results": results,
   859	            "r2_per_class_deltas": deltas,
   860	        }
   861	
   862	    @staticmethod
   863	    def _delta_table(
   864	        results: dict[str, dict[str, dict[str, Optional[float]]]],
   865	        report_classes: list[str],
   866	    ) -> dict[str, dict[str, Optional[float]]]:
   867	        fdb = results.get("fathomdb")
   868	        mem0 = results.get("mem0_oss")
   869	        naive = results.get("naive_rag")
   870	        table: dict[str, dict[str, Optional[float]]] = {}
   871	        for cls in report_classes:
   872	            fa = fdb[cls]["answerer_accuracy"] if fdb else None
   873	            fr = fdb[cls]["recall_at_k"] if fdb else None
   874	            ma = mem0[cls]["answerer_accuracy"] if mem0 else None
   875	            mr = mem0[cls]["recall_at_k"] if mem0 else None
   876	            na = naive[cls]["answerer_accuracy"] if naive else None
   877	            nr = naive[cls]["recall_at_k"] if naive else None
   878	            table[cls] = {
   879	                # primary delta = end-to-end answerer accuracy (null when no answerer)
   880	                "fathomdb_minus_mem0": _delta(fa, ma),
   881	                "fathomdb_minus_naive_rag": _delta(fa, na),
   882	                # retrieval-only deltas (always available when both systems ran)
   883	                "fathomdb_minus_mem0_recall_at_k": _delta(fr, mr),
   884	                "fathomdb_minus_naive_rag_recall_at_k": _delta(fr, nr),
   885	            }
   886	        return table
   887	
   888	
   889	def run_r2_eval(
   890	    query_set: str | Path,
   891	    systems: Mapping[str, RetrievalAdapter],
   892	    answerer: BaseAnswerer,
   893	    corpus_hash: str,
   894	    *,
   895	    k: int = 10,
   896	    limit: Optional[int] = None,
   897	) -> dict[str, Any]:
   898	    """Convenience entry point. Validates the supplied ``corpus_hash`` (COR-2)
   899	    before constructing the harness, then runs the eval."""
   900	    if not corpus_hash.startswith(CORPUS_HASH_PREFIX):
   901	        raise ValueError(
   902	            f"corpus_hash {corpus_hash!r} does not start with {CORPUS_HASH_PREFIX!r} (COR-2)"
   903	        )
   904	    harness = R2Harness(gold_path=query_set, answerer=answerer)
   905	    return harness.run(systems, k=k, limit=limit)
   906	
   907	
   908	# --------------------------------------------------------------------------- #
   909	# Live-run CLI:  python -m eval.r2_parity_eval --corpus-hash fe973fcd --output ...
   910	# --------------------------------------------------------------------------- #
   911	
   912	
   913	def _default_corpus_dir() -> Path:
   914	    env = os.environ.get("FATHOMDB_CORPUS_DIR")
   915	    if env:
   916	        return Path(env)
   917	    # eval/ -> src/python -> src -> repo
   918	    return Path(__file__).resolve().parents[3] / "data" / "corpus-data"
   919	
   920	
   921	def _load_documents(raw_dir: Path) -> dict[str, str]:
   922	    docs: dict[str, str] = {}
   923	    for jsonl in sorted(raw_dir.glob("*.jsonl")):
   924	        with jsonl.open(encoding="utf-8") as fh:
   925	            for line in fh:
   926	                line = line.strip()
   927	                if not line:
   928	                    continue
   929	                rec = json.loads(line)
   930	                doc_id = rec.get("doc_id") or rec.get("id")
   931	                if doc_id is None:
   932	                    continue
   933	                docs[str(doc_id)] = str(rec.get("body", ""))
   934	    return docs
   935	
   936	
   937	def _format_lme_session(turns: list) -> str:
   938	    parts = []
   939	    for turn in turns:
   940	        if isinstance(turn, str):
   941	            try:
   942	                turn = json.loads(turn)
   943	            except (json.JSONDecodeError, ValueError):
   944	                parts.append(turn)
   945	                continue
   946	        role = str(turn.get("role", "unknown")).capitalize()
   947	        content = str(turn.get("content", "")).strip()
   948	        parts.append(f"[{role}]: {content}")
   949	    return "\n".join(parts)
   950	
   951	
   952	def load_longmemeval(
   953	    dataset_name: str,
   954	    split: str,
   955	    *,
   956	    question_limit: Optional[int] = None,
   957	) -> tuple[dict[str, str], list[GoldQuery]]:
   958	    """Load LongMemEval from HuggingFace.
   959	
   960	    Returns (documents, queries) where documents is {session_id: body}
   961	    (unique sessions pooled from all instances) and queries is the R2 gold list.
   962	    Uses streaming to avoid materializing the full 3 GB dataset.
   963	    """
   964	    try:
   965	        from datasets import load_dataset  # type: ignore[import]
   966	    except ImportError as exc:
   967	        raise ImportError(
   968	            "Install the 'datasets' library: pip install datasets"
   969	        ) from exc
   970	
   971	    # Map HF split name: "s" → "longmemeval_s_cleaned", "oracle" → "longmemeval_oracle"
   972	    split_map = {
   973	        "oracle": "longmemeval_oracle",
   974	        "s": "longmemeval_s_cleaned",
   975	        "m": "longmemeval_m_cleaned",
   976	        # accept full names too
   977	        "longmemeval_oracle": "longmemeval_oracle",
   978	        "longmemeval_s_cleaned": "longmemeval_s_cleaned",
   979	        "longmemeval_m_cleaned": "longmemeval_m_cleaned",
   980	    }
   981	    hf_split = split_map.get(split, split)
   982	
   983	    ds = load_dataset(dataset_name, split=hf_split, streaming=True)
   984	
   985	    documents: dict[str, str] = {}
   986	    queries: list[GoldQuery] = []
   987	
   988	    for i, instance in enumerate(ds):
   989	        if question_limit is not None and i >= question_limit:
   990	            break
   991	
   992	        session_ids: list[str] = instance.get("haystack_session_ids") or []
   993	        sessions: list[list[dict]] = instance.get("haystack_sessions") or []
   994	        for sid, turns in zip(session_ids, sessions):
   995	            if sid not in documents:
   996	                documents[sid] = _format_lme_session(turns)
   997	
   998	        q_type: str = str(instance.get("question_type") or "unknown")
   999	        reporting = LME_CLASS_MAP.get(q_type, "unknown")
  1000	        answer_sids: list[str] = instance.get("answer_session_ids") or []
  1001	        answer_text: str = str(instance.get("answer") or "")
  1002	        question_text: str = str(instance.get("question") or "")
  1003	        q_id: str = str(instance.get("question_id") or f"lme-{i}")
  1004	
  1005	        queries.append(
  1006	            GoldQuery(
  1007	                query_id=q_id,
  1008	                question=question_text,
  1009	                reporting_class=reporting,
  1010	                answers=(answer_text,) if answer_text else (),
  1011	                gold_doc_ids=tuple(answer_sids),
  1012	            )
  1013	        )
  1014	
  1015	    return documents, queries
  1016	
