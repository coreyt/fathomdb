   206	                             n_trials=400, n_boot=600, seed=0)
   207	        for shape in ("flat_positive", "monotonic", "inverted_u")
   208	    }
   209	    req = required_n(base_f1, base_em, hops, shape="flat_positive", target=0.8,
   210	                     grid=_POWER_GRID, n_trials=400, n_boot=600, seed=0)
   211	    rho_sweep = {
   212	        f"rho_{rho}": required_n(base_f1, base_em, hops, shape="flat_positive",
   213	                                 target=0.8, rho=rho, grid=_POWER_GRID,
   214	                                 n_trials=400, n_boot=600, seed=0)["required_n"]
   215	        for rho in (0.3, 0.5, 0.7)
   216	    }
   217	
   218	    # Analytic cross-check (normal-approx, paired CI-excludes-0 at ~80% power):
   219	    # required_N ≈ (sd_pair * (z_0.975 + z_0.80) / lift)^2 — a sanity anchor for
