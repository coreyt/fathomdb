   198	    base_em = [r["em"][COMPARATOR_ARM] for r in ge3 if COMPARATOR_ARM in r["em"]]
   199	    hops = [r["hop_count"] for r in ge3 if COMPARATOR_ARM in r["f1"]]
   200	    if len(base_f1) < 5:
