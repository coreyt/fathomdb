    92	        self.n_calls = 0
    93	        self.n_errors = 0
    94	        self.n_retries = 0
    95	        self.prompt_tokens = 0
    96	        self.completion_tokens = 0
    97	        self._lock = threading.Lock()
    98	        self._max_retries = max_retries
    99	        self._backoff_base = backoff_base
   100	        self._max_backoff = max_backoff
   101	        self._sleep = sleep
   102	        self._jitter = random.Random(0)
   103	
   104	    def _open(self, req: Any) -> Any:
   105	        """Seam over the raw POST (injectable in tests). Returns the urlopen ctx mgr."""
   106	        import urllib.request
   107	
   108	        return urllib.request.urlopen(req, timeout=self._timeout)  # noqa: S310
   109	
   110	    def _complete(self, prompt: str, question: str, context: list[str]) -> Optional[str]:
   111	        import urllib.request
   112	
   113	        from eval.r2_parity_eval import normalize_answer
   114	
   115	        payload = json.dumps(
   116	            {
   117	                "model": self.model_id,
   118	                "messages": [{"role": "user", "content": prompt}],
   119	                "temperature": 0,
   120	                "seed": 0,
   121	            }
   122	        ).encode("utf-8")
   123	        req = urllib.request.Request(
   124	            self.base_url.rstrip("/") + "/chat/completions",
   125	            data=payload,
   126	            headers={
   127	                "Content-Type": "application/json",
   128	                "Authorization": f"Bearer {self.api_key}",
   129	            },
   130	        )
