   235	def answer_completeness(
   236	    records: Sequence[Mapping[str, Any]],
   237	    *,
   238	    arms: Sequence[str],
   239	    n_errors: int,
   240	    floor: float = VALID_COMPLETENESS_FLOOR,
   241	) -> dict[str, Any]:
   242	    """Completeness validity guard: fraction of expected answerer cells that did NOT
   243	    fail. Expected = number of ``(question-with-answers, retrieving-arm)`` cells.
   244	
   245	    ``n_errors`` is the retry-exhausted failure count (from the answerer). Below
   246	    ``floor`` the matrix is materially incomplete (a class endpoint is under-populated)
   247	    → ``run_valid=False`` (relaunch auto-resumes only the missing cells)."""
   248	    expected = sum(1 for r in records if r.get("has_answers") for _ in arms)
   249	    completeness = round(1.0 - n_errors / max(expected, 1), 4)
   250	    return {
   251	        "expected_calls": expected,
   252	        "n_errors": int(n_errors),
   253	        "completeness": completeness,
   254	        "floor": floor,
   255	        "run_valid": completeness >= floor,
   256	    }
