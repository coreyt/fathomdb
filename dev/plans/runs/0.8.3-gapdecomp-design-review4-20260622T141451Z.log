   132	        # ``max_retries`` retries. A non-retryable error (or an exhausted budget)
   133	        # propagates; run_baseline's _do then counts it + degrades the cell to None.
   134	        attempt = 0
   135	        while True:
   136	            try:
   137	                with self._open(req) as resp:
   138	                    body = json.loads(resp.read().decode("utf-8"))
