   219	class LLMAnswerer(BaseAnswerer):
   220	    """BYO/local answerer over an OpenAI-compatible ``/chat/completions`` endpoint.
   221	
   222	    Gated by ``R2_RUN=1`` plus ``R2_ANSWERER_MODEL`` and ``R2_ANSWERER_BASE_URL``
   223	    (e.g. a local llama.cpp/ollama OpenAI shim). Temperature 0 + fixed seed for
   224	    replay-determinism (design memo §4). FathomDB never calls this — it is the
   225	    answerer for *all three* systems equally.
   226	    """
   227	
   228	    def __init__(self) -> None:
   229	        self.base_url = os.environ.get("R2_ANSWERER_BASE_URL", "")
   230	        self.api_key = os.environ.get("R2_ANSWERER_API_KEY", "")
   231	        self.model_id = os.environ.get("R2_ANSWERER_MODEL", "<unset>")
   232	
   233	    @property
   234	    def available(self) -> bool:
   235	        return (
   236	            os.environ.get(_R2_RUN_ENV) == "1"
   237	            and bool(self.base_url)
   238	            and self.model_id != "<unset>"
   239	        )
   240	
   241	    def _complete(self, prompt: str, question: str, context: list[str]) -> Optional[str]:
   242	        if os.environ.get(_R2_RUN_ENV) != "1":
   243	            raise RuntimeError(f"{_R2_RUN_ENV} not set; set to 1 to run the full eval")
   244	        if not self.available:
   245	            raise RuntimeError(
   246	                "LLMAnswerer not configured: set R2_ANSWERER_BASE_URL + R2_ANSWERER_MODEL"
   247	            )
   248	        import urllib.request  # local import: stdlib only, keeps the import graph clean
   249	
   250	        payload = json.dumps(
   251	            {
   252	                "model": self.model_id,
   253	                "messages": [{"role": "user", "content": prompt}],
   254	                "temperature": 0,
   255	                "seed": 0,
   256	            }
   257	        ).encode("utf-8")
   258	        req = urllib.request.Request(
   259	            self.base_url.rstrip("/") + "/chat/completions",
   260	            data=payload,
   261	            headers={
   262	                "Content-Type": "application/json",
   263	                "Authorization": f"Bearer {self.api_key}",
   264	            },
   265	        )
   266	        with urllib.request.urlopen(req, timeout=120) as resp:  # noqa: S310 (BYO local endpoint)
   267	            body = json.loads(resp.read().decode("utf-8"))
   268	        return normalize_answer(body["choices"][0]["message"]["content"])
