    86	def paired_metric_deltas(
    87	    records: Sequence[Mapping[str, Any]],
    88	    *,
    89	    metric: str,
    90	    treatment: str,
    91	    comparator: str,
    92	    cls: str,
    93	) -> list[float]:
    94	    """Per-question paired ``treatment − comparator`` deltas for ``metric`` in ``cls``.
    95	
    96	    ``metric`` is ``"recall"`` or ``"acc"``. A question contributes a paired delta
    97	    ONLY when both arms carry a non-``None`` value for that metric on it — so a
    98	    missing/failed answerer cell (absent key) or an arm that did not run is excluded
    99	    from the paired sample (it cannot fabricate a 0 delta)."""
   100	    deltas: list[float] = []
   101	    for r in records:
   102	        if r.get("reporting_class") != cls:
   103	            continue
   104	        m = r.get(metric) or {}
   105	        tv = m.get(treatment)
   106	        cv = m.get(comparator)
   107	        if tv is not None and cv is not None:
   108	            deltas.append(float(tv) - float(cv))
   109	    return deltas
