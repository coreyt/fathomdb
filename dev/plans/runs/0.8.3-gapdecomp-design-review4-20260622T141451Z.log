   294	_CHUNK_SUFFIX_RE = re.compile(r"#c\d+$")
   295	
   296	
   297	def session_id_of(source_doc_id: str) -> str:
   298	    """G0 Phase-2 §E — canonicalize a (possibly chunked) source-doc id to its
   299	    bare session id by stripping a trailing ``#c<N>`` chunk suffix. Gold
   300	    ``answer_session_ids`` are bare session ids, but a chunked ingest writes
   301	    ``"<session>#c0"``, ``"<session>#c1"`` … as ``source_doc_id``; both the
   302	    ``cursor_to_doc`` build and ``doc_id_of`` route through this so a graph-arm
   303	    hit's ``source_id`` resolves to the same id space as gold. Idempotent
   304	    (no suffix → unchanged)."""
   305	    return _CHUNK_SUFFIX_RE.sub("", source_doc_id)
   306	
   307	
   308	def _make_doc_id_of(cursor_to_doc: dict[int, str]) -> Any:
   309	    """G0 Phase-2 §B — resolve a hit to its corpus doc id, preferring the hit's
   310	    carried ``source_id`` (the traversed edge's session, canonicalized) when
   311	    present — this is how a graph-arm entity hit resolves to a gold session —
   312	    else the write-order cursor map."""
   313	
   314	    def _doc_id_of(sh: Any) -> str:
   315	        sid = getattr(sh, "source_id", None)
   316	        if sid:
   317	            return session_id_of(str(sid))
   318	        return cursor_to_doc.get(int(sh.id), str(sh.id))
   319	
   320	    return _doc_id_of
   321	
