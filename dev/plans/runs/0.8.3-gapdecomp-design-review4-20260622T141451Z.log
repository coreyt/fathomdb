    72	class CostTrackingAnswerer(AirlockAnswerer):
    73	    """:class:`AirlockAnswerer` that accumulates token usage + call counts and
    74	    **retries transient HTTP 429 / 5xx with exponential backoff**.
    75	
    76	    The Slice-20 first priced pass was INVALIDATED by a 429 storm (``workers=10``
    77	    tripped the quota; every later call 429'd and degraded to an abstention,
    78	    deflating the ≥3-hop cell). Backoff lets a rate-limited cell recover instead of
    79	    being lost; a cell counts as failed only after ``max_retries`` are exhausted."""
    80	
    81	    def __init__(
    82	        self,
    83	        model_id: str,
    84	        *,
    85	        timeout_s: float = 120.0,
    86	        max_retries: int = 4,
    87	        backoff_base: float = 1.0,
    88	        max_backoff: float = 30.0,
    89	        sleep: Any = time.sleep,
    90	    ) -> None:
