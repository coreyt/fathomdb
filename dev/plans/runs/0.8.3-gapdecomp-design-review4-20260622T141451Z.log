    69	class _FlakyAnswerer(_FakeAnswerer):
    70	    """Raises on a designated set of (call-content) keys to simulate retry-exhausted
    71	    failures (failure ≠ abstention)."""
    72	
    73	    def __init__(self, script: dict[str, Optional[str]], fail_keys: set[str]) -> None:
    74	        super().__init__(script)
    75	        self.fail_keys = set(fail_keys)
    76	
    77	    def answer(self, question: str, context: list[str]) -> Optional[str]:
    78	        key = context[0] if context else ""
    79	        if key in self.fail_keys:
    80	            raise RuntimeError("simulated retry-exhausted 429")
    81	        return super().answer(question, context)
