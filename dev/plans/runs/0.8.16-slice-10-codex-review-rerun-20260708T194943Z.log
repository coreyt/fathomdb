	"cudnn_heuristic64_9.dll",
	"cudnn_ops64_9.dll",
	"cudnn_adv64_9.dll",
	}

	#[must_use]
	pub fn with_max_tuning_duration(mut self, ms: i32) -> Self {
		self.options.set("tunable_op_max_tuning_duration_ms", ms.to_string());
		self
	}
}

