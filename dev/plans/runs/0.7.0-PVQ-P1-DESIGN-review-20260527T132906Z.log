  2835	    connection: &mut Connection,
  2836	    outcomes: &[ProjectionOutcome],
  2837	) -> rusqlite::Result<()> {
  2838	    let tx = connection.transaction()?;
  2839	    for outcome in outcomes {
  2840	        match outcome {
  2841	            ProjectionOutcome::Success { cursor, kind, blob } => {
  2842	                if terminal_state_for_cursor(&tx, *cursor)?.is_some() {
  2843	                    continue;
  2844	                }
