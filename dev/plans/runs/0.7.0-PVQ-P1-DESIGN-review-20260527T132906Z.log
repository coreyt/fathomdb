  2846	                    "INSERT OR IGNORE INTO _fathomdb_vector_rows(rowid, kind, write_cursor) VALUES(?1, ?2, ?3)",
  2847	                    params![cursor, kind, cursor],
  2848	                )?;
  2849	                tx.execute(
  2850	                    "INSERT OR IGNORE INTO vector_default(rowid, embedding) VALUES(?1, ?2)",
  2851	                    params![cursor, blob],
  2852	                )?;
  2853	                record_projection_terminal(&tx, *cursor, "up_to_date")?;
  2854	            }
  2855	            ProjectionOutcome::Failure { cursor, failure_code } => {
  2856	                if terminal_state_for_cursor(&tx, *cursor)?.is_some() {
  2857	                    continue;
  2858	                }
  2859	                let existing: u64 = tx.query_row(
  2860	                    "SELECT COUNT(*) FROM operational_mutations
  2861	                     WHERE collection_name = 'projection_failures'
  2862	                       AND json_extract(payload_json, '$.write_cursor') = ?1",
  2863	                    [cursor],
  2864	                    |row| row.get(0),
  2865	                )?;
  2866	                if existing == 0 {
  2867	                    let payload = format!(
  2868	                        r#"{{"write_cursor":{cursor},"failure_code":"{failure_code}","recorded_at":0}}"#
  2869	                    );
  2870	                    tx.execute(
  2871	                        "INSERT INTO operational_mutations(
  2872	                            collection_name, record_key, op_kind, payload_json, schema_id, write_cursor
  2873	                         ) VALUES('projection_failures', ?1, 'append', ?2, NULL, ?3)",
  2874	                        params![cursor.to_string(), payload, cursor],
  2875	                    )?;
  2876	                }
  2877	                record_projection_terminal(&tx, *cursor, "failed")?;
  2878	            }
  2879	        }
  2880	    }
  2881	    advance_projection_cursor(&tx)?;
