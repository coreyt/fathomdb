   341	/// AC-013 deterministic seeder: N vector rows with varying embeddings.
   342	/// Returns elapsed seed time. Bodies double as both FTS5 documents and
   343	/// the input to the embedder, so the same fixture supports AC-019's
   344	/// FTS+vector mixed workload.
   345	fn seed_ac013_corpus(engine: &Engine, n: usize) -> Duration {
