    >/dev/null; then\n    fail \"moved-in-file fixture: linter must exit 0 (alpha re-appears in same file)\"\nfi\necho \"OK moved-in-file\"\n\necho \"test_removal_detect.sh: all cases pass\"\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":388,"cache_read_input_tokens":64139,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":388},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"17a0ef0a-e71e-4f47-89a1-81a3e1f65155","uuid":"6658f253-56b8-491d-92f9-7f8b14f25ce6"}
