   240	def test_resume_reuses_prior_cells_and_recalls_only_absent(tmp_path: Path) -> None:
   241	    queries, adapters, _ = _build_full_fixture()
   242	    out = tmp_path / "d0b.json"
   243	    ckpt = out.with_suffix(".checkpoint.json")
   244	
   245	    # Pass 1: a flaky answerer that FAILS every naive_rag cell -> those cells are
   246	    # MISSING (absent), counted as errors, never persisted as a scored abstention.
   247	    script = _build_full_fixture()[2].script
   248	    fail_keys = {b for b in script if b.startswith("body-nr-")}
   249	    flaky = _FlakyAnswerer(script, fail_keys=fail_keys)
