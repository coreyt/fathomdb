   323	class FathomDBAdapter:
   324	    """Wraps the FathomDB Python SDK. Retrieval only — the engine is local SQLite
   325	    and makes **zero** network calls (ADR §3.6). ``rerank_depth`` exercises the
   326	    R1 cross-encoder seam; ``use_graph_arm`` the R3 arm (default off).
   327	
   328	    ``doc_id_of`` maps an engine ``SearchHit`` back to its *corpus* doc id; the
   329	    runner supplies it from the write-order → doc-id index built at ingest time.
   330	    """
   331	
   332	    name = "fathomdb"
   333	
   334	    def __init__(
   335	        self,
   336	        engine: "Engine",
   337	        *,
   338	        doc_id_of: Optional[Any] = None,
   339	        rerank_depth: int = 0,
   340	        use_graph_arm: bool = False,
   341	        search_filter: Optional[Any] = None,
   342	    ) -> None:
   343	        self._engine = engine
   344	        self._doc_id_of = doc_id_of
   345	        self._rerank_depth = rerank_depth
   346	        self._use_graph_arm = use_graph_arm
   347	        # Optional SearchFilter applied to the TWO-ARM branches (e.g. kind="doc" to
   348	        # exclude entity nodes from doc-retrieval). Graph-arm seeding queries the FTS
   349	        # index directly and is NOT affected by this filter, so entities still seed.
   350	        self._search_filter = search_filter
   351	
   352	    def retrieve(self, question: str, k: int) -> list[Hit]:
   353	        result = self._engine.search(
   354	            question,
   355	            filter=self._search_filter,
   356	            rerank_depth=self._rerank_depth,
   357	            use_graph_arm=self._use_graph_arm,
   358	        )
   359	        hits: list[Hit] = []
   360	        for sh in result.results[:k]:
   361	            doc_id = str(self._doc_id_of(sh)) if self._doc_id_of is not None else str(sh.id)
   362	            hits.append(Hit(doc_id=doc_id, body=sh.body, score=float(sh.score)))
   363	        return hits
