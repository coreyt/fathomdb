   889	def run_r2_eval(
   890	    query_set: str | Path,
   891	    systems: Mapping[str, RetrievalAdapter],
   892	    answerer: BaseAnswerer,
   893	    corpus_hash: str,
   894	    *,
   895	    k: int = 10,
   896	    limit: Optional[int] = None,
   897	) -> dict[str, Any]:
   898	    """Convenience entry point. Validates the supplied ``corpus_hash`` (COR-2)
   899	    before constructing the harness, then runs the eval."""
   900	    if not corpus_hash.startswith(CORPUS_HASH_PREFIX):
   901	        raise ValueError(
   902	            f"corpus_hash {corpus_hash!r} does not start with {CORPUS_HASH_PREFIX!r} (COR-2)"
   903	        )
   904	    harness = R2Harness(gold_path=query_set, answerer=answerer)
   905	    return harness.run(systems, k=k, limit=limit)
