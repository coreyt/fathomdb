   184	def _build_full_fixture() -> tuple[list[GoldQuery], dict[str, _FakeAdapter], _FakeAnswerer]:
   185	    queries: list[GoldQuery] = []
   186	    hits: dict[str, dict[str, list[Hit]]] = {a: {} for a in ALL_ARMS}
   187	    script: dict[str, Optional[str]] = {}
   188	    for cls in MEMORY_CLASSES:
   189	        for j in range(4):
   190	            qid = f"{cls}-{j}"
   191	            gid = f"g-{qid}"
   192	            q = _gold(qid, cls, (gid,), (f"ans-{qid}",))
   193	            queries.append(q)
   194	            # fathomdb retrieves gold (recall 1) + a body that yields the right answer
   195	            hits["fathomdb"][q.question] = [Hit(doc_id=gid, body=f"body-fdb-{qid}", score=1.0)]
   196	            script[f"body-fdb-{qid}"] = f"ans-{qid}"  # correct
   197	            # mem0 retrieves a wrong doc (recall 0) + a body that yields a wrong answer
   198	            hits["mem0_oss"][q.question] = [Hit(doc_id=f"wrong-{qid}", body=f"body-mem0-{qid}", score=0.5)]
   199	            script[f"body-mem0-{qid}"] = "nope"
   200	            # graphiti retrieves gold (recall 1), correct answer
   201	            hits["graphiti_zep"][q.question] = [Hit(doc_id=gid, body=f"body-gz-{qid}", score=0.9)]
   202	            script[f"body-gz-{qid}"] = f"ans-{qid}"
   203	            # naive retrieves gold half the time
   204	            nid = gid if j % 2 == 0 else f"wrong-{qid}"
   205	            hits["naive_rag"][q.question] = [Hit(doc_id=nid, body=f"body-nr-{qid}", score=0.4)]
   206	            script[f"body-nr-{qid}"] = f"ans-{qid}" if j % 2 == 0 else "nope"
   207	    adapters = {a: _FakeAdapter(a, hits[a]) for a in ALL_ARMS}
   208	    return queries, adapters, _FakeAnswerer(script)
