   366	class NaiveRAGAdapter:
   367	    """Floor baseline: flat BM25 over the same documents, no memory graph / update
   368	    logic (ADR §3.3). Pure-Python (no extra dependency); deterministic given the
   369	    corpus."""
   370	
   371	    name = "naive_rag"
   372	
   373	    def __init__(self, documents: dict[str, str], *, k1: float = 1.5, b: float = 0.75) -> None:
   374	        self._k1 = k1
   375	        self._b = b
   376	        n_docs = max(len(documents), 1)
   377	        self._doc_len: dict[str, int] = {}
   378	        self._bodies: dict[str, str] = {}
   379	        # Inverted index: term -> [(doc_id, term_freq)]. Scoring touches only docs
   380	        # that contain a query term (standard BM25 structure) — identical scores
   381	        # to a dense per-doc scan, but O(matching postings) not O(corpus) per query.
   382	        self._postings: dict[str, list[tuple[str, int]]] = defaultdict(list)
   383	        df: dict[str, int] = defaultdict(int)
   384	        for doc_id, body in documents.items():
   385	            self._bodies[doc_id] = body
   386	            toks = _tokenize(body)
   387	            self._doc_len[doc_id] = len(toks)
   388	            counts: dict[str, int] = defaultdict(int)
   389	            for t in toks:
   390	                counts[t] += 1
   391	            for t, f in counts.items():
   392	                self._postings[t].append((doc_id, f))
   393	                df[t] += 1
   394	        self._avgdl = max(sum(self._doc_len.values()) / n_docs, 1e-9)
   395	        self._idf = {t: math.log(1 + (n_docs - n + 0.5) / (n + 0.5)) for t, n in df.items()}
   396	
   397	    def retrieve(self, question: str, k: int) -> list[Hit]:
   398	        q_terms = set(_tokenize(question))
   399	        scores: dict[str, float] = defaultdict(float)
   400	        for t in q_terms:
   401	            idf = self._idf.get(t)
   402	            if not idf:
   403	                continue
   404	            coeff = self._k1 + 1
   405	            for doc_id, f in self._postings.get(t, ()):
   406	                dl = self._doc_len[doc_id]
   407	                denom = f + self._k1 * (1 - self._b + self._b * dl / self._avgdl)
   408	                scores[doc_id] += idf * (f * coeff) / denom
   409	        ranked = sorted(scores.items(), key=lambda kv: kv[1], reverse=True)[:k]
   410	        return [Hit(doc_id=doc_id, body=self._bodies.get(doc_id, ""), score=score) for doc_id, score in ranked]
