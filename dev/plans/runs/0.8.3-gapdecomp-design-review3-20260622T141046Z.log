    85	
    86	def paired_metric_deltas(
    87	    records: Sequence[Mapping[str, Any]],
    88	    *,
    89	    metric: str,
    90	    treatment: str,
    91	    comparator: str,
    92	    cls: str,
    93	) -> list[float]:
    94	    """Per-question paired ``treatment − comparator`` deltas for ``metric`` in ``cls``.
    95	
    96	    ``metric`` is ``"recall"`` or ``"acc"``. A question contributes a paired delta
    97	    ONLY when both arms carry a non-``None`` value for that metric on it — so a
    98	    missing/failed answerer cell (absent key) or an arm that did not run is excluded
    99	    from the paired sample (it cannot fabricate a 0 delta)."""
   100	    deltas: list[float] = []
   101	    for r in records:
   102	        if r.get("reporting_class") != cls:
   103	            continue
   104	        m = r.get(metric) or {}
   105	        tv = m.get(treatment)
   106	        cv = m.get(comparator)
   107	        if tv is not None and cv is not None:
   108	            deltas.append(float(tv) - float(cv))
   109	    return deltas
   110	
   111	
   112	def class_delta(deltas: Sequence[float], *, n_boot: int = DEFAULT_N_BOOT, seed: int = 0) -> dict[str, Any]:
   113	    """``{point, ci_lo, ci_hi, mde, n}`` for a paired-delta sample.
   114	
   115	    ``point`` = mean; ``ci_lo/ci_hi`` = percentile paired bootstrap (reuses the m1
   116	    helpers, seed-deterministic); ``mde`` = normal-approx paired minimum detectable
   117	    effect ``(z.975+z.80)·sd/√n`` (the §5 power quantity the rule gates on). ``n`` =
   118	    sample size. n==0 → all-``None``; n==1 → degenerate point CI, mde ``None``."""
   119	    import numpy as np
   120	
   121	    n = len(deltas)
   122	    if n == 0:
   123	        return {"point": None, "ci_lo": None, "ci_hi": None, "mde": None, "n": 0}
   124	    arr = np.asarray(deltas, dtype=float)
   125	    point = float(arr.mean())
   126	    if n == 1:
   127	        return {"point": round(point, 6), "ci_lo": round(point, 6), "ci_hi": round(point, 6), "mde": None, "n": 1}
   128	    rng = np.random.default_rng(seed)
   129	    lo = _percentile_ci_low(arr, rng, n_boot=n_boot)
   130	    hi = _percentile_ci_high(arr, rng, n_boot=n_boot)
   131	    sd = float(arr.std(ddof=1))
   132	    mde = (_Z_975 + _Z_80) * sd / math.sqrt(n)
   133	    return {
   134	        "point": round(point, 6),
   135	        "ci_lo": round(lo, 6),
   136	        "ci_hi": round(hi, 6),
   137	        "mde": round(mde, 6),
   138	        "n": n,
   139	    }
   140	
   141	
   142	def per_class_delta_table(
   143	    records: Sequence[Mapping[str, Any]],
   144	    *,
   145	    metric: str,
   146	    comparators: Sequence[str] = COMPARATOR_ARMS,
   147	    classes: Sequence[str] = MEMORY_CLASSES,
   148	    treatment: str = TREATMENT_ARM,
   149	    n_boot: int = DEFAULT_N_BOOT,
   150	    seed: int = 0,
   151	) -> dict[str, dict[str, dict[str, Any]]]:
   152	    """``{comparator: {class: class_delta}}`` for one ``metric`` over every class."""
   153	    out: dict[str, dict[str, dict[str, Any]]] = {}
   154	    for comp in comparators:
   155	        out[comp] = {}
   156	        for cls in classes:
   157	            d = paired_metric_deltas(
   158	                records, metric=metric, treatment=treatment, comparator=comp, cls=cls
   159	            )
   160	            out[comp][cls] = class_delta(d, n_boot=n_boot, seed=seed)
   161	    return out
   162	
   163	
   164	def external_per_class_for_decide(
   165	    acc_delta_table: Mapping[str, Mapping[str, Mapping[str, Any]]],
   166	    *,
   167	    comparator: str = "mem0_oss",
   168	    classes: Sequence[str] = MEMORY_CLASSES,
   169	) -> dict[str, dict[str, float]]:
   170	    """Build the :func:`decide_083` input from the ACCURACY ``fathomdb − <comparator>``
   171	    deltas (the priced gate; design §4).
   172	
   173	    ``decide_083`` requires a finite ``{point, ci_lo, ci_hi, mde}`` + int ``n`` for
   174	    every :data:`MEMORY_CLASSES` entry. A class with no usable delta (n==0/1 → mde
   175	    ``None`` — e.g. the comparator arm did not run) cannot be fed; raise loudly so the
   176	    caller records a blocker rather than fabricate a verdict."""
   177	    table = acc_delta_table.get(comparator, {})
   178	    ext: dict[str, dict[str, float]] = {}
   179	    for cls in classes:
   180	        cd = table.get(cls)
   181	        if cd is None or cd.get("point") is None or cd.get("mde") is None:
   182	            n = cd.get("n") if cd else "missing"
   183	            raise ValueError(
   184	                f"cannot build decide_083 input: class {cls!r} has no usable "
   185	                f"{comparator!r} accuracy delta (n={n}) — record a blocker, do not "
   186	                "fabricate a verdict"
   187	            )
   188	        ext[cls] = {
   189	            "point": float(cd["point"]),
   190	            "ci_lo": float(cd["ci_lo"]),
   191	            "ci_hi": float(cd["ci_hi"]),
   192	            "mde": float(cd["mde"]),
   193	            "n": int(cd["n"]),
   194	        }
   195	    return ext
   196	
