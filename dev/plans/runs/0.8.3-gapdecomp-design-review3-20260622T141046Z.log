   251	            adapters=adapters, answerer=flaky, n_boot=200, checkpoint_every=2)
   252	    persisted = json.loads(ckpt.read_text())
   253	    rmap = resume_map(persisted)
   254	    # naive_rag cells absent (failed); fathomdb/mem0/graphiti present.
   255	    assert not any(arm == "naive_rag" for (_q, arm) in rmap)
   256	    assert any(arm == "fathomdb" for (_q, arm) in rmap)
   257	    n_reused_before = len(rmap)
   258	
   259	    # Pass 2 (restart): a healthy answerer with a call counter. Auto-resume must
   260	    # reuse every persisted cell and re-call ONLY the absent naive_rag cells.
   261	    healthy = _FakeAnswerer(script)
   262	    art2 = run_d0b(mode="full", reader="fake", output=out, queries=queries,
   263	                   adapters=adapters, answerer=healthy, n_boot=200, checkpoint_every=2)
   264	    # exactly the 16 naive_rag cells were (re)called this pass — zero re-spend on reused.
   265	    assert healthy.n_calls == 16
   266	    assert n_reused_before == 48  # 16 q x 3 healthy arms
   267	    # the run is now complete + valid; naive_rag accuracy delta now populated.
   268	    assert art2["run_valid"] is True
   269	    assert art2["accuracy_deltas"]["naive_rag"]["factoid"]["n"] == 4
