   658	def _parse_gold(raw: dict[str, Any]) -> list[GoldQuery]:
   659	    out: list[GoldQuery] = []
   660	    for q in raw.get("queries", []):
   661	        gold_class = str(q.get("query_class", "")).strip()
   662	        reporting = GOLD_CLASS_MAP.get(gold_class, gold_class or "unknown")
   663	        answers = tuple(str(a) for a in (q.get("answers") or []))
   664	        doc_ids: list[str] = []
   665	        for ev in q.get("required_evidence") or []:
   666	            did = ev.get("doc_id")
   667	            if did:
   668	                doc_ids.append(str(did))
   669	        if not doc_ids:
   670	            doc_ids = [str(d) for d in (q.get("expected_top_k_doc_ids") or [])]
   671	        out.append(
   672	            GoldQuery(
   673	                query_id=str(q.get("query_id", "")),
   674	                question=str(q.get("query", "")),
   675	                reporting_class=reporting,
   676	                answers=answers,
   677	                gold_doc_ids=tuple(doc_ids),
   678	            )
   679	        )
   680	    return out
