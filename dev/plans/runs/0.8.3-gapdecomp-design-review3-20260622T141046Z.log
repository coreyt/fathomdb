   937	def _format_lme_session(turns: list) -> str:
   938	    parts = []
   939	    for turn in turns:
   940	        if isinstance(turn, str):
   941	            try:
   942	                turn = json.loads(turn)
   943	            except (json.JSONDecodeError, ValueError):
   944	                parts.append(turn)
   945	                continue
   946	        role = str(turn.get("role", "unknown")).capitalize()
   947	        content = str(turn.get("content", "")).strip()
   948	        parts.append(f"[{role}]: {content}")
   949	    return "\n".join(parts)
