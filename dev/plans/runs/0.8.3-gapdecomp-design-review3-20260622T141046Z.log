   745	class R2Harness:
   746	    """Runs the identical-answerer eval over a set of retrieval adapters.
   747	
   748	    The COR-2 corpus-hash pin is asserted in ``__init__`` — *before* any number is
   749	    produced — so a wrong/unpinned corpus cannot yield a citable result."""
   750	
   751	    def __init__(self, gold_path: str | Path, answerer: BaseAnswerer) -> None:
   752	        path = Path(gold_path)
   753	        raw = json.loads(path.read_text(encoding="utf-8"))
   754	        corpus_hash = str(raw.get("corpus_hash", ""))
   755	        if not corpus_hash.startswith(CORPUS_HASH_PREFIX):
   756	            raise ValueError(
   757	                f"corpus_hash {corpus_hash!r} does not start with {CORPUS_HASH_PREFIX!r} "
   758	                "(COR-2): refusing to produce eval numbers on an unpinned corpus"
   759	            )
   760	        self.corpus_hash = corpus_hash
   761	        self.qrels_version = str(raw.get("qrels_version", ""))
   762	        self.queries = _parse_gold(raw)
   763	        self.answerer = answerer
   764	
   765	    @classmethod
   766	    def from_repin_gold(cls, gold_path: str | Path, answerer: BaseAnswerer) -> "R2Harness":
   767	        """Construct an R2Harness from a 0.8.3 D0a **re-pinned** gold file.
   768	
   769	        The re-pinned memory-class gold is LongMemEval-derived (design §3): its
   770	        ``corpus_hash`` is the LME corpus hash, **not** the COR-2 ``fe973fcd`` IR
   771	        corpus, so it deliberately bypasses the COR-2 ``__init__`` pin via
   772	        :meth:`from_queries` (the same path LME mode uses). The file must still
   773	        declare a non-empty ``corpus_hash`` and ``queries`` (validated here)."""
   774	        corpus_hash, qrels_version, queries = load_repin_gold(gold_path)
   775	        return cls.from_queries(
   776	            queries,
   777	            answerer,
   778	            corpus_hash=corpus_hash,
   779	            qrels_version=qrels_version,
   780	        )
   781	
   782	    @classmethod
   783	    def from_queries(
   784	        cls,
   785	        queries: list[GoldQuery],
   786	        answerer: BaseAnswerer,
   787	        *,
   788	        corpus_hash: str = "lme-eval-v1",
   789	        qrels_version: str = "lme-loaded-v1",
   790	    ) -> "R2Harness":
   791	        """Construct an R2Harness from in-memory queries (no gold file, no COR-2 pin).
   792	
   793	        Used for LME mode where the corpus is different from the frozen FathomDB corpus.
   794	        """
   795	        obj = object.__new__(cls)
   796	        obj.corpus_hash = corpus_hash
   797	        obj.qrels_version = qrels_version
   798	        obj.queries = queries
   799	        obj.answerer = answerer
   800	        return obj
   801	
   802	    def run(
   803	        self,
   804	        systems: Mapping[str, RetrievalAdapter],
   805	        *,
   806	        k: int = 10,
   807	        limit: Optional[int] = None,
   808	    ) -> dict[str, Any]:
   809	        queries = self.queries[:limit] if limit is not None else self.queries
   810	        answerer_available = self.answerer.available
   811	        scorer = PerClassScorer()
   812	
   813	        report_classes = sorted(scorer.classes | {q.reporting_class for q in queries})
   814	
   815	        # accumulators[system][class] -> {"recall": [...], "acc": [...], "abst": [...]}
   816	        acc: dict[str, dict[str, dict[str, list[float]]]] = {
   817	            sys_name: {cls: {"recall": [], "acc": [], "abst": []} for cls in report_classes}
   818	            for sys_name in systems
   819	        }
   820	        n_per_class: dict[str, int] = {cls: 0 for cls in report_classes}
   821	
   822	        for q in queries:
   823	            n_per_class[q.reporting_class] += 1
   824	            for sys_name, adapter in systems.items():
   825	                hits = adapter.retrieve(q.question, k)
   826	                bucket = acc[sys_name][q.reporting_class]
   827	                if q.gold_doc_ids:
   828	                    retrieved = {h.doc_id for h in hits}
   829	                    bucket["recall"].append(
   830	                        1.0 if all(g in retrieved for g in q.gold_doc_ids) else 0.0
   831	                    )
   832	                if answerer_available:
   833	                    answer = self.answerer.answer(q.question, [h.body for h in hits if h.body])
   834	                    bucket["abst"].append(1.0 if answer is None else 0.0)
   835	                    if q.answers:  # only score accuracy when answer strings exist
   836	                        bucket["acc"].append(scorer.score_answer(list(q.answers), answer))
   837	
   838	        results: dict[str, dict[str, dict[str, Optional[float]]]] = {}
   839	        for sys_name in systems:
   840	            results[sys_name] = {}
   841	            for cls in report_classes:
   842	                b = acc[sys_name][cls]
   843	                results[sys_name][cls] = {
   844	                    "recall_at_k": _mean(b["recall"]),
   845	                    "answerer_accuracy": _mean(b["acc"]) if answerer_available else None,
   846	                    "abstention_rate": _mean(b["abst"]) if answerer_available else None,
   847	                }
   848	
   849	        deltas = self._delta_table(results, report_classes)
   850	
   851	        return {
   852	            "corpus_hash": self.corpus_hash,
   853	            "qrels_version": self.qrels_version,
   854	            "answerer_model": self.answerer.model_id,
   855	            "answerer_available": answerer_available,
   856	            "k": k,
   857	            "n_queries_per_class": {cls: n_per_class.get(cls, 0) for cls in report_classes},
   858	            "r2_results": results,
   859	            "r2_per_class_deltas": deltas,
   860	        }
   861	
   862	    @staticmethod
   863	    def _delta_table(
   864	        results: dict[str, dict[str, dict[str, Optional[float]]]],
   865	        report_classes: list[str],
   866	    ) -> dict[str, dict[str, Optional[float]]]:
   867	        fdb = results.get("fathomdb")
   868	        mem0 = results.get("mem0_oss")
   869	        naive = results.get("naive_rag")
   870	        table: dict[str, dict[str, Optional[float]]] = {}
   871	        for cls in report_classes:
   872	            fa = fdb[cls]["answerer_accuracy"] if fdb else None
   873	            fr = fdb[cls]["recall_at_k"] if fdb else None
   874	            ma = mem0[cls]["answerer_accuracy"] if mem0 else None
   875	            mr = mem0[cls]["recall_at_k"] if mem0 else None
   876	            na = naive[cls]["answerer_accuracy"] if naive else None
   877	            nr = naive[cls]["recall_at_k"] if naive else None
   878	            table[cls] = {
   879	                # primary delta = end-to-end answerer accuracy (null when no answerer)
   880	                "fathomdb_minus_mem0": _delta(fa, ma),
   881	                "fathomdb_minus_naive_rag": _delta(fa, na),
   882	                # retrieval-only deltas (always available when both systems ran)
   883	                "fathomdb_minus_mem0_recall_at_k": _delta(fr, mr),
   884	                "fathomdb_minus_naive_rag_recall_at_k": _delta(fr, nr),
   885	            }
   886	        return table
