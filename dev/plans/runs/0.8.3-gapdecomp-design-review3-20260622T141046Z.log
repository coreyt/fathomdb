   275	# --------------------------------------------------------------------------- #
   276	# The resilient run loop.
   277	# --------------------------------------------------------------------------- #
   278	
   279	
   280	def _select_subset(queries: Sequence[GoldQuery], *, per_class: int, classes: Sequence[str]) -> list[GoldQuery]:
   281	    """Stable per-class subset (cheap-validate / pilot): the first ``per_class``
   282	    queries of each class, in gold order — spans all classes, deterministic."""
   283	    out: list[GoldQuery] = []
   284	    for cls in classes:
   285	        out += [q for q in queries if q.reporting_class == cls][:per_class]
   286	    return out
   287	
   288	
   289	def fit_context(bodies: Sequence[str], budget_chars: Optional[int]) -> list[str]:
   290	    """Window-fit the answerer context to a total ``budget_chars`` cap
   291	    ([[priced-runs-need-resilience-before-spend]] — window-fit/chunk + the priced-cost
   292	    lever). Bodies are added in retrieval-rank order until the budget is reached; the
   293	    body that crosses it is truncated to the remaining budget (≥1 doc always kept).
   294	    Applied IDENTICALLY across every arm, so the R2 same-context-budget invariant
   295	    holds (any delta stays retrieval, not a per-arm context advantage). ``None`` /
   296	    non-positive budget = no truncation."""
   297	    if not budget_chars or budget_chars <= 0:
   298	        return list(bodies)
   299	    out: list[str] = []
   300	    used = 0
   301	    for b in bodies:
   302	        if used >= budget_chars:
   303	            break
   304	        remaining = budget_chars - used
   305	        if len(b) <= remaining:
   306	            out.append(b)
   307	            used += len(b)
   308	        else:
   309	            out.append(b[:remaining])
   310	            used = budget_chars
   311	            break
   312	    if not out and bodies:  # always keep at least the top doc (truncated)
   313	        out = [bodies[0][:budget_chars]]
   314	    return out
   315	
