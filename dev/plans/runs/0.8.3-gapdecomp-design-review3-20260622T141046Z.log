   289	class _CostFlakyAnswerer(BaseAnswerer):
   290	    """Mirrors the live ``CostTrackingAnswerer`` ledger seam: exposes ``usd()`` and a
   291	    ``cost_block()`` whose OWN ``n_errors`` stays 0 (the answerer never sees the
   292	    runner's retry-exhausted cells), while ``.answer()`` always raises. This is the
   293	    [P3] inconsistency: the artifact ledger reported ``cost.n_errors == 0`` even though
   294	    ``answer_completeness.n_errors`` counted real failures."""
   295	
   296	    model_id = "cost-flaky-v1"
   297	
   298	    def __init__(self) -> None:
   299	        self.n_calls = 0
   300	
   301	    @property
   302	    def available(self) -> bool:
   303	        return True
   304	
   305	    def answer(self, question: str, context: list[str]) -> Optional[str]:
   306	        self.n_calls += 1
   307	        raise RuntimeError("simulated retry-exhausted 429")
   308	
   309	    def usd(self) -> float:
   310	        return 0.0
   311	
   312	    def cost_block(self) -> dict[str, object]:
   313	        # the answerer's own counter never learns of the runner's retry-exhaustion
   314	        return {"model": self.model_id, "n_calls": self.n_calls, "n_errors": 0, "usd": 0.0}
