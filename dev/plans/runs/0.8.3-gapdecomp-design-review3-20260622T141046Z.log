   500	# Live document / adapter stand-up (CLI only — not exercised by the unit tests).
   501	# --------------------------------------------------------------------------- #
   502	
   503	
   504	def build_documents_from_lme(
   505	    queries: Sequence[GoldQuery],
   506	    *,
   507	    dataset: str = "xiaowu0162/longmemeval-cleaned",
   508	    split: str = "oracle",
   509	    distractor_cap: int = 0,
   510	) -> dict[str, str]:
   511	    """Load LME sessions and restrict to the gold-relevant sessions of ``queries``
   512	    (footprint + Mem0 per-``add()`` cost), optionally padded with up to
   513	    ``distractor_cap`` extra sessions for retrieval realism. CLI-only."""
   514	    from eval.r2_parity_eval import load_longmemeval, session_id_of
   515	
   516	    documents, _q = load_longmemeval(dataset, split)
   517	    gold_sessions = {session_id_of(g) for q in queries for g in q.gold_doc_ids}
   518	    out: dict[str, str] = {sid: documents[sid] for sid in gold_sessions if sid in documents}
   519	    if distractor_cap > 0:
   520	        for sid in documents:
   521	            if sid in out:
   522	                continue
   523	            out[sid] = documents[sid]
   524	            if len(out) >= len(gold_sessions) + distractor_cap:
   525	                break
   526	    return out
   527	
   528	
   529	def build_live_adapters(
   530	    documents: dict[str, str],
   531	    *,
   532	    want_fathomdb: bool = True,
   533	    want_mem0: bool = True,
   534	    want_graphiti: bool = True,
   535	    db_path: str = "/tmp/d0b-fathomdb.sqlite",
   536	    corpus_hash: str | None = None,
   537	    mem0_persist: bool = False,
   538	) -> tuple[dict[str, Any], list[dict[str, str]]]:
   539	    """Best-effort live adapter stand-up. Returns ``(adapters, blockers)``; a backend
   540	    that cannot stand up is a recorded blocker, never a crash (Graphiti especially —
   541	    2nd comparator, design §3). naive_rag is always available (pure-Python BM25).
   542	
   543	    ``mem0_persist`` (Slice 10 / Phase-B): when True AND a ``corpus_hash`` is given,
   544	    the Mem0 arm is built via :meth:`Mem0OSSAdapter.try_build_persistent` — a
   545	    corpus-keyed on-disk store + a doc-id resume sidecar — so the expensive
   546	    full-corpus ingest happens ONCE and is reused/continued across runs instead of
   547	    re-ingested per run. Default (False) keeps the per-run-isolated stand-up."""
   548	    from eval.r2_parity_eval import NaiveRAGAdapter
   549	
   550	    adapters: dict[str, Any] = {"naive_rag": NaiveRAGAdapter(documents)}
   551	    blockers: list[dict[str, str]] = []
   552	
   553	    if want_fathomdb:
   554	        from eval.r2_parity_eval import _build_fathomdb
   555	
   556	        fdb, blk = _build_fathomdb(documents, Path(db_path))
   557	        if fdb is not None:
   558	            adapters["fathomdb"] = fdb
   559	        if blk is not None:
   560	            blockers.append(blk)
   561	
   562	    if want_mem0:
   563	        from eval.r2_parity_eval import Mem0OSSAdapter
   564	
   565	        if mem0_persist and corpus_hash:
   566	            mem0 = Mem0OSSAdapter.try_build_persistent(corpus_hash)
   567	        else:
   568	            mem0 = Mem0OSSAdapter.try_build()
   569	        if mem0 is not None and mem0.available:
   570	            try:
   571	                mem0.ingest(documents)
   572	                adapters["mem0_oss"] = mem0
   573	            except Exception as exc:  # noqa: BLE001
   574	                blockers.append({"id": "mem0-ingest-failed", "description": f"mem0.ingest failed: {exc}"})
   575	        else:
   576	            blockers.append(
   577	                {
   578	                    "id": "mem0-oss-unavailable",
   579	                    "description": "mem0ai/backend not importable; install mem0ai+chromadb+sentence-transformers into the ISOLATED env",
   580	                }
   581	            )
   582	
   583	    if want_graphiti:
   584	        try:
   585	            from eval.graphiti_local import build_graphiti_adapter  # type: ignore[import-not-found]
   586	
   587	            g = build_graphiti_adapter(documents)
   588	            if g is not None:
   589	                adapters["graphiti_zep"] = g
   590	            else:
   591	                blockers.append({"id": "graphiti-zep-unavailable", "description": "graphiti adapter returned None"})
   592	        except Exception as exc:  # noqa: BLE001 — Graphiti is the 2nd comparator (not a hard dep)
   593	            blockers.append(
   594	                {
   595	                    "id": "graphiti-zep-unavailable",
   596	                    "description": f"Graphiti/Zep local stand-up not available ({exc}); running the gap with the arms present",
   597	                }
   598	            )
   599	
   600	    return adapters, blockers
   601	
   602	
   603	def main(argv: Optional[list[str]] = None) -> int:  # pragma: no cover - CLI
   604	    import json
   605	
   606	    from eval.m1_baseline_run import CostTrackingAnswerer
   607	
   608	    ap = argparse.ArgumentParser(description="0.8.3 D0b parity runner (cheap-validate / pilot / full)")
   609	    ap.add_argument("--mode", choices=["cheap", "pilot", "full"], required=True)
   610	    ap.add_argument("--reader", default=None)
   611	    ap.add_argument("--gold", default="dev/plans/runs/0.8.3-d0a-memory-gold.json")
   612	    ap.add_argument("--output", required=True)
   613	    ap.add_argument("--k", type=int, default=10)
   614	    ap.add_argument("--context-char-budget", type=int, default=None,
   615	                    help="window-fit cap on total answerer context chars (priced-cost lever; "
   616	                    "applied identically across arms)")
   617	    ap.add_argument("--per-class", type=int, default=None, help="cheap/pilot per-class subset size")
   618	    ap.add_argument("--distractor-cap", type=int, default=0)
   619	    ap.add_argument("--max-usd", type=float, default=1.0)
   620	    ap.add_argument("--checkpoint", default=None)
   621	    ap.add_argument("--checkpoint-every", type=int, default=10)
   622	    ap.add_argument("--resume", default=None)
   623	    ap.add_argument("--no-fathomdb", action="store_true")
   624	    ap.add_argument("--no-mem0", action="store_true")
   625	    ap.add_argument("--no-graphiti", action="store_true")
   626	    # Slice 10 / Phase-B: persistent + resumable corpus-keyed Mem0 ingest. Defaults
   627	    # ON for --mode full (the long, expensive run that must ingest ONCE and be
   628	    # reusable across S10/S20/S30) and OFF for cheap/pilot; --mem0-persist /
   629	    # --no-mem0-persist override either way.
   630	    ap.add_argument("--mem0-persist", dest="mem0_persist", action="store_true", default=None,
   631	                    help="reuse a corpus-keyed Mem0 store + doc-id resume sidecar "
   632	                    "(ingest once; default ON for --mode full)")
   633	    ap.add_argument("--no-mem0-persist", dest="mem0_persist", action="store_false",
   634	                    help="force per-run-isolated Mem0 ingest (disable persistence)")
   635	    ap.add_argument("--blockers-out", default=None)
   636	    args = ap.parse_args(argv)
   637	
   638	    reader = args.reader or (CHEAP_READER_DEFAULT if args.mode == "cheap" else STRONG_READER_DEFAULT)
   639	    corpus_hash, _qv, queries = load_repin_gold(Path(args.gold))
   640	    if args.mode in ("cheap", "pilot") and args.per_class:
   641	        queries = _select_subset(queries, per_class=args.per_class, classes=MEMORY_CLASSES)
   642	
   643	    mem0_persist = args.mem0_persist if args.mem0_persist is not None else (args.mode == "full")
   644	    documents = build_documents_from_lme(queries, distractor_cap=args.distractor_cap)
   645	    print(
   646	        f"[D0b][CLI] {len(queries)} queries, {len(documents)} sessions in corpus | "
   647	        f"corpus_hash={corpus_hash[:12]} mem0_persist={mem0_persist}",
   648	        flush=True,
   649	    )
   650	    adapters, blockers = build_live_adapters(
   651	        documents,
   652	        want_fathomdb=not args.no_fathomdb,
   653	        want_mem0=not args.no_mem0,
   654	        want_graphiti=not args.no_graphiti,
   655	        corpus_hash=corpus_hash,
   656	        mem0_persist=mem0_persist,
   657	    )
   658	    print(f"[D0b][CLI] adapters: {sorted(adapters)} | blockers: {[b['id'] for b in blockers]}", flush=True)
   659	    answerer = CostTrackingAnswerer(reader, timeout_s=240.0)
   660	    if not answerer.available:
   661	        raise SystemExit(f"[D0b][STOP] answerer {reader!r} unavailable — do not fake answers")
   662	
   663	    art = run_d0b(
   664	        mode=args.mode,
   665	        reader=reader,
   666	        output=Path(args.output),
   667	        queries=queries,
   668	        adapters=adapters,
   669	        answerer=answerer,
   670	        k=args.k,
   671	        checkpoint_path=Path(args.checkpoint) if args.checkpoint else None,
   672	        checkpoint_every=args.checkpoint_every,
   673	        resume=Path(args.resume) if args.resume else None,
   674	        max_usd=args.max_usd,
   675	        context_char_budget=args.context_char_budget,
   676	        on_progress=lambda i, n, usd: print(f"[D0b][{args.mode}] {i}/{n} ${usd:.4f}", flush=True)
   677	        if (i == 1 or i % 5 == 0 or i == n)
   678	        else None,
   679	    )
   680	    art["blockers_encountered"] = blockers
   681	    Path(args.output).write_text(json.dumps(art, indent=2), encoding="utf-8")
   682	    if args.blockers_out:
   683	        Path(args.blockers_out).write_text(json.dumps(blockers, indent=2), encoding="utf-8")
   684	    return 0
   685	
   686	
   687	if __name__ == "__main__":  # pragma: no cover
   688	    raise SystemExit(main())

