    73	#: Default paired-bootstrap resample count for the CI (deterministic given seed).
    74	DEFAULT_N_BOOT = 2000
    75	
    76	#: Normal-approx paired MDE z-multipliers: two-sided α=0.05 + 80% power.
    77	_Z_975 = 1.959963984540054
    78	_Z_80 = 0.8416212335729143
