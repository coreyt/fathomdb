   632	class PerClassScorer:
   633	    """Scores ``(ground_truth, system_answer)`` with abstention, stratified by
   634	    class. Abstention against a positive query is a miss (0.0); answering a
   635	    negative query is a false positive (0.0). Correct abstention on a negative
   636	    query scores 1.0."""
   637	
   638	    def __init__(self, extra_classes: tuple[str, ...] = ("exploratory", "negative")) -> None:
   639	        self.classes: set[str] = set(R2_CLASSES) | set(extra_classes)
   640	
   641	    def score_answer(
   642	        self, ground_truth: list[str] | tuple[str, ...] | None, system_answer: Optional[str]
   643	    ) -> float:
   644	        gt = list(ground_truth or [])
   645	        if gt:  # an answer exists
   646	            if system_answer is None:
   647	                return 0.0  # abstention miss — counted, never skipped
   648	            return 1.0 if _match(gt, system_answer) else 0.0
   649	        # negative class: no answer exists
   650	        return 0.0 if system_answer is not None else 1.0
   651	
