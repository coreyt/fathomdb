{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018HaqQAoetqsPMsgNbAEqka","type":"tool_result","content":"100\t  # because the platform-label convention lives in the napi-rs CLI, not in\n101\t  # us. Binary lands flat at src/ts/fathomdb.<label>.node (NO prebuilds/\n102\t  # subdir; that was the pre-0.6.0 layout).\n103\t  build-napi:\n104\t    needs: verify-release\n105\t    strategy:\n106\t      fail-fast: false\n107\t      matrix:\n108\t        include:\n109\t          - runner: ubuntu-latest\n110\t            target: x86_64-unknown-linux-gnu\n111\t            label: linux-x64-gnu\n112\t          - runner: macos-latest\n113\t            target: x86_64-apple-darwin\n114\t            label: darwin-x64\n115\t          - runner: macos-latest\n116\t            target: aarch64-apple-darwin\n117\t            label: darwin-arm64\n118\t          - runner: windows-latest\n119\t            target: x86_64-pc-windows-msvc\n120\t            label: win32-x64\n121\t    runs-on: ${{ matrix.runner }}\n122\t    steps:\n123\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n124\t      - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0\n125\t        with:\n126\t          node-version: \"22\"\n127\t      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n128\t        with:\n129\t          toolchain: stable\n130\t          targets: ${{ matrix.target }}\n131\t      - uses: Swatinem/rust-cache@c19371144df3bb44fab255c43d04cbc2ab54d1c4 # v2.9.1\n132\t      - name: Install ts deps\n133\t        working-directory: src/ts\n134\t        run: npm ci\n135\t      - name: Build napi binding\n136\t        working-directory: src/ts\n137\t        env:\n138\t          CARGO_BUILD_TARGET: ${{ matrix.target }}\n139\t        run: npm run build:native\n140\t      - uses: actions/upload-artifact@bbbca2ddaa5d8feaa63e36b76fdaad77386f024f # v7.0.0\n141\t        with:\n142\t          name: napi-${{ matrix.label }}\n143\t          path: src/ts/fathomdb.${{ matrix.label }}.node\n144\t\n145\t  # Pre-publish packaging verification for Rust crates:\n146\t  #   1. cargo build --release --workspace — compile check of every crate\n147\t  #      we are about to publish.\n148\t  #   2. cargo package --no-verify for the three leaf crates with no\n149\t  #      in-workspace dependencies (fathomdb-embedder-api, fathomdb-schema,\n150\t  #      fathomdb-query). Validates manifest/readme/license metadata\n151\t  #      without invoking the registry.\n152\t  #\n153\t  # The dependent crates (fathomdb-engine, fathomdb-embedder, fathomdb,\n154\t  # fathomdb-cli) are NOT packaged here: cargo package rewrites path deps\n155\t  # to versioned deps and then does a registry resolve on the rewritten\n156\t  # manifest. For a fresh release the leaf crates are not published yet,\n157\t  # so the resolve cannot find e.g. fathomdb-schema@0.6.0 and fails.\n158\t  # Manifest correctness of the dependent crates is enforced at actual\n159\t  # publish time inside `cargo publish`, which we do not want to duplicate\n160\t  # at CI cost.\n161\t  build-rust:\n162\t    runs-on: ubuntu-latest\n163\t    needs: verify-release\n164\t    steps:\n165\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n166\t      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n167\t        with:\n168\t          toolchain: stable\n169\t      - uses: Swatinem/rust-cache@c19371144df3bb44fab255c43d04cbc2ab54d1c4 # v2.9.1\n170\t      - name: Verify workspace builds in release mode\n171\t        run: cargo build --release --workspace\n172\t      - name: Package fathomdb-embedder-api (leaf, Axis E)\n173\t        run: cargo package --no-verify -p fathomdb-embedder-api\n174\t      - name: Package fathomdb-schema (leaf, no in-workspace deps)\n175\t        run: cargo package --no-verify -p fathomdb-schema\n176\t      - name: Package fathomdb-query (leaf, no in-workspace deps)\n177\t        run: cargo package --no-verify -p fathomdb-query\n178\t\n179\t  # Cross-ecosystem gate: every build must succeed before ANY publish runs.\n180\t  # Without this, a partial release (e.g. crates.io 0.6.0 published but\n181\t  # pypi 0.6.0 blocked on a build failure) leaves downstream versioning\n182\t  # unrecoverable — 0.6.1 would then have mismatched ecosystem coverage.\n183\t  all-builds-passed:\n184\t    runs-on: ubuntu-latest\n185\t    needs:\n186\t      - verify-release\n187\t      - build-python\n188\t      - build-napi\n189\t      - build-rust\n190\t    steps:\n191\t      - run: echo \"all release build gates passed\"\n192\t\n193\t  # --- Tiered cargo publish (T1..T7) -----------------------------------------\n194\t  # Each tier publishes one crate, then sleeps 60s to let the crates.io\n195\t  # index propagate before the next tier resolves the dep against it.\n196\t  # --locked is omitted: the lock file is generated against local path\n197\t  # dependencies, which do not match the crates.io index state during\n198\t  # tiered publishing.\n199\t  # Order rationale: see dev/design/release.md § Tiered publish order.\n200\t\n201\t  publish-rust-t1-embedder-api:\n202\t    runs-on: ubuntu-latest\n203\t    needs: all-builds-passed\n204\t    steps:\n205\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n206\t      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n207\t        with:\n208\t          toolchain: stable\n209\t      - name: cargo publish fathomdb-embedder-api\n210\t        run: |\n211\t          if [ \"${DRY_RUN}\" = \"true\" ]; then\n212\t            cargo publish --dry-run -p fathomdb-embedder-api\n213\t          else\n214\t            cargo publish -p fathomdb-embedder-api --token \"${CARGO_REGISTRY_TOKEN}\"\n215\t          fi\n216\t        env:\n217\t          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n218\t      - name: Wait for crates.io index propagation\n219\t        if: ${{ inputs.dry_run != true }}\n220\t        run: sleep 60\n221\t\n222\t  publish-rust-t2-schema:\n223\t    runs-on: ubuntu-latest\n224\t    needs: publish-rust-t1-embedder-api\n225\t    steps:\n226\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n227\t      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n228\t        with:\n229\t          toolchain: stable\n230\t      - name: cargo publish fathomdb-schema\n231\t        run: |\n232\t          if [ \"${DRY_RUN}\" = \"true\" ]; then\n233\t            cargo publish --dry-run -p fathomdb-schema\n234\t          else\n235\t            cargo publish -p fathomdb-schema --token \"${CARGO_REGISTRY_TOKEN}\"\n236\t          fi\n237\t        env:\n238\t          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n239\t      - name: Wait for crates.io index propagation\n240\t        if: ${{ inputs.dry_run != true }}\n241\t        run: sleep 60\n242\t\n243\t  publish-rust-t3-query:\n244\t    runs-on: ubuntu-latest\n245\t    needs: publish-rust-t2-schema\n246\t    steps:\n247\t      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n248\t      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n249\t        with:"}]},"parent_tool_use_id":null,"session_id":"0166efe2-5172-4c6f-950f-26b3875cd45a","uuid":"26eefb06-08e3-4853-b91b-8d9d902af056","timestamp":"2026-05-17T19:57:48.566Z","tool_use_result":{"type":"text","file":{"filePath":".github/workflows/release.yml","content":"  # because the platform-label convention lives in the napi-rs CLI, not in\n  # us. Binary lands flat at src/ts/fathomdb.<label>.node (NO prebuilds/\n  # subdir; that was the pre-0.6.0 layout).\n  build-napi:\n    needs: verify-release\n    strategy:\n      fail-fast: false\n      matrix:\n        include:\n          - runner: ubuntu-latest\n            target: x86_64-unknown-linux-gnu\n            label: linux-x64-gnu\n          - runner: macos-latest\n            target: x86_64-apple-darwin\n            label: darwin-x64\n          - runner: macos-latest\n            target: aarch64-apple-darwin\n            label: darwin-arm64\n          - runner: windows-latest\n            target: x86_64-pc-windows-msvc\n            label: win32-x64\n    runs-on: ${{ matrix.runner }}\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0\n        with:\n          node-version: \"22\"\n      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n        with:\n          toolchain: stable\n          targets: ${{ matrix.target }}\n      - uses: Swatinem/rust-cache@c19371144df3bb44fab255c43d04cbc2ab54d1c4 # v2.9.1\n      - name: Install ts deps\n        working-directory: src/ts\n        run: npm ci\n      - name: Build napi binding\n        working-directory: src/ts\n        env:\n          CARGO_BUILD_TARGET: ${{ matrix.target }}\n        run: npm run build:native\n      - uses: actions/upload-artifact@bbbca2ddaa5d8feaa63e36b76fdaad77386f024f # v7.0.0\n        with:\n          name: napi-${{ matrix.label }}\n          path: src/ts/fathomdb.${{ matrix.label }}.node\n\n  # Pre-publish packaging verification for Rust crates:\n  #   1. cargo build --release --workspace — compile check of every crate\n  #      we are about to publish.\n  #   2. cargo package --no-verify for the three leaf crates with no\n  #      in-workspace dependencies (fathomdb-embedder-api, fathomdb-schema,\n  #      fathomdb-query). Validates manifest/readme/license metadata\n  #      without invoking the registry.\n  #\n  # The dependent crates (fathomdb-engine, fathomdb-embedder, fathomdb,\n  # fathomdb-cli) are NOT packaged here: cargo package rewrites path deps\n  # to versioned deps and then does a registry resolve on the rewritten\n  # manifest. For a fresh release the leaf crates are not published yet,\n  # so the resolve cannot find e.g. fathomdb-schema@0.6.0 and fails.\n  # Manifest correctness of the dependent crates is enforced at actual\n  # publish time inside `cargo publish`, which we do not want to duplicate\n  # at CI cost.\n  build-rust:\n    runs-on: ubuntu-latest\n    needs: verify-release\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n        with:\n          toolchain: stable\n      - uses: Swatinem/rust-cache@c19371144df3bb44fab255c43d04cbc2ab54d1c4 # v2.9.1\n      - name: Verify workspace builds in release mode\n        run: cargo build --release --workspace\n      - name: Package fathomdb-embedder-api (leaf, Axis E)\n        run: cargo package --no-verify -p fathomdb-embedder-api\n      - name: Package fathomdb-schema (leaf, no in-workspace deps)\n        run: cargo package --no-verify -p fathomdb-schema\n      - name: Package fathomdb-query (leaf, no in-workspace deps)\n        run: cargo package --no-verify -p fathomdb-query\n\n  # Cross-ecosystem gate: every build must succeed before ANY publish runs.\n  # Without this, a partial release (e.g. crates.io 0.6.0 published but\n  # pypi 0.6.0 blocked on a build failure) leaves downstream versioning\n  # unrecoverable — 0.6.1 would then have mismatched ecosystem coverage.\n  all-builds-passed:\n    runs-on: ubuntu-latest\n    needs:\n      - verify-release\n      - build-python\n      - build-napi\n      - build-rust\n    steps:\n      - run: echo \"all release build gates passed\"\n\n  # --- Tiered cargo publish (T1..T7) -----------------------------------------\n  # Each tier publishes one crate, then sleeps 60s to let the crates.io\n  # index propagate before the next tier resolves the dep against it.\n  # --locked is omitted: the lock file is generated against local path\n  # dependencies, which do not match the crates.io index state during\n  # tiered publishing.\n  # Order rationale: see dev/design/release.md § Tiered publish order.\n\n  publish-rust-t1-embedder-api:\n    runs-on: ubuntu-latest\n    needs: all-builds-passed\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n        with:\n          toolchain: stable\n      - name: cargo publish fathomdb-embedder-api\n        run: |\n          if [ \"${DRY_RUN}\" = \"true\" ]; then\n            cargo publish --dry-run -p fathomdb-embedder-api\n          else\n            cargo publish -p fathomdb-embedder-api --token \"${CARGO_REGISTRY_TOKEN}\"\n          fi\n        env:\n          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n      - name: Wait for crates.io index propagation\n        if: ${{ inputs.dry_run != true }}\n        run: sleep 60\n\n  publish-rust-t2-schema:\n    runs-on: ubuntu-latest\n    needs: publish-rust-t1-embedder-api\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n        with:\n          toolchain: stable\n      - name: cargo publish fathomdb-schema\n        run: |\n          if [ \"${DRY_RUN}\" = \"true\" ]; then\n            cargo publish --dry-run -p fathomdb-schema\n          else\n            cargo publish -p fathomdb-schema --token \"${CARGO_REGISTRY_TOKEN}\"\n          fi\n        env:\n          CARGO_REGISTRY_TOKEN: ${{ secrets.CARGO_REGISTRY_TOKEN }}\n      - name: Wait for crates.io index propagation\n        if: ${{ inputs.dry_run != true }}\n        run: sleep 60\n\n  publish-rust-t3-query:\n    runs-on: ubuntu-latest\n    needs: publish-rust-t2-schema\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2\n      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable\n        with:","numLines":150,"startLine":100,"totalLines":502}}}
