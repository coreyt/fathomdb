{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JHF9iv5VP4KiLMuUWQGwcp","type":"tool_result","content":"1455\t    }\n1456\t\n1457\t    pub fn close(&self) -> Result<(), EngineError> {\n1458\t        self.closed.store(true, Ordering::SeqCst);\n1459\t        self.projection_runtime.stop();\n1460\t        // Uninstall profile callbacks before dropping the connections so\n1461\t        // SQLite cannot fire one last callback against a profile context\n1462\t        // whose Box is about to free. Per `dev/design/engine.md` § Close\n1463\t        // path step 6, readers drain before the writer connection so\n1464\t        // SQLite's last-handle checkpointer runs on the writer. Each\n1465\t        // reader worker uninstalls its own callback inside\n1466\t        // `reader_worker_loop` before dropping its connection, then\n1467\t        // exits — `shutdown` joins those threads here.\n1468\t        self.reader_pool.shutdown();\n1469\t        if let Ok(mut connection) = self.connection.lock() {\n1470\t            if let Some(conn) = connection.as_ref() {\n1471\t                uninstall_profile_callback(conn);\n1472\t            }\n1473\t            connection.take();\n1474\t        }\n1475\t        if let Ok(mut contexts) = self.profile_contexts.lock() {\n1476\t            contexts.clear();\n1477\t        }\n1478\t        if let Ok(mut lock) = self.lock.lock() {\n1479\t            lock.take();\n1480\t        }\n1481\t        Ok(())\n1482\t    }\n1483\t\n1484\t    /// Block until in-flight writes drain or `timeout_ms` elapses.\n1485\t    ///\n1486\t    /// Surface owned by `dev/interfaces/rust.md` § Engine-attached\n1487\t    /// instrumentation; semantics are owned by `dev/design/lifecycle.md`.\n1488\t    pub fn drain(&self, timeout_ms: u64) -> Result<(), EngineError> {\n1489\t        self.ensure_open()?;\n1490\t        if self.projection_runtime.wait_for_idle(timeout_ms) {\n1491\t            Ok(())\n1492\t        } else {\n1493\t            Err(EngineError::Scheduler)\n1494\t        }\n1495\t    }\n1496\t\n1497\t    /// Snapshot of engine-internal counters.\n1498\t    ///\n1499\t    /// Field set owned by `dev/design/lifecycle.md`.\n1500\t    #[must_use]\n1501\t    pub fn counters(&self) -> CounterSnapshot {\n1502\t        self.counters.snapshot()\n1503\t    }\n1504\t"}]},"parent_tool_use_id":null,"session_id":"af81e32e-38ea-41b6-ab82-41ce4c91617f","uuid":"ea5b487f-211e-4ea0-b7a0-e2b5fcaf1f4b","timestamp":"2026-05-17T18:59:03.238Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-D-durability-harnesses-20260517T185755Z/src/rust/crates/fathomdb-engine/src/lib.rs","content":"    }\n\n    pub fn close(&self) -> Result<(), EngineError> {\n        self.closed.store(true, Ordering::SeqCst);\n        self.projection_runtime.stop();\n        // Uninstall profile callbacks before dropping the connections so\n        // SQLite cannot fire one last callback against a profile context\n        // whose Box is about to free. Per `dev/design/engine.md` § Close\n        // path step 6, readers drain before the writer connection so\n        // SQLite's last-handle checkpointer runs on the writer. Each\n        // reader worker uninstalls its own callback inside\n        // `reader_worker_loop` before dropping its connection, then\n        // exits — `shutdown` joins those threads here.\n        self.reader_pool.shutdown();\n        if let Ok(mut connection) = self.connection.lock() {\n            if let Some(conn) = connection.as_ref() {\n                uninstall_profile_callback(conn);\n            }\n            connection.take();\n        }\n        if let Ok(mut contexts) = self.profile_contexts.lock() {\n            contexts.clear();\n        }\n        if let Ok(mut lock) = self.lock.lock() {\n            lock.take();\n        }\n        Ok(())\n    }\n\n    /// Block until in-flight writes drain or `timeout_ms` elapses.\n    ///\n    /// Surface owned by `dev/interfaces/rust.md` § Engine-attached\n    /// instrumentation; semantics are owned by `dev/design/lifecycle.md`.\n    pub fn drain(&self, timeout_ms: u64) -> Result<(), EngineError> {\n        self.ensure_open()?;\n        if self.projection_runtime.wait_for_idle(timeout_ms) {\n            Ok(())\n        } else {\n            Err(EngineError::Scheduler)\n        }\n    }\n\n    /// Snapshot of engine-internal counters.\n    ///\n    /// Field set owned by `dev/design/lifecycle.md`.\n    #[must_use]\n    pub fn counters(&self) -> CounterSnapshot {\n        self.counters.snapshot()\n    }\n","numLines":50,"startLine":1455,"totalLines":3828}}}
