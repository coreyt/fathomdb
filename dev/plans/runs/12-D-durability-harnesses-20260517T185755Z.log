{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EKGp4s7Gr5kmc4aNAv6ccd","type":"tool_result","content":"1\t//! Lifecycle observability tests bound to AC-001..AC-010.\n2\t//!\n3\t//! Pure-type tests exercise data-type contracts pinned by\n4\t//! `dev/design/lifecycle.md` and `dev/acceptance.md`. Behavior tests bind\n5\t//! the AC measurement protocols via deterministic fixtures (slow-cte,\n6\t//! page-corruption tool, one-thread-poison stress runner) — see the\n7\t//! per-test comments and `tests/support/corruption.rs`.\n8\t\n9\tuse std::collections::BTreeMap;\n10\tuse std::sync::{Arc, Mutex};\n11\t\n12\tuse fathomdb_engine::lifecycle::{\n13\t    Event, EventCategory, EventSource, Phase, ProfileRecord, ProjectionStatus, SlowStatement,\n14\t    StressFailureContext, Subscriber,\n15\t};\n16\tuse fathomdb_engine::{CounterSnapshot, Engine, EngineOpenError, PreparedWrite};\n17\tuse tempfile::TempDir;\n18\t\n19\t#[path = \"support/corruption.rs\"]\n20\tmod corruption;\n21\t\n22\tfn fixture() -> (TempDir, Engine) {\n23\t    let dir = TempDir::new().unwrap();\n24\t    let engine = Engine::open(dir.path().join(\"observability.sqlite\")).expect(\"engine open\").engine;\n25\t    (dir, engine)\n26\t}\n27\t\n28\t#[derive(Default)]\n29\tstruct CapturingSubscriber {\n30\t    events: Mutex<Vec<Event>>,\n31\t    profile_records: Mutex<Vec<ProfileRecord>>,\n32\t    slow_statements: Mutex<Vec<SlowStatement>>,\n33\t    stress_failures: Mutex<Vec<StressFailureContext>>,\n34\t}\n35\t\n36\timpl Subscriber for CapturingSubscriber {\n37\t    fn on_event(&self, event: &Event) {\n38\t        self.events.lock().unwrap().push(event.clone());\n39\t    }\n40\t\n41\t    fn on_profile(&self, record: &ProfileRecord) {\n42\t        self.profile_records.lock().unwrap().push(*record);\n43\t    }\n44\t\n45\t    fn on_slow_statement(&self, signal: &SlowStatement) {\n46\t        self.slow_statements.lock().unwrap().push(signal.clone());\n47\t    }\n48\t\n49\t    fn on_stress_failure(&self, context: &StressFailureContext) {\n50\t        self.stress_failures.lock().unwrap().push(context.clone());\n51\t    }\n52\t}\n53\t\n54\t// AC-001: Phase enum is a typed value, not a substring of free text.\n55\t#[test]\n56\tfn ac_001_phase_enum_has_five_typed_variants() {\n57\t    let variants = [Phase::Started, Phase::Slow, Phase::Heartbeat, Phase::Finished, Phase::Failed];\n58\t\n59\t    // Pattern-match each variant exhaustively to confirm enum shape.\n60\t    for phase in variants {"}]},"parent_tool_use_id":null,"session_id":"af81e32e-38ea-41b6-ab82-41ce4c91617f","uuid":"23b93d0e-e0c9-4978-bdbb-2808943d2309","timestamp":"2026-05-17T19:00:00.903Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-D-durability-harnesses-20260517T185755Z/src/rust/crates/fathomdb-engine/tests/lifecycle_observability.rs","content":"//! Lifecycle observability tests bound to AC-001..AC-010.\n//!\n//! Pure-type tests exercise data-type contracts pinned by\n//! `dev/design/lifecycle.md` and `dev/acceptance.md`. Behavior tests bind\n//! the AC measurement protocols via deterministic fixtures (slow-cte,\n//! page-corruption tool, one-thread-poison stress runner) — see the\n//! per-test comments and `tests/support/corruption.rs`.\n\nuse std::collections::BTreeMap;\nuse std::sync::{Arc, Mutex};\n\nuse fathomdb_engine::lifecycle::{\n    Event, EventCategory, EventSource, Phase, ProfileRecord, ProjectionStatus, SlowStatement,\n    StressFailureContext, Subscriber,\n};\nuse fathomdb_engine::{CounterSnapshot, Engine, EngineOpenError, PreparedWrite};\nuse tempfile::TempDir;\n\n#[path = \"support/corruption.rs\"]\nmod corruption;\n\nfn fixture() -> (TempDir, Engine) {\n    let dir = TempDir::new().unwrap();\n    let engine = Engine::open(dir.path().join(\"observability.sqlite\")).expect(\"engine open\").engine;\n    (dir, engine)\n}\n\n#[derive(Default)]\nstruct CapturingSubscriber {\n    events: Mutex<Vec<Event>>,\n    profile_records: Mutex<Vec<ProfileRecord>>,\n    slow_statements: Mutex<Vec<SlowStatement>>,\n    stress_failures: Mutex<Vec<StressFailureContext>>,\n}\n\nimpl Subscriber for CapturingSubscriber {\n    fn on_event(&self, event: &Event) {\n        self.events.lock().unwrap().push(event.clone());\n    }\n\n    fn on_profile(&self, record: &ProfileRecord) {\n        self.profile_records.lock().unwrap().push(*record);\n    }\n\n    fn on_slow_statement(&self, signal: &SlowStatement) {\n        self.slow_statements.lock().unwrap().push(signal.clone());\n    }\n\n    fn on_stress_failure(&self, context: &StressFailureContext) {\n        self.stress_failures.lock().unwrap().push(context.clone());\n    }\n}\n\n// AC-001: Phase enum is a typed value, not a substring of free text.\n#[test]\nfn ac_001_phase_enum_has_five_typed_variants() {\n    let variants = [Phase::Started, Phase::Slow, Phase::Heartbeat, Phase::Finished, Phase::Failed];\n\n    // Pattern-match each variant exhaustively to confirm enum shape.\n    for phase in variants {","numLines":60,"startLine":1,"totalLines":663}}}
