{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ExG5ARaQqcQRfxAnMm6b5r","type":"tool_result","content":"740\t        bound.as_millis(),\n741\t    );\n742\t    assert!(\n743\t        concurrent <= bound,\n744\t        \"AC-020 failed: concurrent={concurrent:?} bound={bound:?} sequential={sequential:?}\"\n745\t    );\n746\t}\n747\t\n748\t#[test]\n749\t#[ignore = \"profiling harness: set AC020_PHASE=sequential to opt in\"]\n750\tfn ac_020_sequential_only() {\n751\t    if std::env::var(\"AC020_PHASE\").as_deref() != Ok(\"sequential\") {\n752\t        return;\n753\t    }\n754\t\n755\t    let (_dir, path) = fixture_path(\"ac020_sequential_only\");\n756\t    let embedder = Arc::new(RoutedEmbedder::new(3));\n757\t    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n758\t    seed_ac020_fixture(&opened.engine);\n759\t\n760\t    let started = Instant::now();\n761\t    for _ in 0..AC020_THREADS {\n762\t        run_ac020_mix(&opened.engine);\n763\t    }\n764\t    let elapsed = started.elapsed();\n765\t\n766\t    eprintln!(\"AC020_PHASE_SEQUENTIAL_MS={}\", elapsed.as_millis());\n767\t}\n768\t\n769\t#[test]\n770\t#[ignore = \"profiling harness: set AC020_PHASE=concurrent to opt in\"]\n771\tfn ac_020_concurrent_only() {\n772\t    if std::env::var(\"AC020_PHASE\").as_deref() != Ok(\"concurrent\") {\n773\t        return;\n774\t    }\n775\t\n776\t    let (_dir, path) = fixture_path(\"ac020_concurrent_only\");\n777\t    let embedder = Arc::new(RoutedEmbedder::new(3));\n778\t    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n779\t    seed_ac020_fixture(&opened.engine);\n780\t\n781\t    let engine = Arc::new(opened.engine);\n782\t    let barrier = Arc::new(Barrier::new(AC020_THREADS + 1));\n783\t    let mut handles = Vec::with_capacity(AC020_THREADS);\n784\t    for _ in 0..AC020_THREADS {\n785\t        let engine = Arc::clone(&engine);\n786\t        let barrier = Arc::clone(&barrier);\n787\t        handles.push(thread::spawn(move || {\n788\t            barrier.wait();\n789\t            run_ac020_mix(&engine);\n790\t        }));\n791\t    }\n792\t    let started = Instant::now();\n793\t    barrier.wait();\n794\t    for handle in handles {\n795\t        handle.join().expect(\"reader thread\");\n796\t    }\n797\t    let elapsed = started.elapsed();\n798\t\n799\t    eprintln!(\"AC020_PHASE_CONCURRENT_MS={}\", elapsed.as_millis());\n800\t}\n801\t\n802\t// ── G.3.5 cache-pressure telemetry ───────────────────────────────────────────\n803\t\n804\t/// Pack 6.G G.3.5 — read-only screening test that captures per-worker\n805\t/// `SQLITE_DBSTATUS_CACHE_HIT` / `_CACHE_MISS` / `_CACHE_USED` deltas\n806\t/// across one AC-020 concurrent body. Writes a sidecar JSON to the\n807\t/// path given by `G3_5_OUTPUT_PATH` env var so the orchestrator can\n808\t/// assemble the final per-phase JSON without re-running.\n809\t///\n810\t/// Run with:\n811\t///   `G3_5_OUTPUT_PATH=/tmp/foo.json cargo test --release \\\n812\t///    -p fathomdb-engine --test perf_gates -- --ignored \\\n813\t///    g3_5_cache_pressure_telemetry --nocapture`\n814\t#[cfg(debug_assertions)]\n815\t#[test]\n816\t#[ignore = \"G.3.5 diagnostic: read-only cache-pressure telemetry\"]\n817\tfn g3_5_cache_pressure_telemetry() {\n818\t    let output_path = std::env::var(\"G3_5_OUTPUT_PATH\")\n819\t        .expect(\"G3_5_OUTPUT_PATH env var required for the G.3.5 sidecar JSON\");\n820\t\n821\t    let (_dir, path) = fixture_path(\"g3_5_cache_pressure_telemetry\");\n822\t    let embedder = Arc::new(RoutedEmbedder::new(3));\n823\t    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n824\t    seed_ac020_fixture(&opened.engine);\n825\t    let worker_count = opened.engine.reader_worker_count_for_test();\n826\t\n827\t    // Warmup: 16 dispatched searches so the round-robin reaches every\n828\t    // worker at least twice and the page cache reaches steady state on\n829\t    // the seeded fixture before the pre snapshot.\n830\t    for _ in 0..16 {\n831\t        let _ = opened.engine.search(\"semantic-0\").expect(\"warmup search\");\n832\t    }\n833\t\n834\t    let pre = opened.engine.cache_status_per_worker_for_test(\"pre\");\n835\t    assert_eq!(pre.len(), worker_count);\n836\t\n837\t    // Run the AC-020 concurrent body once (8 threads x 50 rounds x 4\n838\t    // queries = 1600 dispatched searches). Same shape as\n839\t    // `ac_020_concurrent_only` but inlined so we don't depend on env-"}]},"parent_tool_use_id":null,"session_id":"af81e32e-38ea-41b6-ab82-41ce4c91617f","uuid":"3b860d13-f1d4-47e7-823d-cdde6c9e49bc","timestamp":"2026-05-17T18:58:33.695Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-D-durability-harnesses-20260517T185755Z/src/rust/crates/fathomdb-engine/tests/perf_gates.rs","content":"        bound.as_millis(),\n    );\n    assert!(\n        concurrent <= bound,\n        \"AC-020 failed: concurrent={concurrent:?} bound={bound:?} sequential={sequential:?}\"\n    );\n}\n\n#[test]\n#[ignore = \"profiling harness: set AC020_PHASE=sequential to opt in\"]\nfn ac_020_sequential_only() {\n    if std::env::var(\"AC020_PHASE\").as_deref() != Ok(\"sequential\") {\n        return;\n    }\n\n    let (_dir, path) = fixture_path(\"ac020_sequential_only\");\n    let embedder = Arc::new(RoutedEmbedder::new(3));\n    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n    seed_ac020_fixture(&opened.engine);\n\n    let started = Instant::now();\n    for _ in 0..AC020_THREADS {\n        run_ac020_mix(&opened.engine);\n    }\n    let elapsed = started.elapsed();\n\n    eprintln!(\"AC020_PHASE_SEQUENTIAL_MS={}\", elapsed.as_millis());\n}\n\n#[test]\n#[ignore = \"profiling harness: set AC020_PHASE=concurrent to opt in\"]\nfn ac_020_concurrent_only() {\n    if std::env::var(\"AC020_PHASE\").as_deref() != Ok(\"concurrent\") {\n        return;\n    }\n\n    let (_dir, path) = fixture_path(\"ac020_concu