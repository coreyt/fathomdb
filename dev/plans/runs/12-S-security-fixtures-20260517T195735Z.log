{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VVbA8t7ckFz5KB6jBC8z3F","type":"tool_result","content":"1\t//! Concurrent reader/writer test that pins the read-after-write cursor\n2\t//! invariant from `dev/design/engine.md` § Cursor contract and AC-059b /\n3\t//! REQ-013 / REQ-055.\n4\t//!\n5\t//! Invariant under test: the number of canonical rows visible to a\n6\t//! `search` MUST be ≤ the search's reported `projection_cursor`. Because\n7\t//! every committed write advances the engine cursor by exactly one and\n8\t//! inserts exactly one canonical row in this fixture, the row count the\n9\t//! search returned is a lower bound on \"how many writes the reader's\n10\t//! snapshot saw\"; that value can never exceed the cursor the reader\n11\t//! also returned without violating the cursor contract.\n12\t//!\n13\t//! Failure mode under test: the engine loads `next_cursor` from the\n14\t//! writer-side atomic before the reader connection runs its query; a\n15\t//! writer commit between those two events appears in the reader's WAL\n16\t//! snapshot but not in the reported cursor.\n17\t//!\n18\t//! Bounded operationally: 1,000 search calls, hard wall-clock cap of\n19\t//! 30 s, writer throttled.\n20\t//!\n21\t//! Runtime-budget category: long-run only (~1000-iteration race fixture).\n22\t//! `agent-verify.sh` skips this test entirely for runtime budget; the\n23\t//! ~1000-iteration race fixture is exercised only by `scripts/check.sh`\n24\t//! with `AGENT_LONG=1`. There is no smoke variant — the AC-059b evidence\n25\t//! comes exclusively from the long-run gate.\n26\t\n27\tuse std::sync::atomic::{AtomicBool, Ordering};\n28\tuse std::sync::Arc;\n29\tuse std::thread;\n30\tuse std::time::{Duration, Instant};\n31\t\n32\tuse fathomdb_engine::{Engine, PreparedWrite};\n33\tuse tempfile::TempDir;\n34\t\n35\tfn long_run_enabled() -> bool {\n36\t    std::env::var_os(\"AGENT_LONG\").is_some()\n37\t}\n38\t\n39\t#[test]\n40\tfn projection_cursor_bounds_observed_row_count() {\n41\t    if !long_run_enabled() {\n42\t        return;\n43\t    }\n44\t\n45\t    let dir = TempDir::new().unwrap();\n46\t    let path = dir.path().join(\"cursor_race.sqlite\");\n47\t    let opened = Engine::open(&path).expect(\"open\");\n48\t    let engine = Arc::new(opened.engine);\n49\t\n50\t    let stop = Arc::new(AtomicBool::new(false));\n51\t    let writer = {\n52\t        let engine = Arc::clone(&engine);\n53\t        let stop = Arc::clone(&stop);\n54\t        thread::spawn(move || {\n55\t            while !stop.load(Ordering::Relaxed) {\n56\t                let _ = engine.write(&[PreparedWrite::Node {\n57\t                    kind: \"doc\".to_string(),\n58\t                    body: \"needle\".to_string(),\n59\t                    source_id: None,\n60\t                }]);\n61\t                thread::sleep(Duration::from_micros(50));\n62\t            }\n63\t        })\n64\t    };\n65\t\n66\t    let iterations = 1000usize;\n67\t    let mut violations = 0usize;\n68\t    let started = Instant::now();\n69\t    for i in 0..iterations {\n70\t        if started.elapsed() > Duration::from_secs(30) {\n71\t            stop.store(true, Ordering::Relaxed);\n72\t            writer.join().expect(\"writer thread\");\n73\t            panic!(\"cursor invariant test exceeded 30 s wall clock at iteration {i}\");\n74\t        }\n75\t        let result = engine.search(\"needle\").expect(\"search\");\n76\t        // results[0] is the compiled SQL string from `compile_text_query`;\n77\t        // every entry after that is a body row from canonical_nodes.\n78\t        let row_count = result.results.iter().filter(|s| s.as_str() == \"needle\").count() as u64;\n79\t        if row_count > result.projection_cursor {\n80\t            violations += 1;\n81\t            if violations <= 5 {\n82\t                eprintln!(\n83\t                    \"iter {i}: rows_returned={row_count} > projection_cursor={}\",\n84\t                    result.projection_cursor,\n85\t                );\n86\t            }\n87\t        }\n88\t    }\n89\t\n90\t    stop.store(true, Ordering::Relaxed);\n91\t    writer.join().expect(\"writer thread\");\n92\t\n93\t    assert_eq!(\n94\t        violations, 0,\n95\t        \"cursor invariant violated {violations}/{iterations} times: search returned more \\\n96\t         matching rows than the reported projection_cursor permits — projection_cursor was \\\n97\t         derived from a writer-side atomic that races ahead of the reader's WAL snapshot\",\n98\t    );\n99\t}\n100\t"}]},"parent_tool_use_id":null,"session_id":"17a0ef0a-e71e-4f47-89a1-81a3e1f65155","uuid":"cdcaa18b-1862-4bf8-a5c5-fccb0622305e","timestamp":"2026-05-17T19:58:23.052Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-12-S-security-fixtures-20260517T195735Z/src/rust/crates/fathomdb-engine/tests/cursor_read_after_write.rs","content":"//! Concurrent reader/writer test that pins the read-after-write cursor\n//! invariant from `dev/design/engine.md` § Cursor contract and AC-059b /\n//! REQ-013 / REQ-055.\n//!\n//! Invariant under test: the number of canonical rows visible to a\n//! `search` MUST be ≤ the search's reported `projection_cursor`. Because\n//! every committed write advances the engine cursor by exactly one and\n//! inserts exactly one canonical row in this fixture, the row count the\n//! search returned is a lower bound on \"how many writes the reader's\n//! snapshot saw\"; that value can never exceed the cursor the reader\n//! also returned without violating the cursor contract.\n//!\n//! Failure mode under test: the engine loads `next_cursor` from the\n//! writer-side atomic before the reader connection runs its query; a\n//! writer commit between those two events appears in the reader's WAL\n//! snapshot but not in the reported cursor.\n//!\n//! Bounded operationally: 1,000 search calls, hard wall-clock cap of\n//! 30 s, writer throttled.\n//!\n//! Runtime-budget category: long-run only (~1000-iteration race fixture).\n//! `agent-verify.sh` skips this test entirely for runtime budget; the\n//! ~1000-iteration race fixture is exercised only by `scripts/check.sh`\n//! with `AGENT_LONG=1`. There is no smoke variant — the AC-059b evidence\n//! comes exclusively from the long-run gate.\n\nuse std::sync::atomic::{AtomicBool, Ordering};\nuse std::sync::Arc;\nuse std::thread;\nuse std::time::{Duration, Instant};\n\nuse fathomdb_engine::{Engine, PreparedWrite};\nuse tempfile::TempDir;\n\nfn long_run_enabled() -> bool {\n    std::env::var_os(\"AGENT_LONG\").is_some()\n}\n\n#[test]\nfn projection_cursor_bounds_observed_row_count() {\n    if !long_run_enabled() {\n        return;\n    }\n\n    let dir = TempDir::new().unwrap();\n    let path = dir.path().join(\"cursor_race.sqlite\");\n    let opened = Engine::open(&path).expect(\"open\");\n    let engine = Arc::new(opened.engine);\n\n    let stop = Arc::new(AtomicBool::new(false));\n    let writer = {\n        let engine = Arc::clone(&engine);\n        let stop = Arc::clone(&stop);\n        thread::spawn(move || {\n            while !stop.load(Ordering::Relaxed) {\n                let _ = engine.write(&[PreparedWrite::Node {\n                    kind: \"doc\".to_string(),\n                    body: \"needle\".to_string(),\n                    source_id: None,\n                }]);\n                thread::sleep(Duration::from_micros(50));\n            }\n        })\n    };\n\n    let iterations = 1000usize;\n    let mut violations = 0usize;\n    let started = Instant::now();\n    for i in 0..iterations {\n        if started.elapsed() > Duration::from_secs(30) {\n            stop.store(true, Ordering::Relaxed);\n            writer.join().expect(\"writer thread\");\n            panic!(\"cursor invariant test exceeded 30 s wall clock at iteration {i}\");\n        }\n        let result = engine.search(\"needle\").expect(\"search\");\n        // results[0] is the compiled SQL string from `compile_text_query`;\n        // every entry after that is a body row from canonical_nodes.\n        let row_count = result.results.iter().filter(|s| s.as_str() == \"needle\").count() as u64;\n        if row_count > result.projection_cursor {\n            violations += 1;\n            if violations <= 5 {\n                eprintln!(\n                    \"iter {i}: rows_returned={row_count} > projection_cursor={}\",\n                    result.projection_cursor,\n                );\n            }\n        }\n    }\n\n    stop.store(true, Ordering::Relaxed);\n    writer.join().expect(\"writer thread\");\n\n    assert_eq!(\n        violations, 0,\n        \"cursor invariant violated {violations}/{iterations} times: search returned more \\\n         matching rows than the reported projection_cursor permits — projection_cursor was \\\n         derived from a writer-side atomic that races ahead of the reader's WAL snapshot\",\n    );\n}\n","numLines":100,"startLine":1,"totalLines":100}}}
