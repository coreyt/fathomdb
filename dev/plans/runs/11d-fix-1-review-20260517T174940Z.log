if [ "${RELEASE_GATES_SKIP_GIT_REACH:-0}" != "1" ]; then
  main_ref="${RELEASE_GATES_HEAD_REF:-refs/heads/main}"
  if ! git -C "$REPO_ROOT" rev-parse --verify "$main_ref" >/dev/null 2>&1; then
