# Read the [package] block until next [section] and check field presence.
has_package_field() {
  local manifest="$1" field="$2"
  awk -v field="$field" '
    /^\[package\]/ { in_block = 1; next }
    /^\[/ && in_block { exit }
    in_block && $0 ~ ("^" field "[[:space:]]*[=.]") { found = 1; exit }
