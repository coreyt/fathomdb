   108	#[derive(Debug, Clone)]
   109	struct Record {
   110	    commit_sha: String,
   111	    ac_id: String,
   112	    n: u64,
   113	    p50_ms: Option<f64>,
   114	    p99_ms: Option<f64>,
   115	    recall: Option<f64>,
   116	    timestamp: String,
   117	    /// UTC epoch seconds parsed from `timestamp`. This — not the raw string —
   118	    /// is the ordering key, so a malformed/offset timestamp cannot silently
   119	    /// reorder latest-run selection (a lexical sort would).
   120	    ts_epoch: i64,
   121	}
   122	
   123	/// Parse a strict RFC3339 timestamp to UTC epoch seconds for ordering.
   124	///
   125	/// Accepts `YYYY-MM-DDTHH:MM:SS(.fraction)?(Z|±HH:MM)`. Any deviation returns
   126	/// `Err`, so a malformed timestamp fails loudly (exit 2) instead of corrupting
   127	/// "latest by timestamp" via a lexical string sort. Dependency-free (the
   128	/// workspace pulls in no date crate); uses Howard Hinnant's days-from-civil
   129	/// algorithm for the proleptic-Gregorian day count.
   130	fn parse_rfc3339_epoch(s: &str) -> Result<i64, String> {
   131	    let (date, rest) = s.split_once('T').ok_or_else(|| format!("missing 'T': {s}"))?;
   132	    let d: Vec<&str> = date.split('-').collect();
   133	    if d.len() != 3 {
   134	        return Err(format!("bad date: {s}"));
   135	    }
   136	    let year: i64 = d[0].parse().map_err(|_| format!("bad year: {s}"))?;
   137	    let month: i64 = d[1].parse().map_err(|_| format!("bad month: {s}"))?;
   138	    let day: i64 = d[2].parse().map_err(|_| format!("bad day: {s}"))?;
   139	    if !(1..=12).contains(&month) || !(1..=31).contains(&day) {
   140	        return Err(format!("date out of range: {s}"));
   141	    }
   142	
   143	    // Split the time-of-day from the zone designator (Z or ±HH:MM).
   144	    let (time_part, offset_secs) = if let Some(t) = rest.strip_suffix('Z') {
   145	        (t, 0i64)
   146	    } else {
   147	        let sign_idx =
   148	            rest.rfind(['+', '-']).ok_or_else(|| format!("missing zone designator: {s}"))?;
   149	        let (t, off) = rest.split_at(sign_idx);
   150	        let sign = if off.starts_with('-') { -1 } else { 1 };
   151	        let (oh, om) = off[1..].split_once(':').ok_or_else(|| format!("bad zone offset: {s}"))?;
   152	        let oh: i64 = oh.parse().map_err(|_| format!("bad offset hour: {s}"))?;
   153	        let om: i64 = om.parse().map_err(|_| format!("bad offset minute: {s}"))?;
   154	        (t, sign * (oh * 3600 + om * 60))
   155	    };
   156	
   157	    // HH:MM:SS, ignoring any fractional-second suffix.
   158	    let time_core = time_part.split('.').next().unwrap_or(time_part);
   159	    let tp: Vec<&str> = time_core.split(':').collect();
   160	    if tp.len() != 3 {
   161	        return Err(format!("bad time: {s}"));
   162	    }
   163	    let hh: i64 = tp[0].parse().map_err(|_| format!("bad hour: {s}"))?;
   164	    let mi: i64 = tp[1].parse().map_err(|_| format!("bad minute: {s}"))?;
   165	    let ss: i64 = tp[2].parse().map_err(|_| format!("bad second: {s}"))?;
   166	    if hh > 23 || mi > 59 || ss > 60 {
   167	        return Err(format!("time out of range: {s}"));
   168	    }
   169	
   170	    // days_from_civil (Howard Hinnant): days since 1970-01-01, proleptic Gregorian.
   171	    let y = if month <= 2 { year - 1 } else { year };
   172	    let era = (if y >= 0 { y } else { y - 399 }) / 400;
   173	    let yoe = y - era * 400;
   174	    let mp = (month + 9) % 12;
   175	    let doy = (153 * mp + 2) / 5 + day - 1;
   176	    let doe = yoe * 365 + yoe / 4 - yoe / 100 + doy;
   177	    let days = era * 146097 + doe - 719468;
   178	    Ok(days * 86400 + hh * 3600 + mi * 60 + ss - offset_secs)
   179	}
