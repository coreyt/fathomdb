name: perf-canonical (AC-012 / AC-013 / AC-019 long-run gate)

# Canonical-runner perf re-measurement for the 0.6.1 deferred items
# (AC-012 text-query latency; AC-013 retrieval latency; AC-019 mixed
# stress). Long-run harness invoked under AGENT_LONG=1 +
# AC_FULL_SCALE=1 on tier-1 ubuntu-latest x86_64 per
# ADR-0.6.0-tier1-ci-platforms.
#
# Manually-triggered only — these are hours-of-wall-clock runs at
# canonical scale. Default scale (corpus_n inputs) lets the user
# downscale for diagnostic dry-runs.
#
# POLICY (see dev/notes/ac013-ac019-canonical-scale-policy.md):
# AC-013 / AC-019 at ac013_corpus_n=1000000 takes ~2-3 hours on
# the current 4-core canonical EPYC runner — too long to gate
# on. This workflow MUST remain workflow_dispatch-only; do NOT
# add push: / pull_request: / schedule: triggers that invoke
# AC-013 or AC-019 at N=1M. The canonical-scale measurement is a
# once-per-release exercise, not a per-slice gate.
#
# 0.7.2 PR-3 SCOPE NOTE (HITL 2026-05-31): this workflow exercises only
# the SYNTHETIC fixture (VaryingEmbedder, deterministic Zipfian corpus).
# The REAL default-embedder (bge-small) + real-corpus measurement at
# N=1M is a LOCAL-ONLY exercise — seeding 1M docs through the serialized
# candle projection path is ~166 h at the PR-9-measured 1.67 docs/s, vastly
# beyond any runner timeout (see dev/plans/runs/0.7.2-PR-3-output.json). The
# real-embedder AC-013/AC-013b/AC-019 numbers are pinned from local runs
# (perf_gates synthetic N=1M for latency + eu7_real_corpus_ac.rs for the
# real query-embed slice and the recall anchor). The per-push CI "is the
# read path broken?" guard is perf_gates::ac_013_vector_read_path_smoke
# (always-on, fast, fixture-independent) in the normal ci.yml suite.

on:
  workflow_dispatch:
    inputs:
      ac012_corpus_n:
        description: "AC-012 corpus row count (1000000 = canonical; lower for dry-run)"
        required: false
        default: "1000000"
      ac013_corpus_n:
        description: "AC-013 corpus row count (default 10000; canonical 1000000 takes ~2-3h on 4-core runner — see dev/notes/ac013-ac019-canonical-scale-policy.md)"
        required: false
        default: "10000"
      run_full_scale:
        description: "Set AC_FULL_SCALE=1 (canonical 1M scale; otherwise honors corpus_n env knobs)"
        required: false
        type: boolean
        default: true
      experiment_id:
        description: "0.7.0 perf-experiments id (e.g. W1.1); blank = legacy AC-012-only run"
        required: false
        default: ""
      lever_id:
        description: "0.7.0 lever id from dev/plans/0.7.0-perf-experiments.md (e.g. L-A0)"
        required: false
        default: "L-A0"
      targets:
        description: "Space-separated targets: ac012 ac020 ac013 (default ac012)"
        required: false
        default: "ac012"
      perf_record:
        description: "Capture perf record -g --call-graph dwarf + perf report (L-A1 diagnostic)"
        required: false
        type: boolean
        default: false
      sqlite_perf_env:
        description: "Space-separated KEY=VAL list of FATHOMDB_PERF_* env knobs, exported verbatim. Consolidates the former memstatus_off/pcache2/pagecache_spec/writer_pragmas/reader_pragmas/search_limit inputs (GitHub caps workflow_dispatch at 10 inputs). E.g. 'FATHOMDB_PERF_SQLITE_PCACHE2=1 FATHOMDB_PERF_SQLITE_PAGECACHE=8192:32768 FATHOMDB_PERF_SEARCH_LIMIT=1000'"
        required: false
        default: ""

permissions:
  contents: read
  # PR-7: this workflow is workflow_dispatch-only, so there is no PR/push event
  # to comment on. The perf-regression-check verdict is surfaced via
  # $GITHUB_STEP_SUMMARY (always available on dispatch). No pull-requests scope
  # is requested — adding one would be an unused over-grant.

jobs:
  ac012-canonical-measure:
    name: AC-012 canonical re-measurement (legacy)
    if: inputs.experiment_id == ''
    runs-on: ubuntu-latest
    timeout-minutes: 180
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
      - name: Configure per-session TMPDIR
        shell: bash
        run: |
          TMPDIR="$RUNNER_TEMP/fathomdb-${GITHUB_RUN_ID}-${GITHUB_RUN_ATTEMPT}"
          mkdir -p "$TMPDIR"
          echo "TMPDIR=$TMPDIR" >> "$GITHUB_ENV"
      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
        with:
          toolchain: stable
          components: rustfmt, clippy
      - uses: Swatinem/rust-cache@c19371144df3bb44fab255c43d04cbc2ab54d1c4 # v2.9.1
      - name: Capture canonical-runner spec
        shell: bash
        run: |
          echo "=== Runner spec (paste into dev/notes/perf-canonical-runner-2026-MM.md) ==="
          echo "CPU model:"
          grep "model name" /proc/cpuinfo | head -1
          echo ""
          echo "Core count / threads:"
          nproc
          echo ""
          echo "OS:"
          lsb_release -d 2>/dev/null || grep PRETTY_NAME /etc/os-release
          echo ""
          echo "Kernel:"
          uname -a
          echo ""
          echo "glibc:"
          ldd --version | head -1
          echo ""
          echo "rustc:"
          rustc --version
          echo ""
          echo "Runner identifier: ${RUNNER_NAME:-ubuntu-latest} (${RUNNER_OS}/${RUNNER_ARCH})"
          echo "Workflow run URL: ${GITHUB_SERVER_URL}/${GITHUB_REPOSITORY}/actions/runs/${GITHUB_RUN_ID}"
          echo ""
          echo "=== SQLite version (compiled-in via rusqlite) ==="
          cargo run -q --manifest-path scripts/sqlite-version/Cargo.toml 2>/dev/null \
            || echo "(scripts/sqlite-version helper not present; run a small rust snippet locally to extract)"
      - name: Build perf_gates (release; only the perf_gates test binary)
        shell: bash
        run: |
          # Scope to the perf_gates integration test binary only.
          # Other integration tests (e.g. tests/compatibility.rs) use
          # `#[cfg(debug_assertions)]`-gated helpers that disappear in
          # --release, so `--tests` (which builds ALL test binaries)
          # fails the release build despite perf_gates itself being
          # release-clean.
          cargo test --release --no-run -p fathomdb-engine --test perf_gates
      - name: Run AC-012 canonical re-measurement
        env:
          AGENT_LONG: "1"
          AC_FULL_SCALE: ${{ inputs.run_full_scale && '1' || '' }}
          AC012_CORPUS_N: ${{ inputs.ac012_corpus_n }}
          AC013_CORPUS_N: ${{ inputs.ac013_corpus_n }}
          RUST_BACKTRACE: "1"
        shell: bash
        run: |
          set -o pipefail
          # Run only the AC-012 perf gate; explicit test filter so we don't
          # also drag in AC-013 / AC-019 / AC-020 (Pack 7 territory).
          # Test is `#[test]` (not `#[ignore]`); long-run-gated via
          # `AGENT_LONG=1` env. Filter to AC-012 only — AC-013/019/020 stay
          # deferred per Pack 7 trigger evaluation.
          cargo test --release -p fathomdb-engine --test perf_gates -- \
            --nocapture ac_012 \
            2>&1 | tee perf-canonical-ac012.log
      - name: Upload measurement log
        if: always()
        uses: actions/upload-artifact@bbbca2ddaa5d8feaa63e36b76fdaad77386f024f # v7.0.0
        with:
          name: perf-canonical-ac012-log
          path: perf-canonical-ac012.log
          retention-days: 30
      # PR-7 — perf regression detection. Read the append-only
      # dev/perf-history/ store, group by (ac_id, n), and flag the latest run
      # vs the rolling median of prior runs. See
      # dev/design/perf-regression-detection.md.
      #   exit 0 = clean; exit 1 = regression flagged (NOT a hard fail — the
      #   step-summary verdict is the signal); exit 2 = data integrity (fail loudly).
      # This workflow is workflow_dispatch-only, so there is no PR to comment on:
      # the report is written to $GITHUB_STEP_SUMMARY (the dispatch-safe channel)
      # and the step log. A flagged regression (exit 1) is surfaced, not failed,
      # so a human reads the summary; a data-integrity failure (exit 2) fails the
      # step loudly.
      - name: Perf regression check
        id: perf_regression
        if: always()
        shell: bash
        run: |
          set +e
          OUT="$(cargo run --quiet -p fathomdb-cli --bin perf-regression-check -- dev/perf-history)"
          CODE=$?
          echo "$OUT"
          VERDICT="no regressions"
          [ "$CODE" -eq 1 ] && VERDICT="⚠️ regression(s) flagged"
          [ "$CODE" -eq 2 ] && VERDICT="❌ data missing/malformed (integrity failure)"
          {
            echo "## perf-regression-check"
            echo ""
            echo "**Verdict:** ${VERDICT} (exit ${CODE})"
            echo ""
            echo '```'
            echo "$OUT"
            echo '```'
          } >> "$GITHUB_STEP_SUMMARY"
          if [ "$CODE" -eq 2 ]; then
            echo "::error::perf-regression-check exit 2 — perf-history data missing/malformed (integrity failure)"
            exit 2
          fi
          # exit 0 or 1: do not fail the step; the step summary carries the signal.
          exit 0
      - name: Summarize verdict
        if: always()
        shell: bash
        run: |
          echo "=== Verdict guidance ==="
          echo "ADR-0.6.0-text-query-latency-gates budgets: p50 ≤ 20 ms; p99 ≤ 150 ms"
          echo ""
          echo "Copy the measured numbers from perf-canonical-ac012.log into:"
          echo "  dev/notes/perf-canonical-runner-2026-MM.md § Measured numbers"
          echo ""
          echo "Then flip the file's status: template -> status: measured,"
          echo "and update dev/test-plan.md § Current Perf Attribution AC-012"
          echo "to lift the DEFERRED label if GREEN."
          echo ""
          echo "If RED on p50 or p99: do NOT lift the deferral. Surface to"
          echo "orchestrator — Pack 7 un-defer trigger fires (per"
          echo "dev/plans/0.6.0-implementation.md § Pack 7 un-defer trigger)."

  perf-experiment:
    name: 0.7.0 perf-experiment (${{ inputs.experiment_id }} ${{ inputs.lever_id }})
    if: inputs.experiment_id != ''
    runs-on: ubuntu-latest
    timeout-minutes: 240
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd # v6.0.2
      - name: Configure per-session TMPDIR
        shell: bash
        run: |
          TMPDIR="$RUNNER_TEMP/fathomdb-${GITHUB_RUN_ID}-${GITHUB_RUN_ATTEMPT}"
          mkdir -p "$TMPDIR"
          echo "TMPDIR=$TMPDIR" >> "$GITHUB_ENV"
      - uses: dtolnay/rust-toolchain@3c5f7ea28cd621ae0bf5283f0e981fb97b8a7af9 # stable
        with:
          toolchain: stable
          components: rustfmt, clippy
      - uses: Swatinem/rust-cache@c19371144df3bb44fab255c43d04cbc2ab54d1c4 # v2.9.1
      - name: Capture canonical-runner spec
        shell: bash
        run: |
          echo "=== Runner spec ==="
          grep "model name" /proc/cpuinfo | head -1
          echo "cores=$(nproc)"
          uname -srm
          ldd --version | head -1
          rustc --version
          echo "experiment_id=${{ inputs.experiment_id }}"
          echo "lever_id=${{ inputs.lever_id }}"
          echo "targets=${{ inputs.targets }}"
          echo "perf_record=${{ inputs.perf_record }}"
          echo "ac012_corpus_n=${{ inputs.ac012_corpus_n }}"
          echo "ac013_corpus_n=${{ inputs.ac013_corpus_n }}"
          echo "run_full_scale=${{ inputs.run_full_scale }}"
      - name: Install perf (for L-A1 diagnostic)
        if: ${{ inputs.perf_record == true }}
        shell: bash
        run: |
          sudo apt-get update -qq
          sudo apt-get install -y -qq linux-tools-common linux-tools-generic "linux-tools-$(uname -r)" || \
            sudo apt-get install -y -qq linux-tools-common linux-tools-generic
          which perf || true
      - name: Build perf_gates (release)
        shell: bash
        run: |

