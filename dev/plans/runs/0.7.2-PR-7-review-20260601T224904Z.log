   400	fn main() -> ExitCode {
   401	    let mut dir: Option<PathBuf> = None;
   402	    let mut json = false;
   403	    for arg in std::env::args().skip(1) {
   404	        match arg.as_str() {
   405	            "--json" => json = true,
   406	            "-h" | "--help" => {
   407	                print_usage();
   408	                return ExitCode::from(0);
   409	            }
   410	            other if other.starts_with('-') => {
   411	                eprintln!("unknown flag: {other}");
   412	                print_usage();
   413	                return ExitCode::from(2);
   414	            }
   415	            other => {
   416	                if dir.is_some() {
   417	                    eprintln!("unexpected extra argument: {other}");
   418	                    print_usage();
   419	                    return ExitCode::from(2);
   420	                }
   421	                dir = Some(PathBuf::from(other));
   422	            }
   423	        }
   424	    }
   425	
   426	    let dir = match dir {
   427	        Some(d) => d,
   428	        None => {
   429	            print_usage();
   430	            return ExitCode::from(2);
   431	        }
   432	    };
   433	
   434	    match build_report(&dir) {
   435	        Ok(report) => {
   436	            if json {
   437	                match serde_json::to_string_pretty(&report) {
   438	                    Ok(s) => println!("{s}"),
   439	                    Err(e) => {
   440	                        eprintln!("failed to serialize report: {e}");
   441	                        return ExitCode::from(2);
   442	                    }
   443	                }
   444	            } else {
   445	                print_human(&report);
   446	            }
   447	            if report.flagged {
   448	                ExitCode::from(1)
   449	            } else {
   450	                ExitCode::from(0)
   451	            }
   452	        }
   453	        Err(e) => {
   454	            eprintln!("perf-regression-check: {e}");
   455	            ExitCode::from(2)
   456	        }
   457	    }
   458	}
