   181	/// A loaded record paired with the file it came from (for error messages).
   182	fn load_record(path: &Path) -> Result<Record, String> {
   183	    let text = std::fs::read_to_string(path)
   184	        .map_err(|e| format!("{}: cannot read: {e}", path.display()))?;
   185	    let raw: RawRecord = serde_json::from_str(&text)
   186	        .map_err(|e| format!("{}: invalid JSON / schema: {e}", path.display()))?;
   187	    // A record must carry at least one comparable metric.
   188	    if raw.p50_ms.is_none() && raw.p99_ms.is_none() && raw.recall.is_none() {
   189	        return Err(format!(
   190	            "{}: record has no comparable metric (need p50_ms/p99_ms or recall)",
   191	            path.display()
   192	        ));
   193	    }
   194	    // Timestamp must be a parseable RFC3339 instant — a bad one is a data-
   195	    // integrity failure (exit 2), not something to sort lexically and hope.
   196	    let ts_epoch = parse_rfc3339_epoch(&raw.timestamp)
   197	        .map_err(|e| format!("{}: malformed timestamp: {e}", path.display()))?;
   198	    Ok(Record {
   199	        commit_sha: raw.commit_sha,
   200	        ac_id: raw.ac_id,
   201	        n: raw.n,
   202	        p50_ms: raw.p50_ms,
   203	        p99_ms: raw.p99_ms,
   204	        recall: raw.recall,
   205	        timestamp: raw.timestamp,
   206	        ts_epoch,
   207	    })
   208	}
   209	
   210	/// Median of a slice (sorted copy; mean of the two middle elements for an even
   211	/// count). Returns `None` for an empty slice.
   212	fn median(values: &[f64]) -> Option<f64> {
   213	    if values.is_empty() {
   214	        return None;
   215	    }
   216	    let mut v = values.to_vec();
   217	    v.sort_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal));
   218	    let mid = v.len() / 2;
   219	    if v.len() % 2 == 1 {
   220	        Some(v[mid])
   221	    } else {
   222	        Some((v[mid - 1] + v[mid]) / 2.0)
   223	    }
   224	}
   225	
   226	#[derive(Debug, serde::Serialize)]
   227	struct GroupVerdict {
   228	    ac_id: String,
   229	    n: u64,
   230	    latest_commit: String,
   231	    latest_timestamp: String,
   232	    runs: usize,
   233	    flagged: bool,
   234	    /// "ok" | "insufficient-history" | "regression"
   235	    status: String,
   236	    reasons: Vec<String>,
   237	}
   238	
   239	#[derive(Debug, serde::Serialize)]
   240	struct Report {
   241	    flagged: bool,
   242	    groups: Vec<GroupVerdict>,
   243	}
   244	
   245	/// Evaluate one group's runs (already sorted oldest -> newest by timestamp).
   246	fn evaluate_group(ac_id: &str, n: u64, runs: &[Record]) -> GroupVerdict {
   247	    let latest = runs.last().expect("group is never empty");
   248	    let mut verdict = GroupVerdict {
   249	        ac_id: ac_id.to_string(),
   250	        n,
   251	        latest_commit: latest.commit_sha.clone(),
   252	        latest_timestamp: latest.timestamp.clone(),
   253	        runs: runs.len(),
   254	        flagged: false,
   255	        status: "ok".to_string(),
   256	        reasons: Vec::new(),
   257	    };
   258	
   259	    if runs.len() < MIN_RUNS_FOR_MEDIAN {
   260	        verdict.status = "insufficient-history".to_string();
   261	        verdict.reasons.push(format!(
   262	            "only {} run(s) in group; need >= {} to form a median",
   263	            runs.len(),
   264	            MIN_RUNS_FOR_MEDIAN
   265	        ));
   266	        return verdict;
   267	    }
   268	
   269	    // Prior runs = the up-to-ROLLING_WINDOW runs immediately before the latest.
   270	    let prior = &runs[..runs.len() - 1];
   271	    let window_start = prior.len().saturating_sub(ROLLING_WINDOW);
   272	    let window = &prior[window_start..];
   273	
   274	    // Latency: flag if p50 OR p99 degraded > LATENCY_DEGRADATION_FRACTION.
   275	    for (label, get) in [
   276	        ("p50_ms", &Record::p50_ms as &dyn Fn(&Record) -> Option<f64>),
   277	        ("p99_ms", &Record::p99_ms as &dyn Fn(&Record) -> Option<f64>),
   278	    ] {
   279	        let prior_vals: Vec<f64> = window.iter().filter_map(get).collect();
   280	        if let (Some(latest_v), Some(med)) = (get(latest), median(&prior_vals)) {
   281	            if med > 0.0 {
   282	                let frac = (latest_v - med) / med;
   283	                if frac > LATENCY_DEGRADATION_FRACTION {
   284	                    verdict.flagged = true;
   285	                    verdict.reasons.push(format!(
   286	                        "{label} {latest_v:.2} ms is {:.1}% over rolling median {med:.2} ms (threshold {:.0}%) at commit {}",
   287	                        frac * 100.0,
   288	                        LATENCY_DEGRADATION_FRACTION * 100.0,
   289	                        latest.commit_sha,
   290	                    ));
   291	                }
   292	            }
   293	        }
   294	    }
   295	
   296	    // Recall: flag if degraded > RECALL_DEGRADATION_ABSOLUTE (absolute drop).
   297	    let prior_recall: Vec<f64> = window.iter().filter_map(|r| r.recall).collect();
   298	    if let (Some(latest_r), Some(med)) = (latest.recall, median(&prior_recall)) {
   299	        let drop = med - latest_r;
   300	        if drop > RECALL_DEGRADATION_ABSOLUTE {
   301	            verdict.flagged = true;
   302	            verdict.reasons.push(format!(
   303	                "recall {latest_r:.4} is {drop:.4} below rolling median {med:.4} (threshold {RECALL_DEGRADATION_ABSOLUTE}) at commit {}",
   304	                latest.commit_sha,
   305	            ));
   306	        }
   307	    }
   308	
   309	    if verdict.flagged {
   310	        verdict.status = "regression".to_string();
   311	    }
   312	    verdict
   313	}
   314	
   315	impl Record {
   316	    fn p50_ms(&self) -> Option<f64> {
   317	        self.p50_ms
   318	    }
   319	    fn p99_ms(&self) -> Option<f64> {
   320	        self.p99_ms
   321	    }
   322	}
   323	
   324	fn build_report(dir: &Path) -> Result<Report, String> {
   325	    if !dir.is_dir() {
   326	        return Err(format!("perf-history directory not found: {}", dir.display()));
   327	    }
   328	
   329	    // Group by (ac_id, n). BTreeMap gives deterministic, sorted output.
   330	    let mut groups: BTreeMap<(String, u64), Vec<Record>> = BTreeMap::new();
   331	
   332	    let entries =
   333	        std::fs::read_dir(dir).map_err(|e| format!("cannot read dir {}: {e}", dir.display()))?;
   334	    for entry in entries {
   335	        let entry = entry.map_err(|e| format!("dir entry error: {e}"))?;
   336	        let path = entry.path();
   337	        if path.extension().and_then(|s| s.to_str()) != Some("json") {
   338	            continue;
   339	        }
   340	        let rec = load_record(&path)?;
   341	        groups.entry((rec.ac_id.clone(), rec.n)).or_default().push(rec);
   342	    }
   343	
   344	    if groups.is_empty() {
   345	        return Err(format!("no *.json perf records found in {}", dir.display()));
   346	    }
   347	
   348	    let mut report = Report { flagged: false, groups: Vec::new() };
   349	    for ((ac_id, n), mut runs) in groups {
   350	        // Sort oldest -> newest by parsed UTC epoch (not the raw string, which
   351	        // would mis-order offset/Z-mixed timestamps). Tie-break on commit_sha
   352	        // for a deterministic "latest" when two runs share an instant.
   353	        runs.sort_by(|a, b| {
   354	            a.ts_epoch.cmp(&b.ts_epoch).then_with(|| a.commit_sha.cmp(&b.commit_sha))
   355	        });
   356	        let v = evaluate_group(&ac_id, n, &runs);
   357	        report.flagged |= v.flagged;
   358	        report.groups.push(v);
   359	    }
   360	    Ok(report)
   361	}
   362	
   363	fn print_human(report: &Report) {
   364	    println!("perf-regression-check — {} group(s)\n", report.groups.len());
   365	    for g in &report.groups {
   366	        let marker = if g.flagged {
   367	            "REGRESSION"
   368	        } else if g.status == "insufficient-history" {
   369	            "insufficient"
   370	        } else {
   371	            "ok"
   372	        };
   373	        println!(
   374	            "[{marker}] {} @ n={} — {} run(s), latest {} ({})",
   375	            g.ac_id, g.n, g.runs, g.latest_commit, g.latest_timestamp
   376	        );
   377	        for reason in &g.reasons {
   378	            println!("    - {reason}");
   379	        }
   380	    }
   381	    println!();
   382	    if report.flagged {
   383	        println!("RESULT: regression(s) flagged.");
   384	    } else {
   385	        println!("RESULT: no regressions.");
   386	    }
   387	}
   388	
   389	fn print_usage() {
   390	    eprintln!(
   391	        "usage: perf-regression-check <perf-history-dir> [--json]\n\
   392	         \n\
   393	         Reads the append-only perf-history directory, groups runs by\n\
   394	         (ac_id, n), and flags the latest run vs the rolling median of the\n\
   395	         prior up-to-{ROLLING_WINDOW} runs.\n\
   396	         Exit: 0 = clean, 1 = regression flagged, 2 = data missing/malformed."
   397	    );
   398	}
