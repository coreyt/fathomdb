{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LmbCJXb1dnJNRqoJLbed7L","type":"tool_result","content":"1\t\"\"\"FFI safety-contract tests for the PyO3 binding.\n2\t\n3\tCovers AC-067 (panic catch), AC-068a (embedded NUL rejected), and\n4\tAC-068b (unpaired UTF-16 surrogate rejected). The contract is locked\n5\there for Python and mirrored by the napi-rs binding in Phase 11b.\n6\t\"\"\"\n7\t\n8\tfrom __future__ import annotations\n9\t\n10\timport os\n11\t\n12\timport pytest\n13\t\n14\tfrom fathomdb import Engine, admin\n15\tfrom fathomdb._fathomdb import force_panic_for_test\n16\tfrom fathomdb.errors import EngineError, WriteValidationError\n17\t\n18\t\n19\tdef test_panic_surfaces_as_python_exception(db_path: str) -> None:\n20\t    \"\"\"AC-067 — engine panics must not abort the host process.\n21\t\n22\t    The binding must raise PyO3's `PanicException` (not `EngineError`):\n23\t    panic is a contract bug, not a typed engine outcome, so callers that\n24\t    catch `EngineError` must not silently swallow it.\n25\t    \"\"\"\n26\t\n27\t    pid_before = os.getpid()\n28\t    with pytest.raises(BaseException) as excinfo:\n29\t        force_panic_for_test()\n30\t    pid_after = os.getpid()\n31\t    assert pid_before == pid_after, \"host process must not be aborted by engine panic\"\n32\t\n33\t    exc_type = type(excinfo.value)\n34\t    assert exc_type.__name__ == \"PanicException\", (\n35\t        f\"expected pyo3 PanicException, got {exc_type.__module__}.{exc_type.__name__}\"\n36\t    )\n37\t    assert exc_type.__module__ == \"pyo3_runtime\", (\n38\t        f\"PanicException must come from pyo3_runtime, got {exc_type.__module__}\"\n39\t    )\n40\t    assert not isinstance(excinfo.value, EngineError), (\n41\t        \"PanicException must NOT subclass EngineError\"\n42\t    )\n43\t\n44\t    # Subsequent engine work must still succeed.\n45\t    engine = Engine.open(db_path)\n46\t    try:\n47\t        snapshot = engine.counters()\n48\t        assert snapshot is not None\n49\t    finally:\n50\t        engine.close()\n51\t\n52\t\n53\tdef test_embedded_nul_in_body_rejected_before_write(db_path: str) -> None:\n54\t    \"\"\"AC-068a — embedded NUL in any FFI string raises\n55\t    WriteValidationError, and no row is written.\"\"\"\n56\t\n57\t    engine = Engine.open(db_path)\n58\t    try:\n59\t        # Register a latest-state collection so the body would otherwise\n60\t        # commit a row.\n61\t        admin.configure(engine, name=\"nul_col\", body=\"{}\")\n62\t        before = engine._native.counters().write_rows\n63\t\n64\t        with pytest.raises(WriteValidationError) as excinfo:\n65\t            engine.write(\n66\t                [\n67\t                    {\n68\t                        \"op_store\": {\n69\t                            \"collection\": \"nul_col\",\n70\t                            \"record_key\": \"k1\",\n71\t                            \"body\": '{\"x\":\"a\\x00b\"}',\n72\t                        }\n73\t                    }\n74\t                ]\n75\t            )\n76\t        assert isinstance(excinfo.value, EngineError)\n77\t\n78\t        after = engine._native.counters().write_rows\n79\t        assert after == before, \"no row may be written when a NUL is rejected\"\n80\t    finally:\n81\t        engine.close()\n82\t\n83\t\n84\tdef test_unpaired_surrogate_in_body_rejected_before_write(db_path: str) -> None:\n85\t    \"\"\"AC-068b — lone UTF-16 surrogate codepoints raise\n86\t    WriteValidationError, and no row is written.\"\"\"\n87\t\n88\t    engine = Engine.open(db_path)\n89\t    try:\n90\t        admin.configure(engine, name=\"sur_col\", body=\"{}\")\n91\t        before = engine._native.counters().write_rows\n92\t\n93\t        with pytest.raises(WriteValidationError) as excinfo:\n94\t            engine.write(\n95\t                [\n96\t                    {\n97\t                        \"op_store\": {\n98\t                            \"collection\": \"sur_col\",\n99\t                            \"record_key\": \"k1\",\n100\t                            \"body\": '{\"x\":\"a\\ud800b\"}',\n101\t                        }\n102\t                    }\n103\t                ]\n104\t            )\n105\t        assert isinstance(excinfo.value, EngineError)\n106\t\n107\t        after = engine._native.counters().write_rows\n108\t        assert after == before, \"no row may be written when a surrogate is rejected\"\n109\t    finally:\n110\t        engine.close()\n111\t\n112\t\n113\tdef test_embedded_nul_in_node_kind_rejected(db_path: str) -> None:\n114\t    \"\"\"AC-068a — applies to every FFI string field, not just bodies.\"\"\"\n115\t\n116\t    engine = Engine.open(db_path)\n117\t    try:\n118\t        with pytest.raises(WriteValidationError):\n119\t            engine.write([{\"kind\": \"do\\x00c\", \"body\": \"{}\"}])\n120\t    finally:\n121\t        engine.close()\n122\t"}]},"parent_tool_use_id":null,"session_id":"d1c788b7-12bf-4bce-9fc4-3a0fdd43bef6","uuid":"47167128-2508-468e-9b7d-83898d0c1e64","timestamp":"2026-05-16T21:04:18.458Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-11b-napi-binding-20260516T210327Z/src/python/tests/test_ffi_safety.py","content":"\"\"\"FFI safety-contract tests for the PyO3 binding.\n\nCovers AC-067 (panic catch), AC-068a (embedded NUL rejected), and\nAC-068b (unpaired UTF-16 surrogate rejected). The contract is locked\nhere for Python and mirrored by the napi-rs binding in Phase 11b.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport os\n\nimport pytest\n\nfrom fathomdb import Engine, admin\nfrom fathomdb._fathomdb import force_panic_for_test\nfrom fathomdb.errors import EngineError, WriteValidationError\n\n\ndef test_panic_surfaces_as_python_exception(db_path: str) -> None:\n    \"\"\"AC-067 — engine panics must not abort the host process.\n\n    The binding must raise PyO3's `PanicException` (not `EngineError`):\n    panic is a contract bug, not a typed engine outcome, so callers that\n    catch `EngineError` must not silently swallow it.\n    \"\"\"\n\n    pid_before = os.getpid()\n    with pytest.raises(BaseException) as excinfo:\n        force_panic_for_test()\n    pid_after = os.getpid()\n    assert pid_before == pid_after, \"host process must not be aborted by engine panic\"\n\n    exc_type = type(excinfo.value)\n    assert exc_type.__name__ == \"PanicException\", (\n        f\"expected pyo3 PanicException, got {exc_type.__module__}.{exc_type.__name__}\"\n    )\n    assert exc_type.__module__ == \"pyo3_runtime\", (\n        f\"PanicException must come from pyo3_runtime, got {exc_type.__module__}\"\n    )\n    assert not isinstance(excinfo.value, EngineError), (\n        \"PanicException must NOT subclass EngineError\"\n    )\n\n    # Subsequent engine work must still succeed.\n    engine = Engine.open(db_path)\n    try:\n        snapshot = engine.counters()\n        assert snapshot is not None\n    finally:\n        engine.close()\n\n\ndef test_embedded_nul_in_body_rejected_before_write(db_path: str) -> None:\n    \"\"\"AC-068a — embedded NUL in any FFI string raises\n    WriteValidationError, and no row is written.\"\"\"\n\n    engine = Engine.open(db_path)\n    try:\n        # Register a latest-state collection so the body would otherwise\n        # commit a row.\n        admin.configure(engine, name=\"nul_col\", body=\"{}\")\n        before = engine._native.counters().write_rows\n\n        with pytest.raises(WriteValidationError) as excinfo:\n            engine.write(\n                [\n                    {\n                        \"op_store\": {\n                            \"collection\": \"nul_col\",\n                            \"record_key\": \"k1\",\n                            \"body\": '{\"x\":\"a\\x00b\"}',\n                        }\n                    }\n                ]\n            )\n        assert isinstance(excinfo.value, EngineError)\n\n        after = engine._native.counters().write_rows\n        assert after == before, \"no row may be written when a NUL is rejected\"\n    finally:\n        engine.close()\n\n\ndef test_unpaired_surrogate_in_body_rejected_before_write(db_path: str) -> None:\n    \"\"\"AC-068b — lone UTF-16 surrogate codepoints raise\n    WriteValidationError, and no row is written.\"\"\"\n\n    engine = Engine.open(db_path)\n    try:\n        admin.configure(engine, name=\"sur_col\", body=\"{}\")\n        before = engine._native.counters().write_rows\n\n        with pytest.raises(WriteValidationError) as excinfo:\n            engine.write(\n                [\n                    {\n                        \"op_store\": {\n                            \"collection\": \"sur_col\",\n                            \"record_key\": \"k1\",\n                            \"body\": '{\"x\":\"a\\ud800b\"}',\n                        }\n                    }\n                ]\n            )\n        assert isinstance(excinfo.value, EngineError)\n\n        after = engine._native.counters().write_rows\n        assert after == before, \"no row may be written when a surrogate is rejected\"\n    finally:\n        engine.close()\n\n\ndef test_embedded_nul_in_node_kind_rejected(db_path: str) -> None:\n    \"\"\"AC-068a — applies to every FFI string field, not just bodies.\"\"\"\n\n    engine = Engine.open(db_path)\n    try:\n        with pytest.raises(WriteValidationError):\n            engine.write([{\"kind\": \"do\\x00c\", \"body\": \"{}\"}])\n    finally:\n        engine.close()\n","numLines":122,"startLine":1,"totalLines":122}}}
