{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QdouHmerRv2YW64ozLWKTC","type":"tool_result","content":"1272\t    pub fn write(&self, batch: &[PreparedWrite]) -> Result<WriteReceipt, EngineError> {\n1273\t        let category = if batch_is_admin(batch) {\n1274\t            lifecycle::EventCategory::Admin\n1275\t        } else {\n1276\t            lifecycle::EventCategory::Writer\n1277\t        };\n1278\t        self.emit_event(lifecycle::Phase::Started, category, None);\n1279\t        let started = Instant::now();\n1280\t        let outcome = self.write_inner(batch);\n1281\t        self.detect_slow(started, category);\n1282\t        match outcome {\n1283\t            Ok(receipt) => {\n1284\t                let rows = u64::try_from(batch.len()).unwrap_or(u64::MAX);\n1285\t                if batch_is_admin(batch) {\n1286\t                    self.counters.record_admin();\n1287\t                } else {\n1288\t                    self.counters.record_write(rows);\n1289\t                }\n1290\t                self.emit_event(lifecycle::Phase::Finished, category, None);\n1291\t                Ok(receipt)\n1292\t            }\n1293\t            Err(err) => {\n1294\t                let code = err.stable_code();\n1295\t                self.counters.record_error(code);\n1296\t                // AC-003d: capture-ordinal < raise-ordinal — Failed and Error\n1297\t                // events both fire before the EngineError returns to the caller.\n1298\t                self.emit_event(lifecycle::Phase::Failed, category, Some(code));\n1299\t                self.emit_event(\n1300\t                    lifecycle::Phase::Failed,\n1301\t                    lifecycle::EventCategory::Error,\n1302\t                    Some(code),\n1303\t                );\n1304\t                Err(err)\n1305\t            }\n1306\t        }\n1307\t    }\n1308\t\n1309\t    fn write_inner(&self, batch: &[PreparedWrite]) -> Result<WriteReceipt, EngineError> {\n1310\t        self.ensure_open()?;\n1311\t\n1312\t        if batch.is_empty() {\n1313\t            return Err(EngineError::WriteValidation);\n1314\t        }\n1315\t\n1316\t        let mut connection = self.connection.lock().map_err(|_| EngineError::Storage)?;\n1317\t        let connection = connection.as_mut().ok_or(EngineError::Closing)?;\n1318\t        let plans = validate_batch(connection, batch)?;\n1319\t        let projection_jobs = collect_projection_jobs(connection, batch)?;\n1320\t        #[cfg(debug_assertions)]\n1321\t        if self.force_next_commit_failure.swap(false, Ordering::SeqCst) {\n1322\t            return Err(EngineError::Storage);\n1323\t        }\n1324\t        let increment = u64::try_from(batch.len()).unwrap_or(u64::MAX);\n1325\t        let cursor = self.next_cursor.load(Ordering::SeqCst).saturating_add(increment);\n1326\t        let pending_projection = !projection_jobs.is_empty();\n1327\t\n1328\t        if let Err(err) = commit_batch(\n1329\t            connection,\n1330\t            batch,\n1331\t            &plans,\n1332\t            cursor,\n1333\t            pending_projection,\n1334\t            self.provenance_row_cap.load(Ordering::Relaxed),\n1335\t        ) {\n1336\t            self.emit_sqlite_internal_error(&err);\n1337\t            return Err(EngineError::Storage);\n1338\t        }\n1339\t        self.next_cursor.store(cursor, Ordering::SeqCst);\n1340\t        if pending_projection {\n1341\t            self.projection_runtime.notify_new_work();\n1342\t        }\n1343\t\n1344\t        Ok(WriteReceipt { cursor })\n1345\t    }\n1346\t\n1347\t    pub fn search(&self, query: &str) -> Result<SearchResult, EngineError> {\n1348\t        self.emit_event(lifecycle::Phase::Started, lifecycle::EventCategory::Search, None);\n1349\t        let started = Instant::now();\n1350\t        let outcome = self.search_inner(query);\n1351\t        self.detect_slow(started, lifecycle::EventCategory::Search);"}]},"parent_tool_use_id":null,"session_id":"d1c788b7-12bf-4bce-9