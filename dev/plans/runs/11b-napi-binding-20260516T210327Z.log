{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N7gUesfomBiE3smR1ZEvQj","type":"tool_result","content":"55\t    await admin.configure(engine, { name: \"nul_col\", body: \"{}\" });\n56\t    const before = engine.counters().writeRows;\n57\t\n58\t    await assert.rejects(\n59\t      () =>\n60\t        engine.write([\n61\t          {\n62\t            opStore: {\n63\t              collection: \"nul_col\",\n64\t              recordKey: \"k1\",\n65\t              body: '{\"x\":\"a\u0000b\"}',\n66\t            },\n67\t          },\n68\t        ]),\n69\t      (err: unknown) => {\n70\t        assert.ok(err instanceof WriteValidationError, \"must be WriteValidationError\");\n71\t        assert.ok(err instanceof FathomDbError, \"must extend FathomDbError\");\n72\t        return true;\n73\t      },\n74\t    );\n75\t\n76\t    const after = engine.counters().writeRows;\n77\t    assert.equal(after, before, \"no row may be written when a NUL is rejected\");\n78\t  } finally {\n79\t    await engine.close();\n80\t  }\n81\t});\n82\t\n83\ttest(\"AC-068b unpaired UTF-16 surrogate in op-store body rejected as WriteValidationError\", async () => {\n84\t  const engine = await Engine.open(freshDbPath());"}]},"parent_tool_use_id":null,"session_id":"d1c788b7-12bf-4bce-9fc4-3a0fdd43bef6","uuid":"4c331a7e-d78a-4c6a-b0c8-f66f853e4ca9","timestamp":"2026-05-16T21:10:25.077Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-11b-napi-binding-20260516T210327Z/src/ts/tests/ffi-safety.test.ts","content":"    await admin.configure(engine, { name: \"nul_col\", body: \"{}\" });\n    const before = engine.counters().writeRows;\n\n    await assert.rejects(\n      () =>\n        engine.write([\n          {\n            opStore: {\n              collection: \"nul_col\",\n              recordKey: \"k1\",\n              body: '{\"x\":\"a\u0000b\"}',\n            },\n          },\n        ]),\n      (err: unknown) => {\n        assert.ok(err instanceof WriteValidationError, \"must be WriteValidationError\");\n        assert.ok(err instanceof FathomDbError, \"must extend FathomDbError\");\n        return true;\n      },\n    );\n\n    const after = engine.counters().writeRows;\n    assert.equal(after, before, \"no row may be written when a NUL is rejected\");\n  } finally {\n    await engine.close();\n  }\n});\n\ntest(\"AC-068b unpaired UTF-16 surrogate in op-store body rejected as WriteValidationError\", async () => {\n  const engine = await Engine.open(freshDbPath());","numLines":30,"startLine":55,"totalLines":129}}}
