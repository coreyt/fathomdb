{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MEUTwmuhjJUEALW5xG5RiZ","type":"tool_result","content":"1\t// FathomDB TypeScript SDK public surface.\n2\t//\n3\t// Five-verb top-level surface, options.engineConfig camelCase knobs, and\n4\t// caller-visible result shapes per `dev/interfaces/typescript.md`. napi-rs\n5\t// wiring lands in a follow-up slice; the 0.6.0 surface-stub keeps the\n6\t// engine in pure TypeScript so parser and error-hierarchy tests run.\n7\t\n8\timport { ClosingError, WriteValidationError } from \"./errors.js\";\n9\t\n10\texport * from \"./errors.js\";\n11\t\n12\t/**\n13\t * Engine-owned runtime knobs.\n14\t *\n15\t * Field set mirrors the Python EngineConfig in camelCase per\n16\t * `dev/interfaces/typescript.md` § Runtime surface.\n17\t */\n18\texport interface EngineConfig {\n19\t  embedderPoolSize?: number;\n20\t  schedulerRuntimeThreads?: number;\n21\t  provenanceRowCap?: number;\n22\t  embedderCallTimeoutMs?: number;\n23\t  slowThresholdMs?: number;\n24\t}\n25\t\n26\t/** Options object accepted by `Engine.open`. */\n27\texport interface EngineOpenOptions {\n28\t  engineConfig?: EngineConfig;\n29\t}\n30\t\n31\texport interface WriteReceipt {\n32\t  cursor: number;\n33\t}\n34\t\n35\texport type SoftFallbackBranch = \"vector\" | \"text\";\n36\t\n37\texport interface SoftFallback {\n38\t  branch: SoftFallbackBranch;\n39\t}\n40\t\n41\texport interface SearchResult {\n42\t  projectionCursor: number;\n43\t  softFallback: SoftFallback | null;\n44\t  results: string[];\n45\t}\n46\t\n47\texport interface CounterSnapshot {}\n48\t\n49\texport interface SubscriberEvent {}\n50\t\n51\texport type SubscriberCallback = (event: SubscriberEvent) => void;\n52\t\n53\texport interface AttachSubscriberOptions {\n54\t  heartbeatIntervalMs?: number;\n55\t}\n56\t\n57\texport interface AdminConfigureOptions {\n58\t  name: string;\n59\t  body: string;\n60\t}\n61\t\n62\texport class Engine {\n63\t  readonly path: string;\n64\t  readonly config: EngineConfig;\n65\t  #cursor = 0;\n66\t  #closed = false;\n67\t\n68\t  private constructor(path: string, config: EngineConfig) {\n69\t    this.path = path;\n70\t    this.config = config;\n71\t  }\n72\t\n73\t  static async open(path: string, options: EngineOpenOptions = {}): Promise<Engine> {\n74\t    return new Engine(path, options.engineConfig ?? {});\n75\t  }\n76\t\n77\t  async write(batch: unknown[] = []): Promise<WriteReceipt> {\n78\t    this.ensureOpen();\n79\t    this.#cursor += Math.max(batch.length, 1);\n80\t    return { cursor: this.#cursor };\n81\t  }\n82\t\n83\t  async search(query: string): Promise<SearchResult> {\n84\t    this.ensureOpen();\n85\t    const normalized = query.trim();\n86\t    if (normalized.length === 0) {\n87\t      throw new WriteValidationError(\"query must not be empty\");\n88\t    }\n89\t    return {\n90\t      projectionCursor: this.#cursor,\n91\t      softFallback: null,\n92\t      results: [`rewrite scaffold query: ${normalized}`],\n93\t    };\n94\t  }\n95\t\n96\t  async close(): Promise<void> {\n97\t    this.#closed = true;\n98\t  }\n99\t\n100\t  async drain(timeoutMs: number): Promise<void> {\n101\t    void timeoutMs;\n102\t  }\n103\t\n104\t  counters(): CounterSnapshot {\n105\t    return {};\n106\t  }\n107\t\n108\t  async setProfiling(enabled: boolean): Promise<void> {\n109\t    void enabled;\n110\t  }\n111\t\n112\t  async setSlowThresholdMs(value: number): Promise<void> {\n113\t    void value;\n114\t  }\n115\t\n116\t  attachSubscriber(callback: SubscriberCallback, options: AttachSubscriberOptions = {}): void {\n117\t    void callback;\n118\t    void options;\n119\t  }\n120\t\n121\t  /** @internal used by `admin.configure`. */\n122\t  recordAdminConfigure(_options: AdminConfigureOptions): WriteReceipt {\n123\t    this.ensureOpen();\n124\t    this.#cursor += 1;\n125\t    return { cursor: this.#cursor };\n126\t  }\n127\t\n128\t  private ensureOpen(): void {\n129\t    if (this.#closed) {\n130\t      throw new ClosingError(\"engine is closed\");\n131\t    }\n132\t  }\n133\t}\n134\t\n135\t/**\n136\t * Admin namespace exposing the fifth canonical SDK verb.\n137\t *\n138\t * Per `dev/interfaces/typescript.md` § Runtime surface, `admin.configure` is\n139\t * the cross-binding admin entry point. The 0.6.0 stub does not commit\n140\t * anything to a real engine.\n141\t */\n142\texport const admin = {\n143\t  async configure(engine: Engine, options: AdminConfigureOptions): Promise<WriteReceipt> {\n144\t    if (!options.name) {\n145\t      throw new Error(\"admin.configure requires a non-empty name\");\n146\t    }\n147\t    return engine.recordAdminConfigure(options);\n148\t  },\n149\t};\n150\t"}]},"parent_tool_use_id":null,"session_id":"d1c788b7-12bf-4bce-9fc4-3a0fdd43bef6","uuid":"6ac07bc3-6da1-45d0-8ef7-bb3969921177","timestamp":"2026-05-16T21:03:47.323Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-11b-napi-binding-20260516T210327Z/src/ts/src/index.ts","content":"// FathomDB TypeScript SDK public surface.\n//\n// Five-verb top-level surface, options.engineConfig camelCase knobs, and\n// caller-visible result shapes per `dev/interfaces/typescript.md`. napi-rs\n// wiring lands in a follow-up slice; the 0.6.0 surface-stub keeps the\n// engine in pure TypeScript so parser and error-hierarchy tests run.\n\nimport { ClosingError, WriteValidationError } from \"./errors.js\";\n\nexport * from \"./errors.js\";\n\n/**\n * Engine-owned runtime knobs.\n *\n * Field set mirrors the Python EngineConfig in camelCase per\n * `dev/interfaces/typescript.md` § Runtime surface.\n */\nexport interface EngineConfig {\n  embedderPoolSize?: number;\n  schedulerRuntimeThreads?: number;\n  provenanceRowCap?: number;\n  embedderCallTimeoutMs?: number;\n  slowThresholdMs?: number;\n}\n\n/** Options object accepted by `Engine.open`. */\nexport interface EngineOpenOptions {\n  engineConfig?: EngineConfig;\n}\n\nexport interface WriteReceipt {\n  cursor: number;\n}\n\nexport type SoftFallbackBranch = \"vector\" | \"text\";\n\nexport interface SoftFallback {\n  branch: SoftFallbackBranch;\n}\n\nexport interface SearchResult {\n  projectionCursor: number;\n  softFallback: SoftFallback | null;\n  results: string[];\n}\n\nexport interface CounterSnapshot {}\n\nexport interface SubscriberEvent {}\n\nexport type SubscriberCallback = (event: SubscriberEvent) => void;\n\nexport interface AttachSubscriberOptions {\n  heartbeatIntervalMs?: number;\n}\n\nexport interface AdminConfigureOptions {\n  name: string;\n  body: string;\n}\n\nexport class Engine {\n  readonly path: string;\n  readonly config: EngineConfig;\n  #cursor = 0;\n  #closed = false;\n\n  private constructor(path: string, config: EngineConfig) {\n    this.path = path;\n    this.config = config;\n  }\n\n  static async open(path: string, options: EngineOpenOptions = {}): Promise<Engine> {\n    return new Engine(path, options.engineConfig ?? {});\n  }\n\n  async write(batch: unknown[] = []): Promise<WriteReceipt> {\n    this.ensureOpen();\n    this.#cursor += Math.max(batch.length, 1);\n    return { cursor: this.#cursor };\n  }\n\n  async search(query: string): Promise<SearchResult> {\n    this.ensureOpen();\n    const normalized = query.trim();\n    if (normalized.length === 0) {\n      throw new WriteValidationError(\"query must not be empty\");\n    }\n    return {\n      projectionCursor: this.#cursor,\n      softFallback: null,\n      results: [`rewrite scaffold query: ${normalized}`],\n    };\n  }\n\n  async close(): Promise<void> {\n    this.#closed = true;\n  }\n\n  async drain(timeoutMs: number): Promise<void> {\n    void timeoutMs;\n  }\n\n  counters(): CounterSnapshot {\n    return {};\n  }\n\n  async setProfiling(enabled: boolean): Promise<void> {\n    void enabled;\n  }\n\n  async setSlowThresholdMs(value: number): Promise<void> {\n    void value;\n  }\n\n  attachSubscriber(callback: SubscriberCallback, options: AttachSubscriberOptions = {}): void {\n    void callback;\n    void options;\n  }\n\n  /** @internal used by `admin.configure`. */\n  recordAdminConfigure(_options: AdminConfigureOptions): WriteReceipt {\n    this.ensureOpen();\n    this.#cursor += 1;\n    return { cursor: this.#cursor };\n  }\n\n  private ensureOpen(): void {\n    if (this.#closed) {\n      throw new ClosingError(\"engine is closed\");\n    }\n  }\n}\n\n/**\n * Admin namespace exposing the fifth canonical SDK verb.\n *\n * Per `dev/interfaces/typescript.md` § Runtime surface, `admin.configure` is\n * the cross-binding admin entry point. The 0.6.0 stub does not commit\n * anything to a real engine.\n */\nexport const admin = {\n  async configure(engine: Engine, options: AdminConfigureOptions): Promise<WriteReceipt> {\n    if (!options.name) {\n      throw new Error(\"admin.configure requires a non-empty name\");\n    }\n    return engine.recordAdminConfigure(options);\n  },\n};\n","numLines":150,"startLine":1,"totalLines":150}}}
