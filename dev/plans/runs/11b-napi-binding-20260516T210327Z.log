{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0131Tsfd3uB6M7dRXFvapRUb","type":"tool_result","content":"1\t// pyo3 0.22's `create_exception!` and `#[pymodule]` macros emit\n2\t// `#[cfg(feature = \"gil-refs\")]` arms that reference an upstream\n3\t// feature this crate does not export; the resulting `unexpected_cfgs`\n4\t// warnings are noise on a clippy `-D warnings` gate. The\n5\t// `useless_conversion` allow covers `#[pymethods]`-generated PyResult\n6\t// wrappers that clippy flags as redundant `Into<PyErr>` calls.\n7\t#![allow(unexpected_cfgs)]\n8\t#![allow(clippy::useless_conversion)]\n9\t\n10\t//! PyO3 binding from the Python SDK to `fathomdb-engine`.\n11\t//!\n12\t//! FFI safety contract (mirrored by Phase 11b napi-rs):\n13\t//!\n14\t//! 1. Every method that may block inside the engine wraps the call in\n15\t//!    `py.allow_threads(...)` so the GIL is released for the duration.\n16\t//! 2. Engine entry points return typed errors via [`engine_error_to_py`] /\n17\t//!    [`engine_open_error_to_py`] — single-switch mapping with no\n18\t//!    catch-all arm; the binding fails to compile when the Rust variant\n19\t//!    set drifts from the Python class set (AC-060a).\n20\t//! 3. Every string crossing the FFI is checked by [`validate_ffi_string`]\n21\t//!    for embedded NUL or unpaired UTF-16 surrogates BEFORE the writer\n22\t//!    transaction opens (AC-068a / AC-068b).\n23\t//! 4. Panics inside engine code surface as Python `PanicException`\n24\t//!    instances (PyO3 `pyo3::panic::PanicException`); the host process\n25\t//!    is not aborted (AC-067). Engine calls are wrapped in\n26\t//!    `catch_unwind` so the panic is translated on the Rust side rather\n27\t//!    than relying on PyO3's implicit conversion at the FFI boundary.\n28\t//!    PanicException is intentionally NOT an `EngineError` subclass:\n29\t//!    panic is a contract bug, not a typed engine outcome, and callers\n30\t//!    that catch `EngineError` must not silently swallow it.\n31\t\n32\tuse std::panic::{catch_unwind, AssertUnwindSafe};\n33\tuse std::sync::Arc;\n34\t\n35\tuse fathomdb_engine::{\n36\t    CorruptionDetail, CorruptionKind, Engine as RustEngine, EngineError as RustEngineError,\n37\t    EngineOpenError, OpenStage, PreparedWrite, SearchResult as RustSearchResult,\n38\t    SoftFallback as RustSoftFallback, SoftFallbackBranch, WriteReceipt as RustWriteReceipt,\n39\t};\n40\tuse pyo3::create_exception;\n41\tuse pyo3::exceptions::{PyException, PyTypeError, PyValueError};\n42\tuse pyo3::panic::PanicException;\n43\tuse pyo3::prelude::*;\n44\tuse pyo3::types::{PyDict, PyList};\n45\t\n46\t// ===== Exceptions =====================================================\n47\t//\n48\t// Root + concrete leaves per dev/design/errors.md § Binding-facing class\n49\t// matrix. All concrete leaves inherit from `EngineError`; `EngineError`\n50\t// inherits from Python `Exception` via `create_exception!`.\n51\t\n52\tcreate_exception!(_fathomdb, EngineError, PyException);\n53\tcreate_exception!(_fathomdb, StorageError, EngineError);\n54\tcreate_exception!(_fathomdb, ProjectionError, EngineError);\n55\tcreate_exception!(_fathomdb, VectorError, EngineError);\n56\tcreate_exception!(_fathomdb, KindNotVectorIndexedError, VectorError);\n57\tcreate_exception!(_fathomdb, EmbedderError, EngineError);\n58\tcreate_exception!(_fathomdb, EmbedderNotConfiguredError, EmbedderError);\n59\tcreate_exception!(_fathomdb, SchedulerError, EngineError);\n60\tcreate_exception!(_fathomdb, OpStoreError, EngineError);\n61\tcreate_exception!(_fathomdb, WriteValidationError, EngineError);\n62\tcreate_exception!(_fathomdb, SchemaValidationError, EngineError);\n63\tcreate_exception!(_fathomdb, OverloadedError, EngineError);\n64\tcreate_exception!(_fathomdb, ClosingError, EngineError);\n65\tcreate_exception!(_fathomdb, DatabaseLockedError, EngineError);\n66\tcreate_exception!(_fathomdb, CorruptionError, EngineError);\n67\tcreate_exception!(_fathomdb, IncompatibleSchemaVersionError, EngineError);\n68\tcreate_exception!(_fathomdb, MigrationError, EngineError);\n69\tcreate_exception!(_fathomdb, EmbedderIdentityMismatchError, EngineError);\n70\tcreate_exception!(_fathomdb, EmbedderDimensionMismatchError, EngineError);\n71\t\n72\t// ===== String validation (AC-068a / AC-068b) =========================\n73\t\n74\t/// Reject strings carrying an embedded NUL or an unpaired UTF-16\n75\t/// surrogate codepoint (`U+D800..=U+DFFF`).\n76\t///\n77\t/// Both are valid Python `str` values but invalid for SQLite text\n78\t/// columns; AC-068a/b requires the binding to reject them BEFORE the\n79\t/// writer transaction opens (no-row-written invariant).\n80\tpub fn validate_ffi_string(value: &str) -> Result<(), String> {\n81\t    if value.as_bytes().contains(&0) {\n82\t        return Err(\"embedded NUL byte in FFI string\".to_string());\n83\t    }\n84\t    for ch in value.chars() {\n85\t        let cp = ch as u32;\n86\t        if (0xD800..=0xDFFF).contains(&cp) {\n87\t            return Err(format!(\"unpaired UTF-16 surrogate U+{cp:04X} in FFI string\"));\n88\t        }\n89\t    }\n90\t    Ok(())\n91\t}\n92\t\n93\tfn validate_ffi_string_py(value: &str) -> PyResult<()> {\n94\t    validate_ffi_string(value).map_err(WriteValidationError::new_err)\n95\t}\n96\t\n97\t/// Extract a Python string into a Rust `String` and run\n98\t/// [`validate_ffi_string_py`]. PyO3's built-in `str` extraction already\n99\t/// fails on lone surrogates (the underlying `PyUnicode_AsUTF8AndSize`\n100\t/// raises `UnicodeEncodeError`); we re-raise those as the typed\n101\t/// `WriteValidationError` so callers can dispatch on a single class.\n102\tfn extract_validated_str(value: &Bound<'_, PyAny>) -> PyResult<String> {\n103\t    match value.extract::<String>() {\n104\t        Ok(s) => {\n105\t            validate_ffi_string_py(&s)?;\n106\t            Ok(s)\n107\t        }\n108\t        Err(_) => Err(WriteValidationError::new_err(\n109\t            \"string contains characters not representable as UTF-8 (lone surrogate)\",\n110\t        )),\n111\t    }\n112\t}\n113\t\n114\t// ===== Error mapping ==================================================\n115\t\n116\t/// Translate every `EngineError` variant to its Python counterpart.\n117\t///\n118\t/// No catch-all arm: drift between the Rust enum and the Python class\n119\t/// set is a compile error.\n120\tfn engine_error_to_py(err: RustEngineError) -> PyErr {\n121\t    match err {\n122\t        RustEngineError::Storage => StorageError::new_err(\"storage error\"),\n123\t        RustEngineError::Projection => ProjectionError::new_err(\"projection error\"),\n124\t        RustEngineError::Vector => VectorError::new_err(\"vector error\"),\n125\t        RustEngineError::Embedder => EmbedderError::new_err(\"embedder error\"),\n126\t        RustEngineError::EmbedderNotConfigured => {\n127\t            EmbedderNotConfiguredError::new_err(\"embedder is not configured\")\n128\t        }\n129\t        RustEngineError::KindNotVectorIndexed => {\n130\t            KindNotVectorIndexedError::new_err(\"kind is not configured for vector indexing\")\n131\t        }\n132\t        RustEngineError::EmbedderDimensionMismatch { expected, actual } => {\n133\t            let exc = EmbedderDimensionMismatchError::new_err(format!(\n134\t                \"embedder vector dimension mismatch: stored {expected}, supplied {actual}\",\n135\t            ));\n136\t            Python::with_gil(|py| {\n137\t                let v = exc.value_bound(py);\n138\t                let _ = v.setattr(\"stored\", expected);\n139\t                let _ = v.setattr(\"supplied\", actual);\n140\t            });\n141\t            exc\n142\t        }\n143\t        RustEngineError::Scheduler => SchedulerError::new_err(\"scheduler error\"),\n144\t        RustEngineError::OpStore => OpStoreError::new_err(\"op-store error\"),\n145\t        RustEngineError::WriteValidation => WriteValidationError::new_err(\"write validation error\"),\n146\t        RustEngineError::SchemaValidation => {\n147\t            SchemaValidationError::new_err(\"schema validation error\")\n148\t        }\n149\t        RustEngineError::Overloaded => OverloadedError::new_err(\"engine overloaded\"),\n150\t        RustEngineError::Closing => ClosingError::new_err(\"engine is closing\"),\n151\t    }\n152\t}\n153\t\n154\tfn corruption_kind_str(kind: CorruptionKind) -> &'static str {\n155\t    match kind {\n156\t        CorruptionKind::WalReplayFailure => \"WalReplayFailure\",\n157\t        CorruptionKind::HeaderMalformed => \"HeaderMalformed\",\n158\t        CorruptionKind::SchemaInconsistent => \"SchemaInconsistent\",\n159\t        CorruptionKind::EmbedderIdentityDrift => \"EmbedderIdentityDrift\",\n160\t    }\n161\t}\n162\t\n163\tfn open_stage_str(stage: OpenStage) -> &'static str {\n164\t    match stage {\n165\t        OpenStage::HeaderProbe => \"HeaderProbe\",\n166\t        OpenStage::WalReplay => \"WalReplay\",\n167\t        OpenStage::SchemaProbe => \"SchemaProbe\",\n168\t        OpenStage::EmbedderIdentity => \"EmbedderIdentity\",\n169\t    }\n170\t}\n171\t\n172\tfn engine_open_error_to_py(err: EngineOpenError) -> PyErr {\n173\t    match err {\n174\t        EngineOpenError::DatabaseLocked { holder_pid } => {\n175\t            let exc = DatabaseLockedError::new_err(match holder_pid {\n176\t                Some(pid) => format!(\"database is locked by process {pid}\"),\n177\t                None => \"database is locked by another engine instance\".to_string(),\n178\t            });\n179\t            Python::with_gil(|py| {\n180\t                let _ = exc.value_bound(py).setattr(\"holder_pid\", holder_pid);\n181\t            });\n182\t            exc\n183\t        }\n184\t        EngineOpenError::Corruption(detail) => corruption_to_py(detail),\n185\t        EngineOpenError::IncompatibleSchemaVersion { seen, supported } => {\n186\t            IncompatibleSchemaVersionError::new_err(format!(\n187\t                \"database schema version {seen} is incompatible with supported version {supported}\"\n188\t            ))\n189\t        }\n190\t        EngineOpenError::MigrationError {\n191\t            schema_version_before,\n192\t            schema_version_current,\n193\t            step_id,\n194\t        } => MigrationError::new_err(format!(\n195\t            \"schema migration failed at step {step_id}; schema version remained between {schema_version_before} and {schema_version_current}\"\n196\t        )),\n197\t        EngineOpenError::EmbedderIdentityMismatch { stored, supplied } => {\n198\t            let exc = EmbedderIdentityMismatchError::new_err(format!(\n199\t                \"embedder identity mismatch: stored {}@{}, supplied {}@{}\",\n200\t                stored.name, stored.revision, supplied.name, supplied.revision,\n201\t            ));\n202\t            Python::with_gil(|py| {\n203\t                let v = exc.value_bound(py);\n204\t                let _ = v.setattr(\"stored_name\", stored.name);\n205\t                let _ = v.setattr(\"stored_revision\", stored.revision);\n206\t                let _ = v.setattr(\"supplied_name\", supplied.name);\n207\t                let _ = v.setattr(\"supplied_revision\", supplied.revision);\n208\t            });\n209\t            exc\n210\t        }\n211\t        EngineOpenError::EmbedderDimensionMismatch { stored, supplied } => {\n212\t            let exc = EmbedderDimensionMismatchError::new_err(format!(\n213\t                \"embedder vector dimension mismatch: stored {stored}, supplied {supplied}\",\n214\t            ));\n215\t            Python::with_gil(|py| {\n216\t                let v = exc.value_bound(py);\n217\t                let _ = v.setattr(\"stored\", stored);\n218\t                let _ = v.setattr(\"supplied\", supplied);\n219\t            });\n220\t            exc\n221\t        }\n222\t        EngineOpenError::Io { message } => {\n223\t            StorageError::new_err(format!(\"database I/O error: {message}\"))\n224\t        }\n225\t    }\n226\t}\n227\t\n228\tfn corruption_to_py(detail: CorruptionDetail) -> PyErr {\n229\t    let kind = corruption_kind_str(detail.kind);\n230\t    let stage = open_stage_str(detail.stage);\n231\t    let recovery_hint_code = detail.recovery_hint.code;\n232\t    let doc_anchor = detail.recovery_hint.doc_anchor;\n233\t    let exc = CorruptionError::new_err(format!(\n234\t        \"corruption {kind} at stage {stage} ({recovery_hint_code})\"\n235\t    ));\n236\t    Python::with_gil(|py| {\n237\t        let v = exc.value_bound(py);\n238\t        let _ = v.setattr(\"kind\", kind);\n239\t        let _ = v.setattr(\"stage\", stage);\n240\t        let _ = v.setattr(\"recovery_hint_code\", recovery_hint_code);\n241\t        let _ = v.setattr(\"doc_anchor\", doc_anchor);\n242\t    });\n243\t    exc\n244\t}\n245\t\n246\t/// Run the engine call inside `py.allow_threads` and `catch_unwind`;\n247\t/// translate any escaping panic to `EngineError`.\n248\t///\n249\t/// `AssertUnwindSafe` wraps the caller's closure so we do not need to\n250\t/// require `UnwindSafe` from `f`. The engine's `Arc<dyn Embedder>`\n251\t/// makes the natural `UnwindSafe` bound unsatisfiable; the engine\n252\t/// itself takes care of its own atomicity post-panic.\n253\tfn call_engine<R: Send>(\n254\t    py: Python<'_>,\n255\t    f: impl FnOnce() -> Result<R, RustEngineError> + Send,\n256\t) -> PyResult<R> {\n257\t    let wrapped = AssertUnwindSafe(f);\n258\t    let result = py.allow_threads(|| catch_unwind(wrapped));\n259\t    match result {\n260\t        Ok(Ok(value)) => Ok(value),\n261\t        Ok(Err(err)) => Err(engine_error_to_py(err)),\n262\t        Err(_) => Err(PanicException::new_err(\"engine panic (see logs)\")),\n263\t    }\n264\t}\n265\t\n266\t// ===== Data classes ===================================================\n267\t\n268\t#[pyclass(module = \"fathomdb._fathomdb\", name = \"WriteReceipt\", frozen, get_all)]\n269\t#[derive(Clone)]\n270\tstruct PyWriteReceipt {\n271\t    cursor: u64,\n272\t}\n273\t\n274\timpl PyWriteReceipt {\n275\t    fn from_rust(r: RustWriteReceipt) -> Self {\n276\t        Self { cursor: r.cursor }\n277\t    }\n278\t}\n279\t\n280\t#[pyclass(module = \"fathomdb._fathomdb\", name = \"SoftFallback\", frozen, get_all)]\n281\t#[derive(Clone)]\n282\tstruct PySoftFallback {\n283\t    branch: String,\n284\t}\n285\t\n286\timpl PySoftFallback {\n287\t    fn from_rust(s: &RustSoftFallback) -> Self {\n288\t        Self {\n289\t            branch: match s.branch {\n290\t                SoftFallbackBranch::Vector => \"vector\".to_string(),\n291\t                SoftFallbackBranch::Text => \"text\".to_string(),\n292\t            },\n293\t        }\n294\t    }\n295\t}\n296\t\n297\t#[pyclass(module = \"fathomdb._fathomdb\", name = \"SearchResult\", frozen, get_all)]\n298\t#[derive(Clone)]\n299\tstruct PySearchResult {\n300\t    projection_cursor: u64,\n301\t    soft_fallback: Option<PySoftFallback>,\n302\t    results: Vec<String>,\n303\t}\n304\t\n305\timpl PySearchResult {\n306\t    fn from_rust(r: RustSearchResult) -> Self {\n307\t        Self {\n308\t            projection_cursor: r.projection_cursor,\n309\t            soft_fallback: r.soft_fallback.as_ref().map(PySoftFallback::from_rust),\n310\t            results: r.results,\n311\t        }\n312\t    }\n313\t}\n314\t\n315\t#[pyclass(module = \"fathomdb._fathomdb\", name = \"CounterSnapshot\", frozen, get_all)]\n316\t#[derive(Clone)]\n317\tstruct PyCounterSnapshot {\n318\t    queries: u64,\n319\t    writes: u64,\n320\t    write_rows: u64,\n321\t    admin_ops: u64,\n322\t    cache_hit: u64,\n323\t    cache_miss: u64,\n324\t}\n325\t\n326\t// ===== Engine =========================================================\n327\t\n328\t#[pyclass(module = \"fathomdb._fathomdb\", name = \"Engine\")]\n329\tstruct PyEngine {\n330\t    inner: Arc<RustEngine>,\n331\t}\n332\t\n333\t#[pymethods]\n334\timpl PyEngine {\n335\t    #[staticmethod]\n336\t    #[pyo3(signature = (path))]\n337\t    fn open(py: Python<'_>, path: String) -> PyResult<Self> {\n338\t        validate_ffi_string_py(&path)?;\n339\t        let opened = py\n340\t            .allow_threads(|| catch_unwind(AssertUnwindSafe(|| RustEngine::open(path))))\n341\t            .map_err(|_| PanicException::new_err(\"engine panic during open\"))?\n342\t            .map_err(engine_open_error_to_py)?;\n343\t        Ok(Self { inner: Arc::new(opened.engine) })\n344\t    }\n345\t\n346\t    fn write(&self, py: Python<'_>, batch: Bound<'_, PyList>) -> PyResult<PyWriteReceipt> {\n347\t        let prepared = translate_batch(&batch)?;\n348\t        let engine = Arc::clone(&self.inner);\n349\t        let receipt = call_engine(py, move || engine.write(&prepared))?;\n350\t        Ok(PyWriteReceipt::from_rust(receipt))\n351\t    }\n352\t\n353\t    fn search(&self, py: Python<'_>, query: &str) -> PyResult<PySearchResult> {\n354\t        validate_ffi_string_py(query)?;\n355\t        let engine = Arc::clone(&self.inner);\n356\t        let query = query.to_string();\n357\t        let result = call_engine(py, move || engine.search(&query))?;\n358\t        Ok(PySearchResult::from_rust(result))\n359\t    }\n360\t\n361\t    fn close(&self, py: Python<'_>) -> PyResult<()> {\n362\t        let engine = Arc::clone(&self.inner);\n363\t        call_engine(py, move || engine.close())\n364\t    }\n365\t\n366\t    #[pyo3(signature = (timeout_s = 0.0))]\n367\t    fn drain(&self, py: Python<'_>, timeout_s: f64) -> PyResult<()> {\n368\t        let ms =\n369\t            if timeout_s.is_finite() && timeout_s > 0.0 { (timeout_s * 1000.0) as u64 } else { 0 };\n370\t        let engine = Arc::clone(&self.inner);\n371\t        call_engine(py, move || engine.drain(ms))\n372\t    }\n373\t\n374\t    fn counters(&self) -> PyCounterSnapshot {\n375\t        let snap = self.inner.counters();\n376\t        PyCounterSnapshot {\n377\t            queries: snap.queries,\n378\t            writes: snap.writes,\n379\t            write_rows: snap.write_rows,\n380\t            admin_ops: snap.admin_ops,\n381\t            cache_hit: snap.cache_hit,\n382\t            cache_miss: snap.cache_miss,\n383\t        }\n384\t    }\n385\t\n386\t    fn set_profiling(&self, enabled: bool) -> PyResult<()> {\n387\t        self.inner.set_profiling(enabled).map_err(engine_error_to_py)\n388\t    }\n389\t\n390\t    fn set_slow_threshold_ms(&self, value: u64) -> PyResult<()> {\n391\t        self.inner.set_slow_threshold_ms(value).map_err(engine_error_to_py)\n392\t    }\n393\t\n394\t    #[pyo3(signature = (logger, heartbeat_interval_ms = None))]\n395\t    fn attach_logging_subscriber(\n396\t        &self,\n397\t        logger: Bound<'_, PyAny>,\n398\t        heartbeat_interval_ms: Option<u64>,\n399\t    ) -> PyResult<()> {\n400\t        let _ = logger;\n401\t        let _ = heartbeat_interval_ms;\n402\t        // Subscriber wiring lands in a later 0.6.x slice; the binding\n403\t        // accepts the call so callers can wire a logger against the\n404\t        // public surface.\n405\t        Ok(())\n406\t    }\n407\t}\n408\t\n409\t// ===== admin.configure ================================================\n410\t\n411\t#[pyfunction]\n412\t#[pyo3(signature = (engine, name, body))]\n413\tfn admin_configure(\n414\t    py: Python<'_>,\n415\t    engine: &PyEngine,\n416\t    name: &Bound<'_, PyAny>,\n417\t    body: &Bound<'_, PyAny>,\n418\t) -> PyResult<PyWriteReceipt> {\n419\t    let name = extract_validated_str(name)?;\n420\t    let body = extract_validated_str(body)?;\n421\t    if name.is_empty() {\n422\t        return Err(PyValueError::new_err(\"admin.configure requires a non-empty name\"));\n423\t    }\n424\t    // why: `dev/interfaces/python.md` § Runtime surface pins the\n425\t    // admin.configure(name=, body=) signature; the engine's\n426\t    // `PreparedWrite::AdminSchema` requires `kind ∈ {latest_state,\n427\t    // append_only_log}`. The Python verb is sugar over latest-state\n428\t    // collection registration in 0.6.0; an explicit `kind` knob lands\n429\t    // in a later 0.6.x slice if needed.\n430\t    let batch = vec![PreparedWrite::AdminSchema {\n431\t        name,\n432\t        kind: \"latest_state\".to_string(),\n433\t        schema_json: body,\n434\t        retention_json: \"{}\".to_string(),\n435\t    }];\n436\t    let inner = Arc::clone(&engine.inner);\n437\t    let receipt = call_engine(py, move || inner.write(&batch))?;\n438\t    Ok(PyWriteReceipt::from_rust(receipt))\n439\t}\n440\t\n441\t// ===== Batch translation ==============================================\n442\t\n443\tfn translate_batch(batch: &Bound<'_, PyList>) -> PyResult<Vec<PreparedWrite>> {\n444\t    let mut out = Vec::with_capacity(batch.len());\n445\t    for item in batch.iter() {\n446\t        out.push(translate_write_item(&item)?);\n447\t    }\n448\t    Ok(out)\n449\t}\n450\t\n451\tfn dict_get<'py>(d: &Bound<'py, PyDict>, key: &str) -> PyResult<Option<Bound<'py, PyAny>>> {\n452\t    d.get_item(key)\n453\t}\n454\t\n455\tfn dict_str(d: &Bound<'_, PyDict>, key: &str) -> PyResult<Option<String>> {\n456\t    match dict_get(d, key)? {\n457\t        Some(v) if !v.is_none() => Ok(Some(extract_validated_str(&v)?)),\n458\t        _ => Ok(None),\n459\t    }\n460\t}\n461\t\n462\tfn dict_str_required(d: &Bound<'_, PyDict>, key: &str) -> PyResult<String> {\n463\t    dict_str(d, key)?.ok_or_else(|| {\n464\t        WriteValidationError::new_err(format!(\"write item missing required field {key:?}\"))\n465\t    })\n466\t}\n467\t\n468\tfn translate_write_item(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n469\t    let dict = item\n470\t        .downcast::<PyDict>()\n471\t        .map_err(|_| WriteValidationError::new_err(\"write item must be a dict\"))?;\n472\t\n473\t    if let Some(inner) = dict_get(dict, \"edge\")? {\n474\t        return translate_edge(&inner);\n475\t    }\n476\t    if let Some(inner) = dict_get(dict, \"op_store\")? {\n477\t        return translate_op_store(&inner);\n478\t    }\n479\t    if let Some(inner) = dict_get(dict, \"admin_schema\")? {\n480\t        return translate_admin_schema(&inner);\n481\t    }\n482\t    if let Some(inner) = dict_get(dict, \"node\")? {\n483\t        return translate_node(&inner);\n484\t    }\n485\t\n486\t    // Bare `{\"kind\": ..., ...}` shape is treated as a Node — keeps the\n487\t    // five-verb test surface terse and matches the 0.6.0 Python stub.\n488\t    translate_node(item)\n489\t}\n490\t\n491\tfn translate_node(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n492\t    let dict = item\n493\t        .downcast::<PyDict>()\n494\t        .map_err(|_| WriteValidationError::new_err(\"node write item must be a dict\"))?;\n495\t    let kind = dict_str_required(dict, \"kind\")?;\n496\t    let body = dict_str(dict, \"body\")?.unwrap_or_else(|| \"{}\".to_string());\n497\t    let source_id = dict_str(dict, \"source_id\")?;\n498\t    Ok(PreparedWrite::Node { kind, body, source_id })\n499\t}\n500\t\n501\tfn translate_edge(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n502\t    let dict = item\n503\t        .downcast::<PyDict>()\n504\t        .map_err(|_| WriteValidationError::new_err(\"edge write item must be a dict\"))?;\n505\t    let kind = dict_str_required(dict, \"kind\")?;\n506\t    let from = dict_str_required(dict, \"from\")?;\n507\t    let to = dict_str_required(dict, \"to\")?;\n508\t    let source_id = dict_str(dict, \"source_id\")?;\n509\t    Ok(PreparedWrite::Edge { kind, from, to, source_id })\n510\t}\n511\t\n512\tfn translate_op_store(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n513\t    let dict = item\n514\t        .downcast::<PyDict>()\n515\t        .map_err(|_| WriteValidationError::new_err(\"op_store write item must be a dict\"))?;\n516\t    let collection = dict_str_required(dict, \"collection\")?;\n517\t    let record_key = dict_str_required(dict, \"record_key\")?;\n518\t    let schema_id = dict_str(dict, \"schema_id\")?;\n519\t    let body = dict_str_required(dict, \"body\")?;\n520\t    Ok(PreparedWrite::OpStore { collection, record_key, schema_id, body })\n521\t}\n522\t\n523\tfn translate_admin_schema(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n524\t    let dict = item\n525\t        .downcast::<PyDict>()\n526\t        .map_err(|_| PyTypeError::new_err(\"admin_schema write item must be a dict\"))?;\n527\t    let name = dict_str_required(dict, \"name\")?;\n528\t    let kind = dict_str_required(dict, \"kind\")?;\n529\t    let schema_json = dict_str_required(dict, \"schema_json\")?;\n530\t    let retention_json = dict_str(dict, \"retention_json\")?.unwrap_or_else(|| \"{}\".to_string());\n531\t    Ok(PreparedWrite::AdminSchema { name, kind, schema_json, retention_json })\n532\t}\n533\t\n534\t// ===== Test hooks =====================================================\n535\t\n536\t/// AC-067 force-panic probe. Gated by `cfg(any(test, feature =\n537\t/// \"test-hooks\"))` so release wheels built with `--no-default-features`\n538\t/// do not expose it.\n539\t#[cfg(any(test, feature = \"test-hooks\"))]\n540\t#[pyfunction]\n541\tfn force_panic_for_test() -> PyResult<()> {\n542\t    panic!(\"force_panic_for_test: AC-067 probe\");\n543\t}\n544\t\n545\t// ===== Module =========================================================\n546\t\n547\t#[pymodule]\n548\tfn _fathomdb(py: Python<'_>, m: Bound<'_, PyModule>) -> PyResult<()> {\n549\t    m.add_class::<PyEngine>()?;\n550\t    m.add_class::<PyWriteReceipt>()?;\n551\t    m.add_class::<PySoftFallback>()?;\n552\t    m.add_class::<PySearchResult>()?;\n553\t    m.add_class::<PyCounterSnapshot>()?;\n554\t    m.add_function(wrap_pyfunction!(admin_configure, &m)?)?;\n555\t\n556\t    #[cfg(any(test, feature = \"test-hooks\"))]\n557\t    m.add_function(wrap_pyfunction!(force_panic_for_test, &m)?)?;\n558\t\n559\t    m.add(\"EngineError\", py.get_type_bound::<EngineError>())?;\n560\t    m.add(\"StorageError\", py.get_type_bound::<StorageError>())?;\n561\t    m.add(\"ProjectionError\", py.get_type_bound::<ProjectionError>())?;\n562\t    m.add(\"VectorError\", py.get_type_bound::<VectorError>())?;\n563\t    m.add(\"KindNotVectorIndexedError\", py.get_type_bound::<KindNotVectorIndexedError>())?;\n564\t    m.add(\"EmbedderError\", py.get_type_bound::<EmbedderError>())?;\n565\t    m.add(\"EmbedderNotConfiguredError\", py.get_type_bound::<EmbedderNotConfiguredError>())?;\n566\t    m.add(\"SchedulerError\", py.get_type_bound::<SchedulerError>())?;\n567\t    m.add(\"OpStoreError\", py.get_type_bound::<OpStoreError>())?;\n568\t    m.add(\"WriteValidationError\", py.get_type_bound::<WriteValidationError>())?;\n569\t    m.add(\"SchemaValidationError\", py.get_type_bound::<SchemaValidationError>())?;\n570\t    m.add(\"OverloadedError\", py.get_type_bound::<OverloadedError>())?;\n571\t    m.add(\"ClosingError\", py.get_type_bound::<ClosingError>())?;\n572\t    m.add(\"DatabaseLockedError\", py.get_type_bound::<DatabaseLockedError>())?;\n573\t    m.add(\"CorruptionError\", py.get_type_bound::<CorruptionError>())?;\n574\t    m.add(\"IncompatibleSchemaVersionError\", py.get_type_bound::<IncompatibleSchemaVersionError>())?;\n575\t    m.add(\"MigrationError\", py.get_type_bound::<MigrationError>())?;\n576\t    m.add(\"EmbedderIdentityMismatchError\", py.get_type_bound::<EmbedderIdentityMismatchError>())?;\n577\t    m.add(\"EmbedderDimensionMismatchError\", py.get_type_bound::<EmbedderDimensionMismatchError>())?;\n578\t    Ok(())\n579\t}\n580\t\n581\t#[cfg(test)]\n582\tmod tests {\n583\t    use super::*;\n584\t\n585\t    #[test]\n586\t    fn validate_ffi_string_accepts_plain_ascii() {\n587\t        assert!(validate_ffi_string(\"hello\").is_ok());\n588\t    }\n589\t\n590\t    #[test]\n591\t    fn validate_ffi_string_accepts_non_ascii_utf8() {\n592\t        assert!(validate_ffi_string(\"héllo 🦀 文字\").is_ok());\n593\t    }\n594\t\n595\t    #[test]\n596\t    fn validate_ffi_string_rejects_embedded_nul() {\n597\t        let err = validate_ffi_string(\"a\\0b\").unwrap_err();\n598\t        assert!(err.contains(\"NUL\"), \"expected NUL diagnostic, got {err:?}\");\n599\t    }\n600\t\n601\t    #[test]\n602\t    fn validate_ffi_string_rejects_lone_surrogate() {\n603\t        // The surrogate codepoint U+D800 cannot appear in a Rust &str\n604\t        // (it is not valid UTF-8). The Rust-side helper exists for the\n605\t        // case where the Python layer feeds us the codepoint via an\n606\t        // alternate path; construct it through `char::from_u32`\n607\t        // unchecked... actually `char::from_u32` returns None for\n608\t        // surrogates. The exhaustive guard sits in Python; the Rust\n609\t        // helper documents the rule and remains a runtime check for\n610\t        // bytes-derived input.\n611\t        let valid_high_unicode = \"\\u{FFFD}\";\n612\t        assert!(validate_ffi_string(valid_high_unicode).is_ok());\n613\t    }\n614\t}\n615\t"}]},"parent_tool_use_id":null,"session_id":"d1c788b7-12bf-4bce-9fc4-3a0fdd43bef6","uuid":"ec896770-1611-4f4b-8489-7af861eb5640","timestamp":"2026-05-16T21:03:43.608Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-11b-napi-binding-20260516T210327Z/src/rust/crates/fathomdb-py/src/lib.rs","content":"// pyo3 0.22's `create_exception!` and `#[pymodule]` macros emit\n// `#[cfg(feature = \"gil-refs\")]` arms that reference an upstream\n// feature this crate does not export; the resulting `unexpected_cfgs`\n// warnings are noise on a clippy `-D warnings` gate. The\n// `useless_conversion` allow covers `#[pymethods]`-generated PyResult\n// wrappers that clippy flags as redundant `Into<PyErr>` calls.\n#![allow(unexpected_cfgs)]\n#![allow(clippy::useless_conversion)]\n\n//! PyO3 binding from the Python SDK to `fathomdb-engine`.\n//!\n//! FFI safety contract (mirrored by Phase 11b napi-rs):\n//!\n//! 1. Every method that may block inside the engine wraps the call in\n//!    `py.allow_threads(...)` so the GIL is released for the duration.\n//! 2. Engine entry points return typed errors via [`engine_error_to_py`] /\n//!    [`engine_open_error_to_py`] — single-switch mapping with no\n//!    catch-all arm; the binding fails to compile when the Rust variant\n//!    set drifts from the Python class set (AC-060a).\n//! 3. Every string crossing the FFI is checked by [`validate_ffi_string`]\n//!    for embedded NUL or unpaired UTF-16 surrogates BEFORE the writer\n//!    transaction opens (AC-068a / AC-068b).\n//! 4. Panics inside engine code surface as Python `PanicException`\n//!    instances (PyO3 `pyo3::panic::PanicException`); the host process\n//!    is not aborted (AC-067). Engine calls are wrapped in\n//!    `catch_unwind` so the panic is translated on the Rust side rather\n//!    than relying on PyO3's implicit conversion at the FFI boundary.\n//!    PanicException is intentionally NOT an `EngineError` subclass:\n//!    panic is a contract bug, not a typed engine outcome, and callers\n//!    that catch `EngineError` must not silently swallow it.\n\nuse std::panic::{catch_unwind, AssertUnwindSafe};\nuse std::sync::Arc;\n\nuse fathomdb_engine::{\n    CorruptionDetail, CorruptionKind, Engine as RustEngine, EngineError as RustEngineError,\n    EngineOpenError, OpenStage, PreparedWrite, SearchResult as RustSearchResult,\n    SoftFallback as RustSoftFallback, SoftFallbackBranch, WriteReceipt as RustWriteReceipt,\n};\nuse pyo3::create_exception;\nuse pyo3::exceptions::{PyException, PyTypeError, PyValueError};\nuse pyo3::panic::PanicException;\nuse pyo3::prelude::*;\nuse pyo3::types::{PyDict, PyList};\n\n// ===== Exceptions =====================================================\n//\n// Root + concrete leaves per dev/design/errors.md § Binding-facing class\n// matrix. All concrete leaves inherit from `EngineError`; `EngineError`\n// inherits from Python `Exception` via `create_exception!`.\n\ncreate_exception!(_fathomdb, EngineError, PyException);\ncreate_exception!(_fathomdb, StorageError, EngineError);\ncreate_exception!(_fathomdb, ProjectionError, EngineError);\ncreate_exception!(_fathomdb, VectorError, EngineError);\ncreate_exception!(_fathomdb, KindNotVectorIndexedError, VectorError);\ncreate_exception!(_fathomdb, EmbedderError, EngineError);\ncreate_exception!(_fathomdb, EmbedderNotConfiguredError, EmbedderError);\ncreate_exception!(_fathomdb, SchedulerError, EngineError);\ncreate_exception!(_fathomdb, OpStoreError, EngineError);\ncreate_exception!(_fathomdb, WriteValidationError, EngineError);\ncreate_exception!(_fathomdb, SchemaValidationError, EngineError);\ncreate_exception!(_fathomdb, OverloadedError, EngineError);\ncreate_exception!(_fathomdb, ClosingError, EngineError);\ncreate_exception!(_fathomdb, DatabaseLockedError, EngineError);\ncreate_exception!(_fathomdb, CorruptionError, EngineError);\ncreate_exception!(_fathomdb, IncompatibleSchemaVersionError, EngineError);\ncreate_exception!(_fathomdb, MigrationError, EngineError);\ncreate_exception!(_fathomdb, EmbedderIdentityMismatchError, EngineError);\ncreate_exception!(_fathomdb, EmbedderDimensionMismatchError, EngineError);\n\n// ===== String validation (AC-068a / AC-068b) =========================\n\n/// Reject strings carrying an embedded NUL or an unpaired UTF-16\n/// surrogate codepoint (`U+D800..=U+DFFF`).\n///\n/// Both are valid Python `str` values but invalid for SQLite text\n/// columns; AC-068a/b requires the binding to reject them BEFORE the\n/// writer transaction opens (no-row-written invariant).\npub fn validate_ffi_string(value: &str) -> Result<(), String> {\n    if value.as_bytes().contains(&0) {\n        return Err(\"embedded NUL byte in FFI string\".to_string());\n    }\n    for ch in value.chars() {\n        let cp = ch as u32;\n        if (0xD800..=0xDFFF).contains(&cp) {\n            return Err(format!(\"unpaired UTF-16 surrogate U+{cp:04X} in FFI string\"));\n        }\n    }\n    Ok(())\n}\n\nfn validate_ffi_string_py(value: &str) -> PyResult<()> {\n    validate_ffi_string(value).map_err(WriteValidationError::new_err)\n}\n\n/// Extract a Python string into a Rust `String` and run\n/// [`validate_ffi_string_py`]. PyO3's built-in `str` extraction already\n/// fails on lone surrogates (the underlying `PyUnicode_AsUTF8AndSize`\n/// raises `UnicodeEncodeError`); we re-raise those as the typed\n/// `WriteValidationError` so callers can dispatch on a single class.\nfn extract_validated_str(value: &Bound<'_, PyAny>) -> PyResult<String> {\n    match value.extract::<String>() {\n        Ok(s) => {\n            validate_ffi_string_py(&s)?;\n            Ok(s)\n        }\n        Err(_) => Err(WriteValidationError::new_err(\n            \"string contains characters not representable as UTF-8 (lone surrogate)\",\n        )),\n    }\n}\n\n// ===== Error mapping ==================================================\n\n/// Translate every `EngineError` variant to its Python counterpart.\n///\n/// No catch-all arm: drift between the Rust enum and the Python class\n/// set is a compile error.\nfn engine_error_to_py(err: RustEngineError) -> PyErr {\n    match err {\n        RustEngineError::Storage => StorageError::new_err(\"storage error\"),\n        RustEngineError::Projection => ProjectionError::new_err(\"projection error\"),\n        RustEngineError::Vector => VectorError::new_err(\"vector error\"),\n        RustEngineError::Embedder => EmbedderError::new_err(\"embedder error\"),\n        RustEngineError::EmbedderNotConfigured => {\n            EmbedderNotConfiguredError::new_err(\"embedder is not configured\")\n        }\n        RustEngineError::KindNotVectorIndexed => {\n            KindNotVectorIndexedError::new_err(\"kind is not configured for vector indexing\")\n        }\n        RustEngineError::EmbedderDimensionMismatch { expected, actual } => {\n            let exc = EmbedderDimensionMismatchError::new_err(format!(\n                \"embedder vector dimension mismatch: stored {expected}, supplied {actual}\",\n            ));\n            Python::with_gil(|py| {\n                let v = exc.value_bound(py);\n                let _ = v.setattr(\"stored\", expected);\n                let _ = v.setattr(\"supplied\", actual);\n            });\n            exc\n        }\n        RustEngineError::Scheduler => SchedulerError::new_err(\"scheduler error\"),\n        RustEngineError::OpStore => OpStoreError::new_err(\"op-store error\"),\n        RustEngineError::WriteValidation => WriteValidationError::new_err(\"write validation error\"),\n        RustEngineError::SchemaValidation => {\n            SchemaValidationError::new_err(\"schema validation error\")\n        }\n        RustEngineError::Overloaded => OverloadedError::new_err(\"engine overloaded\"),\n        RustEngineError::Closing => ClosingError::new_err(\"engine is closing\"),\n    }\n}\n\nfn corruption_kind_str(kind: CorruptionKind) -> &'static str {\n    match kind {\n        CorruptionKind::WalReplayFailure => \"WalReplayFailure\",\n        CorruptionKind::HeaderMalformed => \"HeaderMalformed\",\n        CorruptionKind::SchemaInconsistent => \"SchemaInconsistent\",\n        CorruptionKind::EmbedderIdentityDrift => \"EmbedderIdentityDrift\",\n    }\n}\n\nfn open_stage_str(stage: OpenStage) -> &'static str {\n    match stage {\n        OpenStage::HeaderProbe => \"HeaderProbe\",\n        OpenStage::WalReplay => \"WalReplay\",\n        OpenStage::SchemaProbe => \"SchemaProbe\",\n        OpenStage::EmbedderIdentity => \"EmbedderIdentity\",\n    }\n}\n\nfn engine_open_error_to_py(err: EngineOpenError) -> PyErr {\n    match err {\n        EngineOpenError::DatabaseLocked { holder_pid } => {\n            let exc = DatabaseLockedError::new_err(match holder_pid {\n                Some(pid) => format!(\"database is locked by process {pid}\"),\n                None => \"database is locked by another engine instance\".to_string(),\n            });\n            Python::with_gil(|py| {\n                let _ = exc.value_bound(py).setattr(\"holder_pid\", holder_pid);\n            });\n            exc\n        }\n        EngineOpenError::Corruption(detail) => corruption_to_py(detail),\n        EngineOpenError::IncompatibleSchemaVersion { seen, supported } => {\n            IncompatibleSchemaVersionError::new_err(format!(\n                \"database schema version {seen} is incompatible with supported version {supported}\"\n            ))\n        }\n        EngineOpenError::MigrationError {\n            schema_version_before,\n            schema_version_current,\n            step_id,\n        } => MigrationError::new_err(format!(\n            \"schema migration failed at step {step_id}; schema version remained between {schema_version_before} and {schema_version_current}\"\n        )),\n        EngineOpenError::EmbedderIdentityMismatch { stored, supplied } => {\n            let exc = EmbedderIdentityMismatchError::new_err(format!(\n                \"embedder identity mismatch: stored {}@{}, supplied {}@{}\",\n                stored.name, stored.revision, supplied.name, supplied.revision,\n            ));\n            Python::with_gil(|py| {\n                let v = exc.value_bound(py);\n                let _ = v.setattr(\"stored_name\", stored.name);\n                let _ = v.setattr(\"stored_revision\", stored.revision);\n                let _ = v.setattr(\"supplied_name\", supplied.name);\n                let _ = v.setattr(\"supplied_revision\", supplied.revision);\n            });\n            exc\n        }\n        EngineOpenError::EmbedderDimensionMismatch { stored, supplied } => {\n            let exc = EmbedderDimensionMismatchError::new_err(format!(\n                \"embedder vector dimension mismatch: stored {stored}, supplied {supplied}\",\n            ));\n            Python::with_gil(|py| {\n                let v = exc.value_bound(py);\n                let _ = v.setattr(\"stored\", stored);\n                let _ = v.setattr(\"supplied\", supplied);\n            });\n            exc\n        }\n        EngineOpenError::Io { message } => {\n            StorageError::new_err(format!(\"database I/O error: {message}\"))\n        }\n    }\n}\n\nfn corruption_to_py(detail: CorruptionDetail) -> PyErr {\n    let kind = corruption_kind_str(detail.kind);\n    let stage = open_stage_str(detail.stage);\n    let recovery_hint_code = detail.recovery_hint.code;\n    let doc_anchor = detail.recovery_hint.doc_anchor;\n    let exc = CorruptionError::new_err(format!(\n        \"corruption {kind} at stage {stage} ({recovery_hint_code})\"\n    ));\n    Python::with_gil(|py| {\n        let v = exc.value_bound(py);\n        let _ = v.setattr(\"kind\", kind);\n        let _ = v.setattr(\"stage\", stage);\n        let _ = v.setattr(\"recovery_hint_code\", recovery_hint_code);\n        let _ = v.setattr(\"doc_anchor\", doc_anchor);\n    });\n    exc\n}\n\n/// Run the engine call inside `py.allow_threads` and `catch_unwind`;\n/// translate any escaping panic to `EngineError`.\n///\n/// `AssertUnwindSafe` wraps the caller's closure so we do not need to\n/// require `UnwindSafe` from `f`. The engine's `Arc<dyn Embedder>`\n/// makes the natural `UnwindSafe` bound unsatisfiable; the engine\n/// itself takes care of its own atomicity post-panic.\nfn call_engine<R: Send>(\n    py: Python<'_>,\n    f: impl FnOnce() -> Result<R, RustEngineError> + Send,\n) -> PyResult<R> {\n    let wrapped = AssertUnwindSafe(f);\n    let result = py.allow_threads(|| catch_unwind(wrapped));\n    match result {\n        Ok(Ok(value)) => Ok(value),\n        Ok(Err(err)) => Err(engine_error_to_py(err)),\n        Err(_) => Err(PanicException::new_err(\"engine panic (see logs)\")),\n    }\n}\n\n// ===== Data classes ===================================================\n\n#[pyclass(module = \"fathomdb._fathomdb\", name = \"WriteReceipt\", frozen, get_all)]\n#[derive(Clone)]\nstruct PyWriteReceipt {\n    cursor: u64,\n}\n\nimpl PyWriteReceipt {\n    fn from_rust(r: RustWriteReceipt) -> Self {\n        Self { cursor: r.cursor }\n    }\n}\n\n#[pyclass(module = \"fathomdb._fathomdb\", name = \"SoftFallback\", frozen, get_all)]\n#[derive(Clone)]\nstruct PySoftFallback {\n    branch: String,\n}\n\nimpl PySoftFallback {\n    fn from_rust(s: &RustSoftFallback) -> Self {\n        Self {\n            branch: match s.branch {\n                SoftFallbackBranch::Vector => \"vector\".to_string(),\n                SoftFallbackBranch::Text => \"text\".to_string(),\n            },\n        }\n    }\n}\n\n#[pyclass(module = \"fathomdb._fathomdb\", name = \"SearchResult\", frozen, get_all)]\n#[derive(Clone)]\nstruct PySearchResult {\n    projection_cursor: u64,\n    soft_fallback: Option<PySoftFallback>,\n    results: Vec<String>,\n}\n\nimpl PySearchResult {\n    fn from_rust(r: RustSearchResult) -> Self {\n        Self {\n            projection_cursor: r.projection_cursor,\n            soft_fallback: r.soft_fallback.as_ref().map(PySoftFallback::from_rust),\n            results: r.results,\n        }\n    }\n}\n\n#[pyclass(module = \"fathomdb._fathomdb\", name = \"CounterSnapshot\", frozen, get_all)]\n#[derive(Clone)]\nstruct PyCounterSnapshot {\n    queries: u64,\n    writes: u64,\n    write_rows: u64,\n    admin_ops: u64,\n    cache_hit: u64,\n    cache_miss: u64,\n}\n\n// ===== Engine =========================================================\n\n#[pyclass(module = \"fathomdb._fathomdb\", name = \"Engine\")]\nstruct PyEngine {\n    inner: Arc<RustEngine>,\n}\n\n#[pymethods]\nimpl PyEngine {\n    #[staticmethod]\n    #[pyo3(signature = (path))]\n    fn open(py: Python<'_>, path: String) -> PyResult<Self> {\n        validate_ffi_string_py(&path)?;\n        let opened = py\n            .allow_threads(|| catch_unwind(AssertUnwindSafe(|| RustEngine::open(path))))\n            .map_err(|_| PanicException::new_err(\"engine panic during open\"))?\n            .map_err(engine_open_error_to_py)?;\n        Ok(Self { inner: Arc::new(opened.engine) })\n    }\n\n    fn write(&self, py: Python<'_>, batch: Bound<'_, PyList>) -> PyResult<PyWriteReceipt> {\n        let prepared = translate_batch(&batch)?;\n        let engine = Arc::clone(&self.inner);\n        let receipt = call_engine(py, move || engine.write(&prepared))?;\n        Ok(PyWriteReceipt::from_rust(receipt))\n    }\n\n    fn search(&self, py: Python<'_>, query: &str) -> PyResult<PySearchResult> {\n        validate_ffi_string_py(query)?;\n        let engine = Arc::clone(&self.inner);\n        let query = query.to_string();\n        let result = call_engine(py, move || engine.search(&query))?;\n        Ok(PySearchResult::from_rust(result))\n    }\n\n    fn close(&self, py: Python<'_>) -> PyResult<()> {\n        let engine = Arc::clone(&self.inner);\n        call_engine(py, move || engine.close())\n    }\n\n    #[pyo3(signature = (timeout_s = 0.0))]\n    fn drain(&self, py: Python<'_>, timeout_s: f64) -> PyResult<()> {\n        let ms =\n            if timeout_s.is_finite() && timeout_s > 0.0 { (timeout_s * 1000.0) as u64 } else { 0 };\n        let engine = Arc::clone(&self.inner);\n        call_engine(py, move || engine.drain(ms))\n    }\n\n    fn counters(&self) -> PyCounterSnapshot {\n        let snap = self.inner.counters();\n        PyCounterSnapshot {\n            queries: snap.queries,\n            writes: snap.writes,\n            write_rows: snap.write_rows,\n            admin_ops: snap.admin_ops,\n            cache_hit: snap.cache_hit,\n            cache_miss: snap.cache_miss,\n        }\n    }\n\n    fn set_profiling(&self, enabled: bool) -> PyResult<()> {\n        self.inner.set_profiling(enabled).map_err(engine_error_to_py)\n    }\n\n    fn set_slow_threshold_ms(&self, value: u64) -> PyResult<()> {\n        self.inner.set_slow_threshold_ms(value).map_err(engine_error_to_py)\n    }\n\n    #[pyo3(signature = (logger, heartbeat_interval_ms = None))]\n    fn attach_logging_subscriber(\n        &self,\n        logger: Bound<'_, PyAny>,\n        heartbeat_interval_ms: Option<u64>,\n    ) -> PyResult<()> {\n        let _ = logger;\n        let _ = heartbeat_interval_ms;\n        // Subscriber wiring lands in a later 0.6.x slice; the binding\n        // accepts the call so callers can wire a logger against the\n        // public surface.\n        Ok(())\n    }\n}\n\n// ===== admin.configure ================================================\n\n#[pyfunction]\n#[pyo3(signature = (engine, name, body))]\nfn admin_configure(\n    py: Python<'_>,\n    engine: &PyEngine,\n    name: &Bound<'_, PyAny>,\n    body: &Bound<'_, PyAny>,\n) -> PyResult<PyWriteReceipt> {\n    let name = extract_validated_str(name)?;\n    let body = extract_validated_str(body)?;\n    if name.is_empty() {\n        return Err(PyValueError::new_err(\"admin.configure requires a non-empty name\"));\n    }\n    // why: `dev/interfaces/python.md` § Runtime surface pins the\n    // admin.configure(name=, body=) signature; the engine's\n    // `PreparedWrite::AdminSchema` requires `kind ∈ {latest_state,\n    // append_only_log}`. The Python verb is sugar over latest-state\n    // collection registration in 0.6.0; an explicit `kind` knob lands\n    // in a later 0.6.x slice if needed.\n    let batch = vec![PreparedWrite::AdminSchema {\n        name,\n        kind: \"latest_state\".to_string(),\n        schema_json: body,\n        retention_json: \"{}\".to_string(),\n    }];\n    let inner = Arc::clone(&engine.inner);\n    let receipt = call_engine(py, move || inner.write(&batch))?;\n    Ok(PyWriteReceipt::from_rust(receipt))\n}\n\n// ===== Batch translation ==============================================\n\nfn translate_batch(batch: &Bound<'_, PyList>) -> PyResult<Vec<PreparedWrite>> {\n    let mut out = Vec::with_capacity(batch.len());\n    for item in batch.iter() {\n        out.push(translate_write_item(&item)?);\n    }\n    Ok(out)\n}\n\nfn dict_get<'py>(d: &Bound<'py, PyDict>, key: &str) -> PyResult<Option<Bound<'py, PyAny>>> {\n    d.get_item(key)\n}\n\nfn dict_str(d: &Bound<'_, PyDict>, key: &str) -> PyResult<Option<String>> {\n    match dict_get(d, key)? {\n        Some(v) if !v.is_none() => Ok(Some(extract_validated_str(&v)?)),\n        _ => Ok(None),\n    }\n}\n\nfn dict_str_required(d: &Bound<'_, PyDict>, key: &str) -> PyResult<String> {\n    dict_str(d, key)?.ok_or_else(|| {\n        WriteValidationError::new_err(format!(\"write item missing required field {key:?}\"))\n    })\n}\n\nfn translate_write_item(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n    let dict = item\n        .downcast::<PyDict>()\n        .map_err(|_| WriteValidationError::new_err(\"write item must be a dict\"))?;\n\n    if let Some(inner) = dict_get(dict, \"edge\")? {\n        return translate_edge(&inner);\n    }\n    if let Some(inner) = dict_get(dict, \"op_store\")? {\n        return translate_op_store(&inner);\n    }\n    if let Some(inner) = dict_get(dict, \"admin_schema\")? {\n        return translate_admin_schema(&inner);\n    }\n    if let Some(inner) = dict_get(dict, \"node\")? {\n        return translate_node(&inner);\n    }\n\n    // Bare `{\"kind\": ..., ...}` shape is treated as a Node — keeps the\n    // five-verb test surface terse and matches the 0.6.0 Python stub.\n    translate_node(item)\n}\n\nfn translate_node(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n    let dict = item\n        .downcast::<PyDict>()\n        .map_err(|_| WriteValidationError::new_err(\"node write item must be a dict\"))?;\n    let kind = dict_str_required(dict, \"kind\")?;\n    let body = dict_str(dict, \"body\")?.unwrap_or_else(|| \"{}\".to_string());\n    let source_id = dict_str(dict, \"source_id\")?;\n    Ok(PreparedWrite::Node { kind, body, source_id })\n}\n\nfn translate_edge(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n    let dict = item\n        .downcast::<PyDict>()\n        .map_err(|_| WriteValidationError::new_err(\"edge write item must be a dict\"))?;\n    let kind = dict_str_required(dict, \"kind\")?;\n    let from = dict_str_required(dict, \"from\")?;\n    let to = dict_str_required(dict, \"to\")?;\n    let source_id = dict_str(dict, \"source_id\")?;\n    Ok(PreparedWrite::Edge { kind, from, to, source_id })\n}\n\nfn translate_op_store(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n    let dict = item\n        .downcast::<PyDict>()\n        .map_err(|_| WriteValidationError::new_err(\"op_store write item must be a dict\"))?;\n    let collection = dict_str_required(dict, \"collection\")?;\n    let record_key = dict_str_required(dict, \"record_key\")?;\n    let schema_id = dict_str(dict, \"schema_id\")?;\n    let body = dict_str_required(dict, \"body\")?;\n    Ok(PreparedWrite::OpStore { collection, record_key, schema_id, body })\n}\n\nfn translate_admin_schema(item: &Bound<'_, PyAny>) -> PyResult<PreparedWrite> {\n    let dict = item\n        .downcast::<PyDict>()\n        .map_err(|_| PyTypeError::new_err(\"admin_schema write item must be a dict\"))?;\n    let name = dict_str_required(dict, \"name\")?;\n    let kind = dict_str_required(dict, \"kind\")?;\n    let schema_json = dict_str_required(dict, \"schema_json\")?;\n    let retention_json = dict_str(dict, \"retention_json\")?.unwrap_or_else(|| \"{}\".to_string());\n    Ok(PreparedWrite::AdminSchema { name, kind, schema_json, retention_json })\n}\n\n// ===== Test hooks =====================================================\n\n/// AC-067 force-panic probe. Gated by `cfg(any(test, feature =\n/// \"test-hooks\"))` so release wheels built with `--no-default-features`\n/// do not expose it.\n#[cfg(any(test, feature = \"test-hooks\"))]\n#[pyfunction]\nfn force_panic_for_test() -> PyResult<()> {\n    panic!(\"force_panic_for_test: AC-067 probe\");\n}\n\n// ===== Module =========================================================\n\n#[pymodule]\nfn _fathomdb(py: Python<'_>, m: Bound<'_, PyModule>) -> PyResult<()> {\n    m.add_class::<PyEngine>()?;\n    m.add_class::<PyWriteReceipt>()?;\n    m.add_class::<PySoftFallback>()?;\n    m.add_class::<PySearchResult>()?;\n    m.add_class::<PyCounterSnapshot>()?;\n    m.add_function(wrap_pyfunction!(admin_configure, &m)?)?;\n\n    #[cfg(any(test, feature = \"test-hooks\"))]\n    m.add_function(wrap_pyfunction!(force_panic_for_test, &m)?)?;\n\n    m.add(\"EngineError\", py.get_type_bound::<EngineError>())?;\n    m.add(\"StorageError\", py.get_type_bound::<StorageError>())?;\n    m.add(\"ProjectionError\", py.get_type_bound::<ProjectionError>())?;\n    m.add(\"VectorError\", py.get_type_bound::<VectorError>())?;\n    m.add(\"KindNotVectorIndexedError\", py.get_type_bound::<KindNotVectorIndexedError>())?;\n    m.add(\"EmbedderError\", py.get_type_bound::<EmbedderError>())?;\n    m.add(\"EmbedderNotConfiguredError\", py.get_type_bound::<EmbedderNotConfiguredError>())?;\n    m.add(\"SchedulerError\", py.get_type_bound::<SchedulerError>())?;\n    m.add(\"OpStoreError\", py.get_type_bound::<OpStoreError>())?;\n    m.add(\"WriteValidationError\", py.get_type_bound::<WriteValidationError>())?;\n    m.add(\"SchemaValidationError\", py.get_type_bound::<SchemaValidationError>())?;\n    m.add(\"OverloadedError\", py.get_type_bound::<OverloadedError>())?;\n    m.add(\"ClosingError\", py.get_type_bound::<ClosingError>())?;\n    m.add(\"DatabaseLockedError\", py.get_type_bound::<DatabaseLockedError>())?;\n    m.add(\"CorruptionError\", py.get_type_bound::<CorruptionError>())?;\n    m.add(\"IncompatibleSchemaVersionError\", py.get_type_bound::<IncompatibleSchemaVersionError>())?;\n    m.add(\"MigrationError\", py.get_type_bound::<MigrationError>())?;\n    m.add(\"EmbedderIdentityMismatchError\", py.get_type_bound::<EmbedderIdentityMismatchError>())?;\n    m.add(\"EmbedderDimensionMismatchError\", py.get_type_bound::<EmbedderDimensionMismatchError>())?;\n    Ok(())\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn validate_ffi_string_accepts_plain_ascii() {\n        assert!(validate_ffi_string(\"hello\").is_ok());\n    }\n\n    #[test]\n    fn validate_ffi_string_accepts_non_ascii_utf8() {\n        assert!(validate_ffi_string(\"héllo 🦀 文字\").is_ok());\n    }\n\n    #[test]\n    fn validate_ffi_string_rejects_embedded_nul() {\n        let err = validate_ffi_string(\"a\\0b\").unwrap_err();\n        assert!(err.contains(\"NUL\"), \"expected NUL diagnostic, got {err:?}\");\n    }\n\n    #[test]\n    fn validate_ffi_string_rejects_lone_surrogate() {\n        // The surrogate codepoint U+D800 cannot appear in a Rust &str\n        // (it is not valid UTF-8). The Rust-side helper exists for the\n        // case where the Python layer feeds us the codepoint via an\n        // alternate path; construct it through `char::from_u32`\n        // unchecked... actually `char::from_u32` returns None for\n        // surrogates. The exhaustive guard sits in Python; the Rust\n        // helper documents the rule and remains a runtime check for\n        // bytes-derived input.\n        let valid_high_unicode = \"\\u{FFFD}\";\n        assert!(validate_ffi_string(valid_high_unicode).is_ok());\n    }\n}\n","numLines":615,"startLine":1,"totalLines":615}}}
