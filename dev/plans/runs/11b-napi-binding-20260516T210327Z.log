{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UQFJs8ZyN4Apz4S5YzCS7Y","type":"tool_result","content":"1\t// Single-rooted FathomDbError hierarchy for the TypeScript SDK.\n2\t//\n3\t// Layout owned by `dev/design/errors.md` § Binding-facing class matrix and\n4\t// `dev/design/bindings.md` § 3. Per-leaf payloads are typed object\n5\t// arguments; callers narrow with `instanceof`.\n6\t\n7\texport class FathomDbError extends Error {\n8\t  constructor(message: string) {\n9\t    super(message);\n10\t    this.name = new.target.name;\n11\t  }\n12\t}\n13\t\n14\texport class StorageError extends FathomDbError {}\n15\texport class ProjectionError extends FathomDbError {}\n16\texport class VectorError extends FathomDbError {}\n17\texport class EmbedderError extends FathomDbError {}\n18\texport class SchedulerError extends FathomDbError {}\n19\texport class OpStoreError extends FathomDbError {}\n20\texport class WriteValidationError extends FathomDbError {}\n21\texport class SchemaValidationError extends FathomDbError {}\n22\texport class OverloadedError extends FathomDbError {}\n23\texport class ClosingError extends FathomDbError {}\n24\t\n25\texport interface DatabaseLockedErrorPayload {\n26\t  holderPid?: number;\n27\t}\n28\t\n29\texport class DatabaseLockedError extends FathomDbError {\n30\t  readonly holderPid?: number;\n31\t  constructor(payload: DatabaseLockedErrorPayload = {}) {\n32\t    super(`database locked (holderPid=${payload.holderPid ?? \"unknown\"})`);\n33\t    this.holderPid = payload.holderPid;\n34\t  }\n35\t}\n36\t\n37\texport interface CorruptionErrorPayload {\n38\t  kind: string;\n39\t  stage: string;\n40\t  recoveryHintCode: string;\n41\t  docAnchor: string;\n42\t}\n43\t\n44\texport class CorruptionError extends FathomDbError {\n45\t  readonly kind: string;\n46\t  readonly stage: string;\n47\t  readonly recoveryHintCode: string;\n48\t  readonly docAnchor: string;\n49\t  constructor(payload: CorruptionErrorPayload) {\n50\t    super(`corruption ${payload.kind} at stage ${payload.stage} (${payload.recoveryHintCode})`);\n51\t    this.kind = payload.kind;\n52\t    this.stage = payload.stage;\n53\t    this.recoveryHintCode = payload.recoveryHintCode;\n54\t    this.docAnchor = payload.docAnchor;\n55\t  }\n56\t}\n57\t\n58\texport class IncompatibleSchemaVersionError extends FathomDbError {}\n59\texport class MigrationError extends FathomDbError {}\n60\t\n61\texport interface EmbedderIdentityMismatchPayload {\n62\t  storedName: string;\n63\t  storedRevision: string;\n64\t  suppliedName: string;\n65\t  suppliedRevision: string;\n66\t}\n67\t\n68\texport class EmbedderIdentityMismatchError extends FathomDbError {\n69\t  readonly storedName: string;\n70\t  readonly storedRevision: string;\n71\t  readonly suppliedName: string;\n72\t  readonly suppliedRevision: string;\n73\t  constructor(payload: EmbedderIdentityMismatchPayload) {\n74\t    super(\n75\t      `embedder identity mismatch: stored ${payload.storedName}@${payload.storedRevision}, ` +\n76\t        `supplied ${payload.suppliedName}@${payload.suppliedRevision}`,\n77\t    );\n78\t    this.storedName = payload.storedName;\n79\t    this.storedRevision = payload.storedRevision;\n80\t    this.suppliedName = payload.suppliedName;\n81\t    this.suppliedRevision = payload.suppliedRevision;\n82\t  }\n83\t}\n84\t\n85\texport interface EmbedderDimensionMismatchPayload {\n86\t  stored: number;\n87\t  supplied: number;\n88\t}\n89\t\n90\texport class EmbedderDimensionMismatchError extends FathomDbError {\n91\t  readonly stored: number;\n92\t  readonly supplied: number;\n93\t  constructor(payload: EmbedderDimensionMismatchPayload) {\n94\t    super(\n95\t      `embedder vector dimension mismatch: stored ${payload.stored}, supplied ${payload.supplied}`,\n96\t    );\n97\t    this.stored = payload.stored;\n98\t    this.supplied = payload.supplied;\n99\t  }\n100\t}\n101\t"}]},"parent_tool_use_id":null,"session_id":"d1c788b7-12bf-4bce-9fc4-3a0fdd43bef6","uuid":"20caf