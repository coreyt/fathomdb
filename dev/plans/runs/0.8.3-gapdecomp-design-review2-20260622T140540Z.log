   512	    def ingest(self, documents: dict[str, str]) -> None:
   513	        if self._memory is None:
   514	            raise RuntimeError("Mem0OSSAdapter not available (mem0ai/backend missing)")
   515	        if not self._persist or self._chroma_path is None:
   516	            # Non-persistent (codex Slice-5 [P1#2] default): ingest every doc, no
   517	            # sidecar — a fresh per-run store starts empty so re-ingest is correct.
   518	            for doc_id, body in documents.items():
   519	                self._memory.add(body, user_id=self._user_id, metadata={"doc_id": doc_id})
   520	            return
   521	        # Persistent + resumable (Slice 10 / Phase-B): the sidecar records every
   522	        # doc_id already written to this corpus-keyed store. SKIP docs already
   523	        # present; ADD only the new ones; flush the sidecar AFTER each add so a kill
   524	        # mid-ingest resumes from exactly where it stopped (incremental + idempotent).
   525	        sidecar = Path(str(self._chroma_path) + ".ingested.json")
   526	        done = self._load_ingested(sidecar)
   527	        for doc_id, body in documents.items():
   528	            if doc_id in done:
   529	                continue
   530	            self._memory.add(body, user_id=self._user_id, metadata={"doc_id": doc_id})
   531	            done.add(doc_id)
   532	            self._write_ingested(sidecar, done)
   533	
   534	    @staticmethod
   535	    def _load_ingested(sidecar: Path) -> set[str]:
   536	        """Load the set of already-ingested doc_ids; tolerate a missing/corrupt
   537	        sidecar (treat as empty → a clean from-scratch ingest)."""
   538	        try:
   539	            data = json.loads(sidecar.read_text(encoding="utf-8"))
   540	        except (OSError, ValueError):
   541	            return set()
   542	        return {str(d) for d in data} if isinstance(data, list) else set()
   543	
   544	    @staticmethod
   545	    def _write_ingested(sidecar: Path, done: set[str]) -> None:
   546	        """Atomically persist the ingested-doc_id set (temp-file + ``os.replace``)
   547	        so a kill mid-write cannot corrupt the resume sidecar."""
   548	        sidecar.parent.mkdir(parents=True, exist_ok=True)
   549	        tmp = sidecar.with_suffix(sidecar.suffix + ".tmp")
   550	        tmp.write_text(json.dumps(sorted(done)), encoding="utf-8")
   551	        os.replace(tmp, sidecar)
