  1061	def _build_fathomdb(
  1062	    documents: dict[str, str],
  1063	    db_path: Path,
  1064	    *,
  1065	    batch: int = 500,
  1066	    elps_harness_cmd: Optional[list[str]] = None,
  1067	    elps_limit: int = 100,
  1068	    use_graph_arm: bool = False,
  1069	) -> tuple[Optional["FathomDBAdapter"], Optional[dict[str, str]]]:
  1070	    """Best-effort: ingest the corpus and return a live adapter.
  1071	
  1072	    When ``elps_harness_cmd`` is supplied the first ``elps_limit`` documents
  1073	    are ingested via ``ingest_with_extractor`` (ELPS path; builds the graph
  1074	    arm).  Remaining documents fall back to plain ``write()``.  When
  1075	    ``elps_harness_cmd`` is None the original FTS-only path is used.
  1076	
  1077	    Returns ``(adapter, None)`` on success or ``(None, blocker_dict)`` on
  1078	    any failure so the runner can degrade gracefully.
  1079	    """
  1080	    try:
  1081	        from fathomdb.engine import Engine
  1082	    except Exception as exc:  # noqa: BLE001 - report, don't crash the eval
  1083	        return None, {
  1084	            "id": "fathomdb-sdk-unavailable",
  1085	            "description": f"could not import fathomdb SDK ({exc}); run `pip install -e src/python`",
  1086	            "resolution": "UNRESOLVED — FathomDB arm skipped; naive-RAG retrieval reported",
  1087	        }
  1088	    if db_path.exists():
  1089	        db_path.unlink()
  1090	    try:
  1091	        # ELPS path uses the embedder so projection scheduler can drain the
  1092	        # edge_fact queue. Plain-write path stays FTS-only (no embedder needed).
  1093	        use_embedder = elps_harness_cmd is not None
  1094	        engine = Engine.open(str(db_path), use_default_embedder=use_embedder)
  1095	        cursor_to_doc: dict[int, str] = {}
  1096	
  1097	        if elps_harness_cmd is not None:
  1098	            # ELPS path -------------------------------------------------------
  1099	            # Two-pass ingest for the ELPS sample:
  1100	            #   Pass 1 — write() for doc nodes: gives FTS searchability + cursor→doc_id
  1101	            #   Pass 2 — ingest_with_extractor: adds entity nodes + edges for graph arm
  1102	            # ingest_with_extractor creates entity/edge nodes but NOT source doc nodes,
  1103	            # so pass 1 is required for correct doc_id resolution in R2 eval.
  1104	            items = list(documents.items())
  1105	            elps_sample = items[:elps_limit]
  1106	            remainder = items[elps_limit:]
  1107	
  1108	            # Pass 1: write doc nodes for all ELPS-sample docs
  1109	            for start in range(0, len(elps_sample), batch):
  1110	                chunk = elps_sample[start : start + batch]
  1111	                receipt = engine.write([{"kind": "doc", "body": body} for _, body in chunk])
  1112	                for (doc_id, _body), cursor in zip(chunk, receipt.row_cursors):
  1113	                    cursor_to_doc[int(cursor)] = session_id_of(doc_id)
  1114	
  1115	            # Drain after pass 1: wait for BGE embedder to finish doc embeddings
  1116	            # before spawning the ELPS harness. Without this the CPU-intensive
  1117	            # embedder competes with harness LLM calls and trips the 60s httpx
  1118	            # timeout, then the Rust 300s IO timeout → EngineError::Extractor.
  1119	            engine.drain(timeout_s=300)
  1120	
  1121	            # Pass 2: ELPS extraction adds entity nodes + edges (graph arm population)
  1122	            elps_docs = [
  1123	                {"source_doc_id": doc_id, "body": body[:_ELPS_MAX_CHARS]} for doc_id, body in elps_sample
  1124	            ]
  1125	            engine.ingest_with_extractor(elps_harness_cmd, elps_docs)
  1126	
  1127	            # Remainder docs: plain write only (no ELPS extraction)
  1128	            for start in range(0, len(remainder), batch):
  1129	                chunk = remainder[start : start + batch]
  1130	                receipt = engine.write([{"kind": "doc", "body": body} for _, body in chunk])
  1131	                for (doc_id, _body), cursor in zip(chunk, receipt.row_cursors):
  1132	                    cursor_to_doc[int(cursor)] = session_id_of(doc_id)
  1133	
  1134	            # Longer drain: embedder processes entity nodes from ELPS extraction
  1135	            engine.drain(timeout_s=600)
  1136	
  1137	            adapter = FathomDBAdapter(
  1138	                engine,
  1139	                doc_id_of=_make_doc_id_of(cursor_to_doc),
  1140	                use_graph_arm=use_graph_arm,
  1141	            )
  1142	        else:
  1143	            # Original FTS-only path ------------------------------------------
  1144	            items = list(documents.items())
  1145	            for start in range(0, len(items), batch):
  1146	                chunk = items[start : start + batch]
  1147	                receipt = engine.write([{"kind": "doc", "body": body} for _, body in chunk])
  1148	                for (doc_id, _body), cursor in zip(chunk, receipt.row_cursors):
  1149	                    cursor_to_doc[int(cursor)] = session_id_of(doc_id)
  1150	            engine.drain(timeout_s=120)
  1151	            adapter = FathomDBAdapter(
  1152	                engine,
  1153	                doc_id_of=_make_doc_id_of(cursor_to_doc),
  1154	                use_graph_arm=use_graph_arm,
  1155	            )
  1156	
  1157	        return adapter, None
  1158	    except Exception as exc:  # noqa: BLE001
  1159	        return None, {
  1160	            "id": "fathomdb-ingest-failed",
  1161	            "description": f"FathomDB open/ingest failed: {exc}",
  1162	            "resolution": "UNRESOLVED — FathomDB arm skipped",
  1163	        }
  1164	
