   992	        session_ids: list[str] = instance.get("haystack_session_ids") or []
   993	        sessions: list[list[dict]] = instance.get("haystack_sessions") or []
   994	        for sid, turns in zip(session_ids, sessions):
   995	            if sid not in documents:
   996	                documents[sid] = _format_lme_session(turns)
   997	
   998	        q_type: str = str(instance.get("question_type") or "unknown")
   999	        reporting = LME_CLASS_MAP.get(q_type, "unknown")
  1000	        answer_sids: list[str] = instance.get("answer_session_ids") or []
  1001	        answer_text: str = str(instance.get("answer") or "")
  1002	        question_text: str = str(instance.get("question") or "")
  1003	        q_id: str = str(instance.get("question_id") or f"lme-{i}")
  1004	
  1005	        queries.append(
  1006	            GoldQuery(
  1007	                query_id=q_id,
  1008	                question=question_text,
  1009	                reporting_class=reporting,
  1010	                answers=(answer_text,) if answer_text else (),
  1011	                gold_doc_ids=tuple(answer_sids),
  1012	            )
  1013	        )
  1014	
  1015	    return documents, queries
