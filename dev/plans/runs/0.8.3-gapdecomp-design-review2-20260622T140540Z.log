   590	def _normalize(text: str) -> str:
   591	    return re.sub(r"[^a-z0-9 ]+", " ", text.lower()).strip()
   592	
   593	
   594	# Abstention strings treated as "no answer", computed THROUGH `_normalize` so the
   595	# comparison is self-consistent: `_normalize` turns "I don't know" into
   596	# "i don t know" (apostrophe -> space). A raw literal set like {"i dont know"}
   597	# silently misses the exact phrase the answerer prompt instructs the model to emit.
   598	_ABSTAIN: frozenset[str] = frozenset(
   599	    _normalize(s) for s in ("I don't know", "I dont know", "idk")
   600	) | {""}
   601	
   602	
   603	def normalize_answer(text: Optional[str]) -> Optional[str]:
   604	    """Raw reader answer -> ``None`` when empty or an abstention (apostrophe-safe).
   605	
   606	    The single normalizer both the sync answerers (``*Answerer._complete``) and the
   607	    batch path (``p0a_batch_e2e.parse_batch_output``) call, so abstention detection
   608	    cannot drift between them."""
   609	    t = (text or "").strip()
   610	    if not t or _normalize(t) in _ABSTAIN:
   611	        return None
   612	    return t
   613	
   614	
   615	def _match(ground_truth: list[str], system_answer: str) -> bool:
   616	    sa = _normalize(system_answer)
   617	    if not sa:
   618	        return False
   619	    for gt in ground_truth:
   620	        g = _normalize(gt)

