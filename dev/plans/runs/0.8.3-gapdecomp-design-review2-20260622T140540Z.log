   683	def load_repin_gold(gold_path: str | Path) -> tuple[str, str, list[GoldQuery]]:
   684	    """Load a 0.8.3 D0a re-pinned gold file → ``(corpus_hash, qrels_version, queries)``.
   685	
   686	    Used by :meth:`R2Harness.from_repin_gold` and the Slice-10 parity runner to
   687	    consume the power-sized memory-class gold. Does NOT enforce the COR-2 pin (the
   688	    re-pin is the LongMemEval corpus, design §3); it requires only that the file
   689	    declares a non-empty ``corpus_hash`` and at least one query.
   690	
   691	    Runtime corpus-validity guard (codex §9 [P2]): runs :func:`validate_repin`
   692	    over the gold itself (per-class counts derived from the file, ``n_min`` from
   693	    the file) and **RAISES** on any problem — an underfilled / N=0 / missing /
   694	    single-session-mislabeled class can never silently run to emit null (the
   695	    Slice-25 N=0 mode)."""
   696	    raw = json.loads(Path(gold_path).read_text(encoding="utf-8"))
   697	    corpus_hash = str(raw.get("corpus_hash", "")).strip()
   698	    if not corpus_hash:
   699	        raise ValueError(f"re-pin gold {gold_path!s} has no corpus_hash")
   700	    raw_queries = list(raw.get("queries", []))
   701	
   702	    from eval.corpus_validity import _observed_counts, validate_repin
   703	
   704	    synth_manifest = {
   705	        "n_min": raw.get("n_min"),
   706	        "per_class_gold_counts": _observed_counts(raw_queries),
   707	    }
   708	    problems = validate_repin(synth_manifest, raw_queries)
   709	    if problems:
   710	        raise ValueError(
   711	            f"re-pin gold {gold_path!s} failed corpus-validity guard: {problems}"
   712	        )
   713	
   714	    queries = _parse_gold(raw)
   715	    if not queries:
   716	        raise ValueError(f"re-pin gold {gold_path!s} has no queries")
   717	
   718	    # The gold's identity is its repin_hash (corpus_hash is the intentionally
   719	    # STABLE LME corpus hash and cannot distinguish gold revisions). Derive the
   720	    # qrels_version from repin_hash so distinct gold revisions stay distinct in
   721	    # results/audit logs (codex §9 fix-2 [P2]). Key off repin_hash first; else
   722	    # the gold's declared qrels_version; only fall back to corpus_hash if a
   723	    # (malformed) gold lacks both — which should not happen for the pinned file.
   724	    repin_hash = str(raw.get("repin_hash", "")).strip()
   725	    declared_version = str(raw.get("qrels_version", "")).strip()
   726	    if repin_hash:
   727	        qrels_version = f"repin-{repin_hash[:8]}"
   728	    elif declared_version:
   729	        qrels_version = declared_version
   730	    else:
   731	        qrels_version = f"repin-{corpus_hash[:8]}"
   732	    return corpus_hash, qrels_version, queries
