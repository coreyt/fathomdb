   148	    treatment: str = TREATMENT_ARM,
   149	    n_boot: int = DEFAULT_N_BOOT,
   150	    seed: int = 0,
   151	) -> dict[str, dict[str, dict[str, Any]]]:
   152	    """``{comparator: {class: class_delta}}`` for one ``metric`` over every class."""
   153	    out: dict[str, dict[str, dict[str, Any]]] = {}
   154	    for comp in comparators:
   155	        out[comp] = {}
   156	        for cls in classes:
   157	            d = paired_metric_deltas(
   158	                records, metric=metric, treatment=treatment, comparator=comp, cls=cls
   159	            )
   160	            out[comp][cls] = class_delta(d, n_boot=n_boot, seed=seed)
   161	    return out
   162	
   163	
   164	def external_per_class_for_decide(
   165	    acc_delta_table: Mapping[str, Mapping[str, Mapping[str, Any]]],
   166	    *,
   167	    comparator: str = "mem0_oss",
   168	    classes: Sequence[str] = MEMORY_CLASSES,
   169	) -> dict[str, dict[str, float]]:
   170	    """Build the :func:`decide_083` input from the ACCURACY ``fathomdb − <comparator>``
   171	    deltas (the priced gate; design §4).
   172	
   173	    ``decide_083`` requires a finite ``{point, ci_lo, ci_hi, mde}`` + int ``n`` for
   174	    every :data:`MEMORY_CLASSES` entry. A class with no usable delta (n==0/1 → mde
   175	    ``None`` — e.g. the comparator arm did not run) cannot be fed; raise loudly so the
   176	    caller records a blocker rather than fabricate a verdict."""
   177	    table = acc_delta_table.get(comparator, {})
   178	    ext: dict[str, dict[str, float]] = {}
   179	    for cls in classes:
   180	        cd = table.get(cls)
   181	        if cd is None or cd.get("point") is None or cd.get("mde") is None:
   182	            n = cd.get("n") if cd else "missing"
   183	            raise ValueError(
   184	                f"cannot build decide_083 input: class {cls!r} has no usable "
   185	                f"{comparator!r} accuracy delta (n={n}) — record a blocker, do not "
   186	                "fabricate a verdict"
   187	            )
   188	        ext[cls] = {
   189	            "point": float(cd["point"]),
   190	            "ci_lo": float(cd["ci_lo"]),
   191	            "ci_hi": float(cd["ci_hi"]),
   192	            "mde": float(cd["mde"]),
   193	            "n": int(cd["n"]),
   194	        }
   195	    return ext
   196	
   197	
   198	def project_full_cost(
   199	    *,
   200	    prompt_tokens: int,
   201	    completion_tokens: int,
   202	    n_calls: int,
   203	    price_in_per_1m: float,
   204	    price_out_per_1m: float,
   205	    n_questions_full: int,
   206	    n_priced_arms: int,
   207	    context_token_budget: Optional[int] = None,
   208	    overhead_tokens: int = 60,
   209	) -> dict[str, Any]:
   210	    """$0 linear cost projection from a measured pilot (the phase-gate number).
   211	
   212	    The answerer cost is input-token-dominated (long session bodies in context). Model
   213	    per-call prompt tokens as ``overhead_tokens`` (template+question) + the context
   214	    tokens, the latter capped at ``context_token_budget`` (the window-fit lever) when
   215	    given. ``projected_full_usd`` = per-call cost × ``n_questions_full`` ×
   216	    ``n_priced_arms`` (the full priced matrix). Pure arithmetic; no LLM call."""
   217	    n_calls = max(n_calls, 1)
   218	    avg_prompt = prompt_tokens / n_calls
   219	    avg_comp = completion_tokens / n_calls
   220	    ctx_tokens = max(avg_prompt - overhead_tokens, 0.0)
   221	    if context_token_budget is not None:
   222	        ctx_tokens = min(ctx_tokens, float(context_token_budget))
   223	    proj_prompt = overhead_tokens + ctx_tokens
   224	    cost_per_call = proj_prompt / 1e6 * price_in_per_1m + avg_comp / 1e6 * price_out_per_1m
   225	    full_calls = n_questions_full * n_priced_arms
   226	    return {
   227	        "context_token_budget": context_token_budget,
   228	        "projected_prompt_tokens_per_call": round(proj_prompt, 1),
   229	        "cost_per_call_usd": round(cost_per_call, 6),
   230	        "projected_full_calls": full_calls,
   231	        "projected_full_usd": round(cost_per_call * full_calls, 2),
   232	    }
   233	
   234	
   235	def answer_completeness(
   236	    records: Sequence[Mapping[str, Any]],
   237	    *,
   238	    arms: Sequence[str],
   239	    n_errors: int,
   240	    floor: float = VALID_COMPLETENESS_FLOOR,

