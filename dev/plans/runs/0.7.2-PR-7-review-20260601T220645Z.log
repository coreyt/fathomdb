     1	//! 0.7.2 PR-7 — `perf-regression-check` bin behaviour tests.
     2	//!
     3	//! TDD surface for the perf-regression detector (see
     4	//! `dev/design/perf-regression-detection.md`). Each test drives the bin
     5	//! against a JSON-per-run fixture directory and asserts the exit code + the
     6	//! flag verdict.
     7	//!
     8	//! Fixture directories (`tests/fixtures/`):
     9	//! - `regression/`      — known degradations; MUST flag (exit 1).
    10	//! - `jitter/`          — normal noise within thresholds; MUST NOT flag (exit 0).
    11	//! - `backfill-dirty/`  — real history ending at the 2026-05-27 batch-collapse
    12	//!   bug (`035cfa3`); MUST flag (exit 1).
    13	//! - `backfill-clean/`  — clean history (excluding the bug); MUST NOT flag.
    14	//! - `insufficient/`    — one row in a group (no median possible); graceful, no flag.
    15	//! - `malformed/`       — a record violating the schema; MUST exit 2.
    16	
    17	use std::path::PathBuf;
    18	use std::process::Command;
    19	
    20	fn bin() -> Command {
    21	    Command::new(env!("CARGO_BIN_EXE_perf-regression-check"))
    22	}
    23	
    24	fn fixture(name: &str) -> PathBuf {
    25	    PathBuf::from(env!("CARGO_MANIFEST_DIR")).join("tests/fixtures").join(name)
    26	}
    27	
    28	/// Repo-root-relative `dev/perf-history/` (the committed, append-only store).
    29	/// CARGO_MANIFEST_DIR is `src/rust/crates/fathomdb-cli`; walk up to repo root.
    30	fn committed_perf_history() -> PathBuf {
    31	    PathBuf::from(env!("CARGO_MANIFEST_DIR")).join("../../../..").join("dev/perf-history")
    32	}
    33	
    34	fn run_on(dir: PathBuf, extra: &[&str]) -> std::process::Output {
    35	    let mut cmd = bin();
    36	    cmd.arg(dir);
    37	    cmd.args(extra);
    38	    cmd.output().expect("spawn perf-regression-check")
