    54	// ===========================================================================
    55	// Detection thresholds — HITL Gate 1, LOCKED 2026-06-01.
    56	//
    57	// These are the ONLY tuning knobs for the detector. Keep them here as named,
    58	// commented constants — do NOT scatter numeric literals through the logic.
    59	// Rationale (full text in dev/design/perf-regression-detection.md):
    60	//   * Recall sigma = 0.0116 (PR-3 measured, N=7667 anchor). A 0.03 absolute
    61	//     recall threshold is ~2.4 sigma (~1% jitter false-flag rate) — the
    62	//     deliberate low-cry-wolf choice; codex's review focus is false-positive
    63	//     resistance. Tradeoff: a 0.03 drop from 0.937 lands at 0.907, near the
    64	//     0.90 floor, so this favours false-positive resistance over early-
    65	//     warning sensitivity (the hard floor is enforced by the AC-013b gate,
    66	//     not by this drift detector).
    67	//   * 15% latency absorbs normal run-to-run variance on the shared 4-core
    68	//     canonical CI runner (cold-cache + neighbour noise swing latency more
    69	//     than recall).
    70	//   * Window = the prior up-to-10 runs per (ac_id, n) group; "latest" is the
    71	//     single most-recent run by timestamp, compared against the median of the
    72	//     prior runs in the window.
    73	// ===========================================================================
    74	
    75	/// Flag a latency metric if the latest run exceeds the rolling median by more
    76	/// than this fraction (15%).
    77	const LATENCY_DEGRADATION_FRACTION: f64 = 0.15;
    78	
    79	/// Flag recall if the latest run is below the rolling median by more than this
    80	/// absolute amount (0.03).
    81	const RECALL_DEGRADATION_ABSOLUTE: f64 = 0.03;
    82	
    83	/// Rolling-median window: the most-recent run is compared against the median
    84	/// of up to this many prior runs in its group.
    85	const ROLLING_WINDOW: usize = 10;
    86	
    87	/// A group needs at least this many runs to evaluate (1 latest + >=1 prior).
    88	const MIN_RUNS_FOR_MEDIAN: usize = 2;
