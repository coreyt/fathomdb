    92	#[derive(Debug, Deserialize)]
    93	struct RawRecord {
    94	    commit_sha: String,
    95	    ac_id: String,
    96	    n: u64,
    97	    #[serde(default)]
    98	    p50_ms: Option<f64>,
    99	    #[serde(default)]
   100	    p99_ms: Option<f64>,
   101	    #[serde(default)]
   102	    recall: Option<f64>,
   103	    timestamp: String,
   104	    // Forward-extensible: any unknown field is ignored, not rejected
   105	    // (serde's deny_unknown_fields is intentionally OFF).
   106	}
   107	
   108	#[derive(Debug, Clone)]
   109	struct Record {
   110	    commit_sha: String,
   111	    ac_id: String,
   112	    n: u64,
   113	    p50_ms: Option<f64>,
   114	    p99_ms: Option<f64>,
   115	    recall: Option<f64>,
   116	    timestamp: String,
   117	}
   118	
   119	/// A loaded record paired with the file it came from (for error messages).
   120	fn load_record(path: &Path) -> Result<Record, String> {
   121	    let text = std::fs::read_to_string(path)
   122	        .map_err(|e| format!("{}: cannot read: {e}", path.display()))?;
   123	    let raw: RawRecord = serde_json::from_str(&text)
   124	        .map_err(|e| format!("{}: invalid JSON / schema: {e}", path.display()))?;
   125	    // A record must carry at least one comparable metric.
   126	    if raw.p50_ms.is_none() && raw.p99_ms.is_none() && raw.recall.is_none() {
   127	        return Err(format!(
   128	            "{}: record has no comparable metric (need p50_ms/p99_ms or recall)",
   129	            path.display()
   130	        ));
   131	    }
   132	    Ok(Record {
   133	        commit_sha: raw.commit_sha,
   134	        ac_id: raw.ac_id,
   135	        n: raw.n,
   136	        p50_ms: raw.p50_ms,
   137	        p99_ms: raw.p99_ms,
   138	        recall: raw.recall,
   139	        timestamp: raw.timestamp,
   140	    })
   141	}
   142	
   143	/// Median of a slice (sorted copy; mean of the two middle elements for an even
   144	/// count). Returns `None` for an empty slice.
   145	fn median(values: &[f64]) -> Option<f64> {
   146	    if values.is_empty() {
   147	        return None;
   148	    }
   149	    let mut v = values.to_vec();
   150	    v.sort_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal));
   151	    let mid = v.len() / 2;
   152	    if v.len() % 2 == 1 {
   153	        Some(v[mid])
   154	    } else {
   155	        Some((v[mid - 1] + v[mid]) / 2.0)
   156	    }
   157	}
   158	
   159	#[derive(Debug, serde::Serialize)]
   160	struct GroupVerdict {
   161	    ac_id: String,
   162	    n: u64,
   163	    latest_commit: String,
   164	    latest_timestamp: String,
   165	    runs: usize,
   166	    flagged: bool,
   167	    /// "ok" | "insufficient-history" | "regression"
   168	    status: String,
   169	    reasons: Vec<String>,
   170	}
   171	
   172	#[derive(Debug, serde::Serialize)]
   173	struct Report {
   174	    flagged: bool,
   175	    groups: Vec<GroupVerdict>,
   176	}
   177	
   178	/// Evaluate one group's runs (already sorted oldest -> newest by timestamp).
   179	fn evaluate_group(ac_id: &str, n: u64, runs: &[Record]) -> GroupVerdict {
   180	    let latest = runs.last().expect("group is never empty");
   181	    let mut verdict = GroupVerdict {
   182	        ac_id: ac_id.to_string(),
   183	        n,
   184	        latest_commit: latest.commit_sha.clone(),
   185	        latest_timestamp: latest.timestamp.clone(),
   186	        runs: runs.len(),
   187	        flagged: false,
   188	        status: "ok".to_string(),
   189	        reasons: Vec::new(),
   190	    };
   191	
   192	    if runs.len() < MIN_RUNS_FOR_MEDIAN {
   193	        verdict.status = "insufficient-history".to_string();
   194	        verdict.reasons.push(format!(
   195	            "only {} run(s) in group; need >= {} to form a median",
   196	            runs.len(),
   197	            MIN_RUNS_FOR_MEDIAN
   198	        ));
   199	        return verdict;
   200	    }
   201	
   202	    // Prior runs = the up-to-ROLLING_WINDOW runs immediately before the latest.
   203	    let prior = &runs[..runs.len() - 1];
   204	    let window_start = prior.len().saturating_sub(ROLLING_WINDOW);
   205	    let window = &prior[window_start..];
   206	
   207	    // Latency: flag if p50 OR p99 degraded > LATENCY_DEGRADATION_FRACTION.
   208	    for (label, get) in [
   209	        ("p50_ms", &Record::p50_ms as &dyn Fn(&Record) -> Option<f64>),
   210	        ("p99_ms", &Record::p99_ms as &dyn Fn(&Record) -> Option<f64>),
   211	    ] {
   212	        let prior_vals: Vec<f64> = window.iter().filter_map(get).collect();
   213	        if let (Some(latest_v), Some(med)) = (get(latest), median(&prior_vals)) {
   214	            if med > 0.0 {
   215	                let frac = (latest_v - med) / med;
   216	                if frac > LATENCY_DEGRADATION_FRACTION {
   217	                    verdict.flagged = true;
   218	                    verdict.reasons.push(format!(
   219	                        "{label} {latest_v:.2} ms is {:.1}% over rolling median {med:.2} ms (threshold {:.0}%) at commit {}",
   220	                        frac * 100.0,
   221	                        LATENCY_DEGRADATION_FRACTION * 100.0,
   222	                        latest.commit_sha,
   223	                    ));
   224	                }
   225	            }
   226	        }
   227	    }
   228	
   229	    // Recall: flag if degraded > RECALL_DEGRADATION_ABSOLUTE (absolute drop).
   230	    let prior_recall: Vec<f64> = window.iter().filter_map(|r| r.recall).collect();
   231	    if let (Some(latest_r), Some(med)) = (latest.recall, median(&prior_recall)) {
   232	        let drop = med - latest_r;
   233	        if drop > RECALL_DEGRADATION_ABSOLUTE {
   234	            verdict.flagged = true;
   235	            verdict.reasons.push(format!(
   236	                "recall {latest_r:.4} is {drop:.4} below rolling median {med:.4} (threshold {RECALL_DEGRADATION_ABSOLUTE}) at commit {}",
   237	                latest.commit_sha,
   238	            ));
   239	        }
   240	    }
   241	
   242	    if verdict.flagged {
   243	        verdict.status = "regression".to_string();
   244	    }
   245	    verdict
   246	}
   247	
   248	impl Record {
   249	    fn p50_ms(&self) -> Option<f64> {
   250	        self.p50_ms
   251	    }
   252	    fn p99_ms(&self) -> Option<f64> {
   253	        self.p99_ms
   254	    }
   255	}
