    93	def build_fts_engine(documents: dict[str, str], db_path: str):
    94	    """Open an FTS-only FathomDB engine, write one doc row per session (kind="doc",
    95	    no entities/edges), drain. Returns (engine, cursor_to_doc)."""
    96	    from fathomdb.engine import Engine
