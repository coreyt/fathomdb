    72	def placebo_doc(body: str, graph: dict, *, foreign: list[str], seed: int) -> str:
    73	    """Length-matched control: append the SAME token budget as the real enrichment,
    74	    drawn from a FOREIGN vocab (deterministic). If recall moves ≈ as much as real
    75	    enrichment, the effect is a length/corpus-stat artifact, not a lexical bridge."""
    76	    real = enrich_doc(body, graph)
    77	    if real == body:
    78	        return body
    79	    # Tokenize the foreign vocab to single whitespace tokens so the placebo is
    80	    # EXACTLY length-matched (codex §9 [P2]: multi-word names would over-add tokens).
    81	    tokens = [t for f in foreign for t in str(f).split() if t]
    82	    n_added = len(real.split()) - len(body.split())
    83	    if n_added <= 0 or not tokens:
    84	        return body
    85	    rng = random.Random(seed)
    86	    sampled = [rng.choice(tokens) for _ in range(n_added)]
    87	    return body + "\n\n" + " ".join(sampled)
