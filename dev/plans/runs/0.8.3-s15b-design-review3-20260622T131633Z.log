    98	    p = Path(db_path)
    99	    if p.exists():
   100	        p.unlink()
   101	    eng = Engine.open(str(p), use_default_embedder=False)
   102	    cursor_to_doc: dict[int, str] = {}
   103	    items = list(documents.items())
   104	    for i in range(0, len(items), 64):
   105	        chunk = items[i : i + 64]
   106	        receipt = eng.write([{"kind": "doc", "body": b} for _, b in chunk])
   107	        for (sid, _b), cur in zip(chunk, receipt.row_cursors):
   108	            cursor_to_doc[int(cur)] = sid
   109	    eng.drain(timeout_s=300)
   110	    return eng, cursor_to_doc
