     1	"""R6 index-key enrichment — acceptance tests (mechanism-level; design §D).
     2	
     3	Pins the enrichment MECHANISM + fairness, NOT a recall threshold (the lift is the
     4	experiment's output). Design: dev/plans/runs/0.8.1-R6-index-key-enrichment-design.md.
     5	"""
     6	
     7	from __future__ import annotations
     8	
     9	from eval.r6_index_key_enrichment import build_fts_engine, enrich_doc, placebo_doc
    10	
    11	
    12	# AC-R6-1 — enrich applies + deterministic + dedup -------------------------------
    13	def test_ac_r6_1_enrich_applies_deterministic_dedup() -> None:
    14	    g = {
    15	        "entities": [{"name": "Cooper"}, {"name": "Cooper"}, {"name": "Dr. Lin"}],
    16	        "relations": [{"subject": "Cooper", "predicate": "vet_is", "object": "Dr. Lin"}],
    17	    }
    18	    body = "I adopted a beagle last March."
    19	    e1 = enrich_doc(body, g)
    20	    e2 = enrich_doc(body, g)
    21	    assert e1 == e2, "enrichment must be deterministic (byte-identical)"
    22	    assert body in e1, "original body preserved"
    23	    assert "Cooper" in e1 and "Dr. Lin" in e1, "entity names present"
    24	    assert "vet_is" in e1, "relation predicate token present"
    25	    ents_line = next(ln for ln in e1.splitlines() if ln.startswith("[entities]"))
    26	    assert ents_line.count("Cooper") == 1, "duplicate entity names collapse (dedup, order-preserving)"
    27	
    28	
    29	# AC-R6-2 — findability + hostile-name safe --------------------------------------
    30	def test_ac_r6_2a_fact_only_token_becomes_present() -> None:
    31	    g = {"entities": [{"name": "Zephyrine"}], "relations": []}
    32	    body = "a session with no special token in it"
    33	    e = enrich_doc(body, g)
    34	    assert "Zephyrine" not in body and "Zephyrine" in e, "fact-only token becomes lexically present"
    35	
    36	
    37	def test_ac_r6_2b_findability_through_engine(db_path: str) -> None:
