   121	def _pooled_r10(retrieval: dict, variant: str) -> Optional[float]:
   122	    pc = retrieval.get(variant, {}).get("per_class", {})
   123	    num = den = 0.0
   124	    for m in pc.values():
   125	        rv, ns = m.get("recall_at_10"), m.get("n_scored", 0)
   126	        if rv is not None and ns:
   127	            num += rv * ns
   128	            den += ns
   129	    return round(num / den, 3) if den else None
