    46	def _facts(graph: dict) -> list[str]:
    47	    out: list[str] = []
    48	    for r in graph.get("relations") or []:
    49	        if not isinstance(r, dict):
    50	            continue
    51	        toks = [str(r.get(k, "")).strip() for k in ("subject", "predicate", "object")]
    52	        toks = [t for t in toks if t]
    53	        if toks:
    54	            out.append(" ".join(toks))
    55	    return out
