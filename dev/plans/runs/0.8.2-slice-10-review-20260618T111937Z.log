dependencies = []

[project.optional-dependencies]
test = ["pytest>=8", "hypothesis>=6", "maturin>=1.7,<2", "pyyaml>=6"]
lint = ["ruff>=0.6"]
typecheck = ["pyright>=1.1.380"]
dev = ["pytest>=8", "hypothesis>=6", "ruff>=0.6", "pyright>=1.1.380", "maturin>=1.7,<2", "pyyaml>=6"]

[tool.maturin]
manifest-path = "../rust/crates/fathomdb-py/Cargo.toml"
module-name = "fathomdb._fathomdb"
python-source = "."
# EU-6 FIX-1: this list is what BOTH editable installs (`pip install -e .`,
# `maturin develop`) AND the release workflow's `PyO3/maturin-action`
# inherit unless they pass an explicit `--features` override. Therefore
# it must match the SHIPPED feature surface exactly:
