+  },
+  "api_shape_decision": {
+    "chosen": "thread a `ReadView` parameter through the five existing read verbs",
+    "rejected": "`*_with_view` sibling verbs",
+    "rationale": "Governed-surface minimisation. Sibling verbs would have added roughly eight new allowlist members across the Py/TS naming conventions (read.get_with_view / readGetWithView, and so on for five verbs); threading adds ZERO new verb names on the read path. The net delta is TWO TYPES (`ReadView`, `BoundaryCrossing`) plus ONE genuinely new command (`crossed_boundary_since`, which has no existing verb to ride on). 0.8.20 is already breaking on the Rust facade, and in both bindings the parameter is OPTIONAL (`view=None` / `view?`), so neither SDK is source-broken. Cost: ~60 internal/test call sites updated to pass `&ReadView::default()` — mechanical, and it has the side benefit that every pre-existing read-verb test now explicitly exercises the strict view."
+  },
+  "integer_vs_text_divergence": {
+    "flag": "DELIBERATE DIVERGENCE — ESCALATED TO HITL, NOT SILENTLY RESOLVED",
+    "what": "`canonical_nodes.valid_from` / `valid_until` are INTEGER epoch seconds. The shipped `canonical_edges.t_valid` / `t_invalid` (migration step 14) are ISO-8601 TEXT compared through `datetime(...)`. The temporal model is now internally inconsistent between nodes and edges.",
+    "why": [
+      "the R-20-NV release contract specifies INTEGER windows",
+      "an INTEGER window stays sargable against `canonical_nodes_validity_idx` with no per-row `datetime()` conversion",
+      "INTEGER lets the instant be a BOUND parameter (the `:now` seam), which is what makes node validity deterministically testable; the shipped EDGE path still inlines `datetime('now')`",
+      "unifying would either re-litigate shipped edge semantics or force a data rewrite of `canonical_edges` — both out of scope for this slice"
+    ],
+    "not_done": "The edge columns were NOT changed, NOT unified, and NOT rewritten. Pinned by `s22_edge_temporal_columns_are_untouched_text` and `r_20_nv_edge_temporal_filter_is_unchanged` so the divergence is a recorded decision rather than drift.",
