+            node: NodeRecord {
+                logical_id: row.get(0)?,
+                kind: row.get(1)?,
+                body: row.get(2)?,
+                write_cursor: row.get::<_, i64>(3)? as u64,
+            },
+            became_valid_at: valid_from.filter(|t| *t > since && *t <= upper),
+            became_invalid_at: valid_until.filter(|t| *t > since && *t <= upper),
+        })
+    })?;
+    let mut out = Vec::new();
+    for row in rows {
+        out.push(row?);
