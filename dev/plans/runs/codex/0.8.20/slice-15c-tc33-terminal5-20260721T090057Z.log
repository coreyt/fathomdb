+    // Optional zone.
+    if i == b.len() {
+        return true; // no zone
+    }
+    match b[i] {
+        b'Z' => i += 1,
+        b'+' | b'-' => {
+            i += 1;
+            // `HH`
+            if i + 2 > b.len() || !d(b[i]) || !d(b[i + 1]) {
+                return false;
+            }
+            i += 2;
+            // `:MM` or `MM`
+            if i < b.len() && b[i] == b':' {
+                i += 1;
+            }
+            if i + 2 > b.len() || !d(b[i]) || !d(b[i + 1]) {
+                return false;
+            }
+            i += 2;
+        }
+        _ => return false,
+    }
