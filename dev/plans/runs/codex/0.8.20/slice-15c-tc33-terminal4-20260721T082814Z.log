-    }
     let rows = statement.query_map(rusqlite::params_from_iter(binds.iter()), |row| {
         Ok(NodeRecord {
             logical_id: row.get(0)?,
             kind: row.get(1)?,
             body: row.get(2)?,
             write_cursor: row.get::<_, i64>(3)? as u64,
