+fn iso8601_to_epoch_seconds(connection: &Connection, raw: &str) -> Option<i64> {
+    connection
+        .query_row("SELECT CAST(strftime('%s', ?1) AS INTEGER)", params![raw], |r| {
+            r.get::<_, Option<i64>>(0)
