11705-        connection.execute(
11706-            "INSERT INTO _fathomdb_open_state(key, value) VALUES(?1, ?2)
11707-             ON CONFLICT(key) DO UPDATE SET value = excluded.value",
11708-            params![SEARCH_INDEX_TOKENIZER_REPROJECT_MARKER_KEY, "1"],
