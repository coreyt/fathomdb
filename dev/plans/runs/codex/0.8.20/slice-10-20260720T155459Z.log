+#[test]
+fn tc31_text_hit_carries_source_id_and_erases() {
+    let dir = TempDir::new().unwrap();
+    let path = db_path(&dir, "tc31_text");
+    let opened = Engine::open_without_embedder_for_test(&path).expect("open");
+
+    let receipt = opened
+        .engine
