+        cursor_column: "write_cursor",
+        class: ProjectionClass::NodeFts,
+    },
+    RowOwnedProjection {
+        table: "search_index_edges",
+        cursor_column: "write_cursor",
+        class: ProjectionClass::EdgeFts,
+    },
+    RowOwnedProjection {
+        table: "vector_default",
+        cursor_column: "rowid",
+        class: ProjectionClass::Vector,
+    },
+    RowOwnedProjection {
