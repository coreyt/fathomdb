 11302	fn canonical_database_path(path: &Path) -> Result<PathBuf, EngineOpenError> {
 11303	    let parent = path
 11304	        .parent()
 11305	        .filter(|parent| !parent.as_os_str().is_empty())
 11306	        .unwrap_or_else(|| Path::new("."));
 11307	    let canonical_parent = parent.canonicalize().map_err(|_| EngineOpenError::Io {
 11308	        message: "database parent directory is not accessible".to_string(),
 11309	    })?;
 11310	    let file_name = path.file_name().ok_or_else(|| EngineOpenError::Io {
 11311	        message: "database path has no file name".to_string(),
 11312	    })?;
 11313	
 11314	    Ok(canonical_parent.join(file_name))
 11315	}
