 11183	/// 0.8.20 Slice 5b (R-20-E6) — the prefixed stable ids
 11184	/// ([`IdSpace::to_prefixed`]) of the canonical rows an erasure verb is about to
 11185	/// delete, so they can be redacted from the telemetry sink.
 11186	///
 11187	/// Must be called INSIDE the erasing transaction and BEFORE the DELETEs — after
 11188	/// them the rows, and with them the `logical_id`/`body` the ids derive from, are
 11189	/// gone. Both queries take one bound parameter (`?1`), applied to nodes and
 11190	/// edges respectively; `derive_stable_id` reproduces exactly what
 11191	/// `capture_telemetry` wrote into `result_stable_ids`.
 11192	fn collect_erased_stable_ids(
 11193	    tx: &Connection,
 11194	    node_sql: &str,
 11195	    edge_sql: &str,
 11196	    bind: &str,
 11197	) -> Result<Vec<String>, EngineError> {
 11198	    let mut ids = Vec::new();
 11199	    for sql in [node_sql, edge_sql] {
 11200	        let mut stmt = tx.prepare(sql).map_err(|_| EngineError::Storage)?;
 11201	        let rows = stmt
 11202	            .query_map(params![bind], |row| {
 11203	                Ok((row.get::<_, Option<String>>(0)?, row.get::<_, Option<String>>(1)?))
 11204	            })
 11205	            .map_err(|_| EngineError::Storage)?;
 11206	        for row in rows {
 11207	            let (logical_id, body) = row.map_err(|_| EngineError::Storage)?;
 11208	            ids.push(
 11209	                derive_stable_id(logical_id.as_deref(), body.as_deref().unwrap_or(""))
 11210	                    .to_prefixed(),
 11211	            );
 11212	        }
 11213	    }
 11214	    ids.sort_unstable();
 11215	    ids.dedup();
 11216	    Ok(ids)
 11217	}
