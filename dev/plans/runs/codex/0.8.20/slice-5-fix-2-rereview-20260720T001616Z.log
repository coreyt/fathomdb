 11495	/// Pre-`pragma WAL` sidecar validation. SQLite silently discards a WAL
 11496	/// file whose header magic is wrong or whose advertised page size is
 11497	/// outside `[512, SQLITE_MAX_PAGE_SIZE]`, which would cause us to lose
 11498	/// committed frames at open time. AC-035a requires that we instead
 11499	/// refuse to open with `Corruption(WalReplayFailure)` rather than
 11500	/// silently rebuild from a truncated WAL.
 11501	fn probe_wal_sidecar(db_path: &Path) -> Result<(), EngineOpenError> {
 11502	    let mut wal_path = db_path.as_os_str().to_owned();
 11503	    wal_path.push("-wal");
 11504	    let wal_path = PathBuf::from(wal_path);
 11505	    // Bounded read: the WAL header is fixed-layout in the first 32
 11506	    // bytes (magic + format + page-size + checkpoint-seq + salts +
 11507	    // checksums); frame data starts at offset 32 and is irrelevant to
 11508	    // the magic + page-size pre-check. A `std::fs::read` of the whole
 11509	    // sidecar would force an unclean-shutdown open path to allocate
 11510	    // and copy the entire WAL into memory before SQLite touches
 11511	    // recovery — a real latency + RSS regression on AC-035.
 11512	    use std::io::Read;
 11513	    let mut file = match std::fs::File::open(&wal_path) {
 11514	        Ok(file) => file,
 11515	        Err(err) if err.kind() == std::io::ErrorKind::NotFound => return Ok(()),
 11516	        Err(_) => return Ok(()),
 11517	    };
 11518	    let mut bytes = [0u8; 32];
 11519	    if file.read_exact(&mut bytes).is_err() {
 11520	        // A short (< 32-byte) sidecar carries no committed frames;
 11521	        // SQLite treats it as empty and re-initializes WAL state.
 11522	        return Ok(());
 11523	    }
 11524	    let magic = u32::from_be_bytes([bytes[0], bytes[1], bytes[2], bytes[3]]);
 11525	    let page_size = u32::from_be_bytes([bytes[8], bytes[9], bytes[10], bytes[11]]);
 11526	    // WAL_MAGIC mask per SQLite `walIndexRecover`: low bit distinguishes
 11527	    // big-endian vs little-endian checksum encoding; the rest of the
 11528	    // magic is fixed.
 11529	    const WAL_MAGIC_MASK: u32 = 0xFFFF_FFFE;
 11530	    const WAL_MAGIC: u32 = 0x377F_0682;
 11531	    const SQLITE_MAX_PAGE_SIZE: u32 = 65536;
 11532	    let magic_ok = (magic & WAL_MAGIC_MASK) == WAL_MAGIC;
 11533	    let page_size_ok =
 11534	        page_size.is_power_of_two() && (512..=SQLITE_MAX_PAGE_SIZE).contains(&page_size);
 11535	    if magic_ok && page_size_ok {
 11536	        return Ok(());
 11537	    }
 11538	    Err(EngineOpenError::Corruption(CorruptionDetail {
 11539	        kind: CorruptionKind::WalReplayFailure,
 11540	        stage: OpenStage::WalReplay,
 11541	        locator: CorruptionLocator::FileOffset { offset: if !magic_ok { 0 } else { 8 } },
 11542	        recovery_hint: RecoveryHint {
 11543	            code: "E_CORRUPT_WAL_REPLAY",
 11544	            doc_anchor: "design/recovery.md#wal-replay-failures",
 11545	        },
 11546	    }))
 11547	}
