 11251	/// 0.8.20 Slice 5b (R-20-E7) — the audit handle for an erased op-store record:
 11252	/// `SHA-256(collection + 0x1F + record_key)`, lowercase hex.
 11253	///
 11254	/// A record key is arbitrary caller-supplied text and may itself be the
 11255	/// identifier being erased, so a durable audit row must not echo it. `0x1F`
 11256	/// (ASCII unit separator) is the delimiter because it cannot appear in a
 11257	/// well-formed collection name, keeping the pairing unambiguous.
 11258	#[cfg(feature = "operator")]
 11259	fn digest_record_identity(collection: &str, record_key: &str) -> String {
 11260	    let mut hasher = Sha256::new();
 11261	    hasher.update(collection.as_bytes());
 11262	    hasher.update([0x1f_u8]);
 11263	    hasher.update(record_key.as_bytes());
 11264	    hasher.finalize().iter().map(|b| format!("{b:02x}")).collect()
 11265	}
