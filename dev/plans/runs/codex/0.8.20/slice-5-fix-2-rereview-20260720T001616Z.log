 11358	            EngineOpenError::IncompatibleSchemaVersion { seen, supported }
 11359	        }
 11360	        SchemaMigrationError::MigrationError(report) => EngineOpenError::MigrationError {
 11361	            schema_version_before: report.schema_version_before,
 11362	            schema_version_current: report.schema_version_current,
 11363	            step_id: report.migration_steps.last().map_or(0, |step| step.step_id),
 11364	        },
 11365	        SchemaMigrationError::Storage { message } => {
 11366	            EngineOpenError::Io { message: message.to_string() }
 11367	        }
 11368	    }
