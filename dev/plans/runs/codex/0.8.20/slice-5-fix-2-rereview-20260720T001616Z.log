 11317	fn acquire_lock(path: &Path) -> Result<File, EngineOpenError> {
 11318	    let lock_path = lock_path(path);
 11319	    let mut options = OpenOptions::new();
 11320	    options.read(true).write(true).create(true);
 11321	    #[cfg(unix)]
 11322	    options.mode(0o600);
 11323	
 11324	    let mut file = options.open(&lock_path).map_err(|_| EngineOpenError::Io {
 11325	        message: "could not open database lock file".to_string(),
 11326	    })?;
 11327	
 11328	    match file.try_lock() {
 11329	        Ok(()) => {
 11330	            let pid = std::process::id().to_string();
 11331	            let _ = file.set_len(0);
 11332	            let _ = file.seek(SeekFrom::Start(0));
 11333	            let _ = file.write_all(pid.as_bytes());
 11334	            Ok(file)
 11335	        }
 11336	        Err(std::fs::TryLockError::WouldBlock) => {
 11337	            Err(EngineOpenError::DatabaseLocked { holder_pid: read_holder_pid(&lock_path) })
 11338	        }
 11339	        Err(_) => {
 11340	            Err(EngineOpenError::Io { message: "could not acquire database lock".to_string() })
 11341	        }
 11342	    }
 11343	}
