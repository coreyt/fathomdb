  7836	/// Line-wise redaction of a JSONL byte buffer. Non-JSON and non-event lines are
  7837	/// passed through unchanged, as is a trailing partial line (no terminating
  7838	/// newline) — the sink is append-only, so a partial tail is a torn write, not
  7839	/// ours to normalize.
  7840	fn redact_jsonl_bytes(bytes: &[u8], erased: &std::collections::HashSet<&str>) -> Vec<u8> {
  7841	    let mut out = Vec::with_capacity(bytes.len());
  7842	    let mut rest = bytes;
  7843	    while !rest.is_empty() {
  7844	        let (line, tail) = match rest.iter().position(|b| *b == b'\n') {
  7845	            Some(idx) => (&rest[..idx], &rest[idx + 1..]),
  7846	            // No trailing newline: a torn/partial final line. Pass it through.
  7847	            None => {
  7848	                out.extend_from_slice(rest);
  7849	                break;
  7850	            }
  7851	        };
  7852	        match redact_jsonl_line(line, erased) {
  7853	            Some(replacement) => out.extend_from_slice(replacement.as_bytes()),
  7854	            None => out.extend_from_slice(line),
  7855	        }
  7856	        out.push(b'\n');
  7857	        rest = tail;
  7858	    }
  7859	    out
  7860	}
