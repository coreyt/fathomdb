 11219	/// 0.8.20 Slice 5 fix-1 (codex §9 P2) — record, INSIDE the erasing transaction,
 11220	/// that a telemetry redaction is owed for `erased_stable_ids`.
 11221	///
 11222	/// Must be called in the same transaction as the DELETEs. That is the whole
 11223	/// point: "the rows are gone" and "a redaction is owed for them" then commit
 11224	/// atomically, so no crash or failure can leave the first true and the second
 11225	/// unrecorded. [`Engine::discharge_pending_redactions`] drains the queue and
 11226	/// deletes the entry only once the sink has actually been rewritten.
 11227	///
 11228	/// `record_key` is the VERB, never a stable id — the ids live in the payload,
 11229	/// which is deleted on discharge.
 11230	fn enqueue_pending_redaction(
 11231	    tx: &Connection,
 11232	    verb: &str,
 11233	    erased_stable_ids: &[String],
 11234	    write_cursor: u64,
 11235	) -> Result<(), EngineError> {
 11236	    if erased_stable_ids.is_empty() {
 11237	        return Ok(());
 11238	    }
 11239	    let payload =
 11240	        serde_json::json!({ "verb": verb, "erased_stable_ids": erased_stable_ids }).to_string();
 11241	    tx.execute(
 11242	        "INSERT INTO operational_mutations(
 11243	            collection_name, record_key, op_kind, payload_json, schema_id, write_cursor
 11244	         ) VALUES(?1, ?2, 'append', ?3, NULL, ?4)",
 11245	        params![ERASURE_PENDING_REDACTION_COLLECTION, verb, payload, write_cursor],
 11246	    )
 11247	    .map_err(|_| EngineError::Storage)?;
 11248	    Ok(())
 11249	}
