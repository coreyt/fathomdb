  7774	/// 0.8.20 Slice 5b (R-20-E6) — rewrite a telemetry JSONL sink with every
  7775	/// `result_stable_ids` element in `erased` replaced by [`REDACTED_STABLE_ID`].
  7776	///
  7777	/// **Selective, never truncating.** Every line is carried across: records that
  7778	/// reference no erased id are byte-identical, records that do keep their shape
  7779	/// and only lose the matching id VALUES, and a line that is not an
  7780	/// engine-authored JSON event (an operator note, a hand-appended record) is
  7781	/// copied through verbatim. The sink is a caller-supplied path that may hold
  7782	/// unrelated eval history; destroying it is not part of any erasure obligation.
  7783	///
  7784	/// **Crash safety.** Write-temp-then-`rename`: the redacted content goes to a
  7785	/// sibling `<sink>.redact.tmp`, is `sync_all`ed, and is then atomically renamed
  7786	/// over the sink. A crash at any point leaves either the intact old file or the
  7787	/// complete new one — never a half-rewritten sink. `rename` is atomic because
  7788	/// the temp file is a sibling (same directory ⇒ same filesystem).
  7789	///
  7790	/// **Concurrent appends.** The caller holds the telemetry mutex, so no
  7791	/// in-process `capture_telemetry` can append into the window. An out-of-process
  7792	/// appender is still possible (the sink is just a file), so before renaming we
  7793	/// re-check the source length: if it grew, the tail delta is read, redacted and
  7794	/// appended, and the check repeats — bounded, so a pathologically hot external
  7795	/// writer surfaces as an error rather than an unbounded loop.
  7796	fn redact_jsonl_stable_ids(
  7797	    path: &Path,
  7798	    erased: &std::collections::HashSet<&str>,
  7799	) -> std::io::Result<()> {
  7800	    /// Bound on the re-check loop for an out-of-process appender.
  7801	    const MAX_TAIL_FOLDS: usize = 8;
  7802	
  7803	    let mut source = std::fs::read(path)?;
  7804	    let mut redacted = redact_jsonl_bytes(&source, erased);
  7805	
  7806	    for _ in 0..MAX_TAIL_FOLDS {
  7807	        let current = std::fs::read(path)?;
  7808	        if current.len() == source.len() {
  7809	            let mut tmp_name = path.file_name().unwrap_or_default().to_os_string();
  7810	            tmp_name.push(".redact.tmp");
  7811	            let tmp = path.with_file_name(tmp_name);
  7812	            {
  7813	                let mut file = std::fs::File::create(&tmp)?;
  7814	                file.write_all(&redacted)?;
  7815	                file.sync_all()?;
  7816	            }
  7817	            std::fs::rename(&tmp, path)?;
  7818	            return Ok(());
  7819	        }
  7820	        // Someone appended while we were building the replacement: fold the
  7821	        // delta in (redacted) rather than dropping it, then re-check.
  7822	        if current.len() > source.len() && current.starts_with(&source) {
  7823	            redacted.extend_from_slice(&redact_jsonl_bytes(&current[source.len()..], erased));
  7824	        } else {
