 11371	/// 0.7.0 perf-experiments hook: process-start `sqlite3_config` calls.
 11372	/// Runs exactly once per process; must precede any `Connection::open`.
 11373	/// Gated on `FATHOMDB_PERF_EXPERIMENTS=1`. Each individual config
 11374	/// option is opt-in via its own env var so unrelated experiments do
 11375	/// not implicitly co-fire.
 11376	///
 11377	/// Currently supports:
 11378	/// - `FATHOMDB_PERF_SQLITE_MEMSTATUS_OFF=1`:
 11379	///   `sqlite3_config(SQLITE_CONFIG_MEMSTATUS, 0)` — drops the
 11380	///   allocator stats locking surface (whitepaper § 7.4). Composes
 11381	///   with other levers; small payoff alone.
 11382	///
 11383	/// Pattern: shutdown → config → initialize, mirroring B.1 attempt #2
 11384	/// (`d448263`, reverted). The captured rc for each config call is
 11385	/// logged to stderr so experiments can verify the call took effect.
 11386	fn init_perf_experiments_runtime() {
 11387	    static INIT: Once = Once::new();
 11388	    INIT.call_once(|| {
 11389	        if std::env::var_os("FATHOMDB_PERF_EXPERIMENTS").is_none() {
 11390	            return;
 11391	        }
 11392	        let memstatus_off =
 11393	            std::env::var_os("FATHOMDB_PERF_SQLITE_MEMSTATUS_OFF").is_some_and(|v| v == "1");
 11394	        // FATHOMDB_PERF_SQLITE_PAGECACHE=<page_size_bytes>:<page_count>
 11395	        // E.g. "4096:5000" => pre-allocate 4096 B × 5000 pages = 20 MB
 11396	        // global page-cache backing. SQLite distributes this across
 11397	        // connections; reduces global allocator pressure for page
 11398	        // cache fills.
 11399	        let pagecache = std::env::var("FATHOMDB_PERF_SQLITE_PAGECACHE").ok();
 11400	        // FATHOMDB_PERF_SQLITE_PCACHE2=1 installs the per-instance
 11401	        // custom page-cache allocator (pcache2.rs). Targets AC-020
 11402	        // residual contention on the default pcache1 mutex.
 11403	        let pcache2_on =
 11404	            std::env::var_os("FATHOMDB_PERF_SQLITE_PCACHE2").is_some_and(|v| v == "1");
 11405	        if !memstatus_off && pagecache.is_none() && !pcache2_on {
 11406	            return;
 11407	        }
 11408	        // SAFETY: sqlite3_shutdown / sqlite3_initialize are documented
 11409	        // as safe to call before any other SQLite API; sqlite3_config
 11410	        // must be called between shutdown and initialize. We pre-empt
 11411	        // rusqlite's lazy first-call sqlite3_initialize via this
 11412	        // explicit shutdown-then-config-then-initialize sequence,
 11413	        // identical to B.1 attempt #2's plumbing.
 11414	        unsafe {
 11415	            let rc_shutdown = rusqlite::ffi::sqlite3_shutdown();
 11416	            let rc_memstatus = if memstatus_off {
 11417	                rusqlite::ffi::sqlite3_config(rusqlite::ffi::SQLITE_CONFIG_MEMSTATUS, 0_i32)
 11418	            } else {
 11419	                -1
 11420	            };
 11421	            // SQLITE_CONFIG_PAGECACHE = 7 per sqlite3.h. With buffer=NULL,
 11422	            // SQLite allocates the backing memory itself but still
 11423	            // partitions it for use as the page-cache pool.
 11424	            let rc_pagecache = if let Some(spec) = pagecache.as_ref() {
 11425	                let mut parts = spec.split(':');
 11426	                let sz = parts.next().and_then(|s| s.parse::<i32>().ok()).unwrap_or(0);
 11427	                let n = parts.next().and_then(|s| s.parse::<i32>().ok()).unwrap_or(0);
 11428	                if sz > 0 && n > 0 {
 11429	                    rusqlite::ffi::sqlite3_config(
 11430	                        7, // SQLITE_CONFIG_PAGECACHE
 11431	                        std::ptr::null_mut::<std::ffi::c_void>(),
 11432	                        sz,
 11433	                        n,
 11434	                    )
 11435	                } else {
 11436	                    eprintln!(
 11437	                        "perf-experiment: bad FATHOMDB_PERF_SQLITE_PAGECACHE spec '{spec}' (expect '<bytes>:<count>')"
 11438	                    );
 11439	                    -1
 11440	                }
 11441	            } else {
 11442	                -1
 11443	            };
 11444	            let rc_pcache2 = if pcache2_on {
 11445	                // SQLITE_CONFIG_PCACHE2 = 18 per sqlite3.h. The methods
 11446	                // table must outlive the SQLite engine; we pass a
 11447	                // pointer to our static.
 11448	                rusqlite::ffi::sqlite3_config(
 11449	                    rusqlite::ffi::SQLITE_CONFIG_PCACHE2,
 11450	                    &raw const pcache2::PCACHE2_METHODS.0,
 11451	                )
 11452	            } else {
 11453	                -1
 11454	            };
 11455	            let rc_init = rusqlite::ffi::sqlite3_initialize();
 11456	            eprintln!(
 11457	                "perf-experiment: runtime-config rcs shutdown={rc_shutdown} \
 11458	                 memstatus={rc_memstatus} pagecache={rc_pagecache} pcache2={rc_pcache2} \
 11459	                 initialize={rc_init} (0=SQLITE_OK; 21=SQLITE_MISUSE; -1=not configured)"
 11460	            );
 11461	        }
 11462	    });
 11463	}
