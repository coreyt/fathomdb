 11345	fn lock_path(path: &Path) -> PathBuf {
 11346	    let mut lock_path = path.as_os_str().to_os_string();
 11347	    lock_path.push(LOCK_SUFFIX);
 11348	    PathBuf::from(lock_path)
 11349	}
