 11267	fn projection_status(
 11268	    connection: &Connection,
 11269	    kind: &str,
 11270	) -> Result<lifecycle::ProjectionStatus, EngineError> {
 11271	    let latest = connection
 11272	        .query_row(
 11273	            "SELECT COALESCE(MAX(write_cursor), 0) FROM canonical_nodes WHERE kind = ?1",
 11274	            [kind],
 11275	            |row| row.get::<_, u64>(0),
 11276	        )
 11277	        .map_err(|_| EngineError::Storage)?;
 11278	    if latest == 0 {
 11279	        return Ok(lifecycle::ProjectionStatus::UpToDate);
 11280	    }
 11281	    let pending: u64 = connection
 11282	        .query_row(
 11283	            "SELECT COUNT(*)
 11284	             FROM canonical_nodes
 11285	             LEFT JOIN _fathomdb_projection_terminal
 11286	               ON _fathomdb_projection_terminal.write_cursor = canonical_nodes.write_cursor
 11287	             WHERE canonical_nodes.kind = ?1
 11288	               AND _fathomdb_projection_terminal.write_cursor IS NULL",
 11289	            [kind],
 11290	            |row| row.get(0),
 11291	        )
 11292	        .map_err(|_| EngineError::Storage)?;
 11293	    if pending > 0 {
 11294	        return Ok(lifecycle::ProjectionStatus::Pending);
 11295	    }
 11296	    match terminal_state_for_cursor(connection, latest).map_err(|_| EngineError::Storage)? {
 11297	        Some(state) if state == "failed" => Ok(lifecycle::ProjectionStatus::Failed),
 11298	        _ => Ok(lifecycle::ProjectionStatus::UpToDate),
 11299	    }
 11300	}
