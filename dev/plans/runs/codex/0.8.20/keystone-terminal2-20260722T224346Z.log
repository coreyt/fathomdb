+            fts: s.fts.is_some(),
+            fts_tokenizer: s.fts.as_ref().and_then(|f| f.tokenizer.clone()),
+            vector: s.vector.is_some(),
+            vector_embedder: s.vector.as_ref().and_then(|v| v.embedder.clone()),
