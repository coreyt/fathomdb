+            roles: self.roles.clone(),
+            fts: if self.fts_present {
+                Some(ProjectionFts { tokenizer: self.fts_tokenizer.clone() })
+            } else {
+                None
+            },
+            vector: if self.vector_declared {
+                Some(ProjectionVector { embedder: self.vector_embedder.clone() })
+            } else {
+                None
+            },
+        }
+    }
