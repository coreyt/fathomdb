   148	/// codex §9 [P2] — convert a napi `i64` id list to the engine's `u64`, rejecting
   149	/// any negative id (which `as u64` would silently wrap). Mirrors the TS/Python
   150	/// wrapper `validateIdArray`/`_validate_id_list` guards so a raw-napi caller
   151	/// cannot smuggle a wrapped id past the boundary.
   152	fn checked_ids_napi(name: &str, ids: &[i64]) -> Result<Vec<u64>> {
   153	    ids.iter()
   154	        .map(|&x| {
   155	            u64::try_from(x).map_err(|_| {
   156	                typed_error(
   157	                    CODE_WRITE_VALIDATION,
   158	                    format!("{name} must contain only non-negative integers, got {x}"),
   159	                    JsonValue::Null,
   160	                )
   161	            })
   162	        })
   163	        .collect()
   164	}
