   167	
   168	/// Translate every `EngineError` variant to its typed JS counterpart.
   169	///
   170	/// No catch-all arm: drift between the Rust enum and the TS class set
   171	/// is a compile error.
   172	fn engine_error_to_napi(err: RustEngineError) -> Error {
