    98	// ===== Typed-error encoder ============================================
    99	
   100	/// Encode a typed-error envelope as JSON in `err.message` so the
   101	/// TS-side `rethrowTyped` can reconstitute the right leaf class with
   102	/// the right payload. napi-rs 2.x has no public API for throwing a
   103	/// Rust-defined JS class directly; the envelope-in-message pattern is
   104	/// the canonical workaround.
   105	#[derive(Serialize)]
   106	struct TypedEnvelope<'a> {
   107	    code: &'a str,
   108	    message: String,
   109	    payload: JsonValue,
   110	}
   111	
   112	fn typed_error(code: &'static str, message: impl Into<String>, payload: JsonValue) -> Error {
   113	    let envelope = TypedEnvelope { code, message: message.into(), payload };
   114	    // serde_json serialization is infallible for our envelope shape;
   115	    // unwrap is safe.
   116	    let reason = serde_json::to_string(&envelope).unwrap();
   117	    Error::new(Status::GenericFailure, reason)
   118	}
   119	
   120	// ===== String validation (AC-068a / AC-068b) =========================
   121	
   122	/// Reject strings carrying an embedded NUL or an unpaired UTF-16
   123	/// surrogate codepoint (`U+D800..=U+DFFF`).
   124	///
   125	/// JavaScript strings are UTF-16 by spec, so lone surrogates are
   126	/// representable on the JS side (`String.fromCharCode(0xD800)`). The
   127	/// napi-rs string conversion translates UTF-16 → UTF-8 and accepts
   128	/// some malformed inputs; this helper rejects them BEFORE the writer
   129	/// transaction opens (no-row-written invariant).
   130	pub fn validate_ffi_string(value: &str) -> std::result::Result<(), String> {
   131	    if value.as_bytes().contains(&0) {
   132	        return Err("embedded NUL byte in FFI string".to_string());
   133	    }
   134	    for ch in value.chars() {
   135	        let cp = ch as u32;
   136	        if (0xD800..=0xDFFF).contains(&cp) {
   137	            return Err(format!("unpaired UTF-16 surrogate U+{cp:04X} in FFI string"));
   138	        }
   139	    }
   140	    Ok(())
   141	}
   142	
   143	fn validate_ffi_string_napi(value: &str) -> Result<()> {
   144	    validate_ffi_string(value)
   145	        .map_err(|msg| typed_error(CODE_WRITE_VALIDATION, msg, JsonValue::Null))
   146	}
