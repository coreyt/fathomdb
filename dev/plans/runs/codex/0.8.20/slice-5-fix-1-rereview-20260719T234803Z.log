-    let count: u64 =
-        connection.query_row("SELECT COUNT(*) FROM operational_mutations", [], |row| row.get(0))?;
+    let count: u64 = connection.query_row(
+        &format!(
+            "SELECT COUNT(*) FROM operational_mutations
+             WHERE collection_name NOT IN ({exempt})"
+        ),
+        [],
+        |row| row.get(0),
+    )?;
     if count <= upper {
