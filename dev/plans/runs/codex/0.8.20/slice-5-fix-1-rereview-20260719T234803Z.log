+    let mut deleted: u64 = 0;
+    for projection in ROW_OWNED_PROJECTIONS.iter().filter(|p| classes.contains(&p.class)) {
+        let sql = format!("DELETE FROM {}", projection.table);
+        deleted = deleted.saturating_add(tx.execute(&sql, [])? as u64);
+    }
+    Ok(deleted)
