+    let exempt = ERASURE_AUDIT_COLLECTIONS
+        .iter()
+        .copied()
+        .chain(std::iter::once(ERASURE_PENDING_REDACTION_COLLECTION))
+        .map(|name| format!("'{name}'"))
+        .collect::<Vec<_>>()
+        .join(", ");
