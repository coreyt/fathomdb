def test_one_authored_bound_leaves_the_other_side_unbounded(db_path: str) -> None:
    _seed(
        db_path,
        [
            _windowed("FROM_ONLY", "from only", 1000, None),
            _windowed("UNTIL_ONLY", "until only", None, 2000),
        ],
    )

