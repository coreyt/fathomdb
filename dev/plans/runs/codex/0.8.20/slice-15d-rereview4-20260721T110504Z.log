        let drop = drop.unwrap_or_default();
        let engine = Arc::clone(&self.inner);
        let delta = call_engine(move || engine.configure_projections(&rust_specs, &drop)).await?;
        Ok(ProjectionDelta::from_rust(&delta))
    }

