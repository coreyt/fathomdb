        return Ok(Some(v));
    }
    json_serialised(item, snake)
}

fn json_serialised_alt_required(item: &JsonValue, camel: &str, snake: &str) -> Result<String> {
    json_serialised_alt(item, camel, snake)?.ok_or_else(|| {
