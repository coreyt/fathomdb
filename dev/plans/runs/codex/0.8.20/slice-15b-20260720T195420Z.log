+/// a silent coercion of exactly the kind this field must never perform. Floats
+/// are rejected by `extract::<i64>()` itself.
+fn dict_epoch_seconds(d: &Bound<'_, PyDict>, key: &str) -> PyResult<Option<i64>> {
