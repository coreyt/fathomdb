         Some(s) => InitialState::from_create_str(&s).ok_or_else(|| {
             typed_error(
                 CODE_WRITE_VALIDATION,
                 format!(
                     "cannot create a node with state {s:?}: only \"pending\" or \"active\" are creatable (deleted/purged require transition/purge)"
                 ),
                 JsonValue::Null,
             )
         })?,
