    */
   async ingestWithExtractor(
     cmd: string[],
     documents: ExtractDocument[],
   ): Promise<IngestWithExtractorReceipt> {
     // fix-28 [P2]: validate all user-controlled strings at the FFI boundary.
     for (const arg of cmd) validateFfiString(arg);
