    // emitted hit's NODE `write_cursor`. First edge to reach a node wins (visited
    // dedup); NULL confidence is never inserted (‚áí neutral in the reweight).
    let mut edge_confidence_by_cursor: HashMap<u64, f64> = HashMap::new();
    // G0 Phase-2 (BLOCK-1) frontier meter ‚Äî distinct seed candidates considered vs
    // resolved-active; `resolved_seed_rate` flips 0‚Üí>0 once entities/edge-facts seed.
    let mut stats = GraphFrontierStats::default();
