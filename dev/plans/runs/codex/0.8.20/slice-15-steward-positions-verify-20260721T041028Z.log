 12526	/// The current (Pack-2) `vector_default` vec0 shape. Slice 10 / G10 adds a plain
 12527	/// `status TEXT` metadata column — **not** aux (`+status`): aux columns
 12528	/// hard-error under a KNN `WHERE`, and the G10 filter constrains `status` in the
 12529	/// phase-1 KNN statement. `status` ships NULL plumbing only (no population source
 12530	/// yet).
 12531	fn vector_partition_create_sql(dimension: u32, if_not_exists: bool) -> String {
 12532	    let guard = if if_not_exists { "IF NOT EXISTS " } else { "" };
 12533	    format!(
 12534	        "CREATE VIRTUAL TABLE {guard}{DEFAULT_VECTOR_PARTITION} USING vec0(\
 12535	            embedding float[{dimension}],\
 12536	            embedding_bin bit[{dimension}],\
 12537	            source_type TEXT partition key,\
 12538	            kind TEXT,\
 12539	            created_at INTEGER,\
 12540	            status TEXT\
 12541	         )"
 12542	    )
 12543	}
 12544	
 12545	fn create_vector_partition(connection: &Connection, dimension: u32) -> rusqlite::Result<()> {
 12546	    connection.execute_batch(&vector_partition_create_sql(dimension, true))
 12547	}
 12548	
 12549	/// Slice 10 / G10 — stage + recreate + back-fill upgrade of an existing
 12550	/// **Pack-1** `vector_default` (has `embedding_bin`, lacks `status`) to the
 12551	/// Pack-2 shape. The existing `embedding_bin` blob is preserved verbatim (it may
 12552	/// be mean-centered; re-quantizing from `embedding` would drop the centering),
 12553	/// and `status` back-fills NULL. Same transactional discipline as
 12554	/// `migrate_vector_partition_to_pack1`: a single `Connection::transaction()`;
 12555	/// reader handles are not opened until `ensure_vector_partition` returns, and
 12556	/// cross-process access is serialized by the sidecar lock, so readers never see
 12557	/// a partial reshape.
 12558	fn migrate_vector_partition_pack1_to_pack2(
 12559	    connection: &mut Connection,
 12560	    dimension: u32,
 12561	) -> rusqlite::Result<()> {
 12562	    let tx = connection.transaction()?;
 12563	    tx.execute_batch(
 12564	        "CREATE TABLE _fathomdb_vector_pack2_stage (
 12565	             rowid         INTEGER PRIMARY KEY,
 12566	             embedding     BLOB NOT NULL,
 12567	             embedding_bin BLOB NOT NULL,
 12568	             source_type   TEXT,
 12569	             kind          TEXT,
 12570	             created_at    INTEGER
 12571	         );
 12572	         INSERT INTO _fathomdb_vector_pack2_stage(
 12573	             rowid, embedding, embedding_bin, source_type, kind, created_at
 12574	         )
 12575	             SELECT rowid, embedding, embedding_bin, source_type, kind, created_at
 12576	             FROM vector_default;
 12577	         DROP TABLE vector_default;",
 12578	    )?;
 12579	    tx.execute_batch(&vector_partition_create_sql(dimension, false))?;
 12580	    // `vec_bit(...)` re-tags the staged blob with the BIT subtype vec0's bit
 12581	    // column requires (a raw blob loses the subtype and fails the type check).
 12582	    // This preserves the existing (possibly mean-centered) bits verbatim — no
 12583	    // re-quantize, so centering survives the upgrade. `status` back-fills the
 12584	    // empty-string sentinel (vec0 TEXT metadata is NOT NULL-able; reserved-gap
 12585	    // candidate 13).
 12586	    tx.execute_batch(
 12587	        "INSERT INTO vector_default(
 12588	             rowid, embedding, embedding_bin, source_type, kind, created_at, status
 12589	         )
 12590	             SELECT rowid, embedding, vec_bit(embedding_bin), source_type, kind, created_at, ''
 12591	             FROM _fathomdb_vector_pack2_stage;
 12592	         DROP TABLE _fathomdb_vector_pack2_stage;",
 12593	    )?;
 12594	    tx.commit()
 12595	}
