 12700	        )
 12701	        .or_else(|err| match err {
 12702	            rusqlite::Error::QueryReturnedNoRows => Ok(None),
 12703	            other => Err(other),
 12704	        })
 12705	        .map_err(|_| EngineError::Storage)?;
 12970	            }
 12971	        }
 12972	    } else {
 12973	        None
 12974	    };
