 10828	fn projection_worker_loop(shared: Arc<ProjectionRuntimeShared>) {
 10829	    let mut connection = match open_runtime_connection(&shared.path) {
 10830	        Ok(connection) => connection,
 10831	        Err(_) => return,
 10832	    };
 10833	    if ensure_vector_partition(&mut connection, shared.embedder_identity.dimension).is_err() {
 10834	        return;
 10835	    }
 10836	    loop {
 10837	        let jobs = {
 10838	            let mut queue = match shared.queue.lock() {
 10839	                Ok(queue) => queue,
 10840	                Err(_) => return,
 10841	            };
 10842	            loop {
 10843	                let stopping = shared.state.lock().map(|state| state.stopping).unwrap_or(true);
 10844	                if stopping && queue.is_empty() {
 10845	                    return;
 10846	                }
 10847	                if let Some(job) = queue.pop_front() {
 10848	                    let mut jobs = vec![job];
 10849	                    while jobs.len() < PROJECTION_COMMIT_BATCH {
 10850	                        let Some(job) = queue.pop_front() else {
 10851	                            break;
 10852	                        };
 10853	                        jobs.push(job);
 10854	                    }
 10855	                    if let Ok(mut state) = shared.state.lock() {
 10856	                        state.queued_jobs = state.queued_jobs.saturating_sub(jobs.len());
 10857	                        state.active_jobs = state.active_jobs.saturating_add(jobs.len());
 10858	                        shared.state_cvar.notify_all();
 10859	                    }
 10860	                    break jobs;
 10861	                }
 10862	                queue = match shared.queue_cvar.wait(queue) {
 10863	                    Ok(queue) => queue,
 10864	                    Err(_) => return,
 10865	                };
 10866	            }
 10867	        };
 10868	
 10869	        // EU-5f — isolate worker faults. A panic inside `embed()` (or the
 10870	        // commit) must not skip the state cleanup below, or `active_jobs`
 10871	        // would stay elevated forever and `wait_for_idle` / `drain` would
 10872	        // wedge into `EngineError::Scheduler` (Finding A). Mirrors the
 10873	        // reader pool's `LiveGuard` panic-safety. The local commit tx rolls
 10874	        // back on unwind, leaving the connection clean for reuse.
 10875	        let panicked = std::panic::catch_unwind(std::panic::AssertUnwindSafe(|| {
 10876	            run_projection_jobs(&shared, &mut connection, &jobs);
 10877	        }))
 10878	        .is_err();
 10879	        if panicked {
 10880	            commit_projection_panic_failures(&shared, &mut connection, &jobs);
 10881	        }
 10882	
 10883	        if let Ok(mut state) = shared.state.lock() {
 10884	            state.active_jobs = state.active_jobs.saturating_sub(jobs.len());
 10885	            for job in &jobs {
 10886	                state.in_flight.remove(&job.cursor);
 10887	            }
 10888	            if !state.stopping {
 10889	                state.pending_scan = true;
 10890	            }
 10891	            shared.state_cvar.notify_all();
 10892	        }
 10893	    }
 10894	}
