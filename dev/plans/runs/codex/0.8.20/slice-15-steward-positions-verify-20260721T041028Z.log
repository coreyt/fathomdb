 10896	enum ProjectionOutcome {
 10897	    /// `blob` is the un-centered f32 BLOB persisted to
 10898	    /// `vector_default.embedding`. `bin_blob` is the (possibly centered)
 10899	    /// f32 BLOB fed to `vec_quantize_binary` for the sign-bit column.
 10900	    /// EU-5a2: `bin_blob == blob` unless the identity is MC-required
 10901	    /// AND a mean_vec is pinned.
 10902	    Success {
 10903	        cursor: u64,
 10904	        kind: String,
 10905	        blob: Vec<u8>,
 10910	        failure_code: &'static str,
 10911	    },
 10912	}
