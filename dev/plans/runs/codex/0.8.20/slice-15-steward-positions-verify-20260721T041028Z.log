 10914	fn run_projection_jobs(
 10915	    shared: &ProjectionRuntimeShared,
 10916	    connection: &mut Connection,
 10917	    jobs: &[ProjectionJob],
 10918	) {
 10919	    let outcomes = embed_projection_batch(shared, jobs);
 10920	    let _ = commit_projection_outcomes(connection, &outcomes, shared);
 10921	}
 10922	
 10923	/// Embed a whole commit-batch in ONE `embed_batch` call (amortizes per-call
 10924	/// overhead; saturates the GPU — minutes -> seconds on a full-corpus embed). The
 10925	/// batched path is the fast HAPPY path only; on ANY anomaly — no embedder, breaker
 10926	/// open, single job, batch timeout/failure, row-count or per-row dimension mismatch
 10927	/// — it falls back to the proven per-job [`run_projection_job`], which carries the
 10928	/// full retry + circuit-breaker + failure-isolation semantics. So batching can only
 10929	/// make the common case faster, never change correctness. A panic inside the batch
 10930	/// embed resume-unwinds exactly like the per-embed watchdog, so the worker's
 10931	/// batch-level `catch_unwind` records `ProjectionPanic` as before.
 10932	///
 10933	/// Batching is **opt-in** via `FATHOMDB_PROJECTION_BATCH=1` (`true`/`on` accepted).
 10934	/// It reshapes the PR-9 per-embed watchdog/breaker accounting into per-batch, so the
 10935	/// conservative DEFAULT keeps the proven per-job path — leaving every PR-9 safety
 10936	/// test (watchdog, serialization, circuit breaker) behaving exactly as before. The
 10937	/// eval GPU-embed run sets the env to get the batched-forward speedup (minutes ->
 10938	/// seconds), where the per-job fallback below still backs every error case.
 10939	fn projection_batch_enabled() -> bool {
 10940	    matches!(
 10941	        std::env::var("FATHOMDB_PROJECTION_BATCH").ok().as_deref(),
 10942	        Some("1") | Some("true") | Some("on")
 10943	    )
 10944	}
 10945	
 10946	fn embed_projection_batch(
 10947	    shared: &ProjectionRuntimeShared,
 10948	    jobs: &[ProjectionJob],
 10949	) -> Vec<ProjectionOutcome> {
 10950	    let per_job = || jobs.iter().map(|job| run_projection_job(shared, job)).collect();
 10951	
 10952	    let Some(embedder) = shared.embedder.as_ref() else {
 10953	        return per_job();
 10954	    };
 10955	    if jobs.len() < 2
 10956	        || shared.embed_circuit_open.load(Ordering::Relaxed)
 10957	        || !projection_batch_enabled()
 10958	    {
 10959	        return per_job();
 10960	    }
 10961	
 10962	    let bodies: Vec<String> = jobs.iter().map(|job| job.body.clone()).collect();
 10963	    let embed_timeout = Duration::from_millis(shared.embed_timeout_ms.load(Ordering::Relaxed));
 10964	    // Each row keeps its single-embed budget worst-case (batch <= COMMIT_BATCH=16).
 10965	    let batch_timeout = embed_timeout.saturating_mul(jobs.len() as u32);
 10966	
 10967	    let vectors = {
 10968	        // PR-9 — serialize the embedder call (ONE batched call at a time) and make
 10969	        // the breaker decision with the guard held (race-free vs other workers),
 10970	        // mirroring `run_projection_job`. The batch thread counts as one live embed.
 10971	        let _embed_permit =
 10972	            shared.embed_serialize.lock().unwrap_or_else(|poisoned| poisoned.into_inner());
 10973	        let threshold = shared.embed_circuit_threshold.load(Ordering::Relaxed);
 10974	        if shared.embed_circuit_open.load(Ordering::Relaxed)
 10975	            || (threshold != 0 && shared.live_embed_threads.load(Ordering::Relaxed) >= threshold)
 10976	        {
 10977	            shared.embed_circuit_open.store(true, Ordering::Relaxed);
 10978	            return per_job();
 10979	        }
 10980	        match embed_batch_with_watchdog(
 10981	            embedder,
 10982	            &bodies,
 10983	            batch_timeout,
 10984	            &shared.live_embed_threads,
 10985	        ) {
 10986	            Ok(vectors) => vectors,
 10987	            // Timeout / failed / disconnected -> the per-job path retries each row
 10988	            // and engages the breaker exactly as before.
 10989	            Err(_) => return per_job(),
 10990	        }
 10991	    };
 10992	
 10993	    if vectors.len() != jobs.len() {
 10994	        return per_job();
 10995	    }
 10996	    let mut outcomes = Vec::with_capacity(jobs.len());
 10997	    for (job, vector) in jobs.iter().zip(vectors) {
 10998	        if u32::try_from(vector.len()).unwrap_or(u32::MAX) != shared.embedder_identity.dimension {
 10999	            // A row came back wrong-dim: fall back per-job for the whole batch
 11000	            // (rare; keeps the dimension-mismatch failure path identical).
 11001	            return per_job();
 11002	        }
 11003	        // Mirror run_projection_job's post-embed step exactly: persisted f32 BLOB is
 11004	        // un-centered; centering for the binary column is finalized in
 11005	        // commit_projection_outcomes (so bin_blob == blob here).
 11006	        let blob = encode_vector_blob(&vector);
 11007	        let bin_blob = blob.clone();
 11008	        outcomes.push(ProjectionOutcome::Success {
 11009	            cursor: job.cursor,
 11010	            kind: job.kind.clone(),
 11011	            blob,
 11012	            bin_blob,
 11013	        });
 11014	    }
 11015	    outcomes
 11016	}
