  6520	    /// 0.7.2 PR-2b — explicit `doctor recompute-mean` path. Re-derives the
  6521	    /// pinned corpus mean from the current `vector_default` rows and
  6522	    /// re-quantizes every row, SYNCHRONOUSLY in one transaction. ALWAYS
  6523	    /// allowed at any corpus size — this is the ONLY mean-refresh path as of
  6524	    /// 0.7.2 (the automatic in-ingest drift detector was carved out / deferred
  6525	    /// to 0.8.x; see `dev/design/embedder.md` §0.3).
  6526	    ///
  6527	    /// Serializes against the projection workers via `commit_gate` so the
  6528	    /// re-quantize sees a totally-ordered history, exactly like the at-pin
  6529	    /// commit. Publishes a `MeanVecRecomputed { trigger: Manual }` event
  6530	    /// only after the transaction is durable. No-op-safe on a non-MC
  6531	    /// identity (returns `EmbedderNotConfigured` rather than corrupting an
  6532	    /// un-centered workspace).
  6533	    #[cfg(feature = "operator")]
  6534	    pub fn recompute_mean(&self) -> Result<MeanRecomputeReport, EngineError> {
  6535	        self.ensure_open()?;
  6536	        let identity = self.runtime_embedder_identity.clone();
  6537	        if !identity_requires_mean_centering(&identity) {
  6538	            return Err(EngineError::EmbedderNotConfigured);
  6539	        }
  6540	        let report = {
  6541	            // Hold the commit gate for the whole recompute so no projection
  6542	            // worker commit interleaves with the re-quantize.
  6543	            let _gate = self
  6544	                .projection_runtime
  6545	                .shared
  6546	                .commit_gate
  6547	                .lock()
  6548	                .unwrap_or_else(|p| p.into_inner());
  6549	            let mut connection = self.connection.lock().map_err(|_| EngineError::Storage)?;
  6550	            let connection = connection.as_mut().ok_or(EngineError::Closing)?;
  6551	            let tx = connection.transaction().map_err(|_| EngineError::Storage)?;
  6552	            #[cfg(debug_assertions)]
  6553	            let fail = self
  6554	                .projection_runtime
  6555	                .shared
  6556	                .force_recompute_failure
  6557	                .swap(false, Ordering::SeqCst);
  6558	            #[cfg(not(debug_assertions))]
  6559	            let fail = false;
  6560	            let report = recompute_mean_in_tx_inner(&tx, &identity, fail)?;
  6561	            tx.commit().map_err(|_| EngineError::Storage)?;
  6562	            report
  6563	        };
  6564	        // Post-durable-commit publish.
  6565	        if let Ok(mut events) = self.projection_runtime.shared.pending_events.lock() {
  6566	            events.push(EmbedderEvent::MeanVecRecomputed {
  6567	                dim: report.dim,
  6568	                doc_count: report.doc_count_requantized,
  6569	                trigger: MeanRecomputeTrigger::Manual,
  6570	            });
 12620	/// rusqlite `Connection::transaction()` (DEFERRED begin per rusqlite
 12621	/// `transaction.rs:417`). Cross-process serialization is provided by
 12622	/// the engine's sidecar `acquire_lock` at `open_with_migrations`
 12623	/// (`lib.rs:1127` area); reader handles are not opened until
 12624	/// `ensure_vector_partition` returns (`lib.rs:1241` area), so readers
 12625	/// never observe a partial reshape.
 12626	fn migrate_vector_partition_to_pack1(
 12627	    connection: &mut Connection,
 12628	    dimension: u32,
 12629	) -> rusqlite::Result<()> {
 12630	    let tx = connection.transaction()?;
 12631	    tx.execute_batch(
 12632	        "CREATE TABLE _fathomdb_vector_migration_v0_7_0 (
 12633	             rowid     INTEGER PRIMARY KEY,
 12634	             embedding BLOB NOT NULL,
 12635	             kind      TEXT NOT NULL
 12636	         );
 12637	         INSERT INTO _fathomdb_vector_migration_v0_7_0(rowid, embedding, kind)
 12638	             SELECT v.rowid, v.embedding, r.kind
 12639	             FROM vector_default v
 12640	             JOIN _fathomdb_vector_rows r ON r.rowid = v.rowid;
 12641	         DROP TABLE vector_default;",
 12642	    )?;
 12643	    // Slice 10 / G10 — recreate directly at the Pack-2 shape (adds `status`), so
 12644	    // a legacy single-column DB lands the current shape in one reshape.
 12645	    tx.execute_batch(&vector_partition_create_sql(dimension, false))?;
 12646	    // `status` back-fills the empty-string sentinel (vec0 TEXT metadata is NOT
 12647	    // NULL-able; reserved-gap candidate 13). Legacy single-column DBs predate
 12648	    // mean-centering, so re-quantizing from the un-centered `embedding` is
 12649	    // correct here.
 12650	    let repopulate_sql = format!(
 12651	        "INSERT INTO vector_default(
 12652	             rowid, embedding, embedding_bin, source_type, kind, created_at, status
 12653	         )
 12654	         SELECT
 12655	             s.rowid,
 12656	             s.embedding,
 12657	             vec_quantize_binary(s.embedding),
 12658	             {KIND_TO_SOURCE_TYPE_CASE_SQL},
 12659	             s.kind,
 12660	             strftime('%s', 'now'),
 12661	             ''
 12662	         FROM _fathomdb_vector_migration_v0_7_0 s;
 12663	         DROP TABLE _fathomdb_vector_migration_v0_7_0;"
 12664	    );
 12665	    tx.execute_batch(&repopulate_sql)?;
 12666	    tx.commit()
 12667	}
