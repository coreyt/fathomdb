 12976	    let mut stmt = connection
 12977	        .prepare(
 12978	            "SELECT probe_ordinal, probe_text, reference_vec, embedder_name, embedder_revision, dim \
 12979	             FROM _fathomdb_embed_probe ORDER BY probe_ordinal",
 12980	        )
