dev/plans/runs/codex/0.8.20/slice-15-steward-positions-verify-20260721T041028Z.log:2792:dev/todos-and-considerations-ledger.jsonl:9:{"ts": "2026-07-08T00:18:18.773Z", "seq": 9, "kind": "consideration", "summary": "C-1 co-design TIMING (EntityTypeSpec -> ProjectionSpec): Memex's Commission C / entity-schema-registry is its ACTUAL 0.5.x work and is LIVE NOW; it builds toward the C-1 seam. C-1 is HARD (one declarative registration flow -- app never syncs two registries). FathomDB's projection registry is 0.9.1, but the EntityTypeSpec->ProjectionSpec co-design ADR should be AGREED before Memex locks Commission C's registry shape, or we recreate the two-registry-sync drift C-1 exists to prevent. Near-term cross-repo coordination watch (raise to HITL) even though the FathomDB build is >=0.9.x.", "area": "cross-repo/co-design", "epistemic": "verified", "id": "TC-7", "owner": "hitl", "priority": "p1", "status": "open", "refs": ["opp:OPP-12", "file:dev/plans/0.9.x-roadmap-DRAFT.md", "git:6f7456c"]}
