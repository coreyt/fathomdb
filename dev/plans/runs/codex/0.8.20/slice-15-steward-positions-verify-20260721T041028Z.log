 12982	    let stored: Vec<(i64, String, Vec<u8>, String, String, i64)> = stmt
 12983	        .query_map([], |row| {
 12984	            Ok((
 12985	                row.get::<_, i64>(0)?,
 12986	                row.get::<_, String>(1)?,
 12987	                row.get::<_, Vec<u8>>(2)?,
 12988	                row.get::<_, String>(3)?,
 12989	                row.get::<_, String>(4)?,
