 12686	/// `_fathomdb_embedder_profiles.mean_vec` for the default profile.
 12687	/// Returns `Ok(None)` when the column is NULL or the row is missing;
 12688	/// returns `Err(EngineError::Storage)` on dimension drift (the open-time
 12689	/// `check_embedder_profile` already fails closed for this, so a runtime
 12690	/// drift here would be an internal-inconsistency signal).
 12691	fn read_pinned_mean_vec(
 12692	    connection: &Connection,
 12693	    dimension: u32,
 12694	) -> Result<Option<Vec<f32>>, EngineError> {
