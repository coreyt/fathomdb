 12991	            ))
 12992	        })
 12993	        .and_then(|rows| rows.collect::<rusqlite::Result<Vec<_>>>())
 12994	        .map_err(|e| format!("could not read the stored probe references: {e}; cannot verify"))?;
 12995	
 12996	    // fix-2 (DEFECT #1 residual) — COMPLETENESS validation of the STORED baseline.
 12997	    // `COUNT(*) > 0` is NOT proof of a complete, trustworthy baseline: a partially
 12998	    // populated or externally-tampered probe table (44 of 45 rows, a gap/dupe in the
 12999	    // ordinals, a mangled reference blob, a mismatched probe_text, or a foreign
 13000	    // embedder identity) is UNVERIFIABLE stored state. The prior code re-embedded
 13001	    // the STORED probe_text and compared it to its OWN reference, so a tampered
 13002	    // probe_text verified against itself and a short table verified only the rows
 13003	    // present — both fail-OPEN. Atomic population stops the ENGINE from writing a
 13004	    // partial set; this closes external corruption, a manual edit, and a future
 13005	    // migration bug the engine did not author. Any mismatch ⇒ fail CLOSED (dense
 13006	    // refused); the text-only/FTS path still serves. The stored baseline must be
 13007	    // EXACTLY the committed probe set, in order, under the current identity.
 13008	    if stored.len() != probes.len() {
 13009	        return Err(format!(
 13010	            "the probe reference table has {} rows but the committed fixture defines {}; \
 13011	             the stored baseline is incomplete or corrupt — cannot verify the dense arm (refused)",
 13012	            stored.len(),
 13013	            probes.len()
 13014	        ));
 13015	    }
 13016	    for (idx, (ordinal, probe_text, ref_blob, name, revision, dim)) in stored.iter().enumerate() {
 13017	        // Contiguous 0-based ordinals, one per committed probe (no gaps/dupes).
 13018	        if *ordinal != idx as i64 {
 13019	            return Err(format!(
 13020	                "probe reference ordinals are non-contiguous (row {idx} carries ordinal {ordinal}); \
 13021	                 the stored baseline is corrupt — cannot verify the dense arm (refused)"
 13022	            ));
 13023	        }
 13024	        // The stored text MUST be the committed fixture text at this ordinal —
 13025	        // otherwise a tampered probe_text re-embeds and verifies against ITSELF,
 13026	        // masking drift (the exact fail-open this fix closes).
 13027	        if probe_text != probes[idx] {
 13028	            return Err(format!(
 13029	                "probe reference {ordinal} text does not match the committed fixture; \
 13030	                 the stored baseline is tampered or corrupt — cannot verify the dense arm (refused)"
 13031	            ));
 13032	        }
 13033	        // Well-formed f32[dim] reference (4*dim little-endian bytes).
 13034	        if ref_blob.len() != dimension * 4 {
 13035	            return Err(format!(
 13036	                "probe reference {ordinal} is malformed (len {} != {}); \
 13037	                 cannot verify the dense arm (refused)",
 13038	                ref_blob.len(),
 13039	                dimension * 4
 13040	            ));
 13041	        }
 13042	        // The stored embedder identity/dim must match the CURRENT expected identity
