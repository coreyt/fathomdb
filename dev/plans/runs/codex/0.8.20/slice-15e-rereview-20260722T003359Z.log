+        stage_names.push_str(&format!(", {col}"));
+    }
+    conn.execute_batch(&format!(
+        "CREATE TABLE _fathomdb_vector_reshape_stage (
+             rowid         INTEGER PRIMARY KEY,
+             embedding     BLOB NOT NULL,
+             embedding_bin BLOB NOT NULL,
+             source_type   TEXT,
+             kind          TEXT,
+             created_at    INTEGER,
+             status        TEXT{stage_defs}
