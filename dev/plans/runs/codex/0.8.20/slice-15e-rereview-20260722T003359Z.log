+        "INSERT INTO {DEFAULT_VECTOR_PARTITION}({insert_cols})
+             SELECT {select_exprs} FROM _fathomdb_vector_reshape_stage;
+         DROP TABLE _fathomdb_vector_reshape_stage;"
+    ))?;
+    Ok(())
 }
 
