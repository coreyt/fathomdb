   const engine = await Engine.open(freshDbPath(), { useDefaultEmbedder: false });
   try {
     await engine.write([
       node("n1", "alice anchor search text"),
       node("n2", "bob reachable via live edge"),
       edge("n1", "n2", "e12"),
