         "to": to_id,
         "logical_id": logical_id,
         "source_id": _SOURCE_ID,
     }
     if t_invalid is not None:
         item["t_invalid"] = t_invalid
     if body is not None:
         item["body"] = body
     return {"edge": item}
 
 
