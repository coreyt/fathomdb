12291-/// rows, pins it, and re-quantizes every row, all in one transaction on the
12292-/// single-threaded open connection (no workers running yet, so no gate is
12293-/// needed). Called only when MC is required, no mean is pinned, and the row
12294-/// count already meets the threshold.
12295-fn recover_mean_vec_pin(
12296-    connection: &mut Connection,
12297-    identity: &EmbedderIdentity,
12298-) -> Result<(), EngineError> {
