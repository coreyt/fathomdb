8478-impl MeanAccumulator {
8479-    fn new(dim: usize) -> Self {
8480-        Self { sum: vec![0.0; dim], count: 0 }
8481-    }
8482-
8483-    fn add(&mut self, v: &[f32]) {
8484-        debug_assert_eq!(v.len(), self.sum.len(), "accumulator dim mismatch");
8485-        for (slot, value) in self.sum.iter_mut().zip(v.iter()) {
8486-            *slot += f64::from(*value);
8487-        }
8488-        self.count = self.count.saturating_add(1);
8489-    }
8490-
8491-    fn materialize(&self) -> Vec<f32> {
8492-        if self.count == 0 {
8493-            return vec![0.0; self.sum.len()];
8494-        }
8495-        let denom = self.count as f64;
8496-        self.sum.iter().map(|s| (s / denom) as f32).collect()
8497-    }
8498-
8499-    fn count(&self) -> u64 {
8500-        self.count
8501-    }
8502-}
