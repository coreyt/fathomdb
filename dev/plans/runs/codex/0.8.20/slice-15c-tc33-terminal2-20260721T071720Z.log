14566-         CREATE VIRTUAL TABLE IF NOT EXISTS temp.bm25f_tok_vocab
14567-             USING fts5vocab('bm25f_tok', 'instance');
14568-         DELETE FROM temp.bm25f_tok;",
14569-    )?;
