12305-/// 0.7.2 PR-2b — shared mean (re)compute core, run INSIDE the caller's
12306-/// transaction. Derives the FULL-corpus mean from the un-centered
12307-/// `vector_default.embedding` BLOBs, writes `mean_vec`, and re-quantizes
12308-/// EVERY row via the existing [`run_pin_and_requantize_pass`] so no row is
12309-/// left under a stale centering.
12310-///
12311-/// This generalizes the EU-5f open-time recovery pin: it has NO "no mean
12312-/// pinned yet" guard, so it equally serves the FIRST pin (recovery) and a
12313-/// REFRESH of an already-pinned mean (PR-2b drift / `doctor recompute-mean`).
12314-/// The caller owns the transaction boundary, which is what makes a fault
12315-/// between the `mean_vec` UPDATE and re-quantize completion roll back
12316-/// wholesale (`dev/design/embedder.md` §0.5 atomicity). It does NOT publish
12317-/// any event — that is the caller's job, strictly post-durable-commit.
12318-fn recompute_mean_in_tx(
12319-    tx: &rusqlite::Transaction<'_>,
12320-    identity: &EmbedderIdentity,
12321-) -> Result<MeanRecomputeReport, EngineError> {
12322-    recompute_mean_in_tx_inner(tx, identity, false)
12323-}
12324-
12325-/// 0.7.2 PR-2b — recompute core with an optional fault-injection point. The
12326-/// `fail_after_mean_update` flag (debug builds only, set via a test seam)
12327-/// errors AFTER the `mean_vec` UPDATE but BEFORE the re-quantize completes,
12328-/// so the caller's tx rolls back the partial recentering.
12329-fn recompute_mean_in_tx_inner(
12330-    tx: &rusqlite::Transaction<'_>,
12331-    identity: &EmbedderIdentity,
12332-    fail_after_mean_update: bool,
12333-) -> Result<MeanRecomputeReport, EngineError> {
12334-    let started = Instant::now();
12335-    let dim = identity.dimension as usize;
12336-    // The previously-pinned mean (if any) is read first so we can report
12337-    // the pre-recompute drift cosine.
12338-    let old_mean = read_pinned_mean_vec(tx, identity.dimension)?;
12339-    let rows: Vec<(i64, Vec<u8>)> = {
12340-        let mut statement = tx
12341-            .prepare("SELECT rowid, embedding FROM vector_default ORDER BY rowid")
12342-            .map_err(|_| EngineError::Storage)?;
12343-        let mapped = statement
12344-            .query_map([], |row| Ok((row.get::<_, i64>(0)?, row.get::<_, Vec<u8>>(1)?)))
12345-            .map_err(|_| EngineError::Storage)?;
12346-        let mut out = Vec::new();
12347-        for r in mapped {
12348-            out.push(r.map_err(|_| EngineError::Storage)?);
12349-        }
12350-        out
12351-    };
12352-    let mut accumulator = MeanAccumulator::new(dim);
12353-    for (_rowid, blob) in &rows {
12354-        if blob.len() != dim * 4 {
12355-            return Err(EngineError::Storage);
12356-        }
12357-        accumulator.add(&decode_vector_blob(blob));
12358-    }
12359-    let old_doc_count = accumulator.count();
12360-    let mean = accumulator.materialize();
12361-    let drift_cos_before = match &old_mean {
12362-        Some(old) => cosine_similarity(&mean, old),
12363-        None => 1.0,
12364-    };
12365-    tx.execute(
12366-        "UPDATE _fathomdb_embedder_profiles SET mean_vec = ?1 WHERE profile = 'default'",
12367-        params![encode_vector_blob(&mean)],
12368-    )
12369-    .map_err(|_| EngineError::Storage)?;
12370-    if fail_after_mean_update {
12371-        // Injected fault: bail before re-quantizing so the caller's tx
12372-        // rolls back the `mean_vec` UPDATE too (crash-atomicity proof).
12373-        return Err(EngineError::Storage);
12374-    }
12375-    let (doc_count, _) = run_pin_and_requantize_pass(tx, &rows, &mean)?;
12376-    Ok(MeanRecomputeReport {
12377-        dim: u32::try_from(dim).unwrap_or(u32::MAX),
12378-        old_doc_count,
12379-        doc_count_requantized: doc_count,
12380-        drift_cos_before,
12381-        mean_was_pinned: old_mean.is_some(),
12382-        elapsed_ms: u64::try_from(started.elapsed().as_millis()).unwrap_or(u64::MAX),
12383-    })
12384-}
