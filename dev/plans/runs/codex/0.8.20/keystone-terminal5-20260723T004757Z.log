+    fn from_rust(d: &RustProjectionDelta) -> Self {
+        Self {
+            built: d.built.clone(),
+            dropped: d.dropped.clone(),
+            deferred: d.deferred.clone(),
+            unchanged: d.unchanged,
+        }
+    }
+}
