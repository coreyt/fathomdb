+    let registry = load_projection_registry(conn)?;
+    let mut cols: Vec<String> = registry
+        .iter()
+        .filter(|(_, stored)| stored.roles.contains(&ProjectionRole::Filterable))
+        .map(|(name, _)| attr_vec0_column(name))
+        .collect();
