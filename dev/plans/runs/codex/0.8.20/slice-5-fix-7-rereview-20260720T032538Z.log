29:[tool.maturin]
[build-system]
requires = ["maturin>=1.7,<2"]
build-backend = "maturin"

[project]
name = "fathomdb"
version = "0.8.9"
description = "FathomDB Python SDK — PyO3 binding to the fathomdb-engine Rust core"
readme = "README.md"
requires-python = ">=3.10"
license = { text = "Apache-2.0" }
dependencies = []

[project.optional-dependencies]
test = ["pytest>=8", "hypothesis>=6", "maturin>=1.7,<2", "pyyaml>=6", "numpy>=1.24", "scipy>=1.11", "networkx>=3.0"]
lint = ["ruff>=0.6"]
typecheck = ["pyright>=1.1.380"]
# numpy is required by the M1 eval harness (eval/m1_baseline.py, eval/m1_baseline_run.py,
# eval/m1_graph_build.py) and their test suites (test_m1_baseline.py imports numpy directly).
# Without this declaration `pip install -e src/python[dev]` fails with ModuleNotFoundError
# ([P1] from codex §9 Slice 5 fix-1 review).
#
# scipy + networkx are required by the M1 PPR-fusion arm (eval/m1_ppr.py — networkx for
# Personalized-PageRank, scipy as its sparse-linalg backend) and test_m1_ppr.py (Slice 15).
# They are HARNESS-only CPU deps (NOT linked into the FathomDB library → footprint-invariant
# safe; design §9). Declared here so a clean `pip install -e src/python[dev]` runs the arm.
dev = ["pytest>=8", "hypothesis>=6", "ruff>=0.6", "pyright>=1.1.380", "maturin>=1.7,<2", "pyyaml>=6", "numpy>=1.24", "scipy>=1.11", "networkx>=3.0"]

[tool.maturin]
manifest-path = "../rust/crates/fathomdb-py/Cargo.toml"
module-name = "fathomdb._fathomdb"
python-source = "."
# EU-6 FIX-1: this list is what BOTH editable installs (`pip install -e .`,
# `maturin develop`) AND the release workflow's `PyO3/maturin-action`
# inherit unless they pass an explicit `--features` override. Therefore
# it must match the SHIPPED feature surface exactly:
#
