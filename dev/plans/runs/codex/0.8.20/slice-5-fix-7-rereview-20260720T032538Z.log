+# Activate at runtime via FATHOMDB_EMBED_DEVICE=cuda|metal.
+embed-cuda = ["default-embedder", "fathomdb-embedder/embed-cuda"]
+embed-metal = ["default-embedder", "fathomdb-embedder/embed-metal"]
