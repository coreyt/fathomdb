   199	        [sys.executable, "-c", probe_source()],
   200	        cwd=str(root), env=env, capture_output=True, text=True,
   201	    )
   202	    return missing_symbols_from_probe(proc.returncode, proc.stdout)
   203	
   204	
   205	def test_probe_accepts_a_complete_binding(tmp_path: Path) -> None:
   206	    root = _fake_binding(
   207	        tmp_path,
   208	        engine_attrs=tuple(a for owner, a in TEST_HOOK_SYMBOLS if owner == "Engine"),
   209	        module_attrs=tuple(a for owner, a in TEST_HOOK_SYMBOLS if owner is None),
   210	    )
   211	    assert _run_probe(root) == ()
   212	
   213	
   214	def test_probe_detects_a_partial_binding(tmp_path: Path) -> None:
   215	    """The observed failure mode: both `Engine` hooks present, module-level
   216	    `force_panic_for_test` absent. Must NOT read as "hooks present"."""
   217	
   218	    root = _fake_binding(
   219	        tmp_path,
   220	        engine_attrs=("_configure_vector_kind_for_test", "_write_vector_for_test"),
   221	        module_attrs=(),
