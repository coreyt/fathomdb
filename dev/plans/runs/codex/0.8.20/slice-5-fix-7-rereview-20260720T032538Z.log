   234	    missing = _run_probe(root)
   235	    decision = _decide(hooks_present=not missing, allow_rebuild=False)
   236	    assert missing
   237	    assert decision.action == DEGRADED, "a partial binding must never PROCEED"
   238	
   239	
   240	def test_probe_reports_the_whole_surface_when_the_import_fails(tmp_path: Path) -> None:
   241	    root = _fake_binding(tmp_path, engine_attrs=(), module_attrs=(), import_raises=True)
