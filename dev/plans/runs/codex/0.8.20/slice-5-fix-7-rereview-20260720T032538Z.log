   124	    to whatever source tree pytest happened to be launched from — including an
   125	    agent worktree, silently repointing every other consumer of that venv at
   126	    unreviewed code.
   127	
   128	    fix-4 closed that by raising at import time when the rebuild was not
   129	    authorized — which made the *documented* default path
   130	    (`pip install -e 'src/python[dev]'` then `scripts/agent-test.sh`) fail
   131	    before collection, i.e. permanently red. fix-6 keeps the hazard closed but
   132	    returns DEGRADED instead: the suite runs, and only the tests carrying
   133	    ``@pytest.mark.requires_test_hooks`` skip (visibly, with the reason). The
   134	    sanctioned dev loop authorizes the rebuild explicitly from
   135	    ``scripts/agent-test.sh``.
   136	
   137	    :raises TestHooksBindingMisconfigured: only for a contradictory
   138	        opt-in/opt-out pair — a configuration error the caller must fix.
   139	    """
   140	
   141	    # Not an editable-install context when `pyproject.toml` is absent (the
   142	    # release-surface tests run against a pip-installed wheel under a throwaway
   143	    # venv). Probing the binding there would be a pointless subprocess, so keep
   144	    # the short-circuit here rather than inside the pure policy.
   145	    is_source_tree = (_PYTHON_SRC_DIR / "pyproject.toml").exists()
   146	    missing = _probe_missing_test_hook_symbols() if is_source_tree else ()
   147	
   148	    decision = decide(
   149	        is_source_tree=is_source_tree,
   150	        # Developer already built with test-hooks (or a previous pytest session
   151	        # in the same venv did) — the normal path, which never consults the
   152	        # opt-in. "Present" means ALL the hook symbols, never merely some.
   153	        hooks_present=is_source_tree and not missing,
   154	        allow_rebuild=os.environ.get(REBUILD_OPT_IN) == "1",
   155	        forbid_rebuild=os.environ.get(REBUILD_OPT_OUT) == "1",
   156	        # `sys.prefix` is the environment root for a venv interpreter.
   157	        venv_owned_by_source_tree=venv_belongs_to_source_tree(sys.prefix, _PYTHON_SRC_DIR),
   158	    )
   159	
   160	    if decision.action == CONTRADICTORY:
   161	        raise TestHooksBindingMisconfigured(decision.reason)
   162	    if decision.action != REBUILD:
   163	        return _annotate_partial(decision, missing)
   164	
   165	    print(
   166	        "\n[conftest] EU-6 FIX-1: rebuilding fathomdb editable binding "
   167	        "with test-hooks feature (one-time per venv; ~5-60s) ...",
   168	        flush=True,
   169	    )
   170	    # `maturin develop` requires an activated virtualenv: it looks for
   171	    # $VIRTUAL_ENV / $CONDA_PREFIX / a `.venv` in cwd-or-parents. A bare
   172	    # subprocess inherits neither when pytest was launched via an absolute
   173	    # interpreter path (e.g. `.venv/bin/python -m pytest`, or any venv not
   174	    # named `.venv`), so it fails with "Couldn't find a virtualenv". Point it
   175	    # at THIS interpreter's environment root (`sys.prefix` is the venv dir for
   176	    # a venv interpreter) so the rebuilt `.so` lands in the venv we are running.
   177	    env = dict(os.environ)
   178	    env["VIRTUAL_ENV"] = sys.prefix
   179	    subprocess.check_call(
   180	        [
   181	            sys.executable,
   182	            "-m",
   183	            "maturin",
   184	            "develop",
   185	            "--features",
   186	            "pyo3/extension-module,test-hooks,default-embedder,default-reranker",
   187	        ],
   188	        cwd=str(_PYTHON_SRC_DIR),
   189	        env=env,
   190	    )
   191	    # Belt-and-suspenders: drop any cached `fathomdb*` modules so the first
   192	    # post-rebuild import re-reads from disk. (The out-of-process probe above
   193	    # means this interpreter has NOT yet dlopen()ed the extension, so the fresh
   194	    # `.so` is what pytest collection loads.)
   195	    for mod_name in list(sys.modules):
   196	        if mod_name == "fathomdb" or mod_name.startswith("fathomdb."):
   197	            del sys.modules[mod_name]
   198	
   199	    # Re-probe rather than trusting a zero exit code. If `maturin develop`
   200	    # somehow lands a binding that still lacks the hooks, DEGRADED (visible
   201	    # skips) is the honest outcome — never let the marked tests run and
   202	    # "pass" against a surface that is not there.
   203	    still_missing = _probe_missing_test_hook_symbols()
   204	    if still_missing:
   205	        return _annotate_partial(
   206	            Decision(
   207	                DEGRADED,
   208	                "`maturin develop` completed but the rebuilt binding still does not expose "
   209	                f"the full test-hooks surface (missing {', '.join(still_missing)}). Check "
   210	                "that the `test-hooks` Cargo feature still gates the expected symbols.",
   211	            ),
   212	            still_missing,
   213	        )
   214	    return decision
   215	
   216	
   217	# Run the rebuild at conftest IMPORT time (before sibling test modules are
   218	# collected), not as a fixture — see the module docstring for why a fixture is
   219	# too late once a sibling module has dlopen()ed the stale extension.
   220	_TEST_HOOKS_DECISION = _ensure_test_hooks_binding()
   170	# `Engine` methods but no module-level `force_panic_for_test` therefore read as
   171	# "hooks present" -> PROCEED, the `requires_test_hooks` skips did not apply, and
   172	# `test_panic_surfaces_as_python_exception` failed on a missing import instead
   173	# of skipping cleanly. These tests run the probe against SYNTHETIC bindings, so
   174	# they need no compiled extension.
   175	# --------------------------------------------------------------------------
   176	
   177	
   178	def _fake_binding(root: Path, *, engine_attrs: tuple[str, ...], module_attrs: tuple[str, ...],
   179	                  import_raises: bool = False) -> Path:
   180	    """Materialize a stand-in `fathomdb._fathomdb` exposing exactly these names."""
   181	
   182	    pkg = root / "fathomdb"
   183	    pkg.mkdir(parents=True, exist_ok=True)
   184	    (pkg / "__init__.py").write_text("")
   185	    if import_raises:
   186	        (pkg / "_fathomdb.py").write_text("raise ImportError('no compiled extension')\n")
   187	        return root
   188	    body = ["class Engine:", "    pass"]
   189	    body += [f"Engine.{name} = lambda self, *a, **k: None" for name in engine_attrs]
   190	    body += [f"def {name}():\n    return None" for name in module_attrs]
   191	    (pkg / "_fathomdb.py").write_text("\n".join(body) + "\n")
   192	    return root
   193	
   194	
   195	def _run_probe(root: Path) -> tuple[str, ...]:
   196	    env = dict(os.environ)
   197	    env["PYTHONPATH"] = str(root)
