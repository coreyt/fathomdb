+fn truncate_all_row_projections(tx: &Connection) -> rusqlite::Result<u64> {
+    truncate_row_projections_in(
+        tx,
+        &[
+            ProjectionClass::NodeFts,
+            ProjectionClass::EdgeFts,
+            ProjectionClass::Vector,
+            ProjectionClass::Readiness,
+        ],
