+fn purged_id_absent_from_sink() {
+    let (_dir, after) = telemetry_fixture("telemetry_redact");
+    assert!(
+        !after.contains("l:victim-1"),
+        "erased stable id still persisted in the telemetry sink:\n{after}"
+    );
+}
