+    let (_dir, after) = telemetry_fixture("telemetry_survive");
+    assert!(
+        after.contains("UNRELATEDEVALHISTORY"),
+        "redaction destroyed an unrelated operator record; the sink must not be truncated:\n{after}"
+    );

