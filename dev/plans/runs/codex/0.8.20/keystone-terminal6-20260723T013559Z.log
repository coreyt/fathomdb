+        if ch.is_ascii_alphanumeric() || ch == '_' {
+            token.push(ch);
+        } else {
+            flush(&mut token, &mut cols);
+        }
+    }
+    flush(&mut token, &mut cols);
+    cols.sort();
+    Ok(cols)
