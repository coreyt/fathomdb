\n44\t\n45\t/// Reader pool size. Per `dev/design/engine.md` § Writer / reader split,\n46\t/// reader connections are pooled and never serialize behind one\n47\t/// connection. AC-021 exercises 8 concurrent readers.\n48\tconst READER_POOL_SIZE: usize = 8;\n49\t\n50\tpub struct Engine {\n51\t    path: PathBuf,\n52\t    next_cursor: AtomicU64,\n53\t    closed: AtomicBool,\n54\t    lock: Mutex<Option<File>>,\n55\t    connection: Mutex<Option<Connection>>,\n56\t    reader_pool: ReaderPool,\n57\t    counters: lifecycle::Counters,\n58\t    subscribers: Arc<lifecycle::SubscriberRegistry>,\n59\t    profiling_enabled: Arc<AtomicBool>,\n60\t    slow_threshold_ms: Arc<AtomicU64>,\n61\t    runtime_embedder: Option<Arc<dyn Embedder>>,\n62\t    runtime_embedder_identity: EmbedderIdentity,\n63\t    projection_runtime: ProjectionRuntime,\n64\t    provenance_row_cap: AtomicU64,\n65\t    /// Per-connection profile-callback contexts. Each box's pointer is\n66\t    /// installed into the connection's `sqlite3_profile` userdata; the\n67\t    /// box must outlive the connection so the callback never reads\n68\t    /// freed memory. Connections are dropped before this vec on\n69\t    /// `close`/`Drop`, so the lifetime ordering holds.\n70\t    ///\n71\t    /// Why `Box<ProfileContext>` and not `ProfileContext` directly: the\n72\t    /// FFI pointer captured during `install_profile_callback` MUST\n73\t    /// remain stable for the connection's lifetime; pushing onto a\n74\t    /// `Vec<ProfileContext>` could reallocate and invalidate that\n75\t    /// pointer.\n76\t    #[allow(clippy::vec_box)]\n77\t    profile_contexts: Mutex<Vec<Box<ProfileContext>>>,\n78\t    #[cfg(debug_assertions)]\n79\t    force_next_commit_failure: AtomicBool,\n80\t}\n81\t\n82\t#[derive(Clone, Debug)]\n83\tstruct ProjectionJob {\n84\t    cursor: u64,\n85\t    kind: String,\n86\t    body: String,\n87\t}\n88\t\n89\t#[derive(Debug, Default)]\n90\tstruct ProjectionRuntimeState {\n91\t    active_jobs: usize,\n92\t    que