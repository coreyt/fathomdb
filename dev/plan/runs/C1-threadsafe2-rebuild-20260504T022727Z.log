{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014Z4Y3gkben5KcqxBuD9XKk","type":"tool_result","content":"1\tuse std::sync::{Arc, Barrier, Mutex};\n2\tuse std::thread;\n3\tuse std::time::{Duration, Instant};\n4\t\n5\tuse fathomdb_embedder_api::{Embedder, EmbedderError, EmbedderIdentity, Vector};\n6\tuse fathomdb_engine::{Engine, PreparedWrite};\n7\tuse fathomdb_schema::SQLITE_SUFFIX;\n8\tuse tempfile::TempDir;\n9\t\n10\tconst PERF_SAMPLES: usize = 1_000;\n11\tconst AC020_THREADS: usize = 8;\n12\tconst AC020_ROUNDS_PER_THREAD: usize = 50;\n13\t\n14\t#[derive(Clone, Debug)]\n15\tstruct DeterministicEmbedder {\n16\t    identity: EmbedderIdentity,\n17\t    vector: Vector,\n18\t    delay: Duration,\n19\t}\n20\t\n21\timpl DeterministicEmbedder {\n22\t    fn new(dimension: u32, delay: Duration) -> Self {\n23\t        Self {\n24\t            identity: EmbedderIdentity::new(\"deterministic\", \"perf-gates\", dimension),\n25\t            vector: unit_vector(dimension as usize),\n26\t            delay,\n27\t        }\n28\t    }\n29\t}\n30\t\n31\timpl Embedder for DeterministicEmbedder {\n32\t    fn identity(&self) -> EmbedderIdentity {\n33\t        self.identity.clone()\n34\t    }\n35\t\n36\t    fn embed(&self, _text: &str) -> Result<Vector, EmbedderError> {\n37\t        thread::sleep(self.delay);\n38\t        Ok(self.vector.clone())\n39\t    }\n40\t}\n41\t\n42\t#[derive(Clone, Debug)]\n43\tstruct RoutedEmbedder {\n44\t    identity: EmbedderIdentity,\n45\t}\n46\t\n47\timpl RoutedEmbedder {\n48\t    fn new(dimension: u32) -> Self {\n49\t        Self { identity: EmbedderIdentity::new(\"routed\", \"perf-gates\", dimension) }\n50\t    }\n51\t}\n52\t\n53\timpl Embedder for RoutedEmbedder {\n54\t    fn identity(&self) -> EmbedderIdentity {\n55\t        self.identity.clone()\n56\t    }\n57\t\n58\t    fn embed(&self, text: &str) -> Result<Vector, EmbedderError> {\n59\t        let mut vector = vec![0.0_f32; self.identity.dimension as usize];\n60\t        let slot = if text.starts_with(\"semantic-\") || text.starts_with(\"vector-doc-\") {\n61\t            0\n62\t        } else if text.starts_with(\"hybrid-\") || text.starts_with(\"hybrid doc\") {\n63\t            1\n64\t        } else {\n65\t            2\n66\t        };\n67\t        vector[slot] = 1.0;\n68\t        Ok(vector)\n69\t    }\n70\t}\n71\t\n72\tfn fixture_path(name: &str) -> (TempDir, std::path::PathBuf) {\n73\t    let dir = TempDir::new().unwrap();\n74\t    let path = dir.path().join(format!(\"{name}{SQLITE_SUFFIX}\"));\n75\t    (dir, path)\n76\t}\n77\t\n78\tfn percentile_ceil(samples: &[Duration], numerator: usize, denominator: usize) -> Duration {\n79\t    assert!(!samples.is_empty());\n80\t    let mut sorted = samples.to_vec();\n81\t    sorted.sort_unstable();\n82\t    let index = ((sorted.len() * numerator).div_ceil(denominator)).saturating_sub(1);\n83\t    sorted[index]\n84\t}\n85\t\n86\tfn unit_vector(dimension: usize) -> Vector {\n87\t    let mut values = vec![0.0_f32; dimension];\n88\t    if dimension > 0 {\n89\t        values[0] = 1.0;\n90\t    }\n91\t    values\n92\t}\n93\t\n94\tfn long_run_enabled() -> bool {\n95\t    std::env::var_os(\"AGENT_LONG\").is_some()\n96\t}\n97\t\n98\tfn ac020_queries() -> [&'static str; 4] {\n99\t    [\"semantic-0\", \"hybrid-0\", \"semantic-1\", \"hybrid-1\"]\n100\t}\n101\t\n102\tfn seed_ac020_fixture(engine: &Engine) {\n103\t    engine.configure_vector_kind_for_test(\"doc\").expect(\"vector kind\");\n104\t    for i in 0..2 {\n105\t        engine\n106\t            .write(&[PreparedWrite::Node {\n107\t                kind: \"doc\".to_string(),\n108\t                body: format!(\"vector-doc-{i}\"),\n109\t            }])\n110\t            .expect(\"vector-only write\");\n111\t        engine\n112\t            .write(&[PreparedWrite::Node {\n113\t                kind: \"doc\".to_string(),\n114\t                body: format!(\"hybrid doc hybrid-{i}\"),\n115\t            }])\n116\t            .expect(\"hybrid write\");\n117\t    }\n118\t    engine.drain(10_000).expect(\"drain\");\n119\t}\n120\t\n121\tfn run_ac020_mix(engine: &Engine) {\n122\t    for _ in 0..AC020_ROUNDS_PER_THREAD {\n123\t        for query in ac020_queries() {\n124\t            let result = engine.search(query).expect(\"search\");\n125\t            assert!(!result.results.is_empty(), \"read-mix query {query} must yield a result\");\n126\t        }\n127\t    }\n128\t}\n129\t\n130\t#[test]\n131\t#[ignore = \"protocol-incomplete: 1M text-query fixture from dev/acceptance.md is not landed yet\"]\n132\tfn ac_012_text_query_latency_on_fts5_path() {}\n133\t\n134\t#[test]\n135\t#[ignore = \"blocked on a protocol-complete vector-latency fixture and retrieval-path evidence\"]\n136\tfn ac_013_vector_retrieval_latency() {}\n137\t\n138\t#[test]\n139\tfn ac_017_vector_projection_freshness_p99_le_five_seconds() {\n140\t    let (_dir, path) = fixture_path(\"projection_freshness\");\n141\t    let embedder = Arc::new(DeterministicEmbedder::new(384, Duration::from_millis(1)));\n142\t    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n143\t    opened.engine.configure_vector_kind_for_test(\"doc\").expect(\"vector kind\");\n144\t\n145\t    let mut samples = Vec::with_capacity(PERF_SAMPLES);\n146\t    for i in 0..PERF_SAMPLES {\n147\t        let commit_started = Instant::now();\n148\t        let receipt = opened\n149\t            .engine\n150\t            .write(&[PreparedWrite::Node {\n151\t                kind: \"doc\".to_string(),\n152\t                body: format!(\"projection doc {i}\"),\n153\t            }])\n154\t            .expect(\"write\");\n155\t\n156\t        loop {\n157\t            let result = opened.engine.search(\"projection\").expect(\"search\");\n158\t            if result.projection_cursor >= receipt.cursor {\n159\t                samples.push(commit_started.elapsed());\n160\t                break;\n161\t            }\n162\t            assert!(\n163\t                commit_started.elapsed() < Duration::from_secs(5),\n164\t                \"projection cursor did not reach commit cursor within 5 s for write {}\",\n165\t                receipt.cursor\n166\t            );\n167\t            thread::sleep(Duration::from_millis(1));\n168\t        }\n169\t    }\n170\t\n171\t    let p99 = percentile_ceil(&samples, 99, 100);\n172\t    assert!(\n173\t        p99 <= Duration::from_secs(5),\n174\t        \"AC-017 failed: p99 freshness {:?} exceeded 5 s over {} samples\",\n175\t        p99,\n176\t        samples.len()\n177\t    );\n178\t}\n179\t\n180\t#[test]\n181\tfn ac_018_drain_of_100_vectors_le_two_seconds() {\n182\t    let (_dir, path) = fixture_path(\"drain_100_vectors\");\n183\t    let embedder = Arc::new(DeterministicEmbedder::new(384, Duration::from_millis(1)));\n184\t    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n185\t    opened.engine.configure_vector_kind_for_test(\"doc\").expect(\"vector kind\");\n186\t\n187\t    for i in 0..100 {\n188\t        opened\n189\t            .engine\n190\t            .write(&[PreparedWrite::Node { kind: \"doc\".to_string(), body: format!(\"doc {i}\") }])\n191\t            .expect(\"write\");\n192\t    }\n193\t\n194\t    let started = Instant::now();\n195\t    opened.engine.drain(5_000).expect(\"drain\");\n196\t    let elapsed = started.elapsed();\n197\t\n198\t    assert!(\n199\t        elapsed <= Duration::from_secs(2),\n200\t        \"AC-018 failed: drain took {:?}, expected <= 2 s\",\n201\t        elapsed\n202\t    );\n203\t    assert_eq!(opened.engine.vector_row_count_for_test().expect(\"vector rows\"), 100);\n204\t}\n205\t\n206\t#[test]\n207\t#[ignore = \"blocked on a protocol-complete mixed-retrieval workload that exercises a non-synthetic second branch\"]\n208\tfn ac_019_mixed_retrieval_stress_workload_tail() {}\n209\t\n210\t#[test]\n211\tfn ac_020_reads_do_not_serialize_on_a_single_reader_connection() {\n212\t    if !long_run_enabled() {\n213\t        return;\n214\t    }\n215\t\n216\t    let (_dir, path) = fixture_path(\"ac020_read_mix\");\n217\t    let embedder = Arc::new(RoutedEmbedder::new(3));\n218\t    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n219\t    seed_ac020_fixture(&opened.engine);\n220\t\n221\t    let sequential_started = Instant::now();\n222\t    for _ in 0..AC020_THREADS {\n223\t        run_ac020_mix(&opened.engine);\n224\t    }\n225\t    let sequential = sequential_started.elapsed();\n226\t\n227\t    let engine = Arc::new(opened.engine);\n228\t    let barrier = Arc::new(Barrier::new(AC020_THREADS + 1));\n229\t    let mut handles = Vec::with_capacity(AC020_THREADS);\n230\t    for _ in 0..AC020_THREADS {\n231\t        let engine = Arc::clone(&engine);\n232\t        let barrier = Arc::clone(&barrier);\n233\t        handles.push(thread::spawn(move || {\n234\t            barrier.wait();\n235\t            run_ac020_mix(&engine);\n236\t        }));\n237\t    }\n238\t    let concurrent_started = Instant::now();\n239\t    barrier.wait();\n240\t    for handle in handles {\n241\t        handle.join().expect(\"reader thread\");\n242\t    }\n243\t    let concurrent = concurrent_started.elapsed();\n244\t\n245\t    let bound = sequential.mul_f32(1.5 / AC020_THREADS as f32);\n246\t    assert!(\n247\t        concurrent <= bound,\n248\t        \"AC-020 failed: concurrent={concurrent:?} bound={bound:?} sequential={sequential:?}\"\n249\t    );\n250\t}\n251\t\n252\t#[test]\n253\t#[ignore = \"profiling harness: set AC020_PHASE=sequential to opt in\"]\n254\tfn ac_020_sequential_only() {\n255\t    if std::env::var(\"AC020_PHASE\").as_deref() != Ok(\"sequential\") {\n256\t        return;\n257\t    }\n258\t\n259\t    let (_dir, path) = fixture_path(\"ac020_sequential_only\");\n260\t    let embedder = Arc::new(RoutedEmbedder::new(3));\n261\t    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n262\t    seed_ac020_fixture(&opened.engine);\n263\t\n264\t    let started = Instant::now();\n265\t    for _ in 0..AC020_THREADS {\n266\t        run_ac020_mix(&opened.engine);\n267\t    }\n268\t    let elapsed = started.elapsed();\n269\t\n270\t    eprintln!(\"AC020_PHASE_SEQUENTIAL_MS={}\", elapsed.as_millis());\n271\t}\n272\t\n273\t#[test]\n274\t#[ignore = \"profiling harness: set AC020_PHASE=concurrent to opt in\"]\n275\tfn ac_020_concurrent_only() {\n276\t    if std::env::var(\"AC020_PHASE\").as_deref() != Ok(\"concurrent\") {\n277\t        return;\n278\t    }\n279\t\n280\t    let (_dir, path) = fixture_path(\"ac020_concurrent_only\");\n281\t    let embedder = Arc::new(RoutedEmbedder::new(3));\n282\t    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n283\t    seed_ac020_fixture(&opened.engine);\n284\t\n285\t    let engine = Arc::new(opened.engine);\n286\t    let barrier = Arc::new(Barrier::new(AC020_THREADS + 1));\n287\t    let mut handles = Vec::with_capacity(AC020_THREADS);\n288\t    for _ in 0..AC020_THREADS {\n289\t        let engine = Arc::clone(&engine);\n290\t        let barrier = Arc::clone(&barrier);\n291\t        handles.push(thread::spawn(move || {\n292\t            barrier.wait();\n293\t            run_ac020_mix(&engine);\n294\t        }));\n295\t    }\n296\t    let started = Instant::now();\n297\t    barrier.wait();\n298\t    for handle in handles {\n299\t        handle.join().expect(\"reader thread\");\n300\t    }\n301\t    let elapsed = started.elapsed();\n302\t\n303\t    eprintln!(\"AC020_PHASE_CONCURRENT_MS={}\", elapsed.as_millis());\n304\t}\n305\t\n306\t// ── A.3 secondary diagnostics ────────────────────────────────────────────────\n307\t\n308\tconst A3_EVIDENCE_DIR: &str = \"dev/plan/runs/A3-evidence\";\n309\t\n310\tfn a3_evidence_path(name: &str) -> std::path::PathBuf {\n311\t    // Resolve relative to repo root (two levels up from tests/).\n312\t    let manifest = std::path::PathBuf::from(env!(\"CARGO_MANIFEST_DIR\"));\n313\t    let repo_root = manifest.ancestors().nth(4).expect(\"repo root\").to_path_buf();\n314\t    let dir = repo_root.join(A3_EVIDENCE_DIR);\n315\t    std::fs::create_dir_all(&dir).expect(\"create evidence dir\");\n316\t    dir.join(name)\n317\t}\n318\t\n319\t/// A.3.2 — In-process timing counters for the concurrent read path.\n320\t/// Measures total wall time per `Engine::search()`. Since `RoutedEmbedder` has no\n321\t/// delay, search_us ≈ borrow_wait + read_search_in_tx. Splitting those requires\n322\t/// production hooks; counters_collection_status is `partial`.\n323\t#[test]\n324\t#[ignore = \"A.3 diagnostic: set AC020_PHASE=concurrent to opt in\"]\n325\tfn ac_a3_counters_concurrent() {\n326\t    if std::env::var(\"AC020_PHASE\").as_deref() != Ok(\"concurrent\") {\n327\t        return;\n328\t    }\n329\t\n330\t    let (_dir, path) = fixture_path(\"a3_counters_concurrent\");\n331\t    let embedder = Arc::new(RoutedEmbedder::new(3));\n332\t    let opened = Engine::open_with_embedder_for_test(&path, embedder.clone()).expect(\"open\");\n333\t    seed_ac020_fixture(&opened.engine);\n334\t\n335\t    let engine = Arc::new(opened.engine);\n336\t    let barrier = Arc::new(Barrier::new(AC020_THREADS + 1));\n337\t    let all_search_ms: Arc<Mutex<Vec<u64>>> = Arc::new(Mutex::new(Vec::new()));\n338\t    let all_embed_ms: Arc<Mutex<Vec<u64>>> = Arc::new(Mutex::new(Vec::new()));\n339\t\n340\t    let mut handles = Vec::with_capacity(AC020_THREADS);\n341\t    for _ in 0..AC020_THREADS {\n342\t        let engine = Arc::clone(&engine);\n343\t        let barrier = Arc::clone(&barrier);\n344\t        let search_sink = Arc::clone(&all_search_ms);\n345\t        let embed_sink = Arc::clone(&all_embed_ms);\n346\t        let embedder = embedder.clone();\n347\t        handles.push(thread::spawn(move || {\n348\t            barrier.wait();\n349\t            let mut local_search = Vec::new();\n350\t            let mut local_embed = Vec::new();\n351\t            for _ in 0..AC020_ROUNDS_PER_THREAD {\n352\t                for query in ac020_queries() {\n353\t                    let t_embed = Instant::now();\n354\t                    let _ = embedder.embed(query);\n355\t                    local_embed.push(t_embed.elapsed().as_micros() as u64);\n356\t\n357\t                    let t_search = Instant::now();\n358\t                    engine.search(query).expect(\"search\");\n359\t                    local_search.push(t_search.elapsed().as_micros() as u64);\n360\t                }\n361\t            }\n362\t            search_sink.lock().unwrap().extend(local_search);\n363\t            embed_sink.lock().unwrap().extend(local_embed);\n364\t        }));\n365\t    }\n366\t    barrier.wait();\n367\t    for h in handles {\n368\t        h.join().expect(\"thread\");\n369\t    }\n370\t\n371\t    let search_us = all_search_ms.lock().unwrap();\n372\t    let embed_us = all_embed_ms.lock().unwrap();\n373\t    let queries_total = search_us.len() as u64;\n374\t    let search_total_us: u64 = search_us.iter().sum();\n375\t    let embed_total_us: u64 = embed_us.iter().sum();\n376\t    // proxy: borrow+read ≈ search - embed (embed is ~0 µs for RoutedEmbedder)\n377\t    let proxy_read_total_us = search_total_us.saturating_sub(embed_total_us);\n378\t\n379\t    let search_per_query_us = search_total_us.checked_div(queries_total).unwrap_or(0);\n380\t    let embed_per_query_us = embed_total_us.checked_div(queries_total).unwrap_or(0);\n381\t    let proxy_per_query_us = proxy_read_total_us.checked_div(queries_total).unwrap_or(0);\n382\t\n383\t    // 4 SQL statements per search (vec0 match, canonical lookup, soft-fallback probe, fts match)\n384\t    // — constant by code inspection of read_search_in_tx.\n385\t    let prepares_per_search: u64 = 4;\n386\t\n387\t    let json = format!(\n388\t        r#\"{{\n389\t  \"reader_borrow_ms_total\": \"n/a: requires production hook\",\n390\t  \"reader_borrow_ms_per_query\": \"n/a: requires production hook\",\n391\t  \"embedder_us_total\": {embed_total_us},\n392\t  \"embedder_us_per_query\": {embed_per_query_us},\n393\t  \"search_us_total\": {search_total_us},\n394\t  \"search_us_per_query\": {search_per_query_us},\n395\t  \"proxy_borrow_plus_read_us_total\": {proxy_read_total_us},\n396\t  \"proxy_borrow_plus_read_us_per_query\": {proxy_per_query_us},\n397\t  \"prepares_per_search\": {prepares_per_search},\n398\t  \"queries_total\": {queries_total},\n399\t  \"counters_collection_status\": \"partial: borrow_wait and read_search_in_tx split requires production hooks; search_us covers both\",\n400\t  \"note\": \"embed is RoutedEmbedder (instant), so proxy_borrow_plus_read_us ≈ read_search_in_tx_us + borrow_wait_us\"\n401\t}}\"#\n402\t    );\n403\t\n404\t    let out_path = a3_evidence_path(\"counters.json\");\n405\t    std::fs::write(&out_path, &json).expect(\"write counters.json\");\n406\t    eprintln!(\"A3_COUNTERS written to {}\", out_path.display());\n407\t    eprintln!(\"  queries_total={queries_total}\");\n408\t    eprintln!(\"  search_us_total={search_total_us}  per_query={search_per_query_us}\");\n409\t    eprintln!(\"  embed_us_total={embed_total_us}  per_query={embed_per_query_us}\");\n410\t    eprintln!(\"  proxy_read_us_total={proxy_read_total_us}  per_query={proxy_per_query_us}\");\n411\t}\n412\t\n413\t/// A.3.3 — EXPLAIN QUERY PLAN for the four read-path SQL statements.\n414\t#[test]\n415\t#[ignore = \"A.3 diagnostic: opt-in with AC020_PHASE=concurrent\"]\n416\tfn ac_a3_explain_query_plan() {\n417\t    if std::env::var(\"AC020_PHASE\").as_deref() != Ok(\"concurrent\") {\n418\t        return;\n419\t    }\n420\t\n421\t    let (_dir, path) = fixture_path(\"a3_explain\");\n422\t    let embedder = Arc::new(RoutedEmbedder::new(3));\n423\t    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n424\t    seed_ac020_fixture(&opened.engine);\n425\t    // Engine must stay alive while we open a raw connection (WAL, shared cache).\n426\t    let db_path = opened.engine.path().to_path_buf();\n427\t\n428\t    // Open a raw rusqlite connection — sqlite_vec auto-extension is process-global\n429\t    // after the first Engine::open, so vec0 virtual tables are accessible.\n430\t    let conn = rusqlite::Connection::open(&db_path).expect(\"raw conn\");\n431\t    conn.pragma_update(None, \"query_only\", \"ON\").ok();\n432\t\n433\t    // (label, sql-with-literal-placeholders-for-EXPLAIN, explain-literal-substituted)\n434\t    // EXPLAIN QUERY PLAN requires parameter binding even though it doesn't execute.\n435\t    // Use rusqlite::params! with one dummy value per ?1 slot.\n436\t    let statements: &[(&str, &str, &str)] = &[\n437\t        (\n438\t            \"vec0_match\",\n439\t            \"SELECT rowid FROM vector_default WHERE embedding MATCH vec_f32(?1) ORDER BY distance LIMIT 10\",\n440\t            \"SELECT rowid FROM vector_default WHERE embedding MATCH vec_f32('[1.0,0.0,0.0]') ORDER BY distance LIMIT 10\",\n441\t        ),\n442\t        (\n443\t            \"canonical_lookup\",\n444\t            \"SELECT body FROM canonical_nodes WHERE write_cursor = ?1 LIMIT 1\",\n445\t            \"SELECT body FROM canonical_nodes WHERE write_cursor = 1 LIMIT 1\",\n446\t        ),\n447\t        (\n448\t            \"soft_fallback_probe\",\n449\t            \"SELECT 1\n450\t             FROM search_index\n451\t             JOIN _fathomdb_vector_kinds ON _fathomdb_vector_kinds.kind = search_index.kind\n452\t             LEFT JOIN _fathomdb_projection_terminal\n453\t               ON _fathomdb_projection_terminal.write_cursor = search_index.write_cursor\n454\t             WHERE search_index MATCH ?1\n455\t              AND _fathomdb_projection_terminal.write_cursor IS NULL\n456\t             LIMIT 1\",\n457\t            \"SELECT 1\n458\t             FROM search_index\n459\t             JOIN _fathomdb_vector_kinds ON _fathomdb_vector_kinds.kind = search_index.kind\n460\t             LEFT JOIN _fathomdb_projection_terminal\n461\t               ON _fathomdb_projection_terminal.write_cursor = search_index.write_cursor\n462\t             WHERE search_index MATCH 'dummy'\n463\t              AND _fathomdb_projection_terminal.write_cursor IS NULL\n464\t             LIMIT 1\",\n465\t        ),\n466\t        (\n467\t            \"fts_match\",\n468\t            \"SELECT body FROM search_index WHERE search_index MATCH ?1 ORDER BY write_cursor\",\n469\t            \"SELECT body FROM search_index WHERE search_index MATCH 'dummy' ORDER BY write_cursor\",\n470\t        ),\n471\t    ];\n472\t\n473\t    let mut out = String::new();\n474\t    let mut regression = false;\n475\t\n476\t    for (label, _parametric_sql, explain_sql) in statements {\n477\t        out.push_str(&format!(\"=== {label} ===\\n\"));\n478\t        let explain = format!(\"EXPLAIN QUERY PLAN {explain_sql}\");\n479\t        let mut stmt = conn.prepare(&explain).expect(\"prepare explain\");\n480\t        let rows: Vec<String> = stmt\n481\t            .query_map([], |row| {\n482\t                let detail: String = row.get(3)?;\n483\t                Ok(detail)\n484\t            })\n485\t            .expect(\"query_map\")\n486\t            .flatten()\n487\t            .collect();\n488\t        for row in &rows {\n489\t            out.push_str(&format!(\"  {row}\\n\"));\n490\t            // Flag SCAN on canonical_nodes or search_index without SEARCH — potential regression.\n491\t            if row.contains(\"SCAN\") && !row.contains(\"vec0\") && !row.contains(\"fts5\") {\n492\t                regression = true;\n493\t                out.push_str(\"  *** REGRESSION CANDIDATE: unexpected SCAN ***\\n\");\n494\t            }\n495\t        }\n496\t        out.push('\\n');\n497\t    }\n498\t\n499\t    out.push_str(&format!(\"regression_observed: {regression}\\n\"));\n500\t\n501\t    let out_path = a3_evidence_path(\"explain-query-plan.txt\");\n502\t    std::fs::write(&out_path, &out).expect(\"write explain-query-plan.txt\");\n503\t    eprintln!(\"A3_EXPLAIN written to {}\", out_path.display());\n504\t    eprintln!(\"{out}\");\n505\t}\n506\t\n507\t/// A.3.4 — sqlite3_threadsafe integer + PRAGMA compile_options.\n508\t///\n509\t/// Also probes the reader-connection pragma profile (cache_size, mmap_size,\n510\t/// page_size, synchronous, journal_mode, query_only).\n511\t#[test]\n512\t#[ignore = \"A.3 diagnostic: opt-in with AC020_PHASE=concurrent\"]\n513\tfn ac_a3_threadsafe_and_compile_options() {\n514\t    if std::env::var(\"AC020_PHASE\").as_deref() != Ok(\"concurrent\") {\n515\t        return;\n516\t    }\n517\t\n518\t    let (_dir, path) = fixture_path(\"a3_threadsafe\");\n519\t    // Open via Engine to register extension and create schema.\n520\t    let opened = Engine::open_without_embedder_for_test(&path).expect(\"open\");\n521\t    let db_path = opened.engine.path().to_path_buf();\n522\t    drop(opened);\n523\t\n524\t    let conn = rusqlite::Connection::open(&db_path).expect(\"conn\");\n525\t\n526\t    // A.3.4a — THREADSAFE\n527\t    let threadsafe_val: i32 = unsafe { rusqlite::ffi::sqlite3_threadsafe() };\n528\t    std::fs::write(a3_evidence_path(\"threadsafe.txt\"), format!(\"{threadsafe_val}\\n\"))\n529\t        .expect(\"write threadsafe.txt\");\n530\t    eprintln!(\"A3_THREADSAFE={threadsafe_val}\");\n531\t\n532\t    // A.3.4b — compile_options\n533\t    let mut stmt = conn.prepare(\"PRAGMA compile_options\").expect(\"prepare compile_options\");\n534\t    let opts: Vec<String> =\n535\t        stmt.query_map([], |r| r.get::<_, String>(0)).expect(\"query_map\").flatten().collect();\n536\t    let opts_text = opts.join(\"\\n\") + \"\\n\";\n537\t    std::fs::write(a3_evidence_path(\"compile_options.txt\"), &opts_text)\n538\t        .expect(\"write compile_options.txt\");\n539\t    eprintln!(\"A3_COMPILE_OPTIONS ({} lines):\\n{opts_text}\", opts.len());\n540\t\n541\t    // A.3.4c — reader pragma profile (WAL + query_only reader mimicking production)\n542\t    conn.pragma_update(None, \"journal_mode\", \"WAL\").ok();\n543\t    conn.pragma_update(None, \"query_only\", \"ON\").ok();\n544\t    let journal_mode: String =\n545\t        conn.pragma_query_value(None, \"journal_mode\", |r| r.get(0)).unwrap_or_default();\n546\t    let query_only: i64 = conn.pragma_query_value(None, \"query_only\", |r| r.get(0)).unwrap_or(0);\n547\t    let cache_size: i64 = conn.pragma_query_value(None, \"cache_size\", |r| r.get(0)).unwrap_or(0);\n548\t    let mmap_size: i64 = conn.pragma_query_value(None, \"mmap_size\", |r| r.get(0)).unwrap_or(0);\n549\t    let page_size: i64 = conn.pragma_query_value(None, \"page_size\", |r| r.get(0)).unwrap_or(0);\n550\t    let synchronous: i64 = conn.pragma_query_value(None, \"synchronous\", |r| r.get(0)).unwrap_or(0);\n551\t\n552\t    let pragma_json = format!(\n553\t        r#\"{{\n554\t  \"journal_mode\": \"{journal_mode}\",\n555\t  \"query_only\": {query_only},\n556\t  \"cache_size\": {cache_size},\n557\t  \"mmap_size\": {mmap_size},\n558\t  \"page_size\": {page_size},\n559\t  \"synchronous\": {synchronous}\n560\t}}\"#\n561\t    );\n562\t    std::fs::write(a3_evidence_path(\"reader_pragmas.json\"), &pragma_json)\n563\t        .expect(\"write reader_pragmas.json\");\n564\t    eprintln!(\"A3_READER_PRAGMAS: {pragma_json}\");\n565\t}\n566\t"}]},"parent_tool_use_id":null,"session_id":"8996a1e6-f0cf-41f6-bd76-ad56a5a9b42e","uuid":"2b60000d-cf7e-4d10-9488-bd44e010c811","timestamp":"2026-05-04T02:27:41.766Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/fdb-pack5-C1-threadsafe2-rebuild-20260504T022727Z/src/rust/crates/fathomdb-engine/tests/perf_gates.rs","content":"use std::sync::{Arc, Barrier, Mutex};\nuse std::thread;\nuse std::time::{Duration, Instant};\n\nuse fathomdb_embedder_api::{Embedder, EmbedderError, EmbedderIdentity, Vector};\nuse fathomdb_engine::{Engine, PreparedWrite};\nuse fathomdb_schema::SQLITE_SUFFIX;\nuse tempfile::TempDir;\n\nconst PERF_SAMPLES: usize = 1_000;\nconst AC020_THREADS: usize = 8;\nconst AC020_ROUNDS_PER_THREAD: usize = 50;\n\n#[derive(Clone, Debug)]\nstruct DeterministicEmbedder {\n    identity: EmbedderIdentity,\n    vector: Vector,\n    delay: Duration,\n}\n\nimpl DeterministicEmbedder {\n    fn new(dimension: u32, delay: Duration) -> Self {\n        Self {\n            identity: EmbedderIdentity::new(\"deterministic\", \"perf-gates\", dimension),\n            vector: unit_vector(dimension as usize),\n            delay,\n        }\n    }\n}\n\nimpl Embedder for DeterministicEmbedder {\n    fn identity(&self) -> EmbedderIdentity {\n        self.identity.clone()\n    }\n\n    fn embed(&self, _text: &str) -> Result<Vector, EmbedderError> {\n        thread::sleep(self.delay);\n        Ok(self.vector.clone())\n    }\n}\n\n#[derive(Clone, Debug)]\nstruct RoutedEmbedder {\n    identity: EmbedderIdentity,\n}\n\nimpl RoutedEmbedder {\n    fn new(dimension: u32) -> Self {\n        Self { identity: EmbedderIdentity::new(\"routed\", \"perf-gates\", dimension) }\n    }\n}\n\nimpl Embedder for RoutedEmbedder {\n    fn identity(&self) -> EmbedderIdentity {\n        self.identity.clone()\n    }\n\n    fn embed(&self, text: &str) -> Result<Vector, EmbedderError> {\n        let mut vector = vec![0.0_f32; self.identity.dimension as usize];\n        let slot = if text.starts_with(\"semantic-\") || text.starts_with(\"vector-doc-\") {\n            0\n        } else if text.starts_with(\"hybrid-\") || text.starts_with(\"hybrid doc\") {\n            1\n        } else {\n            2\n        };\n        vector[slot] = 1.0;\n        Ok(vector)\n    }\n}\n\nfn fixture_path(name: &str) -> (TempDir, std::path::PathBuf) {\n    let dir = TempDir::new().unwrap();\n    let path = dir.path().join(format!(\"{name}{SQLITE_SUFFIX}\"));\n    (dir, path)\n}\n\nfn percentile_ceil(samples: &[Duration], numerator: usize, denominator: usize) -> Duration {\n    assert!(!samples.is_empty());\n    let mut sorted = samples.to_vec();\n    sorted.sort_unstable();\n    let index = ((sorted.len() * numerator).div_ceil(denominator)).saturating_sub(1);\n    sorted[index]\n}\n\nfn unit_vector(dimension: usize) -> Vector {\n    let mut values = vec![0.0_f32; dimension];\n    if dimension > 0 {\n        values[0] = 1.0;\n    }\n    values\n}\n\nfn long_run_enabled() -> bool {\n    std::env::var_os(\"AGENT_LONG\").is_some()\n}\n\nfn ac020_queries() -> [&'static str; 4] {\n    [\"semantic-0\", \"hybrid-0\", \"semantic-1\", \"hybrid-1\"]\n}\n\nfn seed_ac020_fixture(engine: &Engine) {\n    engine.configure_vector_kind_for_test(\"doc\").expect(\"vector kind\");\n    for i in 0..2 {\n        engine\n            .write(&[PreparedWrite::Node {\n                kind: \"doc\".to_string(),\n                body: format!(\"vector-doc-{i}\"),\n            }])\n            .expect(\"vector-only write\");\n        engine\n            .write(&[PreparedWrite::Node {\n                kind: \"doc\".to_string(),\n                body: format!(\"hybrid doc hybrid-{i}\"),\n            }])\n            .expect(\"hybrid write\");\n    }\n    engine.drain(10_000).expect(\"drain\");\n}\n\nfn run_ac020_mix(engine: &Engine) {\n    for _ in 0..AC020_ROUNDS_PER_THREAD {\n        for query in ac020_queries() {\n            let result = engine.search(query).expect(\"search\");\n            assert!(!result.results.is_empty(), \"read-mix query {query} must yield a result\");\n        }\n    }\n}\n\n#[test]\n#[ignore = \"protocol-incomplete: 1M text-query fixture from dev/acceptance.md is not landed yet\"]\nfn ac_012_text_query_latency_on_fts5_path() {}\n\n#[test]\n#[ignore = \"blocked on a protocol-complete vector-latency fixture and retrieval-path evidence\"]\nfn ac_013_vector_retrieval_latency() {}\n\n#[test]\nfn ac_017_vector_projection_freshness_p99_le_five_seconds() {\n    let (_dir, path) = fixture_path(\"projection_freshness\");\n    let embedder = Arc::new(DeterministicEmbedder::new(384, Duration::from_millis(1)));\n    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n    opened.engine.configure_vector_kind_for_test(\"doc\").expect(\"vector kind\");\n\n    let mut samples = Vec::with_capacity(PERF_SAMPLES);\n    for i in 0..PERF_SAMPLES {\n        let commit_started = Instant::now();\n        let receipt = opened\n            .engine\n            .write(&[PreparedWrite::Node {\n                kind: \"doc\".to_string(),\n                body: format!(\"projection doc {i}\"),\n            }])\n            .expect(\"write\");\n\n        loop {\n            let result = opened.engine.search(\"projection\").expect(\"search\");\n            if result.projection_cursor >= receipt.cursor {\n                samples.push(commit_started.elapsed());\n                break;\n            }\n            assert!(\n                commit_started.elapsed() < Duration::from_secs(5),\n                \"projection cursor did not reach commit cursor within 5 s for write {}\",\n                receipt.cursor\n            );\n            thread::sleep(Duration::from_millis(1));\n        }\n    }\n\n    let p99 = percentile_ceil(&samples, 99, 100);\n    assert!(\n        p99 <= Duration::from_secs(5),\n        \"AC-017 failed: p99 freshness {:?} exceeded 5 s over {} samples\",\n        p99,\n        samples.len()\n    );\n}\n\n#[test]\nfn ac_018_drain_of_100_vectors_le_two_seconds() {\n    let (_dir, path) = fixture_path(\"drain_100_vectors\");\n    let embedder = Arc::new(DeterministicEmbedder::new(384, Duration::from_millis(1)));\n    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n    opened.engine.configure_vector_kind_for_test(\"doc\").expect(\"vector kind\");\n\n    for i in 0..100 {\n        opened\n            .engine\n            .write(&[PreparedWrite::Node { kind: \"doc\".to_string(), body: format!(\"doc {i}\") }])\n            .expect(\"write\");\n    }\n\n    let started = Instant::now();\n    opened.engine.drain(5_000).expect(\"drain\");\n    let elapsed = started.elapsed();\n\n    assert!(\n        elapsed <= Duration::from_secs(2),\n        \"AC-018 failed: drain took {:?}, expected <= 2 s\",\n        elapsed\n    );\n    assert_eq!(opened.engine.vector_row_count_for_test().expect(\"vector rows\"), 100);\n}\n\n#[test]\n#[ignore = \"blocked on a protocol-complete mixed-retrieval workload that exercises a non-synthetic second branch\"]\nfn ac_019_mixed_retrieval_stress_workload_tail() {}\n\n#[test]\nfn ac_020_reads_do_not_serialize_on_a_single_reader_connection() {\n    if !long_run_enabled() {\n        return;\n    }\n\n    let (_dir, path) = fixture_path(\"ac020_read_mix\");\n    let embedder = Arc::new(RoutedEmbedder::new(3));\n    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n    seed_ac020_fixture(&opened.engine);\n\n    let sequential_started = Instant::now();\n    for _ in 0..AC020_THREADS {\n        run_ac020_mix(&opened.engine);\n    }\n    let sequential = sequential_started.elapsed();\n\n    let engine = Arc::new(opened.engine);\n    let barrier = Arc::new(Barrier::new(AC020_THREADS + 1));\n    let mut handles = Vec::with_capacity(AC020_THREADS);\n    for _ in 0..AC020_THREADS {\n        let engine = Arc::clone(&engine);\n        let barrier = Arc::clone(&barrier);\n        handles.push(thread::spawn(move || {\n            barrier.wait();\n            run_ac020_mix(&engine);\n        }));\n    }\n    let concurrent_started = Instant::now();\n    barrier.wait();\n    for handle in handles {\n        handle.join().expect(\"reader thread\");\n    }\n    let concurrent = concurrent_started.elapsed();\n\n    let bound = sequential.mul_f32(1.5 / AC020_THREADS as f32);\n    assert!(\n        concurrent <= bound,\n        \"AC-020 failed: concurrent={concurrent:?} bound={bound:?} sequential={sequential:?}\"\n    );\n}\n\n#[test]\n#[ignore = \"profiling harness: set AC020_PHASE=sequential to opt in\"]\nfn ac_020_sequential_only() {\n    if std::env::var(\"AC020_PHASE\").as_deref() != Ok(\"sequential\") {\n        return;\n    }\n\n    let (_dir, path) = fixture_path(\"ac020_sequential_only\");\n    let embedder = Arc::new(RoutedEmbedder::new(3));\n    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n    seed_ac020_fixture(&opened.engine);\n\n    let started = Instant::now();\n    for _ in 0..AC020_THREADS {\n        run_ac020_mix(&opened.engine);\n    }\n    let elapsed = started.elapsed();\n\n    eprintln!(\"AC020_PHASE_SEQUENTIAL_MS={}\", elapsed.as_millis());\n}\n\n#[test]\n#[ignore = \"profiling harness: set AC020_PHASE=concurrent to opt in\"]\nfn ac_020_concurrent_only() {\n    if std::env::var(\"AC020_PHASE\").as_deref() != Ok(\"concurrent\") {\n        return;\n    }\n\n    let (_dir, path) = fixture_path(\"ac020_concurrent_only\");\n    let embedder = Arc::new(RoutedEmbedder::new(3));\n    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n    seed_ac020_fixture(&opened.engine);\n\n    let engine = Arc::new(opened.engine);\n    let barrier = Arc::new(Barrier::new(AC020_THREADS + 1));\n    let mut handles = Vec::with_capacity(AC020_THREADS);\n    for _ in 0..AC020_THREADS {\n        let engine = Arc::clone(&engine);\n        let barrier = Arc::clone(&barrier);\n        handles.push(thread::spawn(move || {\n            barrier.wait();\n            run_ac020_mix(&engine);\n        }));\n    }\n    let started = Instant::now();\n    barrier.wait();\n    for handle in handles {\n        handle.join().expect(\"reader thread\");\n    }\n    let elapsed = started.elapsed();\n\n    eprintln!(\"AC020_PHASE_CONCURRENT_MS={}\", elapsed.as_millis());\n}\n\n// ── A.3 secondary diagnostics ────────────────────────────────────────────────\n\nconst A3_EVIDENCE_DIR: &str = \"dev/plan/runs/A3-evidence\";\n\nfn a3_evidence_path(name: &str) -> std::path::PathBuf {\n    // Resolve relative to repo root (two levels up from tests/).\n    let manifest = std::path::PathBuf::from(env!(\"CARGO_MANIFEST_DIR\"));\n    let repo_root = manifest.ancestors().nth(4).expect(\"repo root\").to_path_buf();\n    let dir = repo_root.join(A3_EVIDENCE_DIR);\n    std::fs::create_dir_all(&dir).expect(\"create evidence dir\");\n    dir.join(name)\n}\n\n/// A.3.2 — In-process timing counters for the concurrent read path.\n/// Measures total wall time per `Engine::search()`. Since `RoutedEmbedder` has no\n/// delay, search_us ≈ borrow_wait + read_search_in_tx. Splitting those requires\n/// production hooks; counters_collection_status is `partial`.\n#[test]\n#[ignore = \"A.3 diagnostic: set AC020_PHASE=concurrent to opt in\"]\nfn ac_a3_counters_concurrent() {\n    if std::env::var(\"AC020_PHASE\").as_deref() != Ok(\"concurrent\") {\n        return;\n    }\n\n    let (_dir, path) = fixture_path(\"a3_counters_concurrent\");\n    let embedder = Arc::new(RoutedEmbedder::new(3));\n    let opened = Engine::open_with_embedder_for_test(&path, embedder.clone()).expect(\"open\");\n    seed_ac020_fixture(&opened.engine);\n\n    let engine = Arc::new(opened.engine);\n    let barrier = Arc::new(Barrier::new(AC020_THREADS + 1));\n    let all_search_ms: Arc<Mutex<Vec<u64>>> = Arc::new(Mutex::new(Vec::new()));\n    let all_embed_ms: Arc<Mutex<Vec<u64>>> = Arc::new(Mutex::new(Vec::new()));\n\n    let mut handles = Vec::with_capacity(AC020_THREADS);\n    for _ in 0..AC020_THREADS {\n        let engine = Arc::clone(&engine);\n        let barrier = Arc::clone(&barrier);\n        let search_sink = Arc::clone(&all_search_ms);\n        let embed_sink = Arc::clone(&all_embed_ms);\n        let embedder = embedder.clone();\n        handles.push(thread::spawn(move || {\n            barrier.wait();\n            let mut local_search = Vec::new();\n            let mut local_embed = Vec::new();\n            for _ in 0..AC020_ROUNDS_PER_THREAD {\n                for query in ac020_queries() {\n                    let t_embed = Instant::now();\n                    let _ = embedder.embed(query);\n                    local_embed.push(t_embed.elapsed().as_micros() as u64);\n\n                    let t_search = Instant::now();\n                    engine.search(query).expect(\"search\");\n                    local_search.push(t_search.elapsed().as_micros() as u64);\n                }\n            }\n            search_sink.lock().unwrap().extend(local_search);\n            embed_sink.lock().unwrap().extend(local_embed);\n        }));\n    }\n    barrier.wait();\n    for h in handles {\n        h.join().expect(\"thread\");\n    }\n\n    let search_us = all_search_ms.lock().unwrap();\n    let embed_us = all_embed_ms.lock().unwrap();\n    let queries_total = search_us.len() as u64;\n    let search_total_us: u64 = search_us.iter().sum();\n    let embed_total_us: u64 = embed_us.iter().sum();\n    // proxy: borrow+read ≈ search - embed (embed is ~0 µs for RoutedEmbedder)\n    let proxy_read_total_us = search_total_us.saturating_sub(embed_total_us);\n\n    let search_per_query_us = search_total_us.checked_div(queries_total).unwrap_or(0);\n    let embed_per_query_us = embed_total_us.checked_div(queries_total).unwrap_or(0);\n    let proxy_per_query_us = proxy_read_total_us.checked_div(queries_total).unwrap_or(0);\n\n    // 4 SQL statements per search (vec0 match, canonical lookup, soft-fallback probe, fts match)\n    // — constant by code inspection of read_search_in_tx.\n    let prepares_per_search: u64 = 4;\n\n    let json = format!(\n        r#\"{{\n  \"reader_borrow_ms_total\": \"n/a: requires production hook\",\n  \"reader_borrow_ms_per_query\": \"n/a: requires production hook\",\n  \"embedder_us_total\": {embed_total_us},\n  \"embedder_us_per_query\": {embed_per_query_us},\n  \"search_us_total\": {search_total_us},\n  \"search_us_per_query\": {search_per_query_us},\n  \"proxy_borrow_plus_read_us_total\": {proxy_read_total_us},\n  \"proxy_borrow_plus_read_us_per_query\": {proxy_per_query_us},\n  \"prepares_per_search\": {prepares_per_search},\n  \"queries_total\": {queries_total},\n  \"counters_collection_status\": \"partial: borrow_wait and read_search_in_tx split requires production hooks; search_us covers both\",\n  \"note\": \"embed is RoutedEmbedder (instant), so proxy_borrow_plus_read_us ≈ read_search_in_tx_us + borrow_wait_us\"\n}}\"#\n    );\n\n    let out_path = a3_evidence_path(\"counters.json\");\n    std::fs::write(&out_path, &json).expect(\"write counters.json\");\n    eprintln!(\"A3_COUNTERS written to {}\", out_path.display());\n    eprintln!(\"  queries_total={queries_total}\");\n    eprintln!(\"  search_us_total={search_total_us}  per_query={search_per_query_us}\");\n    eprintln!(\"  embed_us_total={embed_total_us}  per_query={embed_per_query_us}\");\n    eprintln!(\"  proxy_read_us_total={proxy_read_total_us}  per_query={proxy_per_query_us}\");\n}\n\n/// A.3.3 — EXPLAIN QUERY PLAN for the four read-path SQL statements.\n#[test]\n#[ignore = \"A.3 diagnostic: opt-in with AC020_PHASE=concurrent\"]\nfn ac_a3_explain_query_plan() {\n    if std::env::var(\"AC020_PHASE\").as_deref() != Ok(\"concurrent\") {\n        return;\n    }\n\n    let (_dir, path) = fixture_path(\"a3_explain\");\n    let embedder = Arc::new(RoutedEmbedder::new(3));\n    let opened = Engine::open_with_embedder_for_test(&path, embedder).expect(\"open\");\n    seed_ac020_fixture(&opened.engine);\n    // Engine must stay alive while we open a raw connection (WAL, shared cache).\n    let db_path = opened.engine.path().to_path_buf();\n\n    // Open a raw rusqlite connection — sqlite_vec auto-extension is process-global\n    // after the first Engine::open, so vec0 virtual tables are accessible.\n    let conn = rusqlite::Connection::open(&db_path).expect(\"raw conn\");\n    conn.pragma_update(None, \"query_only\", \"ON\").ok();\n\n    // (label, sql-with-literal-placeholders-for-EXPLAIN, explain-literal-substituted)\n    // EXPLAIN QUERY PLAN requires parameter binding even though it doesn't execute.\n    // Use rusqlite::params! with one dummy value per ?1 slot.\n    let statements: &[(&str, &str, &str)] = &[\n        (\n            \"vec0_match\",\n            \"SELECT rowid FROM vector_default WHERE embedding MATCH vec_f32(?1) ORDER BY distance LIMIT 10\",\n            \"SELECT rowid FROM vector_default WHERE embedding MATCH vec_f32('[1.0,0.0,0.0]') ORDER BY distance LIMIT 10\",\n        ),\n        (\n            \"canonical_lookup\",\n            \"SELECT body FROM canonical_nodes WHERE write_cursor = ?1 LIMIT 1\",\n            \"SELECT body FROM canonical_nodes WHERE write_cursor = 1 LIMIT 1\",\n        ),\n        (\n            \"soft_fallback_probe\",\n            \"SELECT 1\n             FROM search_index\n             JOIN _fathomdb_vector_kinds ON _fathomdb_vector_kinds.kind = search_index.kind\n             LEFT JOIN _fathomdb_projection_terminal\n               ON _fathomdb_projection_terminal.write_cursor = search_index.write_cursor\n             WHERE search_index MATCH ?1\n              AND _fathomdb_projection_terminal.write_cursor IS NULL\n             LIMIT 1\",\n            \"SELECT 1\n             FROM search_index\n             JOIN _fathomdb_vector_kinds ON _fathomdb_vector_kinds.kind = search_index.kind\n             LEFT JOIN _fathomdb_projection_terminal\n               ON _fathomdb_projection_terminal.write_cursor = search_index.write_cursor\n             WHERE search_index MATCH 'dummy'\n              AND _fathomdb_projection_terminal.write_cursor IS NULL\n             LIMIT 1\",\n        ),\n        (\n            \"fts_match\",\n            \"SELECT body FROM search_index WHERE search_index MATCH ?1 ORDER BY write_cursor\",\n            \"SELECT body FROM search_index WHERE search_index MATCH 'dummy' ORDER BY write_cursor\",\n        ),\n    ];\n\n    let mut out = String::new();\n    let mut regression = false;\n\n    for (label, _parametric_sql, explain_sql) in statements {\n        out.push_str(&format!(\"=== {label} ===\\n\"));\n        let explain = format!(\"EXPLAIN QUERY PLAN {explain_sql}\");\n        let mut stmt = conn.prepare(&explain).expect(\"prepare explain\");\n        let rows: Vec<String> = stmt\n            .query_map([], |row| {\n                let detail: String = row.get(3)?;\n                Ok(detail)\n            })\n            .expect(\"query_map\")\n            .flatten()\n            .collect();\n        for row in &rows {\n            out.push_str(&format!(\"  {row}\\n\"));\n            // Flag SCAN on canonical_nodes or search_index without SEARCH — potential regression.\n            if row.contains(\"SCAN\") && !row.contains(\"vec0\") && !row.contains(\"fts5\") {\n                regression = true;\n                out.push_str(\"  *** REGRESSION CANDIDATE: unexpected SCAN ***\\n\");\n            }\n        }\n        out.push('\\n');\n    }\n\n    out.push_str(&format!(\"regression_observed: {regression}\\n\"));\n\n    let out_path = a3_evidence_path(\"explain-query-plan.txt\");\n    std::fs::write(&out_path, &out).expect(\"write explain-query-plan.txt\");\n    eprintln!(\"A3_EXPLAIN written to {}\", out_path.display());\n    eprintln!(\"{out}\");\n}\n\n/// A.3.4 — sqlite3_threadsafe integer + PRAGMA compile_options.\n///\n/// Also probes the reader-connection pragma profile (cache_size, mmap_size,\n/// page_size, synchronous, journal_mode, query_only).\n#[test]\n#[ignore = \"A.3 diagnostic: opt-in with AC020_PHASE=concurrent\"]\nfn ac_a3_threadsafe_and_compile_options() {\n    if std::env::var(\"AC020_PHASE\").as_deref() != Ok(\"concurrent\") {\n        return;\n    }\n\n    let (_dir, path) = fixture_path(\"a3_threadsafe\");\n    // Open via Engine to register extension and create schema.\n    let opened = Engine::open_without_embedder_for_test(&path).expect(\"open\");\n    let db_path = opened.engine.path().to_path_buf();\n    drop(opened);\n\n    let conn = rusqlite::Connection::open(&db_path).expect(\"conn\");\n\n    // A.3.4a — THREADSAFE\n    let threadsafe_val: i32 = unsafe { rusqlite::ffi::sqlite3_threadsafe() };\n    std::fs::write(a3_evidence_path(\"threadsafe.txt\"), format!(\"{threadsafe_val}\\n\"))\n        .expect(\"write threadsafe.txt\");\n    eprintln!(\"A3_THREADSAFE={threadsafe_val}\");\n\n    // A.3.4b — compile_options\n    let mut stmt = conn.prepare(\"PRAGMA compile_options\").expect(\"prepare compile_options\");\n    let opts: Vec<String> =\n        stmt.query_map([], |r| r.get::<_, String>(0)).expect(\"query_map\").flatten().collect();\n    let opts_text = opts.join(\"\\n\") + \"\\n\";\n    std::fs::write(a3_evidence_path(\"compile_options.txt\"), &opts_text)\n        .expect(\"write compile_options.txt\");\n    eprintln!(\"A3_COMPILE_OPTIONS ({} lines):\\n{opts_text}\", opts.len());\n\n    // A.3.4c — reader pragma profile (WAL + query_only reader mimicking production)\n    conn.pragma_update(None, \"journal_mode\", \"WAL\").ok();\n    conn.pragma_update(None, \"query_only\", \"ON\").ok();\n    let journal_mode: String =\n        conn.pragma_query_value(None, \"journal_mode\", |r| r.get(0)).unwrap_or_default();\n    let query_only: i64 = conn.pragma_query_value(None, \"query_only\", |r| r.get(0)).unwrap_or(0);\n    let cache_size: i64 = conn.pragma_query_value(None, \"cache_size\", |r| r.get(0)).unwrap_or(0);\n    let mmap_size: i64 = conn.pragma_query_value(None, \"mmap_size\", |r| r.get(0)).unwrap_or(0);\n    let page_size: i64 = conn.pragma_query_value(None, \"page_size\", |r| r.get(0)).unwrap_or(0);\n    let synchronous: i64 = conn.pragma_query_value(None, \"synchronous\", |r| r.get(0)).unwrap_or(0);\n\n    let pragma_json = format!(\n        r#\"{{\n  \"journal_mode\": \"{journal_mode}\",\n  \"query_only\": {query_only},\n  \"cache_size\": {cache_size},\n  \"mmap_size\": {mmap_size},\n  \"page_size\": {page_size},\n  \"synchronous\": {synchronous}\n}}\"#\n    );\n    std::fs::write(a3_evidence_path(\"reader_pragmas.json\"), &pragma_json)\n        .expect(\"write reader_pragmas.json\");\n    eprintln!(\"A3_READER_PRAGMAS: {pragma_json}\");\n}\n","numLines":566,"startLine":1,"totalLines":566}}}
