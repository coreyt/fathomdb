.wake/
!.wake/shared/
!.wake/shared/**

# Corpus build artifacts — raw upstream downloads and produced JSONL.
# Acquisition scripts in tests/corpus/scripts/ produce these
# reproducibly; the data itself is not tracked. See
# tests/corpus/corpus-card.md for distribution + license posture.
/data/corpus-data/

.codex
# .claude/ holds SHARED harness tooling (tracked) alongside per-user/local files
# (ignored). Ignore the dir's contents by default, then un-ignore the shared
# agent defs + slash commands. settings.json / settings.local.json and any other
# local files stay ignored.
.claude/*
!.claude/agents/
!.claude/commands/
.claude/settings.local.json
.local/
target/
go/fathom-integrity/fathom-integrity
*.test
*.out
*.so
coverage.out
.coverprofile
.idea/
.vscode/
.DS_Store
__pycache__/
_site/
site/
node_modules/
typescript/node_modules/
typescript/packages/*/dist/
typescript/apps/*/dist/
.venv/
**/.venv/
dist/
**/dist/
prebuilds/
**/prebuilds/

src/ts/*.node
src/ts/index.d.ts
src/ts/index.js

# Memex-related scratch notes (not tracked).
dev/memex/

# bream cache directory
.bream-cache/

# bosun cache directory
.bosun-cache/

# Security fix M-6: Prevent accidental commit of secrets and sensitive files.
.env
.env.*
!tooling/sqlite.env
*.pem
*.key
*.p12
*.crt
credentials.*
*.swp
*.swo
*~

# Top-level recovery shim (NOT the SDK source, which is src/python/). This is a
# sourceless, recovered fathomdb binding (.pyc + .so, setuptools, pinned 0.1.0)
# that Memex installs as a uv path dependency (`../fathomdb/python`). Keep it on
# disk for Memex; ignore it here. Root-anchored so it never matches src/python/.
/python/

# 0.8.2 M1 verdict-run checkpoint sidecars (churning runtime resume-state, not deliverables)
dev/plans/runs/0.8.2-m1-verdict-*.checkpoint.json
# 0.8.3 D0a gold re-pin checkpoint sidecar (per-class augmentation resume-state)
dev/plans/runs/0.8.3-d0a-*.checkpoint.json
# 0.8.3 D0b parity-run checkpoint sidecars (runtime resume-state, not deliverables)
dev/plans/runs/0.8.3-d0b-*.checkpoint.json
# 0.8.3 rerank-tune raw CE-pass cache (per-query pools, ~6MB intermediate; the
# tune .json + FINDINGS.md are the deliverables)
dev/plans/runs/0.8.3-rerank-tune*.ce-pass.json

# 0.8.3 Slice 15a — raw codex/full-run TUI logs (verbose diff dumps; concise records committed instead)
dev/plans/runs/0.8.3-s15a-*review-*.log
dev/plans/runs/0.8.3-s15a-full-run-*.log
dev/plans/runs/0.8.3-s15a-design-consult-*.md

# eu7 bisect — raw codex review transcript (concise outcome lives in the bisect-report)
dev/plans/runs/0.8.3-eu7-bisect-doc-review-*.md
# 0.8.3 Slice 15b — raw codex review TUI logs (verbose; verdicts captured in the design review-record)
dev/plans/runs/0.8.3-s15b-*review*.log
dev/plans/runs/0.8.3-s15b-design-consult-*.log

# 0.8.3 gap-decomp — raw codex review/consult TUI dumps (verbose; durable verdicts
# live in the design doc's review-record section, not these logs)
dev/plans/runs/0.8.3-gapdecomp-*review*.log
dev/plans/runs/0.8.3-gapdecomp-*consult*.log
dev/plans/runs/0.8.4-tier1-fair-rerun.ckpt.json
dev/plans/runs/0.8.4-scale-powered-run.ckpt.json
dev/plans/runs/0.8.4-scale-d2-index.json
# 0.8.4 scale/gating runtime caches (rebuildable: answer ckpt + built D2 index)
dev/plans/runs/0.8.4-*.ckpt.json
dev/plans/runs/0.8.4-*-d2-index.json

# 0.8.9.1 baseline raw spills (regenerable; large)
dev/plans/runs/0.8.9.1-mdlint-*.txt
dev/plans/runs/0.8.9.1-prettier-*.txt

# Eval-run resume-state / raw-pool sidecars (churning runtime intermediates, not
# deliverables — the matching -output.json summaries + .md reports are tracked).
# Broad glob supersedes the per-experiment patterns above for future runs.
dev/plans/runs/*.checkpoint.json
dev/plans/runs/*.ckpt.json
dev/plans/runs/*.ce-pass.json

# Orchestrator slice-closure witness at a worktree ROOT — a transient hand-off
# artifact, never a main deliverable (a stray commit of it was caught by codex §9
# at 0.8.16 Slice 10, fix-4). Root-anchored so it does NOT match the tracked eval
# `dev/plans/runs/*-output.json` summaries above. (guardrail: fix the tooling.)
/output.json

# Agent/tool scratch cache (regenerable)
.cache/

# ledgerwatch cursor/shadow state (runtime read-cursors; the steward ledger
# .jsonl + its monotonic .seq sidecar ARE tracked, the cursor state is not).
.ledgerwatch/
dev/steward/.ledgerwatch*
dev/.ledgerwatch-todos*

# 0.8.16 Slice 10 — generated ONNX embedder eval assets (~130 MB). The
# reproducible export tooling (dev/tools/onnx/) IS tracked; the produced
# .onnx binary is NOT (default export path is ~/.cache/fathomdb/, outside the
# repo; this guards any in-repo export target too). See dev/tools/onnx/README.md.
*.onnx

