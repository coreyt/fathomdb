{
  "name": "fathomdb",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "description": "TypeScript SDK for FathomDB 0.6.0 — napi-rs binding to fathomdb-engine",
  "scripts": {
    "build:native": "napi build --platform --release --cargo-cwd ../rust/crates/fathomdb-napi --js false",
    "build:native:debug": "napi build --platform --cargo-cwd ../rust/crates/fathomdb-napi --features test-hooks --js false",
    "build": "npm run build:native && tsc -p tsconfig.json",
    "build:debug": "npm run build:native:debug && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build:debug && node --test dist/tests/*.test.js"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^25.6.0",
    "typescript": "^5.8.3"
  },
  "napi": {
    "name": "fathomdb",
    "triples": {
      "defaults": true,
      "additional": []
    }
  }
}
