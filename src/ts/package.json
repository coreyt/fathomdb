{
  "name": "fathomdb",
  "version": "0.6.1",
  "description": "TypeScript SDK for FathomDB — napi-rs binding to fathomdb-engine",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/coreyt/fathomdb"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "fathomdb.*.node"
  ],
  "scripts": {
    "build:native": "napi build --platform --release --cargo-cwd ../rust/crates/fathomdb-napi --js false",
    "build:native:debug": "napi build --platform --cargo-cwd ../rust/crates/fathomdb-napi --features test-hooks --js false",
    "build": "npm run build:native && tsc -p tsconfig.build.json",
    "build:debug": "npm run build:native:debug && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build:native:debug && tsc -p tsconfig.json && node --test dist/tests/*.test.js"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.0",
    "@types/node": "^25.6.0",
    "typescript": "^5.8.3"
  },
  "napi": {
    "name": "fathomdb",
    "triples": {
      "defaults": true,
      "additional": []
    }
  }
}
