#!/usr/bin/env bash
# pre-push: full agent-verify gate (lint -> typecheck -> test).
# Mirrors what an agent runs locally before declaring work done; catches
# CI-fail-but-local-pass drift.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# Axis W / Axis E version consistency (dev/design/release.md § Version axes).
# Runs before agent-verify so version drift surfaces with an actionable
# message even if lint/typecheck would also catch downstream symptoms.
scripts/set-version.sh --check-files

exec scripts/agent-verify.sh
