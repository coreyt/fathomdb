#!/usr/bin/env bash
# fathomdb-tracked-hook: scripts/hooks (managed by scripts/install-hooks.sh)
# pre-commit: fast format/lint checks on staged files only.
# Heavy gates (clippy, typecheck, tests) run in pre-push via agent-verify.sh.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

# --diff-filter=ACMR excludes deletions so tools don't try to read missing files.
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED" ]; then
  exit 0
fi

# Rust: cargo fmt --check (whole workspace; rustfmt is context-sensitive).
if echo "$STAGED" | grep -qE '\.rs$|Cargo\.toml$'; then
  echo "[pre-commit] cargo fmt --check"
  cargo fmt --all --check
fi

# Python: ruff check on staged .py files. Prefer .venv/bin/ruff.
if echo "$STAGED" | grep -qE '\.py$'; then
  ruff_bin=""
  if [ -x .venv/bin/ruff ]; then
    ruff_bin=".venv/bin/ruff"
  elif command -v ruff >/dev/null 2>&1; then
    ruff_bin="$(command -v ruff)"
  fi
  if [ -n "$ruff_bin" ]; then
    echo "[pre-commit] ruff check (staged)"
    # shellcheck disable=SC2086
    PYFILES=$(echo "$STAGED" | grep '\.py$' | tr '\n' ' ')
    $ruff_bin check $PYFILES
  else
    echo "[pre-commit] skipping ruff (not installed; run scripts/bootstrap.sh)"
  fi
fi

# Markdown: AST-guarded auto-fix on staged *.md, then enforce markdownlint-clean.
# scripts/md-safe-fix.sh runs `markdownlint-cli2 --fix` but reverts (and blocks) any fix that
# changes meaning — see dev/tools/md-fix-corruption-ledger.md. prettier is intentionally not used.
if echo "$STAGED" | grep -qE '\.md$'; then
  echo "[pre-commit] md-safe-fix (AST-guarded markdownlint --fix on staged .md)"
  scripts/md-safe-fix.sh
  # Enforce structural cleanliness of the staged markdown (catches non-auto-fixable findings
  # like MD040 bare fences). markdownlint-cli2 ignores file args (it globs the whole repo from
  # its config), so run it once and match its findings against the staged .md set.
  for c in ./node_modules/.bin/markdownlint-cli2 \
           /home/coreyt/projects/fathomdb/node_modules/.bin/markdownlint-cli2; do
    [ -x "$c" ] || continue
    ml_out="$("$c" 2>&1 || true)"
    bad=""
    while IFS= read -r f; do
      [ -n "$f" ] || continue
      if printf '%s\n' "$ml_out" | grep -qE "^$f:[0-9]"; then bad="$bad $f"; fi
    done < <(echo "$STAGED" | grep '\.md$')
    if [ -n "$bad" ]; then
      echo "[pre-commit] markdownlint findings in staged markdown:$bad" >&2
      echo "[pre-commit] resolve via scripts/md-safe-fix.sh (auto) or by hand, then re-stage." >&2
      exit 1
    fi
    break
  done
fi
