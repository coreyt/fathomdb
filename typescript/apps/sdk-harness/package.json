{
  "name": "@fathomdb/sdk-harness",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/app.ts --format esm",
    "harness": "tsup src/app.ts --format esm --silent && node dist/app.js",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "fathomdb": "file:../../packages/fathomdb"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
