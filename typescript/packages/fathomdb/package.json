{
  "name": "fathomdb",
  "version": "0.5.6",
  "description": "Local datastore for persistent AI agents — graph, vector, and full-text search on SQLite",
  "keywords": [
    "sqlite",
    "graph",
    "vector",
    "fts",
    "ai",
    "agent",
    "database",
    "napi"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coreyt/fathomdb.git",
    "directory": "typescript/packages/fathomdb"
  },
  "license": "MIT",
  "author": "Corey Thompson <coreyt@gmail.com>",
  "homepage": "https://github.com/coreyt/fathomdb",
  "bugs": "https://github.com/coreyt/fathomdb/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "*.node",
    "README.md"
  ],
  "napi": {
    "name": "fathomdb",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
