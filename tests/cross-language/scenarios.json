{
  "scenarios": [
    {
      "name": "canonical_node_chunk_fts",
      "writes": [
        {
          "label": "xlang-canonical",
          "nodes": [
            {
              "row_id": "01JXLANG-CANONICAL-ROW-0001",
              "logical_id": "meeting:xlang-budget",
              "kind": "Meeting",
              "properties": {"marker": "quarterlybudgetneedle", "status": "active", "title": "Q1 budget review"},
              "source_ref": "source:xlang-canonical",
              "upsert": true,
              "chunk_policy": "replace"
            }
          ],
          "chunks": [
            {
              "id": "chunk:meeting:xlang-budget:0",
              "node_logical_id": "meeting:xlang-budget",
              "text_content": "quarterlybudgetneedle and action items for finance"
            }
          ]
        }
      ],
      "queries": [
        {
          "type": "filter_logical_id",
          "kind": "Meeting",
          "logical_id": "meeting:xlang-budget",
          "expect_count": 1,
          "expect_properties": {"marker": "quarterlybudgetneedle", "status": "active", "title": "Q1 budget review"}
        },
        {
          "type": "text_search",
          "kind": "Meeting",
          "query": "quarterlybudgetneedle",
          "limit": 5,
          "expect_min_count": 1
        }
      ],
      "admin": ["check_integrity", "check_semantics"]
    },
    {
      "name": "upsert_supersession",
      "writes": [
        {
          "label": "xlang-upsert-v1",
          "nodes": [
            {
              "row_id": "01JXLANG-UPSERT-ROW-V1-001",
              "logical_id": "task:xlang-upsert",
              "kind": "Task",
              "properties": {"revision": "v1", "title": "Draft follow-up"},
              "source_ref": "source:xlang-upsert-v1",
              "upsert": false
            }
          ]
        },
        {
          "label": "xlang-upsert-v2",
          "nodes": [
            {
              "row_id": "01JXLANG-UPSERT-ROW-V2-001",
              "logical_id": "task:xlang-upsert",
              "kind": "Task",
              "properties": {"revision": "v2", "title": "Send follow-up email"},
              "source_ref": "source:xlang-upsert-v2",
              "upsert": true
            }
          ]
        }
      ],
      "queries": [
        {
          "type": "filter_logical_id",
          "kind": "Task",
          "logical_id": "task:xlang-upsert",
          "expect_count": 1,
          "expect_properties": {"revision": "v2", "title": "Send follow-up email"}
        }
      ],
      "admin": [
        "check_integrity",
        {"type": "trace_source", "source_ref": "source:xlang-upsert-v1", "expect_node_rows": 1},
        {"type": "trace_source", "source_ref": "source:xlang-upsert-v2", "expect_node_rows": 1}
      ]
    },
    {
      "name": "graph_edge_traversal",
      "writes": [
        {
          "label": "xlang-graph",
          "nodes": [
            {
              "row_id": "01JXLANG-GRAPH-ROW-A-00001",
              "logical_id": "task:xlang-a",
              "kind": "Task",
              "properties": {"title": "Prepare board packet"},
              "source_ref": "source:xlang-graph",
              "upsert": true
            },
            {
              "row_id": "01JXLANG-GRAPH-ROW-B-00001",
              "logical_id": "task:xlang-b",
              "kind": "Task",
              "properties": {"title": "Review budget appendix"},
              "source_ref": "source:xlang-graph",
              "upsert": true
            }
          ],
          "edges": [
            {
              "row_id": "01JXLANG-GRAPH-EDGE-000001",
              "logical_id": "edge:xlang-a-depends-b",
              "source_logical_id": "task:xlang-a",
              "target_logical_id": "task:xlang-b",
              "kind": "DEPENDS_ON",
              "properties": {},
              "source_ref": "source:xlang-graph",
              "upsert": true
            }
          ]
        }
      ],
      "queries": [
        {
          "type": "traverse",
          "kind": "Task",
          "start_logical_id": "task:xlang-a",
          "direction": "out",
          "label": "DEPENDS_ON",
          "max_depth": 1,
          "expect_includes": ["task:xlang-b"]
        }
      ],
      "admin": ["check_integrity", "check_semantics"]
    },
    {
      "name": "runtime_tables",
      "writes": [
        {
          "label": "xlang-runtime",
          "nodes": [
            {
              "row_id": "01JXLANG-RUNTIME-NODE-0001",
              "logical_id": "document:xlang-runtime",
              "kind": "Document",
              "properties": {"status": "ready", "title": "Planner output"},
              "source_ref": "source:xlang-runtime",
              "upsert": true
            }
          ],
          "runs": [
            {
              "id": "run:xlang-planner-001",
              "kind": "PlannerRun",
              "status": "succeeded",
              "properties": {"agent": "planner", "revision": 1},
              "source_ref": "source:xlang-runtime",
              "upsert": false
            }
          ],
          "steps": [
            {
              "id": "step:xlang-planner-001:1",
              "run_id": "run:xlang-planner-001",
              "kind": "ToolStep",
              "status": "succeeded",
              "properties": {"name": "fetch-calendar"},
              "source_ref": "source:xlang-runtime",
              "upsert": false
            }
          ],
          "actions": [
            {
              "id": "action:xlang-planner-001:tool-1",
              "step_id": "step:xlang-planner-001:1",
              "kind": "ToolCall",
              "status": "succeeded",
              "properties": {"tool": "calendar.lookup"},
              "source_ref": "source:xlang-runtime",
              "upsert": false
            }
          ]
        }
      ],
      "queries": [
        {
          "type": "filter_logical_id",
          "kind": "Document",
          "logical_id": "document:xlang-runtime",
          "expect_count": 1,
          "expect_properties": {"status": "ready", "title": "Planner output"},
          "expect_runs": true,
          "expect_steps": true,
          "expect_actions": true
        }
      ],
      "admin": [
        {"type": "trace_source", "source_ref": "source:xlang-runtime", "expect_node_rows": 1, "expect_action_rows": 1}
      ]
    },
    {
      "name": "node_retire",
      "writes": [
        {
          "label": "xlang-retire-seed",
          "nodes": [
            {
              "row_id": "01JXLANG-RETIRE-ROW-000001",
              "logical_id": "task:xlang-retired",
              "kind": "Task",
              "properties": {"title": "Will be retired"},
              "source_ref": "source:xlang-retire",
              "upsert": false
            }
          ]
        },
        {
          "label": "xlang-retire-action",
          "node_retires": [
            {
              "logical_id": "task:xlang-retired",
              "source_ref": "source:xlang-retire"
            }
          ]
        }
      ],
      "queries": [
        {
          "type": "filter_logical_id",
          "kind": "Task",
          "logical_id": "task:xlang-retired",
          "expect_count": 0
        }
      ],
      "admin": ["check_integrity"]
    },
    {
      "name": "json_property_types",
      "writes": [
        {
          "label": "xlang-json-types",
          "nodes": [
            {
              "row_id": "01JXLANG-JSON-TYPE-ROW-001",
              "logical_id": "typetest:xlang-json",
              "kind": "TypeTest",
              "properties": {
                "string_val": "hello world",
                "int_val": 42,
                "float_val": 3.14,
                "bool_true": true,
                "bool_false": false,
                "null_val": null,
                "array_val": [1, "two", true, null],
                "nested": {"inner_key": "inner_value", "inner_num": 99},
                "empty_object": {},
                "empty_array": [],
                "unicode": "café ☕ 日本語"
              },
              "source_ref": "source:xlang-json-types",
              "upsert": true
            }
          ]
        }
      ],
      "queries": [
        {
          "type": "filter_logical_id",
          "kind": "TypeTest",
          "logical_id": "typetest:xlang-json",
          "expect_count": 1,
          "expect_properties": {
            "string_val": "hello world",
            "int_val": 42,
            "float_val": 3.14,
            "bool_true": true,
            "bool_false": false,
            "null_val": null,
            "array_val": [1, "two", true, null],
            "nested": {"inner_key": "inner_value", "inner_num": 99},
            "empty_object": {},
            "empty_array": [],
            "unicode": "café ☕ 日本語"
          }
        }
      ],
      "admin": ["check_integrity"]
    },
    {
      "name": "external_content_objects",
      "writes": [
        {
          "label": "xlang-ext-content",
          "nodes": [
            {
              "row_id": "01JXLANG-EXT-ROW-0001",
              "logical_id": "doc:xlang-ext-report",
              "kind": "Document",
              "properties": {"title": "External Report"},
              "source_ref": "source:xlang-ext",
              "upsert": false,
              "chunk_policy": "preserve",
              "content_ref": "s3://docs/xlang-report.pdf"
            },
            {
              "row_id": "01JXLANG-EXT-ROW-0002",
              "logical_id": "doc:xlang-plain-note",
              "kind": "Document",
              "properties": {"title": "Plain Note"},
              "source_ref": "source:xlang-ext",
              "upsert": false,
              "chunk_policy": "preserve"
            }
          ],
          "chunks": [
            {
              "id": "chunk:xlang-ext-report:0",
              "node_logical_id": "doc:xlang-ext-report",
              "text_content": "externalcontentneedle revenue analysis",
              "content_hash": "sha256:xlang-ext-hash"
            },
            {
              "id": "chunk:xlang-plain-note:0",
              "node_logical_id": "doc:xlang-plain-note",
              "text_content": "externalcontentneedle meeting notes"
            }
          ]
        }
      ],
      "queries": [
        {
          "type": "filter_logical_id",
          "kind": "Document",
          "logical_id": "doc:xlang-ext-report",
          "expect_count": 1,
          "expect_properties": {"title": "External Report"}
        },
        {
          "type": "filter_content_ref_not_null",
          "kind": "Document",
          "limit": 10,
          "expect_count": 1,
          "expect_found_ids": ["doc:xlang-ext-report"]
        },
        {
          "type": "text_search",
          "kind": "Document",
          "query": "externalcontentneedle",
          "limit": 10,
          "expect_min_count": 2
        }
      ],
      "admin": ["check_integrity"]
    },
    {
      "name": "property_fts_projection",
      "writes": [
        {
          "label": "xlang-property-fts",
          "nodes": [
            {
              "row_id": "01JXLANG-PROPFTS-ROW-00001",
              "logical_id": "goal:xlang-ship-v2",
              "kind": "Goal",
              "properties": {"name": "propertyftsneedle Ship v2", "description": "Launch the redesign"},
              "source_ref": "source:xlang-property-fts",
              "upsert": true
            }
          ]
        }
      ],
      "queries": [
        {
          "type": "text_search",
          "kind": "Goal",
          "query": "propertyftsneedle",
          "limit": 5,
          "expect_min_count": 1
        }
      ],
      "admin": [
        "check_integrity",
        "check_semantics",
        {
          "type": "describe_fts_property_schema",
          "kind": "Goal",
          "expect_property_paths": ["$.name", "$.description"]
        },
        {
          "type": "list_fts_property_schemas",
          "expect_min_count": 1
        }
      ]
    }
  ],
  "setup_admin": [
    {
      "type": "register_fts_property_schema",
      "kind": "Goal",
      "property_paths": ["$.name", "$.description"],
      "separator": " "
    }
  ]
}
